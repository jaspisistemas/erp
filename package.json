{
  "name": "template-erp",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "packages/shared"
  ],
  "scripts": {
    "install": "npm install backend && npm install frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w packages/shared && npm run build -w backend && npm run build -w frontend"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "concurrently": "^8.2.2",
    "dotenv": "^17.3.1"
  },
  "dependencies": {
    "backend": "^0.0.1",
    "frontend": "^0.0.0"
  }
}
