      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&JurCod);

NoAccept(JurCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
JurCod = &JurCod if not &JurCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Jur Ant Ano')) if JurAntAno.IsEmpty();
Error(Format('WWP_RequiredAttribute','Jur Ant Mes')) if JurAntMes.IsEmpty();
Error(Format('WWP_RequiredAttribute','Juros Ano')) if JurAno.IsEmpty();
Error(Format('WWP_RequiredAttribute','Juros Mês')) if JurMes.IsEmpty();
Error(Format('WWP_RequiredAttribute','Juros Nome')) if JurNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */



UltimoCodigoEmpresa.Call(domParCod.JURO, &Context.EmpCod, 0,JurCod) If insert and JurCod.IsEmpty() on AfterValidate;


Error('Ano Juros Informado inválido!') 
	if JurAno < 1990;
Error('Ano Antecipação Informado inválido!') 
	if JurAntAno < 1990;

]]></Source>
