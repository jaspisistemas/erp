      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		RetornaAutorizacao.Call('WWJURO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		RetornaAutorizacao.Call('WWJURO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF
	gridLevel_JuroMensal.Rows = 2
	gridLevel_JuroAntecipacao.Rows = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'JURO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&JurCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Juro.Call(&EmpCod, &JurCod, &SdtLogAtributos)
		
		prcCarregaLog_JuroMensal.Call(&EmpCod, &JurCod, &JuroMensal_SdtLogAtributosLevel)
		prcCarregaLog_JuroAntecipacao.Call(&EmpCod, &JurCod, &JuroAntecipacao_SdtLogAtributosLevel)
	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_juro.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, JurCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
		
		prcGravaLog_juroMensal.Call(&Context.EmpCod, &Context.FilCod, JurCod, &Pgmname, &Context.UserName, &JuroMensal_SdtLogAtributosLevel)
		prcGravaLog_juroAntecipacao.Call(&Context.EmpCod, &Context.FilCod, JurCod, &Pgmname, &Context.UserName, &JuroAntecipacao_SdtLogAtributosLevel)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
