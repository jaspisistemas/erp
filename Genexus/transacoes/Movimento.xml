        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWSALDO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWSALDO', Status_SimNao.Sim, 2, &AutNiv)
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated MovCtaBanCod
				Case &TrnContextAtt.AttributeName = !"MovCtaBanCod"
					&Insert_MovCtaBanCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	MovHor.Visible = False
	MovCtaBanFilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
