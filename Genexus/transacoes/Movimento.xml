        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&MovCod);

NoAccept(MovCreCod);
NoAccept(MovCreFilCod);
NoAccept(MovCrePagCod);
NoAccept(MovFunCod);
NoAccept(MovCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
MovCod = &MovCod if not &MovCod.IsEmpty();

MovCtaBanCod = &Insert_MovCtaBanCod if &Mode = TrnMode.Insert and not &Insert_MovCtaBanCod.IsEmpty();
noaccept(MovCtaBanCod) if &Mode = TrnMode.Insert and not &Insert_MovCtaBanCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Movimento Item Moeda')) if MovItmVlr.IsEmpty();
Error(Format('WWP_RequiredAttribute','Movimento Data')) if MovDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Movimento Conta Bancária')) if MovCtaBanCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Movimento Documento')) if MovDoc.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
]]></Source>
