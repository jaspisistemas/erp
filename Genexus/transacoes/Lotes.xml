      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&LotCod);

NoAccept(LotCod);
NoAccept(LotSts);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
LotCod = &LotCod if not &LotCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Filial')) if LotFilCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nro Lote')) if LotNro.IsEmpty();
Error(Format('WWP_RequiredAttribute','Peso Inicial')) if LotIniKgs.IsEmpty();
Error(Format('WWP_RequiredAttribute','Quantidade')) if LotQtdIni.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
Default(LotSts,Status_lote.AguardandoAlojamento);
Default(LotIsNew,False);
UltimoCodigoEmpresa.Call(domParCod.lote,EmpCod,0,LotCod)If insert;
]]></Source>
