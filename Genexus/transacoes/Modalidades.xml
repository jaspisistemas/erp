      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do Case
		CAse &Mode = TrnMode.Delete
			RetornaAutorizacao.Call('WWMODALIDADE', Status_SimNao.Sim, 3, &AutNiv)
		Case &Mode = TrnMode.Update
			gridLevel_MdlItm.Rows = 2
			RetornaAutorizacao.Call('WWMODALIDADE', Status_SimNao.Sim, 2, &AutNiv)
		Otherwise
			RetornaAutorizacao.Call('WWMODALIDADE', Status_SimNao.Sim, 2, &AutNiv)
			gridLevel_MdlItm.Rows = 5
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	MdpBlq.TooltipText = "Caso marcado os produtos não podem receber grades manualmente."
	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWModalidades.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
