      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&MdpCod);

NoAccept(MdpItmCod);
NoAccept(EmpCod);
NoAccept(MdpCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
MdpCod = &MdpCod if not &MdpCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Ordem')) if MdpItmOrd.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nome Grade')) if MdpItmNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Modalidade')) if MdpNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Error('Ordem deve ser maior que "1" obrigatório.') if MdpItmOrd <= 1;

Serial(MdpItmCod, MdpUltItmCod, 1);

default(MdpSts, Status_AtivoInativo.ATIVO);
default(MdpItmSts, Status_AtivoInativo.ATIVO);
default(MdpBlq, true);

UltimoCodigoEmpresa.Call(domParCod.MODALIDADE, EmpCod, 0, MdpCod)
	If insert and MdpCod.IsEmpty() 
	on AfterValidate;
]]></Source>
