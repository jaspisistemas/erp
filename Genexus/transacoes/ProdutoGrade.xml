      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	
	EmpCod.Visible = False
	&ProRef.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	ProGraNom.SetFocus()

EndEvent

Event After Trn

	if ProGraBar.IsEmpty()
		if ProTipDef <> Definicao.SERVICO
			GeraEANprodutoGrade.Call(EmpCod, ProCod, ProGraCod)
		Else
			GeraEANservicoGrade.Call(EmpCod, ProCod, ProGraCod)
		EndIF
	EndIF

	GeraCodigoReferencia.Call(EmpCod, ProCod, ProGraCod, ProGraRef, &Context.FilCod, &Context.UserName)

	GravaAtualizaGrade.Call(EmpCod, ProCod)
	
	If &Mode = TrnMode.Insert
		iniciaEstoque.Call(&Context.EmpCod, &Context.FilCod, ProCod, ProGraCod)
	EndiF

	//adicionarPrecoProduto.Call('Produto', &Context.EmpCod, &Context.FilCod, ProCod, 0, &Context.PesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
