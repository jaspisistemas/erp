      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&ProCod, in:&ProGraCod);

NoAccept(EmpCod);
NoAccept(ProCod);
NoAccept(ProGraCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
ProCod = &ProCod if not &ProCod.IsEmpty();
ProGraCod = &ProGraCod if not &ProGraCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Descrição')) if ProGraNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(ProGraSts, Status_AtivoInativo.ATIVO);

//LOCALIZA UM DISPONIVEL
RetornaUltimoCodigoGrade.Call(EmpCod, ProCod, ProGraCod)
	If insert and ProGraCod.IsEmpty() 
	on AfterValidate;

//## Referencia Repetido
ValidaCodigoReferenciaRepetido.Call(EmpCod, ProCod, ProGraCod, ProGraRef, &RepetidoReferenciaMensagem) 
	if After(ProGraRef) and not ProGraRef.IsEmpty();

//## Grade Repetido
ValidaNomeGradeRepetida.Call(EmpCod, ProCod, ProGraCod, ProGraNom, &RepetidoNomeMensagem) 
	if After(ProGraNom) and not ProGraNom.IsEmpty();

error(&RepetidoReferenciaMensagem)
	if (not &RepetidoReferenciaMensagem.IsEmpty()) and (not ProGraRef.IsEmpty()) and after(ProGraRef);

error(&RepetidoNomeMensagem)
	if (not &RepetidoNomeMensagem.IsEmpty()) and (not ProGraNom.IsEmpty()) and after(ProGraNom);

ProGraRef = prcContatenaProRefNom.Udp(ProRef, ProGraNom)
	if ProGraRef.IsEmpty() and After(ProGraNom);

//## EAN 13
ValidaCodigoReferenciaRepetido.Call(EmpCod,ProCod, ProGraCod, ProGraBar, &RepetidoEanMensagem) 
	if After(ProGraBar) and not ProGraBar.IsEmpty();

error(&RepetidoEanMensagem) 
	if (not &RepetidoEanMensagem.IsEmpty()) and (not ProGraBar.IsEmpty()) and after(ProGraBar);

ValidaEan13.Call(ProCod, ProGraBar, &ProBar, &ErroEan13Mensagem) 
	if after(ProGraBar);// and (not ProBar.IsEmpty());

msg(&ErroEan13Mensagem) 
	if not &ErroEan13Mensagem.IsEmpty() and &RepetidoEanMensagem.IsEmpty() and (not ProGraBar.IsEmpty()) and after(ProGraBar);
]]></Source>
