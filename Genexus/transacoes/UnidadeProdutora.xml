      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWUNIDADEPRODUTORA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWUNIDADEPRODUTORA', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False
	UniProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PesCod = &Context.PesCod

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWUnidadeProdutora.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UniProRenAgu.Visible = False
	UniProRenAgu_Cell.Class = !'Invisible'
	UniProTmpAbs.Visible = False
	UniProTmpAbs_Cell.Class = !'Invisible'
	UniProProMed.Visible = False
	UniProProMed_Cell.Class = !'Invisible'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
