        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&UniProCod);

NoAccept(UniProCod);
NoAccept(UniProSts);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
UniProCod = &UniProCod if not &UniProCod.IsEmpty();

UniProRenAgu.Visible = UniProTip <> tipoUnidadeProdutora.TanqueRede;
UniProRenAgu_Cell.Class = !'Invisible' If not(UniProTip <> tipoUnidadeProdutora.TanqueRede);
UniProRenAgu_Cell.Class = !'col-xs-12 DataContentCell' If UniProTip <> tipoUnidadeProdutora.TanqueRede;
UniProTmpAbs.Visible = UniProTip <> tipoUnidadeProdutora.TanqueRede;
UniProTmpAbs_Cell.Class = !'Invisible' If not(UniProTip <> tipoUnidadeProdutora.TanqueRede);
UniProTmpAbs_Cell.Class = !'col-xs-12 DataContentCell' If UniProTip <> tipoUnidadeProdutora.TanqueRede;
UniProProMed.Visible = UniProTip <> tipoUnidadeProdutora.TanqueRede;
UniProProMed_Cell.Class = !'Invisible' If not(UniProTip <> tipoUnidadeProdutora.TanqueRede);
UniProProMed_Cell.Class = !'col-xs-12 DataContentCell' If UniProTip <> tipoUnidadeProdutora.TanqueRede;
Error(Format('WWP_RequiredAttribute','Filial')) if UniProFilCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Descrição')) if UniProNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Quantidade')) if UniProQtd.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(UniProSts,StatusUnidadeProdutora.Disponivel);

UltimoCodigoEmpresa.Call(domParCod.UNIDADEPRODUTORA,EmpCod,0,UniProCod)If insert;
]]></Source>
