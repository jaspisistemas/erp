        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&AreCod);

NoAccept(AreCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
AreCod = &AreCod if not &AreCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Área Nome')) if AreNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(EmpCod, &Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.AREA, &Context.EmpCod, 0, AreCod)If insert and AreCod.IsEmpty() on AfterValidate;
