        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		RetornaAutorizacao.Call('WWAREA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		RetornaAutorizacao.Call('WWAREA', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'AREA')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&AreCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Area.Call(&EmpCod, &AreCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_Area.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, AreCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
