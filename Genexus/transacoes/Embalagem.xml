      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&EmbCod);

NoAccept(EmbCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
EmbCod = &EmbCod if not &EmbCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Embalagem')) if EmbNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Quantidade')) if EmbQtd.IsEmpty();
Error(Format('WWP_RequiredAttribute','Und.')) if EmbUnd.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(EmpCod,&Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.EMBALAGEM, &Context.EmpCod, 0, EmbCod)
	If insert and EmbCod.IsEmpty() 
	on AfterValidate;


ValidaEmbalagemUnica.Call(EmpCod, EmbCod, EmbNom, &Mensagem) 
	if After(EmbNom);

error(&Mensagem) 
	if After(EmbNom) and not &Mensagem.IsEmpty() and (insert or update);
]]></Source>
