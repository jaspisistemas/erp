      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWEMBALAGEM', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWEMBALAGEM', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'EMBALAGEM')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&EmbCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Embalagem.Call(&EmpCod, &EmbCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	if &Mode <> TrnMode.Delete
		PrcAtualizaEmbalagemProduto.Call(EmpCod, EmbCod)
	EndIf

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_Embalagem.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, EmbCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	If Old(EmbQtd) <> EmbQtd 
		ProVlrCus_Embalagem.Call(EmpCod, EmbCod)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
