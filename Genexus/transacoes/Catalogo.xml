        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CtlCod);

NoAccept(CtlCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
CtlCod = &CtlCod if not &CtlCod.IsEmpty();

TabCod = &Insert_TabCod if &Mode = TrnMode.Insert and not &Insert_TabCod.IsEmpty();
noaccept(TabCod) if &Mode = TrnMode.Insert and not &Insert_TabCod.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
Prompt(PromptTabelaPreco, &Context.EmpCod, TabCod, &parTabDtaIni, &parmTabSts, TabCod);
UltimoCodigoEmpresa.Call(domParCod.CATALOGO, &Context.EmpCod, 0, CtlCod)If insert and CtlCod.IsEmpty() on AfterValidate;
]]></Source>
