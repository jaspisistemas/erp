      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		RetornaAutorizacao.Call('WWCATALOGO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		RetornaAutorizacao.Call('WWCATALOGO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated TabCod
				Case &TrnContextAtt.AttributeName = !"TabCod"
					&Insert_TabCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	&parTabDtaIni.Visible = False
	&parmTabSts.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
