      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWPLANOCONTA', Status_SimNao.Sim, 3, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False
	PlanCod.Visible = False
	PlanNomCmp.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'PLANOCONTAS')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&PlanCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_PlanoContas.Call(&EmpCod, &PlanCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_PlanoContas.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, &PlanCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWPlanoContas.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
