        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&PlanCod);

NoAccept(EmpCod);
NoAccept(PlanCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
PlanCod = &PlanCod if not &PlanCod.IsEmpty();

Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

VerificaFilhoPlanoContas.Call(EmpCod, PlanCod, PlanHie, PlanCod, &IsExiste) 
	if &Mode = TrnMode.Delete on AfterValidate;

Error('Não é Possivel eliminar registro, o mesmo possui filhos relacionados!') 
	if &Mode = TrnMode.Delete and &IsExiste = true on AfterValidate;
]]></Source>
