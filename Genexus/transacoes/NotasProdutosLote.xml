      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&NfeCod, in:&NfeItmCod);

NoAccept(NfeProDadAdi);
NoAccept(NfeProQtd);
NoAccept(NfeProNom);
NoAccept(NfeProGraRef);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
noaccept(FilCod) if not &FilCod.IsEmpty();
NfeCod = &NfeCod if not &NfeCod.IsEmpty();
noaccept(NfeCod) if not &NfeCod.IsEmpty();
NfeItmCod = &NfeItmCod if not &NfeItmCod.IsEmpty();
noaccept(NfeItmCod) if not &NfeItmCod.IsEmpty();

Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */



prompt(promptEstoqueProdutoLote, EmpCod, FilCod, NfeProCod, NfeProGraCod, NfeProLotCod);

Error('Informada data de validade menor que a Data de Fabricação') 
	if NfeProLotVct < NfeProLotFab and not NfeProLotVct.IsEmpty();
]]></Source>
