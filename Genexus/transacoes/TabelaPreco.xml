        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&TabCod);

Prompt(PromptArea, EmpCod, TabAreCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
TabCod = &TabCod if not &TabCod.IsEmpty();
noaccept(TabCod) if not &TabCod.IsEmpty();

TabDtaBasVct.Visible = TabAnt > 0;
TabDtaBasVct_Cell.Class = !'Invisible' If not(TabAnt > 0);
TabDtaBasVct_Cell.Class = !'DscTop' If TabAnt > 0;
tbAntecipacao.Visible = (&AGRO_INSUMOS = 'S'  or TabAcre > 0 or TabAnt > 0);
DVPanel_FilialTabela_Cell.Class = !'Invisible' If not(TabIsAllFil = false);
DVPanel_FilialTabela_Cell.Class = !'col-xs-12' If TabIsAllFil = false;
DVPanel_UFTabela_Cell.Class = !'Invisible' If not(TabIsAllUfe = false);
DVPanel_UFTabela_Cell.Class = !'col-xs-12' If TabIsAllUfe = false;
DVPanel_AreasTabela_Cell.Class = !'Invisible' If not(TabIsAllAre = false);
DVPanel_AreasTabela_Cell.Class = !'col-xs-12' If TabIsAllAre = false;
Error(Format('WWP_RequiredAttribute','Filial')) if TabFilCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Estado')) if TabUfeCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Area')) if TabAreCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Coluna')) if TabColCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tabela')) if TabCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tabela Status')) if TabSts.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tabela Descrição')) if TabNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tabela Data Inicial')) if TabDtaIni.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tabela Data Final')) if TabDtaFin.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


//TabDtaBasVct.SetEmpty()
//	if TabAnt <= 0;

Default(EmpCod,&Context.EmpCod);
Default(TabUltAlt, 1);
Default(TabIsAllFil, true);
Default(TabIsAllAre, true);
Default(TabIsAllUfe, true);
Default(TabIsPerCol1, true);
Default(TabDtaIni, serverdate());

Error('Menor Coluna Aceitavel Código 1. Maior Coluna Aceitável código 9!') 
	if TabColCod > 9 or TabColCod < 1;


