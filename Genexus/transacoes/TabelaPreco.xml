      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWTABELAPRECO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWTABELAPRECO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF
	
	GridLevel_Areas.Rows = 2
	gridLevel_Colunas.Rows = 2
	gridLevel_Estados.Rows = 2
	gridLevel_Filial.Rows = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	TabIsPerCol1.TooltipText = "Marcando essa opção o Sistema vai calcular o valor das colunas utilizando valor Base Coluna 1."
	TabRecCol.TooltipText = "Ao trocar o Valor da Coluna 1 Automaticamente o Sistema Recalcula o valor para as Outras colunas."
	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	&AGRO_INSUMOS.Visible = False
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	retornaEmpresaModulo.Call(&Context.EmpCod, ModuloSistema.AGRO_INSUMOS, &AGRO_INSUMOS)
	
	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'TABELAPRECO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&TabCod.IsEmpty(), Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_TabelaPreco.Call(&EmpCod, &TabCod, &SdtLogAtributos)
		prcCarregaLog_TabelaPrecoAreas.Call(&EmpCod, &TabCod, &AreasSdtLogAtributosLevel)
		prcCarregaLog_TabelaPrecoColunas.Call(&EmpCod, &TabCod, &ColunasSdtLogAtributosLevel)
		prcCarregaLog_TabelaPrecoFilial.Call(&EmpCod, &TabCod, &FilialSdtLogAtributosLevel)
		prcCarregaLog_TabelaPrecoUfe.Call(&EmpCod, &TabCod, &UfeSdtLogAtributosLevel)
	Endif

EndEvent

Event After Trn

	AtualizaColunasNomes.Call(EmpCod, TabCod)

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_TabelaPreco.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, TabCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
		prcGravaLog_TabelaPrecoAreas.Call(&Context.EmpCod, &Context.FilCod, TabCod, &Pgmname, &Context.UserName, &AreasSdtLogAtributosLevel)		
		prcGravaLog_TabelaPrecoColunas.Call(&Context.EmpCod, &Context.FilCod, TabCod, &Pgmname, &Context.UserName, &ColunasSdtLogAtributosLevel)
		prcGravaLog_TabelaPrecoFilial.Call(&Context.EmpCod, &Context.FilCod, TabCod, &Pgmname, &Context.UserName, &FilialSdtLogAtributosLevel)
		prcGravaLog_TabelaPrecoUfe.Call(&Context.EmpCod, &Context.FilCod, TabCod, &Pgmname, &Context.UserName, &UfeSdtLogAtributosLevel)
	Endif
	
	WWTabelaPreco.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWTabelaPreco.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dofechar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWTabelaPreco.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TabDtaBasVct.Visible = False
	TabDtaBasVct_Cell.Class = !'Invisible'
	
	DVPanel_FilialTabela_Cell.Class = !'col-xs-12'
	DVPanel_UFTabela_Cell.Class = !'col-xs-12'
	DVPanel_AreasTabela_Cell.Class = !'col-xs-12'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event TabAnt.IsValid

	If TabAnt <= 0
		TabDtaBasVct.SetEmpty()
	EndIf

EndEvent


]]></Source>
