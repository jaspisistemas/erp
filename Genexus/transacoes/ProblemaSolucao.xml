	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_ProblemaSolucao.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, PblCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

