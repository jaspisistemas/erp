	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'PROBLEMASOLUCAO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&PblCod = 0, Trnmode.Insert, Trnmode.Update))
