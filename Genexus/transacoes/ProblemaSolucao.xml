        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&PblCod);

NoAccept(PblCod);
NoAccept(PblSts);
NoAccept(PblFilCod);
NoAccept(PblUsrCod);
NoAccept(PblUsrResCod);
NoAccept(PblUsrResNom);
NoAccept(PblDtaFin);
NoAccept(PblHorFin);
NoAccept(PblObsFin);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
PblCod = &PblCod if not &PblCod.IsEmpty();
PblUsrResCod.Visible = PblSts = Status_Problema.Solucionado;
PblUsrResCod_Cell.Class = !'Invisible' If not(PblSts = Status_Problema.Solucionado);
PblUsrResCod_Cell.Class = !'MergeDataCell' If PblSts = Status_Problema.Solucionado;
TextBlockPblUsrResCod_Cell.Class = !'Invisible' If not(PblSts = Status_Problema.Solucionado);
TextBlockPblUsrResCod_Cell.Class = !'col-sm-3 MergeLabelCell' If PblSts = Status_Problema.Solucionado;
PblUsrResNom.Visible = PblSts = Status_Problema.Solucionado;
PblUsrResNom_Cell.Class = !'Invisible' If not(PblSts = Status_Problema.Solucionado);
PblUsrResNom_Cell.Class = !'DataContentCell' If PblSts = Status_Problema.Solucionado;
PblDtaFin.Visible = PblSts = Status_Problema.Solucionado;
PblDtaFin_Cell.Class = !'Invisible' If not(PblSts = Status_Problema.Solucionado);
PblDtaFin_Cell.Class = !'MergeDataCell' If PblSts = Status_Problema.Solucionado;
TextBlockPblDtaFin_Cell.Class = !'Invisible' If not(PblSts = Status_Problema.Solucionado);
TextBlockPblDtaFin_Cell.Class = !'col-sm-3 MergeLabelCell' If PblSts = Status_Problema.Solucionado;
PblHorFin.Visible = PblSts = Status_Problema.Solucionado;
PblHorFin_Cell.Class = !'Invisible' If not(PblSts = Status_Problema.Solucionado);
PblHorFin_Cell.Class = !'DataContentCell' If PblSts = Status_Problema.Solucionado;
PblObsFin.Visible = PblSts = Status_Problema.Solucionado;
PblObsFin_Cell.Class = !'Invisible' If not(PblSts = Status_Problema.Solucionado);
PblObsFin_Cell.Class = !'col-xs-12 DataContentCell' If PblSts = Status_Problema.Solucionado;
Error(Format('WWP_RequiredAttribute','Pedido')) if PblPedCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data')) if PblDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tipo')) if PblTipo.IsEmpty();
Error(Format('WWP_RequiredAttribute','Obs')) if PblObs.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
Default(EmpCod, &Context.EmpCod);


UltimoCodigoEmpresa.Call(domParCod.PROBLEMAS, &Context.EmpCod, 0, PblCod)
	If insert and PblCod.IsEmpty() 
	on AfterValidate;

Default(PblDta,ServerDate());
Default(PblHor,ServerTime());
Default(PblUsrCod,&Context.PesCod);
Default(PblFilCod,&Context.FilCod);

NoAccept(PblPedCod, PblObs, PblTipo, PblDta, PblHor) 
	if PblSts <> status_Problema.Pendente and &AutNiv < 3;


ValidaPedidoProblema.call(EmpCod,PblFilCod,PblPedCod, &PedCliCodRaz, &PedVlrLiq, &Mensagem) 
	If not PblPedCod.IsEmpty() and after(PblPedCod);

error(&Mensagem) 
	if not &Mensagem.IsEmpty() and after(PblPedCod);


formataHORA.Call(PblHor, PblHor);

]]></Source>
