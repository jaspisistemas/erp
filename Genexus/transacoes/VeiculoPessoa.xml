        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&VeiCod, in:&PesCod);

NoAccept(EmpCod);
Prompt(promptFuncionariosCPF, EmpCod, PesCod, &InOutPesCnpj);
Prompt(PromptVeiculos, EmpCod, VeiCod, VeiPla);
