        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&PrdCod);

NoAccept(FilCod);
NoAccept(PrdCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
PrdCod = &PrdCod if not &PrdCod.IsEmpty();

PrdFunCod = &Insert_PrdFunCod if &Mode = TrnMode.Insert and not &Insert_PrdFunCod.IsEmpty();
noaccept(PrdFunCod) if &Mode = TrnMode.Insert and not &Insert_PrdFunCod.IsEmpty();
BtnTrn_Enter.Visible = True If (1 = 2);
BtnTrn_Enter.Visible = False If Not (1 = 2);
Error(Format('WWP_RequiredAttribute','Data Entrada')) if PrdDtaEnt.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
]]></Source>
