        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&SetCod);

NoAccept(SetCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
SetCod = &SetCod if not &SetCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Setor Nome')) if SetNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

tbSetorPrdMax.Visible = &Modulo_IND_E = 'S';

Default(EmpCod, &Context.EmpCod);

UltimoCodigoEmpresa.Call(domParCod.SETOR, EmpCod, 0, SetCod)
	If insert and SetCod.IsEmpty() 
	on AfterValidate;
]]></Source>
