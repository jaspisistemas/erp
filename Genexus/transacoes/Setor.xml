      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWSETOR', Status_SimNao.Sim, iif(&Mode = TrnMode.Delete, 3, 2), &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	SetPrzEst.TooltipText = "Manter Estoque para X dias."
	SetTaxMo.TooltipText = "% de Custos de Mão de Obra."
	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Modulo_IND_E = RetornaEmpresaModulo.Udp(&Context.EmpCod, ModuloSistema.IND_E)

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'SETOR')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&SetCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Setor.Call(&EmpCod, &SetCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	If &Mode <> TrnMode.Delete
		prcAtualizaSetor.Call(EmpCod, SetCod)
	EndIf
	
	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_Setor.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, SetCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
