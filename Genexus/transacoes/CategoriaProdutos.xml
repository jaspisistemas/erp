EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
GrupCod = &GrupCod if not &GrupCod.IsEmpty();
noaccept(GrupCod) if not &GrupCod.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
GrupoProdutoPossuiFilho.Call(EmpCod, GrupCod, GrupHie, &IsExiste) 
	if &Mode = TrnMode.Delete on AfterValidate;


Error('Não é Possivel eliminar registro, o mesmo possui filhos relacionados!') 
	if &Mode = TrnMode.Delete and &IsExiste = true on AfterValidate;

