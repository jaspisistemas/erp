        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated TalCod
				Case &TrnContextAtt.AttributeName = !"TalCod"
					&Insert_TalCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated TalCtabanCod
				Case &TrnContextAtt.AttributeName = !"TalCtabanCod"
					&Insert_TalCtabanCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated CheBanCod
				Case &TrnContextAtt.AttributeName = !"CheBanCod"
					&Insert_CheBanCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated CheCreCliCod
				Case &TrnContextAtt.AttributeName = !"CheCreCliCod"
					&Insert_CheCreCliCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWCheque.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CheCmc.Visible = False
	CheCmc_Cell.Class = !'Invisible'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
