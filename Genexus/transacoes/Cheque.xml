        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CheCod);

NoAccept(EmpCod);
NoAccept(CheCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
CheCod = &CheCod if not &CheCod.IsEmpty();

TalCod = &Insert_TalCod if &Mode = TrnMode.Insert and not &Insert_TalCod.IsEmpty();
noaccept(TalCod) if &Mode = TrnMode.Insert and not &Insert_TalCod.IsEmpty();
TalCtabanCod = &Insert_TalCtabanCod if &Mode = TrnMode.Insert and not &Insert_TalCtabanCod.IsEmpty();
noaccept(TalCtabanCod) if &Mode = TrnMode.Insert and not &Insert_TalCtabanCod.IsEmpty();
CheBanCod = &Insert_CheBanCod if &Mode = TrnMode.Insert and not &Insert_CheBanCod.IsEmpty();
noaccept(CheBanCod) if &Mode = TrnMode.Insert and not &Insert_CheBanCod.IsEmpty();
CheCreCliCod = &Insert_CheCreCliCod if &Mode = TrnMode.Insert and not &Insert_CheCreCliCod.IsEmpty();
noaccept(CheCreCliCod) if &Mode = TrnMode.Insert and not &Insert_CheCreCliCod.IsEmpty();
CheCmc.Visible = CheTip = 'T';
CheCmc_Cell.Class = !'Invisible' If not(CheTip = 'T');
CheCmc_Cell.Class = !'col-xs-12 col-sm-6 DataContentCell' If CheTip = 'T';
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
]]></Source>
