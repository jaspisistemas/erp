        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&VeiMarCod, In:&DefaultVeiMarNom);

NoAccept(EmpCod);
NoAccept(VeiMarCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
VeiMarCod = &VeiMarCod if not &VeiMarCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Marca')) if VeiMarNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
Default(VeiMarNom,&AuxDefaultVeiMarNom.Trim().ToUpper());

UltimoCodigoEmpresa.Call(domParCod.marCAVEICULO, &Context.EmpCod, 0, VeiMarCod)
	If insert and VeiMarCod.IsEmpty() 
	on AfterValidate;

VerificaMarcaVeiculoRepetida(EmpCod, VeiMarNom, &ErroMensagem) 
	on BeforeValidate;

error(&ErroMensagem) 
	if not &ErroMensagem.IsEmpty() and not VeiMarNom.IsEmpty()
	on BeforeValidate;
]]></Source>
