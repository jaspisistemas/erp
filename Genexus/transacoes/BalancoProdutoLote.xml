        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&BalCod, in:&ProCod, in:&ProGraCod);

NoAccept(BalLotFabAnt);
NoAccept(BalLotVctAnt);
NoAccept(BalLotQtdAnt);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
noaccept(FilCod) if not &FilCod.IsEmpty();
BalCod = &BalCod if not &BalCod.IsEmpty();
noaccept(BalCod) if not &BalCod.IsEmpty();
ProCod = &ProCod if not &ProCod.IsEmpty();
noaccept(ProCod) if not &ProCod.IsEmpty();
ProGraCod = &ProGraCod if not &ProGraCod.IsEmpty();
noaccept(ProGraCod) if not &ProGraCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Lote')) if BalLotCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Fabricado')) if BalLotFab.IsEmpty();
Error(Format('WWP_RequiredAttribute','Vencimento')) if BalLotVct.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Error('ATENÇÃO! Vencimento tem que ser maior ou igual a fabricação!') if not BalLotFab.IsEmpty() and BalLotFab > BalLotVct on aftervalidate;
]]></Source>
