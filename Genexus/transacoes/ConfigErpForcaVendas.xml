Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

prompt(promptTipoLancamento, EmpCod, AppCon005);
prompt(promptTipoLancamento, EmpCod, AppCon006);
prompt(promptTipoLancamento, EmpCod, AppCon009);
]]></Source>
