      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&MonCod);

NoAccept(MonIsNfe);
NoAccept(MonIsTef);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
MonCod = &MonCod if not &MonCod.IsEmpty();
noaccept(MonCod) if not &MonCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Codigo Monitor')) if MonCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nome PC')) if MonNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);


Default(MonTip, &MonTip);

opcoes.Visible = &MonTip <> TipoApp.BI;
]]></Source>
