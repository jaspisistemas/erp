	Else
		RetornaAutorizacao.Call('WWCIDADE', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'AttributesSecurityCode'

	
	EmpCod.Visible = False
	CidAreCodNom.Visible = False
	CidTraCodRaz.Visible = False
	CidCodSync.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	AtualizaCidadeFormula.Call(EmpCod,CidCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CidWs.Visible = False
	CidWs_Cell.Class = !'Invisible'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


