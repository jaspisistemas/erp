      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CidCod);

NoAccept(CidCod);
Prompt(PromptPais, EmpCod, PaiCod);
Prompt(PromptArea, EmpCod, CidAreCod);
NoAccept(CidWs);
NoAccept(CidCodSync);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
CidCod = &CidCod if not &CidCod.IsEmpty();
CidWs.Visible = CidWs = Status_WsUsu.WebService;
CidWs_Cell.Class = !'Invisible' If not(CidWs = Status_WsUsu.WebService);
CidWs_Cell.Class = !'col-xs-12 DataContentCell' If CidWs = Status_WsUsu.WebService;
Error(Format('WWP_RequiredAttribute','Cidade Nome')) if CidNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Cidade IBGE')) if CidIBGE.IsEmpty();
Error(Format('WWP_RequiredAttribute','UF')) if UfeCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','País')) if PaiCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Area Código')) if CidAreCod.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

NoAccept(CidNom, CidIBGE, UfeCod, PaiCod) 
	if CidWs = Status_WsUsu.WebService;

Default(EmpCod, &Context.EmpCod);
Default(CidWs, Status_WsUsu.Usuario);
UltimoCodigoEmpresa.Call(domParCod.CIDADE, &Context.EmpCod, 0, CidCod)
	If insert and CidCod.IsEmpty() 
	on AfterValidate;

default(CidWs,  Status_WsUsu.Usuario);
prompt(PromptTransportadora, EmpCod, CidTraCod);
prompt(promptPais, EmpCod, PaiCod);
prompt(PromptArea,EmpCod, CidAreCod);

Error('Transportadora não Localizada!') 
	If CidTraRaz = 'TRANSPORTADORA NAO LOCALIZADA';

ValidaIbge.Call(EmpCod, CidCod, CidIBGE, &ErroMensagem) 
	if After(CidIBGE);
error(&ErroMensagem) 
	If After(CidIBGE) and not &ErroMensagem.IsEmpty();

]]></Source>
