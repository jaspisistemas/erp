h" /></cell><cell><textblock controlName="PesPerBon_RightText" caption="%" class="DataDescription" /></cell></row></table></cell></row></table></cell></row><row><cell cellClass="DataContentCell"><table controlName="TableSplittedPesVlrOutAcr" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:25},{&quot;width&quot;:75}]]}]"><row><cell cellClass="MergeLabelCell"><textblock controlName="TextBlockPesVlrOutAcr" caption="+ Outros Acrésc." class="Label" /></cell><cell><table controlName="TableMergedPesVlrOutAcr" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><data attribute="PesVlrOutAcr" labelPosition="None" class="AttributeRealWidth" /></cell><cell cellClass="DataContentCell"><data attribute="PesPerOutAcr" labelPosition="None" class="AttributeRealWidth" /></cell><cell><textblock controlName="PesPerOutAcr_RightText" caption="%" class="DataDescription" /></cell></row></table></cell></row></table></cell></row><row><cell cellClass="DataContentCell"><table controlName="TableSplittedPesPerIns" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:25},{&quot;width&quot;:75}]]}]"><row><cell cellClass="MergeLabelCell"><textblock controlName="TextBlockPesPerIns" caption="+ Insalubridade %" class="Label BootstrapTooltipTop" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;É um adicional instituído conforme o grau de risco existente na empresa e exercido pela função do empregado, podendo variar entre 10% (mínimo), 20% (médio) e 40% (máximo) sobre salário da categoria. Normalmente é determinado pelo médico do trabalho (PCMSO), com o acompanhamento de tabelas do Ministério do Trabalho, após avaliação das condições de risco que a saúde do empregado encontra-se exposta, integrando o salário para todos os fins legais.&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></cell><cell><table controlName="TableMergedPesPerIns" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><data attribute="PesPerIns" labelPosition="None" class="AttributeRealWidth BootstrapTooltipRight" /></cell><cell cellClass="DataContentCell"><data attribute="PesPerInsVlr" labelPosition="None" class="AttributeRealWidth" /></cell><cell><textblock controlName="PesPerInsVlr_RightText" caption="Calculado sobre salário mínimo" class="DataDescription" /></cell></row></table></cell></row></table></cell></row><row><cell cellClass="DataContentCell"><table controlName="TableSplittedPesPerPer" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:25},{&quot;width&quot;:75}]]}]"><row><cell cellClass="MergeLabelCell"><textblock controlName="TextBlockPesPerPer" caption="+ Periculosidade %" class="Label BootstrapTooltipTop" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;É um adicional, porém específicos para funções de inflamáveis ou explosivos. Sua percentagem é de 30% sobre o salário base, também acompanhado pelo médico do trabalho (PCMSO), integrando o salário para todos os fins legais.&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></cell><cell><table controlName="TableMergedPesPerPer" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><data attribute="PesPerPer" labelPosition="None" class="AttributeRealWidth BootstrapTooltipRight" /></cell><cell cellClass="DataContentCell"><data attribute="PesPerPerVlr" labelPosition="None" class="AttributeRealWidth" /></cell></row></table></cell></row></table></cell></row><row><cell cellClass="DataContentCell"><table controlName="TableSplittedPesVlrTrp" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:25},{&quot;width&quot;:75}]]}]"><row><cell cellClass="MergeLabelCell"><textblock controlName="TextBlockPesVlrTrp" caption="+ Vale-Transporte" class="Label BootstrapTooltipTop" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;É um benefício entregue por força de lei, do valor entregue ao empregado, o empregador pode descontar no máximo 6% do salário base, isso se o valor entregue for maior, caso contrário, descontar o valor entregue. Exemplo: salário R$ 600,00, valor gasto com vale transporte R$ 80,00, 6% do salário R$ 36,00, valor de desconto R$ 36,00.&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></cell><cell><table controlName="TableMergedPesVlrTrp" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><data attribute="PesVlrTrp" labelPosition="None" class="AttributeRealWidth BootstrapTooltipRight" /></cell><cell cellClass="DataContentCell"><data attribute="PesPerTrp" labelPosition="None" class="AttributeRealWidth" /></cell><cell><textblock controlName="PesPerTrp_RightText" caption="%" class="DataDescription" /></cell></row></table></cell></row></table></cell></row><row><cell cellClass="DataContentCell"><table controlName="TableSplittedPesVlrRef" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:25},{&quot;width&quot;:75}]]}]"><row><cell cellClass="MergeLabelCell"><textblock controlName="TextBlockPesVlrRef" caption="+ Vale-Refeição" class="Label BootstrapTooltipTop" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;Benefício concedido pelo empregador, pois não há lei que obrigue a tal prática, salvo existindo acordo o mesmo é limitado por lei a 20% do salário base.&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></cell><cell><table controlName="TableMergedPesVlrRef" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><data attribute="PesVlrRef" labelPosition="None" class="AttributeRealWidth BootstrapTooltipRight" /></cell><cell cellClass="DataContentCell"><data attribute="PesPerRef" labelPosition="None" class="AttributeRealWidth" /></cell><cell><textblock controlName="PesPerRef_RightText" caption="%" class="DataDescription" /></cell></row></table></cell></row></table></cell></row><row><cell><data attribute="PesVlrSalTotInf" labelCaption="Total Créditos" class="AttributeRealWidth" /></cell></row><row><cell cellClass="DataContentCell"><data attribute="PesSalFam" labelCaption="+ Salário Familia" class="AttributeRealWidth BootstrapTooltipRight" /></cell></row><row><cell cellClass="DataContentCell"><data attribute="PesFunQtdDep" labelCaption="Qtd dependentes" class="AttributeRealWidth BootstrapTooltipRight" /></cell></row><row><cell cellClass="DataContentCell"><data attribute="PesVlrIns" labelCaption="- Valor I.N.S.S." class="AttributeRealWidth" /></cell></row><row><cell cellClass="DataContentCell"><data attribute="PesVlrIrr" labelCaption="- Valor I.R.R.F." class="AttributeRealWidth" /></cell></row><row><cell><data attribute="PesFunVlrTotDes" labelCaption="Total Descontos" class="AttributeRealWidth" /></cell></row><row><cell cellClass="DataContentCell"><table controlName="TableSplittedCboCod" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:25},{&quot;width&quot;:75}]]}]"><row><cell cellClass="MergeLabelCell"><textblock controlName="TextBlockCboCod" caption="Ocupação" class="Label" /></cell><cell><table controlName="TableMergedCboCod" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><data attribute="CboCod" labelPosition="None" class="AttributeRealWidth" /></cell><cell cellClass="DataContentCell"><data attribute="CboNom" labelPosition="None" class="AttributeRealWidth" /></cell></row></table></cell></row></table></cell></row><row><cell cellClass="DataContentCell"><data attribute="PesCtaBanCod" labelCaption="Conta Padrão Pgto " class="AttributeRealWidth" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;ControlType&lt;/Name&gt;&lt;Value&gt;Dynamic Combo Box&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ControlItemValues&lt;/Name&gt;&lt;Value&gt;CtabanCod&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ControlItemDescription&lt;/Name&gt;&lt;Value&gt;CtaBanCodNom&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ControlSortDescription&lt;/Name&gt;&lt;Value&gt;False&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></cell></row><row><cell ce