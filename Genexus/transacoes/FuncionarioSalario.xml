        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWFUNCIONARIOSALARIO',  Status_SimNao.Sim, 2, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	PesFunQtdDep.TooltipText = "Pode ser o marido ou a mulher, filho, filha ou enteados até 21 anos (pode ser até 24 anos se forem universitários ou estiverem cursando escola técnica de segundo grau), todos não declarantes de IR."
	PesSalFam.TooltipText = "Valor fixo devido ao empregado que tiver dependente menor de 14 (quatorze) anos de idade ou nos casos específicos determinados pela previdência social. Esse valor fixo é fornecido pela Previdência Social, com base no limite da faixa salarial no cadastro de salario familia."
	PesVlrRef.TooltipText = "Benefício concedido pelo empregador, pois não há lei que obrigue a tal prática, salvo existindo acordo o mesmo é limitado por lei a 20% do salário base."
	PesVlrTrp.TooltipText = "É um benefício entregue por força de lei, do valor entregue ao empregado, o empregador pode descontar no máximo 6% do salário base, isso se o valor entregue for maior, caso contrário, descontar o valor entregue. Exemplo: salário R$ 600,00, valor gasto com vale transporte R$ 80,00, 6% do salário R$ 36,00, valor de desconto R$ 36,00."
	PesPerPer.TooltipText = "É um adicional, porém específicos para funções de inflamáveis ou explosivos. Sua percentagem é de 30% sobre o salário base, também acompanhado pelo médico do trabalho (PCMSO), integrando o salário para todos os fins legais."
	PesPerIns.TooltipText = "É um adicional instituído conforme o grau de risco existente na empresa e exercido pela função do empregado, podendo variar entre 10% (mínimo), 20% (médio) e 40% (máximo) sobre salário da categoria. Normalmente é determinado pelo médico do trabalho (PCMSO), com o acompanhamento de tabelas do Ministério do Trabalho, após avaliação das condições de risco que a saúde do empregado encontra-se exposta, integrando o salário para todos os fins legais."
	PesCatSalCarCod.TooltipText = "Salário da Função do Funcionário"
	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated PesCatSalCarCod
				Case &TrnContextAtt.AttributeName = !"PesCatSalCarCod"
					&Insert_PesCatSalCarCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated CboCod
				Case &TrnContextAtt.AttributeName = !"CboCod"
					&Insert_CboCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	PesSalTotRec.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWFuncionarioSalario.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
