      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CatCod);

NoAccept(CatCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
CatCod = &CatCod if not &CatCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Categoria Descrição')) if CatNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod, &Context.EmpCod);
	
CatCod = UltimoCodigoEmpresa.Udp(domParCod.CATIMPOSTO, &Context.EmpCod, 0)
	If insert and CatCod.IsEmpty() 
	on AfterValidate;

Default(CatSts, Status_AtivoInativo.ATIVO);

ValidaCategoriaProdutoUnica.Call(EmpCod, CatCod, CatNom, &Mensagem) 
	if After(CatNom);
error(&Mensagem) 
	if After(CatNom) and not &Mensagem.IsEmpty() and (insert or update);

ValidaCategoriaProdutoCodigoUnica.Call(EmpCod, CatCod, CatCodImp, &Mensagem) 
	if After(CatCodImp);
error(&Mensagem) 
	if After(CatCodImp) and not &Mensagem.IsEmpty() and (insert or update);


prompt(PromptClassificacaoTributaria, CatCltSitCod);
prompt(PromptClassificacaoTributariaCltCls, CatCltSitCod, CatCltClsTrib);
]]></Source>
