      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		RetornaAutorizacao.Call('WWCATEGORIAIMPOSTOS', Status_SimNao.Sim, 3, &AutNiv)
	Else
		RetornaAutorizacao.Call('WWCATEGORIAIMPOSTOS', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	UnnamedTable5.Width = 250
	UnnamedTable4.Width = 250
	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	CatNom.SetFocus()
	
	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'CATEGORIAIMPOSTOS')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&CatCod = 0, Trnmode.Insert, Trnmode.Update))
		Call(prcCarregaLog_CategoriaImpostos, &EmpCod, &CatCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	If &Mode <> TrnMode.Delete
		prcAtualizaCategoriaImposto.Call(EmpCod, CatCod)
	EndIf
	
	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_CategoriaImpostos.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, CatCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
