      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&MarCod);

NoAccept(MarCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
MarCod = &MarCod if not &MarCod.IsEmpty();
MarNom_Cell.Class = !'col-xs-12 DataContentCell' if not(MarCod <> 1);
MarNom_Cell.Class = !'col-xs-12 RequiredDataContentCell' if MarCod <> 1;
Error(Format('WWP_RequiredAttribute','Marca Descrição')) if (MarCod <> 1) AND MarNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.MARCA, &Context.EmpCod,  0, MarCod)
	If insert and MarCod.IsEmpty() 
	on AfterValidate;

ValidaMarcaUnica.Call(EmpCod, MarCod, MarNom, &Mensagem) 
	if After(MarNom);

error(&Mensagem) 
	if After(MarNom) and not &Mensagem.IsEmpty() and (insert or update);
]]></Source>
