      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWMARCA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWMARCA', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'AttributesSecurityCode'

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'MARCA')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&MarCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Marca.Call(&EmpCod, &MarCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	If &Mode <> TrnMode.Delete
		prcAtualizaMarca.Call(EmpCod, MarCod)
	EndIf
	
	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_Marca.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, MarCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	MarNom_Cell.Class = !'col-xs-12 DataContentCell'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
