        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWENTRADAPRODUCAO', Status_SimNao.Sim, 2, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	PrdFunCod.TooltipText = "Responsável pelo Lançamento"
	PrdDtaEnt.TooltipText = "Data em que foi Produzido"
	
	PrdFunIs.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If PrdSts <> Status_Pedido.ABERTO
		WWEntradaProducao.Link()
	EndIF

EndEvent

Event After Trn

	wpEntradaProducao.Link(EmpCod, FilCod, PrdCod)

