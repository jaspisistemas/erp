      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&PrdCod);

NoAccept(EmpCod);
NoAccept(FilCod);
NoAccept(PrdCod);
NoAccept(PrdSts);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
PrdCod = &PrdCod if not &PrdCod.IsEmpty();
BtnItens.Visible = True If (PrdCod <> 0);
BtnItens.Visible = False If not (PrdCod <> 0);
Error(Format('WWP_RequiredAttribute','Data Entrada')) if PrdDtaEnt.IsEmpty();
Error(Format('WWP_RequiredAttribute','Código')) if PrdFunCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Funcionário')) if PrdFunIs.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&context.EmpCod);
Default(FilCod,&context.FilCod);

Default(PrdSts, Status_Pedido.ABERTO);
Default(PrdDtaEnt, serverdate());

Default(PrdFunCod, &Context.PesCod);

UltimoCodigoEmpresa.Call(domParCod.ENTRADAPRODUCAO, &Context.EmpCod, FilCod, PrdCod)
	If insert and PrdCod.IsEmpty() 
	on AfterValidate;
	
Prompt(PromptFuncionario, EmpCod, PrdFunCod);
]]></Source>
