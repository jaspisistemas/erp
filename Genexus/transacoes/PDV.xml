      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

//	if &Mode <> TrnMode.Update
//		btnNovoCodigo.Visible = 0
//	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	tbRestricaoUsuarios.Width = 192
	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False
	PdvCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'totaisPDvs'

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWPDV.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovoCodigo'

//	GeraRandom.Call(EmpCod, PdvRandon)

EndEvent

Sub 'totaisPDvs'

	&QtdAtivos = 0
	prcQtdPdv.Call(&Context.EmpCod, &QtdMaximo, &QtdAtivos)
	
	txtQtdUtilizadaUsuarios.Caption = Format('ATIVOS: %1 MÁX.: %2', padl(trim(toformattedString(&QtdAtivos)),2,'0'), padl(trim(toformattedString(&QtdMaximo)),2,'0'))
	Do CAse
		CAse &QtdAtivos = &QtdMaximo
			txtQtdUtilizadaUsuarios.ForeColor = RGB(255,100,50)
		CAse &QtdAtivos > &QtdMaximo
			txtQtdUtilizadaUsuarios.ForeColor = RGB(255,0,0)
		Otherwise
			&IsPodeAdicionar = true
			txtQtdUtilizadaUsuarios.ForeColor = RGB(0,150,255)
	EndCAse

EndSub


]]></Source>
