        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&PdvCod);

EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
PdvCod = &PdvCod if not &PdvCod.IsEmpty();
noaccept(PdvCod) if not &PdvCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','ID PDV')) if PdvId.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(EmpCod, &Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.PDV, &Context.EmpCod, 0, PdvCod)
	If insert and PdvCod.IsEmpty() 
	on AfterValidate;

//default(PdvRandon, '000');

Default(PdvStsSync, Status_Pdv.PENDENTE);
]]></Source>
