      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&BioCod);

NoAccept(BioCod);
NoAccept(BioDtaHor);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
BioCod = &BioCod if not &BioCod.IsEmpty();

BioAloCod = &Insert_BioAloCod if &Mode = TrnMode.Insert and not &Insert_BioAloCod.IsEmpty();
noaccept(BioAloCod) if &Mode = TrnMode.Insert and not &Insert_BioAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data')) if BioDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Qtde Amostras')) if BioQtdAmo.IsEmpty();
Error(Format('WWP_RequiredAttribute','Peso Total')) if BioTotPeso.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
Default(EmpCod,&Context.EmpCod);
Default(BioDta,ServerDate());
Default(BioHor,ServerNow());
UltimoCodigoEmpresa.Call(domParCod.BIOMETRIA,EmpCod,0,BioCod)If insert;
NoAccept(BioFilCod) if BioFilCod.Count <= 1;

BioDtaHor = YMDHMStoT(year(BioDta),month(BioDta),day(BioDta),Hour(BioHor),Minute(BioHor),0) If 	not BioDta.IsEmpty() and not BioHor.IsEmpty() 
	on AfterValidate;
]]></Source>
