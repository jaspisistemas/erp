      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		&OqueFazer = 'DEL'
		retornaAutorizacao.Call('WWBIOMETRIA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		&OqueFazer = 'INS'
		retornaAutorizacao.Call('WWBIOMETRIA', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated BioAloCod
				Case &TrnContextAtt.AttributeName = !"BioAloCod"
					&Insert_BioAloCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	BioCod.Visible = False
	BioAloLin.Visible = False
	BioMedPes.Visible = False
	BioIdade.Visible = False
	BioQtdMor.Visible = False
	BioQtdRac_Formula.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&pescod = &Context.PesCod

EndEvent

Event After Trn

	AtualizaBiometria.Call(EmpCod,BioCod)
	AtualizaStatusAlojamento.call(&OqueFazer,EmpCod,BioAloCod,BioAloUniProCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWBiometria.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
