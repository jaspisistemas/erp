      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtAviso.Visible = iif(&Mode = TrnMode.Update, true, false)
	
	if &mode <> TrnMode.Delete
		RetornaAutorizacao.Call('WWSERVICO', Status_SimNao.Sim, 2,  &AutNiv)
	else
		RetornaAutorizacao.Call('WWSERVICO', Status_SimNao.Sim, 3,  &AutNiv)
	EndIf
	&CreRecPag = ReceberPagar.Receber

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False
	SerCodNomAbvVlr_Form.Visible = False
	SerCodNomAbvVlr.Visible = False
	&SerPlanCod.Visible = False
	&CreRecPag.Visible = False
	&EmpCod.Visible = False
	&PlanCodNomVir.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	AtualizaServico.Call(EmpCod, SerCod)
	&ParSerCod = SerCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWServico.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
