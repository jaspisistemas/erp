      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&SerCod, &ParSerCod);

NoAccept(SerCod);
NoAccept(SerSts);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
SerCod = &SerCod if not &SerCod.IsEmpty();

Error('Você deve informar a Descrição do Serviço!') if SerNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tipo')) if SerTipPlan.IsEmpty();
Error(Format('WWP_RequiredAttribute','ValorServico')) if SerVlr.IsEmpty();
Error('Você deve informar uma Abreviação para este serviço!') if SerAbv.IsEmpty();
Error('Você deve selecionar um Plano de Contas para este Serviço!') if SerPlanCod.IsEmpty();
Error('Você deve selecionar o Local de Cobrança para este Serviço!') if SerCbrCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Ser Sts')) if SerSts.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

prompt(PromptLocalCobranca , EmpCod, SerCbrCod);

prompt(PromptPlanoContasSugg , EmpCod, &SerPlanCod, &CreRecPag, SerPlanCod);

Default(EmpCod,&Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.SERVICO, &Context.EmpCod, 0, SerCod)
	If insert and SerCod.IsEmpty() 
	on AfterValidate;

//Default(SerTipo = TipoLancamentoServico.SERVICO);
/*NoAccept(SerTip)
	if &Mode <> TrnMode.Insert;*/
]]></Source>
