	LoadWWPContext.Call(&Context)

	
	BalTip.Visible = False
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'BALANCO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&BalCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Balanco.Call(&EmpCod, &Context.FilCod, &BalCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_Balanco.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, BalCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	wpBalancoItem.Link(EmpCod, FilCod, BalCod)
	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndEvent

Event 'DoFecharBal'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWBalanco.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


