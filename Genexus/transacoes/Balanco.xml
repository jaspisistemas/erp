        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&BalCod);

NoAccept(BalFunCod);
NoAccept(FilCod);
NoAccept(BalCod);
NoAccept(BalSts);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
BalCod = &BalCod if not &BalCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data Balanco')) if BalDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Descricao Balanco')) if BalObs.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
Default(FilCod, &Context.FilCod);
Default(BalFunCod, &Context.PesCod);
Default(BalDta, serverdate());
Default(BalSts, Status_Pedido.ABERTO);
Default(BalObs, 'NOVO BALANÇO');
Default(BalTip, TipoBalanco.Gerencial);
Default(BalStsPrc, AtualizandoEstoquePedido.Aberto);
UltimoCodigoEmpresa.Call(domParCod.BALANCO, EmpCod, FilCod, BalCod)
	If insert and BalCod.IsEmpty() 
	on AfterValidate;
]]></Source>
