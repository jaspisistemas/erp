BtnItensTrans.Visible = True If (&mode = TrnMode.update);
BtnItensTrans.Visible = False If Not (&mode = TrnMode.update);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.TRANSPEDIDO, &Context.EmpCod, 0, TrsCod)
	If insert and TrsCod.IsEmpty() 
	on AfterValidate;

Default(TrsSaiFilCod, &Context.FilCod);
Default(TrsEntFiLCod, &Context.FilCod);
Default(TrsDtaEms, Serverdate());

]]></Source>
