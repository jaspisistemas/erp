        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&GruImpCod);

NoAccept(GruImpCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
GruImpCod = &GruImpCod if not &GruImpCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Descrição')) if GruImpNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
Default(EmpCod,&Context.EmpCod);

UltimoCodigoEmpresa.Call(domParCod.GRUPOIMPOSTO, EmpCod, 0, GruImpCod)
	If insert and GruImpCod.IsEmpty() 
	on AfterValidate;

prompt(promptTipoLancamento, EmpCod, GruLctCod);
]]></Source>
