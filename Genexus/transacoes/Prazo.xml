      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		RetornaAutorizacao.Call('WWPRAZO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		RetornaAutorizacao.Call('WWPRAZO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF
	
	GridLevel_Parcela.Rows = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	PraColMin.TooltipText = "Prazo será Permitido apartir da Coluna Mínima informada, se não autorizado à Rotina 'VENDAPRAZOFORACOLUNA'"
	PraColMax.TooltipText = "Prazo será Permitido até a Coluna Máxima informada, se não autorizado à Rotina 'VENDAPRAZOFORACOLUNA'"
	PraMedBlo.TooltipText = "Para definir um prazo médio máximo das parcelas abaixo. Ex: (030+060+090)/3 Prazo Médio 60 Dias."
	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'PRAZO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&PraCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Prazo.Call(&EmpCod, &PraCod, &SdtLogAtributos)
		prcCarregaLog_PrazoParcela.Call(&EmpCod, &PraCod, &SdtLogAtributosLevel)
	Endif

EndEvent

Event After Trn

	prcAtualizaPrazo.Call(EmpCod, PraCod)

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_Prazo.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, PraCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
		prcGravaLog_PrazoParcela.Call(&Context.EmpCod, &Context.FilCod, PraCod, &Pgmname, &Context.UserName, &SdtLogAtributosLevel)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWPrazo.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	PraMedBlo.Visible = False
	PraMedBlo_Cell.Class = !'Invisible'
	
	tbVenciemntosDatas.Visible = False
	tbDescritivo.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

