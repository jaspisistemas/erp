      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&PraCod);

NoAccept(PraParCod);
NoAccept(PraCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
PraCod = &PraCod if not &PraCod.IsEmpty();

PraMedBlo.Visible = PraTipParc = '0';
PraMedBlo_Cell.Class = !'Invisible' If not(PraTipParc = '0');
PraMedBlo_Cell.Class = !'col-xs-12 DataContentCell' If PraTipParc = '0';
tbVencimentosPArcelas.Visible = (PraTipParc = '0');
tbVenciemntosDatas.Visible = (PraTipParc = '1');
tbDescritivo.Visible = (PraTipParc = '3');
TableLeafLevel_Parcela.Visible = (PraIsVis = false);
Error(Format('WWP_RequiredAttribute','Prazo Nome')) if PraNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


UltimoCodigoEmpresa.Call(domParCod.PRAZO, &Context.EmpCod, 0,PraCod) 
	If insert and PraCod.IsEmpty() 
	on AfterValidate;

FormataParcela.Call(PraParNom,PraParNom) If After(PraParNom);

Serial(PraParCod, PraParMax,1);


Error('Prazo médio maior que o Máximo autorizado!') 
	If after(PraParMedCal) and (PraParMedCal > PraMedBlo) and PraMedBlo > 0 and PraIsVis = false;
]]></Source>
