      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&PedCod, in:&PedItmCod);

NoAccept(PedQtd);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
noaccept(FilCod) if not &FilCod.IsEmpty();
PedCod = &PedCod if not &PedCod.IsEmpty();
noaccept(PedCod) if not &PedCod.IsEmpty();
PedItmCod = &PedItmCod if not &PedItmCod.IsEmpty();
noaccept(PedItmCod) if not &PedItmCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lote')) if PedProEstLotCod.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Error('Quantidade é obrigatório.') 
	if PedProEstLotQtd.IsEmpty();

//Error('Quantidades de Lotes não Coincide com o Total do Produto.') 
//	if (PedQtd <> PedLotTot and PedLotTot > 0) on BeforeComplete;

//Error('Lote: #SEM_LOTE não pode ser informado caso haja mais de 1 lote!') 
//	if PedLotQtd > 1 and PedProEstLotCod like '%#SEM_LOTE%';


prompt(promptEstoqueProdutoLote, EmpCod, FilCod, ProCod, ProGraCod, PedProEstLotCod);

Error('Informada data de validade menor que a Data de Fabricação') 
	if PedProEstLotVct < PedProEstLotFab and not PedProEstLotVct.IsEmpty();


PedProEstLotFab = PedProEstLotFab_Estoque if PedProEstLotCod <> Old(PedProEstLotCod) and not PedProEstLotFab_Estoque.IsEmpty() and after(PedProEstLotCod);
PedProEstLotVct = PedProEstLotVct_Estoque if PedProEstLotCod <> Old(PedProEstLotCod) and not PedProEstLotVct_Estoque.IsEmpty() and after(PedProEstLotCod);

PedProEstLotFab.Enabled = (PedProEstLotFab_Estoque.IsEmpty() or LctAtuSal <> Status_EntradaSaida.Saida);
PedProEstLotVct.enabled = (PedProEstLotVct_Estoque.IsEmpty() or LctAtuSal <> Status_EntradaSaida.Saida);
]]></Source>
