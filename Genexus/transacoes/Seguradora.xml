      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&SegCod);

NoAccept(EmpCod);
NoAccept(SegCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
SegCod = &SegCod if not &SegCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Cnpj')) if SegCnpj.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nome')) if SegNom.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

UltimoCodigoEmpresa.Call(domParCod.SEGURADORA, EmpCod,  0, SegCod)
	If insert and SegCod.IsEmpty() 
	on AfterValidate;

ValidaCpfCnpj.Call(SegCnpj, &ErroCpf, &ObrigatorioCpfCnpj) 
	IF after(SegCnpj) and not SegCnpj.Trim().IsEmpty();

error('ATENÇÃO! CNPJ Inválido! Obrigatório CNPJ') 
	IF &ErroCpf = 1  and not SegCnpj.Trim().IsEmpty() and after(SegCnpj);
]]></Source>
