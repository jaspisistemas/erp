      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&ImoCod);

Prompt(promptFuncionariosCPF, EmpCod, ImoParPesCod, &InOutPesCnpj);
NoAccept(FilCod);
Prompt(PromptFilial, EmpCod, FilCod);
NoAccept(ImoCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
ImoCod = &ImoCod if not &ImoCod.IsEmpty();

ImoCidCod = &Insert_ImoCidCod if &Mode = TrnMode.Insert and not &Insert_ImoCidCod.IsEmpty();
noaccept(ImoCidCod) if &Mode = TrnMode.Insert and not &Insert_ImoCidCod.IsEmpty();
ImoCaepf_Cell.Class = !'col-xs-12 DataContentCell' if not(ImoTip = tipoImovel.ImovelProprio);
ImoCaepf_Cell.Class = !'col-xs-12 RequiredDataContentCell' if ImoTip = tipoImovel.ImovelProprio;
Terceiros.Visible = (ImoTip <> tipoImovel.ImovelProprio);
Error(Format('WWP_RequiredAttribute','Tipo')) if ImoTip.IsEmpty();
Error(Format('WWP_RequiredAttribute','CAEPF')) if (ImoTip = tipoImovel.ImovelProprio) AND ImoCaepf.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nro CIB Cafir (ITR)')) if ImoItr.IsEmpty();
Error(Format('WWP_RequiredAttribute','Incra')) if ImoIncra.IsEmpty();
Error(Format('WWP_RequiredAttribute','Matricula')) if ImoMat.IsEmpty();
Error(Format('WWP_RequiredAttribute','Cep')) if ImoCep.IsEmpty();
Error(Format('WWP_RequiredAttribute','Logradouro')) if ImoLog.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nro')) if ImoNro.IsEmpty();
Error(Format('WWP_RequiredAttribute','Bairro')) if ImoBai.IsEmpty();
Error(Format('WWP_RequiredAttribute','Cidade')) if ImoCidCod.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
FormataCEP.Call(ImoCep, ImoCep);
Prompt(PromptCidade, EmpCod, ImoCidCod);
UltimoCodigoEmpresa.Call(domParCod.IMOVEIS, &EmpCod, 0, ImoCod)
	If insert and ImoCod.IsEmpty() 
	on AfterValidate;
Prompt(PromptCidade, &EmpCod, ImoCidCod);
]]></Source>
