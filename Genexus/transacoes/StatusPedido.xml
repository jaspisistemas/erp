        <Source><![CDATA[
Event Start

	RetornaCorStatus.Call(&EmpCod, &StsCod, &Color2, &R, &G, &B)
	&GXColor = RGB(&R,&G,&B)
	
	GenomaColorPicker.GXColor = &GXColor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	TableMain.Height = 493
	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Color2.Enabled = 1

EndEvent

Event After Trn

	if &Mode <> TrnMode.Delete
		&Color2 = GenomaColorPicker.HEXColor
		GravaCorStatus.Call(EmpCod, StsCod, &Color2)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GenomaColorPicker.onChange

	&Color2 = GenomaColorPicker.HEXColor

EndEvent


]]></Source>
