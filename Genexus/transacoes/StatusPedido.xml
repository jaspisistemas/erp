      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&StsCod);

NoAccept(EmpCod);
NoAccept(StsCod);
NoAccept(StsWs);
NoAccept(StsHex);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
StsCod = &StsCod if not &StsCod.IsEmpty();
Accept(&Color2);
Error(Format('WWP_RequiredAttribute','Status')) if StsNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(StsWs, Status_WsUsu.Usuario);

UltimoCodigoEmpresa.Call(domParCod.STATUSPEDIDO, &Context.EmpCod, 0, StsCod)
	If insert and StsCod.IsEmpty() 
	on AfterValidate;

NoAccept(StsNom, StsPed, StsPaiCod, StsOrd, StsCrd, StsEst) 
	if StsWs = Status_WsUsu.WebService;
//StsCrd = true if StsWs = Status_WsUsu.WebService;
//StsEst = true if StsWs = Status_WsUsu.WebService;


NomeUnicoStatus.Call(EmpCod, StsCod, StsNom, &Mensagem) 
	if After(StsNom);
error(&Mensagem) 
	if After(StsNom) and not &Mensagem.IsEmpty();
]]></Source>
