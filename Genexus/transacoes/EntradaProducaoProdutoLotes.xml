Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated ProCod
				Case &TrnContextAtt.AttributeName = !"ProCod"
					&Insert_ProCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated ProGraCod
				Case &TrnContextAtt.AttributeName = !"ProGraCod"
					&Insert_ProGraCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
