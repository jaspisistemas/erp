        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&PrdCod, in:&PrdItmCod);

NoAccept(PrdItmQtd);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
noaccept(FilCod) if not &FilCod.IsEmpty();
PrdCod = &PrdCod if not &PrdCod.IsEmpty();
noaccept(PrdCod) if not &PrdCod.IsEmpty();
PrdItmCod = &PrdItmCod if not &PrdItmCod.IsEmpty();
noaccept(PrdItmCod) if not &PrdItmCod.IsEmpty();

ProCod = &Insert_ProCod if &Mode = TrnMode.Insert and not &Insert_ProCod.IsEmpty();
noaccept(ProCod) if &Mode = TrnMode.Insert and not &Insert_ProCod.IsEmpty();
ProGraCod = &Insert_ProGraCod if &Mode = TrnMode.Insert and not &Insert_ProGraCod.IsEmpty();
noaccept(ProGraCod) if &Mode = TrnMode.Insert and not &Insert_ProGraCod.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Error('Data de vencimento não pode ser menor que a fabricada.') if PrdProEstLotVct < PrdProEstLotFab on afterValidate;
]]></Source>
