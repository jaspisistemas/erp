        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&DesCod);

EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
DesCod = &DesCod if not &DesCod.IsEmpty();
noaccept(DesCod) if not &DesCod.IsEmpty();

CbrCod = &Insert_CbrCod if &Mode = TrnMode.Insert and not &Insert_CbrCod.IsEmpty();
