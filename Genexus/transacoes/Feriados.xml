      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		RetornaAutorizacao.Call('WWFERIADOS', Status_SimNao.Sim, 3, &AutNiv)
	Else
		RetornaAutorizacao.Call('WWFERIADOS', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	TableAttributes.Height = 300
	EmpFrdFix.TooltipText = "Para Feriados que acontecem todos os Anos no mesmo dia como o Natal (25/12). Marque como Fixo, para não precisar cadastrar todos os anos."
	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False
	EmpFrdCod.Visible = False
	EmpFrdDia.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWFeriados.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	EmpFrdPaiCod_Cell.Class = !'col-xs-12 DataContentCell'
	EmpFrdUfeCod.Visible = False
	EmpFrdUfeCod_Cell.Class = !'Invisible'
	EmpFrdCidCod.Visible = False
	EmpFrdCidCod_Cell.Class = !'Invisible'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
