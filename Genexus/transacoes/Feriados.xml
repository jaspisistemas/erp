        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&EmpFrdCod);

EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
EmpFrdCod = &EmpFrdCod if not &EmpFrdCod.IsEmpty();
noaccept(EmpFrdCod) if not &EmpFrdCod.IsEmpty();

EmpFrdPaiCod_Cell.Class = !'col-xs-12 DataContentCell' if not(EmpFrdNac <> TipoRegiao.Nacional);
EmpFrdPaiCod_Cell.Class = !'col-xs-12 RequiredDataContentCell' if EmpFrdNac <> TipoRegiao.Nacional;
EmpFrdUfeCod.Visible = EmpFrdNac = TipoRegiao.Municipal or EmpFrdNac = TipoRegiao.Estadual;
EmpFrdUfeCod_Cell.Class = !'Invisible' If not(EmpFrdNac = TipoRegiao.Municipal or EmpFrdNac = TipoRegiao.Estadual);
EmpFrdUfeCod_Cell.Class = !'col-xs-12 RequiredDataContentCell' If EmpFrdNac = TipoRegiao.Municipal or EmpFrdNac = TipoRegiao.Estadual;
EmpFrdCidCod.Visible = EmpFrdNac = TipoRegiao.Municipal;
EmpFrdCidCod_Cell.Class = !'Invisible' If not(EmpFrdNac = TipoRegiao.Municipal);
EmpFrdCidCod_Cell.Class = !'col-xs-12 RequiredDataContentCell' If EmpFrdNac = TipoRegiao.Municipal;
Error(Format('WWP_RequiredAttribute','Descricao Feriado')) if EmpFrdNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Emp Frd Dta')) if EmpFrdDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Feriado Fixo?')) if EmpFrdFix.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tipo')) if EmpFrdNac.IsEmpty();
Error(Format('WWP_RequiredAttribute','País')) if (EmpFrdNac <> TipoRegiao.Nacional) AND EmpFrdPaiCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','UF')) if (EmpFrdNac = TipoRegiao.Municipal or EmpFrdNac = TipoRegiao.Estadual) AND EmpFrdUfeCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Cidade')) if (EmpFrdNac = TipoRegiao.Municipal) AND EmpFrdCidCod.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


UltimoCodigoFeriado.Call(&Context.EmpCod, EmpFrdCod)
	If insert and EmpFrdCod.IsEmpty() 
	on AfterValidate;

Default(EmpFrdFix, Status_SimNao.Sim);
default(EmpFrdPaiCod, 1058);
default(EmpFrdNac, TipoRegiao.Nacional);

EmpFrdDia = trim(toformattedString(EmpFrdDta)) 
	If EmpFrdFix = Status_SimNao.Nao;
EmpFrdDia = Substr(trim(toformattedString(EmpFrdDta)), 1, 5)
	If EmpFrdFix = Status_SimNao.Sim;
]]></Source>
