      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbEntrada.Visible = (&EntradaDevolucaoVarchar = 'E')
	tbDevolucao.Visible = (&EntradaDevolucaoVarchar = 'D')
	if &tmpNFeCod.IsEmpty()
		&AtualizarTemporaria = 'N'
		&AtualizarTemporaria.Visible = 0
		tbatualizaTemporaria.Visible = 0
	Else
		&AtualizarTemporaria = 'S'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	CfoEmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	if &AtualizarTemporaria = 'S'
		prcAtualizaOperacaoNotaTemporaria.Call(&CfoEmpCod, &tmpNFeCod,0,0,0,0)
	Endif
	IF &EntradaDevolucaoVarchar = 'E'
		&CfoEmpInvCod = CfoEmpEntCod
	Else
		&CfoEmpInvCod = CfoEmpInvCod
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbEntradaPercentualICMS.Visible = False
	PercentualICMS.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
