      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&CfoCod, in:&CfoEmpCod, in:&CfoLctCod, In:&EntradaDevolucaoVarchar, In:&tmpNFeCod, Out:&CfoEmpInvCod);

NoAccept(CfoLctCod);
NoAccept(CfoLctNom);
NoAccept(CfoCod);
Prompt(PromptCfop, CfoCod);
NoAccept(CfoDesCpl);
CfoCod = &CfoCod if not &CfoCod.IsEmpty();
CfoEmpCod = &CfoEmpCod if not &CfoEmpCod.IsEmpty();
noaccept(CfoEmpCod) if not &CfoEmpCod.IsEmpty();
CfoLctCod = &CfoLctCod if not &CfoLctCod.IsEmpty();

Accept(&AtualizarTemporaria);
tbEntradaPercentualICMS.Visible = (CfoLctTip = TipoLancamento.EntradaMercadoria);
PercentualICMS.Visible = (CfoEmpAprvCredIcms = 'N');
Default(CfoEmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


ValidaCFOP.Call(CfoEmpEntCod, &IsErroCFOP, &CfoEmpEntNom) 
	if after(CfoEmpEntCod);
error(&CfoEmpEntNom) if after(CfoEmpEntCod) and &IsErroCFOP = true;


Error('CFOP Deve começar com numero 1') 
	if Substr(CfoEmpEntCod,1,1) <> '1' and Substr(CfoCod, 1, 1) = '5' and not CfoEmpEntCod.IsEmpty();

Error('CFOP Deve começar com numero 2') 
	if Substr(CfoEmpEntCod,1,1) <> '2' and Substr(CfoCod, 1, 1) = '6' and not CfoEmpEntCod.IsEmpty();

prompt(PromptCfop, CfoEmpEntCod);
prompt(PromptCfop, CfoEmpInvCod);
]]></Source>
