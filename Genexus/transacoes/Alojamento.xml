      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&AloCod);

NoAccept(AloCod);
NoAccept(AloSts);
NoAccept(AloDtaFch);
NoAccept(AloCAe);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
AloCod = &AloCod if not &AloCod.IsEmpty();

AloUniProCod = &Insert_AloUniProCod if &Mode = TrnMode.Insert and not &Insert_AloUniProCod.IsEmpty();
noaccept(AloUniProCod) if &Mode = TrnMode.Insert and not &Insert_AloUniProCod.IsEmpty();
AloLotCod = &Insert_AloLotCod if &Mode = TrnMode.Insert and not &Insert_AloLotCod.IsEmpty();
noaccept(AloLotCod) if &Mode = TrnMode.Insert and not &Insert_AloLotCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Código')) if AloUniProCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Código')) if AloLotCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data Alojamento')) if AloDtaIni.IsEmpty();
Error(Format('WWP_RequiredAttribute','Qtd Inicial')) if AloQtdUni.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(AloDtaIni,&Today);
Default(AloSts,Status_Alojamento.Emproducao);
UltimoCodigoEmpresa.Call(DomParCod.ALOJAMENTO,EmpCod,0,AloCod)
	If insert and AloCod.IsEmpty() 
	on AfterValidate;

AloQtdUni  = RetornaQtdDisponivel.Udp(EmpCod,AloLotCod) if AloQtdUni = 0 and after(AloLotCod);
AloLin.Visible = AloUniProTip = TipoUnidadeProdutora.TanqueRede;
Error('Quantidade Informada maior que o disponível!') if AloQtdUni > udp(RetornaQtdDisponivel, EmpCod,AloLotCod) and insert on afterValidate;
NoAccept(AloUniProCod) If &Mode = TrnMode.Update;
NoAccept(AloLotCod) If &Mode = TrnMode.Update;
NoAccept(AloQtdUni) If &Mode = TrnMode.Update;
NoAccept(AloFilCod) if AloFilCod.Count <= 1;
AloDtaPreSai = AloDtaIni.AddDays(300) If Insert and AloDtaPreSai.IsEmpty(); 
]]></Source>
