      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWALOJAMENTO', Status_SimNao.Sim, 3, &AutNiv)
		&OqueFazer = 'DEL'
	Else
		&OqueFazer = 'INS'
		retornaAutorizacao.Call('WWALOJAMENTO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated AloUniProCod
				Case &TrnContextAtt.AttributeName = !"AloUniProCod"
					&Insert_AloUniProCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated AloLotCod
				Case &TrnContextAtt.AttributeName = !"AloLotCod"
					&Insert_AloLotCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	AloCod.Visible = False
	AloLin.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PesCod = &Context.PesCod

EndEvent

Event After Trn

//	If &Mode = TrnMode.Insert
//		InserirBiometriaInicial.Call(EmpCod,AloLotCod,AloLin,AloCod)
//	EndIf

//	AtualizaStatusAlojamento.call(&OqueFazer,EmpCod,AloCod,AloUniProCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWAlojamento.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
