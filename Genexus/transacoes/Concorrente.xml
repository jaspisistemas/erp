        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&ConEmpCod, in:&ConCod);

NoAccept(ConEmpCod);
NoAccept(ConCod);
ConEmpCod = &ConEmpCod if not &ConEmpCod.IsEmpty();
ConCod = &ConCod if not &ConCod.IsEmpty();
noprompt(ConEmpCod,ConCod);

Error(Format('WWP_RequiredAttribute','Nome')) if ConRaz.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(ConEmpCod, &Context.EmpCod);

UltimoCodigoEmpresa.Call(domParCod.CONCORRENTE, ConEmpCod, 0, ConCod)
	If insert and ConCod.IsEmpty() 
	on AfterValidate;
]]></Source>
