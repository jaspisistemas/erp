      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&HorCod);

NoAccept(HorCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
HorCod = &HorCod if not &HorCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Dia da Semana')) if HorDiaSem.IsEmpty();
Error(Format('WWP_RequiredAttribute','Horário Descrição')) if HorNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

UltimoCodigoEmpresa.Call(domParCod.HORARIO, &Context.EmpCod, 0, HorCod)
	If insert and HorCod.IsEmpty() 
	on AfterValidate;

FormataHora.Call(Hor1Ent, Hor1Ent);
FormataHora.Call(Hor2Ent, Hor2Ent);
FormataHora.Call(Hor3Ent, Hor3Ent);

FormataHora.Call(Hor1Sai, Hor1Sai);
FormataHora.Call(Hor2Sai, Hor2Sai);
FormataHora.Call(Hor3Sai, Hor3Sai);
]]></Source>
