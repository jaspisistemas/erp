      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWFUNCAO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWFUNCAO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'AttributesSecurityCode'

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaEmpresaModulo.Call(&Context.EmpCod, ModuloSistema.DELIVERY, &DELIVERY)
	
	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'FUNCAO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&FucCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_Funcao.Call(&EmpCod, &FucCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	if &Mode <> TrnMode.Delete
		prcAtualizaFuncao.Call(EmpCod, FucCod)
	Endif
	
	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_Funcao.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, FucCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbOculta.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
