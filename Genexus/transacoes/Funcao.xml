        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FucCod);

NoAccept(FucCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FucCod = &FucCod if not &FucCod.IsEmpty();
tbOculta.Visible = (&DELIVERY = 'S');
Error(Format('WWP_RequiredAttribute','Função Descrição')) if FucNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod, &Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.FUNCAO, &Context.EmpCod, 0, FucCod)
	If insert and FucCod.IsEmpty() 
	on AfterValidate;
]]></Source>
