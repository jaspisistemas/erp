        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&MetCod);

NoAccept(ResCod);
NoAccept(MetCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
MetCod = &MetCod if not &MetCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Resultado Nome')) if ResNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Método Nome')) if MetNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


UltimoCodigoEmpresa.Call(domParCod.METODOCOB, &Context.EmpCod, 0, MetCod)If insert and MetCod.IsEmpty() on AfterValidate;


Serial(ResCod,MaxResCod,1);
]]></Source>
