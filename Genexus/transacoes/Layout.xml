      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
    [web]
    {
	EmpCod.Visible = False
	}

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

   [web]
   {
	Do Case
		Case &Mode = TrnMode.Insert
			&DetailWCInfo.Link = Layout.Link(TrnMode.Display, EmpCod, LayCod)
			GlobalEvents.SplitScreen_LoadDetail(SplitScreen_Action.RecordCreated, &DetailWCInfo, true, !'layout')
		Case &Mode = TrnMode.Update
			GlobalEvents.SplitScreen_LoadDetail(SplitScreen_Action.GoBack, &DetailWCInfo, true, !'layout')
		Case &Mode = TrnMode.Delete
			&DetailWCInfo.Link = Layout.Link(TrnMode.Display, EmpCod, LayCod)
			GlobalEvents.SplitScreen_LoadDetail(SplitScreen_Action.RecordDeleted, &DetailWCInfo, true, !'layout')
		Otherwise
			GlobalEvents.SplitScreen_LoadDetail(SplitScreen_Action.GoBack, &DetailWCInfo, false, !'layout')
	EndCase
   }

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Cancel'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

[web]
{
	GlobalEvents.SplitScreen_LoadDetail(SplitScreen_Action.GoBack, &DetailWCInfo, false, !'layout')
}

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
