	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEditarPropriedade'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Propriedades.Call(TrnMode.Update, EmpCod, PesPrpCod, &IsClientePropriedade, PesCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


