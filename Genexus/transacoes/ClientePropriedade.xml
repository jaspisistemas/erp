      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&PesCod, in:&PesPrpCod);

NoAccept(PesCod);
NoAccept(PesRaz);
NoAccept(PesCpf);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
PesCod = &PesCod if not &PesCod.IsEmpty();
PesPrpCod = &PesPrpCod if not &PesPrpCod.IsEmpty();
noaccept(PesPrpCod) if not &PesPrpCod.IsEmpty();

BtnEditarPropriedade.Visible = True If (&Mode <> TrnMode.insert);
BtnEditarPropriedade.Visible = False If not (&Mode <> TrnMode.insert);
Error(Format('WWP_RequiredAttribute','Pessoa')) if PesCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Propriedade')) if PesPrpCod.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
PesPrpIns = 'ISENTO' If PesPrpIns.IsEmpty() and after(PesPrpIns);
prcValidaInscricaoEstadual.Call(PesPrpIns, PesPrpCidUfeCod, &InsSimNao, PesPrpIns) 
	if not PesPrpIns.IsEmpty() and after(PesPrpIns);
error('Inscrição Estadual Inválida!') 
	if &InsSimNao = 'N' and not PesPrpIns.IsEmpty() and after(PesPrpIns);

Default(EmpCod, &Context.EmpCod);
Default(PesCod, &PesCod);

Prompt(PromptPropriedades,EmpCod,PesPrpCod);
]]></Source>
