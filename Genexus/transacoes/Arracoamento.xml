      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&ArrCod);

NoAccept(ArrCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
ArrCod = &ArrCod if not &ArrCod.IsEmpty();

ArrAloCod = &Insert_ArrAloCod if &Mode = TrnMode.Insert and not &Insert_ArrAloCod.IsEmpty();
noaccept(ArrAloCod) if &Mode = TrnMode.Insert and not &Insert_ArrAloCod.IsEmpty();
Accept(&IsRepetir);
Accept(&ToArrDta);
ArrQtdRac_Cell.Class = !'col-xs-12 DataContentCell' if not(ArrObs.Trim().IsEmpty());
ArrQtdRac_Cell.Class = !'col-xs-12 RequiredDataContentCell' if ArrObs.Trim().IsEmpty();
ArrObs_Cell.Class = !'col-xs-12 DataContentCell' if not(ArrQtdRac <=0);
ArrObs_Cell.Class = !'col-xs-12 RequiredDataContentCell' if ArrQtdRac <=0;
&ToArrDta.Visible = &IsRepetir = true;
ToArrDta_Cell.Class = !'Invisible' If not(&IsRepetir = true);
ToArrDta_Cell.Class = !'col-xs-12 DataContentCell' If &IsRepetir = true;
Error(Format('WWP_RequiredAttribute','Alojamento')) if ArrAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data')) if ArrDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Hora')) if ArrHor = NullValue(ArrHor);
Error(Format('WWP_RequiredAttribute','Produto')) if ArrProCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Ração')) if (ArrObs.Trim().IsEmpty()) AND ArrQtdRac.IsEmpty();
Error(Format('WWP_RequiredAttribute','Obs')) if (ArrQtdRac <=0) AND ArrObs.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
Default(EmpCod,&Context.EmpCod);
Default(ArrDta,ServerDate());
Default(ArrHor,ServerNow());
UltimoCodigoEmpresa.Call(domParCod.ARRACOAMENTO,EmpCod,0,ArrCod)If insert;
NoAccept(ArrFilCod) if ArrFilCod.Count <= 1;

ArrDtaHor = YMDHMStoT(year(ArrDta),month(ArrDta),day(ArrDta),Hour(ArrHor),Minute(ArrHor),0) If not ArrDta.IsEmpty() and not ArrHor.IsEmpty() 
	on AfterValidate;
]]></Source>
