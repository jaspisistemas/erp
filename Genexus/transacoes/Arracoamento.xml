      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWARRACOAMENTO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWARRACOAMENTO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated ArrAloCod
				Case &TrnContextAtt.AttributeName = !"ArrAloCod"
					&Insert_ArrAloCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	ArrCod.Visible = False
	ArrAloLin.Visible = False
	ArrProGraCod.Visible = False
	ArrGeo.Visible = False
	ArrAloLotCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&pesCod = &Context.PesCod

EndEvent

Event After Trn

	If &IsRepetir = true
		RepeteArracoamento.Call(EmpCod,ArrCod,ArrDta,ArrFilCod,ArrHor,ArrDtaHor,ArrProCod,ArrQtdRac,ArrPedCod,ArrTmp,ArrOxi,ArrObs,ArrAloCod,&IsRepetir,&ToArrDta)
	Endif

	If &Mode = TrnMode.Insert
		GravarPedidoArracoamento.call(EmpCod,ArrFilCod,ArrCod,ArrDta,ArrHor,ArrProCod,ArrQtdRac)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWArracoamento.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ToArrDta.Visible = False
	ToArrDta_Cell.Class = !'Invisible'
	ArrQtdRac_Cell.Class = !'col-xs-12 DataContentCell'
	ArrObs_Cell.Class = !'col-xs-12 DataContentCell'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
