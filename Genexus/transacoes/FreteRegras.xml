      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &Mode = TrnMode.Delete
		RetornaAutorizacao.Call('WWFRETEREGRAS', Status_SimNao.Sim, 3, &AutNiv)
	Else
		RetornaAutorizacao.Call('WWFRETEREGRAS', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'FRETEREGRAS')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&RFrtCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_FreteRegras.Call(&EmpCod, &RFrtCod, &SdtLogAtributos)
		
		prcCarregaLog_FreteRegrasTabelas.Call(&EmpCod, &RFrtCod, &FreteRegrasTabelas_SdtLogAtributosLevel)
		prcCarregaLog_FreteRegrasUf.Call(&EmpCod, &RFrtCod, &FreteRegrasUf_SdtLogAtributosLevel)
	Endif

EndEvent

Event After Trn

	if RFrtIsAllUF = true
		prcAtualizaTodosEstadosFrete.Call(EmpCod, RFrtCod)
	Endif

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_FreteRegras.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, RFrtCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
		
		prcGravaLog_FreteRegrasTabelas.Call(&Context.EmpCod, &Context.FilCod, RFrtCod, &Pgmname, &Context.UserName, &FreteRegrasTabelas_SdtLogAtributosLevel)
		prcGravaLog_FreteRegrasUf.Call(&Context.EmpCod, &Context.FilCod, RFrtCod, &Pgmname, &Context.UserName, &FreteRegrasUf_SdtLogAtributosLevel)
	Endif

	If RFrtIsAllTab = true
		FreteRegras.Link(Trnmode.Update, EmpCod, RFrtCod)
	Else
		WWFreteRegras.Link()
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
