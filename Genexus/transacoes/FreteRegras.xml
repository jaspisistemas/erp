      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&RFrtCod);

NoAccept(EmpCod);
NoAccept(RFrtCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
RFrtCod = &RFrtCod if not &RFrtCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','UF')) if RFrtUfeNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data Inicio')) if RFrtIniDta.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */



Default(EmpCod, &Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.REGRAFRETE, &Context.EmpCod, 0, RFrtCod)
	If insert and RFrtCod.IsEmpty() 
	on AfterValidate;
]]></Source>
