        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&RatCod);

NoAccept(RatCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
RatCod = &RatCod if not &RatCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Ramo Nome')) if RatNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod, &Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.RAMOATIVIDADE, EmpCod, 0, RatCod)
	If insert and RatCod.IsEmpty() 
	on AfterValidate;
]]></Source>
