      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CotCod, &PedCod);

NoAccept(EmpCod);
NoAccept(CotCod);
NoAccept(CotFilCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
CotCod = &CotCod if not &CotCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Transp.')) if CotTraCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Valor')) if CotVlr.IsEmpty();
Error(Format('WWP_RequiredAttribute','Transportadora')) if CotTraIs.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data')) if CotDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Hora')) if CotHor.IsEmpty();
Error(Format('WWP_RequiredAttribute','Pedido')) if CotPedCod.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.COTACAO, &Context.EmpCod, 0, CotCod)
	If insert and CotCod.IsEmpty() 
	on AfterValidate;

Default(CotFilCod, &Context.FilCod);
Default(CotPedCod, &PedCod);
NoAccept(CotPedCod) If not &PedCod.IsEmpty();
Default(CotDta, serverDate());
Default(CotHor, serverTime());

ValidaPedidoCotacao.Call(EmpCod, CotFilCod, CotPedCod, &mensagem) 
	if after(CotPedCod);

error(&mensagem) 
	if after(CotPedCod) and not &mensagem.IsEmpty();
	
FormataHora.Call(CotHor, CotHor) 
	if After(CotHor);

prompt(PromptTransportadora, &EmpCod, CotTraCod);
]]></Source>
