        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&TbImpFilCod);

NoAccept(TbImpFilCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
TbImpFilCod = &TbImpFilCod if not &TbImpFilCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Grupo Filial Imposto')) if TbImpFilNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tb Fil Reg Trib')) if TbFilRegTrib.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tb Imp Ufe Cod')) if TbImpUfeCod.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(EmpCod, &Context.EmpCod);

prcUltimoCodigoTabelaImpostoGrupo.Call(&Context.EmpCod, TbImpFilCod)
	If insert and TbImpFilCod.IsEmpty() 
	on AfterValidate;

tbOptante.Visible = (TbFilRegTribMun = opSimpNac.OptanteMeEpp);


error('Para empresas Simples Nacional, Obrigatório a informação dessa informação!') if TbFilRegTribMun = opSimpNac.OptanteMeEpp and TbFilRegTribSN = regApTribSN.NaoSelecionado;
]]></Source>
