 no Simples Nacional na data de competência informada na DPS." class="AttributeColorDanger" /></cell></row><row><cell><textblock controlName="TextBlock4" caption=" 2 - Uma ME/EPP deixará de apurar o ISSQN pelo Simples Nacional quando atribuir ao campo regAPTribSN os valores 2 ou 3, conforme leiaute DPS." class="AttributeColorDanger" /></cell></row></table></cell></row><row><cell cellClass="CellMarginTop10 DataContentCell DscTop"><data attribute="TbFilRegTribMunEsp" labelCaption="Regime de Apuração Especial Tributária pelo Simples Nacional" class="AttributeRealWidth" /></cell></row></table></group></cell></row></table></cell></row><row><cell><actiongroup controlName="ActionGroup_Actions" /></cell></row></table></cell></row><row><cell><html controlName="Html_BottomAuxiliarControls" formId="2" /></cell></row></table><actionGroups><actionGroup controlName="ActionGroup_Actions" class="CellMarginTop10"><item><action controlName="BtnTrn_Enter" onClickEvent="Enter" caption="GX_BtnEnter" class="Button" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;GX_BtnEnter&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></item><item><action controlName="BtnTrn_Cancel" onClickEvent="Cancel" caption="GX_BtnCancel" class="BtnDefault" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;GX_BtnCancel&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></item></actionGroup></actionGroups></layout></detail></Form><Form id="2" type="html"><BODY><gxAttribute ControlType="Edit" InputType="Values" AttID="EmpCod" /><gxAttribute ControlType="Edit" InputType="Values" AttID="TbImpFilCodNom" /></BODY></Form></GxMultiForm>]]></Source>
