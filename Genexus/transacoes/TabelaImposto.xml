ImpCatCod = &ImpCatCod if not &ImpCatCod.IsEmpty();
noaccept(ImpCatCod) if not &ImpCatCod.IsEmpty();

ImpCfoCod = &Insert_ImpCfoCod if &Mode = TrnMode.Insert and not &Insert_ImpCfoCod.IsEmpty();
noaccept(ImpCfoCod) if &Mode = TrnMode.Insert and not &Insert_ImpCfoCod.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
Default(EmpCod,&Context.EmpCod);
