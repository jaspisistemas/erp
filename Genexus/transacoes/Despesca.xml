      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		&OqueFazer = 'DEL'
		retornaAutorizacao.Call('WWDESPESCA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		&OqueFazer = 'INS'
		retornaAutorizacao.Call('WWDESPESCA', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated DspAloCod
				Case &TrnContextAtt.AttributeName = !"DspAloCod"
					&Insert_DspAloCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	DspHor.Visible = False
	DspQtd.Visible = False
	DspPsoMed.Visible = False
	DspQtdRes.Visible = False
	DspPsoMedRes.Visible = False
	DspBioMasRes.Visible = False
	DspAloUniProCod.Visible = False
	DspAloUniProNom.Visible = False
	DspAloLotCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PesCod = &Context.PesCod

EndEvent

Event After Trn

	AtualizaStatusAlojamento.Call(&OqueFazer,EmpCod,DspAloCod,DspAloUniProCod)
	&AloQtdMorLiq = RetornaSobraDespesca.Udp(EmpCod,DspAloCod)
	If DspEncAlo = Status_SimNao.Sim and &AloQtdMorLiq > 0
		WPDespescaAlojamento.Call(EmpCod,DspAloCod,&AloQtdMorLiq)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWDespesca.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
