      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&DspCod);

NoAccept(EmpCod);
NoAccept(DspCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
DspCod = &DspCod if not &DspCod.IsEmpty();

DspAloCod = &Insert_DspAloCod if &Mode = TrnMode.Insert and not &Insert_DspAloCod.IsEmpty();
noaccept(DspAloCod) if &Mode = TrnMode.Insert and not &Insert_DspAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Alojamento')) if DspAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data')) if DspDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Biomassa')) if DspBioMas.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Default(EmpCod,&Context.EmpCod);
Default(DspDta,serverDate());
Default(DspHor,serverNow());
UltimoCodigoEmpresa.Call(DomParCod.DESPESCA,EmpCod,0,DspCod)If insert and DspCod.IsEmpty() on AfterValidate;
NoAccept(DspFilCod) if DspFilCod.Count <= 1;
]]></Source>
