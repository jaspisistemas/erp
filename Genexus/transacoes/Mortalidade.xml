      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&MorCod);

NoAccept(MorCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
MorCod = &MorCod if not &MorCod.IsEmpty();

MorAloCod = &Insert_MorAloCod if &Mode = TrnMode.Insert and not &Insert_MorAloCod.IsEmpty();
noaccept(MorAloCod) if &Mode = TrnMode.Insert and not &Insert_MorAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Filial')) if MorFilCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Alojamento')) if MorAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Tipo')) if MorTip.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data')) if MorDta.IsEmpty();
Error(Format('WWP_RequiredAttribute','Qtde')) if MorQtd.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod,&Context.EmpCod);
Default(MorDta,ServerDate());
Default(MorDta,ServerDate());
MorUltAlt = serverNow();
UltimoCodigoEmpresa.Call(domParCod.MODALIDADE,EmpCod,0,MorCod)If insert;
NoAccept(MorFilCod) if MorFilCod.Count <= 1;

MorAloLin = MorAloLinAlo if MorAloLin = 0  on aftervalidate;
]]></Source>
