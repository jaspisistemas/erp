      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		&OqueFazer = 'DEL'
		retornaAutorizacao.Call('WWMORTALIDADE', Status_SimNao.Sim, 3, &AutNiv)
	Else
		&OqueFazer = 'INS'
		retornaAutorizacao.Call('WWMORTALIDADE', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated MorAloCod
				Case &TrnContextAtt.AttributeName = !"MorAloCod"
					&Insert_MorAloCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	MorCod.Visible = False
	MorAloLin.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PesCod = &Context.PesCod

EndEvent

Event After Trn

	AtualizaStatusAlojamento.call(&OqueFazer,EmpCod,MorAloCod,MorAloUniProCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWMortalidade.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
