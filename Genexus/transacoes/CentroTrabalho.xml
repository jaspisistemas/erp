        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CTrCod);

NoAccept(CTrCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
CTrCod = &CTrCod if not &CTrCod.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


UltimoCodigoEmpresa.Call(domParCod.CENTROTRABALHO, &Context.EmpCod, 0, CTrCod)
	If insert and CTrCod.IsEmpty() 
	on AfterValidate;


ValidaCentroTrabalhoUnico.Call(EmpCod, CTrCod, CTrNom, &Mensagem) 
	if After(CTrNom);

error(&Mensagem) 
	if After(CTrNom) and not &Mensagem.IsEmpty() and (insert or update);
]]></Source>
