        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&ProCod, in:&ProForCod);

EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
ProCod = &ProCod if not &ProCod.IsEmpty();
noaccept(ProCod) if not &ProCod.IsEmpty();
ProForCod = &ProForCod if not &ProForCod.IsEmpty();
noaccept(ProForCod) if not &ProForCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','QTD.Embalagem')) if ProForQtdEmb.IsEmpty();
Error(Format('WWP_RequiredAttribute','Produto')) if ProCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Codigo')) if ProForCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Fornecedor')) if ProForIs.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
]]></Source>
