        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPFORNECEDORPRODUTO', Status_SimNao.Sim, 3, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	ProForVlrIcm.TooltipText = "% Informados nesses Campos serão Utilizados no Lançamento do Pedido Compra"
	ProForIcm.TooltipText = "ICMS não soma do custo, utilizado somente para lançamento de Nota Fiscal de Compra."
	ProForVlrIpi.TooltipText = "% Informados nesses Campos serão Utilizados no Lançamento do Pedido Compra"
	ProForVlrIcmSt.TooltipText = "% Informados nesses Campos serão Utilizados no Lançamento do Pedido Compra"
	ProForVlrCus.TooltipText = "Custo do Produto sem os descontos/Impostos"
	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False
	ProForSts.Visible = False
	ProForIs.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

