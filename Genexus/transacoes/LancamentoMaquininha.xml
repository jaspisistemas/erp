        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&BanCarCod, in:&LanMaqCod);

NoAccept(EmpCod);
NoAccept(LanMaqCod);
NoAccept(BanCarNom);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
BanCarCod = &BanCarCod if not &BanCarCod.IsEmpty();
LanMaqCod = &LanMaqCod if not &LanMaqCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Lan Maq Data Importacao')) if LanMaqDataImportacao.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Bandeira')) if LanMaqBandeira.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Dta Venda')) if LanMaqDtaVenda.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Dta Pgto')) if LanMaqDtaPgto.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Frp')) if LanMaqFrp.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Comissao')) if LanMaqComissao.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Vlr Venda')) if LanMaqVlrVenda.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Vlr Descontado')) if LanMaqVlrDescontado.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Vlr Liquido')) if LanMaqVlrLiquido.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Nro Aut')) if LanMaqNroAut.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq NSU')) if LanMaqNSU.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Cartao Nom')) if LanMaqCartaoNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Cartao Nro')) if LanMaqCartaoNro.IsEmpty();
Error(Format('WWP_RequiredAttribute','Lan Maq Status')) if LanMaqStatus.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
]]></Source>
