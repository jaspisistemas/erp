      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&LcfCod);

NoAccept(LcfCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
LcfCod = &LcfCod if not &LcfCod.IsEmpty();
LcfPlanCod.Visible = LcfCreDeb = 'C' and (LcfCod = 1 or LcfCod = 13 or LcfCod = 14 or LcfCod = 15 or LcfCod = 22 or LcfCod = 23 or LcfCod = 24);
LcfPlanCod_Cell.Class = !'Invisible' If not(LcfCreDeb = 'C' and (LcfCod = 1 or LcfCod = 13 or LcfCod = 14 or LcfCod = 15 or LcfCod = 22 or LcfCod = 23 or LcfCod = 24));
LcfPlanCod_Cell.Class = !'col-xs-12 RequiredDataContentCell DscTop' If LcfCreDeb = 'C' and (LcfCod = 1 or LcfCod = 13 or LcfCod = 14 or LcfCod = 15 or LcfCod = 22 or LcfCod = 23 or LcfCod = 24);
LcfVlrPad.Visible = LcfCreDeb = 'C';
LcfVlrPad_Cell.Class = !'Invisible' If not(LcfCreDeb = 'C');
LcfVlrPad_Cell.Class = !'col-xs-12 DataContentCell DscTop' If LcfCreDeb = 'C';
Error(Format('WWP_RequiredAttribute','Descrição')) if LcfNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Plano de Conta')) if (LcfCreDeb = 'C' and (LcfCod = 1 or LcfCod = 13 or LcfCod = 14 or LcfCod = 15 or LcfCod = 22 or LcfCod = 23 or LcfCod = 24)) AND LcfPlanCod.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod, &Context.EmpCod);
Default(LcfCreDeb, 'C');

UltimoCodigoEmpresa.Call(domParCod.LANCAMENTOFOLHA, &Context.EmpCod, 0, LcfCod)If insert and LcfCod.IsEmpty() on AfterValidate;

NoAccept(LcfCreDeb) If &Mode = TrnMode.Update;
LcfNom.Enabled = false If LcfCod < 100 and update;
]]></Source>
