      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWOPERACAOFOLHA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWOPERACAOFOLHA', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&WebSession.Remove(!'EMPCOD')
	&WebSession.Remove(!'LCFCOD')
	&WebSession.Remove(!'LCFNOM')
	TableMain.Height = 450
	Do 'AttributesSecurityCode'

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

    &WebSession.Set(!'EMPCOD', EmpCod.ToString().Trim())
    &WebSession.Set(!'LCFCOD', LcfCod.ToString().Trim())
    &WebSession.Set(!'LCFNOM', LcfNom)
	
	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LcfPlanCod.Visible = False
	LcfPlanCod_Cell.Class = !'Invisible'
	LcfVlrPad_Cell.Class = !'col-xs-12 DataContentCell DscTop'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
