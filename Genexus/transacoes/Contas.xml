        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CtabanCod);

NoAccept(CtabanCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
CtabanCod = &CtabanCod if not &CtabanCod.IsEmpty();

CtaBanBanCod = &Insert_CtaBanBanCod if &Mode = TrnMode.Insert and not &Insert_CtaBanBanCod.IsEmpty();
noaccept(CtaBanBanCod) if &Mode = TrnMode.Insert and not &Insert_CtaBanBanCod.IsEmpty();
CtaBanBanCod.Visible = CtaBanTip = 'B';
CtaBanBanCod_Cell.Class = !'Invisible' If not(CtaBanTip = 'B');
CtaBanBanCod_Cell.Class = !'col-xs-12 RequiredDataContentCell' If CtaBanTip = 'B';
CtaBanMovFin.Visible = CtaBanBanCod = '999';
CtaBanMovFin_Cell.Class = !'Invisible' If not(CtaBanBanCod = '999');
CtaBanMovFin_Cell.Class = !'col-xs-12 DataContentCell' If CtaBanBanCod = '999';
CtaBanCrt.Visible = CtaBanTip = 'B' and CtaBanBanCod <> '999';
CtaBanCrt_Cell.Class = !'Invisible' If not(CtaBanTip = 'B' and CtaBanBanCod <> '999');
CtaBanCrt_Cell.Class = !'col-xs-12 RequiredDataContentCell' If CtaBanTip = 'B' and CtaBanBanCod <> '999';
CtaBanCrtDig.Visible = CtaBanTip = 'B';
CtaBanCrtDig_Cell.Class = !'Invisible' If not(CtaBanTip = 'B');
CtaBanCrtDig_Cell.Class = !'col-xs-12 DataContentCell' If CtaBanTip = 'B';
CtaBanAgeCod.Visible = CtaBanTip = 'B' and CtaBanBanCod <> '999';
CtaBanAgeCod_Cell.Class = !'Invisible' If not(CtaBanTip = 'B' and CtaBanBanCod <> '999');
CtaBanAgeCod_Cell.Class = !'col-xs-12 DataContentCell' If CtaBanTip = 'B' and CtaBanBanCod <> '999' AND Not(CtaBanTip = 'B'  and CtaBanBanCod <> '999');
CtaBanAgeCod_Cell.Class = !'col-xs-12 RequiredDataContentCell' If CtaBanTip = 'B' and CtaBanBanCod <> '999' AND (CtaBanTip = 'B'  and CtaBanBanCod <> '999');
CtaBanAgeDig.Visible = CtaBanTip = 'B';
CtaBanAgeDig_Cell.Class = !'Invisible' If not(CtaBanTip = 'B');
CtaBanAgeDig_Cell.Class = !'col-xs-12 DataContentCell' If CtaBanTip = 'B';
CtaBanNosNro.Visible = CtaBanTip = 'B';
CtaBanNosNro_Cell.Class = !'Invisible' If not(CtaBanTip = 'B');
CtaBanNosNro_Cell.Class = !'col-xs-12 DataContentCell' If CtaBanTip = 'B';
CtaBanPix.Visible = CtaBanTip = 'B';
CtaBanPix_Cell.Class = !'Invisible' If not(CtaBanTip = 'B');
CtaBanPix_Cell.Class = !'col-xs-12 DataContentCell' If CtaBanTip = 'B';
CtaMotCod.Visible = CtaBanTip = 'M';
CtaMotCod_Cell.Class = !'Invisible' If not(CtaBanTip = 'M');
CtaMotCod_Cell.Class = !'col-xs-12 DataContentCell' If CtaBanTip = 'M';
Error(Format('WWP_RequiredAttribute','Conta Bancária Nome')) if CtaBanNom.IsEmpty();
Error(Format('WWP_RequiredAttribute','Conta Bancária Filial Código')) if CtaBanFilCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Conta Bancária Tipo')) if CtaBanTip.IsEmpty();
Error(Format('WWP_RequiredAttribute','Conta Bancária Banco código')) if (CtaBanTip = 'B') AND CtaBanBanCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Conta Bancária Nro Conta')) if (CtaBanTip = 'B' and CtaBanBanCod <> '999') AND CtaBanCrt.IsEmpty();
Error(Format('WWP_RequiredAttribute','Conta Bancária Agência Código')) if (CtaBanTip = 'B'  and CtaBanBanCod <> '999') AND CtaBanAgeCod.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

UltimoCodigoEmpresa.Call(domParCod.CONTA, EmpCod, 0,CtabanCod) 
	If insert and CtabanCod.IsEmpty() 
	on AfterValidate;

]]></Source>
