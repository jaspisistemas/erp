      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWCONTAS', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWCONTAS', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	CtaBanAgeDig.TooltipText = "Código da agência ou Ponto atendimento no caso de cooperativas"
	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated CtaBanBanCod
				Case &TrnContextAtt.AttributeName = !"CtaBanBanCod"
					&Insert_CtaBanBanCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'Contabancaria'
	&pesCod = &Context.PesCod

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'CONTAS')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&CtabanCod = 0, Trnmode.Insert, Trnmode.Update))
		Call(prcCarregaLog_Contas, &EmpCod, &CtabanCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	AtualizaContaPadraoFuncionario.Call(&EmpCod, &CtabanCod)
	
	if &LogErpTabIsLog = true //GRAVA LOG
		Call(prcGravaLog_Contas, &LogErpRegTip, &Context.EmpCod, &Context.FilCod, CtabanCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWContas.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEditarContasFuncionario'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpContasFuncionario.PopUp(CtabanCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInfoCertificado'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WpAjudaConversao.PopUp('AjudaConversao', 'StepOne', False)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CtaBanBanCod.Visible = False
	CtaBanBanCod_Cell.Class = !'Invisible'
	CtaBanMovFin.Visible = False
	CtaBanMovFin_Cell.Class = !'Invisible'
	CtaBanCrt.Visible = False
	CtaBanCrt_Cell.Class = !'Invisible'
	CtaBanCrtDig.Visible = False
	CtaBanCrtDig_Cell.Class = !'Invisible'
	CtaBanAgeCod.Visible = False
	CtaBanAgeCod_Cell.Class = !'Invisible'
	CtaBanAgeDig.Visible = False
	CtaBanAgeDig_Cell.Class = !'Invisible'
	CtaBanNosNro.Visible = False
	CtaBanNosNro_Cell.Class = !'Invisible'
	CtaBanPix.Visible = False
	CtaBanPix_Cell.Class = !'Invisible'
	CtaMotCod.Visible = False
	CtaMotCod_Cell.Class = !'Invisible'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Contabancaria'

	CtaBanMovFin.Clear()
	CtaBanMovFin.AddItem(0, 'CONTA NAO INFORMADA')
	&SdtContaBancaria = dpContaBancariaNomeFilial_EmpCod.Udp(&Context.EmpCod, &Context.PesCod, &Context.FilCod)
	For &SdtContaBancariaItem in &SdtContaBancaria
		CtaBanMovFin.AddItem(&SdtContaBancariaItem.CtabanCod, &SdtContaBancariaItem.CtaBanCodNom)

	EndFor

EndSub


]]></Source>
