        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FicCod);

NoAccept(FicCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FicCod = &FicCod if not &FicCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nome Ficha')) if FicNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */



Default(EmpCod, &Context.EmpCod);
UltimoCodigoEmpresa.Call(domParCod.FICHA, EmpCod, 0, FicCod)
	If insert and FicCod.IsEmpty() 
	on AfterValidate;


VerificaCodigoUnicoFicha.Call(EmpCod, FicCod, FicBar, &RepetidoEanMensagem) 
	if After(FicBar) and not FicBar.IsEmpty();

error(&RepetidoEanMensagem) 
	if After(FicBar) and (not FicBar.IsEmpty()) and (not &RepetidoEanMensagem.IsEmpty());

]]></Source>
