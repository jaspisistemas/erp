        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&PedCod);

NoAccept(PedComAut);
NoAccept(EmpCod);
NoAccept(FilCod);
NoAccept(PedCod);
NoAccept(PedCliCod);
NoAccept(PedVenCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
PedCod = &PedCod if not &PedCod.IsEmpty();

PedCliCod = &Insert_PedCliCod if &Mode = TrnMode.Insert and not &Insert_PedCliCod.IsEmpty();
PedVenCod = &Insert_PedVenCod if &Mode = TrnMode.Insert and not &Insert_PedVenCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Ped Com Esp Ven Cod')) if PedComEspVenCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Vendedor')) if PedComIsVen.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


prompt(PromptVendedor, EmpCod, PedComEspVenCod);
Default(PedComAut, Status_SimNao.Nao);
]]></Source>
