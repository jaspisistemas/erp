      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	GridLevel_PedVen.Rows = 2
	RetornaAutorizacao.Call('VENDACOMISSAOEXTRA', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated PedCliCod
				Case &TrnContextAtt.AttributeName = !"PedCliCod"
					&Insert_PedCliCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated PedVenCod
				Case &TrnContextAtt.AttributeName = !"PedVenCod"
					&Insert_PedVenCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'PEDIDOCOMISSAO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		prcCarregaLog_Pedidocomissao.Call(&EmpCod, &FilCod, &PedCod, &SdtLogAtributosLevel)
	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_PedidoComissao.Call(&Context.EmpCod, &Context.FilCod, PedCod, &Pgmname, &Context.UserName, &SdtLogAtributosLevel)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
