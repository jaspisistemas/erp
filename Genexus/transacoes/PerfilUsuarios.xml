      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWPERFILUSUARIOS', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWPERFILUSUARIOS', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	
	EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'GRUPOAUTORIZACAO')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&AutGrpCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_GrupoAutorizacao.Call(&EmpCod, &AutGrpCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_GrupoAutorizacao.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, AutGrpCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
