        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&AutGrpCod);

NoAccept(AutGrpCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
AutGrpCod = &AutGrpCod if not &AutGrpCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Descrição')) if AutGrpNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


UltimoCodigoEmpresa.Call(domParCod.GRUPOAUTORIZACAO, EmpCod, 0, AutGrpCod)
	If insert and AutGrpCod.IsEmpty() 
	on AfterValidate;
]]></Source>
