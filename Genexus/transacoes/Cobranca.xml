        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&FilCod, in:&CreCod);

EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
FilCod = &FilCod if not &FilCod.IsEmpty();
noaccept(FilCod) if not &FilCod.IsEmpty();
CreCod = &CreCod if not &CreCod.IsEmpty();
noaccept(CreCod) if not &CreCod.IsEmpty();

CreCliCod = &Insert_CreCliCod if &Mode = TrnMode.Insert and not &Insert_CreCliCod.IsEmpty();
noaccept(CreCliCod) if &Mode = TrnMode.Insert and not &Insert_CreCliCod.IsEmpty();
CreVenCod = &Insert_CreVenCod if &Mode = TrnMode.Insert and not &Insert_CreVenCod.IsEmpty();
noaccept(CreVenCod) if &Mode = TrnMode.Insert and not &Insert_CreVenCod.IsEmpty();
CreCbrCod = &Insert_CreCbrCod if &Mode = TrnMode.Insert and not &Insert_CreCbrCod.IsEmpty();
noaccept(CreCbrCod) if &Mode = TrnMode.Insert and not &Insert_CreCbrCod.IsEmpty();
CrePedCod = &Insert_CrePedCod if &Mode = TrnMode.Insert and not &Insert_CrePedCod.IsEmpty();
noaccept(CrePedCod) if &Mode = TrnMode.Insert and not &Insert_CrePedCod.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
]]></Source>
