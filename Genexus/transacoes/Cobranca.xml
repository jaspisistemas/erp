      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWCOBRANCA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWCOBRANCA', Status_SimNao.Sim, 2, &AutNiv)
	EndIf
	&HjCreDtaCob = serverdate() - 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated CreCliCod
				Case &TrnContextAtt.AttributeName = !"CreCliCod"
					&Insert_CreCliCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated CreVenCod
				Case &TrnContextAtt.AttributeName = !"CreVenCod"
					&Insert_CreVenCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated CreCbrCod
				Case &TrnContextAtt.AttributeName = !"CreCbrCod"
					&Insert_CreCbrCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated CrePedCod
				Case &TrnContextAtt.AttributeName = !"CrePedCod"
					&Insert_CrePedCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	CreCliRaz.Visible = False
	CreCliCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWCobranca.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
