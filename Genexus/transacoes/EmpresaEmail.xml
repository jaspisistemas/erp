      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWEMPRESAEMAIL', Status_SimNao.Sim, 3, &AutNiv)
	

	[web]
	{
		Msgtt.ForeColor = RGB(0,0,150)
	}

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	[web]
	{
	EmpEmlHos.TooltipText = "Nome do servidor de SMTP"
	&auxEmpEmlSen.TooltipText = "Senha do E-Mail."
	EmpEmlUsr.TooltipText = "Usuário ou E-Mail de Login."
	EmpEmlTip.TooltipText = "É possível cadastrar Uma conta de E-Mail para cada Tipo de Documento à Enviar."
	EmpEml.TooltipText = "Caso não possua um e-mail próprio para envio utilize o [nao_responda@jaspi.com.br]"
	}
	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
    [web]
    {
	EmpCod.Visible = False
	EmpEmlCod.Visible = False
	EmpEmlSen.Visible = False
	If &Mode = TrnMode.Insert
		&EmpresaEmailCopyRecordXml = &WebSession.Get(!'EmpresaEmailCopyRecord')
		If &EmpresaEmailCopyRecordXml.Trim() <> ''
			&EmpresaEmailCopyRecord.FromXml(&EmpresaEmailCopyRecordXml)
			&WebSession.Remove(!'EmpresaEmailCopyRecord')
			&EmpCodInitialValue =  &EmpresaEmailCopyRecord.EmpCod
			&EmpEmlCodInitialValue =  &EmpresaEmailCopyRecord.EmpEmlCod
			&EmpEmlInitialValue =  &EmpresaEmailCopyRecord.EmpEml
			&EmpEmlTipInitialValue =  &EmpresaEmailCopyRecord.EmpEmlTip
			&EmpEmlAutInitialValue =  &EmpresaEmailCopyRecord.EmpEmlAut
			&EmpEmlSecInitialValue =  &EmpresaEmailCopyRecord.EmpEmlSec
			&EmpEmlHosInitialValue =  &EmpresaEmailCopyRecord.EmpEmlHos
			&EmpEmlUsrInitialValue =  &EmpresaEmailCopyRecord.EmpEmlUsr
			&EmpEmlSenInitialValue =  &EmpresaEmailCopyRecord.EmpEmlSen
			&EmpEmlPorInitialValue =  &EmpresaEmailCopyRecord.EmpEmlPor
			&EmpEmlCnfInitialValue =  &EmpresaEmailCopyRecord.EmpEmlCnf
			&EmpEmlImapHosInitialValue =  &EmpresaEmailCopyRecord.EmpEmlImapHos
			&EmpEmlImapPorInitialValue =  &EmpresaEmailCopyRecord.EmpEmlImapPor
			&EmpEmlImapSslInitialValue =  &EmpresaEmailCopyRecord.EmpEmlImapSsl
		EndIf
	EndIf         
	}

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If not &EmpEmlSenInitialValue.IsEmpty()
		&Key = RetornaKeyCryptografia.UDP('EMAIL')
		&auxEmpEmlSen = Decrypt64(&EmpEmlSenInitialValue, &Key)
	Else
		If &EmpEmlCod <> 0
			DecryptSenhaEmail.Call(&EmpCod, &EmpEmlCod, '', &auxEmpEmlSen)
		EndIF
	EndIF
	
	&EmpCodInitialValue = &Context.EmpCod
	&EmpEmlCodInitialValue = 0
	
	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'EMPRESAEMAIL')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&EmpEmlCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_EmpresaEmail.Call(&EmpCod, &EmpEmlCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	CryptografaSenhaEmail.Call(EmpCod, EmpEmlCod, &auxEmpEmlSen)

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_EmpresaEmail.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, EmpEmlCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

   [web]
   {
	
	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWEmpresaEmail.Call()
	Endif

	Return
   }

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

[web]
{
	EmpEmlHos_Cell.Class = !'col-xs-12 DataContentCell'
	EmpEmlPor_Cell.Class = !'col-xs-12 DataContentCell'
	EmpEmlUsr.Visible = False
	EmpEmlUsr_Cell.Class = !'Invisible'
	&auxEmpEmlSen.Visible = False
	auxEmpEmlSen_Cell.Class = !'Invisible'
	
	DVPanel_tbConfigura_Cell.Class = !'col-xs-12 CellMarginTop'
}

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
