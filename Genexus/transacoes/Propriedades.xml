      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWPROPRIEDADES', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWPROPRIEDADES', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	PrpFrmLav.TooltipText = "Propriedade Apta a formação de lavoura?"
	Do 'AttributesSecurityCode'

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated PrpEndCidCod
				Case &TrnContextAtt.AttributeName = !"PrpEndCidCod"
					&Insert_PrpEndCidCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	PrpRotVis.Visible = False
	PrpTotTal.Visible = False
	EmpCod.Visible = False
	&PesCidCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaConfSistema.Call(&WWPContext.EmpCod, &WWPContext.FilCod, domConfSistema.TCon126_ObrigatorioEnderecoPropriedade, &Obrigatorioendereco)
	&Possuimoduloagro_insumos  = RetornaEmpresaModulo.Udp(&WWPContext.EmpCod, ModuloSistema.AGRO_INSUMOS)
	
	RetornaCidadeCepFilial.call(&Context.EmpCod, &Context.FilCod, &FilCidCod, &FilCep)
	PrpNom.SetFocus()
	ConsultaSintegra.LinkTarget = '_blank'
	ConsultaSintegra.Link = 'http://www.sintegra.fazenda.pr.gov.br/sintegra/'

EndEvent

Event After Trn

	if &Mode = TrnMode.Update and &PesCod <> 0
		//ATUALIZA CAD-PRO DAS NOTAS
		AtualizaCadProNotasDigitacao.Call(EmpCod,&PesCod,PrpIns)
	EndIf

	if &IsClientePropriedade <> true or &PesCod = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWPropriedades.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		//GRAVA CLIENTE PROPRIEDADE
		GravaClientePropriedade.call(EmpCod, PrpCod, &PesCod)
		//REDIRECIONA ALTERACAO
		ClientePropriedade.Link(Trnmode.Update, EmpCod, &PesCod, PrpCod)
	Endif

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	PrpEndCep_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop'
	PrpEnd_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop'
	PrpEndNro_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop'
	PrpEndBai_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop'
	PrpEndCidCod_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop'
	PrpEndDen_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
