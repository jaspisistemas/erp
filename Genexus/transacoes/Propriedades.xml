parm(in:&Mode, in:&EmpCod, in:&PrpCod, &IsClientePropriedade, &PesCod);

NoAccept(PrpTalCod);
NoAccept(PrpCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
PrpCod = &PrpCod if not &PrpCod.IsEmpty();

PrpEndCidCod = &Insert_PrpEndCidCod if &Mode = TrnMode.Insert and not &Insert_PrpEndCidCod.IsEmpty();
noaccept(PrpEndCidCod) if &Mode = TrnMode.Insert and not &Insert_PrpEndCidCod.IsEmpty();
PrpEndCep_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop' if not(&Obrigatorioendereco <> 'N');
PrpEndCep_Cell.Class = !'col-xs-12 col-sm-4 RequiredDataContentCell DscTop' if &Obrigatorioendereco <> 'N';
PrpEnd_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop' if not(&Obrigatorioendereco <> 'N');
PrpEnd_Cell.Class = !'col-xs-12 col-sm-4 RequiredDataContentCell DscTop' if &Obrigatorioendereco <> 'N';
PrpEndNro_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop' if not(&Obrigatorioendereco <> 'N');
PrpEndNro_Cell.Class = !'col-xs-12 col-sm-4 RequiredDataContentCell DscTop' if &Obrigatorioendereco <> 'N';
PrpEndBai_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop' if not(&Obrigatorioendereco <> 'N');
PrpEndBai_Cell.Class = !'col-xs-12 col-sm-4 RequiredDataContentCell DscTop' if &Obrigatorioendereco <> 'N';
PrpEndCidCod_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop' if not(&Obrigatorioendereco <> 'N');
PrpEndCidCod_Cell.Class = !'col-xs-12 col-sm-4 RequiredDataContentCell DscTop' if &Obrigatorioendereco <> 'N';
PrpEndDen_Cell.Class = !'col-xs-12 col-sm-4 DataContentCell DscTop' if not(&Obrigatorioendereco <> 'N');
PrpEndDen_Cell.Class = !'col-xs-12 col-sm-4 RequiredDataContentCell DscTop' if &Obrigatorioendereco <> 'N';
tbInsumos.Visible = (&Possuimoduloagro_insumos = 'S');
Error(Format('WWP_RequiredAttribute','Cep')) if (&Obrigatorioendereco <> 'N') AND PrpEndCep.IsEmpty();
Error(Format('WWP_RequiredAttribute','Endereço')) if (&Obrigatorioendereco <> 'N') AND PrpEnd.IsEmpty();
Error(Format('WWP_RequiredAttribute','Número')) if (&Obrigatorioendereco <> 'N') AND PrpEndNro.IsEmpty();
Error(Format('WWP_RequiredAttribute','Bairro')) if (&Obrigatorioendereco <> 'N') AND PrpEndBai.IsEmpty();
Error(Format('WWP_RequiredAttribute','Cidade')) if (&Obrigatorioendereco <> 'N') AND PrpEndCidCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Denominação')) if (&Obrigatorioendereco <> 'N') AND PrpEndDen.IsEmpty();
Error(Format('WWP_RequiredAttribute','Nome')) if PrpNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(PrpSts, Status_Propriedade.Ativa);
Default(PrpEndCep,&FilCep);
Default(PrpEndCidCod,&FilCidCod);
UltimoCodigoEmpresa.Call(domParCod.PROPRIEDADE, EmpCod, 0,PrpCod) 
	If insert and PrpCod.IsEmpty()	on AfterValidate;

FormataCEP.Call(PrpEndCep, PrpEndCep);
Prompt(PromptVendedor,EmpCod,PrpVenCodIns);
Prompt(PromptCidadeVarchar, EmpCod, &PesCidCod, PrpEndCidCod);

PrpEndNro = 'S/N' If PrpEndNro.IsEmpty() and after(PrpEndNro);
PrpEndBai = 'ZONA RURAL' If PrpEndBai.IsEmpty() and after(PrpEndBai);
PrpIns = 'ISENTO' If PrpIns.IsEmpty() and after(PrpIns);
RetornaSoNumeros.call(PrpIns,PrpIns) if Not PrpIns.IsEmpty() and after(PrpEndDen) and  PrpIns <> 'ISENTO'; 
ValidaCADPRORepetido.call(EmpCod,PrpIns,&Mensg,&IsErro)  If Insert and  Not PrpIns.IsEmpty() and  PrpIns <> 'ISENTO' and after(PrpIns);  
Error(&Mensg) iF &IsErro = TRUE and  PrpIns <> 'ISENTO' and insert;

prcValidaInscricaoEstadual.Call(PrpIns, PrpEndCidUfeCod, &InsSimNao, PrpIns) if not PrpIns.IsEmpty() and PrpIns <> 'ISENTO' and after(PrpIns);
Error('Inscrição Estadual Inválida!')if &InsSimNao = 'N' and not PrpIns.IsEmpty() and after(PrpIns);

Serial(PrpTalCod,PrpTotTal,1);
]]></Source>
