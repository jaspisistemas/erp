      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWDECLARACAOEXPORTACAO', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWDECLARACAOEXPORTACAO', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	If (&TrnContext.TransactionName = &Pgmname and &Mode = TrnMode.Insert)
		For &TrnContextAtt in &TrnContext.Attributes
			Do Case
				// When inserting with instantiated DecFilCod
				Case &TrnContextAtt.AttributeName = !"DecFilCod"
					&Insert_DecFilCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated DecPrcProCod
				Case &TrnContextAtt.AttributeName = !"DecPrcProCod"
					&Insert_DecPrcProCod.FromString(&TrnContextAtt.AttributeValue)
				// When inserting with instantiated DecFunCod
				Case &TrnContextAtt.AttributeName = !"DecFunCod"
					&Insert_DecFunCod.FromString(&TrnContextAtt.AttributeValue)
			Endcase
		Endfor
	Endif
	
	EmpCod.Visible = False
	DecPedFiLCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	gridLevel_EstadosPartes.Rows = 2
	gridLevel_TerceiroPaises.Rows = 2
	gridLevel_Elementos.Rows = 2
	gridPro.Rows = 2

EndEvent

Event After Trn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWDeclaracaoExportacao.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
