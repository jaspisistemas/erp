        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&DecCod);

NoAccept(DecTerItmCod);
NoAccept(DecMatItmCod);
NoAccept(DecNcmItmCod);
NoAccept(EmpCod);
NoAccept(DecCod);
NoAccept(DecPedFiLCod);
NoAccept(DecPrcProCod);
Prompt(PromptProcessoProdutivo, EmpCod, DecPrcProCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
DecCod = &DecCod if not &DecCod.IsEmpty();

DecFilCod = &Insert_DecFilCod if &Mode = TrnMode.Insert and not &Insert_DecFilCod.IsEmpty();
noaccept(DecFilCod) if &Mode = TrnMode.Insert and not &Insert_DecFilCod.IsEmpty();
DecPrcProCod = &Insert_DecPrcProCod if &Mode = TrnMode.Insert and not &Insert_DecPrcProCod.IsEmpty();
DecFunCod = &Insert_DecFunCod if &Mode = TrnMode.Insert and not &Insert_DecFunCod.IsEmpty();
noaccept(DecFunCod) if &Mode = TrnMode.Insert and not &Insert_DecFunCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Emissao')) if DecDta.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
prompt(PromptFuncionario, EmpCod, DecFunCod);
Default(DecPedFiLCod, &Context.FilCod);
Default(EmpCod, &Context.EmpCod);

UltimoCodigoEmpresa.Call(domParCod.DECLARAPRODUTO, &Context.EmpCod,  0, DecCod)
	If insert and DecCod.IsEmpty() 
	on AfterValidate;

Serial(DecNcmItmCod, DecNcmUltCod, 1);
Serial(DecMatItmCod, DecMatUltCod, 1);
Serial(DecTerItmCod, DecTerUltCod, 1);


prompt(PromptNCM, DecNcmCod);





]]></Source>
