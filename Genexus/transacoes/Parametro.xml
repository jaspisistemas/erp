        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&ParSeq);

EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
ParSeq = &ParSeq if not &ParSeq.IsEmpty();
noaccept(ParSeq) if not &ParSeq.IsEmpty();
Error(Format('WWP_RequiredAttribute','Parâmetro')) if ParCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Parâmetro Nome')) if ParNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod, &Context.EmpCod);

UltimoParametro.Call(&Context.EmpCod, ParSeq)
	If insert and ParSeq.IsEmpty() 
	on AfterValidate;
]]></Source>
