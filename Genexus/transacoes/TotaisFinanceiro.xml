        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&PlanCod, in:&FinAno, in:&FinMes);

NoAccept(FinForCod4);
NoAccept(FinForCod3);
NoAccept(FinForCod2);
NoAccept(FinForCod1);
NoAccept(PlanNom);
NoAccept(FinAno);
NoAccept(FinMes);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
PlanCod = &PlanCod if not &PlanCod.IsEmpty();
noaccept(PlanCod) if not &PlanCod.IsEmpty();
FinAno = &FinAno if not &FinAno.IsEmpty();
FinMes = &FinMes if not &FinMes.IsEmpty();
Error(Format('WWP_RequiredAttribute','Valor')) if FinVlr.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

FinForCod1 = &PesCod1 if &PesCod1 > 0;
FinForCod2 = &PesCod2 if &PesCod2 > 0;
FinForCod3 = &PesCod3 if &PesCod3 > 0;
FinForCod4 = &PesCod4 if &PesCod4 > 0;

error('Percentual Total deve ser 100% ou 0%') 
	if FinTotPer > 0 and FinTotPer < 100;

&FintotPer = FinForPer1 + FinForPer2 + FinForPer3 + FinForPer4;
]]></Source>
