        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWEMPRESAIMPRESSORA', Status_SimNao.Sim, 3, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&TrnContext.FromXml(&WebSession.Get(!"TrnContext"))
	
	EmpCod.Visible = False
	EmpImpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//GRAVAR LOG
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'EMPRESAIMPRESSORA')
	if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
		&LogErpRegTip = iif(&Mode = TrnMode.Delete, TrnMode.Delete, iif(&EmpImpCod = 0, Trnmode.Insert, Trnmode.Update))
		prcCarregaLog_EmpresaImpressora.Call(&EmpCod, &EmpImpCod, &SdtLogAtributos)
	Endif

EndEvent

Event After Trn

	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_EmpresaImpressora.Call(&LogErpRegTip, &Context.EmpCod, &Context.FilCod, EmpImpCod, &Pgmname, &Context.UserName, &SdtLogAtributos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&Mode = TrnMode.Delete and not &TrnContext.CallerOnDelete)
		WWEmpresaImpressora.Call()
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


