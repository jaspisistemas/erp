        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&EmpImpCod);

EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
EmpImpCod = &EmpImpCod if not &EmpImpCod.IsEmpty();
noaccept(EmpImpCod) if not &EmpImpCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','PC')) if EmpImpPC.IsEmpty();
Error(Format('WWP_RequiredAttribute','Impressora')) if EmpImpNom.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Default(EmpCod, &Context.EmpCod);

UltimoCodigoEmpresa.Call(domParCod.IMPRESSORA, &Context.EmpCod, 0, EmpImpCod)
	If insert and EmpImpCod.IsEmpty() 
	on AfterValidate;
	
]]></Source>
