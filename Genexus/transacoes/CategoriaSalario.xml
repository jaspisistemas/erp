        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&CatSalCod);

NoAccept(CatSalItmCod);
NoAccept(CatSalCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
CatSalCod = &CatSalCod if not &CatSalCod.IsEmpty();

Error(Format('WWP_RequiredAttribute','Item Data Inicial')) if CatSalItmDtaIni.IsEmpty();
Error(Format('WWP_RequiredAttribute','Valor Salario')) if CatSalItmVlr.IsEmpty();
Error(Format('WWP_RequiredAttribute','Categoria Descrição')) if CatSalNom.IsEmpty();
Default(EmpCod,&context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

UltimoCodigoEmpresa.Call(domParCod.CATEGORIASALARIO, &Context.EmpCod, 0, CatSalCod)
	If insert and CatSalCod.IsEmpty() 
	on AfterValidate;

Serial(CatSalItmCod, CatSalUltCod, 1);
]]></Source>
