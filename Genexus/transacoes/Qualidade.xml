      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&QuaCod);

NoAccept(QuaCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
QuaCod = &QuaCod if not &QuaCod.IsEmpty();

QuaAloCod = &Insert_QuaAloCod if &Mode = TrnMode.Insert and not &Insert_QuaAloCod.IsEmpty();
noaccept(QuaAloCod) if &Mode = TrnMode.Insert and not &Insert_QuaAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Qua Alo Cod')) if QuaAloCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Data')) if QuaDta.IsEmpty();
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */
Default(EmpCod,&Context.EmpCod);
Default(QuaDta,ServerDate());
Default(QuaHor,ServerNow());
UltimoCodigoEmpresa.Call(domParCod.QUALIDADE,EmpCod,0,QuaCod)If insert;
]]></Source>
