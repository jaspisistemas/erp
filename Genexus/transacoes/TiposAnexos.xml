        <Source><![CDATA[/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */
parm(in:&Mode, in:&EmpCod, in:&TpaCod);

NoAccept(TpaCod);
EmpCod = &EmpCod if not &EmpCod.IsEmpty();
noaccept(EmpCod) if not &EmpCod.IsEmpty();
TpaCod = &TpaCod if not &TpaCod.IsEmpty();
Error(Format('WWP_RequiredAttribute','Descrição')) if TpaNom.IsEmpty();
Default(EmpCod,&Context.EmpCod);
/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

UltimoCodigoEmpresa.Call(domParCod.TIPOANEXOS, &Context.EmpCod, 0, TpaCod)
	If insert and TpaCod.IsEmpty() 
	on AfterValidate;


ValidaTiposAnexosUnico.Call(&EmpCod, &TpaCod, TpaNom, &Mensagem) 
	if After(TpaNom);

error(&Mensagem) 
	if After(TpaNom) and not &Mensagem.IsEmpty() and (insert or update);
]]></Source>
