      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPSUGESTAOCOMPRAINFORMADA', Status_SimNao.Sim, 1, &AutNiv)
	
	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ImprimirSemFonecedor = True
	Do 'getMarca'
	do 'Cliente'

EndEvent

Event 'DoAjuda'

	innewWindow.Target = 'https://ajuda.jaspi.com.br/index.aspx?db211cc1-b68b-4728-acf6-dfd02b9622ea'
	inNewWindow.Name = '_blank'
	innewWindow.OpenWindow()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	do 'Cliente'

EndEvent

Event &PesCod.IsValid

	do 'Cliente'

EndEvent

Event Enter

	do 'Cliente'
	RCOOpenWindow1.LinkOpen = RELJAS117.Link(&PesCod, &GrupHie,&MarCod,&MarNom,&ProSetCod, &AbaixoAcimaEstoque, &Ordem, &ImprimirSomentePadrao, &ImprimirSemFonecedor)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event &MarCod.IsValid

	Do 'getMarca'

EndEvent

Sub 'Cliente'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesRaz = PesRaz
		Exit
	When None
		If &PesCod <> 0
			&PesRaz = 'FORNECEDOR NÃO LOCALIZADO'
		Else
			&PesRaz = 'TODOS OS FORNECEDORES'
		EndIF
	EndFor

EndSub

Sub 'getMarca'

	If &MarCod = 0
		&MarNom = 'Todas as marcas'
	Else
		For each Order EmpCod,MarCod
			Where EmpCod = &EmpCod
			Where MarCod = &MarCod
			&MarNom = MarNom
			Exit
		When none
			&MarNom = 'Marca não encontrada'
			msg('Marca não encontrada')
			&MarCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
