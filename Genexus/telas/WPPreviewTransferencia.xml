      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do 'TransIdentifica'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'TransIdentifica'

	&IsDestino = False
	&IsOrigem = False
	For each Order EmpCod,MovCod,MovCreDeb
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		Where MovCreDeb = 'D'
		&DstMovCod    = MovCod
		&DstMovDta    = MovDta
		&DstMovCtaBanNom = MovCtaBanNom
		&DstMovDoc    = MovDoc
		&DstMovDtaCon = MovDtaCon
		&DstPlanCod   = PlanCod
		&DstMovVlr    = MovVlr
		&DstMovItmCpl = MovItmCpl
		&MovTrnOriCod = MovTrnOriCod
		&MovTrnOriCodItm = MovTrnOriCodItm
		&IsDestino = true
	When none
		For each Order EmpCod,MovCod,MovCreDeb
			Where EmpCod = &EmpCod
			Where MovCod = &MovCod
			Where MovCreDeb = 'C'
			&OriMovCod    = MovCod
			&OriMovDta    = MovDta
			&OriMovCtaBanNom = MovCtaBanNom
			&OriMovDoc    = MovDoc
			&OriMovDtaCon = MovDtaCon
			&OriMovVlr    = MovVlr
			&OriPlanCod    = PlanCod
			&OriMovItmCpl = MovItmCpl
			&IsOrigem = True
			&OriMovTrnOriCod = MovTrnOriCod
			&OriMovTrnOriCodItm = MovTrnOriCodItm
		EndFor		
	EndFor
	
	If &IsDestino = true
		Do 'TransOrigem'
	Else
		DO 'TransDestino'
	EndiF

EndSub

Sub 'TransOrigem'

	For each Order EmpCod,MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovTrnOriCod
		&OriMovCod    = MovCod
		&OriMovDta    = MovDta
		&OriMovCtaBanNom = MovCtaBanNom
		&OriMovDoc    = MovDoc
		&OriMovDtaCon = MovDtaCon
		&OriMovVlr    = MovVlr
		&OriPlanCod    = PlanCod
		&OriMovItmCpl = MovItmCpl
	EndFor

EndSub

Sub 'TransDestino'

	For each Order EmpCod,MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &OriMovTrnOriCod
		&DstMovCod    = MovCod
		&DstMovDta    = MovDta
		&DstMovCtaBanNom = MovCtaBanNom
		&DstMovDoc    = MovDoc
		&DstMovDtaCon = MovDtaCon
		&DstMovVlr    = MovVlr
		&DstPlanCod    = PlanCod
		&DstMovItmCpl = MovItmCpl
	EndFor

EndSub


]]></Source>
