      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&tmpNfeEnvEml = true
	&xJust = 'CONHECIMENTO DE TRANSPORTE EMITIDO COM DIVERGENCIA DE INFORMACOES, CANCELAMENTO SOLICITADO'
	TableFinanceiro.Visible = false
	&tmpCancelarDuplicatas = False

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&FilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CteRemRaz = trim(str(CteRemCod)) + ' - ' + trim(CteRemRaz)
		&CteNum = CteNum
		&CteDtaEms = CteDtaEms
		&FilCodNom = FilCodNom
		&CteVlrRecSer = CteVlrRecSer
		&CteChv = CteChv
		&CteAutNumPro = CteAutNumPro
		
		If not CteRemEml.IsEmpty()
			&PesEml  = CteRemEml
		EndIF
		
		If CteChv.IsEmpty()
			msg('CTe não possui a chave da CTe.')
		EndIF
		
		For each Order EmpCod, FilCod, CteCod,CteDupCod
			TableFinanceiro.Visible = true
			&tmpCancelarDuplicatas = true
			exit
		EndFor
		
		Exit
	EndFor

	
	obs.ForeColor = RGB(0,0,150)

EndEvent

Event 'DoConfirmar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	If &DeOndeVem = 'WWCTE'
		WWCte.Link()
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	loadWWPContext.Call(&Context)
	Do 'Verifica_especial'
	
	Do Case
		Case &CteChv.IsEmpty()
			msg('CTe não possui a chave do CTe, só pode cancelar um CTe se a mesma estiver autorizada!')
		Case &CteAutNumPro.IsEmpty()
			msg('CTe não possui número do protocolo, consulte o CTe no SEFAZ!')
		Case &erro = 0
			GeraXmlCancelamentoCte.Call(&EmpCod, &FilCod, &CteCod, &xJust, &Context.PesCod, &tmpNfeEnvEml,&tmpCancelarDuplicatas, &SolCod)
			wpCancelaCteRecepcao.Link(&DeOndeVEm, &EmpCod, &FilCod, &CteCod, &xJust, &SolCod)
			
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Verifica_especial'

    &erro = 0 
    &Tamanho = len(&xJust)
    if &tamanho < 15 or &tamanho > 255
        msg('Tamanho da justificativa tem que ficar entre 15 e 255')
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&xJust,&Posicao,1) < ' '  or (substr(&xJust,&Posicao,1) > 'z'  ))
                msg('Caracter especial '+  substr(&xJust,&Posicao,1) + 'Não é permitido' ) 
                &erro = 1
            Endif
        EndFor
    EndIf

EndSub


]]></Source>
