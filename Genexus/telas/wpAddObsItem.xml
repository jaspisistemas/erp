Event Start

	loadWWPContext.Call(&wwpContext)
	do 'GetPedidoProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	prcGravaObservacaoInternaComplemento.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &PedItmCmp, &PedItmCmpInt, &wwpContext.UserName)
	Return

EndEvent

Sub 'GetPedidoProduto'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedItmCod = &PedItmCod
		
		&ProGraRef = ProGraRef
		&ProNom = ProNom
		&PedItmCmp = PedItmCmp
		&PedItmCmpInt = PedItmCmpInt
		
		Exit
	EndFor

EndSub


]]></Source>
