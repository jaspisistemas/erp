      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbProcessando.Visible = 0
	tbAvisoErroAberturaFechamento.Visible = 0
	
	RetornaAutorizacao.Call('COMPRAABREESTOQUE', Status_SimNao.Sim, 1, &AutNiv)

	LoadWWPContext.Call(&Context)
		
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		Do CAse
			CAse PedStsPrc = AtualizandoEstoquePedido.Abrindo or PedStsPrc = AtualizandoEstoquePedido.Fechando 
				//ERRO AO ABRIR OU FECHAR, MSG ERRO PARA RECALCULO DE ESTOQUE DO PEDIDO.
				Do cAse
					CAse PedStsPrc = AtualizandoEstoquePedido.Abrindo 
						txtAvisoAbrindo1.Caption = 'Opção 1 - Uma ação de ABRIR estoque está EM ANDAMENTO, aguarde sua conclusão!'
						txtAvisoAbrindo2.Caption = 'Opção 2 - Clique no botão "Ajustar status pedido" para recalcular estoque dos produtos envolvidos e marcar pedido como ABERTO.'
					CAse PedStsPrc = AtualizandoEstoquePedido.Fechando
						txtAvisoAbrindo1.Caption = 'Opção 1 - Uma ação de FECHAR estoque está EM ANDAMENTO, aguarde sua conclusão!'
						txtAvisoAbrindo2.Caption = 'Opção 2 - Clique no botão "Ajustar status pedido" para recalcular estoque dos produtos envolvidos e marcar pedido como ABERTO.'
				EndCase
					
				txtAvisoAbrindo1.ForeColor = RGB(150,0,150)
				txtAvisoAbrindo2.ForeColor = RGB(150,0,150)
				
				tbAvisoErroAberturaFechamento.Visible = 1
				
			Case PedSts <> Status_Pedido.FECHADO and PedSts <> Status_Pedido.CANCELADO
				wwpActions.WCPopup_Close('')
		EndCAse
		
		&PedCliCodRaz = PedCliCodRaz
		&PedDtaEms = PedDtaEms
		&PedDtaFat = PedDtaFat
		&FilCodNom = FilCodNom
		
		txt1.Caption = 'A NF de entrada "CASO EXISTA" não será cancelada e nem excluída, se essa for a intenção favor fazer pelo Monitora Notas!'
		
		&PedObsEst = PedObsEst
			
		&PedCliObs = PedCliObsCli
		If PedCliObsCli.IsEmpty()
			&PedCliObs.Visible = 0
		EndIF
		
		If PedObsEst.IsEmpty()
			&PedObsEst.Visible = 0
		EndIF
		
		&PedObsGer = PedObsGer
		If PedObsGer.IsEmpty()
			&PedObsGer.Visible = 0
		EndIF
		
		Exit
	When none
		WwpActions.WCPopup_Close('')
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&PedDtaFat.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAjustarStatusPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_BtnAjustarStatusPedido.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_BtnAjustarStatusPedido.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Ask If DVelop_ConfirmPanel_BtnAjustarStatusPedido.Result = !'Yes'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if DVelop_ConfirmPanel_BtnAjustarStatusPedido.Result = !'Yes'
		
		&IsAjusteEstoque = true
		tbProcessando.Visible = 1
		btnAjustarStatusPedido.Visible = 0
		
		&ProgressId = trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&PedCod)) + 'ABRIR'
		apagaProgress.Call(&ProgressId)
		scaProgressBar.ProcessId = &ProgressId
		scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar.Start()
		
		prcAjustaStatusEstoque.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &PedCod)

	Endif

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &PedObsGer.IsEmpty())
		&PedObsGer.Visible = False
		PedObsGer_Cell.Class = !'Invisible'
	Else
		&PedObsGer.Visible = True
		PedObsGer_Cell.Class = !'col-xs-12 CellAttributeRed DscTop'
	EndIf
	If Not (Not &PedObsEst.IsEmpty())
		&PedObsEst.Visible = False
		PedObsEst_Cell.Class = !'Invisible'
	Else
		&PedObsEst.Visible = True
		PedObsEst_Cell.Class = !'col-xs-12 CellAttributeRed DscTop'
	EndIf
	If Not (not &PedCliObs.IsEmpty())
		&PedCliObs.Visible = False
		PedCliObs_Cell.Class = !'Invisible'
	Else
		&PedCliObs.Visible = True
		PedCliObs_Cell.Class = !'col-xs-12 CellAttributeRed DscTop'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar.OnComplete

	if &IsAjusteEstoque = true
		For Each Order ProgressId
			Where ProgressId = &ProgressId
			&sdtEstoque.FromXml(ProgressLogXml)
			Exit
		EndFor
		
		If &sdtEstoque.Count > 0
			//msg(scaProgressBar1.ProcessId + ' Recálculo Completo!')
			RCOOpenWindow.LinkOpen = RELJAS008.Link(&EmpCod, &FilCod, &ProgressId)
			RCOOpenWindow.OpenWindow(True, 500, 500, True, 0, 0, False)
		Else
			do 'callLink'
		EndIF
	Else
		do 'callLink'
	Endif

EndEvent

Sub 'calllink'

	wwpActions.WCPopup_Close('')

EndSub


]]></Source>
