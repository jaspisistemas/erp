      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	com.ForeColor  = RGB(0,160,40)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadPedido'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &PedDtaEms < Serverdate()
		atualizaDataPedidoHoje.Call(&EmpCod, &FilCod, &PedCod, &Context.UserName)
		
		PedidoVendas.Link(TrnMode.Update, &EmpCod, &FilCod, &PedCod, &DeOndeVem)
	
	Else
		msg('Pedido não possui data inferior à de Hoje!')
	EndIf

EndEvent

Sub 'loadPedido'

	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&FilCodNom = FilCodNom
		&PedCliCodRaz = PedCliCodRaz
		&PedDtaEms = PedDtaEms
		Exit
	EndFor

EndSub


]]></Source>
