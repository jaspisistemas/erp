      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Form.Backcolor = rgb(238,238,238)
	LayoutMainTable.Class = ThemeClass:MainContainer
	TableError.Visible = false

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 270

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &UserPasswordNew = &UserPasswordNewConf
		&User = GAMRepository.GetUserByLogin(&UserAuthTypeName, &UserName, &Errors)
		If &Errors.Count = 0		
			&ChangePwdOK = &User.ChangePasswordByKey(&KeyToChangePassword, &UserPasswordNew, &Errors)
			If &ChangePwdOK
				Commit
				&AdditionalParameter.RememberUserType	= &UserRememberMe
				&AdditionalParameter.IDPState			= &IDP_State
				&LoginOK = GAMRepository.Login(&UserName, &UserPasswordNew, &AdditionalParameter, &Errors )
				If &LoginOK
					If GAMRepository.IsRemoteAuthentication(&IDP_State)
						//Redirect to remote authentication
						GAMRepository.RedirectToRemoteAuthentication(&IDP_State)
					Else
						&URL = GAMRepository.GetLastErrorsURL()
						If &URL.IsEmpty()
							GAMHome()
						Else
							Link(&URL)
						Endif
					Endif
				Else
					Do 'DisplayMessages'
				EndIf
			Else
				Do 'DisplayMessages'
			Endif
		Else
			Do 'DisplayMessages'
		Endif
	Else
		TableError.Visible = True
		Msg("WWP_GAM_NewPasswordNotMatch")
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarLogin'

	If GAMRepository.IsRemoteAuthentication(&IDP_State)
		GAMRemoteLogin(&IDP_State)
	Else
		Login('', '')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'DisplayMessages'

	TableError.Visible = True
	For &Error in &Errors
		Msg(Format(!"%1", &Error.Message))
	EndFor

EndSub

