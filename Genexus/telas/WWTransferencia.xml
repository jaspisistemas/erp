      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
    &PesCod = &Context.PesCod
	
	&EmpCod = &parEmpCod
	&CtaBanCod = &parCtaBanCod
	If &CtaBanCod = 0 
		Do 'Origem'
	Else
		Do 'Destino'
		Do 'Origem'
	EndIf
	&MovDta = ServerDate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&OldMovDoc.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	do 'gravaLancamento'
	if &IsTudoCerto = true
		do 'Origem'
		
		&OriMovVlr.SetEmpty()
		&MovDoc.SetEmpty()
		&DstMovDoc.SetEmpty()
		&MovItmCpl.SetEmpty()
		&OriMovVlr.SetFocus()
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction2'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		If &EmpCod.IsEmpty()
		&EmpCod = &Context.EmpCod
	EndIf
    &PesCod = &Context.PesCod

EndEvent

Event &MovDoc.IsValid

	if &MovDoc <> &OldMovDoc
		&DstMovDoc = &MovDoc
	Endif	
	&OldMovDoc = &MovDoc

EndEvent

Event &OriMovVlr.IsValid

	Do 'Saldo'
	&OriDifVlr = &SdoAtu - &OriMovVlr
	
	If &OriDifVlr < 0                        // Diferença
		Msg('ATENÇÃO! Valor da transferência é maior que o saldo Verifique!')
	EndIf

EndEvent

Event Enter

	do 'gravaLancamento'
	if &IsTudoCerto = true
		wwpActions.WCPopup_Close('')
	Endif

EndEvent

Event &OriCtaBanCod.IsValid

	If &CtaBanCod = 0
		&CtaBanCod = &OriCtaBanCod
		Do 'Destino'
	EndIf

EndEvent

Sub 'gravaLancamento'

	&IsTudoCerto = false
	PrcValidaCaixaAberto.Call(&EmpCod, &OriCtaBanCod, &MovDta, &IsCaixaFechado, &MensagemConferencia)
	PrcValidaCaixaAberto.Call(&EmpCod, &DstCtabanCod, &MovDta, &IsCaixaFechadoEmissao, &MensagemEmissao)
	
	&MovDoc = &MovDoc.ToUpper()
	&DstMovDoc = &DstMovDoc.ToUpper()
	Do Case
		Case &IsCaixaFechado = true
			msg(&MensagemConferencia)
		Case &IsCaixaFechadoEmissao = true
			msg(&MensagemEmissao)
		Otherwise
			
			If &OriMovVlr > 0                     // Valor a Transferir 
				If &DstCtaBanCod > 0              // Conta Bancaria de Destino
					If not &MovDta.IsEmpty()
						Transferencia.Call(&EmpCod, &Context.FilCod, &OriCtaBanCod,&DstCtabanCod,&DstMovDoc,&OriMovVlr,&MovDta,&MovDoc,&MovItmCpl,'',&Error)
						If &Error = 1
							msg('ATENÇÃO, A  chave do lançamento ja existe, não possível gravar o lançamento! verifique os parâmetros, ou contate a equipe jaspi!')
						Else
							&IsTudoCerto = true
						EndIf
					Else
						msg('ATENÇÃO! A data de transferência não pode Ser vazia!')
					EndIf
				Else
					Msg('ATENÇÃO! Conta de destino inválida, selecione uma conta de destino!')
				EndIf
			Else
				Msg('ATENÇÃO! Valor a transferir tem que ser maior que zero! verifique.')
			EndIf	
	EndCase

EndSub

Sub 'Origem'

	&OriCtaBanCod.Clear()
	For Each Order EmpCod,CtabanCod
		Where EmpCod  = &EmpCod
		Where CtabanCod = &CtaBanCod when not &CtaBanCod = 0
		Where CtaBanSts = Status_AtivoInativo.ATIVO
		&OriCtaBanCod.AddItem(CtabanCod,CtaBanCodNomSdo)
	EndFor

EndSub

Sub 'Destino'

	&CoollFilCod.Clear()
	if &PesCod > 0
		For Each Order EmpCod, PesCod, PesFilAce
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			&CoollFilCod.Add(PesFilAce)
		EndFor
	Else
		For Each Order EmpCod, FilCod
			Where EmpCod = &EmpCod
			&CoollFilCod.Add(FilCod)
		EndFor
	EndIf


	For Each Order EmpCod,CtabanCod
		Where EmpCod  = &EmpCod
		Where CtabanCod <> &CtaBanCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO
		Where CtaBanFilCod in &CoollFilCod
		&DstCtaBanCod.AddItem(CtabanCod,CtaBanCodNom)
	EndFor

EndSub

Sub 'Saldo'

	For each Order EmpCod,CtabanCod,(SdoDta)   //Saldo( EmpCod, CtaBanCod, SdoDta) 
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod		
		&SdoAtu = SdoAtu
		Exit
	EndFor

EndSub


]]></Source>
