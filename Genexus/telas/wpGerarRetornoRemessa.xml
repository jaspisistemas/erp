      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	do 'GetPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	btnEnter.Visible = 0
	btn_Cancel.Visible = 0
	
	Do Case
//		Case &NfeDtaEms < &PedDtaEms or &NfeDtaEms_to < &PedDtaEms 
//			Msg('Datas de Emissão inicial e Emissão Final não podem ser menores que a Remessa de Saída!')
//			&NfeDtaEms.SetFocus()
		Case &NfeDocRefNfe.IsEmpty()
			Msg('Remessa de origem não possui nota fiscal emitida, não é possivel fazer retorno!')
			
		Otherwise
			
			&Random = Random() * 10000000000
			&ProgressId = 'wpImpPedido' + trim(Str(&Random))
			
			scaProgressBar.ProcessId = &ProgressId
			scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar.Start()
			
			
			PrcGeraRetornoNotaFiscal.Submit(&ProgressId, &ProgressId, &EmpCod, &FIlCod, &PedCod, &LctCod, &PedCliCod, &NfeDtaEms, &NfeDocRefNfe)

	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ScaProgressBar.OnComplete

	Return

EndEvent

Sub 'GetPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FIlCod
		Where PedCod = &PedCod
		&LctCod = LctCod
		&PedCliCod = PedCliCod
		&DadosRemessa = 'REMESSA: ' + trim(str(&PedCod))
		&PedDtaEms = PedDtaEms
		Exit
	EndFor

	For each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where NfePedCod = &PedCod
		Where NfeFilCod = &FIlCod
		
		&NfeDtaEms = NfeDtaEms
		&NfeDocRefNfe = NfeChv
		
		Exit
	EndFor

	
	//Pega Tipo lancamento retorno
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctTip = TipoLancamento.RemessaEntrada
		&LctCod = LctCod
		Exit
	EndFor

EndSub


]]></Source>
