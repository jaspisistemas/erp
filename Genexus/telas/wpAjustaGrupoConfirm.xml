			&ProNcmCestCombo.AddItem(NcmCestCod, NcmCestCodDes)
		EndFor
		&ProNcmCestCombo.AddItem(9999999, '000000 - CEST NÃO DISPONIVEL/INFORMADO')
		//	&ProNcmCestCombo.AddItem(9999998, 'NÃO INFORMAR CEST NA NF-E')
		//&ProNcmCestCombo = &AuxProNcmCestCombo

EndEvent

Event &ProEmbCod.IsValid

	Do 'loadEmbalagem'

EndEvent

Event Enter

	do 'NCM'
	Do Case
		CAse &IsTrocaCatImposto = true and &CatCod.IsEmpty()
			msg('Selecione Nova Categoria de Imposto!')
			&CatCod.SetFocus()
		Case &IsTrocaGrupo = true and &GrupCod.IsEmpty()
			msg('Selecione Novo Grupo de Imposto!')
			&GrupCod.SetFocus()
		Case &IsTrocaSetor = true and &SetCod.IsEmpty()
			msg('Selecione Novo Setor Produtos!')
			&SetCod.SetFocus()
		Case &IsTrocaNCM = true and &IsErroNCM = true
			msg('Selecione Novo NCM Produtos!')
			&NcmCod.SetFocus()
		case &IsTrocaMarca = true and &MarCod.IsEmpty()
			msg('Selecione a nova MARCA!')
			&MarCod.SetFocus()
		case&IsTrocaEmbalagem = true and &ProEmbCod.IsEmpty()
			msg('Selecione a nova EMBALAGEM!')
			&ProEmbCod.SetFocus()
		case &IsTrocaTipoCusto = true and &ProTipCus.IsEmpty()
			msg('Selecione o novo TIPO DE CUSTO!')
			&ProTipCus.SetFocus()
		Case &IsTrocaIMC = True And &ProIMC.IsEmpty() 
			Msg('Selecione uma nova % de ACRÉSCIMO (%Acrs)')
			&ProIMC.SetFocus()
		CAse &IsTrocarCor = true and &ProCorCod.IsEmpty()
			Msg('Selecione uma nova COR')
			&ProCorCod.SetFocus()
		Otherwise
			if &IsTrocarCor = true
				&IsExisteCor = false
				For Each ORder EmpCod, CorCod
					Where EmpCod = &EmpCod
					Where CorCod = &ProCorCod
					&IsExisteCor = true
					Exit
				EndFor
			Endif
		
			do CAse
				CAse &IsExisteCor = false and &IsTrocarCor = true
					Msg('Selecione uma nova COR')
					&ProCorCod.SetFocus()
				Otherwise
					AtualizaCadastroProdutos.Call(&EmpCod, &SdtProdutos, &IsTrocaCatImposto, &CatCod, &IsTrocaGrupo, &GrupCod, &IsTrocaSetor, &SetCod, &IsTrocaNCM, &NcmCod, &IsTrocaMarca, &MarCod, &IsTrocaEmbalagem, &ProEmbCod, &IsTrocaTipoCusto, &ProTipCus,&IsTrocaSolTec,&ProReqVen,&IsTrocaSolCpl,&ProInfCmp, &IsTrocaIMC, &ProIMC, &Context.UserName, &IsTrocarCor, &ProCorCod, &IsTrocaTamanho, &ProTam, &IsTrocarDescMax, &ProDesMax, &ProNcmCestCombo, &IsTrocaPeso, &ProPesLiq)
					msg('Produtos Atualizados com Sucesso!')
			EndCAse		
	EndCAse

EndEvent

Sub 'loadEmbalagem'

	For each order EmpCod, EmbCod
		where EmpCod = &EmpCod
		where EmbCod = &ProEmbCod
		&ProEmbUnd = EmbUnd
		exit
	EndFor

EndSub

Sub 'NCM'

	&IsErroNCM = true
	For Each Order NcmCod
		Where NcmCod = &NcmCod
		
		&IsErroNCM = false
		
		if NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()
			if &IsTrocaNCM = true
				Msg('FIM DA VIGENCIA NCM: ' + trim(str(NcmCod)) + ' ' + NcmDes.Trim())
			Endif
			&IsErroNCM = true
		Endif
		
		Exit
	When none
		Do CAse
			CAse &NcmCod =  0
				&IsErroNCM = false
			CAse &NcmCod =  99
				if &IsTrocaNCM = true
					msg('CÓDIGO NCM NÃO INFORMADO!')
				Endif
			Otherwise
				if &IsTrocaNCM = true
					msg('CÓDIGO NCM NÃO CADASTRADO/INVÁLIDO!')
				Endif
		EndCAse
	EndFor

EndSub


