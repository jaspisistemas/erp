      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CreSts.Visible = False
	&EmpCod.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridCurrentPage= Grid.currentPage
	
	&Count.SetEmpty()

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Count += 1
	txtQtd.Caption = &Count.ToFormattedString() + ' - Boletos para Registro.'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

	return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

//	&QtdBolReg.SetEmpty()
//	&QtdBolNaoReg.SetEmpty()
//	RegistraTodosBoletos.Call(&EmpCod,&QtdBolReg,&QtdBolNaoReg)
//	wpResultadoRegBoletos.Popup(&QtdBolReg,&QtdBolNaoReg)
	
	Do 'GetFilialLocalCobranca'
	Do case
		case &CbrCod.IsEmpty()
			msg('Selecione um Local de cobrança ativo!')
		case &CbrCtaBanFilCod.IsEmpty()
			msg('Erro no Local de Cobrança! Não foi possível localizar a Filial vinculada a este Local de Cobrança!')
		otherwise
			//&DataVazia = ServerDate() //JDF VAZIA é VAZIO TIU HENRIQUE. NAO É SERVERDATE()
			&CreSts.SetEmpty()
			GeraCobranca_OnLine.Call(&ProgressId, &EmpCod, &CbrCtaBanFilCod ,&CbrCod, &DataVazia, ServerDate(),Status_SimNao.Sim, &CreSts, &CreDtaVct)
			RCOOpenWindow1.LinkOpen = RELJAS023A.link(&EmpCod, &CbrCtaBanFilCod, &CbrCod, 0)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			Refresh
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'GetFilialLocalCobranca'

	For each order EmpCod,CbrCod
		where EmpCod = &EmpCod
		where CbrCod = &CbrCod
		&CbrCtaBanFilCod = CbrCtaBanFilCod
		exit
	EndFor

EndSub


]]></Source>
