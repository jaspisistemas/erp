      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SupCod = &parSupCod
	do 'loadSuporte'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 600
	&SupCod.Visible = False
	Grid.Rows = 10
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionSelecione.FromImage(DDOMultiselSelOption)
	&ActionSelecione.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SupEmpCod = SupEmpCod
	&SupPesCod = SupPesCod
	do 'GetEmpresaNome'
	
	if SupEmpAce = true
		&ActionSelecione.FromImage(DDOMultiselSelOption)
	Else
		&ActionSelecione.FromImage(DDOMultiselOption)
	Endif

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &SupCod <> 0
		GravaUsuarioSuporte.Call('UPD', &SupCod, &SupEmail, &SupNom, 0)
		Return
	Else
		GravaUsuarioSuporte.Call('UPD', 0, &SupEmail, &SupNom, &SupCod)
		do 'loadSuporte'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &SupPesCod.IsValid

	AtualizasuporteUsuarioAcesso.call(SupCod, SupEmpCod, &SupPesCod)

EndEvent

Event &ActionSelecione.Click

	if &SupCod <> 0
		AtualizaStatusAcessoEmpresa.call(SupCod, SupEmpCod)
		
		Refresh
	Endif

EndEvent

Sub 'GetEmpresaNome'

	For each Order EmpCod
		Where EmpCod = &SupEmpCod
		&EmpRaz = EmpRaz
		Exit
	EndFor

EndSub

Sub 'loadSuporte'

	For Each Order SupCod
		Where SupCod = &SupCod
		&SupEmail  = SupEmail
		&SupNom = SupNom 
		
		Exit
	EndFor
	
	if &SupCod <> 0
		AtualizaSuporteEmpresa.Call(&SupCod)
	Endif

EndSub


]]></Source>
