Event ddo_OqueFazer.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case ddo_OqueFazer.ActiveEventKey = !'Hoje'
			Do 'Do Hoje'
		Case ddo_OqueFazer.ActiveEventKey = !'Nasemana'
			Do 'Do Nasemana'
		Case ddo_OqueFazer.ActiveEventKey = !'NoMes'
			Do 'Do NoMes'
		Case ddo_OqueFazer.ActiveEventKey = !'DoisAntesCincoDepois'
			Do 'Do DoisAntesCincoDepois'
		Case ddo_OqueFazer.ActiveEventKey = !'Prox30'
			Do 'Do Prox30'
		Case ddo_OqueFazer.ActiveEventKey = !'CalendarioAniversarios'
			Do 'Do CalendarioAniversarios'
		Case ddo_OqueFazer.ActiveEventKey = !'AdicionarAniversariante'
			Do 'Do AdicionarAniversariante'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

