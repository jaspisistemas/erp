      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' Remessa'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	retornaAutorizacao.Call('WWREMESSA', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaConfiguracoesPastas.Call(&Context.EmpCod,&Context.FilCod,&SdtConfiguracoesPasta)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	If &auxCbrCod <> RemCbrCod
		&Deletar.Visible=true
	ELSE
		&Deletar.Visible =false
	EndIf
	&auxCbrCod = RemCbrCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Deletar = !'<i class="fa fa-times"></i>'
	
	&Download = !'<i class="fas fa-download"></i>'
	
	&Imprimir = !'<i class="far fa-file-pdf"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If (RemNomArq <> 'REMESSA_ONLINE')
		&Download.Visible = 1
		&Deletar.Visible = 1
	Else
		&Download.Visible = 0
		&Deletar.Visible = 0
	Endif

EndEvent

Event &Deletar.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod_Selected = EmpCod
	&RemCbrCod_Selected = RemCbrCod
	&RemNum_Selected = RemNum
	DVelop_ConfirmPanel_Deletar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Deletar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Deletar.Result = !'Yes'
		Do 'Do Deletar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInserir'

	WWGeraCobranca.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSetwwSaldos'

	WWSaldo.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSetwwretorno'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWRemessaRetorno.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do Deletar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	DeletarRemessa.Call(&EmpCod_Selected,&RemCbrCod_Selected,&RemNum_Selected)
	
	&NomArq = &SdtConfiguracoesPasta.PastaDiretorioCobFis+ trim(&RemNomArq_Selected)
	&file.Source = &NomArq
	
	If &file.Exists() 
		&file.Delete()
		wwremessa.Link()
	EndIf

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"REMCBRCOD"
				&RemCbrCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"REMDTA"
				&RemDta.FromString(&GridStateFilterValue.Value)
				&RemDta_To.FromString(&GridStateFilterValue.ValueTo)
			Case &GridStateFilterValue.Name = !"REMNUM"
				&RemNum.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"REMCBRCOD", "", not &RemCbrCod.IsEmpty(), 0, &RemCbrCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"REMDTA", "", not (&RemDta.IsEmpty() AND &RemDta_To.IsEmpty()), 0, &RemDta.ToString().Trim(), &RemDta_To.ToString().Trim())
	WWP_GridStateAddFilterValue(&GridState, !"REMNUM", "", not &RemNum.IsEmpty(), 0, &RemNum.ToString().Trim(), '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"Remessa"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event 'DoDeletar'

	DVelop_ConfirmPanel_Deletar.ConfirmationText = 'Deseja realmente deletar a remessa '+str(RemNum)
	&RemNomArq_Selected = RemNomArq

EndEvent

Event &Download.Click

	Do Case 				
		Case RemBanCod = '001' or RemBanCod = '133' or RemBanCod = '237'  or RemBanCod = '748'	or RemBanCod = '756' or RemBanCod = '099'
			&NomArq = &SdtConfiguracoesPasta.PastaDiretorioCobFis+ trim(RemNomArq)
			
			&file.Source = &NomArq
			
			If  &file.Exists() 
				&file.Delete()
			EndIf
			&ResultadoAbertura = DfwOpen(&NomArq,'','', 0, 'ISO-8859-1') 
			&ResultadoNext =  dfwptxt(RemTxt)                          // Grava Linha 			
			&ResultadoNext = DFWNext()
			&ResultadoAbertura = dfwclose()
			&link = &SdtConfiguracoesPasta.PastaDiretorioCobVir+ trim(RemNomArq)
			link(&link)
		Otherwise
			Msg('Banco Não configurado contacte o suporte!')
	EndCase

EndEvent

Event &Imprimir.Click

	if RemNomArq <> 'REMESSA_ONLINE'
		&FilCod = &Context.FilCod
		&dia = day(RemDta)
		&mes = Month(RemDta)
		Do Case 				
			Case RemBanCod = '237'
				&randon = serverNow()
				&arquivo = trim(RemNomArq)
		EndCase
		
		&window.url = RELJAS023.Link(EmpCod,&FilCod,RemCbrCod,RemNum,&arquivo,&randon)
		&window.Height = 800
		&window.Width = 800
		&window.Open()
	Else
		&window.url = RELJAS023A.Link(EmpCod,&FilCod,RemCbrCod,RemNum)
		&window.Height = 800
		&window.Width = 800
		&window.Open()
	Endif

EndEvent


