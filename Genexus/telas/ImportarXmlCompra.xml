      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'SelecionarXML'
	&WizardStep.Title = 'Selecione XML'
	&WizardStep.Description = 'Selecione XML'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Envolvidos'
	&WizardStep.Title = 'Envolvidos'
	&WizardStep.Description = 'Envolvidos'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Produtos'
	&WizardStep.Title = 'Produtos'
	&WizardStep.Description = 'Produtos'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Totais'
	&WizardStep.Title = 'Totais'
	&WizardStep.Description = 'Totais'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'GravaNf'
	&WizardStep.Title = 'Gravar NF-e'
	&WizardStep.Description = 'Gravar NF-e'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'SelecionarXML'
		&WebSession.Remove(&Pgmname + !'_Data')
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsUnderlineWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDoVoltarPDV'

//opa
	&WizardDataIMp.FromJson(&WebSession.Get('ImportarXmlCompra_Data'))
	
	Do Case
		Case &WizardDataIMp.SelecionarXML.DeOndeVem = 'WWNOTAS'
			wwNotas.Link()
		Case  &WizardDataIMp.SelecionarXML.DeOndeVem = 'WWORDEMCOSTURA'
			WWORDEMCOSTURA.Link()
		Case  &WizardDataIMp.SelecionarXML.DeOndeVem = 'DEVOLUCAOVENDA' or &WizardDataIMp.SelecionarXML.DeOndeVem = 'WWDEVOLUCAOVENDA'
			WWDevolucaoVenda.Link()
		Case &WizardDataIMp.SelecionarXML.DeOndeVem = 'WWPEDIDOVENDA'
			wwPedidoVenda.Link()
		Otherwise
			wwPedidoCompra.Link()
	Endcase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAjuda'

	innewWindow.Target = 'https://ajuda.jaspi.com.br/index.aspx?23e61b2a-4c15-40d8-90c2-750349072933'
	inNewWindow.Name = '_blank'
	innewWindow.OpenWindow()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'SelecionarXML'
			WizardStepWC.Object = ImportarXmlCompraSelecionarXML.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Envolvidos'
			WizardStepWC.Object = ImportarXmlCompraEnvolvidos.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Produtos'
			WizardStepWC.Object = ImportarXmlCompraProdutos.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Totais'
			WizardStepWC.Object = ImportarXmlCompraTotais.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'GravaNf'
			WizardStepWC.Object = ImportarXmlCompraGravaNf.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
