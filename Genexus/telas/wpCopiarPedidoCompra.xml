      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	do 'getPedido'
	do 'LoadOperaForne'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &NovPedCliCod.IsValid

	do 'LoadOperaForne'

EndEvent

Event &NovLctCod.IsValid

	do 'LoadOperaForne'

EndEvent

Event Enter

	do 'ValidaOperacao'
	do 'ValidaFornecedor'
	
	Do Case
		Case &IsOkCliente = false
			msg(&ClienteMensagem)
		Case &IsOkOperacao = false
			msg(&OperacaoMensagem)
			
		Otherwise
			CopiaPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &NovLctCod, &NovPedCliCod, &Mensagem, &NovoPedCod)
			if not &Mensagem.IsEmpty()
				wwPedidoCompra.Link()	
			EndIf
	EndCase

EndEvent

Sub 'LoadOperaForne'

	&LctNom = ''
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &NovLctCod
		&LctNom = LctNom
		Exit
	When none
		&LctNom = 'OPERAÇÃO NÃO ENCONTRADA'
	EndFor

	&PesRaz = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NovPedCliCod
		&PesRaz = PesRaz
		Exit
	When none
		&PesRaz = 'FORNECEDOR NÃO ENCONTRADO'
	EndFor

EndSub

Sub 'ValidaOperacao'

	&IsOkOperacao = false
	&OperacaoMensagem = ''
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &NovLctCod
		Where LctTip in (TipoLancamento.EntradaMercadoria, TipoLancamento.OrcamentoCompra)
		&IsOkOperacao = true
		Exit
	When none
		&OperacaoMensagem = 'Operação Informada não Corresponde à uma compra!'
	EndFor

EndSub

Sub 'ValidaFornecedor'

	&IsOkCliente = false
	&ClienteMensagem = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NovPedCliCod
		Where PesIsFor = true
		&IsOkCliente = true
		Exit
	When none
		&ClienteMensagem = 'Pessoa informada não é um Fornecedor!'
	EndFor

EndSub

Sub 'getPedido'

    For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
	    Where FilCod = &FilCod
	    Where PedCod = &PedCod
		&FilCodNom = FilCodNom
		&PedCliCodRaz = PedCliCodRaz
		&PedVlrLiq = PedVlrLiq
		&PedVenCodRaz = PedVenCodRaz
		&PedDtaEms = PedDtaEms
		&LctCodNom = LctCodNom
		
		&NovLctCod = LctCod
		&NovPedCliCod = PedCliCod
	    Exit
    EndFor

EndSub


]]></Source>
