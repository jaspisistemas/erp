        <Source><![CDATA[
Event Start

	Form.Caption = '#LIBERA CRÉDITO PEDIDO: ' + trim(str(&PedCod))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 1024
	TableMain.Height = 530

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	wcCapaPedd.Object = wcPedidoVenda2.Create(TrnMode.Update, &EmpCod, &FilCod, &PedCod)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PesCod = &Context.PesCod
	do 'LoadPedido'
	
	AlterarCadastro.Link = wpPessoa.Link('WWCLIENTE', 'UPD', &EmpCod, &PedCliCod)
	AlterarCadastro.LinkTarget = '_blank'
	
	RetornaAutorizacao.call('LIBERACREDITOPEDIDO', Status_SimNao.Nao, 1, &CREDITOPEDIDOAutNiv)
	RetornaAutorizacao.call('LIBERACREDITOPEDIDOANALISADO', Status_SimNao.Nao, 1, &CREDITOANALISADOAutNiv)
		
	if &CREDITOANALISADOAutNiv < 1 and &CREDITOPEDIDOAutNiv < 1
		Return
	EndIF

	RetornaAutorizacao.call('LIBERACREDITOADM', Status_SimNao.Nao, 1, &LIBERACREDITOADM)
	if &LIBERACREDITOADM < 1
		gxUITabsPanel_tabLibera.HideTab(10)
	Else
		gxUITabsPanel_tabLibera.HideTab(9)
	EndIf

EndEvent

Event gxUITabsPanel_tabLibera.TabChanged

	&numeric = gxUITabsPanel_tabLibera.ActivePage
	
	Do CAse
		Case &numeric = 1
			wcCapaPedd.Object = wcPedidoVenda2.Create(TrnMode.Update, &EmpCod, &FilCod, &PedCod)
			
		Case &numeric = 2
			wcAnexPed.Object = wpAnexosPedido.Create(&EmpCod, &FilCod, &PedCod)
		Case &numeric = 3 //COTACAO
			wcCotacao.Object = wcCotacoesFrete.Create(&EmpCod, &FilCod, &PedCod)
			
		Case &numeric = 4
			wcDuplicatas.Object = wcHistoricoCliente.create(&PedCliCod) //wcDuplicatasCliente.Create(&EmpCod, &FilCod, &PedCliCod)
			
		Case &numeric = 5 //CADASTRO
			wwcCadCliente.Object = wcSociosPessoa.Create(&EmpCod, &PedCliCod)
			//			wcCliente.Create(TrnMode.Update, &EmpCod, &PedCliCod)
			
		Case &numeric = 6
			WCwpReferencias.Object = wpReferencias.Create(&EmpCod, &PedCliCod)
		Case &numeric = 7
			WCwpUploadArquivos.Object = wpUploadArquivos.Create(&EmpCod, &PedCliCod)
			
		Case &numeric = 8
//			if &Context.PesCod = -1
				gxwcFin.Object = wcFinanceiroClienteNovo1.Create(&EmpCod, &PedCliCod)
//			Else
//				gxwcFin.Object = wcFinanceiroClienteNovo.Create(&EmpCod, &PedCliCod)
//			Endif
			
		Case &numeric = 9
			
//			if &IsClicou9 = true
//				wcava.Refresh()
//			Else				
				wcava.Object = wcLiberarCreditoAvaliacao.Create(&EmpCod, &FilCod, &PedCod)
//				&IsClicou9 = true
//			Endif
			
		Case &numeric = 10
//			if &IsClicou10 = true
//				wwcGerr.Refresh()
//			Else			
				wwcGerr.Object = wcLiberaCreditoNovo.Create(&EmpCod, &FilCod, &PedCod)
//				&IsClicou10 = true
//			Endif
	
	EndCase

EndEvent

Sub 'LoadPedido'

	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon030_LiberaCreditoDataEmissao, &CfgVlr)
	&AlterarDtaCfgVlr.FromString(&CfgVlr)
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon016_ZerarCancLiberarCredito, &CfgVlr)
	&ZerarQtdCanCfgVlr.FromString(&CfgVlr)
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmPCod
		Where FilCod = &FiLCod
		Where PedCod = &PedCod
		
		&PedObsAna = PedObsAna
		
		&FilCodNom = FilCodNom
		&PedCliCod = PedCliCod
		&PesVinCod = PedCliVinCod
		do 'getCliente'
		&PedVlrLiq = PedVlrLiq		
		
		&PedSts = PedSts
		&PedStsCrd = PedStsCrd
		&PedDtaCrd = PedDtaCrd
		&PedStsAna = PedStsAna
		Exit
	When none
		Return
	EndFor
	
	&UtilizadoPesCliCrd = RetornaCreditoDisponivelCliente.Udp(&EmpCod, &FilCod, &PedCliCod)
	&CreditoDisponivel = &PedCliCrd - &UtilizadoPesCliCrd
	If &CreditoDisponivel < 0
		&CreditoDisponivel = 0
	EndIF

	&Moeda = &UtilizadoPesCliCrd + &PedVlrLiq
	RetornaAtencaoLiberacaoPedido.Call(&EmpCod, &FilCod, &PedCliCod, &Moeda, &IsAtencao, &Mensagem)

EndSub

Sub 'getCliente'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		
		&PedCliCodRaz = PesCodRaz
		&PedCliCrd = PesCliCrd
		&PesClaTip = PesClaTip
		
		&PesProAtv = PesProAtv
		&PesResSpc = PesResSpc
		&PesResChe = PesResChe
		&PesDtaCon = PesDtaCon
		&PesVenAprz = PesVenAprz
		&PesEnvSpc = PesEnvSpc
		Exit
	EndFor

EndSub


]]></Source>
