      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	Do 'CarregaPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItensPedido.Rows = Page.Rows
	&GridItensPedidoCurrentPage = 1
	&GridItensPedidoCurrentPage.Visible = False
	&GridItensPedidoPageCount = -1
	GridItensPedidoPaginationBar.RowsPerPageSelectedValue = GridItensPedido.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridItensPedidoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridItensPedidoPageCount 	= GridItensPedido.PageCount
	&GridItensPedidoCurrentPage = GridItensPedido.CurrentPage

EndEvent

Event GridItensPedido.Load

	&GridIsMarcado.Enabled 	= 1
	&GridPedQtd.Enabled		= 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&GridPedQtd = PedQtd
	&GridPedVlrUntDscVarchar = trim(toformattedString(PedVlrUntDsc)) 
RetiraZerosDepoisVirgulaDuasCasas.Call(&GridPedVlrUntDscVarchar, &GridPedVlrUntDscVarchar)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridItensPedidoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridItensPedidoPaginationBar.SelectedPage = !'Previous'
			&GridItensPedidoCurrentPage -= 1
			GridItensPedido.PreviousPage()
		Case GridItensPedidoPaginationBar.SelectedPage = !'Next'
			&GridItensPedidoCurrentPage += 1
			GridItensPedido.NextPage()
		Otherwise
			&PageToGo.FromString(GridItensPedidoPaginationBar.SelectedPage)
			&GridItensPedidoCurrentPage = &PageToGo
			GridItensPedido.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridItensPedidoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItensPedido.Rows = GridItensPedidoPaginationBar.RowsPerPageSelectedValue
	&GridItensPedidoCurrentPage = 1
	GridItensPedido.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &IsSelecionarTodos.Click

	If &IsSelecionarTodos = True
		For Each Line In GridItensPedido
			&GridIsMarcado 		= True
			&CountSelecionados	+= 1
		EndFor
	Else
		For Each Line In GridItensPedido
			&GridIsMarcado 	= False
		EndFor
		&CountSelecionados	= 0
	EndIf

	&TotalSelecionado = &CountSelecionados

EndEvent

Event &GridIsMarcado.Click

	If &GridIsMarcado = True
		&CountSelecionados	+= 1
	Else
		&CountSelecionados	-= 1
	EndIf
	
	Do case
		Case &TotalSelecionado > &CountSelecionados
			&IsSelecionarTodos = False
		Case
			&TotalSelecionado = &CountSelecionados
			&IsSelecionarTodos = True
	EndCase

EndEvent

Event Enter

	&IsRetornar = True
	&CollErrProGraRef.Clear()
	&PedItmCod = 0
	Do 'CheckValidations'
	If &IsGravar = True
		For Each Line In GridItensPedido
			If &GridIsMarcado 	= True 
				&AuxEmpCod 		= EmpCod
				&AuxFilCod 		= FilCod
				&AuxPedItmCod 	= PedItmCod
				&AuxProCod		= ProCod
				&GridPedQtd		= &GridPedQtd
				
				Do 'GravaItemDevolucao'
			EndIf
		EndFor
		
		If not &inseridoMensagem.IsEmpty()
			msg(&inseridoMensagem)
		EndIF
		
		If not &AlteradoMensagem.IsEmpty()
			msg(&AlteradoMensagem)
		EndIf
	
		For &AuxProGraRef In &CollErrProGraRef
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", "Não foi possível adicionar o item com o Réf. Cód.: " + Trim(&AuxProGraRef) + ", porquê a quantidade não foi informada.", DVMessageType.error, "", DVMessageBoolean.True,"") )
		EndFor

		If &IsRetornar = True
			WWPActions.WCPopup_Close('')
		EndIf

	EndIf

EndEvent

Sub 'CheckValidations'

	Do Case
		Case &CountSelecionados = 0
			&IsGravar = False
			Msg('É necessário selecionar ao menos um produto para a devolução!')
			
		OtherWise
			&IsGravar = True
	EndCase

EndSub

Sub 'CarregaPedido'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod 	= &parmEmpCod
		Where FilCod 	= &parmFilCod
		Where NfeChv	= &parmPedNfeChvRef.Trim()
		
		&AuxPedCod 	= NfePedCod
		
		Exit
	EndFor

EndSub

Sub 'GravaItemDevolucao'

	If &GridPedQtd >= 1
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where EmpCod 	= &AuxEmpCod
			Where FilCod 	= &AuxFilCod
			Where PedCod 	= &AuxPedCod
			Where PedItmCod = &AuxPedItmCod
			
			If &IsparmAceitaDuplicado = True
				&PedItmCod = 0
			Else
				Do 'BuscaItmPedido'
			EndIf
			
			&PedProEmbQtd	= PedProEmbQtd
			Do 'AtualizaTotais'
						
			&sdtAddPedidoProduto = new()			
			&sdtAddPedidoProduto.PedItmAcr = PedItmAcr
			&sdtAddPedidoProduto.PedItmDsc = PedItmDsc
			&sdtAddPedidoProduto.PedItmIpi = PedItmIpi
			&sdtAddPedidoProduto.PedItmIcmSt = PedItmIcmSt
			&sdtAddPedidoProduto.PedItmIcmStPob = PedItmIcmStPob
			&sdtAddPedidoProduto.PedItmIcm = PedItmIcm
			&sdtAddPedidoProduto.PedQtdEmb = &GridPedQtd
			&sdtAddPedidoProduto.PedProEmbQtd = PedProEmbQtd
			&sdtAddPedidoProduto.PedItmCmp = PedItmCmp
		//	&sdtAddPedidoProduto.PedItmAjuIpiBas = PedItmAjuIpiBas
		//	&sdtAddPedidoProduto.PedItmAjuIcmBas = PedItmAjuIcmBas
		//	&sdtAddPedidoProduto.PedItmAjuIcmStBas = PedItmAjuIcmStBas
		//	&sdtAddPedidoProduto.PedItmAjuPisBas = PedItmAjuPisBas
			&sdtAddPedidoProduto.PedItmPis = PedItmPis
			&sdtAddPedidoProduto.PedItmCofins = PedItmCofins
			
			GravaItemPedidoCompra.Call(&AuxEmpCod, &AuxFilCod, &DevPedCod, &PedItmCod, ProCod, ProGraCod, &PedQtd, PedVlrUnt, &sdtAddPedidoProduto, &sdtProdutoLote, &inseridoMensagem, &AlteradoMensagem, &WwpContext.UserName, 'S')
			
			Exit
		EndFor
		&GridIsMarcado = False
	Else
		&GridPedQtd.SetFocus()
		&CollErrProGraRef.Add(ProGraRef)
		&IsRetornar = False
	EndIf

EndSub

Sub 'AtualizaTotais'

	Do case
        Case &PedProEmbQtd > 0
            &PedQtd = ((&GridPedQtd * &PedProEmbQtd))
		Case &PedProEmbQtd < 0 and &PedQtd > 0
			&PedQtd = ((&GridPedQtd / (&PedProEmbQtd*-1)))
        Otherwise
            &PedQtd = &GridPedQtd
    EndCase

EndSub

Sub 'BuscaItmPedido'

	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where EmpCod 	= &AuxEmpCod
		Where FilCod 	= &AuxFilCod
		Where PedCod 	= &DevPedCod
		Where ProCod 	= &AuxProCod
		
		&PedItmCod		= PedItmCod
		
		Exit
	When None
		&PedItmCod = 0
	EndFor

EndSub


