Event &Deletar.Click

	For &SdtAdiantamentoItem in &SdtAdiantamento
		If &SdtAdiantamentoItem.dtaVct = &DtaVct and &SdtAdiantamentoItem.Valor = &Valor
			&index = &SdtAdiantamento.IndexOf(&SdtAdiantamentoItem)
			&SdtAdiantamento.Remove(&index) 
		EndIf
	EndFor

	Refresh

EndEvent

Event &PesCod.IsValid

	Do 'BuscarPessoa'

EndEvent

Sub 'Tipo'

	Do case
		case &Tipo = 'M' //Manual
			tbManual.Visible = true
			tbParcelar.Visible = false	
		case &Tipo = 'P' //Parcelar
			tbParcelar.Visible = true	
			tbManual.Visible = false
	EndCase

EndSub

Sub 'PlanoContas'

	&IsErroPlano = true
	
	For Each Order EmpCod, PlanCod
		Where EmpCod = &EmpCod
		Where PlanCod = &PlanCod
		
		Do Case
			Case PlanUtiTra = True
				MSG('ERRO! Plano utilizado somente para transferência, escolha outro plano!')
				
			Case PlanAnaSin <> 'A'
				MSG('ERRO! Plano sintético escolha um plano analítico!')
				
			Case PlanCatTip <> &MovCreDeb
				Msg('ERRO! Plano não é do tipo '+ Iif(&MovCreDeb = 'C','CRÉDITO','DÉBITO'))
				
			Otherwise
				&IsErroPlano = false
		EndCase
		
		&PlanCodNom = PlanCodNom
		Exit
	EndFor

EndSub

Sub 'PlanoContasParcelar'

	&IsErroPlano = true
	
	For Each Order EmpCod, PlanCod
		Where EmpCod = &EmpCod
		Where PlanCod = &PlanCod
		
		Do Case
			Case PlanUtiTra = True
				MSG('ERRO! Plano utilizado somente para transferência, escolha outro plano!')
				
			Case PlanAnaSin <> 'A'
				MSG('ERRO! Plano sintético escolha um plano analítico!')
				
			Case PlanCatTip <> &MovCreDeb
				Msg('ERRO! Plano não é do tipo '+ Iif(&MovCreDeb = 'C','CRÉDITO','DÉBITO'))
				
			Otherwise
				&IsErroPlano = false
		EndCase
		
		&PlanCodNom = PlanCodNom
		Exit
	EndFor

EndSub

Sub 'PlanoPadrao'

	If &CreRecPag = ReceberPagar.Pagar //ADIANTAMENTO PARA O FORNECEDOR
		RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon027_PlanoContasFornecedor, &CfgVlr)
	Else
		//RECEBIMENTO ADIANTANDO DO CLIENTE
		RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &CfgVlr)
	EndIf
	&auxPlanCod = retornaMesmoValor.Udp(&CfgVlr, &EmpCod)
	&PlanCodParcelar = retornaMesmoValor.Udp(&CfgVlr, &EmpCod)

EndSub

Sub 'BuscarPessoa'

	If &PesCod <> 0
		For each Order EmpCod,PesCod,PesSts
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			Where PesSts = Status_AtivoInativo.ATIVO
			
			
			&PesRaz = PesRaz	
			Exit
		When none
			&PesCod.SetFocus()
		EndFor
	Else
		&PesCod.SetFocus()
	EndIf

EndSub


