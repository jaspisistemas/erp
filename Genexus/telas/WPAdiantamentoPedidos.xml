	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &MovCtaBanCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', 'Atenção! Selecione a conta de Lançamento.', DVMessageType.error, &MovCtaBanCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &MovDtaCon.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', 'Atenção! Data Contábil é obrigatório.', DVMessageType.error, &MovDtaCon.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PesCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Cliente'), DVMessageType.error, &PesCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

