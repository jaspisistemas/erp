Event 'DoBtnGravar'

	9
	
	if &totalAdt > 0
		Do 'CheckRequiredFields'
		If &CheckRequiredFieldsResult = True and not &PlanCod.IsEmpty()
			GravaAdiantamentoPedido.Call(&EmpCod,&Filcod,&MovCtaBanCod,&CreRecPag,&MovDtaPgt,&MovDtaCon,&MovDoc,&PesCod,&MovItmCpl,&SdtAdiantamento,&Context.PesCod,&Context.TipoPerfil)
			IF &DeOndeVem = 'WWDuplicataPagar'
				WWDuplicataPagar.Call()
			Else
				WWDuplicataReceber.Call()
			EndIf
		Else
			Msg(DVMessageGetBasicNotificationMsg('Erro', 'Ação não permitida verifique possíveis falhas!', DVMessageType.error, '', DVMessageBoolean.True, ''))
		EndIf
	else
		Msg(DVMessageGetBasicNotificationMsg('Erro', 'Atenção! Não é possível gerar um adiantamento com valor zero! Verifique se o valor foi adicionado.', DVMessageType.error, '', DVMessageBoolean.True, ''))
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoParcelar'

	RetornaCodigoPlanoContas.Call(&EmpCod, &PlanCodParcelar, &PlanCod)
	Do 'PlanoContasParcelar'
	Do Case
		Case &ValorTotal.IsEmpty()
			Msg('Atenção! Valor Total não pode ser zero para parcelar.')
			&ManMovVlr.SetFocus()
		case &ValorParcela.IsEmpty()
			Msg('Atenção! Valor da Parcela não pode ser zero.')
		Case &IsErroPlano = false
				
			&auxDtaVct = &PrimeiroCreDtaVct
			&count = 1
			Do while &count <= &QtdParcelas
				&SdtAdiantamentoItem = new()
				&SdtAdiantamentoItem.DtaVct = &auxDtaVct
				&SdtAdiantamentoItem.Valor = &ValorParcela
				&SdtAdiantamentoItem.PlanCod = &PlanCod
				&SdtAdiantamentoItem.PlanCodNom = &PlanCodNom
				&SdtAdiantamento.Add(&SdtAdiantamentoItem)
				&auxDtaVct = &auxDtaVct.addMonths(1)
				&count += 1
			EndDo
		
			Grid.Refresh()
		otherwise
			msg('Informe Plano de Contas!')
	EndCase
	Do 'PlanoPadrao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RetornaCodigoPlanoContas.Call(&EmpCod, &AuxPlanCod, &PlanCod)
	Do 'PlanoContas'
	Do Case
		Case &ManMovVlr.IsEmpty()
			Msg('Valor não pode ser vazio para adicionar item.')
			&ManMovVlr.SetFocus()
		Case &IsErroPlano <> true	
			&SdtAdiantamentoItem = new()
			&SdtAdiantamentoItem.DtaVct = &AuxCreDtaVct
			&SdtAdiantamentoItem.Valor = &ManMovVlr
			&SdtAdiantamentoItem.PlanCod = &PlanCod
			&SdtAdiantamentoItem.PlanCodNom = &PlanCodNom
			&SdtAdiantamento.Add(&SdtAdiantamentoItem)
			Grid.Refresh()
		otherwise
			msg('Informe Plano de Contas!')
	EndCase

	

	Do 'PlanoPadrao'

