Event &ValorParcela.IsValid

	if &ValorParcela > 0
		&ValorTotal = &ValorParcela * &QtdParcelas
	EndIf

EndEvent

Event &ValorTotal.IsValid

	if &ValorTotal > 0
		&ValorParcela = &ValorTotal / &QtdParcelas
	EndIf

EndEvent

Event &QtdParcelas.IsValid

	Do case
		case &ValorTotal > 0
			&ValorParcela = &ValorTotal / &QtdParcelas
		case &ValorParcela > 0
			&ValorTotal = &ValorParcela * &QtdParcelas
	EndCase

EndEvent

Event &Tipo.IsValid

	Do 'Tipo'

EndEvent

Event &MovDtaPgt.IsValid

	if &OldMovDtaPgt <> &MovDtaPgt
		&MovDtaCon = &MovDtaPgt
		&OldMovDtaPgt = &MovDtaPgt
	Endif

EndEvent

