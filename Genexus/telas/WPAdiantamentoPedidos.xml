      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	//######################## Pega configurações de Parâmetro #############################################
	retornaAutorizacao.Call('WPADIANTAMENTOPEDIDO', Status_SimNao.Sim, 3, &AutNiv)
	
	&CreRecPag.Enabled = false
	
	iF &DeOndeVem = 'WWDuplicataPagar'
		&CreRecPag = ReceberPagar.Pagar
		&PesCod.Caption = 'Fornecedor'
	Else
		&CreRecPag = ReceberPagar.Receber
		&PesCod.Caption = 'Cliente.'
	EndIf
	
	&MovTip  = TipoMovimento.AdiantamentoPedido
	&MovDta  = ServerDate()
	&OldMovDtaPgt = &MovDta
	&MovDtaPgt = &MovDta
	&AuxCreDtaVct = &MovDta
	&PrimeiroCreDtaVct = &MovDta
	&MovDtaCon = ServerDate()
	&MovCreDeb = 'D' 
	
	Do 'PlanoPadrao'
	//######################### Configurações de parâmetro para lançamento de origem (DÉBITO)#########

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&MovDoc.TooltipText = "Nro do documento"
	&PlanCod.Visible = False
	&MovTip.Visible = False
	&MovDta.Visible = False
	&MovCreDeb.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 5

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'Tipo'

EndEvent

Event Grid.Load

	&total = 0
	For &SdtAdiantamentoItem in &SdtAdiantamento
		&DtaVct = &SdtAdiantamentoItem.DtaVct
		&auxPlanCod = Str(&SdtAdiantamentoItem.PlanCod)
		&valor = &SdtAdiantamentoItem.Valor
		&total += &valor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar = !'<i class="fas fa-times"></i>'

