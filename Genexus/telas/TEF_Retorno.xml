      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&WwpContext)
	tbProgresso.Visible = 0
	btnEnter.Visible = 0
	btnImprimir.Visible = 0
	btnImprimirA4.Visible = 0
	
	&Imagem.FromImage(Loading)
	&Count = 0
	txt1.Caption = 'Aguardando inicio terminal TEF'
	txt2.Caption = 'Aguarde, ...'
	txt3.Caption = 'Tentativa conexão, ...'
	txt4.Caption = ''
	txt5.Caption = ''
	txt6.Caption = ''
	txt7.Caption = ''
	txt8.Caption = ''

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 200
	UnnamedTable2.Width = 60
	UnnamedTable2.Height = 50

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each ORder EmpCod, TefCod
		Where EmpCod = &EmpCod
		Where TefCod = &TefCod
		&ProgressId = 'TEF'+TefGUID.Trim()
		
		if TefSts = 'F' or TefSts = 'S'
			do 'VerificaRetornoTEF'
		Else
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()	
			EsperaSegundosEstipulados.Submit('', &ProgressId, 2 )
		EndIf
		
		Exit
	When none
		Return
	EndFor

EndEvent

Event Enter

	Do Case
		CAse &DeOndeVem = 'AVULSO'
			Return
		Otherwise
			Return
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	RetornaTefAutorizado.call(&EmpCod, &TefCod, &TefMsg)
	if not &TefMsg.IsEmpty()
		RCOOpenWindow1.LinkOpen = TEF_COmPROVANTE_0.Link(&EmpCod, &TefCod)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirA4'

	RetornaTefAutorizado.call(&EmpCod, &TefCod, &TefMsg)
	if not &TefMsg.IsEmpty()
		RCOOpenWindow1.LinkOpen = TEF_COmPROVANte_A4.Link(&EmpCod, &TefCod)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ScaProgressBar1.OnComplete

	do 'VerificaRetornoTEF'
	if &TefItmSts.IsEmpty() and &IsAutorizado <> true
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()	
		EsperaSegundosEstipulados.Submit('', &ProgressId, 2 )
	Endif

EndEvent

Sub 'VerificaRetornoTEF'

	txt1.Caption = ''
	txt2.Caption = ''
	txt3.Caption = ''
	txt4.Caption = ''
	txt5.Caption = ''
	txt6.Caption = ''
	txt7.Caption = ''
	txt8.Caption = ''
	
	&Count = 0
	
	For Each Order EmpCod, TefCod, (TefItmID)
		Where EmpCod = &EmpCod
		Where TefCod = &TefCod
		
		&PedCod = TefPedCod
		&FilCod = TefFilCod
		&TEfCrePar = TefCrePar
		&TefBanCarCod = TefBanCarCod
		&TefDtaSol = TefDtaSol
//		&TefPlanCod = TefPlanCod
		Do Case
			CAse TefItmSts = 'F'
				&Imagem.FromImage(errosucesso)
				btnEnter.Visible = 1
				
			CAse TefItmSts = 'S'
				
				if TefPedCod > 0
					if TefCreDebVou = 'D'
						&CarForPag = 1
					Else
						&CarForPag = 2
					Endif
					
					do 'ForPedido'
				Else
					&IsAutorizado = true
				EndIf
				
				if &IsAutorizado = true
					&Imagem.FromImage(Completado)
					btnEnter.Visible = 1
					btnImprimir.Visible = 1
					btnImprimirA4.Visible = 1
				Else
					&Count += 1
					
					Do CAse
						Case &Count = 1
							txt1.Caption = TefMsg
						Case &Count = 2
							txt2.Caption = TefMsg
						Case &Count = 3
							txt3.Caption = TefMsg
						Case &Count = 4
							txt4.Caption = TefMsg
						Case &Count = 5
							txt5.Caption = TefMsg
						Case &Count = 6
							txt6.Caption = TefMsg
						Case &Count = 7
							txt7.Caption = TefMsg
						Case &Count = 8
							txt8.Caption = TefMsg
					endCase
				EndIf
				
			Otherwise
				&Count += 1
				
				Do CAse
					Case &Count = 1
						txt1.Caption = TefMsg
					Case &Count = 2
						txt2.Caption = TefMsg
					Case &Count = 3
						txt3.Caption = TefMsg
					Case &Count = 4
						txt4.Caption = TefMsg
					Case &Count = 5
						txt5.Caption = TefMsg
					Case &Count = 6
						txt6.Caption = TefMsg
					Case &Count = 7
						txt7.Caption = TefMsg
					Case &Count = 8
						txt8.Caption = TefMsg
				endCase
		EndCase
	
		if not TefItmSts.IsEmpty() and not TefItmSts.IsNull()
			&TefItmSts = TefItmSts
		Endif
		
	When NOne
		txt1.Caption = 'Aguardando inicio terminal TEF'
		txt2.Caption = 'Aguarde, ...'
		txt3.Caption = 'Tentativa conexão, ...'
	EndFor

EndSub

Sub 'ForPedido'

	For Each Order EmpCod, FilCod, PedCod, PedFrpItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedFrpIsTefCod = &TefCod
		
		if &CarForPag = 1 //DEBITO
			&sdtPgto  = new()
			&sdtPgto.FrpPgtoCod = 5
			&sdtPgto.FrpPgtoTip = TipoDuplicata.CARTAOD
			&sdtPgto.CreDtaEms = &TefDtaSol
			
			&sdtPgto.CreDtaVct = &TefDtaSol
			&sdtPgto.creVlrDup = PedTipVlr
			&sdtPgto.PlanCod = &CarPlanCod
			
			//Cartao
			&sdtPgto.CreCarArqc = &CreCarArqc
			&sdtPgto.CreCarNroAut = PedFrpAutCrt
			&sdtPgto.CarParQtd = &TEfCrePar
			&sdtPgto.BanCarCod = &TefBanCarCod
			&sdtPgto.CarForPag = &CarForPag
			
			do 'GravaFormaSelecionada'
			
		Else
			&sdtPgto  = new()
			&sdtPgto.FrpPgtoCod = 8
			&sdtPgto.FrpPgtoTip = TipoDuplicata.CARTAOC
			&sdtPgto.CreDtaEms = &TefDtaSol
			
			&sdtPgto.CreDtaVct = &TefDtaSol
			&sdtPgto.creVlrDup = PedTipVlr
			&sdtPgto.PlanCod = &CarPlanCod
			
			//Cartao
			&sdtPgto.CreCarArqc = &CreCarArqc
			&sdtPgto.CreCarNroAut = PedFrpAutCrt
			&sdtPgto.CarParQtd = &TEfCrePar
			&sdtPgto.BanCarCod = &TefBanCarCod
			&sdtPgto.CarForPag = &CarForPag
			
			do 'GravaFormaSelecionada'
		Endif
		
		&IsAutorizado = true
		Exit
	EndFor

EndSub

Sub 'GravaFormaSelecionada'

	MontaDuplicatasPedidoVenda01_JDF.Call('ADD', &EmpCod, &FilCod, &PedCod, &sdtPgto)

EndSub


