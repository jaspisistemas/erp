      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	
	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	
	&HojeDataHora = serverdate()
	
	&PesSacPrxLig = &HojeDataHora
	&Hora = '18:00:00'
	
	&PrxPesSacPrxLig = &PesSacPrxLig 
	&Hor = val(Substr(&Hora, 1, 2))
	&min = val(Substr(&Hora, 4, 2))
	&Seg = val(Substr(&Hora, 7, 2))
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddHours(&Hor)
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddMinutes(&min)
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddSeconds(&Seg)
	
	&Dias = 7
	&oldDias = &Dias
	&PesSacPrxLig = &HojeDataHora.AddDays(&Dias)
	txtDiaSemana.Caption = Substr(CDoW(&PesSacPrxLig), 1, 3)
	
	TextBlockTitle.Caption = 'Incluir Diálogo, CLIENTE: ' + trim(str(&PesCod))
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &Context.EmpCod
		Where PesCod = &PesCod
		&PesVinCod = PesVinCod
		&PesCodRaz = PesCodRaz
		Exit
	EndFor
	do 'TrocaTelevendas'
	do 'MONTACOMBOBOX'
	
	&Link = &DeOndeVem.Trim() + '.aspx'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Link.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	wctele.Object = wcTelefones.Create(&Context.EmpCod, &PesCod)
	wcEmail.Object = wcEmailContato.Create(&Context.EmpCod, &PesCod)
	//wcClientesVinculo.Object = wcClientesVinculos.Create(&Context.EmpCod, &PesVinCod)
	//wcdadosad.Object = wcDadosComerciais.Create(&Context.EmpCod, &PesCod)
	//wcDupCliente.Object = wcDuplicatasCliente.Create(&Context.EmpCod, &Context.FilCod, &PesCod)
	wcHistorico.Object = wcObservacaoesSac.Create(&Context.EmpCod, &PesCod, 5)

EndEvent

Event Enter

	&PesSacDlg = &PesSacDlg.ToUpper().ReplaceRegEx('#JASPI#','-JASPI-')
	&IsRedirecionarVendas = false
	do 'GravaComentario'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGravarEcontinuar'

	&IsRedirecionarVendas = true
	do 'GravaComentario'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraClientes'

	link(&Link)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn_MonitoraVendas'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPedidoTelevendas.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoHistorico'

	wwHistoricoCliente.Link(&PesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	
	&HojeDataHora = serverdate()

EndEvent

Event &PesSacPrxLig.IsValid

	txtDiaSemana.Caption = Substr(CDoW(&PesSacPrxLig), 1, 3)

EndEvent

Event gxUITabsPanel_DadosCliente.TabChanged

	&Numeric = gxUITabsPanel_DadosCliente.ActivePage
	
	do CAse 
		Case &Numeric = 1	
			wctele.Object = wcTelefones.Create(&Context.EmpCod, &PesCod)
			wcEmail.Object = wcEmailContato.Create(&Context.EmpCod, &PesCod)
		Case &Numeric = 2
			wcdadosad.Object = wcDadosComerciais.Create(&Context.EmpCod, &PesCod)
		Case &Numeric = 3
			wcDupCliente.Object = wcDuplicatasCliente.Create(&Context.EmpCod, &Context.FilCod, &PesCod)
		Case &Numeric = 4
			wcClientesVinculo.Object = wcClientesVinculos.Create(&Context.EmpCod, &PesVinCod)
		Case &Numeric = 5
			WCCatalogoTelevendasWC.Object = CatalogoTelevendasWC.Create(&PesCod)
	EndCase

EndEvent

Event &Hora.IsValid

	FormataHORA.Call(&Hora, &Hora)
	if &Hora = '00:00:00'
		&Hora = '18:00:00'
	EndiF

EndEvent

Event &Dias.IsValid

	If &oldDias <> &Dias
		&oldDias = &Dias
		&PesSacPrxLig = &HojeDataHora.AddDays(&Dias)
		txtDiaSemana.Caption = Substr(CDoW(&PesSacPrxLig), 1, 3)
	EndIF

EndEvent

Event &PesSacDlg.IsValid

	&PesSacDlg = &PesSacDlg.ToUpper()

EndEvent

Sub 'TrocaTelevendas'

	RetornaAutorizacao.CALL('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1, &TrocarTelevendas)
	if &TrocarTelevendas < 1
		&VendedorPesCod.Enabled = 0
	EndIF

EndSub

Sub 'MONTACOMBOBOX'

	&VendedorPesCod.Clear()
	
	if &ContextPesCod <> &Context.PesCod
		retornaNomePessoa.Call(&Context.EmpCod, &ContextPesCod, &AuxPesRaz)
		if not &AuxPesRaz.IsEmpty()
			&NomeCombo = trim(str(&ContextPesCod)) + ' - ' + trim(&AuxPesRaz)
			&NomeCombo = gxGetMLi(&NomeCombo, 1, 50)
			&VendedorPesCod.AddItem(&ContextPesCod, trim(&NomeCombo))
		EndiF
	EndIF

	&NomeCombo = trim(str(&Context.PesCod)) + ' - ' + trim(&Context.PesRaz)
	&NomeCombo = gxGetMLi(&NomeCombo, 1, 50)
	&VendedorPesCod.AddItem(&Context.PesCod, trim(&NomeCombo))
	&VendedorPesCod = &ContextPesCod

EndSub

Sub 'GravaComentario'

	&PrxPesSacPrxLig = &PesSacPrxLig 
	&Hor = val(Substr(&Hora, 1, 2))
	&min = val(Substr(&Hora, 4, 2))
	&Seg = val(Substr(&Hora, 7, 2))
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddHours(&Hor)
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddMinutes(&min)
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddSeconds(&Seg)
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon043_DiasMaxPrxLig, &CfgVlr)
	&valor =  val(&CfgVlr)
	&MaximaData = Serverdate() + &valor
	&HojeDataHora = serverdate()
	Do Case
		Case &PesSacDlg.IsEmpty()
			msg('Escreva o conteúdo da conversa para poder agendar uma próxima ligação!')
			&PesSacDlg.Setfocus()
			
		Case &PrxPesSacPrxLig > &MaximaData
			&Mensagem = 'Não é Permitido o Agendamento para uma data superior à ' + trim(str(&valor)) + ' dias! [CONF197]'
			msg(&Mensagem)
			&PesSacDlg.Setfocus()
			
			//		Case &HojeDataHora > &PrxPesSacPrxLig 
			//			msg('Não é possível agendar uma data inferior à Hoje!')
			//			&PesSacDlg.Setfocus()
			
		Otherwise
			RetornaIsVendedor.Call(&Context.EmpCod, &VendedorPesCod, &PesIsVen, &PesVenIntExt)
			
			Do CAse
				Case &PesSacTipObs = true
					&auxPesSacTipObs = 'A'
				CAse &PesIsVen = true and &PesVenIntExt = Status_InternoExterno.INTERNO
					&auxPesSacTipObs = 'I'
				CAse &PesIsVen = true and &PesVenIntExt = Status_InternoExterno.EXTERNO
					&auxPesSacTipObs = 'E'
				Otherwise
					&auxPesSacTipObs = 'A'
			EndCAse	
			&PesSacDlg = &PesSacDlg.ToUpper()
			GravaLigacaoTelevendas.Call(&Context.EmpCod, &PesCod, &VendedorPesCod, &PesIsVen, &PesVenIntExt, &PesSacDlg, &PrxPesSacPrxLig, &auxPesSacTipObs, &Context.PesCod)
			
			If &IsRedirecionarVendas = true
				&WebSession.Set('TELEVENDAS_VENDEDOR', &VendedorPesCod.ToString())
				&WebSession.Set('TELEVENDAS_CLIENTE', &PesCod.ToString())
				PedidoVendas.Link(TrnMode.Insert, &EmpCod, &FilCod, 0, 'PEDIDOTELEVENDAS')
			Else
				link(&Link)
			EndIF
		
	EndCase

EndSub


]]></Source>
