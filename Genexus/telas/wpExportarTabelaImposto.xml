	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&PedCod > 0 and &ImpCatCod = 0)
		&CategoriasPedido.Visible = False
		CategoriasPedido_Cell.Class = !'Invisible'
	Else
		&CategoriasPedido.Visible = True
		CategoriasPedido_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &ImpCatCod = 0
		&CategoriasPedido = false
	EndIf

EndSub

Event &ImpCatCod.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event fileUpload1.UploadComplete

	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&NomeArquivoXml = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			ImportarTabelaImposto.Call(&EmpCod, &wwpContext.PesCod, &NomeArquivoXml)
			
			wpImportacaoTabelaImposto.Link(&EmpCod, &wwpContext.PesCod)
		EndiF
	EndFor
	
	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent

