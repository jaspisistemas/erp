	UnnamedTable4.Height = 300
	UnnamedTable5.Height = 300

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&parPedCod = 0
	if &CategoriasPedido = true and &ImpCatCod = 0
		&parPedCod = &Pedcod
	Endif

	ExportarTabelaImpostoConfiguracoes.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &ImpLctCod, &ImpFilCod, &ImpUfeCod, &ImpGruImpCod, &ImpCatCod, &parPedCod, &CaminhoVirtual)
