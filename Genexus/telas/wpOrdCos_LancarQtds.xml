      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	&AptDtaLct = serverdate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&QuantidaeJaLancada.Visible = False
	&diferenca.Visible = False
	&Precisa.Visible = False
	&AptAtiCod.Visible = False
	&AptCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadOrdemCostura'

EndEvent

Event 'DoSair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWOrdemCostura.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AptProRef.Click

	do 'loadProduto'

EndEvent

Event &AptProRef.IsValid

	do 'loadProduto'

EndEvent

Event Enter

	prcOrdemCostura_QuantidadeLancada.Call(&EmpCod, &OcsCod, &AptProRef, &AptEtpCod, &QuantidaeJaLancada)
	
	do 'RetornaQuantoPrecisa'	
	&diferenca = &Precisa-&QuantidaeJaLancada
	
	Do Case
		Case &AptQtd <= 0
			msg('Informe a Quantidade Produzida!')
			&AptQtd.SetFocus()
			
		Case &diferenca < &AptQtd 
			msg('Quantidade informada já ultrapassa a quantidade restante!, resta: ' + trim(ToformattedString(&diferenca)))
			&AptQtd.SetFocus()
			
		Case &diferenca <= 0
			msg('Não a mais quantidades pendentes nessa etapa!')
			&AptQtd.SetFocus()
			
		Case &AptProRef.IsEmpty() or &AptProRef = 0
			msg('Informe o Produto')
			&AptProRef.SetFocus()
			
		Case &AptFunCod.IsEmpty() or &AptFunCod = 0
			msg('Informe o Funcionário')
			&AptFunCod.SetFocus()
			
		Case &AptEtpCod.IsEmpty() or &AptEtpCod = 0
			msg('Informe a Etapa do produto')
			&AptEtpCod.SetFocus()
		
		Case &AptDtaLct.IsEmpty()
			msg('Informe a Data do Lançamento!')
			&AptDtaLct.SetFocus()
			
		Otherwise
			
			GravaApontamentos_OrdemCostura.Call(&EmpCod, &AptCod, &AptDtaLct, &AptAtiCod, &AptFunCod, &ProCod, &ProGraCod, &AptEtpCod, &AptQtd, &AptObs, &OcsCod, &AptProRef)
			
			refresh
			msg('Quantidades Lançadas com sucesso!')
			do 'LoadOrdemCostura'
		
			&AptQtd.SetEmpty()
			&AptFunCod.SetEmpty()
			&AptObs.SetEmpty()
			&AptDtaLct.SetFocus()
	EndCase

EndEvent

Sub 'RetornaQuantoPrecisa'

	&Precisa = 0
	For Each Order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &AptProRef
		&Precisa = OcsQtd
		Exit
	EndFor

EndSub

Sub 'loadProduto'

	&GrupCod = 0
	&GrupCodNom.SetEmpty()
	&ProCod.SetEmpty()
	&ProGraCod.SetEmpty()
	
	For Each Order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &AptProRef
//		if &OcsProGraNom = &AptProRef
			&ProCod = OcsProCod
			&ProGraCod = OcsProGraCod
			Exit
//		EndIF	
	EndFor
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&GrupCodNom = GrupCodNom
		&GrupCod = GrupCod
		Exit
	EndFor

EndSub

Sub 'LoadOrdemCostura'

	&Count = 0
	
	For Each Order EmpCod, OcsCod
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		
		&Cliente = OcsCliRaz
		
		//PRODUTOS
		&Count = 0
		For Each Order EmpCod, OcsCod, OcsItm
			Where OcsPerCon < 100
			&Count +=1
			&OcsProGraNom = '[ITEM: ' +trim(str(OcsItm)) + '] '+ OcsProGraRef.Trim() + ' - ' + OcsProGraNom.Trim()
			&AptProRef.AddItem(OcsItm, &OcsProGraNom)
		EndFor
		
		Exit
	EndFor

	if &Count > 1
		&OcsProGraNom = '0 - SELECIONE O PRODUTO'
		&AptProRef.AddItem(0, &OcsProGraNom)
	EndIF

EndSub


]]></Source>
