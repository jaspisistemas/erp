      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPALTERAVENDEDORCLIENTE', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	&PedVenRaz = '<-- INFORME O VENDEDOR'
	&NovPedVenRaz = '<-- INFORME O VENDEDOR'
	&CliPesRaz = 'TODOS OS CLIENTES'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImportar'

	wpImportarClienteVendedor.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CliPesCod.IsValid

	do 'GetCliente'
	grid.Refresh()

EndEvent

Event &PedVenCod.IsValid

	&VendedorCodigo = &PedVenCod
	do 'LoadVendedor'
	&PedVenRaz = &VendedorNome
	&PesVenIntExt = &InternoExterno
	&IsErroVendedorAnterior = &IsErroVendedor
	grid.Refresh()

EndEvent

Event &NovPedVenCod.IsValid

	&NovPesVenIntExt.SetEmpty()
	&VendedorCodigo = &NovPedVenCod
	do 'LoadVendedor'
	&NovPedVenRaz = &VendedorNome
	&NovPesVenIntExt = &InternoExterno
	&IsErroNovoVendedor = &IsErroVendedor
	
	If &NovPedVenCod = 1
		&NovPesVenIntExt = Status_InternoExterno.EXTERNO
	EndIf
	grid.Refresh()

EndEvent

Event &NovIntPedVenCod.IsValid

	&NovIntPesVenIntExt.SetEmpty()
	&VendedorCodigo = &NovIntPedVenCod
	do 'LoadVendedor'
	&NovIntPedVenRaz = &VendedorNome
	&NovIntPesVenIntExt = &InternoExterno
	&IsErroIntNovoVendedor = &IsErroVendedor
	If &NovIntPedVenCod = 1
		&NovIntPesVenIntExt = Status_InternoExterno.INTERNO
	EndIf

	grid.Refresh()

EndEvent

Event Enter

	Do Case
		Case &NovIntPesVenIntExt <> Status_InternoExterno.INTERNO and (&NovIntPedVenCod > 1)
			msg('Novo Vendedor INTERNO não pode ser do Tipo EXTERNO!')
			&NovIntPedVenCod.SetFocus()
			
		Case &NovPesVenIntExt <> Status_InternoExterno.EXTERNO and (&NovPedVenCod > 1)
			msg('Novo Vendedor EXTERNO não pode ser do Tipo INTERNO!')
			&NovPedVenCod.SetFocus()
			
		Case &IsErroCliente = true
			msg('Cliente informado não Localizado')
			&CliPesCod.SetFocus()
			
		Case &IsErroIntNovoVendedor = true and (&NovIntPedVenCod > 1)
			msg('Novo Vendedor INTERNO informado, inválido!')
			&NovPedVenCod.SetFocus()
			
		Case &IsErroNovoVendedor = true and (&NovPedVenCod > 1)
			msg('Novo Vendedor EXTERNO informado, inválido!')
			&NovPedVenCod.SetFocus()
			
		Case &IsErroVendedorAnterior = true and (&PedVenCod > 1)
			msg('Vendedor Anterior informado, inválido!')
			&PedVenCod.SetFocus()
						
		Otherwise
			wpAlteraVendedorCliente1.Popup(&EmpCod, &PedVenCod, &NovPedVenCod, &NovIntPedVenCod, &CliPesCod)
			Refresh
	EndCase

EndEvent

Sub 'GetCliente'

	&CliPesRaz = 'TODOS OS CLIENTES DO VENDEDOR ATUAL'
	&IsErroCliente = false
	
	If &CliPesCod <> 0
		For Each Order EmpCod, PesCod, PesIsCli
			Where EmpCod = &EmpCod
			Where PesCod = &CliPesCod
			Where PesIsCli = true
			&CliPesRaz = PesRaz
			Exit
		When none
			&CliPesRaz = 'CLIENTE NÃO LOCALIZADO'
			&IsErroCliente = true
		EndFor
	EndIF

EndSub

Sub 'LoadVendedor'

	&VendedorNome = '<-- INFORME O VENDEDOR'
	
	&IsErroVendedor = true
	
	If &VendedorCodigo <> 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &VendedorCodigo
			Where PesIsVen = true
			
			&InternoExterno = PesVenIntExt
			&VendedorNome = PesRaz
			
			If not PesDtaDem.IsEmpty()
				msg('Atenção!, Vendedor ' + trim(str(PesCod)) + ' consta como Demitido!')
			EndIF
			&IsErroVendedor = false
			
			Exit
		When none
			&VendedorNome = 'VENDEDOR NÃO LOCALIZADO'
		EndFor	
	EndIf

