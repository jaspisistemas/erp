      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each ORder EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where CreCod = &CreCod
		if CreSts = Status_Duplicata.CANCELADA
			
			If not CreCheCod.IsEmpty() and not CreCheCod.IsNull()
				ChequeTerceiros_AlteraStatus.Call(EmpCod, CreCheCod, MotivoCheque.CANCELADO)
			Endif
		
			return
			
		EndIF
		
		Do CAse
			Case CreFrpPgtoTip = TipoDuplicata.CHEQUEP or CreFrpPgtoTip = TipoDuplicata.CHEQUET
				txtMsg.Caption = 'ATENÇÃO! Esta duplicata é do tipo CHEQUE, Nro.:' + trim(CreDupNro) + ' CLI/FOR.:' + trim(CreCliRaz)+', se cancelar essa duplicata, o cheque será excluido!'
			Case CreOriDup = OrigemDuplicata.PagamentoFerias or CreOriDup = OrigemDuplicata.PagamentoRescisao
				txtMsg.Caption = 'Deseja cancelar o laçamento de Férias/Rescisão Nro.:' + trim(CreDupNro) + ' CLI/FOR.:' + trim(CreCliRaz)
			Otherwise
				txtMsg.Caption = 'Deseja cancelar a duplicata Nro.:' + trim(CreDupNro) + ' CLI/FOR.:' + trim(CreCliRaz)
		EndCase
	
		tbAvisoBoleto.Visible	= CreCbrTipBol = TipoBoleto.Hibrido And Not CreBloNro.IsEmpty() And Not CreDtaRet.IsEmpty()
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Width = 750
	tbAvisoBoleto.Height = 40

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	CancelarDuplicata.call(&EmpCod,&FilCod,&CreCod, &Mensagem)
	if &Mensagem.IsEmpty()
		Return
	Else
		msg(&Mensagem)
	EndIF

EndEvent


]]></Source>
