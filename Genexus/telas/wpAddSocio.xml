      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	RetornaAutorizacao.Call('WWPESSOASOCIO', Status_SimNao.Sim, 2, &AutNiv)
	
	&PesSocCod = &inPesSocCod
	do 'loadSocio'
	&PesSocCpf.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	RETURN

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbDataExclusao.Visible = (&PesSocSts = Status_AtivoInativo.Inativo)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &pesSocSts.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event Enter

	validaCpfCnpj.Call(&PesSocCpf, &erroCPF, 'S')
	
	Do Case
		Case &erroCPF <> 0 and &PesSocSts <> Status_AtivoInativo.INATIVO
			msg('CPF/CNPJ inválido ou não informado!')
			&PesSocCpf.SetFocus()
			
		Case &PesSocNom.IsEmpty() and &PesSocSts <> Status_AtivoInativo.INATIVO
			msg('Nome do Sócio Obrigatório')
			&PesSocNom.SetFocus()
			
		Case (&PesSocPer.IsEmpty() or &PesSocPer > 100)  and &PesSocSts <> Status_AtivoInativo.INATIVO
			msg('Percentual Participação Inválido')
			&PesSocPer.SetFocus()
			
		Case (&PesSocDtaInc.IsEmpty() or &PesSocDtaInc > serverdate())  and &PesSocSts <> Status_AtivoInativo.INATIVO
			msg('Data de inclusão do Sócio à Sociedade inválida')
			&PesSocDtaInc.SetFocus()
			
		Case &PesSocDtaFin.IsEmpty() and &PesSocSts = Status_ativoInativo.INATIVO
			msg('Data de exclusão do Sócio à Sociedade obrigatório!')
			&PesSocDtaFin.SetFocus()
			
		Otherwise
			if &PesSocSts <> Status_ativoInativo.INATIVO
				&PesSocDtaFin.SetEmpty()
			EndIF
		
			AtualizaCapitalSocial.Call(&EmpCod, &PesCod, &PesSocVlrTot, &PesDtaFun)
			GravaSocio.Call('ADD', &EmpCod, &wwpContext.FilCod, &PesCod, &PesSocCod, &PesSocNom, &PesSocCpf, &PesSocPer, &PesSocDtaInc, &PesSocDtaFin, &PesSocSts,&PesSocDtaNas,&PesSocAdm, &wwpContext.UserName)
			Return
	EndCase

EndEvent

Event &PesSocCpf.IsValid

	validaCpfCnpj.Call(&PesSocCpf, &erroCPF, 'S')
	
	if &oldPesSocCpf <> &PesSocCpf
		LoadSocioCPF.Call(&EmpCod, &PesCod, &PesSocCpf, &PesSocNom, &PesSocCod, &PesSocSts, &PesSocPer, &PesSocDtaInc)
	Endif
	&oldPesSocCpf = &PesSocCpf

EndEvent

Event &PesSocPer.IsValid

	Do 'CalculaCapital'

EndEvent

Event &PesSocVlrTot.IsValid

	Do 'CalculaCapital'

EndEvent

Event Refresh

	Do 'CalculaCapital'

EndEvent

Sub 'loadSocio'

	For each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod 
		
		&PesCodRaz = PesCodRaz
		&PesSocVlrTot = PesSocVlrTot
		&PesDtaFun = PesDtaFun
		
		For each Order EmpCod, PesCod, PesSocCod
			Where PesSocCod = &PesSocCod
			&PesSocDtaNas = PesSocDtaNas
			&PesSocNom = PesSocNom
			&PesSocCpf = PesSocCpf
			&PesSocSts = PesSocSts
			&PesSocAdm = PesSocAdm
			&PesSocPer = PesSocPer
			&PesSocDtaInc = PesSocDtaInc
			&oldPesSocCpf = PesSocCpf
			Exit
		EndFor
	
		Exit
	EndFor

EndSub

Sub 'CalculaCapital'

	if &PesSocPer > 0 and &PesSocVlrTot > 0 
		&ValorCapitalSocio = &PesSocVlrTot * (&PesSocPer / 100)
	else
		&ValorCapitalSocio.SetEmpty()
	EndIf

EndSub


