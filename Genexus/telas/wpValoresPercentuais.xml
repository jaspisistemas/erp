      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Percentual1 = &FinForPer1
	&Percentual2 = &FinForPer2
	&Percentual3 = &FinForPer3
	&Percentual4 = &FinForPer4
	
	if &FinVlr > 0
		If &Percentual1 > 0
			&Moeda1 = (&FinVlr * &FinForPer1) / 100
		EndIf
		If &Percentual2 > 0
			&Moeda2 = (&FinVlr * &FinForPer2) / 100
		EndIf
		If &Percentual3 > 0
			&Moeda3 = (&FinVlr * &FinForPer3) / 100
		EndIf
		If &Percentual4 > 0
			&Moeda4 = (&FinVlr * &FinForPer4) / 100
		EndIf
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Moeda1.IsValid

	do 'Calcula'

EndEvent

Event &Moeda2.IsValid

	do 'Calcula'

EndEvent

Event &Moeda3.IsValid

	do 'Calcula'

EndEvent

Event &Moeda4.IsValid

	do 'Calcula'

EndEvent

Event Enter

	&FinForPer1 = &Percentual1
	&FinForPer2 = &Percentual2
	&FinForPer3 = &Percentual3
	&FinForPer4 = &Percentual4
	
	Return

EndEvent

Sub 'Calcula'

	&Percentual1 = 0
	&Percentual2 = 0
	&Percentual3 = 0
	&Percentual4 = 0
	
	if &FinVlr > 0 and &Moeda1 > 0
		&Percentual1 = round((&Moeda1 / &FinVlr) * 100, 2)
	EndIF

	if &FinVlr > 0 and &Moeda1 > 0
		&Percentual2 = round((&Moeda2 / &FinVlr) * 100, 2)
	EndIF

	if &FinVlr > 0 and &Moeda1 > 0
		&Percentual3 = round((&Moeda3 / &FinVlr) * 100, 2)
	EndIF

	if &FinVlr > 0 and &Moeda1 > 0
		&Percentual4 = round((&Moeda4 / &FinVlr) * 100, 2)
	EndIF

EndSub


]]></Source>
