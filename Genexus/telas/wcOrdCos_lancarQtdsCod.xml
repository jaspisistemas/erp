      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	&AptDtaLct = serverdate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&QuantidaeJaLancada.Visible = False
	&diferenca.Visible = False
	&Precisa.Visible = False
	&AptAtiCod.Visible = False
	&AptCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadOrdemCostura'

EndEvent

Event 'DoSair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWOrdemCostura.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConsulta'

	wpOrdemCostura_Lancamentos.Link(&EmpCod, &OcsCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AptEtpCod.IsValid

	do 'LoadEtapa'

EndEvent

Event &OcsProNroCor.IsValid

	do 'loadProduto'

EndEvent

Event Enter

	prcOrdemCostura_QuantidadeLancada.Call(&EmpCod, &OcsCod, &OcsItm, &AptEtpCod, &QuantidaeJaLancada)
	
	do 'RetornaQuantoPrecisa'	
	&diferenca = &Precisa-&QuantidaeJaLancada
	
	do 'loadProduto'
	do 'loadEtapa'
	
	Do Case
		Case &OcsProGraNom.IsEmpty()
			msg('Corte não Localizado!')
			&OcsProNroCor.SetFocus()
			
		Case &AptEtpCod.IsEmpty()
			msg('Etapa Não Localizada!')
			&AptEtpCod.SetFocus()
			
		Case &AptQtd <= 0
			msg('Informe a Quantidade Produzida!')
			&AptQtd.SetFocus()
			
		Case &diferenca < &AptQtd 
			msg('Quantidade informada já ultrapassa a quantidade restante!, resta: ' + trim(ToformattedString(&diferenca)))
			&AptQtd.SetFocus()
			
		Case &diferenca <= 0
			msg('Não a mais quantidades pendentes nessa etapa!')
			&AptQtd.SetFocus()
			
		Case &OcsProNroCor.IsEmpty()
			msg('Informe o Código do Corte')
			&OcsProNroCor.SetFocus()
			
		Case &OcsItm.IsEmpty()
			Msg('Código do Corte não localizado!')
			&OcsProNroCor.SetFocus()
			
		Case &AptFunCod.IsEmpty() or &AptFunCod = 0
			msg('Informe o Funcionário')
			&AptFunCod.SetFocus()
			
		Case &AptEtpCod.IsEmpty() or &AptEtpCod = 0
			msg('Informe a Etapa do produto')
			&AptEtpCod.SetFocus()
		
		Case &AptDtaLct.IsEmpty()
			msg('Informe a Data do Lançamento!')
			&AptDtaLct.SetFocus()
			
		Otherwise
			
			GravaApontamentos_OrdemCostura.Call(&EmpCod, &AptCod, &AptDtaLct, &AptAtiCod, &AptFunCod, &ProCod, &ProGraCod, &AptEtpCod, &AptQtd, &AptObs, &OcsCod, &OcsItm)
			
//			refresh
//			msg('Quantidades Lançadas com sucesso!')
		
			do 'LoadOrdemCostura'
		
			&AptQtd.SetEmpty()
//			&AptFunCod.SetEmpty()
			&AptObs.SetEmpty()
			&AptDtaLct.SetFocus()
	EndCase

EndEvent

Event &AptFunCod.IsValid

	do 'loadFuncionario'

EndEvent

Sub 'LoadEtapa'

	&CTrNom.SetEmpty()
	For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &OcsItm
		where OcsEtpItm = &AptEtpCod
		&CTrNom = OcsEtpGrupNom
		Exit
	When none
		msg('Etapa não Localizada')
		
	EndFor

EndSub

Sub 'loadFuncionario'

	&AptFunNom.SetEmpty()
	
	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &AptFunCod
		&AptFunNom = PesRaz
		Exit
	When none
		msg('Costureira não Localizada!')
	EndFor

EndSub

Sub 'RetornaQuantoPrecisa'

	&Precisa = 0
	&OcsItm = 0
	For Each Order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsProNroCor = &OcsProNroCor
		&OcsItm = OcsItm
		&Precisa = OcsQtd
		Exit
	When none
		msg('Corte não Localizado')
	EndFor

EndSub

Sub 'loadProduto'

	&ProCod.SetEmpty()
	&ProGraCod.SetEmpty()
	&OcsProGraNom.SetEmpty()
	
	For Each Order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsProNroCor = &OcsProNroCor
		
		&OcsItm = OcsItm
		
		&ProCod = OcsProCod
		&ProGraCod = OcsProGraCod
		
		&OcsProGraNom = OcsProGraNom
		Exit
	EndFor

EndSub

Sub 'LoadOrdemCostura'

	&Count = 0
	
	For Each Order EmpCod, OcsCod
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		
		&Cliente = OcsCliRaz
				
		Exit
	EndFor

EndSub


]]></Source>
