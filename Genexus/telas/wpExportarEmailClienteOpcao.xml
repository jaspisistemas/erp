      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	padraousuario.Call('L', '#EMAILEXPORTOpcoes#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&ExportarTipoEmail = Substr(&PadObs, 1, 1)
	if Substr(&PadObs, 2, 1) = '1'
		&ExportarUmEmail = true
	Else
		&ExportarUmEmail = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&SdtEmail.Clear()
	&AuxPesCod = 0
	
	For each
		order EmpCod PesRaz 
		using DSWWCliente(&FiltroPesRaz, &PesCod, &PesSts, &PesIsCli, &DynamicFiltersSelector1, &PesCpf1, &RatCod1, &RatNom1, &PesCliTraCod1, &PesCidCod1, &PesCidNom1, &PesCidUfeCod1, &PesFan1, &PesUltVenDta1, &PesUltVenDta_To1, &PesDtaUltCom1, &PesDtaUltCom_To1, &PesLog1, &PesBai1, &DynamicFiltersEnabled2, &DynamicFiltersSelector2, &PesCpf2, &RatCod2, &RatNom2, &PesCliTraCod2, &PesCidCod2, &PesCidNom2, &PesCidUfeCod2, &PesFan2, &PesUltVenDta2, &PesUltVenDta_To2, &PesDtaUltCom2, &PesDtaUltCom_To2, &PesLog2, &PesBai2, &DynamicFiltersEnabled3, &DynamicFiltersSelector3, &PesCpf3, &RatCod3, &RatNom3, &PesCliTraCod3, &PesCidCod3, &PesCidNom3, &PesCidUfeCod3, &PesFan3, &PesUltVenDta3, &PesUltVenDta_To3,&PesDtaUltCom3, &PesDtaUltCom_To3,  &PesLog3, &PesBai3)
		Where PesEmlFin = true when &ExportarTipoEmail = 'F'
		Where PesEmlPed = true when &ExportarTipoEmail = 'P'
		Where PesEmlFat = true when &ExportarTipoEmail = 'N'
		
		&PesEml = PesEml.Trim()
		&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
	   
	   	if &AuxPesCod <> PesCod or &ExportarUmEmail = false
			&IsAdd = false
			If not &PesEml.IsEmpty() and (&PesEml.IsMatch(&pattern) = true)
				
				&IsAchou = false
				for &SdtEmailItem in &SdtEmail
					if &SdtEmailItem.EmlUrl = &PesEml.Trim()
						&IsAchou = true
						&IsAdd = true
						&AuxPesCod = PesCod
						Exit
					Endif
				EndFor
				
				if &IsAchou = false
					&IsAdd = true
					&AuxPesCod = PesCod
					
					&SdtEmailItem = new()
					&SdtEmailItem.EmlUrl = &PesEml.Trim()
					&SdtEmail.Add(&SdtEmailItem)
				Endif
			Endif
		Endif
	EndFor
	
	for &SdtEmailItem in &SdtEmail
		&Mensagem += &SdtEmailItem.EmlUrl.Trim() + '; '
	EndFor

	&PadObs = &ExportarTipoEmail
	if &ExportarUmEmail = true
		&PadObs += '1'
	Else
		&PadObs += '0'
	Endif
	padraousuario.Call('G', '#EMAILEXPORTOpcoes#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	padraousuario.Call('G', '#EMAILEXPORTSDT#', &Context.PesCod, &Context.EmpCod, &SdtEmail.toJson(), &PadDtaMod)
	
	padraousuario.Call('G', '#EMAILEXPORT#', &Context.PesCod, &Context.EmpCod, &Mensagem, &PadDtaMod)
	WpExportarEmails.Popup()
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
