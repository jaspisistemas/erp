      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWPRODUTO', Status_SimNao.Sim, 2, &AutNiv)
	do 'ComboMarca'
	
	ProBarQtd.Visible = 0
	
	do 'LocalizaProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	ProBarQtd.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&TipoCodigo.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	&gridMarNom = ''
	RetornaNomeMarca.Call(EmpCod, ProBarMarCod, &gridMarNom)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&RemoverCodigo = !'<i class="fa fa-times"></i>'

	Do CAse
	CAse ProBarTip = 'R'
		&TipoCodigo = 'CÓD.REFERENCIA'
	Case ProBarTip = 'B'
		&TipoCodigo = 'CÓD.BARRAS'
	Case ProBarTip = 'E'
		&TipoCodigo = 'ETIQUETA'
	Case ProBarTip = 'O'
		&TipoCodigo = 'ORIGINAL'
	Otherwise
		&TipoCodigo = 'AVULSO'
EndCase

	Do Case
		Case ProBarTip = 'R'
			&TipoCodigo.ColumnClass = !'WWColumn WWColumnSuccess WWColumnSuccessSingleCell'
		Case ProBarTip = 'B'
			&TipoCodigo.ColumnClass = !'WWColumn WWColumnInfo WWColumnInfoSingleCell'
		Case ProBarTip = 'E'
			&TipoCodigo.ColumnClass = !'WWColumn WWColumnWarning WWColumnWarningSingleCell'
		Case ProBarTip = 'O'
			&TipoCodigo.ColumnClass = !'WWColumn WWColumnGray WWColumnGraySingleCell'
		Otherwise
			&TipoCodigo.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if ProBarTip = 'E'
		ProBarQtd.Visible = 1
	Endif
	
	&RemoverCodigo.Visible = (ProBarTip = 'A' OR ProBarTip = 'O' )

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProBarRef.IsValid

	do 'RetornaMarcaOrdem'
	if &ProBarOrd = 0
		&ProBarOrd = 1
	EndIf

EndEvent

Event Enter

	GravaCodigoProduto.Call(&EmpCod, &ProCod, &ProGraCod, &ProBarRef, 'A', 0, &AddMarCod, &ProBarOrd, &Mensagem, &IsErro)
	
	if &IsErro = false
		&ProBarRef.SetEmpty()
		msg(&Mensagem)
		grid.Refresh()
		&ProBarRef.SetFocus()
	Else
		msg(&Mensagem)
		&ProBarRef.SetFocus()
	Endif

EndEvent

Event &RemoverCodigo.Click

	if &AutNiv > 2
		RemoveCodigoProduto.Call(&EmpCod, &ProCod, &ProGraCod, ProBarRef)
		Refresh
	Else
		msg('Não autorizado ao nivel 3 de cadastro de produtos, Excluir Codigo/Cadastro produto!')
	ENdif

EndEvent

Sub 'RetornaMarcaOrdem'

	For Each Order EmpCod, ProCod, ProGraCod, ProBarId
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where ProBarRef = &ProBarRef
		&AddMarCod = ProBarMarCod
		&ProBarOrd = ProBarOrd
		Exit
	EndFor

EndSub

Sub 'ComboMarCa'

	&AddMarCod.Clear()
	For Each Order EmpCod, MarCod
		Where EmpCod = &EmpCod
		
		&AddMarCod.AddItem(MarCod, MarCodNom)
		
	EndFor

EndSub

Sub 'LocalizaProduto'

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		txtProdutoNome.Caption = ProNom
		&ProRef = ProRef
		&ProBar = ProBar
		
		if ProIsGra = true
			
			For Each Order EmpCod, ProCod, ProGraCod
				Where ProGraCod = &ProGracod
				txtProdutoNome.Caption = ProNomGra
				&ProRef = ProGraRef
				&ProBar = ProGraBar
				Exit
			EndFor
		Endif
		
		Exit
	EndFor

	GravaCodigoProdutoRefBarras.Call(&EmpCod, &ProCod, &ProGracod, &ProRef, 'R') //REFERENCIA
	GravaCodigoProdutoRefBarras.Call(&EmpCod, &ProCod, &ProGracod, &ProBar, 'B') //BARRAS

EndSub


]]></Source>
