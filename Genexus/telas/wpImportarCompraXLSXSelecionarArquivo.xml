        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	asdasd.Width = 250
	asdasd.Height = 70
	&tmpNFeCod.Visible = False
	&DeOndeVem.Visible = False
	&FilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	loadwwpContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod
	//&DeOndeVem = 'WPPEDIDOCOMPRAITEM'
	&PrimeiraLinha = 12
	&ColunaREFERENCIA = 2
	&ColunaDESCRICAO = 3
	&ColunaQUANTIDADE = 4
	&ColunaVALORUNITARIO = 7
	&ColunaNCM = 6
	&ColunaCODIGOBARRAS = 9

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		wpImportarCompraXLSX(!'SelecionarArquivo', !'Produtos', false, &SessionGuid)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&PedCliCodRaz = &WizardData.SelecionarArquivo.PedCliCodRaz
	&ColunaVALORUNITARIO = &WizardData.SelecionarArquivo.ColunaVALORUNITARIO
	&ColunaQUANTIDADE = &WizardData.SelecionarArquivo.ColunaQUANTIDADE
	&ColunaNCM = &WizardData.SelecionarArquivo.ColunaNCM
	&ColunaCODIGOBARRAS = &WizardData.SelecionarArquivo.ColunaCODIGOBARRAS
	&ColunaDESCRICAO = &WizardData.SelecionarArquivo.ColunaDESCRICAO
	&ColunaREFERENCIA = &WizardData.SelecionarArquivo.ColunaREFERENCIA
	&PrimeiraLinha = &WizardData.SelecionarArquivo.PrimeiraLinha
	&PedCod = &WizardData.SelecionarArquivo.PedCod
	&tmpNFeCod = &WizardData.SelecionarArquivo.tmpNFeCod
	&DeOndeVem = &WizardData.SelecionarArquivo.DeOndeVem
	&FilCod = &WizardData.SelecionarArquivo.FilCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.SelecionarArquivo.PedCliCodRaz = &PedCliCodRaz
	&WizardData.SelecionarArquivo.ColunaVALORUNITARIO = &ColunaVALORUNITARIO
	&WizardData.SelecionarArquivo.ColunaQUANTIDADE = &ColunaQUANTIDADE
	&WizardData.SelecionarArquivo.ColunaNCM = &ColunaNCM
	&WizardData.SelecionarArquivo.ColunaCODIGOBARRAS = &ColunaCODIGOBARRAS
	&WizardData.SelecionarArquivo.ColunaDESCRICAO = &ColunaDESCRICAO
	&WizardData.SelecionarArquivo.ColunaREFERENCIA = &ColunaREFERENCIA
	&WizardData.SelecionarArquivo.PrimeiraLinha = &PrimeiraLinha
	&WizardData.SelecionarArquivo.PedCod = &PedCod
	&WizardData.SelecionarArquivo.tmpNFeCod = &tmpNFeCod
	&WizardData.SelecionarArquivo.DeOndeVem = &DeOndeVem
	&WizardData.SelecionarArquivo.FilCod = &FilCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event FileUpload1.UploadComplete

	//&WebSession.Set('S', 'FilWPIMP')
	&NomeTemporario = &DeOndeVem.Trim() + 'IMPXLS' + trim(str(&EmpCod)) + trim(Str(&PedCod)) + '-'
	NotaTemporariaApaga.Call(&NomeTemporario)
		
	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&NomeArquivoXml = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			&tmpNFeCod = &NomeTemporario + '1'
			
			GravaXlsxNotaTemporaria.Call(&EmpCod, &FilCod, &PedCod, &tmpNFeCod, &NomeArquivoXml, &PrimeiraLinha, &ColunaREFERENCIA, &ColunaCODIGOBARRAS, &ColunaDESCRICAO, &ColunaNCM, &ColunaQUANTIDADE, &ColunaVALORUNITARIO)
			
			Do 'SaveVariablesToWizardData'			
			wpImportarCompraXLSX(!'SelecionarArquivo', !'Produtos', false, &SessionGuid)
		EndiF
	EndFor

//	if &FileUploadDataColl.Count > 0
//		wpNotaImportadas.Link(&NomeTemporario)
//	Endif
	
	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent


]]></Source>
