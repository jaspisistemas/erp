      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&EnviarAutorizacao 	= Status_SimNao.Nao
	&EnviarConsulta 	= Status_SimNao.Nao
	&AlterarDataNota 	= Status_SimNao.Sim
	
	&Data = SErverDate()
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	txtAviso.ForeColor = RGB(255,102,0)
	&Count = 0
	&NfeDtaEms = Serverdate() - 30
	
	For Each Order EmpCod, NfeProTer, NfeSts, NfeCod
		Where EmpCod = &EmpCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_NFe.Digitando
		Where not NfeNum.IsEmpty() and not NfeNum.IsNull()
		Where ModCod = '65' //NFCe
		&Count += 1
	EndFor

	txtAviso.Caption = 'No momento existem (' + trim(str(&Count)) + ') notas pendentes.'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do case
		Case &Count < 1
			msg('Não existem notas pendentes no momento!')
		Case (&EnviarAutorizacao = Status_SimNao.Nao and &EnviarConsulta = Status_SimNao.Nao and &AlterarDataNota = Status_SimNao.Nao )
			msg('Não selecionado nenhuma opção!')
		Case &AlterarDataNota = Status_SimNao.Sim and &Data > SErverDate()
			msg('Não é possivel atualizar as notas para uma data futura, no máximo até o dia de Hoje!')
		OtherWise
			&ProgressId = 'RetransEmLote' + trim(Str(&Context.EmpCod)) + trim(str(&Context.PesCod))
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			RetransmissaoEmLote.Submit('RetransmissaoEmLote', &ProgressID, &Context.EmpCod, &Context.PesCod, &EnviarAutorizacao, &EnviarConsulta,&AlterarDataNota,&Data, &Context.FilCod)
	EndCase

EndEvent


]]></Source>
