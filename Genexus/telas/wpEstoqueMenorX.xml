      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPESTOQUEMENORX', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	
	&ProSts = Status_AtivoInativo.ATIVO
	&Quantidade = 10
	&SomenteComLocacao = Status_SimNao.Sim
	&UltimoBalanco = Status_SimNao.Sim
	padraousuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	if not &PadObs.IsEmpty()
		do Case
			Case substr(&PadObs, 1,1) = 'A'
				&ProSts = Status_AtivoInativo.ATIVO
			Case substr(&PadObs, 1,1) = 'I'
				&ProSts = Status_AtivoInativo.InATIVO
			Otherwise
				&ProSts.SetEmpty()
		EndCAse
		
		if substr(&PadObs, 2,1) = 'S'
			&SomenteComLocacao = Status_SimNao.Sim
		Else
			&SomenteComLocacao = Status_SimNao.Nao
		EndIF

		
		&Quantidade = val(substr(&PadObs, 3,10))
		&Ordem = substr(&PadObs, 13,1)
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PadObs = padL(&ProSts.ToFormattedString(), 1, ' ')
	&PadObs += padL(&SomenteComLocacao.ToFormattedString(), 1, ' ')
	&PadObs += padL(trim(str(&Quantidade)), 10, '0')
	&PadObs += &Ordem
	padraousuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	Do case
		case &ProSts = Status_AtivoInativo.ATIVO
			&AuxProSts = Status_Produto.ATIVO
		case &ProSts = Status_AtivoInativo.INATIVO
			&AuxProSts = Status_Produto.INATIVO
		otherwise
			&AuxProSts = nullvalue(&AuxProSts)
	EndCase

	RCOOpenWindow1.LinkOpen = RELJAS053.Link(&EmpCod, &FilCod, &AuxProSts, &GrupHie, &MarCod, &Quantidade, &SomenteComLocacao, &Ordem, &UltimoBalanco,&EstLoc)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


]]></Source>
