      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&InGrupAnaSin = 'A'
	&NomePadraoUsuario = '#wpProducaoMensal#'
	&TcpAno = year(Serverdate())
	&TcpMes = month(Serverdate())
	&SinteticoAnalitico = Status_SimNao_PS.NAO

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	GridsdtTipEtqs.Rows = Page.Rows
	GridsdtTipEtqsPaginationBar.RowsPerPageSelectedValue = GridsdtTipEtqs.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&Count = 0
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&NomePadraoUsuario = '#wpProducaoMensal#'
	&InGrupAnaSin = 'A'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtTipEtqsCurrentPage = GridsdtTipEtqs.CurrentPage
	&GridsdtTipEtqsPageCount = GridsdtTipEtqs.PageCount
	&delete.ColumnHeaderClass = !'WWIconActionColumn'
	sdtTipEtq__CD.ColumnHeaderClass = !'WWColumn'
	sdtTipEtq__DES.ColumnHeaderClass = !'WWColumn'
	sdtTipEtq__NWD.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqs.Load

	&Count += 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&delete = !'<i class="fas fa-times"></i>'

	&delete.ColumnClass = iif(&Count > 9, !'WWIconActionColumn WWColumnDanger WWColumnDangerFirstColumn', !'WWIconActionColumn')
	sdtTipEtq__CD.ColumnClass = iif(&Count > 9, !'WWColumn WWColumnDanger', !'WWColumn')
	sdtTipEtq__DES.ColumnClass = iif(&Count > 9, !'WWColumn WWColumnDanger', !'WWColumn')
	sdtTipEtq__NWD.ColumnClass = iif(&Count > 9, !'WWColumn WWColumnDanger', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqsPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtTipEtqsPaginationBar.SelectedPage = !'Previous'
			GridsdtTipEtqs.PreviousPage()
		Case GridsdtTipEtqsPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtTipEtqs.CurrentPage
			&PageToGo += 1
			GridsdtTipEtqs.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtTipEtqsPaginationBar.SelectedPage)
			GridsdtTipEtqs.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqsPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtTipEtqs.Rows = GridsdtTipEtqsPaginationBar.RowsPerPageSelectedValue
	GridsdtTipEtqs.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	do 'ValidaFornecedor'
	&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
	
	RCOOpenWindow1.LinkOpen = RELJAS104.Link(&NomePadraoUsuarioGrava, &Context.EmpCod, &Context.FilCod, &TcpAno, &TcpMes, &proSts, &ProPadForCod, &SinteticoAnalitico)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDadosProducao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpAtualizaDetalhesProducao.PopUp(&EmpCod, &TcpAno, &TcpMes, &ProPadForCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSalvarTodos'

	if not &NomePadraoUsuarioGrava.IsEmpty()
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesSts = Status_AtivoInativo.ATIVO
			Where not PesExtCod.IsEmpty() and not PesExtCod.IsNull()
			
			&PadObs = &sdtTipEtq.ToJson()
			padraoUsuario.Call('G', &NomePadraoUsuarioGrava, PesCod, EmpCod, &PadObs, &padDtaMod)
		EndFor
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProPadForCod.IsValid

	do 'ValidaFornecedor'
	&sdtTipEtq.Clear()
	&PadObs.SetEmpty()
	
	if not &ProPadForRaz.IsEmpty()
		&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
		padraoUsuario.Call('L', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
		&sdtTipEtq.FromJson(&PadObs)
	EndiF

EndEvent

Event Enter

	do 'ValidaFornecedor'
	retornaCodigoCategoriaProduto.Call(&EmpCod, &GrupHie, &GrupCod, &GrupNom, &AuxGrupHie)
	
	
	retornaCodigoCategoriaProduto.Call(&EmpCod, &GrupHieAgrupar, &GrupCodAgrupar, &GrupNomAgrupar, &AuxGrupHieAgrupar)
	
	&IsChou = false
	
	if not &GrupNom.IsEmpty() and not &ProPadForRaz.IsEmpty()
		For &sdtTipEtqItem in &sdtTipEtq
			if &sdtTipEtqitem.CD = &AuxGrupHie
				&IsChou = true
				Exit
			EndIF
		EndFor
		
		if &IsChou = false
			&sdtTipEtqItem = new()
			&sdtTipEtqItem.CD = &AuxGrupHie
			&sdtTipEtqItem.DES = &GrupNom
			&sdtTipEtqItem.NWD = &AuxGrupHieAgrupar
			&sdtTipEtq.Add(&sdtTipEtqItem)
		EndIF
		
		&PadObs = &sdtTipEtq.ToJson()
		&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
		padraoUsuario.Call('G', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
		
		&GrupHieAgrupar.SetEmpty()
	Endif
	
	&GrupHie.SetFocus()

EndEvent

Event &delete.Click

	do 'ValidaFornecedor'
	if not &ProPadForRaz.IsEmpty()
		For &sdtTipEtqItem in &sdtTipEtq
			if &sdtTipEtqItem.CD = &sdtTipEtq.CurrentItem.CD
				&index = &sdtTipEtq.IndexOf(&sdtTipEtqItem)
				&sdtTipEtq.Remove(&Index)
			EndIF
		EndFor
		
		&PadObs = &sdtTipEtq.ToJson()
		&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
		padraoUsuario.Call('G', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
	EndiF

EndEvent

Sub 'ValidaFornecedor'

	&ProPadForRaz.SetEmpty()
	For Each order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &ProPadForCod
		&ProPadForRaz = PesRaz
		Exit
	EndFor

EndSub


