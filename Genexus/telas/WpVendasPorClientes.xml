      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPVENDASPORCLIENTES', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	
	&TrocarTelevendas = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
	&AuxPesVenCod.Enabled = &TrocarTelevendas
	If &TrocarTelevendas = 0
		&AuxPesVenCod = &Context.PesCod
	EndIf

	CodigoCli.Visible = 0
	
	Do 'CarregaDados'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do Case 
		Case &FiltrarPorCliente = True And &PesCod.IsEmpty() //## Caso Clique para filtrar o cliente e não escolher nenhum, emite este erro	##\\
			Msg(DVMessageGetBasicNotificationMsg('', 'É obrigatório informar o Cliente!', DVMessageType.error, &PesCod.InternalName, DVMessageBoolean.True, ''))
			
		OtherWise
			
			OpenNewWindow.LinkOpen = RELJAS155.Link(&PesCod, &CidCod, &PesSts, &RatCod, &AuxPesVenCod, &PedDtaFat_De, &PedDtaFat_Ate, &PesUltVenDta, &AuxPesVenRaz, &RatNom, &CidCodNomUfe)
			OpenNewWindow.OpenWindow(True, 500, 500, True, 0, 0, False)
			
	EndCase

EndEvent

Event &AuxPesVenCod.IsValid

	Do 'CarregaDados'

EndEvent

Event &RatCod.IsValid

	Do 'CarregaDados'

EndEvent

Event &CidCod.IsValid

	Do 'CarregaDados'

EndEvent

Event &FiltrarPorCliente.Click

	If CodigoCli.Visible = 0
		
		CodigoCli.Visible = 1
		
	Else
		
		CodigoCli.Visible = 0
		&PesCod = 0
		
	EndIf

EndEvent

Sub 'CarregaDados'

	If &AuxPesVenCod = 0												//## Se o código do Vendedor for vazio 				##\\
		
		&AuxPesVenRaz = 'TODOS OS VENDEDORES'							//## Define a impressão de todos os vendedores		##\\
		
	Else
		
		For Each Order EmpCod, PesCod									//## Faz uma Busca na Tabela Pessoa					##\\
			Where EmpCod 	= 	&EmpCod									//## Código da Empresa por Parâmetro				##\\
			Where PesCod 	= 	&AuxPesVenCod							//## Código do Vendedor por Parâmetro				##\\
			//Where PesIsVen 	= 	True //jdf nao é mais agora, mas ja foi
			
			&AuxPesVenRaz = PesRaz										//## Atribui a sua Razão Social						##\\
			
		When None														//## Se não houver resultados, emite a mensagem 	##\\
			
			Msg('Vendedor não encontado, ou pessoa não é vendedor!')
			&AuxPesVenCod.SetFocus()
			
		EndFor
	
	EndIf
			
	If &RatCod = 0 														//## Se o código do RAMO/ATIVIDADE for vazio				##\\
		
		&RatNom = 'TODOS OS RAMOS/ATIVIDADES'							//## Define a impressão de todos os RAMOS/ATIVIDADES		##\\
		
	Else
		
		For Each Order RatCod, EmpCod									//## Faz uma busca na Tabela RAMOATIVIDADE					##\\
			Where RatCod = &RatCod										//## Código do RAMO/ATIVIDADE por parâmetro					##\\
			Where EmpCod = &EmpCod										//## Código da Empresa por parâmetro						##\\
			
			&RatNom = RatNom											//## Atribui o nome do RAMO/ATIVIDADE						##\\
			
		When None														//## Se não houver resultados, emite a mensagem 			##\\
			
			Msg('Ramo/Atividade não encontrado, ou cadastrado!')
			&RatCod.SetFocus()
			
		EndFor
	
	EndIf

	If &CidCod = 0														//## Se o código da Cidade for vazio				##\\
		
		&CidCodNomUfe = 'TODAS AS CIDADES/UFE' + 's'					//## Define a impressão de todos os Cidades			##\\
		
	Else		
		
		For Each Order EmpCod, CidCod									//## Faz uma busca na Tabela Cidade					##\\
			Where EmpCod = &EmpCod										//## Código da Empresa por parâmetro				##\\
			Where CidCod = &CidCod										//## Código da Cidade por parãmetro					##\\
			
			&CidCodNomUfe = CidCodNomUfe								//## Atribui o Código, Nome e a Ufe da Cidade		##\\
			
		When None														//## Se não houver resultados, emite a mensagem 	##\\
			
			Msg('Cidade não encontrada, ou não cadastrada!')
			&CidCod.SetFocus()
			
		EndFor
	
	EndIF

EndSub


]]></Source>
