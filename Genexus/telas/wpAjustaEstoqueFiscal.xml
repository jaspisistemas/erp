      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPAJUSTACUSTOFISCAL', Status_SimNao.Sim, 1, &AutNiv)
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	
	padraousuario.Call('L', 'wpAjustaCustoFiscal', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

	&Estoque.FromString(Substr(&PadObs,3,1))
	
//	RetornaTabelaFilial.Call(&EmpCod, &FilCod, &TabNum)
	
//	For Each Order EmpCod, TabCod
//		Where EmpCod = &EmpCod
//		Where TabCod = &TabNum
//		
//		&TabAltCod = TabUltAlt
//		&TabIsPerCol1 = TabIsPerCol1
//		Exit
//	EndFor
//		
	RetornaColunasTabelas.Call(&EmpCod, &TabNum, &TabPerCol, &TabPerCol2, &TabPerCol3,&TabPerCol4,&TabPerCol5,&TabPerCol6,&TabPerCol7,&TabPerCol8,&TabPerCol9,&tem1,&tem2,&tem3,&tem4,&tem5,&tem6,&tem7,&tem8,&tem9)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ProRef.SetFocus()

EndEvent

Event 'DoNovoProduto'

	&sdtGravaProduto.IsPoupop = true	
	&WebSession.Set('DADOSDEFAUT_PRODUTO', &sdtGravaProduto.ToXml())
	
	Produtos.Popup('RETURN', TrnMode.Insert, &EmpCod, &ProCod, &ProRef)
	&ProRef.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&Estoque = 1)
		DVPanel_tbEstoque_Cell.Class = !'Invisible'
	Else
		DVPanel_tbEstoque_Cell.Class = !'col-xs-12'
	EndIf
	If not(&Estoque = 2)
		DVPanel_addtbEstoque_Cell.Class = !'Invisible'
	Else
		DVPanel_addtbEstoque_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Estoque.IsValid

	Do 'AttributesSecurityCode'
	do 'GravaPadObs'

EndEvent

Event &ProRef.IsValid

	do 'carregaProduto'

	Do Case
		Case &ProRef.IsEmpty()
			&ProRef.SetFocus()
		Case &Estoque = 1
			&NovEstQtd.SetFocus()
		Case &Estoque = 2
			&NovaddEstQtd.SetFocus()
	Endcase

EndEvent

Event 'F4'

 4
	PromptProdutoRef.Popup(&EmpCod, &ProCod, &ProRef)
	&ProRef.SetFocus()

EndEvent

Event Enter

	if (&ProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &ProGraCod = 1)
		//GravaBalanco
		if &NovEstQtd <> &EstQtd and &Estoque = 1
			GravaBalancoAcertoEstoqueFiscal.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &NovEstQtd)
		EndIf
		
		//GravaBalanco
		if &NovaddEstQtd > 0 and &Estoque = 2
			&NovEstQtd = &addEstQtd + &NovaddEstQtd
			GravaBalancoAcertoEstoqueFiscal.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &NovEstQtd)
		EndIf
		
		msg('Dados Atualizados com sucesso!')
		
		&ProRef.SetEmpty()
		&EstQtd.SetEmpty()
		&addEstQtd.SetEmpty()
		&NovaddEstQtd.SetEmpty()
		&NovEstQtd.SetEmpty()
		
	Else
		msg('Produto com Variação, é preciso inserir o Código da Variação!')
	EndIF

	&ProRef.SetFocus()

EndEvent

Sub 'LocalizaCodigo'

	For Each Order EmpCod, ProGraCod,ProCod
		Where EmpCod = &EmpCod
		Where ProGraRef = &ProRef
		&ProNom = ProNomGra
		&ProCod = ProCod
		&ProIsGra = ProIsGra
		&ProGraCod = ProGraCod
		
			
		if (&ProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &ProGraCod = 1)
		Else
			msg('Produto com Variação, é preciso inserir o Código da Variação!')
		EndIF
	
		Exit
	EndFor

EndSub

Sub 'CarregaProduto'

	do 'LocalizaCodigo'
	
	For Each order EmpCod, ProCod, ProGraCod,FilCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&Estqtd = EstQtdFis
		&addEstQtd = EstQtdFis
		&NovEstQtd = EstQtdFis
		Exit
	EndFor

EndSub

Sub 'GravaPadObs'

	Do Case
		CAse &Estoque = 1
			&PadObs += '1'
		CAse &Estoque = 2
			&PadObs += '2'
		Otherwise
			&PadObs += '0'
	EndCase
	padraousuario.Call('G', 'wpAjustaCustoFiscal', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

EndSub


]]></Source>
