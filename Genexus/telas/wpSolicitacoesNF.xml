      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 493
	Grid.Rows = 10
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaLinhaTam.Call(&linhaNumeric, &TamanhoNumeric)
	TableMain.Height = &TamanhoNumeric
	Grid.Rows = &linhaNumeric
	
	Do case
		Case &Oquefazer = 'NOTA'
//			TextBlockTitle.Caption = 'Solicitações da Nota Fiscal'
			Form.Caption = 'Solicitações da NFe'
		Case &Oquefazer = 'MDFE'
			Form.Caption = 'Solicitações do MDFe'
//			TextBlockTitle.Caption = 'Solicitações do MDFe'
		Case &Oquefazer = 'CTE'
			Form.Caption = 'Solicitações do CTe'
//			TextBlockTitle.Caption = 'Solicitações do CTe'
		CAse &OqueFazer = 'NFSE'
			form.Caption = 'Solicitações da NFSe'
//			textBlockTitle.Caption = 'Solicitações da NFSe'
	EndCase

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	&SolMsg = Substr(SolMsg, 1, 50)
	&SolMsg.Link = wpSolicitacaoAviso.Link(SolEmpCod, SolCod)
	Do Case
		Case SolSts = Status_Solicitacao.Pendente
			SolSts.ForeColor = RGB(255,150,0)
			
		Case SolSts = Status_Solicitacao.Falha
			SolSts.ForeColor = RGB(255,0,0)
			
		Case SolSts = Status_Solicitacao.Finalizada
			SolSts.ForeColor = RGB(0,150,0)
			
		otherwise
			SolSts.ForeColor = RGB(0,0,0)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
