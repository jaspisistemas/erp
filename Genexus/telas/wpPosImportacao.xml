      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context) 
	if &Context.Old_Perfil < 3
		Dashboard.Link()
		
	EndiF

	&SomenteTotaisNfe = Status_SimNao.Nao
	&AtualizaCadastroPessoas = Status_SimNao.Nao
	&AtualizaCadastroProdutos = Status_SimNao.Nao
	&AtualizaSaldo = Status_SimNao.Nao
	&AtualizaPedidos = Status_SimNao.Nao
	&AtualizaSequenciasTabelas = Status_SimNao.Nao
	&ApagarProdutosSemMovimento = Status_SimNao.Nao
	&SomenteTotaisPedido = Status_SimNao.Nao
	&SomenteVendedor = Status_SimNao.Nao
	&CadastrosPadroes = Status_SimNao.Nao
	&AtualizaDuplicatas = Status_SimNao.Nao
	&SomenteStatus = Status_SimNao.Nao
	&RecadastrarOperacoesFolha = Status_SimNao.Nao
	&RecadastraPlanoContasPadrao = Status_SimNao.Nao
	&DeletarOperacoesFolha = Status_SimNao.Nao
	&DeletarPlanoContas = Status_SimNao.Sim //Por enquanto não tem a opção de não deletar, sempre deleta

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&AtualizaPedidos = Status_SimNao.Sim)
		&SomenteTotaisPedido.Visible = False
		SomenteTotaisPedido_Cell.Class = !'Invisible'
	Else
		&SomenteTotaisPedido.Visible = True
		SomenteTotaisPedido_Cell.Class = !'col-xs-12'
	EndIf
	If Not (&AtualizaPedidos = Status_SimNao.Sim)
		&SomenteTotaisNfe.Visible = False
		SomenteTotaisNfe_Cell.Class = !'Invisible'
	Else
		&SomenteTotaisNfe.Visible = True
		SomenteTotaisNfe_Cell.Class = !'col-xs-12'
	EndIf
	If Not (&AtualizaPedidos = Status_SimNao.Sim)
		&SomenteStatus.Visible = False
		SomenteStatus_Cell.Class = !'Invisible'
	Else
		&SomenteStatus.Visible = True
		SomenteStatus_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AtualizaPedidos.Click

	Do 'AttributesSecurityCode'

EndEvent

Event &AtualizaPedidos.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event scaProgressBar1.OnComplete

		msg('Procedimentos Executados com Sucesso!')
		btnEnter.Visible = 1

EndEvent

Event Enter

	msg('Aguarde...')
	btnEnter.Visible = 0
	&ProgressId = 'wpPosImportacao' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	posImportacao.Submit('posImportacao', &ProgressId, &Context.EmpCod, &AtualizaCadastroPessoas, &AtualizaCadastroProdutos,&AtualizaSaldo,&AtualizaPedidos, &AtualizaSequenciasTabelas, &ApagarProdutosSemMovimento, &SomenteVendedor, &SomenteTotaisPedido, &CadastrosPadroes, &AtualizaDuplicatas, &SomenteStatus, &ApartirData, &SomenteTotaisNfe,&ApagaArquivosTemp,&RecalculaAlojamentos,&CorrigeNcm,&RecadastrarOperacoesFolha,&DeletarOperacoesFolha,&RecadastraPlanoContasPadrao, &Context.UserName)

EndEvent


]]></Source>
