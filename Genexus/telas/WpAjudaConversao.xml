      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'StepOne'
	&WizardStep.Title = 'Definições'
	&WizardStep.Description = 'Definições'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'StepTwo'
	&WizardStep.Title = 'Coversâo'
	&WizardStep.Description = 'Coversâo'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'StepOne'
		&WebSession.Remove(&Pgmname + !'_Data')
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	Do 'LoadWizardStepWC'

	UnnamedTable2.Height = 10
	UnnamedTable1.Width = 800
	StepTitles.Object = WizardStepsVerticalWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'StepOne'
			WizardStepWC.Object = WpAjudaConversaoStepOne.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'StepTwo'
			WizardStepWC.Object = WpAjudaConversaoStepTwo.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: AssignWizardStepDescription
	WizardStepDescription.Caption = ""
	&StepNumber = 1
	for &WizardStep in &WizardSteps
		if &WizardStep.Code = &CurrentStepAux
			if not &WizardStep.Description.IsEmpty()
				WizardStepDescription.Caption = Format("Step %1/%2 :: %3",&StepNumber.ToString().Trim(),&WizardSteps.Count.ToString().Trim(),&WizardStep.Description)
			endif
		else
			&StepNumber += 1
		endif
	endfor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&StepNumber = 1
		for &WizardStep in &WizardSteps
			if &WizardStep.Code = &CurrentStepAux
				if not &WizardStep.Description.IsEmpty()
					WizardStepDescription.Caption = &WizardStep.Description
				endif
			else
				&StepNumber += 1
			endif
		endfor
	EndIf

EndEvent


]]></Source>
