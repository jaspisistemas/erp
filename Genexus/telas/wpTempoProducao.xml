Event Start

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	&AptDtaLctIni = CtoD('01/11/2018')
	&AptDtaLctFin = CtoD('30/11/2018')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	btnEnter.Enabled = 0
	btnEnter.Caption = 'Aguarde ...'
	
	if &wwpContext.PesCod < 0
		prcCalculaTempoProducao.Call(&EmpCod, &FilCod, 0, &GrupHie, &AptDtaLctIni, &AptDtaLctFin, &ProForCod, &wwpContext.UserName)
	Endif

	RCOOpenWindow1.LinkOpen = RELJAS107_A.Link(&EmpCod, &FilCod, 0, &GrupHie, &AptDtaLctIni, &AptDtaLctFin, &ProForCod, &AnaliticoSintetico)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	btnEnter.Enabled = 1
	btnEnter.Caption = 'Confirmar'

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&wwpContext.PesCod < 0)
		&AptDtaLctIni.Visible = False
		AptDtaLctIni_Cell.Class = !'Invisible'
		AptDtaLctIni_RightText_Cell.Class = !'Invisible'
		TextBlockAptDtaLctIni_Cell.Class = !'Invisible'
	Else
		&AptDtaLctIni.Visible = True
		AptDtaLctIni_RightText_Cell.Class = !''
		AptDtaLctIni_Cell.Class = !'MergeDataCell'
		TextBlockAptDtaLctIni_Cell.Class = !'col-sm-2 MergeLabelCell'
	EndIf
	If Not (&wwpContext.PesCod < 0)
		&AptDtaLctFin.Visible = False
		AptDtaLctFin_Cell.Class = !'Invisible'
	Else
		&AptDtaLctFin.Visible = True
		AptDtaLctFin_Cell.Class = !'DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


