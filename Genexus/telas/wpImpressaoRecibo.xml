      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &ParMovCod.IsEmpty()
		&Varchar = &Websession.Get(&random)
		&MovCod = val(&Varchar)
		&MsgDev = 'WebSession: ' +  &Varchar
	Else
		&MovCod = &ParMovCod
		&MsgDev = 'Parametro: ' + &ParMovCod.ToFormattedString()
	Endif

	&webSession.Remove(&Random)
	if &Context.EmpCod = 0 or &Context.PesCod = 0
		LoadWWPContext.Call(&Context)
	EndIf
	
	if &DeOndeVem <> 'AVULSO'
		if &GeraRecibo = '1' //TICKET
			EmbPage1.Source = RELJAS114.Link(&Random, &EmpCod, &FilCod, &MovCod, &CreCliCod, &Context.PesCod)
		Else
			EmbPage1.Source = RELJAS020_001.Link(&Random, &EmpCod, &MovCod, 'MOVIMENTO')
		Endif
	Else
		&sdtRecibo.Clear()
		&sdtReciboItem = new()
		&sdtReciboItem.EmpCod = &EmpCod
		&sdtReciboitem.RcbMovCod = &MovCod
		&sdtRecibo.Add(&sdtReciboItem)
		
		&WebSession.Set('ReciboImp', &sdtRecibo.ToXml())
		
		if &GeraRecibo = '1' //TICKET
			EmbPage1.Source = RELJAS114.Link(&Random, &EmpCod, &FilCod, &MovCod, &CreCliCod, &Context.PesCod)
		Else
			EmbPage1.Source = RELJAS020.Link(&Random, 'MOVIMENTO')
		Endif
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&Context.EmpCod = 1)
		&MsgDev.Visible = False
		MsgDev_Cell.Class = !'Invisible'
	Else
		&MsgDev.Visible = True
		MsgDev_Cell.Class = !'DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
