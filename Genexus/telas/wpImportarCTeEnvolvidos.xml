		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&CteCod = &WizardData.Envolvidos.CteCod
		&EmpCod = &WizardData.Envolvidos.EmpCod
		&FilCod = &WizardData.Envolvidos.FiLCod
		
		For Each ORder EmpCod, FilCod, CteCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CteCod = &CteCod
			
			&LctCod = CteLctCod
			
			if CteEntSai = Status_EntradaSaida.Entrada
				&tmpDestxNom = CteDesRaz
				if CteDesCnpj.IsEmpty() or CteDesCnpj.IsNull()
					&tmpDestxCNPJ = CteDesCpf
				 	validaCpfCnpj.Call(&tmpDestxCNPJ, &Cnpjerro, 'S')
				Else
					&tmpDestxCNPJ = CteDesCnpj
					validaCpfCnpj.Call(&tmpDestxCNPJ, &Cnpjerro, 'S')
				Endif
			
				&tmpDestxCod = CteDesCod
				
				&tmpEmixNom = FilRaz
				&tmpEmixCpfCnpj = FilCpj
				&tmpEmixCod = FilCod
			Else
				&tmpDestxNom = FilRaz
				&tmpDestxCNPJ = FilCpj
				&tmpDestxCod = FilCod
				
				&tmpEmixNom = CteDesRaz
				
				if CteDesCnpj.IsEmpty() or CteDesCnpj.IsNull()
					&tmpEmixCpfCnpj = CteDesCpf
				 	validaCpfCnpj.Call(&tmpEmixCpfCnpj, &Cnpjerro, 'S')
				Else
					&tmpEmixCpfCnpj = CteDesCnpj
					validaCpfCnpj.Call(&tmpEmixCpfCnpj, &Cnpjerro, 'S')
				Endif
			
				&tmpEmixCod = CteDesCod
			Endif

			&tmpTraxNom = CteTomRaz
			&tmpTraxCod = CteTomCod
			if CteTomCnpj.IsEmpty() or CteTomCnpj.IsNull()
				&CteTomCnpj = CteTomCpf
			 	validaCpfCnpj.Call(&CteTomCnpj, &Cnpjerro, 'S')
			Else
				&CteTomCnpj = CteTomCnpj
				validaCpfCnpj.Call(&CteTomCnpj, &Cnpjerro, 'S')
			Endif
		
			&CTeDtaEms = CteDtaEms
			&CteNum = CteNum
			&CteSer = CteSer 
			&CteEntSai = CteEntSai 
			&CteChv = CteChv 
			
			&tmpEmixNom.Link = ''
			&tmpDestxNom.Link = ''
			&tmpTraxNom.Link = ''
			
			//ORigem
			if &tmpEmixCod.IsEmpty()
				txtEmitente.Caption = "Origem da Prestação nao localizado!"
			Else
				&tmpEmixNom.LinkTarget = '_blank'
				&tmpEmixNom.Link = verCliente.Link('DashBoard', EmpCod, &tmpEmixCod)
				txtEmitente.Caption = ""
			EndIF
		
			//Destino
			if &tmpDestxCod.IsEmpty()
				txtDestinatario.Caption = "Destinatario nao localizado!"
			Else
				&tmpDestxNom.LinkTarget = '_blank'
				&tmpDestxNom.Link = verCliente.Link('DashBoard', EmpCod, &tmpDestxCod)
				txtDestinatario.Caption = ""
			EndIF
		
			//Transporte
			if &tmpTraxCod.IsEmpty()
				txtTransportadora.Caption = "Transportador nao localizado!"
			Else
				&tmpTraxNom.LinkTarget = '_blank'
				&tmpTraxNom.Link = verCliente.Link('DashBoard', EmpCod, &tmpTraxCod)
				txtTransportadora.Caption = ""
			EndIF
			
			VerificaNotaJahLancadaCTe.Call(EmpCod, FilCod, Nota_ProPriaTerceira.TERCEIROS, CteTomCod, CteNum, CteSer, CteModCod, 0, &JaLancadoCteCod )
			if &JaLancadoCteCod  > 0
				txtNota.Caption = 'CTe Já Lançado! SISTEMA IRÁ ATUALIZAR A NOTA DE TRANSPORTE JÁ LANÇADA!'
			Else
				txtNota.Caption = ''
			Endif
		
			Exit
		when None
			wpImportarCTe.Link('Envolvidos', 'SelecioneXML', true, &SessionGuid)
		EndFor
	
	EndIf

EndSub

