      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&AuxEmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&AcePesCod = &Context.PesCod
	&PedDtaEmb = serverdate()
	
	If &ParmPedCod > 0
		&PedCod = &ParmPedCod
		&FilCod = &ParmPedFilCod
		
		do  'Pedido'
	Else
		If not &ParmNfeCod.IsEmpty()
			For Each Order EmpCod, FilCod, NfeCod
				Where EmpCod = &EmpCod
				Where FilCod = &ParmFilCod
				Where NfeCod = &ParmNfeCod
				&NfeNum = NfeNum
				&PedCliCod = NfeCliCod
				&PedTraSaiCod = NfeTraCod
				Exit
			EndFor
		EndiF	
	EndiF
	
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod,&Context.EmpCod, &PadObs, &PadDtaMod)
	
	If not &PadObs.IsEmpty()
		&ModeloEtiqueta = trim(Substr(&PadObs,1,3))
		&AuxPedEspVol = Substr(&PadObs, 4,20)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PedTraRedRaz.TooltipText = "Transportadora Impressa na NFE."
	&PedTraSaiRaz.TooltipText = "Transportadora que Retirou a mercadoria da Empresa."
	&PedCod.TooltipText = "Informe o Pedido para Emissão de Etiquetas de Volumes. Deixe 0 para emissão de Etiquetas SEM pedido."

	Do 'AttributesSecurityCode'
	&FinPedQtdVol.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaConfiguracoesPastas.Call(&EmpCod, &Context.FilCod, &sdtConfiguracoesPasta)

	&FilCod.SetFocus()

EndEvent

Event 'Dosdd'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpLocalizaNotaPedido.PopUp(&EmpCod, &Pedcod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&ModeloEtiqueta = 'B')
		&ImprimirEmitente.Visible = False
		ImprimirEmitente_Cell.Class = !'Invisible'
	Else
		&ImprimirEmitente.Visible = True
		ImprimirEmitente_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&PedCod <> 0)
		&NfeNum.Visible = False
		NfeNum_Cell.Class = !'Invisible'
	Else
		&NfeNum.Visible = True
		NfeNum_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&PedCod <> 0)
		&PedDtaEmb.Visible = False
		PedDtaEmb_Cell.Class = !'Invisible'
		TextBlockPedDtaEmb_Cell.Class = !'Invisible'
	Else
		&PedDtaEmb.Visible = True
		PedDtaEmb_Cell.Class = !'MergeDataCell'
		TextBlockPedDtaEmb_Cell.Class = !'col-sm-3 MergeLabelCell'
	EndIf
	If Not (&PedCod <> 0)
		&PedPesTot.Visible = False
		PedPesTot_Cell.Class = !'Invisible'
	Else
		&PedPesTot.Visible = True
		PedPesTot_Cell.Class = !'DataContentCell'
	EndIf
	If Not (&PedCod <> 0)
		&PedEspVol.Visible = False
		PedEspVol_Cell.Class = !'Invisible'
	Else
		&PedEspVol.Visible = True
		PedEspVol_Cell.Class = !'DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &ModeloEtiqueta.Click

	do 'AttributesSecurityCode'

EndEvent

Event &ModeloEtiqueta.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event &PedCod.IsValid

	do 'Pedido'

EndEvent

Event Enter

	do 'FinVolume'
	
	&PadObs = PadL(&ModeloEtiqueta,3, ' ')
	&PadObs += PadR(trim(&PedEspVol),20, '')
	PadraoUsuario.Call( 'G', &Pgmname, &Context.PesCod, &Context.EmpCod,&PadObs, &PadDtaMod)
	
	If &PedCod <> 0
		GravaDataEtiquetado.Call( &EmpCod, &FilCod, &PedCod, &PedQtdVol, &PedPesTot, &PedDtaEmb, &PedEspVol, &PedTraSaiCod,&PedTraRedCod, &Context.PesCod, &Context.UserName)
	EndIF

	&Random = (Random() * 10000000)
	&ArquivoFisico  = &sdtConfiguracoesPasta.PastaDiretorioTempFis + 'EtiqVol' + trim(str(&PedCod)) + trim(str(&Context.PesCod)) + trim(str(&Random)) + '.pdf'
	&File.source = &ArquivoFisico
	If &File.Exists()
		&File.Delete()
	EndIF
		
	Do Case
		
		Case &FinPedQtdVol < &IniPedQtdVol
			msg('Sequência Final do Volume não pode ser menor que a Inicial!')
		Case &IsExitePedido = false and &PedCod.IsEmpty()
			msg('Pedido não Localizado!')
			
		Case &ModeloEtiqueta = 'N' //SOMENTE GRAVAR NO PEDIDO
			msg('Informações de Saída, gravados com sucesso!')
			
		Case &ModeloEtiqueta in ('A', 'B', 'G', 'H','I') //Impressao para Volume MODELO 1 e MODELO 2
			
			RCOOpenWindow1.LinkOpen = RELJAS047.Link(&EmpCod, &FilCod, &PedCod, &Controle, &NfeNum, &IniPedQtdVol, &FinPedQtdVol, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico, &ImprimirEmitente)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &ModeloEtiqueta in ('C', 'D') //Impressao para Volume MODELO 3 e MODELO 4
			RCOOpenWindow1.LinkOpen = RELJAS060.Link(&EmpCod, &FilCod, &PedCod, &Controle, &NfeNum, &IniPedQtdVol, &FinPedQtdVol, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &ModeloEtiqueta = 'E' //Impressao para Volume MODELO 5			
			RCOOpenWindow1.LinkOpen = RELJAS095.Link(&EmpCod, &FilCod, &PedCod, &Controle, &NfeNum, &IniPedQtdVol, &FinPedQtdVol, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		
		Case &ModeloEtiqueta = 'F' //MODELO INDAGRIL
			RCOOpenWindow1.LinkOpen = RELJAS047_003.Link(&EmpCod, &FilCod, &PedCod, &NfeNum, &IniPedQtdVol, &FinPedQtdVol, &PedCliCod, &PedTraSaiCod,&PedTraRedCod,&ArquivoFisico, &ImprimirEmitente)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent

Event &PedQtdVol.IsValid

	do 'FinVolume'

EndEvent

Event &IniPedQtdVol.IsValid

	do 'FinVolume'

EndEvent

Event &PedCliCod.IsValid

	do 'Cliente'

EndEvent

Event &PedTraSaiCod.IsValid

	&PesCod = &PedTraSaiCod
	do 'Transportadora'
	&PedTraSaiRaz = &PesRaz

EndEvent

Event &PedTraRedCod.IsValid

	&PesCod = &PedTraRedCod
	do 'Transportadora'
	&PedTraredRaz = &PesRaz

EndEvent

Sub 'Pedido'

	Do 'AttributesSecurityCode'
	&NfeNum.SetEmpty()
	
	If &PedCod <> 0
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			RetornaNotaAutorizadaPedido.Call(EmpCod, FilCod, PedCod, &NfeNum)
			&IsExitePedido = true
			&PedCliCod = PedCliCod
			&PedCliRaz = PedCliRaz
			&PedTraRedCod = PedTraRedCod
			&PedTraRedRaz = PedTraRedRaz
			&PedTraSaiCod = PedTraSaiCod
			&PedTraSaiRaz = PedTraSaiRaz
			
			&PedEspVol = PedEspVol
			&PedQtdVol = PedQtdVol
			
			if not PedDtaEmb.IsEmpty() and not PedDtaEmb.IsNull()
				&PedDtaEmb = PedDtaEmb
			EndIF
			
			&PedPesTot = PedPesTot
			
			Exit
		When none
			&IsExitePedido = false
			&PedCliCod = 0
			&PedCliRaz = ''
			&PedTraRedCod = 0
			&PedTraRedRaz = ''
			&PedEspVol = ''
			&PedQtdVol = 0
			msg('Pedido não Localizado!')
		EndFor
	Else
		&IsExitePedido = False
	EndIF
	
	If &IniPedQtdVol.IsEmpty()
		&IniPedQtdVol = 1
	EndIF
	
	if &PedEspVol.IsEmpty()
		if &AuxPedEspVol.IsEmpty()	
			&PedEspVol = 'CAIXAS'
		Else
			&PedEspVol = &AuxPedEspVol
		EndIF
	EndIF

EndSub

Sub 'FinVolume'

	&FinPedQtdVol = &IniPedQtdVol + &PedQtdVol -1
	TextFinQtd.Caption = ' à ' + trim(str(&FinPedQtdVol))

EndSub

Sub 'Cliente'

	&PedCliRaz = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		&PedCliRaz = PesRaz
		Exit
	When none
		&PedCliRaz = 'CLIENTE NÃO LOCALIZADO'
		msg(&PedCliRaz)
	EndFor

EndSub

Sub 'Transportadora'

	&PesRaz = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesRaz = PesRaz
		Exit
	When none
		&PesRaz = 'TRANSPORTADORA NÃO LOCALIZADA'
		msg(&PesRaz)
	EndFor

EndSub

