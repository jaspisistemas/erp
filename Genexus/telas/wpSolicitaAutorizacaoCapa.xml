      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	&AuxPedCliCod = &PedCliCod
	do 'loadAutorizacao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbAviso.Width = 300
	&PedLibSts.Visible = False
	&PedLibSolDta.Visible = False
	&EmpCod.Visible = False
	&PedLibSolFun.Visible = False
	&PedLibItm.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSolicitarRemoto'

	Do Case
		Case (&SolicitarQtd = true and &PedLibSolPedQtd <= 0)
			msg('Selecionado autorização para Quantidade e não informado a Quantidade Requisitada!')
		Case (&SolicitarValor = 'V' and &PedLibSolPedVlr <= 0) 
			msg('Selecionado autorização para Valor e não informado o Valor Requisitado!')
		Case (&SolicitarValor = 'D' and &PedLibSolPedDesc <= 0) 
			msg('Selecionado autorização para Desconto e não informado o Desconto Requisitado!')
		Case &SolicitarValor <> 'S' or &SolicitarQtd = true		
			
			if &SolicitarValor <> 'D'
				&PedLibSolPedDesc = 0
			EndiF
			if &SolicitarValor <> 'V'
				&PedLibSolPedVlr = 0
			EndIF
			if &SolicitarQtd = false
				&PedLibSolPedQtd = 0
			EndIF
			
			SolicitarAutorizacao.Call('ADD', &EmpCod, &FilCod, &PedCod, &PedLibCliCod, &PedLibItm, &PedLibProCod, &PedLibProGraCod, TipoLiberacao.LiberacaoProduto, &PedSolLibObs, &PedLibSolPedQtd, &PedLibSolPedVlr,&PedLibSolPedDesc, &Context.PesCod)
			Return
		Otherwise
			msg('Nenhuma Forma de Requisição foi selecionada!')
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoReavaliacao'

	Do Case
		Case (&SolicitarQtd = true and &PedLibSolPedQtd <= 0)
			msg('Selecionado autorização para Quantidade e não informado a Quantidade Requisitada!')
		Case (&SolicitarValor = 'V' and &PedLibSolPedVlr <= 0) 
			msg('Selecionado autorização para Valor e não informado o Valor Requisitado!')
		Case (&SolicitarValor = 'D' and &PedLibSolPedDesc <= 0) 
			msg('Selecionado autorização para Desconto e não informado o Desconto Requisitado!')
		Case &SolicitarValor <> 'S' or &SolicitarQtd = true		
			
			if &SolicitarValor <> 'D'
				&PedLibSolPedDesc = 0
			EndiF
			if &SolicitarValor <> 'V'
				&PedLibSolPedVlr = 0
			EndIF
			if &SolicitarQtd = false
				&PedLibSolPedQtd = 0
			EndIF
			
			SolicitarAutorizacao.Call('REA', &EmpCod, &FilCod, &PedCod, &PedLibCliCod, &PedLibItm, &PedLibProCod, &PedLibProGraCod, TipoLiberacao.LiberacaoProduto, &PedSolLibObs, &PedLibSolPedQtd, &PedLibSolPedVlr,&PedLibSolPedDesc, &Context.PesCod)
			Return
		Otherwise
			msg('Nenhuma Forma de Requisição foi selecionada!')
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'loadAutorizacao'

	btnReavaliacao.Visible = 0
	For Each ORder EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&TabCod = TabCod
		&TabPrmCod = TabPrmCod
		&TabColCod = TabColCod
				
		if &PedCliCod.IsEmpty()
			&AuxPedCliCod = PedCliCod
			
		EndIF
		&PedCliRaz = PedCliRaz
		
		For Each Order EmpCod, FilCod, PedCod, PedLibTip
			Where PedLibTip = TipoLiberacao.LiberacaoProduto
			Where PedLibCliCod = &AuxPedCliCod
			Where PedLibProCod = &ProCod
			Where PedLibProGraCod = &ProGraCod
			
			&PedLibCliCod	= PedLibCliCod
			&PedLibItm	= PedLibItm
			&PedSolLibObs	= PedLibObs
			&PedLibAutObs = PedLibAutObs
			&PedLibProCod	= PedLibProCod
			&PedLibProGraCod	= PedLibProGraCod
			&PedLibSolDta	= PedLibSolDta
			&PedLibSolFun	= PedLibSolFun
			&PedLibSts	= PedLibSts
				
			btnReavaliacao.Visible = 1
			btnSolicitarRemoto.Visible = 0
			If PedLibSts = StatusLiberacao.Autorizado and PedLIbRea = 0
				&AvisoSolicitacao = 'SOLICITAÇÃO APROVADA'
				IconAmarelo.FromImage(iconVerde)
			Else
				Do CAse
					Case PedLibSts = StatusLiberacao.NaoAutorizado and PedLIbRea = 0
						IconAmarelo.FromImage(Iconvermelho)
						&AvisoSolicitacao = 'SOLICITAÇÃO REPROVADA'
					Case PedLIbRea = 1
						IconAmarelo.FromImage(iconAzul)
						&AvisoSolicitacao = 'EM REAVALIAÇÃO'
					Otherwise
						btnSolicitarRemoto.Visible = 1
						btnReavaliacao.Visible = 0
						IconAmarelo.FromImage(IconAmarelo)
						&AvisoSolicitacao = 'SOLICITAÇÃO PENDENTE'
				EndCAse
			EndiF
		
		
			&PedLibAutDta		=PedLibAutDta
			&PedLibAutFun		=PedLibAutFun
			&PedLibAutPedDesc	=PedLibAutPedDesc
			&PedLibAutPedQtd	= PedLibAutPedQtd
			&PedLibAutPedVlr	= PedLibAutPedVlr
			
			&PedLibSolPedQtd = PedLibSolPedQtd
			&PedLibSolPedVlr = PedLIbSolPedVlr
			&PedLibSolPedDesc = PedLibSolPedDesc
			
			if &PedLibSolPedQtd > 0
				&SolicitarQtd = true
			EndIF
		
			Do Case
				Case &PedLibSolPedVlr > 0
					&SolicitarValor = 'V'
				CAse &PedLibSolPedDesc > 0
					&SolicitarValor = 'D'
				Otherwise
					&SolicitarValor = 'S'
			EndCase
		
			Exit
		When none
			IconAmarelo.FromImage(IconAmarelo)
			&AvisoSolicitacao = 'SOLICITAÇÃO PENDENTE'
						
			&PedLibSolPedQtd = &PedQtd
			&PedLibSolPedVlr = &PedVlrUnt
			&PedLibSolPedDesc = &DescontoPercentual
			&PedLibCliCod	= &AuxPedCliCod
			&PedLibItm	= 0
			&PedLibAutObs	= ''
			&PedLibProCod	= &ProCod
			&PedLibProGraCod	= &ProGraCod
			&PedLibSolDta	= ServerNow()
			&PedLibSolFun	= &Context.PesCod
			&PedLibSts	= StatusLiberacao.Aguardando
		EndFor
		Exit
	EndFor

EndSub


]]></Source>
