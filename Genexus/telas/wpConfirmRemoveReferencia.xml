      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &DelPesRefCod = 0
		&sdtAnexos.FromJson(&JsonSdt)
	Else
		&sdtAnexosItem = new()
		&sdtAnexosItem.AnxCod = &DelPesRefCod
		&sdtAnexos.Add(&sdtAnexosItem)
	Endif

	loadwwpContext.Call(&WwpContext)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 450
	TableMain.Height = 150

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	retornaAutorizacao.Call('WPREFERENCIASCOMERCIAIS', Status_SimNao.Nao, 3, &AutNiv)
	
	If &AutNiv < 3
		msg('Não Autorizado ao Nível de Eliminar Referência Comercial. [WPREFERENCIASCOMERCIAIS]')
	Else
		if &DelPesRefCod = 0
			for &sdtAnexosItem in &sdtAnexos
				EliminaReferenciaComercial.Call(&DelEmpCod, &DelPesCod, &sdtAnexosItem.AnxCod, &WwpContext.UserName)
			EndFor
		Endif
	
		Return
	EndiF

EndEvent


]]></Source>
