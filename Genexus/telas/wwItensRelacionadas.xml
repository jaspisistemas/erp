      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&LogErpEmpCod = &parmLogErpEmpCod
	&LogErpTabCod = &parmLogErpTabCod
	&LogErpRegCod1 = &parmLogErpRegKey

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid_DWC.Class = !'Invisible WCD_' + upper(Grid.InternalName)
	
	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	//COMO ESTA INICIANDO NO START DO wcDetalhamentoLog, ai nao precisa do Refresh senao da erro de tabela Empresa.
//	prcGetDadosBanco.Call(&EmpBDerp, &EmpBDAudit)
//	if not &EmpBDAudit.IsEmpty()
//		&SQLSentence = 'USE ' + trim(&EmpBDAudit)
//		SQL [!&SqlSentence!]
//	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	&DetailWebComponent.ColumnHeaderClass = !'WWIconActionColumn WCD_ActionColumn'
	LogErpDtaHorMod.ColumnHeaderClass = !'WWColumn'
	LogErpRegTip.ColumnHeaderClass = !'WWColumn'
	LogErpTabCod.ColumnHeaderClass = !'WWColumn'
	LogErpRegKey.ColumnHeaderClass = !'WWColumn'
	LogErpUsuGuid.ColumnHeaderClass = !'WWColumn'
	LogTrnCod.ColumnHeaderClass = !'WWColumn'
	LogErpExt.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'
	
	If LogErpRegGUID = &LogErpRegGUID
		&DetailWebComponent.ColumnClass = !'WWIconActionColumn WCD_ActionColumn WWColumnSuccess WWColumnSuccessFirstColumn'
		LogErpDtaHorMod.ColumnClass = !'WWColumn WWColumnSuccess'
		LogErpRegTip.ColumnClass = !'WWColumn WWColumnSuccess'
		LogErpTabCod.ColumnClass = !'WWColumn WWColumnSuccess'
		LogErpRegKey.ColumnClass = !'WWColumn WWColumnSuccess'
		LogErpUsuGuid.ColumnClass = !'WWColumn WWColumnSuccess'
		LogTrnCod.ColumnClass = !'WWColumn WWColumnSuccess'
		LogErpExt.ColumnClass = !'WWColumn WWColumnSuccess'
	Else
		&DetailWebComponent.ColumnClass = 'WWIconActionColumn WCD_ActionColumn'
		LogErpDtaHorMod.ColumnClass = 'WWColumn'
		Do Case
			Case LogErpRegTip = TrnMode.Insert
				LogErpRegTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
			Case LogErpRegTip = TrnMode.Update
				LogErpRegTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
			Case LogErpRegTip = TrnMode.Delete
				LogErpRegTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
			Case LogErpRegTip = TrnMode.Display
				LogErpRegTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
			Otherwise
				LogErpRegTip.ColumnClass = 'WWColumn'
		EndCase
		LogErpTabCod.ColumnClass = 'WWColumn'
		LogErpRegKey.ColumnClass = 'WWColumn'
		LogErpUsuGuid.ColumnClass = 'WWColumn'
		LogTrnCod.ColumnClass = 'WWColumn'
		LogErpExt.ColumnClass = 'WWColumn'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DetailWebComponent.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_DWC.Object = wcDetalhamentoLog.Create(LogErpRegGUID)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"LOGERPEMPCOD"
				&LogErpEmpCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"LOGERPTABCOD"
				&LogErpTabCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"LOGERPREGCOD1"
				&LogErpRegCod1.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"LOGERPREGCOD2"
				&LogErpRegCod2.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndSub

Sub 'SaveGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"LOGERPEMPCOD", "", not &LogErpEmpCod.IsEmpty(), 0, &LogErpEmpCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"LOGERPTABCOD", "", not &LogErpTabCod.IsEmpty(), 0, &LogErpTabCod, '')
	WWP_GridStateAddFilterValue(&GridState, !"LOGERPREGCOD1", "", not &LogErpRegCod1.IsEmpty(), 0, &LogErpRegCod1, '')
	WWP_GridStateAddFilterValue(&GridState, !"LOGERPREGCOD2", "", not &LogErpRegCod2.IsEmpty(), 0, &LogErpRegCod2, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"LogErpRegistros"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


