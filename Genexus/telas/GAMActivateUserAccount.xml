        <Source><![CDATA[
Event Start

	&isOK = GAMRepository.ActivateUser(&ActivationKey, True, &Errors)
	If &isOK
		TBMsg.Caption = "WWP_GAM_UserAccountActivatedSuccessfully" + NewLine() + "WWP_GAM_YouMustGoLoginToEnterApplication"
	Else
		For &Error in &Errors
			TBMsg.Caption = &Error.Message.Trim()
			Exit
		EndFor
	Endif

