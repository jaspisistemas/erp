      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	
	&PlanCod.Clear()
	&SdtPlanoConta =  dpPlanoAnadeb_EmpCod.Udp(&Context.EmpCod)
	for &SdtPlanoContaItem in &SdtPlanoConta
		&PlanCod.AddItem(&SdtPlanoContaItem.PlanCod, &SdtPlanoContaItem.PlanCodNom)
	EndFor
	
	&CreRecPag = ReceberPagar.Pagar
	&CreFilPgt = &FilCod
	
	do 'loadEditarDuplicata'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CreRecPag.Visible = False
	&CreFilPgt.Visible = False
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &CreDupNro.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Número'), DVMessageType.error, &CreDupNro.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CreVlrDup.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','R$ Valor Duplicata'), DVMessageType.error, &CreVlrDup.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CreDtaVct.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Vencimento'), DVMessageType.error, &CreDtaVct.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CreCbrCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Local Cobr.'), DVMessageType.error, &CreCbrCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CreCliCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Fornecedor'), DVMessageType.error, &CreCliCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &CreDtaVct.ControlValueChanged

	&PedTmpPrz = 0
	IF (not &PedDtaFat.IsEmpty()) and (not &CreDtaVct.IsEmpty())
		&PedTmpPrz = (&CreDtaVct - &PedDtaFat) 
	EndIF
	&PedTmpSem = substr(cdow(&CreDtaVct), 1, 3)

EndEvent

Event Enter

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = true
		if &PedCod > 0
			AtualizaTemporariaDuplicata.Call(&EmpCod, &FilCod, &PedCod, &PedTmpDupCod, &CreDupNro, &CreDtaVct, &PedTmpFrpPgtoCod, &PedTmpSem,&PedTmpPrz, &CreVlrDup, &CreCbrCod, &PlanCod, &CrePagDta,0 ,0,'',0)
		Else
			GravaTmpBaixaDuplicata.Call(&EmpCod, &FilCod, &PedCod, &PedTmpDupCod, &PedTmpFrpPgtoCod, &CreVlrDup, 0, &MovDtaCon, &CreCbrCod, &PlanCod, 0, &CreDupNro, 0 ,0,&CreDtaVct, '', &CreDtaVct, '',&CreCliCod)	
		EndIf
	
		Return
	Endif

EndEvent

Event &CreCliCod.ControlValueChanged

	Do 'GetCliente'

EndEvent

Sub 'GetCliente'

	For each order EmpCod,PesCod
		where EmpCod = &EmpCod
		where PesCod = &CreCliCod
		&CreCliRaz = PesRaz
		exit
	when none
		&CreCliCod.SetEmpty()
		&CreCliRaz.SetEmpty()
		&CreCliCod.SetFocus()
		msg('Cliente não localizado!')
	EndFor

EndSub

Sub 'loadEditarDuplicata'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod		
		
		if PedTmpDupDtaFat.IsEmpty()
			&PedDtaFat = PedDtaFat
		Else
			&PedDtaFat = PedTmpDupDtaFat
		Endif
		
		Exit
	EndFor

	if &PedDtaFat.IsEmpty()
		&PedDtaFat = serverdate()
	Endif
	
	For Each Order EmpCod, FilCod, PedCod, PedTmpDupCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedTmpDupCod = &PedTmpDupCod
		
		&PedTmpFrpPgtoCod = PedTmpFrpPgtoCod
		
		&CreDupNro = PedTmpDupNro
		&CreVlrDup = PedTmpDupVlr
		&CreDtaVct = PedTmpDupVct
		&CreCod = PedTmpCreCod
		
		&PlanCod = PedTmpPlanCod
		&CreCliCod = PedTmpCreCliCod
		&CreCbrCod = PedTmpDupCbrCod
		&PedTmpSem = PedTmpSem
		&PedTmpPrz = PedTmpPrz
		
		if PedTmpSts = Status_SimNao.Sim
			Return
		EndIf

		exit
	EndFor
	
	if &CreCliCod.IsEmpty() 
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			&CreCliCod = PedCliCod
			Exit
		EndFor
	Endif

		
	Do 'GetCliente'

EndSub


]]></Source>
