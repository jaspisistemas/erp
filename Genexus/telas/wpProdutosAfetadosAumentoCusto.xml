      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadwwpContext.Call(&wwpContext)
	RetornaConfSistema.Call(&wwpContext.EmpCod, &wwpContext.FilCod, domConfSistema.TCon108_CasasDecimais, &TConVlr)
	&QtdCasasDecimais = iif(&TConVlr.IsEmpty(),2, val(&TConVlr))
	do 'GetFilial'
	do 'loadpedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PrecosProduto.Title = 'Add R$'
	&ProdutosAfetados.Title = 'Afetados'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

EndEvent

Event Grid.Load

	RetornaProdutosAfetadosCusto.call(EmpCod, ProCod, 1, &IsProdutosAfetados)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ProdutosAfetados = !'<i class="fas fa-cubes"></i>'
	
	&PrecosProduto = !'<i class="fa fa-plus"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ProdutosAfetados.Visible = &IsProdutosAfetados
	
	&ProVlrCus = ProVlrCus
	
	&AuxProVlrCus = &ProVlrCus+(&Diferenca*RecProQtd)
	&PedVlrCusNov = 0
	
	//ESTA DANDO ERRO UND MEDIDA< GENEXUS ESTA CONFUNDINDO COM RecProEmbUn -JDF
	RetornaProdutoEmbalagem.Call(EmpCod, ProCod, &ProEmbCod, &ProEmbNom, &ProEmbUnd, &ProEmbQtd)
	
	if &AuxProVlrCus > 0
		do case
			CAse &ProEmbQtd > 0 and &AuxProVlrCus > 0
				&PedVlrCusNov = round(&AuxProVlrCus / &ProEmbQtd, 5)
			CAse &ProEmbQtd < 0
				&PedVlrCusNov = &AuxProVlrCus * &ProEmbQtd
			Otherwise
				&PedVlrCusNov = &AuxProVlrCus
		EndCase
	EndIF
	
	IF &PedVlrCusNov > 0 and ProIMC <> 0 
		&ProNovPrc = round((&PedVlrCusNov * ( 1 + (ProIMC/100))), &QtdCasasDecimais)
	EndIF
	
	&TabPrc1 = RetornaValorTab.UDP(EmpCod, &FilTabCod, ProCod, 1)
	
	&TabPrc1.ForeColor = RGB(0,0,0)
	if &TabPrc1 < &ProNovPrc
		&TabPrc1.ForeColor = RGB(250,0,0)
	EndIF

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProdutosAfetados.Click

	wpProdutosAfetadosAumentoCusto.Popup(&EmpCod, &PedCod, &FilCod, &PedItmCod, ProCod, 1) //Grade 1 pois nao tem a grade na receita.

EndEvent

Event ProIMC.Click

	wpAlterarAcrescimo.Popup(EmpCod, ProCod, &PedVlrCusNov)
	Refresh keep

EndEvent

Event &PrecosProduto.Click

	wpProdutosPrecosNovo.Popup(&EmpCod, &FilCod, 0, 0, ProCod, &PedVlrCusNov)
	Refresh

EndEvent

Sub 'GetFilial'

	For Each order EmpCod, FilCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &wwpContext.FilCod
		
		&FilTabCod = FilTabCod
		&vFilTabCod = FilTabCod
		Exit
	EndFor
	
	//LOAD USADO EM VARIOS LUGARES.
	padraousuario.Call('L', '#TABELASSELECIONADAS#', 1, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	if not &PadObs.IsEmpty()
		&FilTabCod = trim(Substr(&PadObs, 1, 5))
		&vFilTabCod= &FilTabCod
	Endif

EndSub

Sub 'loadPedido'

	if &PedCod > 0
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedItmCod = &PedItmCod
			
			&ProCodNom = ProRefNom
			
			if PedVlrCus > 0
				do case 
					CAse PedProEmbQtd > 0 and PedVlrCus > 0
						&PedVlrUntComDsc = round(PedVlrCus / PedProEmbQtd, 5)
					CAse PedProEmbQtd < 0
						&PedVlrUntComDsc = PedVlrCus * PedProEmbQtd
					Otherwise
						&PedVlrUntComDsc = PedVlrCus
				EndCase
			Else
				do case 
					CAse PedProEmbQtd > 0 and PedVlrUntDsc > 0
						&PedVlrUntComDsc = round(PedVlrUntDsc / PedProEmbQtd, 5)
					CAse PedProEmbQtd < 0
						&PedVlrUntComDsc = PedVlrUntDsc * PedProEmbQtd
					Otherwise
						&PedVlrUntComDsc = PedVlrUntDsc
				EndCase
			EndIF
			
			&OldCusto = ProVlrCus		
			
			Exit
		EndFor
		
		If &OldCusto < &PedVlrUntComDsc
			&PedVlrUntComDsc.ForeColor = RGB(200,0,0)
		Else
			&PedVlrUntComDsc.ForeColor = RGB(0,60,200)
		Endif
		
		&Diferenca = &PedVlrUntComDsc - &OldCusto
	Else
		For Each Order EmpCod, ProCod, ProGraCod
			Where EmpCod = &EmpCod
			Where ProCod = &RecProCod
			Where ProGraCod = &RecProGraCod
			&ProCodNom = ProRefNom
			&OldCusto = ProVlrCus
			Exit
		EndFor
	
		tbped0.Visible = 0
		tbped1.Visible = 0
		tbped2.Visible = 0
	Endif

EndSub


]]></Source>
