      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbconte.Width = 1210
	tbAoa.Height = 250
	tabsdsd.Height = 50
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 10
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CtabanCodNom = trim(str(&Context.CtaBanCod)) + ' - ' + &Context.CtaBanNom
	
	btnRetornaPDV.SetFocus()

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)
	
	btnRetornaPDV.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	retornaAutorizacao.Call('VENDAREMOVEITEM', Status_SimNao.nao, 1, &VENDAREMOVEITEM)
	
	&GridCurrentPage = Grid.CurrentPage
	&GridPAgeCount = grid.PageCount
	&GridRecordCount = Grid.RecordCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EliminarItem.FromImage(ActionDelete)
	&EliminarItem.TooltipText = "Deletar Item"
	If (&VENDAREMOVEITEM > 0)
		&EliminarItem.Class = !'DeleteAttribute'
	Else
		&EliminarItem.Class = !'Invisible'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	ProNom.Link = VerProduto.Link('DashBoard', EmpCod, ProCod)
	ProNom.LinkTarget = '_blank'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRetornaPDV'

 2
	
	pdvm_venda.Link(&PedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBRINDES'

	iF &PedItmCod > 0
		WPBRIndeprodutopedido.Link(&EmpCod, &FiLCod, &PedCod,&PedItmCod)
	Else
		msg('Selecione o item clicando na grid.')	
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEliminarItem'

	&PedItmCod = PedItmCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_EliminarItem.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_EliminarItem.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_EliminarItem.Result = !'Yes'
		Do 'Do EliminarItem'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	btnRetornaPDV.SetFocus()

EndEvent

Sub 'Do EliminarItem'

	If &PedItmCod <> 0
	    DeletaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod)
		grid.Refresh()
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event grid.OnLineActivate

	&PedItmCod = PedItmCod
	btnRetornaPDV.SetFocus()

EndEvent


]]></Source>
