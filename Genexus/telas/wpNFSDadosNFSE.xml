Event 'DoTransmitir'

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult AND not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		
		prcGravaTotaisNFs.Call(&EmpCod, &NfsCod, &WizardData)
		prcNotaServicoTransmitida.Call(&EmpCod, &NfsCod)
		GravaSolicitacao.Call(&EmpCod, &NfsFilCod, &NfsCod, 0, TipoSolicitacao.Autorizar_NFSE, &WwpContext.PesCod, &SolCod)
		
		&WizardData.Totais.SolCod = &SolCod
		&WebSession.Set(&WebSessionKey, &WizardData.ToJson())
		wpNFS(!'Totais', !'Transmitir', false, &SessionGuid)

	EndIf

EndEvent

Event &NfsCNAE.IsValid

	if &NfsTipNF <> 'S'
		do 'loadCNAE'
	Endif

EndEvent

Event &NfsCnaeSer.IsValid

	if &NfsTipNF <> 'S'
		do 'loadCnaeServico'
	Endif

EndEvent

Event &NfsTribNac.ControlValueChanged

	do 'TipoServico'
	
	if not &TipSerNbsPad.IsEmpty()
		&NfsNbs = &TipSerNbsPad
		do 'Nbs'
	Endif

EndEvent

Event &NfsNbs.ControlValueChanged

	do 'Nbs'

EndEvent

Event &NfsItmValTot.ControlValueChanged

	do 'Totaliza'

EndEvent

Event &NfsTotDesc.ControlValueChanged

	do 'Totaliza'

EndEvent

Event &NfsItmProRef.IsValid

	if &NfsItmProRef <> &OldNfsItmProRef
		&OldNfsItmProRef = &NfsItmProRef
		Do 'GetProduto'
	Endif

EndEvent

Sub 'loadCnaeServico'

	&IsErroCnaeServico = false
	&CnaeItmDesc = ''
	tbRTB.Visible = 0
	
	For Each ORder EmpCod, CnaeCod, CnaeItmCod
		Where EmpCod = &EmpCod
		Where CnaeCod = &NfsCNAE
		Where CnaeFilCod = &NfsFilCod
		Where CnaeItmCod = &NfsCnaeSer
		
		If CnaeSts <> status_AtivoInativo.ATIVO
			&CnaeItmDesc =  'INATIVO '
			&IsErroCnaeServico = true
		EndIf
		&CnaeItmDesc +=  CnaeItmDesc
		&CnaeItmTax = CnaeItmTax
		
		tbRTB.Visible = CnaeDtaHorUltMod < &CnaedtaHorUltMod or CnaeDtaHorUltMod.IsEmpty() or CnaeDtaHorUltMod.IsNull()
		
		Exit
	When none
		&CnaeItmDesc = 'SERVICO NAO LOCALIZADO'
		&IsErroCnaeServico = true
	EndFor

EndSub

Sub 'loadCNAE'

	&IsErroCnae = false
	&CnaeDesc = ''
	
	For Each ORder EmpCod, CnaeCod
		Where EmpCod = &EmpCod
		Where CnaeCod = &NfsCNAE
		
		If CnaeSts <> status_AtivoInativo.ATIVO
			&CnaeDesc =  'INATIVO '
			&IsErroCnae = true
		EndIf
		&CnaeDesc +=  CnaeDesc
		
		Exit
	When none
		&CnaeDesc = 'CNAE NAO LOCALIZADO'
		&IsErroCnae = true
	EndFor

EndSub

Sub 'Nbs'

	&IsErroNBS = false
	
	For Each ORder NcmCod
		Where NcmCod = &NfsNbs
		Where NCMTip = '1' 
		&NcmObs = NcmDes
		Exit
	when none
		&IsErroNBS = true
		&NcmObs = 'CÓDIGO NBS NÃO CADASTRADO/INVÁLIDO!'
	EndFor

EndSub

Sub 'TipoServico'

	&TipSerNbsPad = 0
	&IsErroTipoServico = false
	For Each Order TipSerCod
		Where TipSerCod = &NfsTribNac
		
		&TipSerNom = TipSerNom
		
		For Each ORder TipSerCod, TipSerItmCod
			Where TipSerEmpCod = &EmpCod
			&TipSerNbsPad = TipSerNbsPad
			Exit
		EndFor
		Exit
	When none
		&IsErroTipoServico = true
		&TipSerNom = 'TIPO SERVIÇO NÃO INFORMADO/INVÁLIDO'
	EndFor

EndSub

Sub 'Totaliza'

	&NfsTotSer = &NfsItmValTot-&NfsTotDesc

EndSub

Sub 'loadNFSe'

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&EmpCod = &WizardData.Capa.EmpCod
	&NfsCod = &WizardData.Capa.NfsCod
	
	if &NfsCod = 0
		wwNotasServico.Link()
	Else
		For Each Order EmpCod, NfsCod
			Where EmpCod = &EmpCod
			Where NfsCod = &NfsCod
			
			&NfsTipNF = NfsTipNF
			BtnItens.Visible = (NfsTipNF <> 'S')
			
			&NfsFilCod = NfsFilCod
			&NfsCNAE = NfsCNAE
			&NfsCnaeSer = NfsCnaeSer
			&NfsDisSer = NfsDisSer
			&NfsInfComp = NfsInfComp
			
			&CnaeItmTax = NfsPerISS
			
			&NfsSts = NfsSts
			
			&NfsItmValTot = NfsTotSer
			&NfsTotDesc = NfsTotDesc
			&NfsTotSer = NfsVlrTot 
			
			&NfsNbs = NfsNbs
			&NfsTribNac = NfsTribNac
			
			if &NfsSts = Status_nFe.Autorizada or &NfsSts = Status_Nfe.Cancelada 
				btnCopiarUltima.Visible = 0
			Else
				RetornaUltimaNFSe.call(EmpCod, NfsCod, NfsCliCod, &OrigemNfsCod)
				if &OrigemNfsCod.IsEmpty()
					btnCopiarUltima.Visible = 0
				Endif
			Endif
						
			For Each Order EmpCod, NfsCod, NfsItmCod
				&ProCod = NfsItmProCod
				&ProGraCod = NfsItmProGraCod
				do 'GetReferencia'
				Exit
			EndFor
			
			Exit
		EndFor
	EndIf
	
	if &NfsTipNF <> 'S'
		do 'loadCNAE'
		do 'loadCnaeServico'
	Else
		do 'TipoServico'
		do 'Nbs'
	Endif

EndSub

Sub 'GetReferencia'

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&NfsItmProRef = ProGraRef
		&OldNfsItmProRef = &NfsItmProRef
		
		&ProNom = ProNom
		Exit
	When none
		&ProNom = 'Serviço não Selecionado'
	EndFor

EndSub

Sub 'GetProduto'

	&NfsItmProCod.SetEmpty()
	RetornaProdutoReferencia.Call(&EmpCod, &NfsItmProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		WHere ProGraCod = &ProGraCod
		
		&varchar = trim(str(NcmCod))
		if &Varchar.Length() = 9
			&NfsNbs = NcmCod
		Endif
	
		if not ProTribNac.IsEmpty() and not ProTribNac.IsNull()
			&NfsTribNac = ProTribNac
		Endif
	
		Exit
	EndFor

	do 'TipoServico'
	do 'Nbs'

EndSub


