Sub 'CheckRequiredFields'

	if &NfsTipNF <> 'S'
		do 'loadCNAE'
		do 'loadCnaeServico'
	Endif

	&NfsDisSer = upper(&NfsDisSer)
	
	&NfsInfComp = upper(&NfsInfComp)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If (&WizardData.Capa.NfsTipNF = 'S') AND &NfsTribNac.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Serviço'), DVMessageType.error, &NfsTribNac.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&WizardData.Capa.NfsTipNF = 'S') AND &NfsNbs.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Codigo NBS'), DVMessageType.error, &NfsNbs.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&WizardData.Capa.NfsTipNF <> 'S') AND &NfsCNAE.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','CNAE '), DVMessageType.error, &NfsCNAE.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&WizardData.Capa.NfsTipNF <> 'S') AND &NfsCnaeSer.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Serviço'), DVMessageType.error, &NfsCnaeSer.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &NfsDisSer.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Discriminação do Serviço'), DVMessageType.error, &NfsDisSer.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &NfsItmValTot.IsEmpty()
