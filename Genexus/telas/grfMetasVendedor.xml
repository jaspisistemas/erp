      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Retornaautorizacao.Call('GRFMETASVENDEDOR', Status_SimNao.Sim, 1, &AutNiv)
	loadWWPContext.Call(&Context)
	
	padraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	if &PadObs.IsEmpty()
		&PesMetAno = Year(serverdate())
		&PesMetMes = month(serverDate())
		do 'gravaPadrao'
		if 1=2
			abreGrfMetasVendedor.Link()
		EndIf	
	Else
		&Hora = val(substr(&PadObs, 1, 4))
		&PesMetAno = val(Substr(&PadObs, 5, 4))
		&PesMetMes = val(Substr(&PadObs, 9, 2))
		
	EndiF
	
	&BaseData = YMDtoD(&PesMetAno,&PesMetMes, 1)
	
	TableAttributes.Visible = 0
	&MostrarFiltros = 'N'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order ProgressId
		Where ProgressId = &ParmProgressId
		UltimaAtualizacao.Caption = 'Ult.Atualização: '+ trim(ToFormattedString(ProgressFin)) + ' | ' + CMonth(&BaseData, 'por') + '/' + trim(str(&PesMetAno))
		&ProgressFin = ProgressFin
		Exit
	EndFor

	wcgraf.Object = wcGrafMetas.Create(&ParmProgressId, Status_Pedido.FECHADO, true)
	wcgrafdois.Object = wcGrafMetas.Create(&ParmProgressId, Status_Pedido.AbERTO, false)
	
	tbIndicador.Visible = 0
	Atu.Visible = 1
	if &ParmProgressId.IsEmpty() or &ProgressFin.IsEmpty()
		do 'StartExecutionProgress'
	Else
		If &Hora > 0
			do 'Aguardando'
		EndIf
	EndiF

EndEvent

Event 'DocONF'

	if &MostrarFiltros = 'S'
		&MostrarFiltros = 'N'
	Else
		&MostrarFiltros = 'S'
	EndIF

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAtu'

	do 'StartExecutionProgress'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&MostrarFiltros = 'N'
	Do 'AttributesSecurityCode'
	do 'gravaPadrao'
	do 'StartExecutionProgress'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&MostrarFiltros = 'S')
		DVPanel_tbFiltros_Cell.Class = !'Invisible'
	Else
		DVPanel_tbFiltros_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	tbIndicador.Visible = 0
	Atu.Visible = 1
	grfMetasVendedor.Link(&ProgressId)

EndEvent

Event scaProgressBarAguardar.OnComplete

	if &MostrarFiltros <> 'S'
		&PesMetAno = Year(serverdate())
		&PesMetMes = month(serverDate())
		do 'gravaPadrao'
		
		do 'StartExecutionProgress'
	Else
		 do 'Aguardando'
	EndiF

EndEvent

Sub 'gravaPadrao'

	&PadObs = padL(str(&Hora), 4, '0')

	if &PesMetAno > 2000
		&PadObs += trim(str(&PesMetAno))
	Else
		&PadObs += trim(str(Year(serverDate())))
	EndiF
	&PadObs += PadL(str(&PesMetMes),2, '0' )
	padraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

EndSub

Sub 'StartExecutionProgress'

	tbIndicador.Visible = 1
	Atu.Visible = 0
	&Random =Random() * 100000000
	&ProgressId = 'grfMetasVendedor' + trim(str(&Context.EmpCod)) + trim(str(&Random))
	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	prcGraficoMetasVendedor.Submit('', &ProgressId, &Context.EmpCod, &Context.FilCod, &PesMetAno, &PesMetMes)
	ApagaProgressDia.Submit('', 'grfMetasVendedor')

EndSub

Sub 'Aguardando'

	&Random =Random() * 100000000
	&ProgressId = 'esperaSegundosEstipulados' + trim(str(&Context.EmpCod)) + trim(str(&Random))
	
	scaProgressBarAguardar.ProcessId = &ProgressId
	scaProgressBarAguardar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBarAguardar.Start()
	
	
	esperaSegundosEstipulados.Submit('', &ProgressId, &Hora)
	ApagaProgressDia.Submit('', 'esperaSegundosEstipulados')

EndSub


]]></Source>
