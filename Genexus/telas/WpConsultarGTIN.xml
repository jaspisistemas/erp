      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&ProBar.Enabled = 1			//## Habilita para editar o GTIN ##\\
	
	PnDadosProduto.Visible = 0	//## Painel de dados do Produto invisivel ##\\
	
	btnEnter.Visible = 0		//## Botão de Enter invisivel ##\\
	TbScaProgress.Visible = 0	//## Barra de progresso inivisivel ##\\

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConsGTIN'

	TbScaProgress.Visible = 1															//## Barra de progresso visivel ##\\
	
	prcGeraXmlCodigoGTIN.Call(&EmpCod, &FilCod, &ProBar, &SdtConfiguracoesPasta)		//## Gera o XML para o envio ao SEFAZ ##\\

	&Random = Random() * 10000000000													//## Gera um número aleatório para o ID do Progresso ##\\
	&ProgressId = 'ConsultaGTIN' + trim(Str(&Random))									//## Define o ID progresso como 'ConsultaGTIN' + str(Número aleatório)
	
	scaProgressBar1.ProcessId = &ProgressId												//## Define o ID da barra de Progresso ##\\
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)				//## Cria o Progresso na tabela ##\\
	scaProgressBar1.Start()																//## Inicia a barra de progresso ##\\
	
	prcProgressoConsultaGTIN.Submit('', &ProgressId, &SdtConfiguracoesPasta, &ProBar)	//## Executa o progresso ##\\
	
	btnConsGTIN.Visible = 0																//# Botão para a consulta invisivel ##\\
		
	&AuxMensagem.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	//## Quando a barra de progresso for concluida ##\\
	PnDadosProduto.Visible = 1																//## Painel de dados do Produto visivel ##\\
	btnEnter.Visible = 1																	//## Botão de Enter Visivel ##\\
	TbScaProgress.Visible = 0																//## Barra de Progresso invisivel ##\\
	
	prcLerXMLGTIN.Call( &SDtConfiguracoesPasta, &ProBar, &AuxProNom, &AuxNcmCod, &Mensagem, &statusConsulta, &IsAchou)	//## Lê o XML de retorno ##\\
	
	If &IsAchou = True //## Se achou o GTIN ##\\
		
		Do Case //## Verifica o Status ##\\
			Case &statusConsulta = '9490' //## Caso o Status for de 'Sucessso', carrega as informações na Tela ##\\
				&NcmCod = &AuxNcmCod
				&ProNom = &AuxProNom
				&AuxMensagem = &Mensagem
				
				TbMensagem.Visible = 1
				
				&AuxProNom.Enabled = 1
				
			Otherwise //## Caso houver um status de Rejeição, não carrega nada e emite a msg ##\\
				&AuxMensagem = 'Não foi possível realizar a consulta pela '+trim(&Mensagem)+ ' Tente atráves de um outro Código GTIN.'
				btnConsGTIN.Visible = 1
				&AuxProNom.Enabled = 0
		EndCase
	
	Else //## Se não achou ##\\
		
		&AuxMensagem = 'Produto não encontrado. Verifique se o app UNInfe está ativo e faça a busca novamente!'
		btnConsGTIN.Visible = 1
		&AuxProNom.Enabled = 0
		
	EndIf

	Refresh

EndEvent

Event Enter

	Return

EndEvent


]]></Source>
