      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SdtBiometria.FromXml(&WebSession.Get('BIOMETRIAREPLICAR'))
	&SdtAlojamentoWeb.FromXml(&WebSession.Get('ALOJAMENTOREPLICAR'))
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtAlojamentoWebs.Rows = Page.Rows
	GridSdtAlojamentoWebsPaginationBar.RowsPerPageSelectedValue = GridSdtAlojamentoWebs.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod
	&BioQtdAmo = 0
	&BioPesTot = 0
	For &SdtBiometriaItem in &SdtBiometria
		&BioAloLotCod = &SdtBiometriaItem.BioAloLotCod
		&BioDta = &SdtBiometriaItem.BioDta
		&BioFilCod = &SdtBiometriaItem.BioFilCod
		&BioQtdAmo += &SdtBiometriaItem.BioQtdAmo
		&BioPesTot += &SdtBiometriaItem.BioPesTot
	Endfor
	iF &SdtAlojamentoWeb.Count <= 0 
		Do 'CarregaAlojamentos'
	EndIf

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridSdtAlojamentoWebsCurrentPage = GridSdtAlojamentoWebs.CurrentPage
	&GridSdtAlojamentoWebsPageCount = GridSdtAlojamentoWebs.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtAlojamentoWebs.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtAlojamentoWebsPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSdtAlojamentoWebsPaginationBar.SelectedPage = !'Previous'
			GridSdtAlojamentoWebs.PreviousPage()
		Case GridSdtAlojamentoWebsPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridSdtAlojamentoWebs.CurrentPage
			&PageToGo += 1
			GridSdtAlojamentoWebs.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridSdtAlojamentoWebsPaginationBar.SelectedPage)
			GridSdtAlojamentoWebs.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtAlojamentoWebsPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtAlojamentoWebs.Rows = GridSdtAlojamentoWebsPaginationBar.RowsPerPageSelectedValue
	GridSdtAlojamentoWebs.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoReplicar'

	GravaBiometria.Call(&EmpCod,&BioQtdAmo,&BioPesTot,&BioDta,&BioFilCod,&SdtAlojamentoWeb)
	&SdtBiometria.Clear()
	&SdtAlojamentoWeb.Clear()
	&WebSession.Set('ALOJAMENTOREPLICAR',&SdtAlojamentoWeb.Toxml())
	padraoUsuario.call('G', 'SEL_WWBiometria', &Context.PesCod, &Context.EmpCod, &SdtBiometria.ToJson(), &PadDtaMod)
	WWBiometria.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event SdtAlojamentoWeb__Select.Click

	&WebSession.Set('ALOJAMENTOREPLICAR',&SdtAlojamentoWeb.Toxml())
	WPReplicaBiometria.Call()

EndEvent

Sub 'CarregaAlojamentos'

	&SdtAlojamentoWeb.Clear()
	For each Order EmpCod,AloLotCod
		Where EmpCod = &EmpCod
		Where AloLotCod = &BioAloLotCod
		RetornaUltimaBiometria.call(EmpCod,AloCod,&BioAloDta,&BioPesMed)
		If  &BioAloDta.IsEmpty()
			&BioAloDta = AloDtaIni
		EndIf
	
		If &BioAloDta < &BioDta 
			&SdtAlojamentoWebItem = New()
			&SdtAlojamentoWebItem.AloCod = AloCod
			&SdtAlojamentoWebItem.AloUniProCod = AloUniProCod
			&SdtAlojamentoWebItem.AloLin = AloLin
			&SdtAlojamentoWebItem.AloLotCod = AloLotCod
			&SdtAlojamentoWebItem.AloLotNro = AloLotNro
			&SdtAlojamentoWebItem.AloUniProNom = TRIM(str(AloUniProNom))
			&SdtAlojamentoWeb.Add(&SdtAlojamentoWebItem)
		EndIf
	EndFor

EndSub


