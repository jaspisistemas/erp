      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&PesCod = &Context.PesCod
	&PesRaz = &Context.PesRaz

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Height = 100

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&CreVlrSdo.Visible = False
	&CreRecPag.Visible = False
	&CreFilPgt.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CampoData = &Today+1
	do 'LoadDuplicata'
	
	&CreCmdIns.Clear()
	do CAse
		Case &CreCbrCtaBanBanCod  = '748' //SICREDI
			&CreCmdIns.AddItem(1, '1 - Pedido Baixa')
			//			&CreCmdIns.AddItem(2, '2 - Concessão abatimento')
			//			&CreCmdIns.AddItem(3, '3 - Cancelamento de abatimento')
			&CreCmdIns.AddItem(4, '4 - Alteração de vencimento')
			//			&CreCmdIns.AddItem('5', '')
			&CreCmdIns.AddItem(6, '6 - Pedido de protesto')
			//			&CreCmdIns.AddItem(7, '7 - Sustar protesto e baixar título')
			//			&CreCmdIns.AddItem(8, '8 - Sustar protesto e manter em carteira')
			&CreCmdIns.AddItem(9, '9 - Alteração de outros dados')
			
		Case &CreCbrCtaBanBanCod  = '999' //JASPI - Pagamentos
			&CreCmdIns.AddItem(1, '1 - Pedido Baixa')
			&CreCmdIns.AddItem(4, '4 - Alteração de vencimento')
			
		Case &CreCbrCtaBanBanCod = '077'
			&CreCmdIns.AddItem(1, '1 - Pedido Baixa')
	EndCAse

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbComplemento.Visible = (&CreCmdIns = 9)
	tbCampoTexto.Visible = (&CreCmdIns = 5  or &CreCmdIns = 9 or &CreCmdIns = 2)
	tbData.Visible = (&CreCmdIns = 4)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CreCmdIns.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event Enter

	Do case
		Case &CreCbrCtaBanBanCod = '748' and  &CreCbrTipBol <> tipoBoleto.Hibrido  // Sicredi Tradicional
			InstrucaoBoletoApiECommerce.call(&EmpCod,&FilCod,&CreCod,&CreCmdIns,&CreCmdCpl,&CampoData,&CampoTexto,&MsgErro,&MsgSucesso)
			
		Case &CreCbrCtaBanBanCod = '748' and  &CreCbrTipBol = tipoBoleto.Hibrido // Sicredi Hibrido
			InstrucaoBoletoSicredi.call(&EmpCod,&FilCod,&CreCod,&CreCmdIns,&CreCmdCpl,&CampoData,&CampoTexto,&PesCod,&PesRaz,&MsgErro,&MsgSucesso)
		
		CAse &CreCbrCtaBanBanCod = '077'
			Do 'GetLocalCobranca'
			
			If &IsErro	= False
				&MotivoVarChar	= 'Duplicata cancelada via Sistema JASPI.'
				prcCancelarCobranca_Inter.Call(&EmpCod, &FilCod, 0, '', &CreCod, &CreCbrCod, &CbrChaTra, &contacorrente, &CreCodSol, &MotivoVarChar, &Mensagem)
				if not &Mensagem.IsEmpty()
					msg(&Mensagem)
				Endif
			
			EndIf
	EndCase
	
	If not &MsgErro.Trim().IsEmpty()
		msg(&MsgErro)
	EndIf
	
	If not &MsgSucesso.Trim().IsEmpty()
		msg(&MsgSucesso)
	EndIf

EndEvent

Sub 'GetLocalCobranca'

	&IsErro 		= False
	For each Order EmpCod, CbrCod, CrbRegAut
		Where EmpCod 	= &EmpCod
		Where CbrCod 	= &CreCbrCod
		Where CrbRegAut = Status_SimNao.Sim
		
		&contacorrente	= CbrNroCon.Trim() + CbrNroConDig.Trim()
		If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow()
			&CbrChaTra 			= CbrChaTra
		Else
			prcOAuth_Inter.Call(&EmpCod, &FilCod, &PesCod, CbrCod, &CbrChaTra, &MsgErro)
			If Not &Mensagem.IsEmpty()
				&IsErro			= True
			EndIf
		EndIf
		
		Exit
	When None
		&IsErro	= True
	EndFor

EndSub

Sub 'LoadDuplicata'

	For each Order EmpCod,FilCod,CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		&CreRecPag = CreRecPag
		&CreFilPgt = CreFilPgt
		&CreBloNro = CreBloNro
		&CreCbrCod = CreCbrCod
		&CreCliCod = CreCliCod
		&CreCliRaz = CreCliRaz
		&CreDtaEms = CreDtaEms
		&CreDtaVct = CreDtaVct
		&CreDupNro = CreDupNro
		&CreVlrDup = CreVlrDup
		&CreVlrSdo = CreVlrSdo
		&CreCodSol = CreCodSol
		exit
	EndFor

EndSub


]]></Source>
