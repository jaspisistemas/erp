Event Start

	loadwwpContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&Mensagem = 'INFORME NUMERO DO PEDIDO'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	validaDesagrupamento.Call(&EmpCod, &FilCod, &PedCod, &Mensagem, &IsErro, &ErroMensagem)
	if not &ErroMensagem.IsEmpty()
		msg(&ErroMensagem)
		&PedCod.SetFocus()
	Else
		GravaDesagrupamento.Call(&EmpCod, &FilCod, &PedCod, &Context.PesCod)
		return
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedCod.IsValid

	validaDesagrupamento.Call(&EmpCod, &FilCod, &PedCod, &Mensagem, &IsErro, &ErroMensagem)
	if not &ErroMensagem.IsEmpty()
		msg(&ErroMensagem)
		&PedCod.SetFocus()
	Endif

EndEvent

Event Refresh

	loadwwpContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

EndEvent


