Event Start

	txtId.ForeColor = RGB(50,150,50)
	txtValor.ForeColor = RGB(50,150,50)
	txtDimDesc.ForeColor = RGB(255,0,0)
	
	LoadWWPContext.Call(&Context)
	if &Context.Old_Perfil < 3
		SyncImg.Visible = 0
	EndIF
	do 'Empresa'
	padraoUsuarioHora.Call('L', '#PLANOJASPICONTRATADO#', 1, &Context.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	&sdtPlanoContratado.FromXml(&PadObs)

	For &sdtPlanoContratadoDetalhamento in &sdtPlanoContratado.Detalhamento
		Do Case
			CAse &sdtPlanoContratadoDetalhamento.ID = 'FORMAPAGAMENTO'
				txtFormaPagamento.Caption = 'Forma Pagamento: ' + &sdtPlanoContratadoDetalhamento.Dados
			CAse &sdtPlanoContratadoDetalhamento.ID = 'DIAVENCIMENTO'
				txtDiaVencimento.Caption = 'Dia Vencimento: ' + &sdtPlanoContratadoDetalhamento.Dados
			CAse &sdtPlanoContratadoDetalhamento.ID = 'PLANOTOTAL'
				txtValorContratado.Caption = 'Valor plano contratado: R$ ' + trim(&sdtPlanoContratadoDetalhamento.Dados)
		EndCase
	
	EndFor

	//SOMENTE ADMs, E AUTORIZADOS AO CONTAS A PAGAR>
	
	//AVISA DUPLICATA DISPONIVEL
	&AutIsAdm = RetornaAutorizacaoAdministrador.Udp(&Context.EmpCod, &Context.PesCod)
	retornaAutorizacao.Call('WWDUPLICATAPAGAR', Status_SimNao.Nao, 1, &AutNiv)
	tbDadosPlano.Visible = (&AutNiv > 1 or &AutIsAdm = true or &Context.Old_Perfil = 3  or &Context.Old_Perfil = 2)

