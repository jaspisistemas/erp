Sub 'AtualizaTotaisUsuarios'

	&QtdMaximo = 0
	&EmpQtdWhatsMsg0800 = 0
	&EmpQtdWhatsMsg = 0
	&auxEmpQtdWhatsMsg = 0
	&QtdMaximoPdvs = 0
	For Each Order EmpCod
		Where EmpCod = &Context.EmpCod
		&QtdMaximo = EmpQtdUsu
		&EmpQtdWhatsMsg0800 = EmpQtdWhatsMsg0800
		&auxEmpQtdWhatsMsg = EmpQtdWhatsMsg
		&QtdMaximoPdvs = EmpQtdPDV
		Exit
	EndFor
	
	//GET MENSALIDADES
	PadraoUsuarioHora.Call('L', '#VENCIMENTODUPLICATAJASPI#', 1, &Context.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	if not &PadObs.IsEmpty()
		EmbeddedPage.Visible = 1
		&dupCreDtavct = CtoD(Substr(&PadObs,1,10))
		&Cryptografado = Substr(&PadObs,11,37)
		
		CodigoExternoDuplicata.Call(&Cryptografado, 0, 0, 0, 0, &dupCreDtavct, &Cryptografado)				
		
		&Mensagem = 'https://app.jaspi.com.br/portalcliente.areacliente.aspx?' + &Cryptografado.Trim()
		EmbeddedPage.Height = 300
		
		EmbeddedPage.Width = 600
		EmbeddedPage.Source = &Mensagem
	Else
		EmbeddedPage.Visible = 0
	Endif
	
		
	//VERIFICA RESTRICAO WHATSAPP
	&WaDtaEms = serverdate()
	&Ano = year(&WaDtaEms)
	&Mes = month(&WaDtaEms)
	&WaAnoMes = trim(str(&Ano)) + trim(str(&mes))
	
	prcWhatsApp_verificaQtdEnviadaAnoMes.Call(&Context.EmpCod, &WaAnoMes, &WaAnoMesQtd, &EmpQtdWhatsMsg)
	&Extra = &EmpQtdWhatsMsg - (&EmpQtdWhatsMsg0800+&auxEmpQtdWhatsMsg)
	if &Extra < 0
		&Extra = 0
	Endif
	
	&Mensagem = Format('ENVIADO: %1 MÁX.: %2',trim(toformattedString(&WaAnoMesQtd)), trim(toformattedString(&EmpQtdWhatsMsg))) 
	if &Extra > 0 or &EmpQtdWhatsMsg0800 > 0 or &auxEmpQtdWhatsMsg > 0
		&Mensagem += ' ['
		&IsAdd = false
		if &EmpQtdWhatsMsg0800 > 0	
			&Mensagem = &Mensagem.Trim() + 'BONIF.:' + trim(toformattedString(&EmpQtdWhatsMsg0800))
			&IsAdd = true
		Endif
		if &auxEmpQtdWhatsMsg > 0
			if &IsAdd = true
				&Mensagem = &Mensagem.Trim() + ' / '
			Endif
			&IsAdd = true
			&Mensagem = &Mensagem + 'CONTRAT.:' + trim(toformattedString(&auxEmpQtdWhatsMsg))
		Endif
		if &Extra > 0
			if &IsAdd = true
				&Mensagem = &Mensagem.Trim() + ' / '
			Endif
			&Mensagem = &Mensagem + 'EXTR.:' + trim(toformattedString(&Extra))
		Endif
		&Mensagem = &Mensagem.Trim() + ']'
	Endif

	txtQtdUtilizadaWhatsApp.Caption = &Mensagem
	
	
		
	Do CAse
		CAse &WaAnoMesQtd > &EmpQtdWhatsMsg
			txtQtdUtilizadaWhatsApp.ForeColor = RGB(255,0,0)
		CASe &EmpQtdWhatsMsg = &WaAnoMesQtd
			txtQtdUtilizadaWhatsApp.ForeColor = RGB(255,100,50)
		otherwise
			txtQtdUtilizadaWhatsApp.ForeColor = RGB(0,150,255)
	EndCase

	//VERIFICA RESTRICAO USUARIO
	if &QtdMaximo > 0
		tbRestricaoUsuarios.Visible = 1
		&QtdAtivos = 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &Context.EmpCod
			Where not PesExtCod.IsEmpty() and not PesExtCod.IsNull()
			&AuxPesExtCod = PesExtCod
			do 'getUsuariosGAMverifica'		
		EndFor
		
		txtQtdUtilizadaUsuarios.Caption = Format('ATIVOS: %1 MÁX.: %2', padl(trim(toformattedString(&QtdAtivos)),2,'0'), padl(trim(toformattedString(&QtdMaximo)),2,'0'))
		Do CAse
			CAse &QtdAtivos = &QtdMaximo
				txtQtdUtilizadaUsuarios.ForeColor = RGB(255,100,50)
			CAse &QtdAtivos > &QtdMaximo
				txtQtdUtilizadaUsuarios.ForeColor = RGB(255,0,0)
			Otherwise
				txtQtdUtilizadaUsuarios.ForeColor = RGB(0,150,255)
		EndCAse
			
	Else
		tbRestricaoUsuarios.Visible = 0
	Endif

	if &QtdMaximoPdvs > 0
		&QtdPdvsAtivos = 0
		For Each Order EmpCod, PdvCod
			Where EmpCod = &Context.EmpCod
			&QtdPdvsAtivos += 1
		EndFor
		
		txtQtdUtilizadaUsuarios.Caption = Format('ATIVOS: %1 MÁX.: %2', padl(trim(toformattedString(&QtdPdvsAtivos)),2,'0'), padl(trim(toformattedString(&QtdMaximoPdvs)),2,'0'))
		Do CAse
			CAse &QtdPdvsAtivos = &QtdMaximoPdvs
				txtQtdUtilizadaUsuarios.ForeColor = RGB(255,100,50)
			CAse &QtdPdvsAtivos > &QtdMaximoPdvs
				txtQtdUtilizadaUsuarios.ForeColor = RGB(255,0,0)
			Otherwise
				txtQtdUtilizadaUsuarios.ForeColor = RGB(0,150,255)
		EndCAse
	else
		tbrestricaoPDvs.Visible = 0
	EndIf

EndSub

Sub 'getUsuariosGAMverifica'

	&Filter.AuthenticationTypeName	= ''
	&Filter.ReturnAnonymousUser 	= false
	&Filter.ExternalId = trim(str(&AuxPesExtCod))
	
	For &User in GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors)		
		If &User.IsActive = true and &User.IsBlocked <> true
			&QtdAtivos += 1
		Endif
		
		Exit
	EndFor

EndSub

Sub 'Empresa'

	AtualizarSistema.Visible = 0
	
	if &Context.Old_Perfil > 2
		For Each Order EmpCod
			if not EmpAgeUpd.IsEmpty() and not EmpAgeUpd.IsNull()
				AtualizarSistema.Visible = 1
			Endif
			
			Exit
		EndFor
	EndIf

EndSub


