        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLocalizar'

	Status.Caption = 'Aguarde ... localizando Informações ...'
	&SoNumero = RetornaSoNumeros.Udp(&PesCnpj)
	
	&urlString = "/v1/cnpj/" +&SoNumero.Trim()
	&httpClient.Host = 'receitaws.com.br/'
	&httpClient.Port = 80
	&httpClient.Secure = false
	&httpClient.Timeout = 10
	&httpClient.Execute("GET", &urlString)
 	
	If &httpClient.ErrCode = 0
		&SdtCnpj.FromJson(&httpClient.ToString())
		Status.Caption = ''
	Else 
		msg(&httpClient.ErrDescription)
		Status.Caption = 'ERROR'
	EndIF
	&XmlWriter.Open('inadimpl.xml')
&XmlWriter.WriteRawText(&SdtCnpj.toXml())
&XmlWriter.Close()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


