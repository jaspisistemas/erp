      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPCALCULOJUROS', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FunCod = &Context.PesCod
	&Posicao = 0
	If &AuxCliCod <> 0
		&PesCod = &AuxCliCod
		Do 'Cliente'
	Else
		DeletaTmpJur.call(&EmpCod, &funCod, &auxCliCod)
	EndIf

	TmpJurDtaIni.Enabled = True
	TmpJurDtaFim.Enabled = True
	&TxtJur.Enabled = True
	&TxaMlt.Enabled = True
	&VlrTit.Enabled = True
	&CreDupNro.Enabled = True
	&OutVlr.Enabled = True

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableTotGer.Width = 120
	TableTotmlt.Width = 120
	TableTot.Width = 120
	TableTotRes.Width = 120
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 30

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

		TmpJurDtaIni.Enabled = True
		TmpJurDtaFim.Enabled = True
		&TxtJur.Enabled = True
		&TxaMlt.Enabled = True
		&VlrTit.Enabled = True
		&CreDupNro.Enabled = True
		&OutVlr.Enabled = True
		
		&TmpJurCliCod = TmpJurCliCod
		&TmpFunCod = FunCod
		&TmpJurCod = TmpJurCod
	
	    &TxtJur = TmpJurTxaJur
        &VlrTit = TmpJurVlrTit
		&VlrJur = TmpJurVlrJur
		&VlrSdo = TmpJurVlrTot
		&QtdDias = TmpJurDia
		&OutVlr = TmpJurOutVlr
		&TxaMlt = TmpJurTxaMlt
		&VlrMlt = TmpJurVlrMlt
		&CreDupNro = TmpJurCreDup
		&Posicao+=1
		&TotOtrVlr += &OutVlr
		&TotVlrJur += &VlrJur
		&TotVlrSdo += &VlrSdo
		&TotVlrMlt += &VlrMlt

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Grava.FromImage(ActionCancel)
	&Grava.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	&TmpJurCod = 0
	
    &TxtJur = 0
    &VlrTit = 0
	&VlrJur = 0
	&VlrSdo = 0
	&QtdDias = 0
	&OutVlr  = 0
	&TxaMlt  = 0
	&VlrMlt  = 0
	&CreDupNro = ''
	GravaTmpJuros.Call(&EmpCod,&funCod,&TmpJurCod,&PesCod,&CreDupNro,TmpJurDtaIni,TmpJurDtaFim,&QtdDias,&TxtJur,&TxaMlt,&VlrTit,&OutVlr,&VlrJur,&VlrMlt,&VlrSdo)
	Grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	RCOOpenWindow1.LinkOpen = RELJAS036.Link(&EmpCod,&Context.FilCod,&PesCod,&PesRaz,&FunCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDetelar'

	DeletaTmpJur.call(&EmpCod, &funCod, &PesCod)
	Grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Grava.Click

	Do 'Gravar'

EndEvent

Event &OutVlr.IsValid

	Do 'Gravar'

EndEvent

Event &VlrTit.IsValid

	Do 'Gravar'
	&index = 1

EndEvent

Event &PesCod.IsValid

	Do 'Cliente'

EndEvent

Event Refresh

	&Posicao = 0
	&TotDias = 0 
	&TotOtrVlr = 0
	&TotVlrJur = 0
	&TotVlrSdo = 0
	&TotVlrMlt = 0

EndEvent

Sub 'Cliente'

	If &PesCod = 0
		&PesRaz = 'NENHUM CLIENTE SELECIONADO.'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			Where PesIsCli = true
			&PesRaz = PesRaz
			Exit
		When none
			&PesRaz = 'CLIENTE NÃO ENCONTRADO!'
			&PesCod.SetFocus()
		EndFor
		If &AuxCliCod = 0
			Grid.Refresh()
		EndIf		
	EndIf

EndSub

Sub 'Gravar'

	&VlrMlt = 0
	&VlrSdo = 0
	&VlrJur = 0
    CalculaJurosLivre.Call(&EmpCod,&TxtJur,&TxaMlt,TmpJurDtaIni,TmpJurDtaFim,&VlrTit,&VlrJur,&QtdDias,&VlrMlt)
    &VlrSdo = &VlrTit + &VlrJur + &OutVlr + &VlrMlt
	If &TmpJurCliCod = 0
		&TmpJurCliCod = &PesCod
	EndIf
	GravaTmpJuros.Call(&EmpCod,&TmpfunCod,&TmpJurCod,&TmpJurCliCod,&CreDupNro,TmpJurDtaIni,TmpJurDtaFim,&QtdDias,&TxtJur,&TxaMlt,&VlrTit,&OutVlr,&VlrJur,&VlrMlt,&VlrSdo)
//	Grid.Refresh()
//	Do Case
//		Case &index = 1
//			&OutVlr.SetFocus()
//	EndCase

EndSub

//Event &TxaMlt.IsValid
//	
//	Do 'Gravar'
//	
//EndEvent
]]></Source>
