      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SalvarAvancar = true 
	
	&tmpNfeItmCod = &intmpNfeItmCod
	
	For Each ORder tmpNFeCod
		Where tmpNFeCod = &tmpNfeCod
		
		For Each ORder tmpNFeCod, tmpNfeItmCod
			&minimo = tmpNfeItmCod
			Exit
		EndFor
		
		For Each ORder tmpNFeCod, (tmpNfeItmCod)
			&Maximo = tmpNfeItmCod
			Exit
		EndFor
	
		Exit
	EndFor
	
	do 'carregaItemTemporario'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable8.Height = 50
	UnnamedTable12.Width = 60
	UnnamedTable16.Width = 60
	UnnamedTable14.Width = 300
	UnnamedTable24.Width = 120
	UnnamedTable23.Width = 60
	UnnamedTable22.Width = 120
	UnnamedTable27.Width = 120
	UnnamedTable26.Width = 60
	UnnamedTable25.Width = 120
	UnnamedTable30.Width = 120
	UnnamedTable29.Width = 60
	UnnamedTable28.Width = 120
	UnnamedTable34.Width = 200

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&tmpPedQtd.SetFocus()

EndEvent

Event 'DoItemAnterior'

	if &minimo > &tmpNfeItmCod
		&tmpNfeItmCod -= 1
		do 'carregaItemTemporario'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoProximoItem'

	if &Maximo > &tmpNfeItmCod
		&tmpNfeItmCod += 1
		do 'carregaItemTemporario'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

//	&tmpProVlrFrt
	&VarcharSituacao = trim(&SitCod.ToString())
	&CfoCod = formataCFOP.Udp(&CfoCod)
	AtualizaItemNotaTemporaria.Call(&tmpNFeCod, &tmpNfeItmCod, &VarcharSituacao, &CfoCod, &tmpPedQtd, &tmpPedVlrUnt, &tmpProVlrFrt, &tmpPedVlrTot, &PedItmIcmBas, &PedItmIcm, &PedItmVlrIcm, &PedItmVlrIcmStBas, &PedItmIcmSt, &PedItmVlrIcmSt, &PedItmVlrIpiBas, &PedItmIpi,  &PedItmVlrIpi, 0, 0, &PedItmPisBas, &PedItmPis, &PedItmCofins, &PedItmVlrPis, &PedItmVlrCofins, &NewNfeCstCofins)
	
	if &SalvarAvancar = true and &tmpNfeItmCod < &Maximo
		&tmpNfeItmCod += 1
		do 'carregaItemTemporario'
	Else
		wwpActions.WCPopup_Close('S')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CfoCod.IsValid

	&CfoCod = formataCFOP.Udp(&CfoCod)

EndEvent

Event &tmpPedQtd.ControlValueChanged

	&tmpPedVlrTot = round(&tmpPedVlrUnt * &tmpPedQtd, 2)

EndEvent

Event &tmpPedVlrUnt.ControlValueChanged

	&tmpPedVlrTot = round(&tmpPedVlrUnt * &tmpPedQtd, 2)

EndEvent

Event &PedItmIcm.ControlValueChanged

	//ICMS
	&PedItmVlrIcm = round(&PedItmIcmBas * (&PedItmIcm * 0.01), 2)

EndEvent

Event &PedItmIcmBas.ControlValueChanged

	&PedItmVlrIcm = round(&PedItmIcmBas * &PedItmIcm * 0.01, 2)

EndEvent

Event &PedItmVlrIcmStBas.ControlValueChanged

	&PedItmVlrIcmSt = round(&PedItmVlrIcmStBas * (&PedItmIcmSt * 0.01), 2)
	&PedItmVlrIcmStPob = round(&PedItmVlrIcmStPobBas * (&PedItmIcmStPob * 0.01), 2)

EndEvent

Event &PedItmIcmSt.ControlValueChanged

	//ICMS ST
	&PedItmVlrIcmSt = round(&PedItmVlrIcmStBas * (&PedItmIcmSt * 0.01), 2)

EndEvent

Event &PedItmVlrIpiBas.ControlValueChanged

	&PedItmVlrIpi = round(&PedItmVlrIpiBas * &PedItmIpi * 0.01, 2)

EndEvent

Event &PedItmIpi.ControlValueChanged

	//IPI
	&PedItmVlrIpi = round(&PedItmVlrIpiBas * (&PedItmIpi * 0.01), 2)

EndEvent

Event &PedItmPisBas.ControlValueChanged

	&PedItmVlrPis = round(&PedItmPisBas * &PedItmPis * 0.01, 2)
	&PedItmVlrCofins = round(&PedItmPisBas * &PedItmCofins * 0.01, 2)

EndEvent

Event &PedItmPis.ControlValueChanged

	&PedItmVlrPis = round(&PedItmPisBas * &PedItmPis * 0.01, 2)

EndEvent

Event &PedItmCofins.ControlValueChanged

	&PedItmVlrCofins = round(&PedItmPisBas * &PedItmCofins * 0.01, 2)

EndEvent

Sub 'carregaItemTemporario'

	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNfeCod
		
		
		For Each Order tmpNFeCod, tmpNfeItmCod
			Where tmpNfeItmCod = &tmpNfeItmCod
			
			&tmpProNom = tmpProNom
			
			&tmpPedVlrTot = tmpPedVlrTot
			&tmpPedVlrUnt = tmpPedVlrUnt 
			&tmpPedQtd = tmpPedQtd
			
			&CfoCod = tmpCFOP
			&SitCod.FromString(tmpNfeSitCod)

			//taxa
			
			&PedItmPis	=	tmpProPerPIS
			&PedItmCofins	=	tmpProPerCOFINS
			&PedItmIcmSt	=	tmpProPerIcmSt
			&PedItmIcm	=	tmpProPerIcm
			&PedItmIpi	=	tmpProPerIpi
			
			//base
			&PedItmVlrIpiBas	=	tmpProBasVlrIpi
			&PedItmIcmBas	=	tmpProBasVlrIcm
			&PedItmVlrIcmStBas	=	tmpProBasVlrIcmSt
			&PedItmPisBas	=	tmpProBasPIS
			
			//valores
			&PedItmVlrIpi	=	tmpProVlrIpi
			&PedItmVlrIcm	=	tmpProVlrIcm
			&PedItmVlrIcmSt	=	tmpProVlrIcmSt
			&PedItmVlrCofins	=	tmpProVlrCOFINS
			&PedItmVlrPis	=	tmpProVlrPIS
			
			&NewNfeCstCofins = tmpNfeCstPIS
			
			Exit
		When none
			wwpActions.WCPopup_Close('S')
		EndFor
		
		Exit
	EndFor

EndSub


]]></Source>
