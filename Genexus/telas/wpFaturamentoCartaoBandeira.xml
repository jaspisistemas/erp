      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&CreCod.Visible = False
	&DataInicial.Visible = False
	&DataFinal.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

//	&DataInicial = &Today.AddDays(-30)
//	&DataFinal = &Today
	if &FilCod.IsEmpty()
		&FilCod = &Context.FilCod
	EndIf
	&Ano = Year(&Today)
	&Mes = Month(&Today)
	&Parameters.Clear()
	
	Do "SetObjectQCartaoBandeira"
	Do "SetQueryViewerParametersQCartaoBandeira"
	Do "SetObjectQCartaoGeral"
	Do "SetQueryViewerParametersQCartaoGeral"

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if not &Ano.IsEmpty()
		Do "SetObjectQCartaoBandeira"
		Do "SetQueryViewerParametersQCartaoBandeira"
		Do "SetObjectQCartaoGeral"
		Do "SetQueryViewerParametersQCartaoGeral"
	else
		msg('Atenção! Obrigatório informar o ano.')
	EndIf

EndEvent

Sub 'Show Messages'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: ShowMessages
	For &Message in &Messages
		msg(&Message.Description)
	endfor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub "SetObjectQCartaoBandeira"

	// Config nome do Query
	UTChartColumnLine.ObjectName = "QCartaoBandeira"

EndSub

Sub "SetQueryViewerParametersQCartaoBandeira"

	&Parameters = New()
	
	//EmpCod
	&Parameter = New()
	&Parameter.Name = "EmpCod"
	&Parameter.Value = &EmpCod.ToString().Trim() 				
	&Parameters.Add(&Parameter)
	
	//FilCod
	&Parameter = New()
	&Parameter.Name = "FilCod"
	&Parameter.Value = &FilCod.ToString().Trim() 				
	&Parameters.Add(&Parameter)
	
	// Ano
	&AuxAno = &Ano 
	&Parameter = New()
	&Parameter.Name = "Ano"
	&Parameter.Value = &AuxAno.ToString().Trim()		
	&Parameters.Add(&Parameter)
	
	//Mes
	&Parameter = New()
	&Parameter.Name = "Mes"
	&Parameter.Value = &Mes.ToString().Trim()		
	&Parameters.Add(&Parameter)
	
	//Bandeira 
	&Parameter = New()
	&Parameter.Name = "CreCarBanNom"
	&Parameter.Value = &CreCarBanNom.ToString().Trim()
	&Parameters.Add(&Parameter)

EndSub

Sub "SetObjectQCartaoGeral"

	// Config nome do Query
	UTChartColumnLine2.ObjectName = "QCartaoGeral"

EndSub

Sub "SetQueryViewerParametersQCartaoGeral"

	&AuxParameters = New()
	
	//EmpCod
	&AuxParameter = New()
	&AUxParameter.Name = "EmpCod"
	&AUxParameter.Value = &EmpCod.ToString().Trim()
	&AuxParameters.Add(&AUxParameter)
	
	//FilCod
	&AuxParameter = New()
	&AUxParameter.Name = "FilCod"
	&AUxParameter.Value = &FilCod.ToString().Trim()
	&AuxParameters.Add(&AUxParameter)
	
	//Mes	
	&AuxParameter = New()
	&AUxParameter.Name = "Mes"
	&AUxParameter.Value = &Mes.ToString().Trim()
	&AuxParameters.Add(&AUxParameter)
	
	//Ano
	&AuxAno = &Ano 
	&AuxParameter = New()
	&AUxParameter.Name = "Ano"
	&AUxParameter.Value = &AuxAno.ToString().Trim()
	&AuxParameters.Add(&AUxParameter)

EndSub


