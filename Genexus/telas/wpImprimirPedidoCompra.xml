      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&PesCod = &Context.PesCod
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&OqueFazer = trim(Substr(&PadObs, 1, 5))
		&Ordem = Substr(&PadObs, 6, 1)
		if Substr(&PadObs, 7, 1) = '1'
			&DestacarImpostos = true
		Else
			&DestacarImpostos = false
		EndIF
	EndIF
	
	do 'loadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 200

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&OqueFazer = '1' or &OqueFazer = '4' Or &OqueFazer = '5')
		&DestacarImpostos.Visible = False
		DestacarImpostos_Cell.Class = !'Invisible'
	Else
		&DestacarImpostos.Visible = True
		DestacarImpostos_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&OqueFazer = '1' or &OqueFazer = '4')
		&MostrarItemNota.Visible = False
		MostrarItemNota_Cell.Class = !'Invisible'
	Else
		&MostrarItemNota.Visible = True
		MostrarItemNota_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	
	tbuss.Visible = (1=2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &OqueFazer.Click

	do 'AttributesSecurityCode'

EndEvent

Event &OqueFazer.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event Enter

	btnEnter.Visible = 0
	
	&PadObs = PadR(trim(&OqueFazer), 5, ' ') + trim(&Ordem)
	If &DestacarImpostos = true
		&PadObs += '1'
	Else
		&PadObs += '0'
	EndiF
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&Varchar = ServerTime()

	Do Case
		Case &OqueFazer = '1' //IMPRESSÃO PEDIDO COMPRA
			&NomeArquivo = 'PedidoCompra' + trim(str(&PedCod))
			RCOOpenWindow1.LinkOpen = RELJAS003.Link(&EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, &Varchar, &DestacarImpostos,&MostrarItemNota)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '4' //IMPRESSÃO PEDIDO COMPRA - MODELO02
			&NomeArquivo = 'PedidoCompra' + trim(str(&PedCod))
			RCOOpenWindow1.LinkOpen = RELJAS076.Link(&EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, &Varchar, &DestacarImpostos,&MostrarItemNota)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '2' //IMPRESSAO CONFERENCIA SEM QUANTIDADE
			&NomeArquivo = 'Conferencia' + trim(str(&PedCod))
			RCOOpenWindow1.LinkOpen = RELJAS009.Link(&EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, 'S', &Varchar)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '3' //IMPRESSAO CONFERENCIA COM QUANTIDADE
			&NomeArquivo = 'Conferencia' + trim(str(&PedCod))
			RCOOpenWindow1.LinkOpen = RELJAS009.Link(&EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, 'C', &Varchar)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '5'
			RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)		
			&URlFisicoEXCELL = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim()  + '/Excel' + trim(str(&PedCod))
			&URlVirtualEXCELL = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim()  + '/Excel' + trim(str(&PedCod)) + '.xlsx'
			&File.Source = &URlFisicoEXCELL + '.xlsx'
			If &File.Exists()
				&File.Delete()
			EndIf
			PedidoExcellCompra.Call(&EmpCod, &FilCod, &PedCod, &URlFisicoEXCELL, &IsErro, &DestacarImpostos)
			link(&URlVirtualEXCELL)
			
	EndCase


	&ProgressId = 'wpImprimePed' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	EsperaSegundos.Submit('', &ProgressId)

EndEvent

Event scaProgressBar1.OnComplete

	Return

EndEvent

Sub 'loadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		Do Case
			Case LctTip = TipoLancamento.DevolucaoCompra
				Form.Caption = 'Impressão Pedido Devolução Compra'
				
			Case  LctTip = TipoLancamento.DevolucaoVenda
				Form.Caption = 'Impressão Pedido Devolução Venda'
		EndCAse
		Exit
	EndFor

EndSub


]]></Source>
