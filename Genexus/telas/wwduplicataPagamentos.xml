EndEvent

Event &DoDeleteRe.Click

	if &CreRenOriCod > 0
		wpCancelarRenegociacaoReceber.Popup(&EmpCod, &CreRenOriCod)
		Refresh
	Else
		msg('Renegociação não pode ser deletada!')
	Endif

EndEvent

Sub 'ValidaPermisaoConta'

	&IsAutorizado = False
	For each Order EmpCod,CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &MovCtaBanCod
		Where CtaFunCod = &Context.PesCod
		where CtaFunIsCx <> Status_SimNao.Nao
		&IsAutorizado = True
		exit
	EndFor

EndSub

Sub 'LocalizaLancamentoCaixa'

	&CreMovCplItem.SetEmpty()
	&CreMovPlanCod.SetEmpty()
	&CreMovPlanNom.SetEmpty()
	&MOvCtaBanNom.SetEmpty()
	&MovCtaBanCod.SetEmpty()
	if not &CreMovCod.IsEmpty()
		For Each Order EmpCod, MovCod, MovCreCod
			Where EmpCod = &EmpCod
			Where MovCod = &CreMovCod
			Where MovCreCod = &CreCod
			&MovCtaBanCod = MovCtaBanCod
			&MOvCtaBanNom = MovCtaBanNom
			&CreMovPlanCod = PlanCod
			&CreMovPlanNom = PlanHie.Trim() + ' - ' + PlanNom.Trim()
			&CreMovCplItem = MovCplMan.Trim() + ' ' + MovItmCpl.Trim()
			&CreMovCplItem = &CreMovCplItem.Trim()
			Exit
		When none
			For Each Order EmpCod, MovCod
				Where EmpCod = &EmpCod
				Where MovCod = &CreMovCod
				//Where MovCreCod = &MovCreCod
				&MovCtaBanCod = MovCtaBanCod
				&MOvCtaBanNom = MovCtaBanNom
				&CreMovPlanCod = PlanCod
				&CreMovPlanNom = PlanHie.Trim() + ' - ' + PlanNom.Trim()
				&CreMovCplItem = MovCplMan.Trim() + ' ' + MovItmCpl.Trim()
				&CreMovCplItem = &CreMovCplItem.Trim()
				Exit
			EndFor
			
		EndFor
	EndIf

EndSub

Sub 'Enabledisable'

	tbPanDup.Visible = 0
	tbPanRen.Visible = 0
	
	For each Order EmpCod,FilCod,CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		
		TextBlockTitle.Caption = 'PAGAMENTOS DP.: ' + trim(CreDupNro)
		
		//RENEGOCIACAO
		For each Order EmpCod,FilCod,CreCod,CreRenCod
			tbPanRen.Visible = 1
			Exit
		EndFor		
		
		//PAGAMENTO
		For each Order EmpCod,FilCod,CreCod,CrePagCod
			
			tbPanDup.Visible = 1
			Exit
		endFor
		
		Exit
	Endfor

EndSub


