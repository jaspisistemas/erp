Event &CreMovCod.Click

	do 'ValidaPermisaoConta'
	if &MovCtaBanCod <> 0
		if &IsAutorizado = true
			wpMovimento.Link(TrnMode.Update, EmpCod, CreMovCod, 0)
		Else
			msg('Usuário não Autorizado a acessar lançamento da conta : ' + trim(&MOvCtaBanNom))
		Endif
	Else
		msg('Movimento não Localizado')
	Endif

EndEvent

