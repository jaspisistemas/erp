        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbconte.Width = 1210
	tbAoa.Height = 250
	tbtil12.Height = 100
	tabsdsd.Height = 50
	&ProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CtabanCodNom = trim(str(&Context.CtaBanCod)) + ' - ' + &Context.CtaBanNom

	btnEnter.SetFocus()
	Do  'carregaItem'

EndEvent

Event 'DoRetornaPDV'

 2
	
	Pdvm_venda.Link(&PedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	AutorizacaoBrinde.popup(&EmpCod, &FilCod, &PedCod, &PedItmCod)
	pdvm_venda.call(&PedCod)

EndEvent

Sub 'carregaItem'

	For Each Order EmpCod, FilCod, PedCod,PedItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedItmCod = &PedItmCod
		Where PedSts = Status_Pedido.ABERTO
		&ProCod = ProCod
		&ProCodNom = ProCodNom
		&PedQtd = PedQtd
		exit
	When none
		&ProCodNom = 'ITEM NÃO ENCONTRADO!'
		msg('Item não encontrado!')
	EndFor

EndSub


