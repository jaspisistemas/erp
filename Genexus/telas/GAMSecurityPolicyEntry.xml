      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &Mode <> GAMAPiMode.Insert
		&SecurityPolicy.Load(&Id)
		&SecurityPolicyId = &SecurityPolicy.Id
		&SecurityPolicyGUID = &SecurityPolicy.GUID
		&SecurityPolicyName = &SecurityPolicy.Name
		&SecurityPolicyPeriodChangePassword = &SecurityPolicy.PeriodChangePassword
		&SecurityPolicyMinimumTimeToChangePasswords = &SecurityPolicy.MinimumTimeToChangePasswords
		&SecurityPolicyMinimumLengthPassword = &SecurityPolicy.MinimumLengthPassword
		&SecurityPolicyMinimumNumericCharactersPassword = &SecurityPolicy.MinimumNumericCharactersPassword
		&SecurityPolicyMinimumUpperCaseCharactersPassword = &SecurityPolicy.MinimumUpperCaseCharactersPassword
		&SecurityPolicyMinimumSpecialCharactersPassword = &SecurityPolicy.MinimumSpecialCharactersPassword
		&SecurityPolicyMaximumPasswordHistoryEntries = &SecurityPolicy.MaximumPasswordHistoryEntries
		&SecurityPolicyAllowMultipleConcurrentWebSessions = &SecurityPolicy.AllowMultipleConcurrentWebSessions
		&SecurityPolicyWebSessionTimeout = &SecurityPolicy.WebSessionTimeout
		&SecurityPolicyOauthTokenExpire = &SecurityPolicy.OauthTokenExpire
		&SecurityPolicyOauthTokenMaximumRenovations = &SecurityPolicy.OauthTokenMaximumRenovations
	endif
	If &Mode = GAMAPiMode.Display
		Btnenter.Visible = False
	Endif
	If &Mode = GAMAPiMode.Display or &Mode = GAMAPiMode.Delete
		&SecurityPolicyName.Enabled = False
		&SecurityPolicyAllowMultipleConcurrentWebSessions.Enabled = False
		&SecurityPolicyWebSessionTimeOut.Enabled = False
		&SecurityPolicyOauthTokenExpire.Enabled = False
		&SecurityPolicyOauthTokenMaximumRenovations.Enabled = False
		&SecurityPolicyPeriodChangePassword.Enabled = False
		&SecurityPolicyMinimumTimeToChangePasswords.Enabled = False
		&SecurityPolicyMinimumLengthPassword.Enabled	= False
		&SecurityPolicyMinimumNumericCharactersPassword.Enabled = False
		&SecurityPolicyMinimumUpperCaseCharactersPassword.Enabled = False
		&SecurityPolicyMinimumSpecialCharactersPassword.Enabled = False		
		&SecurityPolicyMaximumPasswordHistoryEntries.Enabled = False
		BtnEnter.Caption = "Delete"
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&SecurityPolicy.Load(&Id)
	Do Case
		Case &Mode = GAMAPiMode.Insert or &Mode = GAMAPiMode.Update
			&SecurityPolicyId = &SecurityPolicy.Id
			&SecurityPolicy.GUID = &SecurityPolicyGUID
			&SecurityPolicy.Name = &SecurityPolicyName 
			&SecurityPolicy.PeriodChangePassword = &SecurityPolicyPeriodChangePassword 
			&SecurityPolicy.MinimumTimeToChangePasswords = &SecurityPolicyMinimumTimeToChangePasswords 
			&SecurityPolicy.MinimumLengthPassword = &SecurityPolicyMinimumLengthPassword 
			&SecurityPolicy.MinimumNumericCharactersPassword = &SecurityPolicyMinimumNumericCharactersPassword 
			&SecurityPolicy.MinimumUpperCaseCharactersPassword = &SecurityPolicyMinimumUpperCaseCharactersPassword 
			&SecurityPolicy.MinimumSpecialCharactersPassword = &SecurityPolicyMinimumSpecialCharactersPassword 
			&SecurityPolicy.MaximumPasswordHistoryEntries = &SecurityPolicyMaximumPasswordHistoryEntries 
			&SecurityPolicy.AllowMultipleConcurrentWebSessions.FromString(&SecurityPolicyAllowMultipleConcurrentWebSessions.ToString()) 
			&SecurityPolicy.WebSessionTimeout = &SecurityPolicyWebSessionTimeout 
			&SecurityPolicy.OauthTokenExpire = &SecurityPolicyOauthTokenExpire 
			&SecurityPolicy.OauthTokenMaximumRenovations = &SecurityPolicyOauthTokenMaximumRenovations
			&SecurityPolicy.Save()
		Case &Mode = GAMAPiMode.Delete
			&SecurityPolicy.Delete()
	EndCase
	if &SecurityPolicy.Success()
		commit
		return
	else
		&Errors = &SecurityPolicy.GetErrors()
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor
	endif

EndEvent


]]></Source>
