      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do 'loadFilaImpressao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&FIempCod.Visible = False
	&FiUsuCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'loadFilaImpressao'

	For each order FIempCod, FIcod
		where FIempCod = &FiEmpCod
		where FIcod = &FiCod
		&FiSts = FIsts
		&FiDtaIni = FiDtaIni
		&FiDtaFim = FiDtaFim
		&FiDtaEms = FiDtaEms
		&FIimpTip = FIimpTip	
		&FIimpPC = FIimpPC
		&FiUsuCod = FiUsuCod
		&FiPedCod = FiPedCod
		&FiFilCod = FiFilCod
		&FiRelNam = FIrelNam
		&FiMsg = FImsg
		exit
	EndFor
	Do 'loadPessoa'

EndSub

Sub 'loadPessoa'

	For each order EmpCod, PesCod
		where EmpCod = &FiEmpCod
		where PesCod = &FiUsuCod
		&PesCodRaz = PesCodRaz
		exit
	when none
		if &FiUsuCod = -1
			&PesCodRaz = 'SISTEMA'
		else
			&PesCodRaz = 'NÃO DEFINIDO'
		EndIf
	EndFor

EndSub


