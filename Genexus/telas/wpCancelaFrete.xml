      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('FRETECANCELAFINANCEIRO', Status_SimNao.Sim, 1, &AutNiv)
	LoadwwpContext.Call(&WwpContext)
	For Each ORder EmpCod, FilCod, FrtCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where FrtCod = &FrtCod
		if FrtStsFin <> Status_Financeiro.FECHADO
			return
		EndIF
	
		txtMsg.Caption = 'Deseja cancelar o financeiro do lançamento de frete SEQ.:' + trim(str(FrtCod)) + ' TRANS.:' + trim(FrtTraCodRaz)

		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	CancelarFinancConhecimento.Call(&EmpCod, &FiLCod, &FrtCod, &Mensagem, &WwpContext.UserName)
	if &Mensagem.IsEmpty()
		Return
	Else
		msg(&Mensagem)
	EndIF

EndEvent


]]></Source>
