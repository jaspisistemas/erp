      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&FpagSts = Status_Folha.Aberto
	For Each Order EmpCod, FPagCod
		Where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		
		&FpagSts = FPagSts
		Exit
	EnDfor

	if &FpagSts <> Status_Folha.Aberto
		btnEnter.Enabled = 0
	Endif

	&Mensagem = &WebSession.Get(&PESSOACONTAS)
	&sdtPagamentoFolhaAdiantamentos.FromJson(&Mensagem)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'loadFuncionario'
	Do 'loadComboAno'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsMarcado.ColumnHeaderClass = !'WWColumn'
	&gridMovCod.ColumnHeaderClass = !'WWColumn'
	&gridMovItmCod.ColumnHeaderClass = !'WWColumn'
	&gridMovItmCpl.ColumnHeaderClass = !'WWColumn'
	&gridMovItmVlr.ColumnHeaderClass = !'WWColumn'
	&gridMovFunAno.ColumnHeaderClass = !'WWColumn'
	&gridMovFunMes.ColumnHeaderClass = !'WWColumn'
	&gridMovFunSts.ColumnHeaderClass = !'WWColumn'
	&RemoveAdiantamento.ColumnHeaderClass = !'WWIconActionColumn'

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SdtMovimentoItem.Clear()
	&TotalAdiantamento.SetEmpty()
	RetornaAdiantamentosPagamentoFolha.Call(&EmpCod, &FPagCod, &ParFolAno, &ParFolMes, &ParFolFunCod, &sdtPagamentoFolhaAdiantamentos, &SdtMovimentoItem)

EndEvent

Event Grid.Load

	For &SdtMovimentoItemItem in &SdtMovimentoItem
		&gridMovCod    = &SdtMovimentoItemItem.MovCod
		&gridMovItmCod = &SdtMovimentoItemItem.MovItmCod
		&gridMovItmVlr = &SdtMovimentoItemItem.MovItmVlr
		&gridMovFunAno = &SdtMovimentoItemItem.MovFunAno
		&gridMovFunMes = &SdtMovimentoItemItem.MovFunMes
		&gridMovFunCod = &SdtMovimentoItemItem.MovFunCod
		&gridMovFunSts = &SdtMovimentoItemItem.MovFunSts
		&gridMovItmCpl = &SdtMovimentoItemItem.MovItmCpl
		
		Do case
			case &SdtMovimentoItemItem.MovFunSts = Status_abertoFechado.Fechado
				&IsMarcado.visible = false
				&TotalAdiantamento += &SdtMovimentoItemItem.MovItmVlr
				&IsMarcado = true
			case &SdtMovimentoItemItem.MovFunSts = Status_AbertoFechado.Aberto
				&IsMarcado.visible = true
				&IsMarcado = false
		EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&RemoveAdiantamento = !'<i class="fa fa-times"></i>'

	&IsMarcado.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess WWColumnSuccessFirstColumn', !'WWColumn')
	&gridMovCod.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess', !'WWColumn')
	&gridMovItmCod.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess', !'WWColumn')
	&gridMovItmCpl.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess', !'WWColumn')
	&gridMovItmVlr.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess', !'WWColumn')
	&gridMovFunAno.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess', !'WWColumn')
	&gridMovFunMes.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess', !'WWColumn')
	&gridMovFunSts.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWColumn WWColumnSuccess', !'WWColumn')
	&RemoveAdiantamento.ColumnClass = iif(&gridMovFunSts = Status_AbertoFechado.Fechado, !'WWIconActionColumn WWColumnSuccess', !'WWIconActionColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//&RemoveAdiantamento.Enabled = 
	
		if &FpagSts <> Status_Folha.Aberto
			&RemoveAdiantamento.Visible = 0
			&IsMarcado.Enabled = 0
		Endif
	
		if (&gridMovFunSts = &MovFunSts or &MovFunSts.IsEmpty()) and (&gridMovFunAno = &MovFunAno or &MovFunAno.IsEmpty()) and (&gridMovFunMes = &MovFunMes or &MovFunMes.IsEmpty())
			load
		EndIf
	EndFor

EndEvent

Event 'DoUserFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &IsMarcado.IsValid

	Do 'Total'

EndEvent

Event Enter

	&sdtPagamentoFolhaAdiantamentos.Clear()
	For each line in Grid
		if &IsMarcado = true 
			&sdtPagamentoFolhaAdiantamentosItem = new()
			&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovCod  = &gridMovCod
			&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovItmCod = &gridMovItmCod
			&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovVlr = &gridMovItmVlr
			&sdtPagamentoFolhaAdiantamentos.Add(&sdtPagamentoFolhaAdiantamentosItem)
		EndIf
	EndFor

	&WebSession.Set(&PESSOACONTAS, &sdtPagamentoFolhaAdiantamentos.ToJson())	
	
	wwpActions.WCPopup_Close('S')

EndEvent

Event &RemoveAdiantamento.Click

	for &sdtPagamentoFolhaAdiantamentosItem in &sdtPagamentoFolhaAdiantamentos
		if &sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovCod = &gridMovCod and &sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovItmCod = &gridMovItmCod
			&index = &sdtPagamentoFolhaAdiantamentos.IndexOf(&sdtPagamentoFolhaAdiantamentosItem)
			&sdtPagamentoFolhaAdiantamentos.Remove(&index)
		Endif
	Endfor

	Refresh

EndEvent

Sub 'loadComboAno'

	&AnoAtual = &Today.Year()
	&Ano = &AnoAtual - 1
	&MovFunAno.AddItem(&Ano, &Ano.ToFormattedString())
	&MovFunAno.AddItem(&AnoAtual, &AnoAtual.ToFormattedString())
	&Ano = &AnoAtual + 1
	&MovFunAno.AddItem(&Ano, &Ano.ToFormattedString())
	//Add Ano anterior, atual, e proximo (em ordem)

EndSub

Sub 'loadFuncionario'

	&FolFunCod = &ParFolFunCod
	For each order EmpCod,PesCod,PesSts,PesIsFun
		where EmpCod = &EmpCod
		where PesCod = &FolFunCod
		where PesSts = Status_ativoInativo.ATIVO
		where PesIsFun = true
		&PesRaz = PesRaz
		exit
	EndFor

EndSub

Sub 'Total'

	&TotalAdiantamento.SetEmpty()
	For each line in Grid
		if &IsMarcado = true	
			&TotalAdiantamento += &gridMovItmVlr
		EndIf
	EndFor

EndSub


]]></Source>
