      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&ProCod = &parProCod
	&GrupHie = &parGrupHie
	&ProSetCod = &parProSetCod
	do 'LoadConf'
	textInadim.LinkTarget = '_blank'
	textInadim.Link = wwInadimplencia.Link()
	&AtualizarIMC = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProCod.IsValid

	do 'loadProduto'
	do 'LoadConf'

EndEvent

Event &ProSetCod.Click

	do 'LoadConf'

EndEvent

Event &ProSetCod.IsValid

	do 'LoadConf'

EndEvent

Event &GrupHie.ClICk

	do 'loadGrupoproduto'
	do 'LoadConf'

EndEvent

Event &GrupHie.IsValid

	do 'loadGrupoproduto'
	do 'LoadConf'

EndEvent

Event Enter

	GravaIMC.Call(&EmpCod, &ProCod, &ProImcCusInd, &ProImcDesAdm, &ProImcDesFin, &ProImcDesVen, &ProImcMarLuc, &AtualizarIMC)
	msg('Dados de Markup Atualizados com sucesso!')

EndEvent

Event &ProImcCusInd.IsValid

	do 'TotalizaIMC'

EndEvent

Event &ProImcMarLuc.IsValid

	do 'TotalizaIMC'

EndEvent

Event &ProImcDesVen.IsValid

	do 'TotalizaIMC'

EndEvent

Event &ProImcDesFin.IsValid

	do 'TotalizaIMC'

EndEvent

Event &ProImcDesAdm.IsValid

	do 'TotalizaIMC'

EndEvent

Sub 'TotalizaIMC'

	&ProImcTotCusInd = &ProImcMarLuc + &ProImcDesVen + &ProImcDesFin + &ProImcDesAdm + &ProImcCusInd

EndSub

Sub 'loadGrupoproduto'

	&GrupCod = 0
	&AuxGrupHie = &GrupHie + '.'
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		Where GrupHie = &GrupHie or GrupHie like &AuxGrupHie
		&GrupCod = GrupCod
		Exit
	EndFor

EndSub

Sub 'LoadConf'

	&ProIMC = 0
	&ProImcCusInd = 0
	&ProImcDesAdm = 0
	&ProImcDesFin = 0
	&ProImcDesVen = 0
	&ProImcMarLuc = 0
	&ProImcTotCusInd = 0
	&SetTaxMo        = 0
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod When &ProCod <> 0
		Where ProSetCod = &ProSetCod when &ProSetCod <> 0
		Where GrupCod = &GrupCod when &GrupCod <> 0
		
		&ProIMC		 	 = ProIMC
		&ProImcCusInd	 = ProImcCusInd
		&ProImcDesAdm	 = ProImcDesAdm
		&ProImcDesFin	 = ProImcDesFin
		&ProImcDesVen	 = ProImcDesVen
		&ProImcMarLuc	 = ProImcMarLuc
		&SetTaxMo        = ProSetTaxMo 
		Exit
	EndFor
	
	do 'TotalizaIMC'

EndSub

Sub 'loadProduto'

	&ProNom = 'TODOS OS PRODUTOS'
	if &ProCod <> 0
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProNom = ProNom
		Exit
	When None
		&ProNom = 'PRODUTO NÃO ENCONTRADO'
	EndFor
	EndIF

EndSub


]]></Source>
