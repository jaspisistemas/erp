EndEvent

Sub "SetObjectQCartaoBandeira"

	// Change query or dataprovider in runtime
	UTChartColumnLine.ObjectName = "QCartaoBandeira"			// Or QueryViewer1.ObjectName = &CharacterVariable

EndSub

Sub "SetQueryViewerParametersQCartaoBandeira"

	&Parameters = New()
	// Numeric parameter
	&Parameter = New()
	&Parameter.Name = "EmpCod"
	&Parameter.Value = &EmpCod.ToString().Trim() 				// Or &Parameter.Value = &NumericVariable.ToString().Trim()
