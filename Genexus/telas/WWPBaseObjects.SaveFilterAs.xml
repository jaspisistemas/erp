        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &FilterName.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','WWP_FiltersName'), DVMessageType.error, &FilterName.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	&FilterName = &FilterName.Trim()
	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult
		&GridStateCollection.FromXml(LoadManageFiltersState(&UserKey))
		&IsNameUnique = True
		For &GridStateCollectionItem in &GridStateCollection
			If &GridStateCollectionItem.Title = &FilterName
				&IsNameUnique = False
			EndIf
		EndFor
		If &IsNameUnique
			&GridStateCollectionItem = new()
			&GridStateCollectionItem.Title = &FilterName
			&GridStateCollectionItem.GridStateXML = &Session.Get(&GridStateKey)
			&GridStateCollection.Add(&GridStateCollectionItem, 1)
			
			SaveManageFiltersState(&UserKey, &GridStateCollection.ToXml())
			Return
		Else
			Msg(DVMessageGetBasicNotificationMsg('', 'Name must be unique', DVMessageType.error, &FilterName.InternalName, DVMessageBoolean.True, ''))
		EndIf		
	EndIf

EndEvent


]]></Source>
