      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
		&EmpCod = &Context.EmpCod
		&FilCod = &Context.FilCod
		&PesCod = &Context.PesCod
		
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon075_ValidaNroDuplicata, &TCon075_ValidaNroDuplicata)
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon076_ExibeComissaoCobrador, &TCon076_ExibeComissaoCobrador)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 300

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&TotDupVlr += DupTmpCreVlrDup
//	&TotDupVlr = 0
	&CreDupNro = DupTmpCreDupNro		
	&CreFilPgt = DupTmpCreFilPgt
	&CreRecPag = DupTmpCreRecPag
	&CreDtaEms = DupTmpCreDtaEms
	&CreVlrDup = DupTmpCreVlrDup
	
	&CreCbrCod = DupTmpCreCbrCod
	
	&Semana = substr(cdow(DupTmpCreDtaVct), 1, 3)
	&CreVlrSdo = DupTmpCreVlrSdo
	&CreCliCod = DupTmpCreCliCod
	&CreVenCod = DupTmpCreVenCod
	&AuxEmpCod = DupTmpEmpCod
	&AuxPesCod = DupTmpPesCod
	&AuxFilCod = DupTmpFilCod
	&AuxCreCod = DupTmpCreCod
	&CreBloNro = DupTmpCreBloNro
	&CrePlanCod = DupTmpCrePlanCod
//	&TotDupVlr +=&CreVlrSdo
	&CreDupNro.Enabled = 1
	DupTmpCreDtaVct.Enabled = 1
	&CreVlrDup.Enabled = 1
	&CreCbrCod.Enabled = 1
	&CreDtaEms.Enabled = 1
	&CreBloNro.Enabled = 1
	&CrePlanCod.Enabled = 1
	If &TCon076_ExibeComissaoCobrador = 'S'
		&CrePerComCbr = DupTmpCrePerComCbr
		&CrePerComCbr.visible = True
	Else
		&CrePerComCbr.Visible = false
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&PROXIMO.FromImage(ActionCancel)
	&PROXIMO.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CreDupNro.IsValid

	Do 'GravaGrid'

EndEvent

Event &CreVlrDup.IsValid

	Do 'GravaGrid'

EndEvent

Event &CreCbrCod.IsValid

	Do 'GravaGrid'

EndEvent

Event &CrePlanCod.IsValid

	Do 'GravaGrid'

EndEvent

Event Enter

	&IsErro = false
	&AuxMsg = ''
	
	
	do 'subverifica'

	If &IsErro = False 
		GravaDuplicatas.Call(&Context.EmpCod,&Context.PesCod,&CreCobObs)
		wwduplicatas.Call()
	Else
		Msg(&AuxMsg)
	EndIf

EndEvent

Event DupTmpCreDtaVct.IsValid

	Do 'GravaGrid'
	&Semana = substr(cdow(DupTmpCreDtaVct), 1, 3)

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)

EndEvent

Sub 'Subverifica'

	If &TCon075_ValidaNroDuplicata <> 'S'//Aceita Repetido? S=SIM N=NAO
		For each Order DupTmpEmpCod,DupTmpFilCod,DupTmpPesCod
			Where DupTmpEmpCod = &Context.EmpCod
			Where DupTmpFilCod = &Context.FilCod
			Where DupTmpPesCod = &Context.PesCod
			ValidaNumeroDuplicataRepetido2.Call(DupTmpEmpCod,DupTmpFilCod,0,DupTmpCreCliCod,DupTmpCreRecPag,DupTmpCreDupNro,&IsErro,&AuxMsg)
			
		EndFor
	EndIf

EndSub

Sub 'GravaGrid'

	AtualizaDuplicatasTemporarias.Call(&AuxEmpCod,&AuxFilCod,&CreFilPgt,&AuxCreCod,&AuxPesCod,&CreDupNro,DupTmpCreDtaVct,&CreVlrDup,&CreCbrCod,&CreDtaEms,&CreBloNro,&CrePlanCod,&CrePerComCbr, '')
	
	do 'SubTotaliza'

EndSub

Sub 'SubTotaliza'

	&TotDupVlr = 0
	For each Order DupTmpEmpCod,DupTmpFilCod,DupTmpPesCod
		Where DupTmpEmpCod = &Context.EmpCod
		Where DupTmpFilCod = &Context.FilCod
		Where DupTmpPesCod = &Context.PesCod
		&TotDupVlr += DupTmpCreVlrSdo
	EndFor

EndSub


