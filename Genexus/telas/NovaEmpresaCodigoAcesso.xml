Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&EmpCodSec = &WizardData.CodigoAcesso.EmpCodSec
	&EmpRaz = &WizardData.CodigoAcesso.EmpRaz
	&FilCpj = &WizardData.CodigoAcesso.FilCpj

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.CodigoAcesso.EmpCodSec = &EmpCodSec
	&WizardData.CodigoAcesso.EmpRaz = &EmpRaz
	&WizardData.CodigoAcesso.FilCpj = &FilCpj
	&WizardData.NovoUsuario.IsFiscal = &EmptyWizardData.NovoUsuario.IsFiscal
	&WizardData.NovoUsuario.FilVctCer = &EmptyWizardData.NovoUsuario.FilVctCer
	&WizardData.NovoUsuario.FilCtaEml = &EmptyWizardData.NovoUsuario.FilCtaEml
	&WizardData.NovoUsuario.FilIdQrCode = &EmptyWizardData.NovoUsuario.FilIdQrCode
	&WizardData.NovoUsuario.FilSenQrCode = &EmptyWizardData.NovoUsuario.FilSenQrCode
	&WizardData.NovoUsuario.PesEml = &EmptyWizardData.NovoUsuario.PesEml
	&WizardData.NovoUsuario.UsuarioAcesso = &EmptyWizardData.NovoUsuario.UsuarioAcesso
	&WizardData.NovoUsuario.GAMPasswordDB = &EmptyWizardData.NovoUsuario.GAMPasswordDB
	&WizardData.NovoUsuario.ConfirmaPass = &EmptyWizardData.NovoUsuario.ConfirmaPass
	&WizardData.NovoUsuario.EmpCodSec = &EmptyWizardData.NovoUsuario.EmpCodSec
	&WizardData.NovoUsuario.EmpRaz = &EmptyWizardData.NovoUsuario.EmpRaz
	&WizardData.NovoUsuario.FilCpj = &EmptyWizardData.NovoUsuario.FilCpj
	&WizardData.NovoUsuario.PesRaz = &EmptyWizardData.NovoUsuario.PesRaz
	&WizardData.NovoUsuario.PesCpf = &EmptyWizardData.NovoUsuario.PesCpf
	&WizardData.NovoUsuario.PesFonNum = &EmptyWizardData.NovoUsuario.PesFonNum
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'getWebservice'

	&IsOk = false
	
	HostWebServiceJaspiADM.Call(0, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	&Location = GetLocation('ppJASPI_Empresa') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost //servidor 
	&Location.Port = &EmpWebPor //porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	&Location.Secure = false //false 
	&Location.CancelOnError = 2 //tratar exceção do WS 	
	
	&ppJASPI_EmpresasdtEmpresa = &ppJASPI_Empresa.Execute(&EmpCodSec, false)
	
	If GetSOAPErr()= 0 
		If &ppJASPI_EmpresasdtEmpresa.StsErro = 1
			&IsOk = true
			&EmpRaz = &ppJASPI_EmpresasdtEmpresa.CliRaz
			&FilCpj = &ppJASPI_EmpresasdtEmpresa.CliCnpj
		Else
			msg(&ppJASPI_EmpresasdtEmpresa.StsMensagem)
		EndIF
	Else 
		&Msg = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&Msg += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&Msg) 
	EndIf

EndSub


