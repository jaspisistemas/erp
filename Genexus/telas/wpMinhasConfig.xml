      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	PadraoUsuario.call('L', '#CONFIG_USUARIO#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	if Substr(&PadObs, 1, 1) = '2'
		&SalvarFiltros = false
	Else
		&SalvarFiltros = true
	EndIF
//	if Substr(&PadObs, 2, 1) = '2'
//		&MenuLateral = false
//	Else
//		&MenuLateral = true
//	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &SalvarFiltros = true
		&PadObs = '1'
	Else
		&PadObs = '2'
	EndIF
//	if &MenuLateral = true
//		&PadObs += '1'
//	Else
//		&PadObs += '2'
//	EndIF

	PadraoUsuario.call('G', '#CONFIG_USUARIO#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	msg('Configurações Salvas!')

EndEvent


]]></Source>
