      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridLacres.Rows = Page.Rows
	&GridLacresCurrentPage = 1
	&GridLacresCurrentPage.Visible = False
	&GridLacresPageCount = -1
	GridLacresPaginationBar.RowsPerPageSelectedValue = GridLacres.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If &ParCteInfUndTraCarTip <> 0 
		Do 'GetCarga'
	EndIf

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridLacresPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SdtCte.FromXml(&webSession.get('CTE'))
	If &sdtCte.Tela = 'WPDocTraCarAddLac'
		&sdtEmpCod = &sdtCte.EmpCod
		&sdtFilCod = &sdtCte.FilCod
		&sdtCteCod = &sdtCte.CteCod
		&sdtCteDocCod = &sdtCte.CteDocCod 
		&sdtCteDocTip = &sdtCte.CteDocTip
		&sdtCteInfUndTraTip = &SdtCte.CteInfUndTraTip 
		&sdtCteInfUndTraCarTip = &sdtCte.CteInfUndTraCarTip
		Do 'GetCargaReturn'
	EndIf

EndEvent

Event GridLacres.Load

&Udelete.JSEvent( "onclick", "confirm ( 'Tem certeza que deseja excluir este lacre?')")
	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip,CteInfUndTraCarTip
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		Where CteInfUndTraTip = &CteInfUndTraTip 
		Where CteInfUndTraCarTip = &ParCteInfUndTraCarTip
		&CteUniTraCarLac = CteUniTraCarLac

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Udelete.FromImage(ActionDelete)
	&Udelete.TooltipText = "Deletar Lacre"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load 
	EndFor

EndEvent

Event GridLacresPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridLacresPaginationBar.SelectedPage = !'Previous'
			&GridLacresCurrentPage -= 1
			GridLacres.PreviousPage()
		Case GridLacresPaginationBar.SelectedPage = !'Next'
			&GridLacresCurrentPage += 1
			GridLacres.NextPage()
		Otherwise
			&PageToGo.FromString(GridLacresPaginationBar.SelectedPage)
			&GridLacresCurrentPage = &PageToGo
			GridLacres.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridLacresPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridLacres.Rows = GridLacresPaginationBar.RowsPerPageSelectedValue
	&GridLacresCurrentPage = 1
	GridLacres.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	&sdtCte.EmpCod = &EmpCod
	&sdtCte.FilCod = &FilCod
	&sdtCte.CteCod = &CteCod
	&sdtCte.CteDocCod = &CteDocCod
	&sdtCte.CteDocTip = &CteDocTip
	&SdtCte.CteInfUndTraTip = &CteInfUndTraTip
	&sdtCte.Tela = 'WPDocTraAddCar'
	&websession.Set('CTE',&SdtCte.ToXml())
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUInsertLacres'

	If not &CteInfUndTraCarTip.IsEmpty()
		GravaCarga.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndTraTip,&CteInfUndTraCarTip,&CteInfUndTraCarIde,&CteInfUndTraCarQtd)
		WPDocTraCarAddLac.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndTraTip,&CteInfUndTraCarTip,'0')
	Else
		MSG('ATENÇÃO! Tipo do transporte não pode ser vazio.Favor Informe.')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If not &CteInfUndTraCarTip.IsEmpty()
		GravaCarga.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndTraTip,&CteInfUndTraCarTip,&CteInfUndTraCarIde,&CteInfUndTraCarQtd)
	Else
		MSG('ATENÇÃO! Tipo da carga não pode ser vazio.Favor Informe.')
	EndIf

EndEvent

Event &Udelete.Click

	DeletaCteDocTransporteCargaLacre.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndTraTip,&CteInfUndTraCarTip,&CteUniTraCarLac)
	Refresh Keep

EndEvent

Sub 'GetCarga'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		Where CteInfUndTraTip = &CteInfUndTraTip
		Where CteInfUndTraCarTip = &ParCteInfUndTraCarTip
		&CteInfUndTraCarTip = CteInfUndTraCarTip
		&CteInfUndTraCarIde = CteInfUndTraCarIde
		&CteInfUndTraCarQtd = CteInfUndTraCarQtd
		Exit		
	EndFor

EndSub

Sub 'GetCargaReturn'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip
		Where EmpCod = &sdtEmpCod
		Where FilCod = &sdtFilCod
		Where CteCod = &sdtCteCod
		Where CteDocCod = &sdtCteDocCod
		Where CteInfUndTraTip = &sdtCteInfUndTraTip
		Where CteInfUndTraCarTip = &sdtCteInfUndTraCarTip
		&CteInfUndTraCarTip = CteInfUndTraCarTip
		&CteInfUndTraCarIde = CteInfUndTraCarIde
		&CteInfUndTraCarQtd = CteInfUndTraCarQtd
		Exit		
	EndFor

EndSub


]]></Source>
