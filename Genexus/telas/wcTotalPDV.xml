Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbfic.Visible = (&PedFicCod <> 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	&TotalItens = TotalItensPDV.Udp(&EmpCod, &FilCod, &PedCod)
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedVlrLiq = PedVlrLiq
		&PedFicCod = PedFicCod
		Exit
	EndFor
	For each Order EmpCod,FicCod
		Where EmpCod = &EmpCod
		Where FicCod = &PedFicCod
		&FicBar = FicBar
		EXIT
	EndFor

	Do 'AttributesSecurityCode'

EndEvent


