      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'SelecionarArquivo'
	&WizardStep.Title = 'Selecione XLSX'
	&WizardStep.Description = 'Selecione XLSX'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Produtos'
	&WizardStep.Title = 'Produtos'
	&WizardStep.Description = 'Produtos'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'GravarPedido'
	&WizardStep.Title = 'Gravar Pedido'
	&WizardStep.Description = 'Gravar Pedido'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'SelecionarArquivo'
		&WebSession.Remove(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim())
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	&SessionGuidAux = iif(&SessionGuid.IsEmpty(), GUID.NewGuid(), &SessionGuid)
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsUnderlineWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim()))
	if &WizardData.SelecionarArquivo.PedCod.IsEmpty()
		do 'Voltar'
	EndIf

EndEvent

Event 'DoDoVoltarPDV'

	do 'Voltar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'SelecionarArquivo'
			WizardStepWC.Object = wpImportarCompraXLSXSelecionarArquivo.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'Produtos'
			WizardStepWC.Object = wpImportarCompraXLSXProdutos.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'GravarPedido'
			WizardStepWC.Object = wpImportarCompraXLSXGravarPedido.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Voltar'

	Do Case
		CAse &WizardData.SelecionarArquivo.DeOndeVem = 'WPPEDIDOCOMPRAITEM'
			wwPedidoCompra.Link()
		Otherwise
			Dashboard.Link()
	EndCase

EndSub


]]></Source>
