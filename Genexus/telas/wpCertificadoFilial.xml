      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&FilRaz.ForeColor = RGB(255,0,0)
	retornaAutorizacao.Call('WWFILIAL', Status_SimNao.Sim, 2, &AutNiv)
	txtAviso.Caption = ' '
	loadwwpContext.Call(&WwpContext)
	retornaConfiguracoesPastas.Call(&WwpContext.EmpCod, &WwpContext.FilCod, &SdtConfiguracoesPasta)
	&FilCertNovo.SetFocus()
	do 'loadCertificadoDIgital'
	&FilCerPswNovo = &FilCerPsw

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbDataHo.Height = 190
	&Mensagem.Visible = False
	&FilCert.Visible = False
	&FilCerNomOri.Visible = False
	&FilCerExt.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDownloadArquivo'

	link(&linkDownload)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEmpresaNova'

	prcAtualizaDadosUninfe.Call(&EmpCod, &FilCod, true)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&FilCpjVarchar = retornaSoNumeros.Udp(&FilCpj)
	if &FilCerA1A3 = 'A3'
		&FilCertNovo.SetEmpty()
	Endif
	
	&dataHora = ServerNow()
	&serverNowVarchar = toformattedString(&dataHora)
	RetornaSoNumeros.Call(&serverNowVarchar , &serverNowVarchar )
	
	&FilCerNomNovo = trim(&FilCpjVarchar) +'-'+ trim(gxGetMLi(&FilRaz, 1, 25))+'-'+trim(&serverNowVarchar)+'.pfx'
	&CaminhoCertificadoNovo = format('%1%2', &SdtConfiguracoesPasta.PastaDiretorioCertificado , trim(&FilCerNomNovo))
	
	prcAtualizaCertificadoDigital.Call(&EmpCod, &FilCod, &LongVarchar, &FilCert, &FilCerNom, &FilCerPsw, &FilCerDtaHor, &FilCerA1A3, &FilIdQrCode, &FilSenQrCode, &FilVctCer)
	do 'loadCertificadoDigital'
	
	&LongVarchar = &FilCertNovo.ToBase64String()
	
	if not &LongVarchar.IsEmpty() and &LongVarchar.Length() > 100
		
		&Directory.Source = &sdtConfiguracoesPasta.PastaDiretorioCertificado
		If not &Directory.Exists()
			&Directory.Create()
		EndIF
		
		&File.Source = &CaminhoCertificadoNovo
		If &File.Exists()
			&File.Delete()
		EndIf			
		&File.Close()
		
		&File.Source = &CaminhoCertificadoNovo
		&File.Create()
		&File.FromBase64String(&LongVarchar) 
		&File.Close()
		
		&PrivateKey.LoadPKCS12(&CaminhoCertificadoNovo, '', &FilCerPswNovo)
		&Certificate.LoadPKCS12(&CaminhoCertificadoNovo, '', &FilCerPswNovo)
		&Mensagem = &Certificate.Subject
		Do Case
			case (not &Mensagem like '%'+trim(&FilCpjVarchar)) and (not &Mensagem like '%'+Substr(trim(&FilCpjVarchar), 1, 8))
				txtAviso.Caption = "ERRO: Não Localizado CNPJ da Filial no Certificado!"
				txtAviso.ForeColor = RGB(200,0,0)
				
				&File.Source = &CaminhoCertificadoNovo
				If &File.Exists()
					&File.Delete()
				EndIf			
				&File.Close()
				
			Case &FilCerPswNovo = ''
				txtAviso.Caption = "ERRO: Senha não informada!"
				txtAviso.ForeColor = RGB(200,0,0)
				
				&File.Source = &CaminhoCertificadoNovo
				If &File.Exists()
					&File.Delete()
				EndIf			
				&File.Close()
				
			CAse &Certificate.HasError()
				txtAviso.Caption = "ERRO: private key. Code: " + &Certificate.GetErrorCode() + " Description: " + &Certificate.GetErrorDescription()
				txtAviso.ForeColor = RGB(200,0,0)
				
				&File.Source = &CaminhoCertificadoNovo
				If &File.Exists()
					&File.Delete()
				EndIf			
				&File.Close()
				
			CAse &PrivateKey.HasError()
				txtAviso.Caption = "ERRO: public key. Code: " + &Certificate.GetErrorCode() + " Description: " + &Certificate.GetErrorDescription()
				txtAviso.ForeColor = RGB(200,0,0)
				
				&File.Source = &CaminhoCertificadoNovo
				If &File.Exists()
					&File.Delete()
				EndIf			
				&File.Close()
			Otherwise
				&DateTime =  &Certificate.NotAfter
				&FilCerDtaHor = &DateTime
				&Varchar = &DateTime.ToFormattedString()
				&FilVctCer.FromString(Substr(&Varchar, 1, 10))
				&FilCerNom = &FilCerNomNovo
				
				prcAtualizaCertificadoDigital.Call(&EmpCod, &FilCod, &LongVarchar, &FilCertNovo, &FilCerNomNovo, &FilCerPswNovo, &FilCerDtaHor, &FilCerA1A3, &FilIdQrCode, &FilSenQrCode, &FilVctCer)
				
				txtAviso.Caption = "Dados Salvos com sucesso, Certificado Atualizado!"
				txtAviso.ForeColor = RGB(0,130,0)
				
				&File.Source = &CaminhoCertificado
				If &File.Exists()
					&File.Delete()
				EndIf			
				&File.Close()
		EndCAse
	Else
		VerificaCertificadoFilial.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta.PastaDiretorioCertificado, &CaminhoCertificadoVarChar, &FilCerPswNovo)
		txtAviso.Caption = "Dados salvos com sucesso!"
		txtAviso.ForeColor = RGB(0,130,0)
	Endif
	
	prcAtualizaDadosUninfe.Call(&EmpCod, &FilCod, false)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRemoverCertificado'

	prcAtualizaCertificadoVazio.Call(&EmpCod, &FilCod)
	&FilCerPsw.SetEmpty()
	&FilCerPswNovo.SetEmpty()
	&FilCertNovo.SetEmpty()
	
	&File.Source = &CaminhoCertificado
	If &File.Exists()
		&File.Delete()
	EndIf			
	&File.Close()
	
	do 'loadCertificadoDIgital'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FilCerA1A3.IsValid

	do 'A1A3'

EndEvent

Sub 'A1A3'

	if &FilCerA1A3 = 'A1'
		tbDataHoraA1.Visible = 1
		tbDataHoraA1a.Visible = 1
		tbDataHoraA3.Visible = 0
	Else
		tbDataHoraA1.Visible = 0
		tbDataHoraA1a.Visible = 0
		tbDataHoraA3.Visible = 1
	Endif
	
	if &FilCerDtaHor.IsEmpty()
		tbDataHoraA3.Visible = 1
	Endif

EndSub

Sub 'loadCertificadoDigital'

	For each Order EmpCod, FilCod
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		
		&FilCpj = FilCpj
		&FilRaz = FilRaz
		&AuxFilCert = FilCert
		
		&FilCerNom = FilCerNom
		&FilCerPsw = FilCerPsw
		
		&FilCerDtaHor = FilCerDtaHor
		
		if not FilCerDtaHor.IsEmpty() and FilCerDtaHor < serverNow()
			&FilCerDtaHor.ForeColor = rgb(200,0,0)
		Endif
		
		&FilCerA1A3 = FilCerA1A3
		&FilIdQrCode = FilIdQrCode
		&FilSenQrCode = FilSenQrCode
		&FilVctCer = FilVctCer
		
		if &FilCerNom.IsEmpty()
			RetornaSoNumeros.Call(FilCpj, &FilCpjVarchar)
			&FilCerNom = trim(&FilCpjVarchar) +'-'+ trim(FilRaz)+'.pfx'
		Endif
		
		RetornaSoNumeros.Call(FilCpj, &FilCpjVarchar)
		
		&CaminhoCertificado = format('%1%2', &SdtConfiguracoesPasta.PastaDiretorioCertificado , trim(&FilCerNom))		
		
		&linkDownload = &CaminhoCertificado
		&linkDownload = &linkDownload.Replace(EmpDirFis, EmpDirVir)
		
	
		&FilCerNomOri = FilCerNomOri
		&FilCerExt = FilCerExt	
		Exit
	EndFor

	if &FilCerA1A3.IsEmpty()
		&FilCerA1A3 = 'A1'
	Endif

	do 'A1A3'

EndSub


]]></Source>
