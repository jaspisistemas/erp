      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LayoutMainTable.Class = ThemeClass:MainContainerNoBackground
	if &ParmUsuario.IsEmpty()
		&retCookie = GetCookie("JJAESAPNI")
		if not &retCookie.IsEmpty()
			&xUsuario = trim(Substr(&retCookie, 1, 50))
		endif
	else
		&xUsuario = &ParmUsuario
	EndIf
	if not &xUsuario.IsEmpty()
		&xSenhor.SetFocus()
	EndIf
	Form.HeaderRawHTML = '<link rel="shortcut icon" href="Resources/jaspi.png" type="image/x-icon">'
	Form.HeaderRawHTML += '<link rel="icon" href="Resources/jaspi.png" type="image/x-icon">'
	
	//&LogOnTo.Visible = false
	
//	TxtSite.LinkTarget = '_blank' - fica como link
//	TxtSite.Link = link('http://www.jaspi.com.br/')
	Site.LinkTarget = '_blank'
	Site.Link = link('http://www.jaspi.com.br/')
	Facebook.LinkTarget = '_blank'
	Facebook.Link = link('https://www.facebook.com/JaspiSistemas/')
	Instagram.LinkTarget = '_blank'
	Instagram.Link = Link('https://www.instagram.com/jaspisistemas/')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ttb3.Height = 60
	tbb1.Height = 30

	Do 'AttributesSecurityCode'
	&URL.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//&RememberMe.Visible = 0
	//ForgotPassword.Visible = 0
	
	&KeepMeLoggedIn = true
	&RememberMe = false
	
	&xSenhor = &ParmSenha
	
	Compilacao.Call(false, &Compilacao, &IsExecutaUpdate, &DisEmpVer, &DisEmpCmp)
	If &IsExecutaUpdate = true
		AplicaAtualizacao.Link()
	EndIf

	CurrentRepository.Caption = format('versão: %1 c: %2',&DisEmpVer, trim(str(&DisEmpCmp)))

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (1=1)
		&RememberMe.Visible = False
		RememberMe_Cell.Class = !'Invisible'
	Else
		&RememberMe.Visible = True
		RememberMe_Cell.Class = !'col-xs-12 DataContentCellLogin'
	EndIf
	If Not (1=1)
		&KeepMeLoggedIn.Visible = False
		KeepMeLoggedIn_Cell.Class = !'Invisible'
	Else
		&KeepMeLoggedIn.Visible = True
		KeepMeLoggedIn_Cell.Class = !'col-xs-12 DataContentCellLogin'
	EndIf
	If &KeepMeLoggedIn.Visible = False
		ttb3.Visible = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &xUsuario.IsValid

	if not &xSenhor.IsEmpty() and not &xUsuario.IsEmpty()
		do 'loginSistemaERP'
	EndIf

EndEvent

Event &xSenhor.IsValid

	if not &xSenhor.IsEmpty() and not &xUsuario.IsEmpty()
		do 'loginSistemaERP'
	EndIf

EndEvent

Event Refresh

	&SessionValid = GAMSession.IsValid(&Session, &Errors)
	
	If &SessionValid and not &Session.IsAnonymous
		&URL = GAMRepository.GetLastErrorsURL()
		&UserNick = &GAMUser.GetName()
		
		If upper(&UserNick) = 'SUPORTE.JASPI'
			&TipoPerfil = 3
		Else
			&TipoPerfil = RetTipNick.Udp(&GAMUser.GetExternalId()) // 1 Usuario 2 Contador
		Endif
		
		Do Case 
			Case &TipoPerfil = 3
				&QtdEmpCod = RetQtdEmp.udp()
				If &QtdEmpCod > 1
					WWAdmin.Link()
				Else
					prcLogaPrimeiraEmpresa.call(&IsOkLicenca,&IsOkAcesso)
					
					if &IsOkLicenca = true and &IsOkAcesso = True
						do 'home'
					EndIF
				EndIF
			
			Case &TipoPerfil = 2
				WWContador.Link(&GAMUser.GetExternalId())
				
			Case &TipoPerfil = 1
				&URL = GAMRepository.GetLastErrorsURL()
				
				If Not &GAMUser.GetExternalId().IsEmpty()
					ProcLoadInicio.Call(0,0, &IsOkLicenca,&IsOkAcesso)
				EndIF
				if &IsOkLicenca = true and &IsOkAcesso = True
					do 'home'
				EndIF
		EndCase
	EndIF

EndEvent

Event EsqueceuSenha.Click

	AlterarSenhaPasso1.Link('', &xUsuario)

EndEvent

Sub 'loginSistemaERP'

	&UserName = &xUsuario
	if upper(&UserName) = 'ADMJASPI' //se for este usuario ele seta a senha vazia pra nao acessar com admjaspi
		&UserPassword = ''
	Else		
		&UserPassword = &xSenhor
	EndIF
	
	&xSenhor.SetEmpty()
	
	// Set Remember User type //////////////////////////////////
	If &KeepMeLoggedIn
		&AdditionalParameter.RememberUserType = iif(&KeepMeLoggedIn, GAMRememberUserTypes.Authentication, GAMRememberUserTypes.None)
	Else
		If &RememberMe 
			&AdditionalParameter.RememberUserType = iif(&RememberMe, GAMRememberUserTypes.Login, GAMRememberUserTypes.None)
		Else
			&AdditionalParameter.RememberUserType = GAMRememberUserTypes.None
		Endif
	Endif
	
	&AdditionalParameter.AuthenticationTypeName = &LogOnTo
	// Login User //////////////////////////////////////////////
	
	
	// CASO MUDE, OU IMPLEMENTE ALGO AQUI, TERÁ DE SER MUDADO NO AlterarSenhaPasso2 //////////////////////////////////////////////////////
	&LoginOK = GAMRepository.Login(&UserName, &UserPassword, &AdditionalParameter, &Errors )
	
	If &LoginOK = true
		&gravar = padL(&xUsuario, 50, ' ')
		&validade = &Today + 30
		&ret = SetCookie("JJAESAPNI",&gravar,,&validade)		
		
		//**Uncomment the following lines if you use the property Web User Experience = Smooth
		
		&UserNick = &GAMUser.GetName()
		
		
		If upper(&UserNick) = 'SUPORTE.JASPI'
			&TipoPerfil = 3
		Else
			&TipoPerfil = RetTipNick.Udp(&GAMUser.GetExternalId()) // 1 Usuario 2 Contador
		Endif
		
		Do Case 
			Case &TipoPerfil = 3
				&QtdEmpCod = RetQtdEmp.udp()
				If &QtdEmpCod > 1
					WWAdmin.Link()
				Else
					prcLogaPrimeiraEmpresa.call(&IsOkLicenca,&IsOkAcesso)
					
					if &IsOkLicenca = true and &IsOkAcesso = True
						do 'home'
					EndIF
				EndIF
				
			Case &TipoPerfil = 2
				WWContador.Link(&GAMUser.GetExternalId())
				
			Case &TipoPerfil = 1
				&URL = GAMRepository.GetLastErrorsURL()
				
				If Not &GAMUser.GetExternalId().IsEmpty()
					ProcLoadInicio.Call(0,0, &IsOkLicenca,&IsOkAcesso)
				EndIF
				if &IsOkLicenca = true and &IsOkAcesso = True
					do 'home'
				EndIF
		EndCase
		////////////////////////////////////////////////////////////	
	Else		
		If &Errors.Count > 0 
			Do Case
				Case (&Errors.Item(1).Code = GAMErrorMessages.UserPasswordExpired   OR  &Errors.Item(1).Code = GAMErrorMessages.UserPasswordMustBeChanged)
					//Webpanel to Change Password
					wpRedefinirSenha.Link(&LogOnTo, &UserName, &UserRememberMe )
					//Case &Errors.Item(1).Code = GAMErrorMessages.UserMissingRequiredData
					//Webpanel to Complete User data
					//GAMUpdateRegisterUser()
				Otherwise
					Do 'DisplayMessages'
			EndCase
		EndIf
	Endif
	////////////////////////////////////////////////////////////

EndSub

Sub 'Home'

	If &URL.IsEmpty()
		loadWWPContext.Call(&WwpContext)
		RetQtdFilialAcesso.Call(&WwpContext.EmpCod, &WwpContext.PesCod, 2, &QuantidadeFilial)
		
		if &QuantidadeFilial > 1 and upper(&UserNick) <> 'SUPORTE.JASPI'
			wwSelecionaFilial.Link()
		Else
			Dashboard.Link()
		Endif
		
	Else
		loadWWPContext.Call(&WwpContext)
		RetQtdFilialAcesso.Call(&WwpContext.EmpCod, &WwpContext.PesCod, 2, &QuantidadeFilial)
					
		if &QuantidadeFilial > 1 and upper(&UserNick) <> 'SUPORTE.JASPI'
			wwSelecionaFilial.Link()
		Else
			Link(&URL)
		Endif
	Endif

EndSub

Sub 'DisplayMessages'

	For &Error in &Errors
		If &Error.Code <> GAMErrorMessages.SessionExpired			
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		Endif
	EndFor	
	&xUsuario.SetFocus()

EndSub


