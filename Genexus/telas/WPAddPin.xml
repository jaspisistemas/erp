      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCarga.Rows = Page.Rows
	&GridCargaCurrentPage = 1
	&GridCargaCurrentPage.Visible = False
	&GridCargaPageCount = -1
	GridTransporte.Rows = Page.Rows
	&GridTransporteCurrentPage = 1
	&GridTransporteCurrentPage.Visible = False
	&GridTransportePageCount = -1
	GridCargaPaginationBar.RowsPerPageSelectedValue = GridCarga.Rows
	GridTransportePaginationBar.RowsPerPageSelectedValue = GridTransporte.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'GetPin'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridCargaPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	//The variable '&GridTransportePageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SdtCte.FromXml(&webSession.get('CTE'))
	If &sdtCte.Tela = 'WPDocAddTra'
		&sdtEmpCod = &sdtCte.EmpCod
		&sdtFilCod = &sdtCte.FilCod
		&sdtCteCod = &sdtCte.CteCod
		&sdtCteDocCod = &sdtCte.CteDocCod 
		&sdtCteDocTip = &sdtCte.CteDocTip

		Do 'GetPinReturn'
	EndIf

EndEvent

Event GridCarga.Load

	&UDeleteCarga.JSEvent( "onclick", "confirm ( 'Tem certeza que deseja excluir esta carga?')")
	For Each Order EmpCod,FilCod,CteCod,CteDocCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		&CteInfUndCarTip = CteInfUndCarTip
		&CteInfUndCarIde = CteInfUndCarIde
		&CteInfUndCarQtd = CteInfUndCarQtd

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UDeleteCarga.FromImage(ActionDelete)
	&UDeleteCarga.TooltipText = "Delete item"
	
	&UpdateCarga.FromImage(ActionUpdate)
	&UpdateCarga.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load
	EndFor

EndEvent

Event GridTransporte.Load

	&UDeleteTransporte.JSEvent( "onclick", "confirm ( 'Tem certeza que deseja excluir este transporte?')")
	For Each Order EmpCod,FilCod,CteCod,CteDocCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		&CteInfUndTraTip = CteInfUndTraTip
		&CteInfUndTraIde = CteInfUndTraIde
		&CteInfUndTraQtd = CteInfUndTraQtd

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UDeleteTransporte.FromImage(ActionDelete)
	&UDeleteTransporte.TooltipText = "Delete item"
	
	&UUpdateTransporte.FromImage(ActionUpdate)
	&UUpdateTransporte.TooltipText = "Editar Transporte"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	load
	EndFor

EndEvent

Event GridCargaPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridCargaPaginationBar.SelectedPage = !'Previous'
			&GridCargaCurrentPage -= 1
			GridCarga.PreviousPage()
		Case GridCargaPaginationBar.SelectedPage = !'Next'
			&GridCargaCurrentPage += 1
			GridCarga.NextPage()
		Otherwise
			&PageToGo.FromString(GridCargaPaginationBar.SelectedPage)
			&GridCargaCurrentPage = &PageToGo
			GridCarga.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridCargaPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCarga.Rows = GridCargaPaginationBar.RowsPerPageSelectedValue
	&GridCargaCurrentPage = 1
	GridCarga.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridTransportePaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridTransportePaginationBar.SelectedPage = !'Previous'
			&GridTransporteCurrentPage -= 1
			GridTransporte.PreviousPage()
		Case GridTransportePaginationBar.SelectedPage = !'Next'
			&GridTransporteCurrentPage += 1
			GridTransporte.NextPage()
		Otherwise
			&PageToGo.FromString(GridTransportePaginationBar.SelectedPage)
			&GridTransporteCurrentPage = &PageToGo
			GridTransporte.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridTransportePaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridTransporte.Rows = GridTransportePaginationBar.RowsPerPageSelectedValue
	&GridTransporteCurrentPage = 1
	GridTransporte.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	&sdtCte.EmpCod = &EmpCod
	&sdtCte.FilCod = &FilCod
	&sdtCte.CteCod = &CteCod
	&sdtCte.CteDocCod = &CteDocCod
	&sdtCte.CteDocTip = &CteDocTip
	&sdtCte.Tela = 'WPAddPin'
	&websession.Set('CTE',&SdtCte.ToXml())
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUInsertCarga'

	GravaCtePin.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocPinSuf)
	WPDocAddCar.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndCarTip)
	GridCarga.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUInsertTransporte'

	GravaCtePin.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocPinSuf)
	WPDocAddTra.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndTraTip)
	GridTransporte.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &UDeleteTransporte.Click

	DeletaCteDocTransporte.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndTraTip)
	Refresh Keep

EndEvent

Event &UUpdateTransporte.Click

	WPDocAddTra.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndTraTip)
	GridTransporte.Refresh()

EndEvent

Event Enter

	GravaCtePin.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocPinSuf)

EndEvent

Event &UDeleteCarga.Click

	DeletaCteDocCarga.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndCarTip)
	Refresh Keep

EndEvent

Event &UpdateCarga.Click

	WPDocAddCar.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndCarTip)
	GridTransporte.Refresh()

EndEvent

Sub 'GetPin'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		&CteDocPinSuf = CteDocPinSuf
		
		Exit
	EndFor

EndSub

Sub 'GetPinReturn'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod
		Where EmpCod = &sdtEmpCod
		Where FilCod = &sdtFilCod
		Where CteCod = &sdtCteCod
		Where CteDocCod = &sdtCteDocCod
		&CteDocPinSuf = CteDocPinSuf
		
		Exit
	EndFor

EndSub


]]></Source>
