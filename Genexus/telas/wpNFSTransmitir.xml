      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtMsg.Caption = ''
	pro.Visible = 1
	funcaoAutorizada.Visible = 0
	Sucesso.Visible = 0
	Falha.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&wwpContext)
	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&EmpCod = &WizardData.Capa.EmpCod
	&NfsCod = &WizardData.Capa.NfsCod
	&SolCod = &WizardData.Totais.SolCod
	
	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod		
		Where NfsCod = &NfsCod
		
		BtnItens.Visible = (NfsTipNF <> 'S')
		
		if NfsSts = Status_NFe.Digitando
			&Random = random()* 1000000000
			&ProgressId = 'autoNFe' + trim(Str(&wwpContext.EmpCod)) + trim(Str(&wwpContext.FilCod)) + trim(Str(&wwpContext.PesCod)) + trim(str(&Random))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			RecepcaoNFe.Submit('RecepcaoNFe', &ProgressId, &EmpCod, &wwpContext.FilCod, &NfsCod, &SolCod)
//			txtMsg.Caption = ''
		Else
			wwNotasservico.Link()
		EndIF
	
		Exit
		
	When none
		wwNotasservico.Link()
	EndFor

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovaNFSe'

	&SessionGuidAux = GUID.NewGuid()
	
	&NEwWebSessionKey = 'wpNFS_Data' + &SessionGuidAux.ToString().Trim()
	&WizardData = new()	
	&WebSession.Set(&NEwWebSessionKey, &WizardData.ToJson())
	
	wpNFs.Link('Capa', 'Capa', true, &SessionGuidAux)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoReimprimir'

 8

	do 'imprimenota'
	
	RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCapa'

	wpNFS(!'Transmitir', !'Capa', false, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDados'

	wpNFS(!'Transmitir', !'DadosNFSE', false, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoItens'

	wpNFS(!'Transmitir', !'Itens', false, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoTotais'

	wpNFS(!'Transmitir', !'Totais', false, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoReenviaNFSe'

	prcValidacoesNFSe.call(&EmpCod, &NfsCod, &IsErro, &erroMensagem)
	
	if &IsErro = false //sem erro
		GeraXmlNFSe.Call(&EmpCod, &NfsFilCod, &NfsCod, 'S', &wwpContext.PesCod, &SolCod)
		&SessionGuidAux = GUID.NewGuid()
			
		&NewWebSessionKey = 'wpNFS_Data' + &SessionGuidAux.ToString().Trim()
		&WizardData = new()
		&WizardData.Capa.EmpCod = &EmpCod
		&WizardData.Capa.NfsCod = &NfsCod
		&WizardData.Totais.SolCod = &SolCod
		&WebSession.Set(&NewWebSessionKey, &WizardData.ToJson())
		
		wpnfs.Link('Capa', 'Transmitir', true, &SessionGuidAux)
	Else
		msg(&ErroMensagem)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConsultarNFSe'

	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod		
		Where NfsCod = &NfsCod

		GravaConsultaSEFAZ_NFSE.Call('WWNOTASSERVICO', EmpCod, NfsFilCod, NfsCod, &wwpContext.PesCod, &SolCod)
		
		Exit
	EndFor

	wpConsultaNFSe.Link(&EmpCod, &NfsCod, &SolCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'FinishWizard'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	pro.Visible = 0
	
	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		txtMsg.ForeColor = RGB(210,130,0)
		txtMsg.Caption = ProgressLogXml.Trim()
		
		do 'imprimenota'
		
		if not &UrlPDF.IsEmpty()			
			&Window.Url = Link(&UrlPDF)
			&Window.Height = 500	
			&Window.Width = 900
			&Window.Open()
		Endif
	
		Exit
	EndFor

EndEvent

Sub 'imprimenota'

	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NfsCod
		
		If not NfsArqXml.IsEmpty() and NfsSts = Status_NFe.Autorizada
			
			funcaoAutorizada.Visible = 1
			Sucesso.Visible = 1
			
			//GravarStatusIMpressao.Submit('GravarStatusIMpressao', EmpCod, FilCod, NfsCod, 0)
			txtMsg.ForeColor = RGB(0,210,25)

			GeraPdfDanfeNFSe.Call(EmpCod, NfsCod, &UrlPDF, &UrlFisico)
						
			btnNovaNFSe.SetFocus()
		Else
			Falha.Visible = 1
			btnNovaNFSe.SetFocus()
		EndIF
		
		Exit
	EndFor

EndSub


