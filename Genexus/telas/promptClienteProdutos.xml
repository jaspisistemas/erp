      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&EmpCod = &InEmpCod
	&FilCod = &inFilCod 
	&PedCod = &inPedcod
	&PedClICod = &inPedCliCod
	txtAviso.caption = 'Itens comprados pelo Cliente: ' + trim(Str(&inPedCliCod))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PedDtaEms_To = serverdate()
    &PedDtaEms = &PedDtaEms_To.AddMonths(-1)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Select.ColumnHeaderClass = !'WWIconActionColumn'
	PedCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	ProGraRef.ColumnHeaderClass = !'WWColumn'
	ProNomGra.ColumnHeaderClass = !'WWColumn'
	ProGraBar.ColumnHeaderClass = !'WWColumn'
	PedVlrUntComDsc.ColumnHeaderClass = !'WWColumn'
	PedQtd.ColumnHeaderClass = !'WWColumn'
	PedVlrItm.ColumnHeaderClass = !'WWColumn'
	PedQtdDev_FORMULA.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Select = !'<i class="fas fa-check"></i>'
	If (PedQtd > PedQtdDev_FORMULA)
		&Select.Class = !'Attribute'
	Else
		&Select.Class = !'Invisible'
	Endif

	&Select.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWIconActionColumn WWColumnLineThrough WWColumnLineThroughFirstColumn', !'WWIconActionColumn')
	PedCod.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	ProGraRef.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough', !'WWColumn')
	ProNomGra.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough', !'WWColumn')
	ProGraBar.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PedVlrUntComDsc.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PedQtd.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PedVlrItm.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PedQtdDev_FORMULA.ColumnClass = iif(PedQtd <= PedQtdDev_FORMULA, !'WWColumn WWColumnLineThrough', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&OutProGraRef = ProGraRef
	&OutPedCod = PedCod
	&OutPedItmCod = PedItmCod
	&OutPedQtd = PedQtd
	Return

EndEvent


]]></Source>
