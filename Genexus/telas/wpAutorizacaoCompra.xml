      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWAUTORIZACAOCOMPRA', Status_SimNao.Sim, 2, &AutNiv)
	
	loadWWpContext.Call(&Context)
	if &ACmpCod <> 0
		do 'loadLancamento'
	Else
		
		&ACmpDtaEms = Serverdate()
		&ACmpDigCod = &Context.PesCod
		retornaNomePessoa.Call(&Context.EmpCod, &Context.PesCod, &ACmpDigNome)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&OldACmpForCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwAutorizacaoCompra.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	loadWWpContext.Call(&Context)
	
	
	RetornaNomeFuncionario.Call(&EmpCod, &ACmpAutCod, &ACmpAutPesIsFun, &ACmpAutNome)
	RetornaNomeFuncionario.Call(&EmpCod, &ACmpResCod, &ACmpResPesIsFun, &ACmpResNome)

EndEvent

Event &ACmpForCod.IsValid

	if (&OldACmpForCod <> &ACmpForCod) or (&ACmpForNomMan.IsEmpty() and not &ACmpForCod.IsEmpty())
		RetornaNomeFuncionario.Call(&EmpCod, &ACmpForCod, &ACmpForPesIsFor, &ACmpForNomMan)
		&ACmpForNomMan.SetFocus()
	Endif
	&OldACmpForCod = &ACmpForCod

EndEvent

Event &ACmpAutCod.IsValid

	RetornaNomeFuncionario.Call(&EmpCod, &ACmpAutCod, &ACmpAutPesIsFun, &ACmpAutNome)
	&ACmpObs.SetFocus()

EndEvent

Event &ACmpResCod.IsValid

	RetornaNomeFuncionario.Call(&EmpCod, &ACmpResCod, &ACmpResPesIsFun, &ACmpResNome)
	&ACmpAutCod.SetFocus()

EndEvent

Event Enter

	do case
		Case &ACmpResNome.IsEmpty()
			&ACmpResCod.SetFocus()
			msg('Favor informar o Autorizador!')
			
		Case &ACmpAutNome.IsEmpty()
			&ACmpAutCod.SetFocus()
			msg('Favor informar o Autorizado!')
		Case &ACmpDtaEms.IsEmpty()
			&ACmpDtaEms.SetFocus()
			msg('Favor informar Data de Emissão!')
		Otherwise
			PrcAutorizacaoCompra.Call(&EmpCod,&ACmpCod,&ACmpObs,&ACmpAutCod,&ACmpAutCod,&ACmpForCod,&ACmpForNomMan, &ACmpResCod,&ACmpFilCod,&ACmpDtaEms,&ACmpDigCod, &Context.UserName)
			wwAutorizacaoCompra.Link()
	Endcase

EndEvent

Sub 'loadLancamento'

	For Each order EmpCod, ACmpAutCod
		Where EmpCod = &EmpCod
		Where ACmpCod = &ACmpCod 
		&ACmpObs = ACmpObs
		&ACmpAutCod = ACmpAutCod
		//&ACmpAutNome = ACmpAutNome
		&ACmpAutCod = ACmpAutCod
		&ACmpForCod = ACmpForCod
		&ACmpForNomMan = ACmpForNomMan
		&ACmpResCod = ACmpResCod
		//&ACmpResNome = ACmpResNome
		&ACmpFilCod = ACmpFilCod
		&ACmpDtaEms = ACmpDtaEms
		&ACmpDigCod = ACmpDigCod
		//&ACmpDigNome = ACmpDigNome
		Exit
	EndFor

EndSub


]]></Source>
