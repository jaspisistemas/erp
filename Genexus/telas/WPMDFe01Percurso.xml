Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If &MdfeSegRes = ResponsavelSeguro.Contratante and &MDFeTipEmt = MDFe_TipoEmitente.Prestador
		MdfeSegCnpj_Cell.Class = !'col-xs-12 col-sm-6 RequiredDscTop'
	Else
		MdfeSegCnpj_Cell.Class = !'col-xs-12 col-sm-6 DscTop'
	EndIf
	If &MdfeSegRes = ResponsavelSeguro.Contratante and &MDFeTipEmt = MDFe_TipoEmitente.Prestador
		MdfeSegNom_Cell.Class = !'col-xs-12 col-sm-6 RequiredDscTop'
