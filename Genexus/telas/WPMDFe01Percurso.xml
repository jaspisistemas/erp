		&FilCod = &WizardData.Mdfe.FilCod
		&MDFeCod = &WizardData.Mdfe.MdfeCod
		&MdfeDstUfeCod = &WizardData.Mdfe.MdfeDstUfeCod
		&MDFeTipEmt = &WizardData.Mdfe.MdfeTipEmt
		Do 'Cidade'
		If &MDFeTipEmt = MDFe_TipoEmitente.Prestador
			Do 'GetSeguro'
		EndIf
		&MDFeDesCidCod = &WizardData.Percurso.MDFeDesCidCod
		RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon094_IntegracaoQCT, &CfgVlr)
	EndIf
	
	if &MDFeCod.IsEmpty()
		wwMdfe.Link()
	Endif

