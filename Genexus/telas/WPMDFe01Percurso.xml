Event Refresh

	Do 'AttributesSecurityCode'

EndEvent

Event &MdfeSegRes.IsValid

	If &MdfeSegRes = ResponsavelSeguro.Emitente
		Do 'SeguroEmitente'
	EndIf
	do 'AttributesSecurityCode'

EndEvent

Event &MdfeSegRes.Click

	If &MdfeSegRes = ResponsavelSeguro.Emitente
		Do 'SeguroEmitente'
	EndIf
	Do 'AttributesSecurityCode'

EndEvent

Event &DeletePercurso.Click

	MDFE_PErcurso.Call('DEL', &EmpCod, &FilCod, &MDFeCod, &gridMDFePerCod, '')
	gridPercurso.Refresh()

EndEvent

Event &DeletaAverba.Click

	DeletarAverbacao.call(EmpCod,FilCod,MDFeCod,MdfeSegCod,MdfeSegNroAve)
	
	If &MDFeTipEmt = MDFe_TipoEmitente.Prestador
		Do 'GetSeguro'
	EndIf
	Do 'AttributesSecurityCode'
	Refresh keep

EndEvent

Event &MdfeSegRef.IsValid

	If &MdfeSegRef <> 0 
		Do 'GetSeguradora'
	EndIf

EndEvent

Sub 'GetSeguro'

	For Each Order EmpCod, FilCod, MDFeCod,MdfeSegCod
		Where EmpCod = &WizardData.Mdfe.EmpCod
		WHere FilCod = &WizardData.Mdfe.FilCod
		Where MDFeCod = &WizardData.Mdfe.MDFeCod
		Where MdfeSegCod = 1
		&MdfeSegRef = MdfeSegRef
		&MdfeSegRes = MdfeSegRes
		&MdfeSegNom = MdfeSegNom
		&MdfeSegCnpj = MdfeSegCnpj
		&MdfeSegNroApo = MdfeSegNroApo
		&MdfeMaxAve = MdfeMaxAve
		Exit
	EndFor

EndSub

Sub 'Cidade'

	For each Order EmpCod,UfeCod,CidCod
		Where EmpCod = &EmpCod
		Where UfeCod = &MDFeDstUfeCod		
		&MDFeDesCidCod.AddItem(CidCod,CidNomUfe)
	EndFor

EndSub

Sub 'SeguroEmitente'

	For each Order EmpCod,FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		&MdfeSegNom = FilRaz
		&MdfeSegCnpj= FilCpj
		Exit	
	EndFor

EndSub

Sub 'GetSeguradora'

	For Each Order EmpCod, FilCod, MDFeCod,MdfeSegCod
		Where EmpCod = &WizardData.Mdfe.EmpCod
		Where SegCod = &MdfeSegRef
		&MdfeSegNom = SegNom
		&MdfeSegCnpj = SegCnpj
		&MdfeSegNroApo = SegApo
		Exit
	EndFor

EndSub


