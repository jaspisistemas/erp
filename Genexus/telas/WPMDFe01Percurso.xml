Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If (&MdfeSegRes = ResponsavelSeguro.Contratante and &MDFeTipEmt = MDFe_TipoEmitente.Prestador) AND &MdfeSegCnpj.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','CNPJ da seguradora'), DVMessageType.error, &MdfeSegCnpj.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&MdfeSegRes = ResponsavelSeguro.Contratante and &MDFeTipEmt = MDFe_TipoEmitente.Prestador) AND &MdfeSegNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nome Seguradora'), DVMessageType.error, &MdfeSegNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

