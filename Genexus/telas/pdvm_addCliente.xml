      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	//	tbLimiteCLIENTE

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	erdd.Width = 1210
	espacsdss.Height = 30
	tabsdsd.Height = 50

	Do 'AttributesSecurityCode'
	&UtilizadoPesCliCrd.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CtabanCodNom = trim(str(&Context.CtaBanCod)) + ' - ' + &Context.CtaBanNom
	
	&CodigoClienteVar.SetFocus()
	If &PedCod <> 0
		retornaAutorizacao.Call('VENDAEDITAFICHAECREDITO', Status_SimNao.nao, 1, &VENDAEDITAFICHAECREDITO)
		If &VENDAEDITAFICHAECREDITO > 0
			&FicBar.Enabled = 1
			&PedVlrLmt.Enabled = 1
		Else
			&FicBar.Enabled = 0
			&PedVlrLmt.Enabled = 0
		EndIf
	EndIf
	BtnDuplicatas.Visible = False
	BtnPedidos.Visible = False

EndEvent

Event 'DoVoltarPDV'

 2

	PDVM_Venda.Link(&PedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConsultarCliente'

 4
	PromptClientePDV.Popup(&EmpCod, &PedCliCod, &CodigoClienteVar)
	&CodigoClienteVar.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDuplicatas'

	WWDuplicataReceber.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoPedidos'

	wwpedidopdv.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If (&TCon086_SolicitarClientePDV = 'S') AND &FicBar.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','FICHA'), DVMessageType.error, &FicBar.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If &TCon086_SolicitarClientePDV = 'S'
		FicBar_Cell.Class = !'col-xs-12 RequiredCellMarginLeft DscTop'
	Else
		FicBar_Cell.Class = !'col-xs-12 CellMarginLeft DscTop'
	EndIf
	
	tbmensagemm.Visible = (&mensagemErro <> '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event addCliente.Click

	wpNovaPessoa.Popup('CLI', &AuxPesCod, &CodigoClienteVar)
	&CodigoClienteVar.SetFocus()

EndEvent

Event Enter

	do 'Confirma'

EndEvent

Event 'F11'

 11
	do 'confirma'

EndEvent

Event &PedVlrLmt.IsValid

	BtnEnter.SetFocus()

EndEvent

Event 'F10'

 10
	do 'confirma'

EndEvent

Event &CodigoClienteVar.IsValid

	do 'ValidaClienteVar'
	if &IsClienteErro = true	
		&CodigoClienteVar.SetFocus()
	EndIF
	Do 'ValidaClienteNegativo'
	do 'AttributesSecurityCode'

EndEvent

Event &NomeCliente.IsValid

	if not &NomeCliente.IsEmpty() 
		Do 'validaClienteNome'
		
		if &IsClienteErro = true	
			&CodigoClienteVar.SetFocus()
		EndIF
		Do 'ValidaClienteNegativo'
		do 'AttributesSecurityCode'
	Endif

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon020_ClientePadraoVista, &CfgVlr)
	&VisPedCliCod = iif(&CfgVlr = '', 1, val(&CfgVlr))
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon086_SolicitarClientePDV, &TCon086_SolicitarClientePDV)
	do 'loadPedido'

EndEvent

Sub 'validaClienteNome'

	&IsClienteErro = false
	For Each Order EmpCod, PesCodRazSugg
		Where EmpCod = &EmpCod
		Where PesCodRazSugg = &NomeCliente
		
		&CodigoClienteVar = trim(str(PesCod))
		&PedCliCod = PesCod
		&PesRaz = PesRaz
		&PesTip = PesTip
		
		If PesTip = TipoPessoa.JURIDICA
			&PesCnpj = PesCnpj
		Else
			&PesCnpj = PesCpf
		EndIf
				
		 Do Case
		 	Case PesSts = Status_AtivoInativo.INATIVO
				&mensagemErro =  'Cliente com cadastro inativado, verifique!'
				&IsClienteErro = true
				//Case 
				
		EndCase
		
		Exit
	When none
		&IsClienteErro = true
		if &PedCliCod = 0
			&PedCliRaz = 'CLIENTE NÃO INFORMADO'
		Else
			&PedCliRaz = 'CLIENTE NÃO LOCALIZADO'
			&mensagemErro = &PedCliRaz
		EndIF
	Endfor

EndSub

Sub 'validaClienteVar'

	&CodigoClienteVar = RetornaSonumeros.Udp(&CodigoClienteVar)
	&PedCliCod = val(&CodigoClienteVar)
	
	&IsClienteErro = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		&PedCliRaz = PesRaz
	
		&PesCodRazSugg = PesCodRazSugg
		&PesRaz = PesRaz
		&PesTip = PesTip
		If PesTip = TipoPessoa.JURIDICA
			&PesCnpj = PesCnpj
		Else
			&PesCnpj = PesCpf
		EndIf
		

		 Do Case
		 	Case PesSts = Status_AtivoInativo.INATIVO
				&mensagemErro = 'Cliente com cadastro inativado, verifique!'
				&IsClienteErro = true
			//Case 
				
		EndCase
	
		Exit
	When none
		&IsClienteErro = true
		if &PedCliCod = 0
			&PedCliRaz = 'CLIENTE NÃO INFORMADO'
		Else
			&PedCliRaz = 'CLIENTE NÃO LOCALIZADO'
			&mensagemErro =  &PedCliRaz
		EndIF
	Endfor
	
	&NomeCliente = RetornaMesmoValor.udp(&PesCodRazSugg, &EmpCod)

EndSub

Sub 'Confirma'

	&PedCliCod = val(&CodigoClienteVar)
	&mensagemErro.SetEmpty()
	&FicCod.SetEmpty()
	&Mensagem.SetEmpty()
	
	do 'ValidaClienteVar'	
	do 'CheckRequiredFields'
	if not &FicBar.IsEmpty()
		localizaPedidoFicha.Call(&EmpCod, &FilCod, &FicBar, &FicCod, &AuxPedCod, &Mensagem,&IsLimite)
	EndiF
	Do 'ValidaClienteNegativo'
	Do CAse
		Case &IsClienteErro = true	
			&CodigoClienteVar.SetFocus()
	
//		Case &IsErroDebitos = True   //TAVA BLOQUEANDO AS VENDAS PARA CLIENTES DEVEDORES.
//			&mensagemErro = 'Verifique as Pendências'
		CAse (not &AuxPedCod.IsEmpty()) and (&AuxPedCod <> &PedCod) and (not &FicBar.IsEmpty())
			&mensagemErro = 'Ficha já utilizada em outro pedido: ' + trim(Str(&AuxPedCod))
			&FicBar.SetFocus()
			
		Case not &Mensagem.IsEmpty()
			&mensagemErro  = &Mensagem
			&FicBar.SetFocus()
		Case &CheckRequiredFieldsResult = False
			&mensagemErro = 'Obrigações não preenchidas verifique!'
		Case not &FicBar.IsEmpty() and &IsLimite = true
			&mensagemErro = &Mensagem
		CAse &InvalidCliente = false
			If &PedCod = 0
				RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon039_TipoLancamentoPDV, &CfgVlr)
				&ConLctCod = iif(&CfgVlr = '', 8, val(&CfgVlr))
				
				GravaCapaPedidoPDV.Call(&EmpCod, &FilCod, &PedCliCod, &ConLctCod, &Context.PesCod, Pedido_Gerado.PDV, &FicCod, &PedCod)
			EndIF
	
			AlteraCapaPedidoPDV.Call(&EmpCod, &FilCod, &PedCod, &PedCliCod, &PesRaz, &PesTip, &PesCnpj, &FicCod,&PedVlrLmt, &Context.UserName)
			
			pdvM_venda.Link(&PedCod)
	EndCase
	
	Do 'AttributesSecurityCode'

EndSub

Sub 'LoadPedido'

	For Each order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&CodigoClienteVar = trim(Str(PedCliCod))
		&PedVlrLmt = PedVlrLmt
		&PedFicCod = PedFicCod
		If PedFicCod > 0
			do 'localizaFicha'
		EndIF
		
		do 'ValidaClienteVar'
		
		Exit
	When none
		RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon020_ClientePadraoVista, &CfgVlr)
		&CodigoClienteVar = iif(&CfgVlr = '', '', &CfgVlr.Trim())
		
		do 'ValidaClienteVar'
		If &auxFicCod > 0
			&PedFicCod = &auxFicCod
			do 'localizaFicha'
		EndIf
	EndFor

EndSub

Sub 'localizaFicha'

	For Each Order EmpCod, FicCod
		Where EmpCod = &EmpCod
		Where FicCod = &PedFicCod
		&FicBar = FicBar
		Exit
	EndFor

EndSub

Sub 'ValidaClienteNegativo'

	BtnDuplicatas.Visible = False
	BtnPedidos.Visible = False
	&mensagemErro = ''
	&IsErroDebitos = False
	&PedVlrBrt = 0
	For each Order EmpCod,PedCliCod,PedStsFin
		Where EmpCod = &EmpCod
		Where PedCliCod = &PedCliCod
		Where PedCod <> &PedCod when &PedCod <> 0
		Where PedStsFin = Status_Financeiro.ABERTO
		//Msg('ATENÇÃO! O Cliente '+trim(PedCliCodRaz)+' contém débitos pendentes, nos Pedido/Fichas '+trim(Str(PedCod))+'/'+trim(Str(PedFicCod))+'! Verifiqe')
		&PedVlrBrt += PedVlrBrt
		&mensagemErro = 'ATENÇÃO! Débitos pendentes! no valor de '+ &PedVlrBrt.ToFormattedString()
		&IsErroDebitos = True
		BtnPedidos.Visible = true
	EndFor

	For each Order EmpCod,CreCliCod,CreVlrSdo
		Where EmpCod = &EmpCod
		Where CreCliCod = &PedCliCod
		Where CreRecPag =  ReceberPagar.Receber
		Where CreVlrSdo > 0
		Where CreDtaVct <= (&Today+5) //vencidas e á vencer daqui 5 dias
		&PedVlrBrt += CreVlrSdo
		&mensagemErro = 'ATENÇÃO! Débitos pendentes! no valor de '+ &PedVlrBrt.ToFormattedString()
		//Msg('ATENÇÃO! O Cliente '+trim(CreCliCodRazSugg)+' contém débitos pendentes, na Duplicata/Pedido '+trim(Str(CreCod))+'/'+trim(Str(CrePedCod))+'! Verifiqe')
		&IsErroDebitos = True
		BtnDuplicatas.Visible = True
	
	EndFor

EndSub


]]></Source>
