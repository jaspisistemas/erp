      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&Ano = year(&Today)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	retornaAutorizacao.Call('WPIMPOSTORENDA', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEnviarEmail'

	If &PesCod = 0
		Msg('ATENÇÃO, Para envio do email é necessário informar um cliente!')
	Else

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpEnviaExtratoImposto.PopUp(&EmpCod, &FilCod, &PesCod, &Ano)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIf

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS125.link(&EmpCod,&context.FilCod,&ano,&PesCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event &PesCod.IsValid

	do 'GetCliente'

EndEvent

Sub 'GetCliente'

	If &PesCod = 0
		&PesCodRaz = 'Todos os Clientes'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			&PesCodRaz = PesCodRaz
			Exit
		when none
			&PesCodRaz = 'Cliente não encontrado!'
		EndFor
	EndIf

EndSub


]]></Source>
