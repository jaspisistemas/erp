      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	
	if &ParPadGrupCod.IsEmpty()
		&EmpCod = &wwpContext.EmpCod
	else
		&EmpCod = &parEmpCod
		&PadGrupCod = &parPadGrupCod
		do 'loadPadrao'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PadGrupCod.Visible = False
	&PadGrupProGraCod.Visible = False
	&PadGrupProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PadGrupNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Descrição'), DVMessageType.error, &PadGrupNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PadGrupLctCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Operacao'), DVMessageType.error, &PadGrupLctCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &ProGraRef.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Ref.Cód.'), DVMessageType.error, &ProGraRef.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	do 'GetProdutoRef'
	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = true
		prcGravaGrupoPadrao.Call(&EmpCod, &PadGrupCod, &PadGrupNom, &PadGrupTip, &PadGrupProCod, &PadGrupProGraCod, &PadGrupCpl, &PadGrupDia, &PadGrupNfeNfs,&PadGrupLctCod)
		Return
	EndIf

EndEvent

Event &ProGraRef.IsValid

	do 'GetProdutoRef'

EndEvent

Sub 'GetProdutoRef'

	RetornaProdutoReferencia.Call(&EmpCod, &ProGraRef, &PadGrupProCod, &PadGrupProGraCod, &ProGraNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)

EndSub

Sub 'loadPadrao'

	For Each Order EmpCod, PadGrupCod
		Where EmpCod = &EmpCod
		Where PadGrupCod = &PadGrupCod
		
//		&PadGrupNfeVlr = PadGrupNfeVlr
		&PadGrupNom = PadGrupNom
		&PadGrupTip = PadGrupTip
		
		&PadGrupProCod = PadGrupProCod
		&PadGrupProGraCod = PadGrupProGraCod
		&PadGrupCpl = PadGrupCpl
		
		&PadGrupDia = PadGrupDia
		&PadGrupNfeNfs = PadGrupNfeNfs
		&PadGrupLctCod = PadGrupLctCod
		do 'GetProduto'
		
		
		Exit
	EndFor

EndSub

Sub 'GetProduto'

	For Each ORder EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &PadGrupProCod
		Where ProGraCod = &PadGrupProGraCod
		&ProGraRef = ProGraRef
		&ProGraNom = ProGraNom
		Exit
	EndFor

EndSub


