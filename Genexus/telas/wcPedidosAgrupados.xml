      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do 'GetPedido'
	Do 'GetAgrupamento'
	RetornaPedidosAgrupados.Call(&EmPCod, &FilCod, &PedCodAgr, &sdtPedidos)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 30

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For &sdtPedidosItem in &sdtPedidos
		
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmPCod
			Where FilCod = &sdtPedidosItem.FiLCod
			Where PedCod = &sdtPedidosItem.PedCod
			
			&gridPedCod = &sdtPedidosItem.PedCod
			&gridPedVlrLiq = &sdtPedidosItem.PedVlrLiq
			&gridPedCliCodRaz = PedCliCodRaz
			
			If &OqueFazer = 'V'
				if PedCodAgr = PedCod
					&gridOqueAcontece = 'RECEBIDO VALOR FINANCEIRO PED.' + trim(str(PedCod))
				Else
					&gridOqueAcontece = 'FINANCEIRO AGRUPADO NO PED.' + trim(str(PedCodAgr))
				EndIF
			
			Else
				&gridOqueAcontece = ''
			EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			Load
		EndFor

	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'GetPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedCodAgr = PedCodAgr	
		exit
	EndFor

EndSub

Sub 'GetAgrupamento'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		Where PedCod = &PedCodAgr
			If PedVlrAgr <> 0
				&OqueFazer = 'V'
				
				txtTipoAgrupamento.Caption = 'AGRUPAMENTO DE VALORES'
				txtTipoAgrupamento.ForeColor = RGB(0,100,40)
			Else
				&OqueFazer = 'T'
				txtTipoAgrupamento.Caption = 'AGRUPAMENTO TOTAL DE PEDIDOS'
				txtTipoAgrupamento.ForeColor = RGB(0,40,100)
			EndiF
		
		exit
	EndFor

EndSub


]]></Source>
