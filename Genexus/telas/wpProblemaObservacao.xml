        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PblCod.Visible = False
	&PblSts.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Visualizar = !'<i class="fa fa-search"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

//	PblObsFunCod.LinkTarget = '_blank'
//	PblObsFunCod.Link = verCliente.Link('', EmpCod, PblObsFunCod)
	
	&PesCod = PblObsFunCod
	do 'loadUsuario'
	
	if PblObsArqAnx.IsEmpty()
		&Visualizar.Visible = false
	else
		&Visualizar.Visible = true
		&link = pathToUrl(PblObsArqAnx)
		PblObsArqNom.LinkTarget = '_blank'
		PblObsArqNom.Link = &link
		&Visualizar.LinkTarget = '_blank'
		&Visualizar.Link = &link
	EndIf

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdiconar'

	wwpProblemaObs.Popup(&EmpCod, &PblCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'loadUsuario'

	For each order EmpCod, PesCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		&PesCodRaz = PesCodRaz
		exit
	when none
		if &PesCod = -1
			&PesCodRaz = 'SUPORTE'
		else 
			&PesCodRaz = 'CONTADOR'
		EndIf
	EndFor

EndSub

