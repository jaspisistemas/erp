        <Source><![CDATA[
Event Start

	Aviso.Caption = ''
	do 'LoadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 700
	&EmpCod.Visible = False
	&FilCod.Visible = False
	Grid.Rows = 12
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = grid.PageCount

EndEvent

Event Grid.Load

	&EstQtd = EstQtd
	&Pedqtd = PedQtd
	
	If (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
		&PedQtdCan = PedQtdCan
	Else		
		if EstQtd < 0
			&PedqtdCan = PedQtd
		Else
			&PedqtdCan = PedQtd - EstQtd
		EndIf
	EndIf

	&PedVlrItm = PedVlrUnt * &PedQtdCan

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRetornar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirFaltas'

	RCOOpenWindow1.LinkOpen = RELJAS037.Link(&EmpCod, &FilCod, &PedCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
				
		&PedCliCodRaz = PedCliCodRaz
		If (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
			Form.Caption = 'FALTAS DO PEDIDO'
		Else
			Form.Caption = '#SUPOSTAS FALTAS DO PEDIDO'
			
			if PedSts = Status_Pedido.ABERTO
				aviso.Caption = 'Pedido com Status ABERTO, essa situação ainda poderá ser alterada!'
				aviso.ForeColor = RGB(200,150,0)
			EndIf
		EndIF
		
		Exit
	EndFor
	
	&TotalFaltas = RetornaTotalFaltas.Udp(&EmpCod, &FilCod, &PedCod)

EndSub


]]></Source>
