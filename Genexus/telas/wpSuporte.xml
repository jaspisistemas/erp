      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&QtdAtivos = 0
//	if upper(&Context.UserName) <> 'SUPORTE.JEAN' and  upper(&Context.UserName) <> 'SUPORTE.TIAGO' and upper(&Context.UserName) <> 'SUPORTE.JASPI'
//		msg('Autorizado somente para "SUPORTE.JEAN", "SUPORTE.TIAGO"')
//		dashboard.Link()
//	Endif
	if &Context.Old_Perfil < 3
		Dashboard.Link()
	Endif

	GravaUsuarioSuporte.Call('INS', -1, 'contato@jaspi.com.br', 'SUPORTE SUPERIOR SISTEMA JASPI', &SupCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' Suporte'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GAMSessionStatusFil	= GamSessionStatus.Active

EndEvent

Event Refresh

	&ActiveSessionCount 			= GAMRepository.GetAliveSessionCount(&Errors)
	&Filter.AuthenticationTypeName	= ''
	&Filter.ReturnAnonymousUser 	= false
	&GAMUsers 						= GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors)
	&ValueCard4						= &GamUsers.Count
	For &User in &GAMUsers		
		If &User.IsActive = true and &User.IsBlocked <> true
			&QtdAtivos += 1
		Endif
		
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&UsrUpdate = !'<i class="fa fa-pen"></i>'
	
	&UsrDelete = !'<i class="fa fa-times"></i>'
	
	&CriarUsuario = !'<i class="fa fa-pen"></i>'
	
	&DeletaUsuario = !'<i class="fa fa-times"></i>'
	If (SupExtID > 0 and &Context.PesCod <> SupCod and upper(&Context.UserName) = 'SUPORTE.JASPI')
		&DeletaUsuario.Class = !'Attribute'
	Else
		&DeletaUsuario.Class = !'Invisible'
	Endif
	&AdicionarSenha = !'<i class="fa fa-key"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&gridStatusUsuario = 'SEM USUARIO'
	&gridStatusUsuario.ForeColor = RGB(0,0,0)
	&AuxPesExtCod = SupExtID
	&gridGUID = ''
	
	&gridPesEml = ''
	&gridNomeUsuario = ''
	&SupCod = SupCod
	If &AuxPesExtCod <> 0 or &SupCod = -1
		do 'getUsuariosGAM'
	endIf

	If (&gridGUID <> '') and (upper(&Context.UserName) = 'SUPORTE.JASPI' OR (upper(&Context.UserName) = 'SUPORTE.JEAN') OR (upper(&Context.UserName) = 'SUPORTE.TIAGO'))
		&AdicionarSenha.Visible = 1
	Else
		&AdicionarSenha.Visible = 0
	EndIf

EndEvent

Event 'DoUsrInserir'

	wpSuporteNovo.Popup(0)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"Suporte"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &UsrUpdate.Click

	wpSuporteNovo.Popup(SupCod)
	Refresh

EndEvent

Event &AdicionarSenha.Click

	If not &gridGUID.IsEmpty()
		wpSetarNovaSenha.Popup(&gridGUID)
		Refresh
	Else
		msg( DVMessageBasicNotification.Udp(!"Erro!", 'Pessoa não HABILITADO como Usuário!' ,DVMessageType.error, "", DVMessageBoolean.True) )
	EndIF

EndEvent

Event &CriarUsuario.Click

	If &gridGUID.IsEmpty()
		NovoUsuarioSuporte.Popup(TrnMode.Insert, '',0, SupCod)
	Else
		NovoUsuarioSuporte.Popup(TrnMode.Update, &gridGUID, 0, SupCod)
	EndIf
	refresh

EndEvent

Event &DeletaUsuario.Click

	NovoUsuarioSuporte.Popup(TrnMode.Delete, &gridGUID, 0, SupCod)
	Refresh

EndEvent

Event &UsrDelete.Click

	if &gridNomeUsuario.IsEmpty()
		Suporte.Popup(TrnMode.Delete, SupCod)
		Refresh
	Else
		msg( DVMessageBasicNotification.Udp(!"Erro!", 'Favor remover primeiramente o Usuario GAM.' ,DVMessageType.error, "", DVMessageBoolean.True) )
	Endif

EndEvent

Sub 'getUsuariosGAM'

	&Filter.AuthenticationTypeName	= ''
	&Filter.ReturnAnonymousUser 	= false
	if &SupCod = -1 //SUPORTE.JASPI'
		&Filter.Name = 'suporte.jaspi'
		&Filter.ExternalId = ''
	Else		
		&Filter.Name = ''
		&Filter.ExternalId = trim(str(&AuxPesExtCod))
	Endif

	For &User in GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors)
		&gridGUID = &User.GUID
		&gridPesEml = &User.EMail
		&gridNomeUsuario = &User.Name
		
		Do Case
			Case &User.IsBlocked = true
				&gridStatusUsuario.ForeColor = RGB(160,40,0)
				&gridStatusUsuario = 'BLOQUEADO'
				
			Case &User.IsActive = true
				&gridStatusUsuario.ForeColor = RGB(0,40,160)
				&gridStatusUsuario = 'HABILITADO'
				
			Otherwise
				&gridStatusUsuario.ForeColor = RGB(160,40,0)
				&gridStatusUsuario = 'BLOQUEADO'
		EndCAse
		
		Exit
	EndFor

EndSub


