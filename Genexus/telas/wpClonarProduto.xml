      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	
	retornaAutorizacao.Call('WWPRODUTO', Status_SimNao.Sim, 2, &AutNiv)
	RetornaConfSistema_CadastroProduto.Call(&Context.EmpCod, &Context.FilCod, &sdtConfSistema_CadastroProduto)
	
	tbCodigo.Visible = (&sdtConfSistema_CadastroProduto.TCon065_BloquearAlteracaoCodigo = 'S')
	tbref.Visible    = (&sdtConfSistema_CadastroProduto.TCon065_BloquearAlteracaoCodigo <> 'S')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&NewProCod.TooltipText = "Informe o código do novo Produto ou deixe 0 para o sistema buscar uma sequência disponível."
	&ProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProCodNom = ProRefNom
		Exit
	EndFOr
	
	&IsClonarImagens = false
	&IsClonarReceitas = false
	&IsClonarValoresVenda = false

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if (&sdtConfSistema_CadastroProduto.TCon065_BloquearAlteracaoCodigo = 'S')
		if &NewProCod <> 0 //CASO INFORMOU CODIGO VALIDA
			verificaCodigoDisponivelProduto.Call(&EmpCod, &NewProCod, &IsDisponivel) 
			
			If &IsDisponivel = false
				msg('Código: '+trim(str(&NewProCod))+' já utilizado, Informe outro Código para o Cadastro.') 
			Else
				deletaProduto.Call(&EmpCod, &NewProCod, 1, true, &Context.UserName)
				//GRAVA CODIGO SELECIONADO
				&NewProRef = trim(str(&NewProCod))
				GravaProdutoClonado.Call(&EmpCod, &ProCod, &NewProCod, &NewProRef, &IsClonarImagens, &IsClonarReceitas, &IsClonarValoresVenda, &outProRef)
				msg('Criado novo Produto ' + trim(str(&NewProCod)) + ' Com sucesso!')
				btnEnter.Visible = 0
				&NewProCod.Enabled = 0
			EndIF
			
		Else//SENAO LOCALIZA UM DISPONIVEL
			UltimoCodigoEspecial.Call(domParCod.PRODUTO, &EmpCod, 0, &NewProCod)
			
			//GRAVA CODIGO SELECIONADO
			&NewProRef = trim(str(&NewProCod))
			GravaProdutoClonado.Call(&EmpCod, &ProCod, &NewProCod, &NewProRef, &IsClonarImagens, &IsClonarReceitas, &IsClonarValoresVenda, &outProRef)
			msg('Criado novo Produto ' + trim(str(&NewProCod)) + ' Com sucesso!')
			&NewProCod.Enabled = 0
			btnEnter.Visible = 0
		EndIF
	Else
		if not &NewProRef.IsEmpty() //CASO INFORMOU CODIGO VALIDA
			ValidaCodigoReferenciaRepetido.Call(&EmpCod, 0,  1, &NewProRef, &RepetidoReferenciaMensagem) 
			
			If not &RepetidoReferenciaMensagem.IsEmpty()
				msg('Código: '+trim(&NewProRef)+' já utilizado, Informe outro Código para o Cadastro.') 
			Else
				//GRAVA CODIGO SELECIONADO
				UltimoCodigoEspecial.Call(domParCod.PRODUTO, &EmpCod, 0, &NewProCod)
				GravaProdutoClonado.Call(&EmpCod, &ProCod, &NewProCod, &NewProRef, &IsClonarImagens, &IsClonarReceitas, &IsClonarValoresVenda, &outProRef)
				msg('Criado novo Produto ' + trim(&NewProRef) + ' Com sucesso!')
				btnEnter.Visible = 0
				&NewProRef.Enabled = 0
			EndIF
			
		Else//SENAO LOCALIZA UM DISPONIVEL
			UltimoCodigoEspecial.Call(domParCod.PRODUTO, &EmpCod, 0, &NewProCod)
			
			//GRAVA CODIGO SELECIONADO
			GravaProdutoClonado.Call(&EmpCod, &ProCod, &NewProCod, &NewProRef, &IsClonarImagens, &IsClonarReceitas, &IsClonarValoresVenda, &outProRef)
			msg('Criado novo Produto ' + trim(&outProRef) + ' Com sucesso!')
			&NewProRef.Enabled = 0
			btnEnter.Visible = 0
		EndIF
	Endif

EndEvent


]]></Source>
