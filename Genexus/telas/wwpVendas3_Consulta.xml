      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&EmpCod = &parEmpCod
	&TabCod = &parTabCod
	&IsPesquisa = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsPesquisa.Visible = False

	Grid.Rows = Page.Rows
	&gridProSts = nullvalue(&gridProSts)
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' Tabela Preco Produto'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CodigoProduto.SetEmpty()

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	ProGraRef.ColumnHeaderClass = !'WWColumn'
	ProGraEstQtd.ColumnHeaderClass = !'WWColumn hidden-xs'
	ProGraEstSdo.ColumnHeaderClass = !'WWColumn hidden-xs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Selecionar = !'<i class="fas fa-check"></i>'
	
	ProGraRef.ColumnClass = iif(ProSts <> Status_Produto.ATIVO, !'WWColumn WWColumnDanger WWColumnDangerSingleCell', !'WWColumn')
	Do Case
		Case ProGraEstQtd < 0
			ProGraEstQtd.ColumnClass = !'WWColumn hidden-xs WWColumnDanger WWColumnDangerSingleCell'
		Case ProGraEstQtd = 0
			ProGraEstQtd.ColumnClass = !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell'
		Case ProGraEstQtd > 0
			ProGraEstQtd.ColumnClass = !'WWColumn hidden-xs WWColumnBold WWColumnBoldSingleCell'
		Otherwise
			ProGraEstQtd.ColumnClass = 'WWColumn hidden-xs'
	EndCase
	Do Case
		Case ProGraEstSdo < 0
			ProGraEstSdo.ColumnClass = !'WWColumn hidden-xs WWColumnDanger WWColumnDangerSingleCell'
		Case  ProGraEstSdo = 0
			ProGraEstSdo.ColumnClass = !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell'
		Case ProGraEstSdo > 0
			ProGraEstSdo.ColumnClass = !'WWColumn hidden-xs WWColumnBold WWColumnBoldSingleCell'
		Otherwise
			ProGraEstSdo.ColumnClass = 'WWColumn hidden-xs'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&TabPrc1 = 0
	Do Case
		Case &TabColCod = 1
			&TabPrc1 = TabPrc1
		Case &TabColCod = 2
			&TabPrc1 = TabPrc2
		Case &TabColCod = 3
			&TabPrc1 = TabPrc3
		Case &TabColCod = 4
			&TabPrc1 = TabPrc4
		Case &TabColCod = 5
			&TabPrc1 = TabPrc5
		Case &TabColCod = 6
			&TabPrc1 = TabPrc6
		Case &TabColCod = 7
			&TabPrc1 = TabPrc7
		Case &TabColCod = 8
			&TabPrc1 = TabPrc8
		Case &TabColCod = 9
			&TabPrc1 = TabPrc9
	EndCAse

	ProNomGra.Link = VerProduto.Link('WWTABELAPRECOPRODUTO', EmpCod, ProCod)
	ProNomGra.LinkTarget = '_blank'
	
	//RetornaQuantidadePedido.Call(EmpCod, &FilCod, &PedCod, 0, ProCod, ProGraCod, &QuantoTem)
	//&OldQuantoTem = &QuantoTem

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"CODIGOPRODUTO"
				&CodigoProduto.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"GRIDPROSTS"
				&gridProSts.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"ISSALDO"
				&IsSaldo.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"EMPCOD"
				&EmpCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"TABCOD"
				&TabCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"TABULTALT"
				&TabUltAlt.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PROISGRA"
				&ProIsGra.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor

