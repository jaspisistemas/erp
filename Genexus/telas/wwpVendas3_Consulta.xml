	WWP_GridStateAddFilterValue(&GridState, !"TABCOD", "", not &TabCod.IsEmpty(), 0, &TabCod, '')
	WWP_GridStateAddFilterValue(&GridState, !"TABULTALT", "", not &TabUltAlt.IsEmpty(), 0, &TabUltAlt.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"PROISGRA", "", not &ProIsGra.IsEmpty(), 0, &ProIsGra.ToString().Trim(), '')

	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

