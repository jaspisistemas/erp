      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	RetornaTabelaFilial.Call(&Context.EmpCod, &Context.FilCod, &TabNum)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PesCod = &ParPesCod
	if &PesCod <> 0
		RetornaNomePessoa.Call(&EmpCod, &PesCod, &PesRaz)
	EndIF

	if not &ParProRef.IsEmpty()	
		&CodigoProduto = &ParProRef
		RetornaProdutoReferencia.Call(&EmpCod, &CodigoProduto, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
		do 'LoadPrecoEspecial'
	EndIF

EndEvent

Event 'DoDeletar'

	If &ProCod <> 0 and &PesCod <> 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Deletar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		msg('Nenhum produto Informado para Eliminação!')
		&CodigoProduto.SetEmpty()
	EndIF

EndEvent

Event DVelop_ConfirmPanel_Deletar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Deletar.Result = !'Yes'
		Do 'Do Action Deletar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Deletar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	GravaProdutoCombinado.Call(&EmpCod, &PesCod, &ProCod, &ProGraCod, 'DEL', &TabProDtaIni, &TabProDtaFin, &TabPrc1, &TabPrc2, &TabPrc3, &TabPrc4, &TabPrc5, &TabPrc6,&TabPrc7,&TabPrc8,&TabPrc9, &Context.PesCod)
    do 'limpaCampos'

EndSub

Event Refresh

	RetornaColunasTabelas.Call(&EmpCod, &TabNum, &TabPerCol, &TabPerCol2, &TabPerCol3,&TabPerCol4,&TabPerCol5,&TabPerCol6,&TabPerCol7,&TabPerCol8,&TabPerCol9,&tem1,&tem2,&tem3,&tem4,&tem5,&tem6,&tem7,&tem8,&tem9)
	&TabPerCol = 0
	&TabPerCol2 = 0
	&TabPerCol3 = 0
	&TabPerCol4 = 0
	&TabPerCol5= 0
	&TabPerCol6= 0
	&TabPerCol7= 0
	&TabPerCol8= 0
	&TabPerCol9= 0
	
	For Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabNum
		&TabIsPerCol1 = TabIsPerCol1
		&TabRecCol = TabRecCol
		Exit
	EndFor
	
	If &tem2 = 0
		&TabPrc2.Visible = 0
	EndIF

	If &tem3 = 0
		&TabPrc3.Visible = 0
	EndIF

	If &tem4 = 0
		&TabPrc4.Visible = 0
	EndIF

	If &tem5 = 0
		&TabPrc5.Visible = 0
	EndIF

	If &tem6 = 0
		&TabPrc6.Visible = 0
	EndIF

	If &tem7 = 0
		&TabPrc7.Visible = 0
	EndIF

	If &tem8 = 0
		&TabPrc8.Visible = 0
	EndIF
	
	If &tem9 = 0
		&TabPrc9.Visible = 0
	EndIF

EndEvent

Event &CodigoProduto.IsValid

	&NovoProBar = Substr(trim(&CodigoProduto),1, 18)
	RetornaProdutoReferencia.Call(&EmpCod, &NovoProBar, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
			
	&TabPrc1.SetEmpty()
	&TabPrc2.SetEmpty()
	&TabPrc3.SetEmpty()
	&TabPrc4.SetEmpty()
	&TabPrc5.SetEmpty()
	&TabProDtaFin.SetEmpty()
	&TabProDtaini.SetEmpty()
	
	Do 'LoadPrecoEspecial'
	do 'Grade'
	
	if &ProCod <> 0
		Refresh
		&TabPrc1.SetFocus()
	Else
		If not &CodigoProduto.IsEmpty()
			msg('PRODUTO NÃO LOCALIZADO!')
		EndiF
		
		&CodigoProduto.SetFocus()
	EndIF

EndEvent

Event &PesCod.IsValid

	do 'LoadCliente'

EndEvent

Event Enter

	do 'LoadCliente'
	
    Do Case
		Case &TabPrc1 = 0
	        msg('Preço da primeira coluna não pode ser zero!')
	        &TabPrc1.SetFocus()
			
		cAse &IsErroPessoa = true
			msg('Informe o cliente!')
	        &PesCod.SetFocus()
			
    	Case &ProCod <> 0
			GravaProdutoCombinado.Call(&EmpCod, &PesCod, &ProCod, &ProGraCod, 'ADD', &TabProDtaIni, &TabProDtaFin, &TabPrc1, &TabPrc2, &TabPrc3, &TabPrc4, &TabPrc5,&TabPrc6,&TabPrc7,&TabPrc8,&TabPrc9, &Context.PesCod)
            do 'limpaCampos'
			&ProCod.SetEmpty()
			&CodigoProduto.SetEmpty()
			
			If &parmProCod <> 0
				wpCombinado.Link()
			Else
				&CodigoProduto.SetFocus()
	        EndIF
	EndCase

EndEvent

Event &TabPrc1.IsValid

	If &TabPrc1 = 0
		&CodigoProduto.SetEmpty()
	EndIF
	
	if &TabPrc1 > 9999999999
		msg('Valor muito alto, Verifique!')
		&CodigoProduto.SetFocus()
	Else
	    If &IsInsert = true or &TabRecCol = true
	        do 'CarregaValores'        
	    EndIF
	EndiF

EndEvent

Event 'PromptProdutoF4'

 4
	PromptProdutoGradeRef.Popup(&EmpCod, &ProCod, &ProGraCod, &CodigoProduto)
	&CodigoProduto.SetFocus()

EndEvent

Sub 'LoadCliente'

	&IsErroPessoa = true
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesRaz = PesRaz
		&IsErroPessoa = False
		Exit
	EndFor

EndSub

Sub 'LoadPrecoEspecial'

	do 'limpaCampos'
	
	if &ProCod <> 0	
	    For Each Order EmpCod, PesCod, EspProCod, EspProGraCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where EspProCod = &ProCod
		Where EspProGraCod = &ProGraCod
			
	        &ProNom = EspProNom
			
			&CodigoProduto = EspProRef
			&TabPrc1 = EspPrc1
			&TabPrc2 = EspPrc2
			&TabPrc3 = EspPrc3
			&TabPrc4 = EspPrc4
			&TabPrc5 = EspPrc5
			&TabPrc6 = EspPrc6
			&TabPrc7 = EspPrc7
			&TabPrc8 = EspPrc8
			&TabPrc9 = EspPrc9
			
			&TabProDtaIni = EspDtaIni
			&TabProDtaFin = EspDtaFin
			
			&IsInsert = false
					
		    Exit
	    When none
	        For Each Order EmpCod, ProCod, ProGraCod
				Where EmpCod = &EmpCod
		        Where ProCod = &ProCod
				
	            &ProNom = ProNom
				&CodigoProduto = ProGraRef

	            do 'carregaValores'
				
	            &IsInsert = true
				
		        Exit
	        When none
				If &ProCod <> 0
					&ProNom = 'Produto não localizado!'
					msg(&ProNom)
					
					&CodigoProduto.SetEmpty()
				EndIF
	        EndFor
	    EndFor
		
		&TabProDtaFin.Enabled = 1
		For Each Order EmpCod, TabCod, (TabCglCod)
			Where EmpCod = &EmpCod
			Where TabCod = &TabNum
			Where TabCglCod > &TabAltCod 
			&TabProDtaFin.Enabled = 0
			If &TabProDtaFin.IsEmpty()
				&TabProDtaFin = TabCglDtaFin - 1
			EndIF
			
			Exit
		EndFor
		
		&TabProDtaIni.Enabled = 1
		For Each Order EmpCod, TabCod, (TabCglCod)
			Where EmpCod = &EmpCod
			Where TabCod = &TabNum
			Where TabCglCod < &TabAltCod 
			&TabProDtaIni.Enabled = 0
			if &TabProDtaIni.IsEmpty()
				&TabProDtaIni = TabCglDtaFin + 1
			EndIF
			
			Exit
		EndFor
	EndiF

EndSub

Sub 'Grade'

	if &ProGraCod = 1
		&ProNomGra =  'TODAS VARIAÇÕES'
	Else
		For Each Order EmpCod, ProCod, ProGraCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			&ProNomGra = ProGraNom
			Exit
		EndFor
	EndIF

EndSub

Sub 'limpaCampos'

    &ProNom = '<-- INFORME O CÓDIGO DO PRODUTO'
    &TabProDtaFin.SetEmpty()
    &TabProDtaIni.SetEmpty()

    &TabPrc1 = 0
    &TabPrc2 = 0
    &TabPrc3 = 0
    &TabPrc4 = 0
    &TabPrc5 = 0
	&TabPrc6 = 0
    &TabPrc7 = 0
    &TabPrc8 = 0
    &TabPrc9 = 0

    &IsInsert = true

EndSub

Sub 'CarregaValores'

    If &TabIsPerCol1 = true
		if &TabPerCol2 <> 0 
            &TabPrc2 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol2/100),2)
		Else
			&TabPrc2 = &TabPrc1
        EndIF
		
        if &TabPerCol3 <> 0 
            &TabPrc3 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol3/100),2)
		Else
			&TabPrc3 = &TabPrc1
        EndIF
		
        if &TabPerCol4 <> 0 
            &TabPrc4 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol4/100),2)
		Else
			&TabPrc4 = &TabPrc1
        EndIF
		
        if &TabPerCol5 <> 0 
            &TabPrc5 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol5/100),2)
		Else
			&TabPrc5 = &TabPrc1
        EndIF
		
        if &TabPerCol6 <> 0 
            &TabPrc6 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol6/100),2)
		Else
			&TabPrc6 = &TabPrc1
        EndIF
		
        if &TabPerCol7 <> 0 
            &TabPrc7 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol7/100),2)
		Else
			&TabPrc7 = &TabPrc1
        EndIF
		
        if &TabPerCol8 <> 0 
            &TabPrc8 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol8/100),2)
		Else
			&TabPrc8 = &TabPrc1
        EndIF
		
        if &TabPerCol9 <> 0 
            &TabPrc9 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol9/100),2)
		Else
			&TabPrc9 = &TabPrc1
        EndIF
