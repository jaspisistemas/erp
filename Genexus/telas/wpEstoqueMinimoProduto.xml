      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&ProRef = &ParProRef
	RetornaAutorizacao.Call('WPESTOQUEMINIMO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&FilCodNom = trim(str(&Context.FilCod)) + ' - ' + trim(&Context.FilRaz)
	
	&IncluirVendasAbertas  = Status_SimNao.Nao
	&IncluirVendasPerdidas = Status_SimNao.Nao
	
    &iniPedDtaEms = serverdate() - 51
	&finPedDtaEms = serverdate() -1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 493
	&diasApuracao.TooltipText = "O Cálculo de Estoque Mínimo é montado em cima da quantidade Vendida em um Período de Apuração. Então informe o período de vendas. Recomenda-se no mínimo 60 Dias."
	&ProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	if not &PadObs.IsEmpty()
		&ProForCod = val(Substr(&PadObs,1, 8))
		&SetCod = val(Substr(&PadObs,9, 8))
		&iniPedDtaEms = CtoD(Substr(&PadObs,17,10))
		&finPedDtaEms = CtoD(Substr(&PadObs,27,10))
		
		if Substr(&PadObs,37, 1) = 'S'
			&IncluirVendasAbertas = Status_SimNao.Sim
		Else
			&IncluirVendasAbertas = Status_SimNao.Nao
		EndIF
		
		if Substr(&PadObs,38, 1) = 'S'
			&IncluirVendasPerdidas = Status_SimNao.Sim
		Else
			&IncluirVendasPerdidas = Status_SimNao.Nao
		EndIF
		
		if Substr(&PadObs,39, 1) = 'S'
			&IncluirMaiorMenor = Status_SimNao.Sim
		Else
			&IncluirMaiorMenor = Status_SimNao.Nao
		EndIF
	
		&GrupHie = trim(Substr(&PadObs,40, 20))
	EndIF
	
    do 'DiasApuracao'
	Do 'getProduto'
	
	InicializaAgendador.Call(&Context.EmpCod, TipoAgendamento.CalculaEstoqueMinimo, 0, &AgdCod)
	For Each Order EmpCod, AgdCod
		Where EmpCod = &EmpCod
		Where AgdCod = &AgdCod
		
		&AgdSts = AgdSts
		&AgdTip = AgdTip
		
		&AgdUltDtaHora = AgdUltDtaHora
		Exit
	EndFor

EndEvent

Event 'DoVerificaCalculo'

	wpConfereCalculoMinimo.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAgendarEnvio'

	wpAgendaOpc.Popup(&Context.EmpCod, &AgdCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	Do 'getProduto'

EndEvent

Event scaProgressBar1.OnComplete

	Return

EndEvent

Event &iniPedDtaEms.IsValid

	do 'DiasApuracao'

EndEvent

Event &finPedDtaEms.IsValid

	do 'DiasApuracao'

EndEvent

Event Enter

	Do case
		Case &IsErrorproduto = True or &ProRef.IsEmpty()
			msg('Produto inválido!')		
			&ProRef.SetFocus()
			
		Case &iniPedDtaEms > &finPedDtaEms
			msg('Período Inicial deve ser menor que o Período Final!')
			&iniPedDtaEms.SetFocus()
			
		Otherwise
			
			&PadObs = PadL(trim(str(&ProForCod)),8, ' ')
			&PadObs += PadL(trim(str(&SetCod)),8, ' ')
			&PadObs += trim(&iniPedDtaEms.ToFormattedString())
			&PadObs += trim(&finPedDtaEms.ToFormattedString())
			&PadObs += &IncluirVendasAbertas
			&PadObs += &IncluirVendasPerdidas
			&PadObs += &IncluirMaiorMenor
			&PadObs += PadL(trim(&GrupHie),20, ' ')
			
			PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)		
			
			BtnEnter.Visible = 0
			&ProgressId = 'prcCalculaEstoqueMinimo' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			prcCalculaEstoqueMinimo.Submit('prcCalculaEstoqueMinimo', &ProgressId, &EmpCod, &FilCod, 0,&ProCod, 0, '', &iniPedDtaEms, &finPedDtaEms, &IncluirVendasAbertas,&IncluirVendasPerdidas, &IncluirMaiorMenor)
	EndCase

EndEvent

Sub 'getProduto'

	&IsErrorproduto = False
	If &ProRef.IsEmpty()
		&ProNom = 'Todos os produtos'
	Else
		RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
		
		For each Order EmpCod,ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			
			If ProSts <> Status_Produto.ATIVO
				&ProNom = 'Produto não esta ativo'
				Msg('Produto não esta ativo')
				&ProRef.SetFocus()
				&IsErrorproduto = True
			EndIf
		
			&auxProCod = ProCod
			&ProNom = ProNom
			Exit			
		When none
			&ProNom = 'Produto não encontrado'
			Msg('Produto não encontrado')
			&ProRef.SetFocus()
			&IsErrorproduto = True
		EndFor
	EndIf

EndSub

Sub 'DiasApuracao'

	&diasApuracao = &finPedDtaEms - &iniPedDtaEms

EndSub


]]></Source>
