      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtGnre.Rows = Page.Rows
	&GridSdtGnreCurrentPage = 1
	&GridSdtGnreCurrentPage.Visible = False
	&GridSdtGnrePageCount = -1
	GridSdtGnrePaginationBar.RowsPerPageSelectedValue = GridSdtGnre.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Random 							=	Random() * 10000000000							//## Gera um número aleatório para o ID do Progresso 					
	&ProgressId 						= 	'EmitirGNRE' + trim(Str(&Random))				//## Define o ID progresso como 'EmitirGNRE' + str(Número aleatório)	
			
	scaProgressBar1.ProcessId 			= 	&ProgressId										//## Define o ID da barra de Progresso 									
	scaProgressBar1.UpdateProgressURL 	= 	retornaProgresso.Link(&ProgressId)				//## Cria o Progresso na tabela 										
	scaProgressBar1.Start()	

	RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
	&sdtGNRE.FromXml(&WebSession.Get("!ItensGNRE"))
	
	prcVerificaProgressEmissaoGNRE.Submit('', &ProgressId, &sdtGNRE, &Context.EmpCod, &Context.FilCod, &GerarDuplicata, &PesCodFornecedor, &AuxPlanCod, &FuncPesCod)

	&StatusProcessamento.ForeColor 	= RGB(184,134,11)
	&ImprimirPDF.Visible 			= 0
	&IsAchou 						= False

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridSdtGnrePageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridSdtGnreCurrentPage	= GridSdtGnre.CurrentPage
	&GridSdtGnrePageCount	= GridSdtGnre.PageCount
	&GridSdtGnreRows		= GridSdtGnre.Rows

EndEvent

Event GridSdtGnre.Load

	&GridSdtGnrePageCount	= 1
	&GridSdtGnreRows		= GridSdtGnre.Rows
	&GridSdtGnreLinha		= 0
	
	For &sdtGNREItem In &sdtGNRE

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ImprimirPDF = !'<i class="fas fa-file-pdf"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&gridUfeCod 	= &sdtGNREItem.UFFavorecida
		&gridCnpjEmi 	= &sdtGNREItem.FilCnpj
		&gridGNRENovRec = &sdtGNREItem.GnreRecCod
		&gridGNREVlrTot = &sdtGNREItem.ValorPrincipal
		&gridIEEmi 		= &sdtGNREItem.FilInsEst
		&gridGNRENumRec = &sdtGNREItem.NumRec
		&GridNfeNum 	= &sdtGNREItem.NfeNum
		
		If 	&IsAchou 	= True
			Do 'BuscaPDF'
		EndIf
		
		Load
		
		&GridSdtGnreLinha	+= 1
		If &GridSdtGnreLinha = &GridSdtGnreRows
			&GridSdtGnrePageCount	+= 1
			&GridSdtGnreLinha		= 0
		EndIf
	EndFor

EndEvent

Event GridSdtGnrePaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSdtGnrePaginationBar.SelectedPage = !'Previous'
			&GridSdtGnreCurrentPage -= 1
			GridSdtGnre.PreviousPage()
		Case GridSdtGnrePaginationBar.SelectedPage = !'Next'
			&GridSdtGnreCurrentPage += 1
			GridSdtGnre.NextPage()
		Otherwise
			&PageToGo.FromString(GridSdtGnrePaginationBar.SelectedPage)
			&GridSdtGnreCurrentPage = &PageToGo
			GridSdtGnre.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtGnrePaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtGnre.Rows = GridSdtGnrePaginationBar.RowsPerPageSelectedValue
	&GridSdtGnreCurrentPage = 1
	GridSdtGnre.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ScaProgressBar1.OnComplete

	TbScaProgress.Visible 	= 0
	&IsAchou 				= True
	GridSdtGnre.Refresh()

EndEvent

Event &ImprimirPDF.Click

	&Caminho 					= 	&sdtConfiguracoesPasta.PastaNFretornoVir+'Gnre_'+Trim(Str(&GridNfeNum))+Trim(Str(&gridGNREVlrTot))+'_guias-gnre.pdf'
	OpenNewWindow1.LinkOpen 	= 	&Caminho
	OpenNewWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'BuscaPDF'

	//## Busca o Arquivo em PDF	##\\
	For Each Order EmpCod, FilCod, (GNRENumRec), GNREChavNot, GNRETipo, GNREVlrTot
		Where EmpCod 		= 	&EmpCod
		Where FilCod 		= 	&FilCod
		Where GNREChavNot	= 	&sdtGNREItem.NfeChv
		Where GNREVlrTot 	= 	Trim(Str(&sdtGNREItem.ValorPrincipal, 8, 2)) When Not GNREVlrTot.IsEmpty()
		
		&pdfArquivo 			= 	GNRELotPDF
		&gridGNRENumRec			= 	GNRENumRec
		
		Do Case
			Case GNRESts = '403'
				&StatusProcessamento.ForeColor 	= RGB(128,0,0)
				&StatusProcessamento			= 'Processado com pendência.'
				
			Case (Trim(GNRESts) = '400') or (Trim(GNRESts) 	= '401')
				&StatusProcessamento.ForeColor 	= RGB(184,134,11)
				&StatusProcessamento			= 'Lote Recebido. Aguardando processamento...'
				
			Case GNRESts = '402'
				&StatusProcessamento			= 'Lote processado com sucesso!'
				&StatusProcessamento.ForeColor 	=  RGB(0,100,0)
				&ImprimirPDF.Visible 			= 	1
				
				msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'GNRE de protocolo: ' +  GNRENumRec + ' processada com sucesso.' ,DVMessageType.success, "", DVMessageBoolean.True,"") )
				
		EndCase
		
		If Not GNREErros.IsEmpty() And &IsAchou = True
			&Erros = 'GNRE de protocolo: ' + Trim(GNRENumRec) + ' apresenta erros. ' + Trim(GNREErros)
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", Trim(&Erros)  ,DVMessageType.error, "", DVMessageBoolean.True,"") )
		Else
			&Erros.SetEmpty()
		EndIf
		Exit
		
	EndFor

EndSub


]]></Source>
