Sub 'Funcionario'

	If &MovFunCod = 0
		&MovFunRaz = 'Todos os funcionários!'
	Else		
		For each Order EmpCod,PesIsFun,PesSts,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &MovFunCod when not &MovFunCod.IsEmpty()
			Where PesIsFun = True
			Where PesSts = Status_AtivoInativo.ATIVO
			&MovFunRaz = PesRaz		
			Exit
		When none
			msg('Esta pessoa não é um funcionário, ou não esta ativo, Verifique!')
			&MovFunCod.SetFocus()
		EndFor
	EndIf

EndSub

Sub 'NomeFuncionario'

	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &GridMovFunCod
		&GridPesRaz = str(PesCod)+'-'+trim(PesRaz)
		Exit
	EndFor

EndSub


