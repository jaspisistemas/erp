      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWADIANTAMENTO', Status_SimNao.Sim, 1, &AutNiv)
	&DtaIni = &Today - 45
	&DtaFin = &Today
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&Status = Status_AbertoFechado.Aberto
	Do 'Funcionario'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&MovDoc.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&GridStatus.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

		&GridEmpCod = EmpCod
		&GridMovCod = MovCod
		&GridMovDta = MovDta
		&GridMovVlr = MovVlr
		&GridMovDoc = MovDoc
		&GridMovDtaCon = MovDtaCon
		&GridMovCtaBanCod = MovCtaBanCod
		&GridMovCtaBanNom = str(MovCtaBanCod) +' - '+trim(MovCtaBanNom)
		&GridMovTip = MovTip
		&GridMovItmCod = MovItmCod
		&GridMovFunCod = MovFunCod
		&GridMovFunAno = MovFunAno
		&GridMovFunMes = MovFunMes
		&GridMovItmVlr = MovItmVlr
		&GridStatus = MovFunSts
		&GridMovDoc = MovDoc
		Do 'NomeFuncionario'
		&GridMovDta.Link = ViewMovimento.Link(&GridEmpCod, &GridMovCod, '')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar = !'<i class="fas fa-times"></i>'
	If (&GridStatus = Status_AbertoFechado.Aberto)
		&Deletar.Class = !'Attribute'
	Else
		&Deletar.Class = !'Invisible'
	Endif
	&Recibo = !'<i class="far fa-file-pdf"></i>'
	
	&actionGrids.Clear()
	&actionGrids.AddItem(0, 'WWP_ActionGroupCaption')
	If (&GridStatus = Status_AbertoFechado.Aberto)
		&actionGrids.AddItem(1, 'Descontar Manual')
	Endif
	If &actionGrids.Count = 1
		&actionGrids.Class = !'Invisible'
	Else
		&actionGrids.Class = !'Attribute'
	EndIf

	Do Case
		Case &GridStatus = Status_AbertoFechado.Aberto
			&GridStatus.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case &GridStatus = Status_AbertoFechado.Fechado
			&GridStatus.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			&GridStatus.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
