Event &Recibo.Click

	&sdtRecibo.Clear()
	ValidaRecibo.Call(&GridEmpCod,&GridMovCod)
	If &GridMovTip = TipoMovimento.Manual
		WPRecibo.Call(&GridEmpCod,&GridMovCod)
	Else
		&sdtReciboItem.EmpCod = &GridEmpCod
		&sdtReciboitem.RcbMovCod = &GridMovCod
		&sdtRecibo.Add(&sdtReciboItem)
		&WebSession.Set('ReciboImp',&sdtRecibo.ToXml())
		&ServerTime = ServerTime()
		RCOOpenWindow1.LinkOpen = RELJAS020.Link(&ServerTime,'MOVIMENTO') 
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIf

