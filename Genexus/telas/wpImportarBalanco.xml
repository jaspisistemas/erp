        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	tbNaoLocalizados.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 450
	GridsdtProdutoss.Rows = Page.Rows
	GridsdtProdutossPaginationBar.RowsPerPageSelectedValue = GridsdtProdutoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtProdutossCurrentPage = GridsdtProdutoss.CurrentPage
	&GridsdtProdutossPageCount = GridsdtProdutoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtProdutoss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtProdutossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtProdutossPaginationBar.SelectedPage = !'Previous'
			GridsdtProdutoss.PreviousPage()
		Case GridsdtProdutossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtProdutoss.CurrentPage
			&PageToGo += 1
			GridsdtProdutoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtProdutossPaginationBar.SelectedPage)
			GridsdtProdutoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtProdutossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtProdutoss.Rows = GridsdtProdutossPaginationBar.RowsPerPageSelectedValue
	GridsdtProdutoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	PadraoUsuario.Call('G', '#ARQUIVOSNAOIMPORTADOSBALANCO', &WwpContext.PEsCod, &WwpContext.EmpCod, &SdtProdutos.ToJson(), &PadDtaMod)
	RCOOpenWindow1.LinkOpen = REJAS138.link(&EmpCod, &FilCod, &BalCod, &WwpContext.PesCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FileUpload1.UploadComplete

	tbProgresso.Visible = 0
	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&selectedURL = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			If &selectedURL <> ''	
				tbProgresso.Visible = 1
				
				&ProgressID = serverTime()	
				scaProgressBar1.ProcessId = &ProgressId
				scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
				scaProgressBar1.Start()
				
				

				 PrcImportarBalanco.Submit(&ProgressID, &ProgressID, &EmpCod, &FilCod, &BalCod, &selectedURL, &ExcluirImportar)
				
				
			Else
				msg('Arquivo Inválido!')
			EndIf
		Endif
	EndFor

EndEvent

Event scaProgressBar1.OnComplete

	&MensagemSucesso.SetEmpty()
	&MensagemErro.SetEmpty()
	&SdtProdutos.Clear()

	for Each Order ProgressId
		Where ProgressId = &ProgressID
		&SdtProdutos.FromJson(ProgressLogXml)
		If &SdtProdutos.Count > 0
			tbNaoLocalizados.Visible = 1
		Endif
		Exit
	EndFor
	
	For Each Order ProgressId
		Where ProgressId = 'SUCESSO'+ &ProgressID
		&MensagemSucesso = ProgressLogXml
		Exit
	EndFor
	
	For Each Order ProgressId
		Where ProgressId = 'ERRO'+ &ProgressID
		&MensagemErro = ProgressLogXml
		Exit
	Endfor

EndEvent


]]></Source>
