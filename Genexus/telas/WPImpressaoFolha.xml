      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPIMPRESSAOFOLHA', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&Ano = Year(&Today)
	&Mes = Month(&Today)-1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&IsSintetico.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&Tipo = 2)
		&Ordenar.Visible = False
		Ordenar_Cell.Class = !'Invisible'
	Else
		&Ordenar.Visible = True
		Ordenar_Cell.Class = !'col-xs-12 col-sm-6 DataContentCell'
	EndIf
	If Not (&Tipo = 2)
		&FolPgtCtaBanCod.Visible = False
		FolPgtCtaBanCod_Cell.Class = !'Invisible'
	Else
		&FolPgtCtaBanCod.Visible = True
		FolPgtCtaBanCod_Cell.Class = !'col-xs-12 col-sm-6 DataContentCell'
	EndIf
	If Not (&Tipo = 2)
		&FolPgtCtaTip.Visible = False
		FolPgtCtaTip_Cell.Class = !'Invisible'
	Else
		&FolPgtCtaTip.Visible = True
		FolPgtCtaTip_Cell.Class = !'col-xs-12 col-sm-6 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Tipo.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event Enter

	Do Case
		Case &Tipo = 1 //Folha
			Do 'ImpressaoFolha'
			&randon = serverNow()
			RCOOpenWindow1.LinkOpen = RELJAS051_FolhaPagamento.Link(&IsSintetico,&randon)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Case &Tipo = 2 //LISTAGEM
			RCOOpenWindow1.LinkOpen = RELJAS079_PagamentoFolha.Link(&EmpCod,&FilCod,&Ano,&Mes,&FunCod,&DataVazia,&FolPgtCtaBanCod,&FolPgtCtaTip,&Ordenar, &DiariaFolha)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent

Event &FunCod.IsValid

	Do 'Funcionario'

EndEvent

Sub 'ImpressaoFolha'

	&FolhaPgto.Clear()
	For each Order EmpCod,PesSts,PesFunFilCod,PesIsFun,PesCod
		Where EmpCod = &EmpCod
		Where PesFunFilCod = &FilCod when &FilCod <> 0
		Where PesCod = &FunCod when not &FunCod.IsEmpty()
		Where PesIsFun = True
		Where PesSts = Status_AtivoInativo.ATIVO
		Where not PesDtaAdm.IsEmpty()
		Where PesSalTotRec > 0
		Where PesSalTip = &PesSalTip when not &PesSalTip.IsEmpty()
		&AuxFunCod = PesCod
		
		For each Order EmpCod, FPagCod
			Where EmpCod = &EmpCod
			Where FPagAno = &Ano
			Where FPagMes = &Mes when not &Mes.IsEmpty()
			Where FPagPesCod = &AuxFunCod
			Where FPagTip = TIpoPagamentoFolha.FolhaMensal when &DiariaFolha = 'F' 
			Where FPagTip = TIpoPagamentoFolha.PagamentoDiarias when &DiariaFolha = 'D'
			Where FPagTip = TIpoPagamentoFolha.PagamentoDiarias or FPagTip = TIpoPagamentoFolha.FolhaMensal when &DiariaFolha = 'T'
			
			&FolhaPgtoItem = new()
			&FolhaPgtoItem.EmpCod = EmpCod
			&FolhaPgtoItem.FolFunCod = FPagPesCod
			&FolhaPgtoItem.FolAno = FPagAno
			&FolhaPgtoItem.FolMes = FPagMes
			&FolhaPgto.Add(&FolhaPgtoItem)
		Endfor
	EndFor
	&WebSession.Set('FolhaPagamento',&FolhaPgto.ToXml())

EndSub

Sub 'funcionario'

	If &FunCod = 0
		&FunNom = 'Todos os funcionários'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &FunCod
			Where PesIsFun = True
			Where PesSts = Status_AtivoInativo.ATIVO
			&FunNom = PesRaz
			Exit
		When none
			msg('Pessoa não encontada por não ser um funcionário ou estar inativo. Verifique!')
			&FunNom = 'Pessoa não encontada Verifique!'
			&FunCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
