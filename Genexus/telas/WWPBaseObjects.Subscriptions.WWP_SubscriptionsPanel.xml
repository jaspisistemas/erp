      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPNotificationDefinitionId.Visible = False
	&WWPSubscriptionId.Visible = False

	Grid.Rows = Page.Rows

	Do 'PrepareTransaction'
	Do 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each WWPBaseObjects.WWP_Entity
		Where WWPEntityName.ToLower() = &WWPEntityName.ToLower()
		&WWPEntityId = WWPEntityId
		Exit
	EndFor
	&WWPSubscriptionRoleIdCollection = WWPBaseObjects.WWP_GetLoggedUserRoles()

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&WWPNotificationId = WWPNotificationDefinitionId
	Do 'LoadCheckIncludeNotifications'

EndEvent

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"WWPBaseObjects.Notifications.Common.WWP_NotificationDefinition"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event TableSubscriptionItem.Click

	&IncludeNotification = not &IncludeNotification
	WWPBaseObjects.Subscriptions.WWP_UserUpdateSubscription(&IncludeNotification, &WWPSubscriptionId, WWPNotificationDefinitionId, &WWPSubscriptionEntityRecordId, &RecordAttDescription)

	If 1 = 0
		For Each line 
			//Dummy
		EndFor
	EndIf

EndEvent

Sub 'LoadCheckIncludeNotifications'

	&IncludeNotification = False
	For Each WWPBaseObjects.Subscriptions.WWP_Subscription
		Where (WWPUserExtendedId = WWP_GetLoggedUserId() And WWPSubscriptionSubscribed) Or WWPSubscriptionRoleId In &WWPSubscriptionRoleIdCollection
		Where WWPNotificationDefinitionId = &WWPNotificationId
		Where WWPSubscriptionEntityRecordId = &WWPSubscriptionEntityRecordId When &WWPSubscriptionEntityRecordId <> ''
		&WWPSubscriptionId = WWPSubscriptionId
		&IncludeNotification = True
		If Not WWPSubscriptionRoleId.IsEmpty()
			&IncludeNotification = WWPBaseObjects.Subscriptions.WWP_CheckUserIsNotUnsubscribed(&WWPNotificationDefinitionId, &WWPSubscriptionId)
		EndIf
		Exit
	EndFor

EndSub


]]></Source>
