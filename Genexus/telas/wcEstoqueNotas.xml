Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtEstoques.Rows = Page.Rows
	GridsdtEstoquesPaginationBar.RowsPerPageSelectedValue = GridsdtEstoques.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	CarregaSDT_EstoqueFiscal.Call(&EmpCod,&FilCod,&ProCod,&ProGraCod,&sdtEstoque)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtEstoquesCurrentPage = GridsdtEstoques.CurrentPage
	&GridsdtEstoquesPageCount = GridsdtEstoques.PageCount
	sdtEstoque__LctAtuEst.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtEstoques.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	Do Case
		Case &sdtEstoque.CurrentItem.LctAtuEst = Status_EntradaSaida.Entrada
			sdtEstoque__LctAtuEst.ColumnClass = !'WWColumn WWColumnInfo WWColumnInfoSingleCell'
		Case &sdtEstoque.CurrentItem.LctAtuEst = Status_EntradaSaida.Saida
			sdtEstoque__LctAtuEst.ColumnClass = !'WWColumn WWColumnDanger WWColumnDangerSingleCell'
		Otherwise
			sdtEstoque__LctAtuEst.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtEstoquesPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtEstoquesPaginationBar.SelectedPage = !'Previous'
			GridsdtEstoques.PreviousPage()
		Case GridsdtEstoquesPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtEstoques.CurrentPage
			&PageToGo += 1
			GridsdtEstoques.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtEstoquesPaginationBar.SelectedPage)
			GridsdtEstoques.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtEstoquesPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtEstoques.Rows = GridsdtEstoquesPaginationBar.RowsPerPageSelectedValue
	GridsdtEstoques.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


