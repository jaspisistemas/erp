      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&exit = &WebSession.Get('wpEditDadosCArtao')
	&WebSession.Remove('wpEditDadosCArtao')
	if &Exit = 'S'
		Return
	Endif

	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		
		&CreCarArqc = CreCarArqc
		&CreCarBanCod = CreCarBanCod
		&CreCarNroAut = CreCarNroAut
		&CreCarBanNom = CreCarBanNom
		&CreCarCardNom = CreCarCardNom
		&CreCarNroNsu = CreCarNroNsu
		&BanCarCod = CreCarBanCod
		&CreCarTax = CreCarTax
		do 'GetBandeira'
		if &CreCarNroAut.IsEmpty() and &BanCarConfAut = 'J' //BAIXA MAQUININHA JASPI
			wpSelecionaPagamentoZoop.Link(&EmpCod, &FilCod, &zoopID, &CreCod)
		EndiF
	
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	prcGravaDadosBandeiraDuplicata.Call(&EmpCod, &FilCod, &CreCod, &CreCarArqc, &CreCarBanCod, &CreCarNroAut, &CreCarNroNsu, &CreCarBanNom, &CreCarCardNom, &CreCarTax)
	do 'Reparacao'
	AtualizaSaldoDuplicata.Call(&EmpCod,&CreCod,&FilCod)
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLocalizarPagamentoZoop'

	wpSelecionaPagamentoZoop.Link(&EmpCod, &FilCod, &zoopID, &CreCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'GetBandeira'

	&BanCarConfAut.SetEmpty()
	For Each Order EmpCod, BanCod
		Where EmpCod = &EmpCod
		Where BanCarCod = &BanCarCod
		
		&BanCarConfAut = BanCarConfAut
		Exit
	EndFor

EndSub

Sub 'reparacao'

	if not &CreCarNroAut.IsEmpty()
		//TRANSACAO
		For Each Order EmpCod, FilCod, ZoopId
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			//Where ZoopId = &InOutZoopId
			Where ZoopCardId = &CreCarNroAut
			Where ZoopCardNSU = &CreCarNroNsu when Not &CreCarNroNsu.IsEmpty()
			
			&zoopEvent = new()
			&zoopEvent.fee_details.Clear()
			&zoopEvent.history.Clear()
			&zoopEvent.FromJson(ZoopObs)
			prcGravaRegistroEntradaZoop.Call(EmpCod, FilCod, &zoopEvent, ZoopObs)
			
			//RECEBIVEIS
			For Each Order EmpCod, FilCod, ZoopId, ZoopHisDta
				&AuxZoopEvent = new()
				&AuxZoopEvent.fee_details.Clear()
				&AuxZoopEvent.history.Clear()
				&AuxZoopEvent.FromJson(ZoopHisObs)
				prcGravaRegistroEntradaZoop_Recebimento.Call(EmpCod, FilCod, &AuxZoopEvent, ZoopHisObs)
			EndFor
		EndFor
	Endif

EndSub


]]></Source>
