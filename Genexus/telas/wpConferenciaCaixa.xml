Sub 'loadCaixa'

	For Each Order EmpCod, CxPdvCod, CxCod
		Where EmpCod = &EmpCod
		Where CxPdvCod = &CxPdvCod
		Where CxCod = &CxCod
	
	
		 &CxUsuDin =CxUsuDin
		 &CxUsuChq =CxUsuChq
		 &CxUsuCar =CxUsuCar
		 &CxUsuCre =CxUsuCre
		
		do 'getNomeCaixa'
		txtDadosCAixa.Caption = format('CAIXA %1, ABERTURA: %2, FECHAMENTO: %3', trim(&PdvId), trim(toformattedString(CxDtaHorIni)), trim(toFormattedString(CxDtaHorFin)))
		Exit
	EndFor

EndSub

Sub 'getNomeCaixa'

	For Each ORder EmpCod, PdvCod
		Where EmpCod = &EmpCod
		Where PdvCod = &CxPdvCod
		&PdvId = PdvId
		Exit
	EndFor

EndSub


