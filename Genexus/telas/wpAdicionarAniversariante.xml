      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&AnvUsuCod  = &wwpContext.PesCod
	txtAviso.Caption = ''
	
	if &AnvCod > 0
		&EmpCod = &ParEmpCod
		do 'loadAniversariante'
	Else
		&EmpCod = &wwpContext.EmpCod
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&AnvCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	FormataFone.Call(&AnvTel, &AnvTel)
	do 'ValidaEmail'
	
	Do case
		cAse &AnvNom.IsEmpty()
			&Mensagem = 'Informe o nome do aniversariante.'
			do 'erro'
			&AnvNom.SetFocus()
		Case &AnvDtaNas.IsEmpty()
			&Mensagem = 'Informe a data de nascimento do aniversariante.'
			do 'erro'
			&AnvDtaNas.SetFocus()
		case &IsErrorEmail = true
			Do 'erro'
			&AnvEml.SetFocus()
		Otherwise
			prcAtualizaAniversariantes.Call('ADD', &EmpCod, &AnvNom, TipoAniversario.Avulso, &AnvTod, &AnvUsuCod, &AnvObs, &AnvDtaNas, &AnvDia, &AnvMes, &AnvTel, &AnvEml)
			Return
	Endcase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AnvTel.IsValid

	FormataFone.Call(&AnvTel, &AnvTel)

EndEvent

Event &AnvEml.IsValid

	do 'ValidaEmail'

EndEvent

Sub 'ValidaEmail'

	&IsErrorEmail = false
	&EmailVerificacao = &AnvEml
	
	&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
	if (&EmailVerificacao.IsMatch(&pattern) = false) and not &AnvEml.IsEmpty()
		&Mensagem = ' Endereço de E-mail não coincide com o padrão!'
		do 'erro'
		&IsErrorEmail = True
	EndIf

EndSub

Sub 'erro'

	txtAviso.Caption = &Mensagem
	txtAviso.ForeColor = RGB(200,0,0)

EndSub

Sub 'loadAniversariante'

	For Each Order EmpCod, AnvCod
		Where EmpCod = &EmpCod
		Where AnvCod = &AnvCod
		
		&AnvNom = AnvNom
		&AnvTod = AnvTod
		&AnvUsuCod = AnvUsuCod
		&AnvObs = AnvObs
		&AnvDtaNas = AnvDtaNas
		&AnvDia = AnvDia
		&AnvMes = AnvMes
		&AnvTel = AnvTel
		&AnvEml = AnvEml
		&AnvTip = AnvTip
		&AnvID1 = AnvID1
		&AnvID2 = AnvID2 
		Exit
	EndFor

EndSub


]]></Source>
