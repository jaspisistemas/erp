      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&NfsMotObs = 'NOTA EMITIDA COM DIVERGENCIA DE INFORMACOES, CANCELAMENTO SOLICITADO'
	loadWWPContext.Call(&Context)
	&tmpNfeEnvEml = true

	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NfsCod
		&NfeCliRaz = trim(str(NfsCliCod)) + ' - ' + trim(NfsCliRaz)
		&NfeNum = NfsNum
		&NfsFilCod = NfsFilCod
		&NfeDtaEms = NfsDtaEms
		//&FilCodNom = NfsFil
		&NfeVlrTot = NfsVlrTot
		&NfeChv = NfsChv
//		&NfeAutNumPro = NfeAutNumPro
		
		if not NfsCliEml.IsEmpty()
			&PesEml  = NfsCliEml
			Else
		EndIF
	
		If NfsChv.IsEmpty()
			msg('NFS-e não possui a chave de Acesso.')
		EndIF
	
		Exit
	EndFor
	
//	obs.ForeColor = RGB(0,0,150)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	if &DeOndeVem = 'WWNOTASSERVICO'
		wwNotasServico.Link()
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	loadWWPContext.Call(&Context)
	&NfsMotObs = retiraCaracteresEspeciais.Udp(&NfsMotObs)
	Do 'Verifica_especial'
	
	Do Case
		Case &NfeChv.IsEmpty()
			msg('NFe não possui a chave da NFe, só pode cancelar uma Nota se a Mesma Estiver Autorizada!')
//		Case &NfeAutNumPro.IsEmpty()
//			msg('NFe não possui número do Protocolo, Consulte a Nota no SEFAZ!')
		Case &erro = 0
			GeraXmlCancelamentoNFSe.Call(&EmpCod, &NfsFilCod, &NfsCod, &xJust, &NfsMotObs, &Context.PesCod, &SolCod)
			
			wpCancelandoNFSe.Link(&EmpCod, &NfsCod, &SolCod)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &xJust.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Motivo do Cancelamento'), DVMessageType.error, &xJust.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &NfsMotObs.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Justificativa'), DVMessageType.error, &NfsMotObs.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Verifica_especial'

    &erro = 0 
    &Tamanho = len(&NfsMotObs)
    if &tamanho < 15 or &tamanho > 255
        msg('Tamanho da justificativa tem que ficar entre 15 e 255')
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&NfsMotObs,&Posicao,1) < ' '  or (substr(&NfsMotObs,&Posicao,1) > 'z'  ))
                msg('Caracter especial '+  substr(&NfsMotObs,&Posicao,1) + 'Não é permitido' ) 
                &erro = 1
            Endif
        EndFor
    EndIf

EndSub


]]></Source>
