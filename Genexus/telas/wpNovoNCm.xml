      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	For Each Order NcmCod
		Where NcmCod = &NcmCod
		&NcmDes = NcmDes	
		
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'loadNcm'
	if &IsErroNCM = false
		prcAtualizaNcmProdutos.Call(&EmpCod, &NcmCod, &NovNcmCod, &Context.UserName)
		Return
	Else
		msg(&NovNcmDes)
	Endif

EndEvent

Event &NovNcmCod.IsValid

	do 'loadNcm'

EndEvent

Sub 'loadNcm'

	&NovNcmDes.SetEmpty()
	&IsErroNcm = true
	For Each Order NcmCod
		Where NcmCod = &NovNcmCod
		&NovNcmDes = NcmDes	
		&IsErroNCM = false
		
		if NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()
			&NovNcmDes = ' FIM DA VIGENCIA DO NCM: ' + trim(str(NcmCod))
			&IsErroNCM = true
		Endif
		
		Exit
	When none
		Do CAse
			CAse &NovNcmCod =  0
				&NovNcmDes = 'CÓDIGO 00000000 - SERVIÇOS'
				&IsErroNCM = false
			CAse &NovNcmCod =  99
				&NovNcmDes = 'CÓDIGO NCM NÃO INFORMADO!'
			Otherwise
				&NovNcmDes = 'CÓDIGO NCM NÃO CADASTRADO/INVÁLIDO!'
		EndCAse
	EndFor

EndSub


]]></Source>
