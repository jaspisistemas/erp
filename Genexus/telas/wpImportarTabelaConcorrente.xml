      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tb2.Visible = 1
	tb1.Visible = 0
	informativo.ForeColor = RGB(20,120,75)
	LoadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	&IsGrid2 = false
	&IsGrid1 = false
	&PrimeiraLinha = 2
	&ColunaProduto = 1
	&CodConcorrente = 2
	&Colunavlr = 3
	TextBlockTitle.Caption = 'Importar Produtos do Concorrente: ' + trim(str(&ConCod))
	
	padraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
	if not &padObs.IsEmpty()
		&PrimeiraLinha = val(Substr(&padObs, 1, 3))
		&ColunaProduto = val(Substr(&padObs, 4, 3))
		&Colunavlr = val(Substr(&padObs, 7, 4))
		&CodConcorrente = val(Substr(&padObs, 11, 4))
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	Grid.Rows = 2000
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	Grid2.Rows = 2000
	&Grid2CurrentPage = 1
	&Grid2CurrentPage.Visible = False
	&Grid2PageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows
	Grid2PaginationBar.RowsPerPageSelectedValue = Grid2.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	//The variable '&Grid2PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&count = 0
	&IsGrid1 = false
	for &SdtProdutoConcorrenteItem in &SdtProdutoConcorrente
		If &SdtProdutoConcorrenteItem.Erro = 'N'
			&IsGrid1 = true
			&grid1ProCod = &SdtProdutoConcorrenteItem.ProCod
			&grid1ProNom = &SdtProdutoConcorrenteItem.ProNom
			&Grid1ConForCod = &SdtProdutoConcorrenteItem.ConForCod
			&Grid1ProVlr = &SdtProdutoConcorrenteItem.ProVlr
			&count +=1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			load
		EndIF
	EndFor
	
	Do 'AttributesSecurityCode'

EndEvent

Event Grid2.Load

	&IsGrid2 = false
	&Grid2Mensagem.ForeColor = RGB(150,0,20)
	for &SdtProdutoConcorrenteItem in &SdtProdutoConcorrente
		If &SdtProdutoConcorrenteItem.Erro = 'S'
			&IsGrid2 = true
			
			&grid2ProCod = &SdtProdutoConcorrenteItem.ProCod
			&grid2ProNom = &SdtProdutoConcorrenteItem.ProNom
			&Grid2Mensagem = &SdtProdutoConcorrenteItem.Mensagem

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			load
		EndIF
	EndFor
	
	Do 'AttributesSecurityCode'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid2PaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case Grid2PaginationBar.SelectedPage = !'Previous'
			&Grid2CurrentPage -= 1
			Grid2.PreviousPage()
		Case Grid2PaginationBar.SelectedPage = !'Next'
			&Grid2CurrentPage += 1
			Grid2.NextPage()
		Otherwise
			&PageToGo.FromString(Grid2PaginationBar.SelectedPage)
			&Grid2CurrentPage = &PageToGo
			Grid2.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid2PaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid2.Rows = Grid2PaginationBar.RowsPerPageSelectedValue
	&Grid2CurrentPage = 1
	Grid2.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConcorrente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWConcorrente.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoHelp1'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	AjudaImportarConcorrente.PopUp()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&IsGrid2 = true)
		DVPanel_panelIrregu_Cell.Class = !'Invisible'
	Else
		DVPanel_panelIrregu_Cell.Class = !'col-xs-12 CellMarginTop'
	EndIf
	If not(&IsGrid1 = true)
		DVPanel_tbIntes_Cell.Class = !'Invisible'
	Else
		DVPanel_tbIntes_Cell.Class = !'col-xs-12 CellMarginTop'
	EndIf
	If not(&IsGrid2 = true)
		DVPanel_NaoAdicionados_Cell.Class = !'Invisible'
	Else
		DVPanel_NaoAdicionados_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	WWConcorrente.Link()

EndEvent

Event Enter

	If &SdtProdutoConcorrente.Count > 0
		&IsPossui = False
		For &SdtProdutoConcorrenteItem in &SdtProdutoConcorrente
			If &SdtProdutoConcorrenteItem.Erro = 'N'
				&IsPossui = true
			EndIF
		EndFor
		
		If &IsPossui = true 
			&padObs = PadL(str(&PrimeiraLinha), 3, ' ') +  PadL(str(&ColunaProduto), 3, ' ') + PadL(str(&Colunavlr), 4, ' ') + PadL(str(&CodConcorrente), 4, ' ')
			padraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
			
			tb2.Visible = 0
			tb1.Visible = 1
			&ProgressId = 'ImportaTabelaConcorrente' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			ProdutosImportadosConcorrentes.Submit('ProdutosImportadosConcorrentes', &ProgressId, &EmpCod, &ConCod, &SdtProdutoConcorrente)
		Else
			msg('Nenhum produto sem erro a ser gravado.')
		EndIF
	Else
		msg('Nenhum produto a ser gravado.')
	EndIf

EndEvent

Event FileUpload1.UploadComplete

	&SdtProdutoConcorrente.Clear()
	
	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&selectedURL = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			ImportaTabelaConcorrente.Call(&EmpCod, &ConCod, &selectedURL, &PrimeiraLinha, &ColunaProduto, &Colunavlr,&CodConcorrente ,&SdtProdutoConcorrente)
			
			grid2.Refresh()
			grid.Refresh()
		EndiF
	endfor

	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent


]]></Source>
