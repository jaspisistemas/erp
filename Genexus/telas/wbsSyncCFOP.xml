      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&Clique = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadEmpresa'

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	progress.Visible = (&Clique = 1)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	&Clique = 1
	Do 'AttributesSecurityCode'
		
	HostWebServiceJaspiADM.Call(&Context.EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	&Location = GetLocation('ppJASPI_CFOP') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost //servidor 
	&Location.Port = &EmpWebPor //porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	&Location.Secure = false //false 
	&Location.CancelOnError = 2 //tratar exceção do WS 	
	
	&ppJASPI_CFOPsdtEstruturaCFOP = &ppJASPI_CFOP.Execute(&EmpSyncCfop, &EmpCodSec)
	
	If GetSOAPErr()= 0 
		&ProgressId = 'prcWbsCFOP' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		prcWbsCFOP.Submit('prcWbsCFOP', &ProgressId, &Context.EmpCod, &ppJASPI_CFOPsdtEstruturaCFOP)
	Else 
		&Msg = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&Msg += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&Msg) 
	EndIf

EndEvent

Event scaProgressBar1.OnComplete

	&Clique = 0
	Do 'AttributesSecurityCode'
	do 'LoadEmpresa'
	msg('Cadastro Syncronizado com sucesso!')

EndEvent

Sub 'LoadEmpresa'

	For Each Order EmpCod
		Where EmpCod = &Context.EmpCod
		&EmpCodSec = EmpCodSec
		&EmpSyncCfop = EmpSyncCfop
		
		Exit
	EndFor
	if &EmpSyncCfop.IsEmpty()
		&EmpSyncCfop = CtoD('01/01/2001')
	EndIF

EndSub


]]></Source>
