        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	EmpCod.Visible = False
	MovCtaBanFilCod.Visible = False
	MovMaxItm.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//wpMovimento.Link(TrnMode.Update, EmpCod, CreMovCod, 0)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	MovItmCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	PlanCod.ColumnHeaderClass = !'WWColumn'
	MovItmCpl.ColumnHeaderClass = !'WWColumn hidden-xs'
	MovItmVlr.ColumnHeaderClass = !'WWColumn'
	MovFunCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	MovCreCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	MovCrePagCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	MovTrnOriCod.ColumnHeaderClass = !'WWColumn hidden-xs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	MovItmCod.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn hidden-xs')
	PlanCod.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn')
	MovItmCpl.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn hidden-xs')
	MovItmVlr.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn')
	MovFunCod.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn hidden-xs')
	MovCreCod.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn hidden-xs')
	MovCrePagCod.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn hidden-xs')
	MovTrnOriCod.ColumnClass = iif(MovItmSts = Status_Caixa.Cancelado, !'WWColumn hidden-xs WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn hidden-xs')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	MovCod.Link = wpMovimento.Link(TrnMode.Update, EmpCod, MovCod, 0)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


