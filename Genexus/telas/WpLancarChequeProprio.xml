      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&FilCod = &Context.FilCod
	&CrefilPgt = &Context.FilCod
	
	&CreRecPag = ReceberPagar.Pagar
	&CreRecPag.Enabled = 0
	
	&CheTip = TipoCheque.Proprio
	
	&CheCtaBanCod.Clear()
	For Each Order EmpCod, CtabanCod
		Where EmpCod = &EmpCod
		&CheCtaBanCod.AddItem(CtabanCod, CtaBanCodNom)
	EndFor

	if &CheCod > 0
		do 'LoadLancamento'
		&ChePlanCod = retornaMesmoValor.Udp(&PlanCodNomVir, &EmpCod)
	else
		RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon044_PlanoRecCliente, &TCon044_PlanoRecCliente)
		&ChePlanCod = retornaMesmoValor.Udp(&TCon044_PlanoRecCliente, &EmpCod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	t.Width = 180

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&AuxPlanCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAddCliente'

	WpNovaPessoa.PopUp('CLI', &CreCliCod, '')
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbObs.Visible = (&CheCod = 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&ErroMensagem.SetEmpty()
	ValidaChequesTerceiros.call(&EmpCod, &CheCod, &CheBanCod, &CheAgeCod, &CheCon, &CheNro, &ErroChequeMensagem, &AlertaMensagem)
	RetornaCodigoPlanoContas.Call(&EmpCod, &ChePlanCod, &PlanCod)
	
		Do 'ValidaLocalCobranca'
		do 'ValidaVendedor'
		
		Do Case
			CAse not &ErroChequeMensagem.IsEmpty()
				&ErroMensagem = &ErroChequeMensagem
			Case &CreCliRaz.IsEmpty()
				&ErroMensagem = 'Fornecedor Inválido!'
				&CreCliCod.SetFocus()
			Case &CheVlr <= 0
				&ErroMensagem = 'Valor do Cheque é obrigatório!'
				&CheVlr.SetFocus()
			Case &CheDtaEmi.IsEmpty()
				&ErroMensagem = 'Emissão do Cheque é obrigatório!'
				&CheDtaEmi.SetFocus()
			Case &CheDtaVct.IsEmpty()
				&ErroMensagem = 'Vencimento do Cheque é obrigatório!'
				&CheDtaVct.SetFocus()
			Case &CheTitNom.IsEmpty()
				&ErroMensagem = 'Titular do Cheque é obrigatório!'
				&CheTitNom.SetFocus()
			Case &PlanCod.IsEmpty()
				&ErroMensagem = 'Informe Plano de Contas!'
				&ChePlanCod.SetFocus()
//			Case &CreCbrNom.IsEmpty()
//				&ErroMensagem = 'Local Cobrança inválido!'
//				&CreCbrCod.SetFocus()
			Case &CreVenNom.IsEmpty()
				&ErroMensagem = 'Vendedor Informado Inválido!'
				&CreVenCod.SetFocus()
			
			Otherwise
				
				//PrcGravaChequeTabelaChequeDuplicata.Call('ADD',&EmpCod, &FilCod, &CheCod,&CheTip,&TalCod,&TalCtabanCod,&CheCom,&CheBanCod,&CheAgeCod,&CheCon,&CheNro,&CheVlr,&CheDtaEmi,&CheDtaVct,&CheTitNom,&CheTitCpf,&CheTitRg,&CheTel,&CheCmc,&CheObs, &CreCliCod, &CreVenCod, &CreCbrCod,&PlanCod, &CreDtaCrt,&CreDtaPrt,&CreFilPgt, &CreIsPer, &CheCtaBanCod)
				Return
				
		Endcase

Return

EndEvent

Event &CreCliCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &CreCliCod, &CreCliRaz)
	if &CheTitNom.IsEmpty()
		&CheTitNom = &CreCliRaz
	Endif

EndEvent

Event &CreVenCod.IsValid

	do 'ValidaVendedor'

EndEvent

Event &CreCbrCod.IsValid

	Do 'ValidaLocalCobranca'

EndEvent

Sub 'LoadLancamento'

	//TABELA CHEQUE
	For Each order EmpCod, CheCod
		Where EmpCod = &EmpCod  
		Where CheCod = &CheCod
		
		&CheBanCod = CheBanCod
		&CheAgeCod = CheAgeCod
		&CheCon = CheCon
		&CheNro = CheNro
		&CheVlr = CheVlr
		&CheDtaEmi = CheDtaEmi
		&CheDtaVct = CheDtaVct
		&CheTitNom = CheTitNom
		&CheCmc = CheCmc
		
		&CheTip = CheTip
		&TalCod = TalCod
		&TalCtabanCod = TalCtabanCod
		&CheCom = CheCom
		
		&CheMot = CheMot
		&CheCtaBanCod = TalCtabanCod
		Exit
	EndFor

	//TABELA DUPLICATA
	For Each order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod  
		Where CreCheCod = &CheCod
		
		&PlanCodNomVir = CrePlanHie
		
		&CreCliCod = CreCliCod
		&CreCliRaz = CreCliRaz
		&CreVenCod = CreVenCod
		&CreVenNom = CreVenNom
		&CreCbrCod = CreCbrCod
		&CreCbrNom = CreCbrNom
		&CrePedCod = CrePedCod
		If ((CreVlrTotPgto > 0) or (not CrePedCod.IsEmpty()) or (not CreFrtCod.IsEmpty()) or (not CreNfeCod.IsEmpty()))
			&CreFilPgt.Enabled = false
		Else
			&CreFilPgt.Enabled = true
		EndIf

		&CreFilPgt = CreFilPgt
		&CreDtaCrt = CreDtaCrt
		&CreDtaPrt = CreDtaPrt
		&CreVlrSdo = CreVlrSdo
		Exit
	EndFor	
	
	if &CrePedCod <> 0
		//BLOQUEIA CAMPOS DO PEDIDO
		&CreCliCod.Enabled = 0
		&CreVenCod.Enabled = 0
		btnAddCliente.Visible = 0
	Endif

	if &OqueFazer = 'DEL'
		btnAddCliente.Visible = 0
		&CheVlr.Enabled = 0
		&CheDtaEmi.Enabled = 0
		&CheDtaVct.Enabled = 0
		&CheTitNom.Enabled = 0
		&ChePlanCod.Enabled = 0
	EndIF

EndSub

Sub 'ValidaVendedor'

	&CreVenNom.SetEmpty()
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CreVenCod
		Where PesIsVen = true
		&CreVenNom = PesRaz
		Exit
	Endfor

EndSub

Sub 'ValidaLocalCobranca'

	&CreCbrNom.SetEmpty()
	For Each Order EmpCod, CbrCod
		Where EmpCod = &EmpCod
		Where CbrCod = &CreCbrCod
		&CreCbrNom = CbrNom
		Exit
	EndFor

EndSub


