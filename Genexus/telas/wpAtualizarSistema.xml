        <Source><![CDATA[
Event Start

	Compilacao.Call(false, &Compilacao, &isexecutaUpdate, &EmpVer, &EmpCmp)
	
	For Each Order EmpCod
		&EmpAgeUpd = EmpAgeUpd
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVerificarAtualizacoes'

	if &EmpAgeUpd.IsEmpty()
		msg('Não Configurado update!')
	Else
		&File.Source = '_startAgendador.bat'
		&CaminhoExecutar = &File.GetPath()
		&File.Close()
		
		&CaminhoExecutar += '/bin/'+ '_startAgendador.bat ' + &EmpAgeUpd.Trim()
		&CaminhoExecutar = &CaminhoExecutar.Replace('/', '\')
		&CaminhoExecutar = &CaminhoExecutar.Replace('\\', '\')
		&executa = Shell(&CaminhoExecutar, 0)
		//msg(&CaminhoExecutar)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


