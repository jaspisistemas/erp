      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Form.Backcolor = rgb(238,238,238)
	LayoutMainTable.Class = ThemeClass:MainContainer
	TableError.Visible = False
	
	&User = GAMRepository.GetUserByKeyToCompleteUserData(&Errors)
	If &Errors.Count > 0
		Do 'DisplayMessages'
	Else
		//Gets last error in the GAM 
		&Errors = GAMRepository.GetLastErrors()
		Do 'DisplayMessages'
		&Name 		= &User.Name
		&EMail		= &User.EMail
		&FirstName	= &User.FirstName
		&LastName	= &User.LastName
		&Birthday	= &User.Birthday
		&Gender		= &User.Gender
	Endif
	&Repository = GAMRepository.Get()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &Name.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','WWP_GAM_UserName'), DVMessageType.error, &Name.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&Repository.RequiredEmail) AND &EMail.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','WWP_GAM_Email'), DVMessageType.error, &EMail.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&Repository.RequiredFirstName) AND &FirstName.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','WWP_GAM_FirstName'), DVMessageType.error, &FirstName.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&Repository.RequiredLastName) AND &LastName.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','WWP_GAM_LastName'), DVMessageType.error, &LastName.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&Repository.RequiredBirthday) AND &Birthday.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','WWP_GAM_Birthday'), DVMessageType.error, &Birthday.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&Repository.RequiredGender) AND &Gender.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','WWP_GAM_Gender'), DVMessageType.error, &Gender.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If &Repository.RequiredEmail
		EMail_Cell.Class = !'col-xs-12 RequiredDataContentCellLogin CellPaddingLogin'
	Else
		EMail_Cell.Class = !'col-xs-12 DataContentCellLogin CellPaddingLogin'
	EndIf
	If &Repository.RequiredFirstName
		FirstName_Cell.Class = !'col-xs-12 RequiredDataContentCellLogin CellPaddingLogin'
	Else
		FirstName_Cell.Class = !'col-xs-12 DataContentCellLogin CellPaddingLogin'
	EndIf
	If &Repository.RequiredLastName
		LastName_Cell.Class = !'col-xs-12 RequiredDataContentCellLogin CellPaddingLogin'
	Else
		LastName_Cell.Class = !'col-xs-12 DataContentCellLogin CellPaddingLogin'
	EndIf
	If &Repository.RequiredBirthday
		Birthday_Cell.Class = !'col-xs-12 RequiredDataContentCellLogin CellPaddingLogin'
	Else
		Birthday_Cell.Class = !'col-xs-12 DataContentCellLogin CellPaddingLogin'
	EndIf
	If &Repository.RequiredGender
		Gender_Cell.Class = !'col-xs-12 RequiredDataContentCellLogin CellPaddingLogin'
	Else
		Gender_Cell.Class = !'col-xs-12 DataContentCellLogin CellPaddingLogin'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult
		&User = GAMRepository.GetUserByKeyToCompleteUserData(&Errors)
		&User.Load(&User.GUID)
		&User.Name			= &Name
		&User.EMail			= &EMail
		&User.FirstName		= &FirstName
		&User.LastName		= &LastName
		&User.Birthday		= &Birthday
		&User.Gender.FromString(&Gender)
		&isOK = GAMRepository.UpdateUserByKeyToCompleteUserData(&User, &Errors)
		If &isOK
			If &Errors.Count > 0
				Msg("WWP_GAM_DataSuccessfullyUpdated")
				Do 'DisplayMessages'
			Else	
				If GAMRepository.IsRemoteAuthentication(&IDP_State)
					//Redirect to remote authentication
					GAMRepository.RedirectToRemoteAuthentication(&IDP_State)
				Else
					&URL = GAMRepository.GetLastErrorsURL()
					If &URL.IsEmpty()
						GAMRepository.ApplicationGoHome(GAMInternalGUIDs.AppGAMUserBackend)
					Else
						Link(&URL)
					Endif
				Endif
			Endif
		Else
			Do 'DisplayMessages'
		Endif
	Endif

EndEvent

Sub 'DisplayMessages'

	TableError.Visible = True
	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


]]></Source>
