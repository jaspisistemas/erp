      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&GAMApplication.Load(&ApplicationId)
	&ApplicationMenu = &GAMApplication.GetMenu(&MenuId, &Errors)	
	If &Mode <> GAMAPiMode.Insert		
		&ApplicationMenuOption = &ApplicationMenu.GetMenuOptionById(&ApplicationId, &Id, &Errors)
		&Name 				= &ApplicationMenuOption.Name
		&Dsc				= &ApplicationMenuOption.Description
		&GUID				= &ApplicationMenuOption.GUID
		&Type				= &ApplicationMenuOption.Type
		&MenusId			= &ApplicationMenuOption.SubMenuId
		&RelResId			= &ApplicationMenuOption.PermissionResourceGUID		
		&Resource 			= &ApplicationMenuOption.Resource		
		&ResourceParameters = &ApplicationMenuOption.ResourceParameters
		if &ApplicationMenuOption.Properties.Count > 0
			&IconClass = &ApplicationMenuOption.Properties.Item(1).Value
			&Link = &ApplicationMenuOption.Properties.Item(2).Value
		endif
		
		&GUID.Enabled	= False
		If &Mode = GAMAPiMode.Display or &Mode = GAMAPiMode.Delete
			If &Mode = GAMAPiMode.Display
				BtnEnter.Visible = False
			Endif
			&Name.Enabled 		= False
			&Dsc.Enabled		= False
			&Type.Enabled		= False
			&MenusId.Enabled	= False
			&RelResId.Enabled	= False	
			&Resource.Enabled = False
			&ResourceParameters.Enabled = False
			BtnEnter.Caption = "Delete"
			&Link.Enabled = false
			&IconClass.Enabled = false
		Endif
	Endif
	If &Type = GAMMenuOptionType.Simple		
		For &Permission in &GAMApplication.GetPermissions(&PermissionFilter, &Errors)
			&RelResId.AddItem(&Permission.GUID, &Permission.Name)
		EndFor		
	Else		
		For &Menu in &GAMApplication.GetSubMenus(&MenuId, &Errors)		
			&MenusId.AddItem(&Menu.Id, &Menu.Name)		
		EndFor		
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&Type = GAMMenuOptionType.Menu)
		&MenusId.Visible = False
		MenusId_Cell.Class = !'Invisible'
	Else
		&MenusId.Visible = True
		MenusId_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&Type = GAMMenuOptionType.Simple)
		&RelResId.Visible = False
		RelResId_Cell.Class = !'Invisible'
	Else
		&RelResId.Visible = True
		RelResId_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Type.Click

	do 'AttributesSecurityCode'
	If &Type = GAMMenuOptionType.Simple
		If &RelResId.IsEmpty()
			&GAMApplication.Load(&ApplicationId)
			For &Permission in &GAMApplication.GetPermissions(&PermissionFilter, &Errors)
				&RelResId.AddItem(&Permission.GUID, &Permission.Name)	
			EndFor
		Endif
	Else
		If &MenusId.IsEmpty()
			&GAMApplication.Load(&ApplicationId)
			For &Menu in &GAMApplication.GetSubMenus(&MenuId, &Errors)		
				&MenusId.AddItem(&Menu.Id, &Menu.Name)		
			EndFor
		Endif
	Endif

EndEvent

Event Enter

	&GAMApplication.Load(&ApplicationId)
	If not &Name.IsEmpty()
		Do Case
			Case &Mode = GAMAPiMode.Insert
				Do 'Load_ApplicationMenuOption'
				&isOK = &GAMApplication.AddMenuOption(&MenuId, &ApplicationMenuOption, &Errors)
			Case &Mode = GAMAPiMode.Update
				&ApplicationMenuOption = &GAMApplication.GetMenuOption(&MenuId, &Id, &Errors)
				Do 'Load_ApplicationMenuOption'
				&isOK = &GAMApplication.UpdateMenuOption(&MenuId, &ApplicationMenuOption, &Errors)
			Case &Mode = GAMAPiMode.Delete
				&ApplicationMenuOption = &GAMApplication.GetMenuOption(&MenuId, &Id, &Errors)
				&isOK = &GAMApplication.DeleteMenuOption(&MenuId, &ApplicationMenuOption, &Errors)
		EndCase
	Else
		&isOK = False
		&Error = new()
		&Error.Code 	= GAMErrorMessages.ApplicationMenuOptionNameNull
		&Error.Message	= GAMErrorMessages.EnumerationDescription(&Error.Code)
		&Errors.Add(&Error)		
	Endif
	If &isOK
		Commit
		return
	Else
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor
	Endif

EndEvent

Event &RelResId.IsValid

	&GAMApplication.Load(&ApplicationId)
	&Permission	= &GAMApplication.GetPermissionByGUID(&RelResId, &Errors)
	&Resource	= &Permission.Resource

EndEvent

Sub 'Load_ApplicationMenuOption'

	&ApplicationMenuOption.GUID							= &GUID
	&ApplicationMenuOption.Name							= &Name
	&ApplicationMenuOption.Description 					= &Dsc
	&ApplicationMenuOption.Type.FromString(&Type)
	&ApplicationMenuOption.SubMenuId					= &MenusId
	&ApplicationMenuOption.PermissionResourceGUID		= &RelResId
	&ApplicationMenuOption.Resource						= &Resource
	&ApplicationMenuOption.ResourceParameters			= &ResourceParameters
	
	&GAMPropertyCollection = new()

	&GAMProperty = new()
	&GAMProperty.Id = "IconClass"
	&GAMProperty.Value = &IconClass
	&GAMPropertyCollection.Add(&GAMProperty)
	
	&GAMProperty = new()
	&GAMProperty.Id = "Link"
	&GAMProperty.Value = &Link
	&GAMPropertyCollection.Add(&GAMProperty)
  
  &ApplicationMenuOption.Properties = &GAMPropertyCollection

EndSub


]]></Source>
