Sub 'ParcelasCartao'

	If &CarForPag = 1
		&CarParQtd.AddItem(1,'1X S/Juros') 
	Else
		For each Order EmpCod,BanCarCod
			Where EmpCod = &EmpCod
			Where BanCarCod = &BanCarCod
			&BanCarVlrMinPar = &CarMovVlr / BanCarCrePar
			If  &BanCarVlrMinPar >= BanCarVlrMinPar
				If BanCarVlrJurPar > 0 
					&des = trim(str(BanCarCrePar))+'X C/Juros'
				Else
					&des = trim(str(BanCarCrePar))+'X S/Juros'
				EndIf			
				&CarParQtd.AddItem(BanCarCrePar,&des)
			EndIf
		When none	
			&CarParQtd.AddItem(1,'1X S/Juros')
		EndFor
	EndIF

EndSub

Sub 'SomaTotais'

	&TotalAcerto.SetEmpty()
	
	For &AuxSdtPedidosItem in &AuxSdtPedidos
		if &AuxSdtPedidosItem.Localizado = 'S' and &AuxSdtPedidosItem.PedFrpPgtoTip = &PedFrpPgtoTip
			&TotalAcerto += &AuxSdtPedidosItem.PedVlrLiq
			&PedTraRedRaz = &AuxSdtPedidosItem.PedTraRedCodRaz
			&PedTraRedCod = &AuxSdtPedidosItem.PedTraRedCod
			if &PedTraRedCod.IsEmpty()
				Return
			Endif
		EndIf
	EndFor

EndSub

