      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('RELCONHECIMENTOSFRETES', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&FatFilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&fimPedDtaFat = serverdate()
	&iniPedDtaFat = serverdate()
	
	PadraoUsuario.Call('L', &Pgmname, &Context.pesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&TipoPeriodo = Substr(&PadObs, 1, 1)
		&TipoRelatorio = Substr(&PadObs, 2, 1)
	EndIF

EndEvent

Event 'DoMonitoraConhecimentos'

	wwFrete.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FrtTraCod.IsValid

	do 'loadTransportadora'

EndEvent

Event 'F4'

 4
	promptTransportadora.Popup(&EmpCod, &FrtTraCod)
	&FrtTraCod.SetFocus()

EndEvent

Event Enter

	do 'loadTransportadora'
	If &IsExisteTransportadora = true
		&PadObs = &TipoPeriodo + &TipoRelatorio
		PadraoUsuario.Call('G', &Pgmname, &Context.pesCod,&Context.EmpCod, &PadObs, &PadDtaMod)
		
		RCOOpenWindow1.LinkOpen = RELJAS022T.Link(&EmpCod, &FilCod, &FatFilCod, &FrtTraCod, &iniPedDtaFat, &fimPedDtaFat, &PedCliEntUfeCod, &TipoPeriodo, &TipoRelatorio)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIF

EndEvent

Sub 'loadTransportadora'

	&IsExisteTransportadora = true
	For Each Order EmpCod, PesCod
		Where PesCod = &FrtTraCod
		Where PesIsTra = true
		&FrtTraRaz = PesRaz
		
		Exit
	When none
		If &FrtTraCod = 0
			&FrttraRaz = 'TODAS TRANSPORTADORAS'
		Else
			&FrttraRaz = 'TRANSPORTADORA NÃO LOCALIZADA'
			msg(&FrttraRaz)
			&IsExisteTransportadora = false
		EndIF
	EndFor

EndSub


]]></Source>
