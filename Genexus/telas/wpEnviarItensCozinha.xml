Event Start

	&TrazerSomenteProduto = 'C'
	LoadWWpContext.Call(&Context)
	
	do 'CarregaSDT'
	do 'montaImpressora'
	
	PadraoUsuario.Call('L', 'WPIMPRESSORADELIVERY', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&EmpImpCod1 = iif(val(Substr(&PadObs, 1, 8)) > 0, val(Substr(&PadObs, 1, 8)), 0 )
	&EmpImpCod2 = iif(val(Substr(&PadObs, 9, 8)) > 0, val(Substr(&PadObs, 9, 8)), 0 )
//	&EmpImpCod3 = iif(val(Substr(&PadObs, 17, 8)) > 0, val(Substr(&PadObs, 17, 8)), 0 )
	
	&QtdVias1 = iif(val(Substr(&PadObs, 25, 1)) > 0, val(Substr(&PadObs, 25, 1)), 1 )
	&QtdVias2 = iif(val(Substr(&PadObs, 26, 1)) > 0, val(Substr(&PadObs, 26, 1)), 1 )
	&QtdVias3 = iif(val(Substr(&PadObs, 27, 1)) > 0, val(Substr(&PadObs, 27, 1)), 1 )

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TBEDITARPRODUTOGRID.Width = 35
	TBEDITARPRODUTOGRID.Height = 20
	&EmpImpCod3.Visible = False
	&QtdVias3.Visible = False
	&QtdVias2.Visible = False
	&QtdVias1.Visible = False
	&FilCod.Visible = False
	&PedFicCod.Visible = False
	&EmpCod.Visible = False
	&PedItmCod.Visible = False
	&GridProdutosProGraRef.Visible = False
	&GridProdutosPedItmCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridProdutosPedido.Load

	For Each Order EmpCod, FilCod, PedCod, (PedItmDtaAdd)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod 
		Where PedCod = &PedCod
		Where PedItmCodRef.IsEmpty() or PedItmCodRef.IsNull() or PedItmCodRef = PedItmCod
		Where PedItmSts <> 'C' or PedItmSts.IsNull() or PedItmSts.IsEmpty() when &TrazerSomenteProduto <> 'T'
		
		&ProGraNom = ProNomGra
		&ProCod = ProCod
		&PedItmCod = PedItmCod
		
		&AuxPedItmDtaAdd = PedItmDtaAdd
		&PedItmDtaAdd = strreplace(&AuxPedItmDtaAdd.ToString(), ' ', '_') //TIRAR OS SEGUNDOS
		
		EditarItemProduto.FromImage(DDOMultiselOption)
		&PedItmSts = PedItmSts
		&PedVlrUnt = PedVlrUnt
		&PedVlrItm = PedVlrItm
				
		&SelPedItmCod = PedItmCod
		do 'VerificaSDT'
		
		if &IsSelecionado = true
			EditarItemProduto.FromImage(DDOMultiselSelOption)
		EndIf
		
		&GridProdutosPedidoProNom = PedProNom
		RetornaObsProduto.Call(EmpCod, FilCod, PedCod, PedItmCod, &GridProdutosPedidoObservacao)	
		RetornaObs_Complementos.Call(EmpCod, FilCod, PedCod, PedItmCod, &AuxPedVlrItm, &GridProdutosPedidoComplemento)
		RetornaObs_Composicao.Call(EmpCod, FilCod, PedCod, PedItmCod, &ComposicaoPedVlrItm, &ComposicaoMensagem)
		
		&GridProdutosPedidoProNom += ' ' + &ComposicaoMensagem

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		tbGridProLoadComplemento.Visible = (Not &GridProdutosPedidoComplemento.isEmpty())
		tbGridProLoadObs.Visible = (Not &GridProdutosPedidoObservacao.isEmpty())
		
		&GridProdutosPedidoPedVlrItm = &AuxPedVlrItm+&ComposicaoPedVlrItm + PedVlrItm
		Load
	EndFor

EndEvent

Event 'DoBtnImprime3'

	do 'GravaPadrao'
	GravaEnvioProdutosCozinha.Call(&EmpCod, &FilCod, &PedCod, &PedFicCod, &Context.PesCod, &EmpImpCod, &sdtRELJAS124_A_Produtos)
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtnImprime1'

	Do 'GravaPadrao'
	AtualizaCadastroCliente.call(&EmpCod, &FilCod, &PedCod, &Context.PesCod)
	if &EmpImpCod1 > 0 
		if not &EmpImpCod2.IsEmpty()
			&ViaImpressao = '1'
		Endif
	
		GravaEnvioProdutos_Delivery.Call(&EmpCod, &FilCod, &PedCod, &PedFicCod, &Context.PesCod, &EmpImpCod1, &ViaImpressao, &sdtRELJAS124_A_Produtos)
	Endif

	if &EmpImpCod2 > 0
		if not &EmpImpCod1.IsEmpty()
			&ViaImpressao = '2'
		Endif
		
		GravaEnvioProdutos_Delivery.Call(&EmpCod, &FilCod, &PedCod, &PedFicCod, &Context.PesCod, &EmpImpCod2, &ViaImpressao, &sdtRELJAS124_A_Produtos)
	Endif

	
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event TBEDITARPRODUTOGRID.Click

	&SelPedItmCod = &PedItmCod
	
	if &IsSelecionado = true
		&IsSelecionado = false
		EditarItemProduto.FromImage(DDOMultiselOption)
	Else
		&IsSelecionado = true
		EditarItemProduto.FromImage(DDOMultiselSelOption)
	EndIf
	do 'AddSDT'

EndEvent

Event EditarItemProduto.Click

	&SelPedItmCod = &PedItmCod
	
	if &IsSelecionado = true
		&IsSelecionado = false
		EditarItemProduto.FromImage(DDOMultiselOption)
	Else
		&IsSelecionado = true
		EditarItemProduto.FromImage(DDOMultiselSelOption)
	EndIf
	do 'AddSDT'

EndEvent

Sub 'CarregaSDT'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod 
		Where PedCod = &PedCod
		
		Do Case
			Case PedStsGer = Pedido_Gerado.DElivery //Delivery
				&PedStsGeracao = 'DELIVERY'
				&PedStsGeracao.ForeColor = RGB(255,0,0)
				&TrazerSomenteProduto = 'T'
				tbImpressoraDelivery.Visible = 1
				tbImpressoraBalcao.Visible = 0 
				
			Case PedStsGer = Pedido_Gerado.PDV and PedFicCod > 0 //MEsa
				&PedStsGeracao = RetornaNomeFicha.Udp(EmpCod, PedFicCod)
				&PedStsGeracao.ForeColor = RGB(10,10,255)
				&TrazerSomenteProduto = 'C'
				tbImpressoraDelivery.Visible = 0
				tbImpressoraBalcao.Visible = 1
				
			Case PedStsGer = Pedido_Gerado.PDV //Balcao
				&PedStsGeracao = 'BALCAO'
				&PedStsGeracao.ForeColor = RGB(0,150,0)	
				&TrazerSomenteProduto = 'C'
				tbImpressoraDelivery.Visible = 0
				tbImpressoraBalcao.Visible = 1
		EndCase
		Exit
	EndFor

	For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod 
		Where PedCod = &PedCod
		Where PedItmCodRef.IsEmpty() or PedItmCodRef.IsNull() or PedItmCodRef = PedItmCod
		//Where PedItmSts <> 'C' or PedItmSts.IsNull() //DIFERENTE DE COZINHA
		Where PedItmSts <> 'C' or PedItmSts.IsNull() or PedItmSts.IsEmpty() when &TrazerSomenteProduto <> 'T'
	
		&SelPedItmCod = PedItmCod
		do 'addSdt'
	EndFor

EndSub

Sub 'addSdt'

	&IsAchou = false
	For &sdtRELJAS124_A_ProdutosItem in &sdtRELJAS124_A_Produtos
		if &sdtRELJAS124_A_ProdutosItem.PeditmCod = &SelPedItmCod
			&IsAchou = true
			&sdtRELJAS124_A_Produtos.Remove(&sdtRELJAS124_A_Produtos.IndexOf(&sdtRELJAS124_A_ProdutosItem))
			Exit
		EndIf
	EndFor

	if &IsAchou = false 
		&sdtRELJAS124_A_ProdutosItem = new()
		&sdtRELJAS124_A_ProdutosItem.PeditmCod = &SelPedItmCod
		&sdtRELJAS124_A_Produtos.Add(&sdtRELJAS124_A_ProdutosItem)
		
	EndIf

EndSub

Sub 'GravaPadrao'

	&PadObs = PadL(str(&EmpImpCod1), 8, '0')
	&PadObs += PadL(str(&EmpImpCod2), 8, '0')
	&PadObs += PadL(str(&EmpImpCod3), 8, '0')
	&PadObs += PadL(str(&QtdVias1), 1, '0')
	&PadObs += PadL(str(&QtdVias2), 1, '0')
	&PadObs += PadL(str(&QtdVias3), 1, '0')
	PadraoUsuario.Call('G', 'WPIMPRESSORADELIVERY', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

EndSub

Sub 'montaImpressora'

	&EmpImpCod1.Clear()
	&EmpImpCod2.Clear()
	
	&EmpImpCod1.AddItem(0, 'NÃO IMPRIMIR')
	&EmpImpCod2.AddItem(0, 'NÃO IMPRIMIR')
	For Each Order EmpCod, EmpImpCod
		Where EmpCod = &Context.EmpCod		
		Where EmpImpTip like '%CUPOM%'
		
		&Mensagem = EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
		
		if EmpImpTip = DomTipoImpressora.CUPOM1
			&EmpImpCod1.AddItem(EmpImpCod,&Mensagem)		
		Else
			&EmpImpCod2.AddItem(EmpImpCod,&Mensagem)
		Endif
//		&EmpImpCod3.AddItem(EmpImpCod,&Mensagem)
	EndFor

EndSub

Sub 'VerificaSDT'

	&IsSelecionado = false
	For &sdtRELJAS124_A_ProdutosItem in &sdtRELJAS124_A_Produtos
		if &sdtRELJAS124_A_ProdutosItem.PeditmCod = &SelPedItmCod
			&IsSelecionado = true
			Exit
		EndIf
	EndFor

EndSub

