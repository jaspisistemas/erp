        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridProdutos_Empowerer.GridInternalName = GridProdutos.InternalName
	GridProdutos.Rows = 5
	&GridProdutosCurrentPage = 1
	&GridProdutosCurrentPage.Visible = False
	&GridProdutosPageCount = -1
	GridProdutosPaginationBar.RowsPerPageSelectedValue = GridProdutos.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridProdutosPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridProdutosCurrentPage = GridProdutos.CurrentPage
	&GridProdutosPageCount = GridProdutos.PageCount

EndEvent

Event GridProdutos.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar.FromImage(ActionDelete)
	&Deletar.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridProdutosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridProdutosPaginationBar.SelectedPage = !'Previous'
			&GridProdutosCurrentPage -= 1
			GridProdutos.PreviousPage()
		Case GridProdutosPaginationBar.SelectedPage = !'Next'
			&GridProdutosCurrentPage += 1
			GridProdutos.NextPage()
		Otherwise
			&PageToGo.FromString(GridProdutosPaginationBar.SelectedPage)
			&GridProdutosCurrentPage = &PageToGo
			GridProdutos.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridProdutosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridProdutos.Rows = GridProdutosPaginationBar.RowsPerPageSelectedValue
	&GridProdutosCurrentPage = 1
	GridProdutos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDeletar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Deletar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Deletar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Deletar.Result = !'Yes'
		Do 'Do Deletar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Deletar'

	&ProCod = ProCod
	&ProGraCod = 1
		
	do 'carregaLocacaoExtra'
	GravaLocacao.Call(EmpCod, FilCod, ProCod, ProGraCod, '', &sdtLocacaoExtra)
	
	refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CarregaLocacaoExtra'

	&sdtLocacaoExtra.Clear()
	For each Order EmpCod, FilCod, ProCod, ProGraCod, EstLocExt
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &PrOCod
		Where ProGraCod = &ProGraCod	
		
		&sdtLocacaoExtraItem = new()
		&sdtLocacaoExtraItem.EstLocExt = EstLocExt
		&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		
	EndFor

EndSub


]]></Source>
