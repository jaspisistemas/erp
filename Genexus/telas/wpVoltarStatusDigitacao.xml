      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	do 'loadPedido'
	txtMsg.ForeColor = RGB(0, 100, 255)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'loadPedido'
	GravaStatusDigitado.Call(&EmpCod, &FilCod, &PedCod, true, &Context.PesCod)
	do 'EnviaNotificacao'
	
	Return

EndEvent

Sub 'loadPedido'

	btnEnter.Visible = 1
	btnEnter.Enabled = 1
				
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedCliCod = PedCliCod
		&PedCliRaz = PedCliRaz
		&LctCodNom = LctCodNom
		
		If PedStsDigBlk = true 
			msg('Pedido já está bloqueado para o Vendedor.')
			btnEnter.Visible = 0
			btnEnter.Enabled = 0
		Else
			if LctTip <> TipoLancamento.OrcamentoVenda
				msg('É preciso alterar o Pedido para ORÇAMENTO, para o vendedor poder editar.')
				btnEnter.Visible = 0
				btnEnter.Enabled = 0
			EndIF
		EndIF
		&PedVenCod = PedVenCod
		Exit
	EndFor

EndSub

Sub 'EnviaNotificacao'

	For Each Order EmpCod, PesCod	//## Procura o Código GAMGUID do Vendedor, na tabela Pessoa, e envia uma Notificação para o mesmo ##\\
		Where EmpCod = &EmpCod		//## Código da Empresa ##\\
		Where PesCod = &PedVenCod	//## Código do Vendedor ##\\
		
		&AuxPesExtCod = trim(str(PesExtCod))	//## Atribuí o Código Externo do Vendedor ##\\
		do 'BuscaUsuariosGAM'					//## Busca o GAMGUID referente ao Código Externo GAM ##\\
			
		&NotificationLink = wwPedidoTelevendas.Link()	//## Define o Link da Notificação, ao clicar nela ##\\
		WWP_SendNotification(!'RetornarDigitacao', !"StatusDigitacao", '', "fas fa-exclamation FontColorIconWarning", "Mudança de Status da Digitação!", Format("%1 mudou o Status de digitação de um pedido recentemente. %2 %3",WWP_GetUserFullName(WWP_GetLoggedUserId()), "Confira em: VENDAS TELEVENDAS"), Format("%1  mudou o Status de digitação de um pedido recentemente. %2 %3",WWP_GetUserFullName(WWP_GetLoggedUserId()), "Confira em: VENDAS TELEVENDAS"), &NotificationLink, '', '', True, &IDUsuario)
	
		Exit 
	EndFor

EndSub

Sub 'BuscaUsuariosGAM'

	&Filter.ExternalId = &AuxPesExtCod	//## Define o filtro que será usado no GetUser ##\\
	
	For &User in GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors)	//## Procura o GAMGUID do usuário ##\\
		&IDUsuario = &User.GUID	//## Define IDUsuario como o código do GAMGUID ##\\
		Exit
	EndFor

EndSub


]]></Source>
