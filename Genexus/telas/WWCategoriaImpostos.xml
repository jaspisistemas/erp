      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWCATEGORIAIMPOSTOS', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	&CatSts = nullvalue(&CatSts)
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = 'Produto Imposto'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	&Update.ColumnHeaderClass = !'WWIconActionColumn'
	&Delete.ColumnHeaderClass = !'WWIconActionColumn'
	CatCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	CatNom.ColumnHeaderClass = !'WWColumn'
	CatSts.ColumnHeaderClass = !'WWColumn hidden-xs'
	CatCodImp.ColumnHeaderClass = !'WWColumn hidden-xs'
	CatCltSitCod.ColumnHeaderClass = !'WWColumn'
	CatCltClsTrib.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	if CatSts.IsEmpty() or CatSts.IsNull()
		prcAtualizaCategoriaImposto.Call(EmpCod, CatCod)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Update = !'<i class="fa fa-pen"></i>'
	
	&Delete = !'<i class="fa fa-times"></i>'
	
	&Update.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWIconActionColumn WWColumnTag WWColumnTagDanger WWColumnTag WWColumnTagDangerFirstColumn', !'WWIconActionColumn')
	&Delete.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWIconActionColumn WWColumnTag WWColumnTagDanger', !'WWIconActionColumn')
	CatCod.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger hidden-xs', !'WWColumn hidden-xs')
	CatNom.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger', !'WWColumn')
	CatSts.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger hidden-xs', !'WWColumn hidden-xs')
	CatCodImp.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger hidden-xs', !'WWColumn hidden-xs')
	CatCltSitCod.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger', !'WWColumn')
	CatCltClsTrib.ColumnClass = iif(CatSts = Status_AtivoInativo.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Update.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CategoriaImpostos.PopUp(TrnMode.Update, EmpCod, CatCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Delete.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CategoriaImpostos.PopUp(TrnMode.Delete, EmpCod, CatCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CategoriaImpostos.PopUp(TrnMode.Insert, nullvalue(EmpCod), nullvalue(CatCod))
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"FILTERFULLTEXT"
				&FilterFullText.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"CATSTS"
				&CatSts.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"FILTERFULLTEXT", "", not &FilterFullText.IsEmpty(), 0, &FilterFullText, '')
	WWP_GridStateAddFilterValue(&GridState, !"CATSTS", "", not &CatSts.IsEmpty(), 0, &CatSts, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"CategoriaImpostos"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
