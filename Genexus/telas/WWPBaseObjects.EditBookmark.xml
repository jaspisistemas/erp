      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&BookmarkURL.LinkTarget = !'_blank'
	&BookmarkURL.Link = &BookmarkURL

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&BookmarkURL = upper(&InBookmarkURL)
	&BookmarkURL = &BookmarkURL.Replace('.ASPX', '')
	&BookmarkName = &BookmarkPageDescription
	
	loadWWPContext.Call(&wwpContext)
	//VERIFICA SE PODE ADICIONAR AOS FAVORITOS
	Form.Caption = "WWP_Bookmark_Edit"
	For Each Order EmpCod, PesCod, FavRotAutCod
		Where EmpCod = &wwpContext.EmpCod
		Where PesCod = &wwpContext.PesCod
		Where FavRotAutCod = &BookmarkURL
		Where FavWebSmart = 'W' or FavWebSmart.IsNull() or FavWebSmart.IsEmpty()
		
		&BookmarkName = FavRotAutNom
		
		Exit
	When none
		BtnDel.Visible = False
		Form.Caption = "WWP_Bookmark_Add"
		For Each Order EmpCod, RotAutCod, RotCod
			Where EmpCod = &wwpContext.EmpCod
			Where RotAutCod = &BookmarkURL or RotLin = &BookmarkURL.Trim() + '.aspx'
			where not RotLin.IsEmpty()
			
			if RotNomFav.IsEmpty() or RotNomFav.IsNull()
				&BookmarkName = RotNom
			Else
				&BookmarkName = RotNomFav
			EndIF
			
			Exit
		EndFor
		
		If &BookmarkName.IsEmpty()
			msg('Página não Disponível para Favorito!')
			btnEnter.Visible = false
			&BookmarkName.Enabled = false
		EndIf
	EndFor

EndEvent

Event 'DoDel'

	Gravafavorito.Call('DEL', &wwpContext.EmpCod, &wwpContext.PesCod, &BookmarkURL, '',  0,&Mensagem)
	NovoLateralGx15.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &wwpContext.Old_Perfil)
	GlobalEvents.Master_RefreshHeader()
	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserCancel'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&BookmarkName = &BookmarkName.Trim()
	If &BookmarkName.IsEmpty()
		msg('Nome da Página não pode ser vazio!')
	Else
		Gravafavorito.Call('ADD', &wwpContext.EmpCod, &wwpContext.PesCod, &BookmarkURL, &BookmarkName,  0,&Mensagem)
		
		NovoLateralGx15.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &wwpContext.Old_Perfil)
		GlobalEvents.Master_RefreshHeader()
		WWPActions.WCPopup_Close('')
	EndIf

EndEvent


]]></Source>
