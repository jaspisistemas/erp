        <Source><![CDATA[
Event Start

	&AlterarNCMs.Title = 'Alterar'
	&VisualizarProdutos.Title = 'Produtos'
	
	loadWWPContext.Call(&wwpContext)
	&EmpCOd = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	
	padraoUsuarioHora.Call('L', '#WPCORRIGENCM#', 1, &EmpCod, &padObs, &paddtaMod, &PadDtaHorMod, 'T')
	&SdtNCM.FromJson(&padObs)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 200

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For &SdtNCmItem in &SdtNCm

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&AlterarNCMs = !'<i class="fas fa-pen"></i>'
	
	&VisualizarProdutos = !'<i class="far fa-file-pdf"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&NcmCod = &SdtNCmItem.NcmCod
		&Mensagem = &SdtNCmItem.Msg
		load
	EndFor

EndEvent

Event Enter

	prcAnalisaNCMs.Call(&EmpCOd)
	padraoUsuarioHora.Call('L', '#WPCORRIGENCM#', 1, &EmpCod, &padObs, &paddtaMod, &PadDtaHorMod, 'T')
	&SdtNCM.FromJson(&padObs)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNCMInvalidos'

	RCOOpenWindow1.LinkOpen = RELJAS149.Link(&EmpCod, &FilCod, 0)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AlterarNCMs.Click

	wpNovoNcm.Popup(&EmpCOd, &NcmCod)
	wpCorrigencm.Link()

EndEvent

Event &VisualizarProdutos.Click

	RCOOpenWindow1.LinkOpen = RELJAS149.Link(&EmpCod, &FilCod, &NcmCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


