      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	
	&SdtPedido.FromXml(&websession.Get('LIBERACAOMULTIPLO'))
	if &SdtPedido.Count < 1
		wwPedidoVenda.Link()
	EndIf
	
	&StsCod.Clear()
	RetornaCodigoStatusPedido.Call(&EmpCod, 'AUTORIZ.', &PedStsPaiCod)
	For Each Order EmpCod, StsOrd
		Where EmpCod = &EmpCod
		Where StsCod = &PedStsPaiCod or StsPaiCod = &PedStsPaiCod
		
		&StsCod.AddItem(StsCod, StsNom)
	When none
		&StsCod.Visible = 0
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbesp.Height = 20
	Grid.Rows = 50

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For &SdtPedidoItem in &SdtPedido
		
		&PedCod = &SdtPedidoItem.PedCod
		
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			&NovoStatus = trim(PedNovStsNom)			
			prcStatusPedidoRGB.Call(EmpCod, PedNovStsNom, &R, &G, &B )
			&NovoStatus.ForeColor = RGB(&R, &G, &B)
			
			&NovoStatusFin = trim(PedNovStsFinNom)
			prcStatusPedidoRGB.Call(EmpCod, PedNovStsFinNom, &R, &G, &B )
			&NovoStatusFin.ForeColor = RGB(&R, &G, &B)
	
			Exit
		EndFor

		&PedCliCodRaz = &SdtPedidoItem.PedCliCodRaz
		&PedVlrLiq = &SdtPedidoItem.PedVlrLiq
		
		&PedCliCod = &SdtPedidoItem.PedCliCod
		do 'getCliente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&deletar = !'<i class="fa fa-times"></i>'
	
	&StatusPedido.FromImage(WarningIcon)
	&StatusPedido.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&StatusPedido.FromImage(iconVerde)
		
		&Moeda = &PedCliCrdUti + &PedVlrLiq
		RetornaAtencaoLiberacaoPedido.Call(&EmpCod, &FilCod, &PedCliCod, &Moeda, &IsAtencao, &Mensagem)
		&StatusPedido.Tooltiptext = 'Cliente/Pedido sem restrições!'
		If not &Mensagem.IsEmpty()
			&StatusPedido.Tooltiptext = &Mensagem
			If &IsAtencao = true
				
				&StatusPedido.FromImage(WarningIcon)
			Else
				&StatusPedido.FromImage(IconVermelho)
				
			EndIF
		EndIF
	
		Do Case
			Case &PesClaTip = ClienteClassificacao.INADIMPLENTE
				&PesClaTip.ForeColor = RGB(220, 40, 0)
				
			Case &PesClaTip = ClienteClassificacao.RUIM
				&PesClaTip.ForeColor = RGB(160, 40, 0)
				
			Case &PesClaTip = ClienteClassificacao.OTIMO
				&PesClaTip.ForeColor = RGB(0, 150, 0)
				
			Otherwise
				&PesClaTip.ForeColor = RGB(0, 100, 200)
		EndCase
	
		Load
	EndFor

EndEvent

Event Enter

	For &SdtPedidoItem in &SdtPedido
		GravaLiberacaoCreditoPedido.Call(&EmpCod, &FilCod, &SdtPedidoItem.PedCod, &PesCod, &Context.UserName, 'AUTM', &PedObsAna)
		GravaStatusPedido.Call(&EmpCod, &FilCod, &SdtPedidoItem.PedCod, 0, '', &StsCod, &Context.PesCod)
	EndFor
	
	wwPedidoVenda.Link()

EndEvent

Event &StatusPedido.Click

	wpLiberarCreditoPedidoNovo.Popup(&EmpCod, &FilCod, &PedCod)
	Refresh

EndEvent

Event &deletar.Click

	//DELETA DO SDT
	For &SdtPedidoItem in &SdtPedido
		If &SdtPedidoItem.PedCod = &PedCod
			&index = &SdtPedido.IndexOf(&SdtPedidoItem)
			&SdtPedido.Remove(&Index)
			Exit
		EndIF
	EndFor

	&websession.Set('LIBERACAOMULTIPLO',&SdtPedido.ToXml())
	Refresh

EndEvent

Sub 'getCliente'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		
		&PedCliCrd = PesCliCrd
		&PesClaTip = PesClaTip
		Exit
	EndFor

	&PedCliCrdUti = RetornaCreditoDisponivelCliente.Udp(&EmpCod, &FilCod, &PedCliCod)
	&PedCliCrdDis = &PedCliCrd - &PedCliCrdUti
	If &PedCliCrdDis < 0
		&PedCliCrdDis = 0
	EndIF

EndSub


]]></Source>
