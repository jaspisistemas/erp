      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	do 'loadEtapa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do Case
		Case &NovoOcsEtpItm.IsEmpty()
			msg('Nova Etapa não pode ser 0')
		Case &OcsEtpItm = &NovoOcsEtpItm
			msg('Nova Etapa e Etapa Atual devem ser diferentes!')
		Otherwise
			
			AlteraordemEtapaCostura.Call( &EmpCod, &OcsCod, &OcsItm, &OcsEtpItm, &NovoOcsEtpItm)
			return
	EndCase

EndEvent

Sub 'loadEtapa'

	For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &OcsItm
		Where OcsEtpItm = &OcsEtpItm
		&OcsProNroCor = OcsProNroCor
		&OcsProGraNom = OcsProGraNom
		&CTrCodNom = CTrCodNom
		Exit
	EndFor

EndSub


]]></Source>
