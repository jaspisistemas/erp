      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Guid = guid.NewGuid()
	&ProgressId = &Guid.ToString()
	
	tbProgresso.Visible = 0	
	
	do 'getCotacaoFornecedor'
	Do CAse
		CAse &OqueFazer = 'B' //Bloquear
			txtObs.Caption = 'INTERROMPER/BLOQUEAR a cotação impedirá que os fornecedores acessem o link, ao libera-la novamente um novo link será criado para cada fornecedor!'
			wwpActions.WCPopup_UpdateTitle('INTERROMPER/BLOQUEAR Cotação dos fornecedores')
			txtObs.ForeColor = rgb(255, 0, 0)
			
		CAse &OqueFazer = 'C' //Cancelar
			txtObs.Caption = 'Ao CANCELAR, Sistema tornará a cotação de compra indisponível permanentemente!'
			wwpActions.WCPopup_UpdateTitle('CANCELAR Cotação no Sistema')
			txtObs.ForeColor = rgb(246, 149, 0)
			
		CAse &OqueFazer = 'E' //Finalizar
			if &CotComSts = StatusCotacao.Encerrada
				txtObs.Caption = 'Ao ABRIR, a cotação Voltará para Finalizada, podendo alterar fornecedores ganhadores da cotação!'
				wwpActions.WCPopup_UpdateTitle('ABRIR Cotação no Sistema')
				txtObs.ForeColor = rgb(246, 149, 0)
			Else
				txtObs.Caption = 'Ao ENCERRAR, a cotação se dará como completada, não podendo mais alterar fornecedores ganhadores da cotação!'
				wwpActions.WCPopup_UpdateTitle('ENCERRAR Cotação no Sistema')
				txtObs.ForeColor = rgb(246, 149, 0)
			Endif
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

		tbProgresso.Visible = 1
		tbenter.Visible = 0
		
		scaPrograssBar1.ProcessId = &ProgressId
		scaPrograssBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaPrograssBar1.Start()
		
		prcAlterarStatusInterromperCotacao.Submit(&ProgressID, &ProgressID, &EmPCod, &CotComCod, &OqueFazer)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaPrograssBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		&SdtWbsRetorno.FromJson(ProgressLogXml)
		
		if &SdtWbsRetorno.sts = 'J200' or &OqueFazer = 'E'
			wwpActions.WCPopup_Close('')
		Else
			tbEnter.Visible = 1
			tbProgresso.Visible = 0
			tbAvisoerro.Visible = 1

			txtAvisoErro.Caption = &SdtWbsRetorno.obs
		EndIf
		
		Exit		
	EndFor

EndEvent

Sub 'getCotacaoFornecedor'

	For Each ORder EmpCod, CotComCod
		Where EmpCod = &EmPCod
		Where CotComCod = &CotComCod
		
		&CotComSts = CotComSts
		txtFornecedor.Caption = 'COTACAO: ' + padL(trim(str(CotComCod)), 3, '0') +'.'+padL(trim(str(CotComVer)), 3, '0')
		
		if &AuxOqueFazer = 'E'
			&OqueFazer = &AuxOqueFazer
		Else
			if CotComSts = StatusCotacao.Liberada
				&OqueFazer = 'B' //Bloquear
			Else
				&OqueFazer = 'C' //Cancelar
			Endif
		EndIf
	
		Exit
	EndFor

EndSub


]]></Source>
