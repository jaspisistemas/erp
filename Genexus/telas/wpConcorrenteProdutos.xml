      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWCONCORRENTE', Status_SimNao.Sim, 2, &AutNiv)
	
	mensagem.ForeColor = RGB(0,60,140)
	
	mensagem.Caption = ''
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	do 'loadProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ConForCod.TooltipText = "Código do produto no seu concorrente."
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadConcorrente'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

EndEvent

Event Grid.Load

	For Each Order ConEmpCod, ConCod
		Where ConEmpCod = &ConEmpCod
		Where ConCod = &ConCod
		
		&gridConProVlr = ConProVlr
		&gridConProCod = ConProCod
		For Each Order EmpCod, ProCod
			Where EmpCod = ConEmpCod
			Where ProCod = ConProCod
			
			&gridConProNom = ProNom
			Exit
		EndFor

		&gridConForCod = ConForCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EliminarProduto.FromImage(ActionDelete)
	&EliminarProduto.TooltipText = ""
	
	&AlterarProduto.FromImage(ActionUpdate)
	&AlterarProduto.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &ConForCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Código no Concorrente'), DVMessageType.error, &ConForCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &ConProVlr.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Preço Unit.'), DVMessageType.error, &ConProVlr.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &ProCod.IsValid

	&Mensagem = ''
	mensagem.Caption = &Mensagem
	Do 'LoadProduto'
	do 'LoadProdutoConcorrente'

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	
	if &CheckRequiredFieldsResult = True
		do 'LoadProduto'
		if &IsErroProduto = false
			GravaProdutoConcorrente.Call(&ConEmpCod, &ConCod, &ProCod, &ConForCod, &ConProVlr, &Mensagem)
			grid.Refresh()
			mensagem.Caption = &Mensagem
			do 'limpa'
		EndIf
	EndIf
	
	&ProCod.SetFocus()

EndEvent

Event &EliminarProduto.Click

	deletaProdutoConcorrente.Call(&ConEmpCod, &ConCod, &gridConProCod)
	grid.Refresh()
	
	&ProCod.SetFocus()

EndEvent

Event 'PromptProduto'

	4
	PromptProduto.Popup(&ConEmpCod, &ProCod)

EndEvent

Sub 'limpa'

	&ProCod.SetFocus()
	do 'loadProduto'
	&ConForCod.SetEmpty()
	&ConProVlr.SetEmpty()

EndSub

Sub 'LoadProdutoConcorrente'

	For Each Order ConEmpCod, ConCod, ConProCod
		Where ConEmpCod = &ConEmpCod
		Where ConCod = &ConCod
		Where ConProCod = &ProCod
		
		&ConForCod = ConForCod
		&ConProVlr = ConProVlr
		Exit
	EndFOr

EndSub

Sub 'LoadProduto'

	&IsErroProduto = true
	&ProNom = '<-- INFORME O CÓDIGO DO PRODUTO'
	If &ProCod <> 0
		For Each Order EmpCod, ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			&ProNom = ProNom
			&IsErroProduto = false
		When None
			&ProNom = 'PRODUTO NÃO ENCONTRADO'
		EndFor
	EndIF

EndSub

Sub 'loadConcorrente'

	For Each Order ConEmpCod, ConCod
		Where ConEmpCod = &ConEmpCod
		Where ConCod = &ConCod
		&ConCodRaz = ConCodRaz
		
		Exit
	EndFor

EndSub


]]></Source>
