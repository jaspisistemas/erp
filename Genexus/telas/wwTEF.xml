      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WWPContext)
	&Imprimir.Title = 'Imprimir'
	&Historico.Title = 'Histórico'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' TEF'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	TefSts.ColumnHeaderClass = !'WWColumn hidden-xs'
	TefCreDebVou.ColumnHeaderClass = !'WWColumn hidden-xs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Imprimir = !'<i class="far fa-file-pdf"></i>'
	If (TefSts = 'S')
		&Imprimir.Class = !'Attribute'
	Else
		&Imprimir.Class = !'Invisible'
	Endif
	&Historico = !'<i class="fas fa-bars"></i>'
	
	Do Case
		Case TefSts.ToString().Trim() = !"P"
			TefSts.ColumnClass = !'WWColumn hidden-xs WWColumnBold WWColumnBoldSingleCell'
		Case TefSts.ToString().Trim() = !"F"
			TefSts.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case TefSts.ToString().Trim() = !"S"
			TefSts.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Otherwise
			TefSts.ColumnClass = 'WWColumn hidden-xs'
	EndCase
	Do Case
		Case TefCreDebVou.ToString().Trim() = !"D"
			TefCreDebVou.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case TefCreDebVou.ToString().Trim() = !"C"
			TefCreDebVou.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			TefCreDebVou.ColumnClass = 'WWColumn hidden-xs'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovoTEF'

	TEf_Avulso.Popup(&WWPContext.EmpCod, &WWPContext.FilCod, 0, &BanCarCod, &TefCreDebVou, &TefCrePar, &TotCreVlrDup, 0)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"TEF"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event TefID.Click

	Tef_Retorno.Popup('AVULSO', EmpCod, TefCod)
	Refresh

EndEvent

Event &Imprimir.Click

	wpImprimirTEf.popup(EmpCod, TefCod)
//	RetornaTefAutorizado.call(EmpCod, TefCod, &TefMsg)
//	if not &TefMsg.IsEmpty()
//		RCOOpenWindow1.LinkOpen = TEF_COmPROVANTE_0.Link(EmpCod, TefCod)
//		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
//	Endif

EndEvent

Event &Historico.Click

	wwTefHistorico.Popup(EmpCod, TefCod)

EndEvent


