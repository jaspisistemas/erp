      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPFORNECEDORPRODUTO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	do 'LoadNomes'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	ProForCod.ColumnHeaderClass = !'WWColumn hidden-xs'

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UpdateButton = !'<i class="fa fa-pen"></i>'
	
	&DeletarPreco = !'<i class="fa fa-times"></i>'

	ProForCod.ColumnClass = iif(ProForCod = &ProPadForCod, !'WWColumn hidden-xs WWColumnSuccess WWColumnSuccessSingleCell', !'WWColumn hidden-xs')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PedCod.Link = ''
	RetornaUltimaCompraFornecedor.Call(EmpCod, &Context.FilCod, ProForCod, ProCod, 1, &PedCod, &PedDtaEms, &PedVlrUnt )
	if &PedCod > 0
		&PedCod.Link = verPedido.Link('', EmpCod, &Context.FilCod, &PedCod)
	EndIF

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraProdutos'

	Do Case 
		CAse &DeOndeVem = 'Produto'
			Produtos.Link('', TrnMode.Insert, &EmpCod, 0, &ParProRef)
		CAse &DeOndeVem = 'ImpProduto'
	   		ImpProduto.Link(TrnMode.Insert, &EmpCod, 0)
		Case &DeOndeVem = 'WWIMPPRODUTO'
			WWimpProduto.Link()
		Case &DeOndeVem = 'WWPRODUTO'
			WWProduto.Link()
		Case &DeOndeVem = 'WPESTOQUEFORNECEDOR'
			WPEstoqueFornecedor.call()
		Otherwise
			WWProduto.Link()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	CadastroProdutoFornecedor.link(&EmpCod, &ProCod, 0, &DeOndeVem)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &UpdateButton.Click

	CadastroProdutoFornecedor.link(EmpCod, ProCod, ProForCod, 'P')

EndEvent

Event &DeletarPreco.Click

	ProdutoFornecedor.Link(TrnMode.Delete, EmpCod, ProCod, ProForCod)

EndEvent

Sub 'LoadNomes'

	If &ProCod <> 0
		For Each Order EmpCod, ProCod
			Where EmpCod = &Context.EmpCod
			Where ProCod = &ProCod
			&ProNom = ProRefNom
			&ProPadForCod = ProPadForCod
			Exit
		EndFor
	EndIF

EndSub


]]></Source>
