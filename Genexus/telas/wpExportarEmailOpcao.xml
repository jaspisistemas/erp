      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	padraousuario.Call('L', '#EMAILEXPORTOpcoes#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&ExportarTipoEmail = Substr(&PadObs, 1, 1)
	if Substr(&PadObs, 2, 1) = '1'
		&ExportarUmEmail = true
	Else
		&ExportarUmEmail = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&SdtEmail.Clear()
	&AuxPesCod = 0
	
	For each
		order EmpCod, PesSts, PesIsCli, PesCliHabVenInt, PesRaz, PesCod, PesEmlCod  when &OrderedBy = 1
		order EmpCod, PesSts, PesIsCli, PesCliHabVenInt, PesCidUfeCod, PesCidNom, PesRaz, PesCod, PesEmlCod  when &OrderedBy = 2
		order EmpCod, PesSts, PesIsCli, PesCliHabVenInt, PesPrxLig, PesRaz, PesCod, PesEmlCod  when &OrderedBy = 3
		order EmpCod, PesSts, PesIsCli, PesCliHabVenInt, (PesUltVenDta), PesRaz, PesCod, PesEmlCod  when &OrderedBy = 4
		
		using DSwwClienteTelevendas(&PesIntVenCod, &PesIntBlo, &PesCod, &PesCidAreCod, &PesPrxLigDta, &PesPrxLigDta_To
		, &TodosAgendados, &PesSts, &PesIsCli, &PesIsCli_To, &PesCliHabVenInt, &DynamicFiltersSelector1
		, &PesRaz1, &PesCidUfeCod1, &PesCidCod1, &PesCidNom1, &RatCod1, &PesCpf1
		, &PesUltVenDta1, &PesUltVenDta_To1, &DynamicFiltersEnabled2, &DynamicFiltersSelector2, &PesRaz2, &PesCidUfeCod2
		, &PesCidCod2, &PesCidNom2, &RatCod2, &PesCpf2, &PesUltVenDta2, &PesUltVenDta_To2
		, &DynamicFiltersEnabled3, &DynamicFiltersSelector3, &PesRaz3, &PesCidUfeCod3, &PesCidCod3, &PesCidNom3
		, &RatCod3, &PesCpf3, &PesUltVenDta3, &PesUltVenDta_To3, &DynamicFiltersEnabled4, &DynamicFiltersSelector4
		, &PesRaz4, &PesCidUfeCod4, &PesCidCod4, &PesCidNom4, &RatCod4, &PesCpf4
		, &PesUltVenDta4, &PesUltVenDta_To4, &DynamicFiltersEnabled5, &DynamicFiltersSelector5, &PesRaz5, &PesCidUfeCod5
		, &PesCidCod5, &PesCidNom5, &RatCod5, &PesCpf5, &PesUltVenDta5, &PesUltVenDta_To5)
		Where PesEmlFin = true when &ExportarTipoEmail = 'F'
		Where PesEmlPed = true when &ExportarTipoEmail = 'P'
		Where PesEmlFat = true when &ExportarTipoEmail = 'N'
		
		
		&PesEml = PesEml.Trim()
		&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
	   
	   if &AuxPesCod <> PesCod or &ExportarUmEmail = false
		   &IsAdd = false
			If not &PesEml.IsEmpty() and (&PesEml.IsMatch(&pattern) = true)
				&IsAchou = false
				for &SdtEmailItem in &SdtEmail
					if &SdtEmailItem.EmlUrl = &PesEml.Trim()
						&IsAchou = true
						&IsAdd = true
						&AuxPesCod = PesCod
						Exit
					Endif
				EndFor
				
				if &IsAchou = false
					&IsAdd = true
					&AuxPesCod = PesCod
					&SdtEmailItem = new()
					&SdtEmailItem.EmlUrl = &PesEml.Trim()
					&SdtEmail.Add(&SdtEmailItem)
				Endif
			Endif
		Endif
	EndFor
	
	for &SdtEmailItem in &SdtEmail
		&Mensagem += &SdtEmailItem.EmlUrl.Trim() + '; '
	EndFor

	&PadObs = &ExportarTipoEmail
	if &ExportarUmEmail = true
		&PadObs += '1'
	Else
		&PadObs += '0'
	Endif
	padraousuario.Call('G', '#EMAILEXPORTOpcoes#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	padraousuario.Call('G', '#EMAILEXPORTSDT#', &Context.PesCod, &Context.EmpCod, &SdtEmail.toJson(), &PadDtaMod)
	
	padraousuario.Call('G', '#EMAILEXPORT#', &Context.PesCod, &Context.EmpCod, &Mensagem, &PadDtaMod)
	WpExportarEmails.Popup()
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
