      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&OqueFazer = &parOqueFazer
	&CotComForCod = &parCotComForCod
	if &OqueFazer <> 'INS'
		&OldCotComForCod = &parCotComForCod
		&CotComForCod.Enabled = 0
		tbJaexisteProduto.Visible = false
		&IsAdicionarTodos = false
		Form.Caption = 'Alterar Fornecedor Cotação'
		
		if &OqueFazer = 'DEL'
			&CotComForEmail.Enabled = false
			&CotComForNum.Enabled = false
			btnEnter.Caption= '[ Eliminar fornecedor ]'
			Form.Caption = 'Eliminar Fornecedor Cotação'
		Endif
		
		do 'loadLancamento'
	Else
		Form.Caption = 'Adicionar Fornecedor Cotação'
		&OqueFazer = 'INS'
		do 'verificaItensJaAdicionados'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'ValidaFone'
	do 'ValidaEmail'
	do 'validaJaCadastrado'
	Do CAse
		Case &IsExiste = true and &OqueFazer = 'INS'
			msg('Fornecedor Já adicionado a Cotação de Compra!')
			&CotComForCod.SetFocus()
		CAse &IsErroCotComForCod = true
			msg('Fornecedor não informado ou inválido!')
			&CotComForCod.SetFocus()
		CAse &IsErrorFone = true and &OqueFazer <> 'DEL'
			msg(' Número de telefone inválido!')
			&CotComForNum.SetFocus()
		Case &IsErrorEmail = true and &OqueFazer <> 'DEL'
			msg('Endereço de E-mail não coincide com o padrão especificado!')
			&CotComForEmail.SetFocus()		
		Case &CotComForEmail.IsEmpty() and &OqueFazer <> 'DEL'
			msg('Endereço de E-mail Obrigatório!')
			&CotComForEmail.SetFocus()				
		Otherwise
		
			prcAddFornecedorCotacao.Call(&OqueFazer, &EmpCod, &CotComCod, &CotComForCod, &CotComForNum, &CotComForEmail, &IsAdicionarTodos)
		
			wwpActions.WCPopup_Close('')
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CotComForNum.IsValid

	do 'ValidaFone'

EndEvent

Event &CotComForEmail.IsValid

	do 'ValidaEmail'

EndEvent

Event &CotComForCod.IsValid

	if &OldCotComForCod <> &CotComForCod
		&OldCotComForCod = &CotComForCod
		do 'loadFornecedor'	
		do 'loadFoneEmail'
	Endif

EndEvent

Sub 'validaJaCadastrado'

	&IsExiste = false
	For Each Order EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComForCod = &CotComForCod
		&IsExiste = true
		Exit
	EnDfor

EndSub

Sub 'ValidaEmail'

	&IsErrorEmail = false	
	if not &CotComForEmail.IsEmpty()
		&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
		if (&EmailVerificacao.IsMatch(&pattern) = false)
			
			&IsErrorEmail = True
		EndIf
	Endif

EndSub

Sub 'ValidaFone'

	FormataFONE.Call(&CotComForNum,&CotComForNum)
	&IsErrorFone = false
	RetornaSoNumeros.Call(&CotComForNum, &Varchar)
	if (&Varchar.Length() >= 10 and &Varchar.Length() < 13) or &Varchar.IsEmpty()
	else
		&IsErrorFone = true
	EndIf

EndSub

Sub 'loadLancamento'

	For Each Order EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComForCod = &CotComForCod
		
		RetornaNomePessoa.Call(EmpCod, CotComForCod, &CotComForRaz)
		
		&CotComForEmail = CotComForEmail
		&CotComForNum = CotComForNum
		
		Exit
	Endfor

EndSub

Sub 'loadFornecedor'

	&CotComForRaz = 'SELECIONE O FORNECEDOR'
	&IsErroCotComForCod = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CotComForCod
		
		&CotComForRaz = PesRaz
		
		if PesSts = Status_AtivoInativo.INATIVO or PesIsFor = false
			&IsErroCotComForCod = true
		Endif
		
		Exit
	When none
		&IsErroCotComForCod = true
	EndFor

EndSub

Sub 'loadFoneEmail'

	&CotComForNum.SetEmpty()
	&CotComForEmail.SetEmpty()
	
	//email
	For Each Order EmpCod, PesCod, PesEmlCod
		Where EmpCod = &EmpCod
		Where PesCod = &CotComForCod
		Where PesEmlPed = true
		&CotComForEmail = PesEml.Trim()
		Exit
	EndFor

	//fone
	For Each Order EmpCod, PesCod, PesFonCod
		Where EmpCod = &EmpCod
		Where PesCod = &CotComForCod
		Where PesFonWhatsPed = true
		&CotComForNum = PesFonNum.Trim()
		Exit
	EndFor

EndSub

Sub 'verificaItensJaAdicionados'

	tbJaexisteProduto.Visible = false
	&IsAdicionarTodos = false
	For Each Order EmpCod, CotComCod, CotComItmCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		
		tbJaexisteProduto.Visible = true
		&IsAdicionarTodos = true
		Exit
	EndFor

EndSub


]]></Source>
