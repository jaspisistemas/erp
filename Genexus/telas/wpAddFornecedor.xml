        <Source><![CDATA[parm(in:&parOqueFazer, in:&EmpCod, in:&CotComCod, in:&parCotComForCod);


prompt(promptFornecedores, &EmpCod, &CotComForCod);
prompt(promptPessoaEmail, &CotComForCod, &CotComForEmail);
prompt(promptPessoaFone, &CotComForCod, &CotComForNum);
]]></Source>
