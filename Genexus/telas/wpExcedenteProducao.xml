      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&AuxGrupHie = &GrupHie.Trim() + '.'
	&ProSetCod.Enabled = true
	&ProTipDef.Enabled = true
	&GrupHie.Enabled = True
	&ClsPrdCod.Enabled = True

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 10
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	UltimaDataQuantidadeProducaoExcedente.Call(EmpCod, FilCod, 0, serverdate(), ProCod, ProGraCod, &UltEstQtd, &EstUltOrd, &GrupHie, &ProSetCod)
	         UltimaDataQuantidadeProducao.Call(EmpCod, FilCod, 0, serverdate(), ProCod, ProGraCod, &OrdEstPrd, &OrdUltOrd, &GrupHie, &ProSetCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If &UltEstQtd.IsEmpty() and EstPrd < 0
		ProNom.ForeColor = RGB(160,0,0)
		ProCod.ForeColor = RGB(160,0,0)
	Else
		ProNom.ForeColor = RGB(0,0,0)	
		ProCod.ForeColor = RGB(0,0,0)
	EndIF

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do Case
		Case &ProTipDef.Trim().IsEmpty() or &ProSetCod.IsEmpty() 
			Msg('ATENÇÃO! Só é possível gerar exedente por DEFINIÇÃO do produto e SETOR, então esses filtros não podem estar vazios ou selecionada TODAS.')
		OtherWise
			CarregaSdtProducao.Call(&EmpCod, &FilCod, &ProSetCod, &ProTipDef, &GrupHie, 4, TipoOrdem.ExedenteProducao, &ClsPrdCod, &sdtOrdemProducao)
			
			GravaOrdemProducao.Call(&EmpCod, &FilCod, &GrupHie, &ProSetCod, &ClsPrdCod, &sdtOrdemProducao, TipoOrdem.ExedenteProducao, &OrdCod)
			
			wpConfirmaOrdem.Popup(&FilCod, &OrdCod, 4)
			Refresh
	EndCase

EndEvent


]]></Source>
