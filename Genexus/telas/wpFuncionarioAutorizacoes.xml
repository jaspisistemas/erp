        <Source><![CDATA[
Event Start

	loadWwpContext.Call(&WwpContext)
	do 'loadFuncionario'
	REtornaEmpresaModulo.Call(&wwpContext.EmpCod, moduloSistema.PDV_M, &PDV_M)
	tbautorizacaoPDV.Visible = (&PDV_M = 'S')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.DESCONTO_QUANTIDADE, &IsDescontoMaximo, &WwpContext.UserName)
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.LIMITE_CREDITO, &IsLimiteCredito, &WwpContext.UserName)
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.PDVBrindes, &IsBrindeItens, &WwpContext.UserName)
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.REDEFINIRFINANCEIRO, &IsCancelarVenda, &WwpContext.UserName)
	
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.CANCELARITEMPEDIDO, &IsCancelarDevolverItem, &WwpContext.UserName)
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.ACESSOADMINISTRATIVO, &IsFuncoesAdministrativas, &WwpContext.UserName)
	
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.SALDODEVEDOR, &IsSaldoDevedor, &WwpContext.UserName)
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.VENDAABERTO, &IsManterVendasAbertas, &WwpContext.UserName)
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.VENDAFUNCIONARIO, &IsVendaFuncionario, &WwpContext.UserName)
	GravaFuncionarioTelasAutorizadas.Call(&EmpCod, &WwpContext.FilCod, &PesCod, AutorizaTela.TROCARCLIENTEPEDIDO, &IsVendaFuncionario, &WwpContext.UserName)
	
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'loadFuncionario'

	&IsLimiteCredito = false
	&IsDescontoMaximo = false
	&IsBrindeItens = false
	&IsCancelarVenda = false
	&IsCancelarDevolverItem = false
	&IsFuncoesAdministrativas = false
	
	For Each Order EmpCod, PesCod
		where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PesRaz = PesRaz
		
			For Each Order EmpCod, PesCod, PesSenItm				
				Do CAse
					CAse PesSenLoc = AutorizaTela.DESCONTO_QUANTIDADE
						&IsDescontoMaximo = true
					CAse PesSenLoc = AutorizaTela.LIMITE_CREDITO
						&IsLimiteCredito = true
					CAse PesSenLoc = AutorizaTela.PDVBrindes
						&IsBrindeItens = true						
					Case PesSenLoc =  AutorizaTela.REDEFINIRFINANCEIRO
						&IsCancelarVenda = true
					Case PesSenLoc = AutorizaTela.CANCELARITEMPEDIDO
						&IsCancelarDevolverItem = true						
					Case PesSenLoc = AutorizaTela.ACESSOADMINISTRATIVO
					 	&IsFuncoesAdministrativas = true
					Case PesSenLoc = AutorizaTela.SALDODEVEDOR
						&IsSaldoDevedor = true
					Case PesSenLoc = AutorizaTela.VENDAABERTO
						&IsManterVendasAbertas = true
					Case PesSenLoc = AutorizaTela.VENDAFUNCIONARIO
						&IsVendaFuncionario = true
					Case PesSenLoc = AutorizaTela.TROCARCLIENTEPEDIDO
						&IsTrocarCliente = true
				EndCAse
			EndFor
		
		Exit
	EndFor

EndSub


]]></Source>
