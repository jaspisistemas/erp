        <Source><![CDATA[
Event Start

	&SplittedGeolocation = &Geolocation.SplitRegEx(',')
	
	if &SplittedGeolocation.Count = 2
		&GxMapPoint.PointLat = &SplittedGeolocation.Item(1).Trim()
		&GxMapPoint.PointLong = &SplittedGeolocation.Item(2).Trim()
		&GxMapData.Points.Add(&GxMapPoint) 
		googleMapControl1.Latitude = &SplittedGeolocation.Item(1).Trim()
		googleMapControl1.Longitude = &SplittedGeolocation.Item(2).Trim()
	endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if not &Latitude.IsEmpty() OR not &Geolocation.Trim().IsEmpty()
		if not &Latitude.IsEmpty()
			&Geolocation = &Latitude + ',' + &Longitude
		endif
		return
	endif

EndEvent


]]></Source>
