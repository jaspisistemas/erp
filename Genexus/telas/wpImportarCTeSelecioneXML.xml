        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod
	&FilCod = &WwpContext.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	asdd.Width = 250
	asdd.Height = 70
	asdasd.Width = 250
	asdasd.Height = 70

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		wpImportarCTe(!'SelecioneXML', !'Envolvidos', false, &SessionGuid)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	endif

EndEvent

Event 'DoSelecionarArquivo'

	wpSelecionaCTeManifestacao.Popup(&WebSessionKey, &EmpCod, 0)
	wpImportarCTe.Link('SelecioneXML', 'Envolvidos', false, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event FileUpload1.UploadComplete

	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&NomeArquivoXml = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			GravaXmlCteTerceiros.Call(&WebSessionKey, &EmpCod, &NomeArquivoXml, '')
			
			wpImportarCTe.Link('SelecioneXML', 'Envolvidos', false, &SessionGuid)
		EndiF
	EndFor

EndEvent


]]></Source>
