      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbDadosAntecipacao.Visible = 0
	retornaAutorizacao.Call('WWTABELAPRECO', Status_SimNao.Sim, 2, &AutNiv)
	LoadWWPContext.Call(&Context)
	
	&TabDtaFin = serverdate()
	&newTabDtaIni = &TabDtaFin + 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&newTabDtaFin.TooltipText = "Data final da Validade desse Congelamento. Caso não Tenha uma Data limite deixe em Branco."
	&TabDtaFin.TooltipText = "Será gravado em todos os produtos essa Data final de Validade."
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadTabela'

EndEvent

Event 'DoFechar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWTabelaPreco.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &TabDtaFin.IsValid

	&newTabDtaIni = &TabDtaFin + 1

EndEvent

Event Enter

	do 'loadTabela'
	
	Do Case
		Case &TabDtaFin.IsEmpty()
			msg('Obrigatório informar uma data final para a Alteração Anterior!')
		Case &TabCglDtaFin >= &TabDtaFin
			msg('Já possui um Congelamento com Data Maior ou Igual a essa. O novo congelamento só pode ser feito com data superior à ' + trim(ToformattedString(&TabCglDtaFin))+ '!')
		Case (&TabIsAntAcr = true and (&TabDtaVct.IsEmpty() or &TabDtaFin > &TabDtaVct))
			msg('Necessário Informar data Vencimento e não pode ser menor que Data do Congelamento!')
			&TabDtaVct.SetFocus()
		Otherwise
			&newTabDtaIni = &TabDtaFin + 1
			
			msg('Aguarde...')
			BtnEnter.Visible = 0
			&ProgressId = 'CongTabela' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			CongelaTabelaPreco.Submit('CongelaTabelaPreco', &ProgressId, &EmpCod, &TabCod, &TabDtaFin, &newTabDtaIni, &newTabDtaFin, &TabDtaVct)
			
	EndCase

EndEvent

Event scaProgressBar1.OnComplete

	msg('Congelamento realizado com Sucesso!')

EndEvent

Sub 'loadTabela'

	For Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		
		&OldTabUltAlt = TabUltAlt - 1
		
		&TabUltAlt = TabUltAlt
		&newTabUltAlt = TabUltAlt + 1
		&TabIsAntAcr = TabIsAntAcr
		
		if TabIsAntAcr = true
			tbDadosAntecipacao.Visible = 1
			tbDadosVencimento.Visible = 0
		Endif
		
		For Each Order EmpCod, TabCod, TabCglCod
			where TabCglCod = &OldTabUltAlt
			&TabCglDtaFin = TabCglDtaFin
			Exit
		EndFor
	
		Exit
	EndFor

EndSub


]]></Source>
