      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&AuxEmpCod = &Context.EmpCod
	&PrcHisHor = '00:00:00'
	&PrcHisDta = serverdate()
	&PrcHisIs = False
	
	&UsuPesCod = &Context.PesCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 500
	&EmpCod.Visible = False
	&PescodNomePequeno10.Visible = False
	GridSdtClientess.Rows = 8
	GridSdtClientessPaginationBar.RowsPerPageSelectedValue = GridSdtClientess.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)
	&UsuPesCod = &Context.PesCod
	do 'carregaSDT'
	do 'loadHistorico'
	Do 'loadCliente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridSdtClientessCurrentPage = GridSdtClientess.CurrentPage
	&GridSdtClientessPageCount = GridSdtClientess.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtClientess.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtClientessPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSdtClientessPaginationBar.SelectedPage = !'Previous'
			GridSdtClientess.PreviousPage()
		Case GridSdtClientessPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridSdtClientess.CurrentPage
			&PageToGo += 1
			GridSdtClientess.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridSdtClientessPaginationBar.SelectedPage)
			GridSdtClientess.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtClientessPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtClientess.Rows = GridSdtClientessPaginationBar.RowsPerPageSelectedValue
	GridSdtClientess.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AgeCliCod.IsValid

	Do 'loadCliente'

EndEvent

Event &AgeCliCod.ControlValueChanged

	Do 'loadCliente'

EndEvent

Event Enter

	&Count.SetEmpty()
	For &sdtClientesItem in &SdtClientes
		if &sdtClientesItem.IsSelect = true
			&Count += 1
		EndIf
	EndFor
	
	FormataHora.Call(&PrcHisHor, &PrcHisHor)
	do 'loadDstCodNom'
	Do Case 
		Case &PrcHisDta.IsEmpty()
			&mensagem = 'DATA COMPROMISSO é obrigatório.'
			&PrcHisDta.SetFocus() 
		Case &PrcHisDta.IsEmpty()
			&mensagem = 'DATA REGISTRO não pode ser anterior à Hoje.'
			&PrcHisDta.SetFocus()
		Case &PrcHisObs.IsEmpty()
			&mensagem = 'OBSERVAÇÃO/AGENDAMENTO é obrigatório.'
			&PrcHisObs.SetFocus()
		case &auxDstCod.IsEmpty() and not &DstCod.IsEmpty()
			&mensagem = 'DESTAQUE DO COMPROMISSO, inválido.'
			&DstCod.SetFocus()
		case &Count = 0
			&mensagem = 'Você deve selecionar no mínimo um usuário para este compromisso!'
		Otherwise
			GravaCompromissoAgenda.Call(&EmpCod, &AgeCod, '0', &PrcHisDta, &PrcHisHor, &PrcHisObs, &auxDstCod, &UsuPesCod, 0,&AgeCliCod, &sdtClientes, &Context.UserName)
			Return
	EndCAse
	Msg(&mensagem)

EndEvent

Event &PrcHisHor.IsValid

	FormataHora.Call(&PrcHisHor, &PrcHisHor)

EndEvent

Sub 'loadDstCodNom'

	RetornaCodigoDestaqueSugestNome.Call(&EmpCod, &DstCod, &auxDstCod)

EndSub

Sub 'carregaSDT'

	&sdtClientes.Clear()
	
	&IsSelecnt = false
	do 'verificaSelecionado'
	If &PesCod = &Context.PesCod and &AgeCod = 0
		&IsSelecnt = true
	EndIF

	For Each Order EmpCod, PesRaz
		Where EmpCod = &EmpCod
		Where PesCod > 0
		Where PesSts = Status_AtivoInativo.ATIVO
		Where not PesExtCod.IsEmpty() and Not PesExtCod.IsNull()
		
		&PesRaz = PesRaz
		&PesCod = PesCod
		
		&IsSelecnt = false
		do 'verificaSelecionado'
		
//		&IsSelecnt.Enabled = true
		If PesCod = &Context.PesCod and &AgeCod = 0
//			&IsSelecnt.Enabled = false
			&IsSelecnt = true
		EndIF
		
		&sdtClientesItem = new()
		&sdtClientesItem.CreCliCod = PesCod
		&sdtClientesItem.PesRaz = PesRaz
		&sdtClientesItem.IsSelect = &IsSelecnt
		&sdtClientes.Add(&sdtClientesItem)
	EndFor

EndSub

Sub 'verificaSelecionado'

	For Each Order EmpCod, AgeCod, AgePesCod
		Where EmpCod = &EmpCod
		Where AgeCod = &AgeCod
		Where AgePesCod = &PesCod
		&IsSelecnt = true
	EndFor

EndSub

Sub 'loadHistorico'

	For Each Order EmpCod, AgeCod
		Where EmpCod = &EmpCod
		Where AgeCod = &AgeCod
		&AgeCliCod = AgeCliCod
		&PrcHisDta = AgeDta
		&PrcHisHor = AgeHor
		&PrcHisObs = AgeObs
		&DstCodNom = DstCodNom
		&auxDstCod = DstCod
		//&PrcHisVisCli = PrcHisVisCli
		//&PrcHisIs = PrcHisIs
		Exit
	When None
		For Each Order EmpCod, DstCod
			Where EmpCod = &EmpCod
				&DstCodNom = DstCodNom
				&auxDstCod = DstCod
			Exit
		EndFor
	
	EndFor

	&DstCod = &DstCodNom

EndSub

Sub 'loadCliente'

	For each order EmpCod, PesCod
		where EmpCod = &EmpCod
		where PesCod = &AgeCliCod
		where PesSts = Status_AtivoInativo.ATIVO
		&PesRaz = PesRaz
		exit
	when none
		&PesRaz.SetEmpty()
		if not &AgeCliCod.IsEmpty()
			msg('Cliente não localizado ou Inativo.')
		EndIf
		&AgeCliCod.SetEmpty()
		&AgeCliCod.SetFocus()
	EndFor

EndSub


]]></Source>
