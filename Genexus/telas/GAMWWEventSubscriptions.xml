      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WWPContext)
	if &WWPContext.Old_Perfil <> 3
		Dashboard.Link()
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Form.Caption = 'WWP_GAM_EventSubscriptions'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	TextBlockTitle.Caption = Form.Caption

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	//&GridPageCount has to be loaded manually

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&GridPageSize = Grid.Rows
	&GAMEventSubscriptions = GAMRepository.GetEventSubscriptions(&EventSubscriptionFilter, &Errors)	
	If &GAMEventSubscriptions.Count = 0
		&GridPageCount = 0
	Else
		&GridPageCount = (&GAMEventSubscriptions.Count/&GridPageSize) + iif(Mod(&GAMEventSubscriptions.Count, &GridPageSize) > 0, 1, 0)
	EndIf
	&GridRecordCount = &GAMEventSubscriptions.Count
	For &EventSuscription in &GAMEventSubscriptions
		&Id			= &EventSuscription.Id
		&Description= &EventSuscription.Description
		&Status		= &EventSuscription.Status		
		&Event	  	= &EventSuscription.Event
		&FileName 	= &EventSuscription.FileName
		&ClassName	= &EventSuscription.ClassName		
		&MethodName = &EventSuscription.MethodName

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the data
	
	&Display = !'<i class="fa fa-search"></i>'
	&Display.Link = GAMEventSubscriptionEntry.Link(GAMAPiMode.Display, &Id)
	&Update = !'<i class="fa fa-pen"></i>'
	&Update.Link = GAMEventSubscriptionEntry.Link(GAMAPiMode.Update, &Id)
	&Delete = !'<i class="fa fa-times"></i>'
	&Delete.Link = GAMEventSubscriptionEntry.Link(GAMAPiMode.Delete, &Id)
	&Subscribe = !'<i class="fa fa-plus"></i>'
	
	&Description.Link = GAMEventSubscriptionEntry.Link(GAMAPiMode.Display, &Id)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

If &Status = GAMEventSubscriptionStatus.Subscribed
	&Subscribe = !'<i class="fa fa-minus"></i>'
	&Subscribe.TooltipText = "Unsubscribe"
endif
		Load
	
	EndFor

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GAMEventSubscriptionEntry.Call(GAMAPiMode.Insert, '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Subscribe.Click

	If &Status = GAMEventSubscriptionStatus.Unsubscribed
		&isOK = GAMRepository.SubscribeEvent(&Id, &Errors)
		&Status = GAMEventSubscriptionStatus.Subscribed
	Else
		&isOK = GAMRepository.UnsubscribeEvent(&Id, &Errors)
		&Status = GAMEventSubscriptionStatus.Unsubscribed
	EndIf
	If not &isOK
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor
	Else		
		If &Status = GAMEventSubscriptionStatus.Unsubscribed
			Msg("Event " + &Description + " Unsubscription success")
		Else
			Msg("Event " + &Description + " subscription success")
		EndIf
		commit
		Grid.Refresh()
	EndIf

EndEvent


]]></Source>
