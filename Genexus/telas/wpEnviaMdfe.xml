Sub 'LoadDados'

	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilEnvEml = FilEnvEml
		Exit	
	EndFor
	
	&SdtEmail.Clear()
	For Each Order EmpCod, FilCod,MDFeCod, MDFeCteItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		&FilFonNum = FilFonNum		
		&MdfeNum = MDFeNum
		&EmlAss = 'Manifesto de Conhecimento de Transporte ' + trim(toformattedString(&MdfeNum)) + ' da ' + trim(FilFan)
		&PesRaz = FilRaz
		&MDFeCteCod = MDFeCteCod
		&MDFeCteFilCod = MDFeCteFilCod
		
		Do 'CarregaCte'
	EndFor

	For Each Order EmpCod, FilCod,MDFeCod,MDFeNFeItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		&FilFonNum = FilFonNum		
		&MdfeNum = MDFeNum
		&EmlAss = 'Manifesto de Conhecimento de Transporte ' + trim(toformattedString(&MdfeNum)) + ' da ' + trim(FilRaz)
		&PesRaz = FilRaz
		&MdfeNfeCod = MDFeNfeCod
		&MDFeNFeFilCod = MDFeNFeFilCod
		Do 'CarregaNfe'
	EndFor

	For &ItemSdtEmail in &SdtEmail
		Do Case
			Case &EmlUrl1.IsEmpty()
				&EmlUrl1 = &ItemSdtEmail.EmlUrl
				
			Case &EmlUrl2.IsEmpty()
				&EmlUrl2 = &ItemSdtEmail.EmlUrl
				
			Case &EmlUrl3.IsEmpty()
				&EmlUrl3 = &ItemSdtEmail.EmlUrl
				
			Case &EmlUrl4.IsEmpty()
				&EmlUrl4 = &ItemSdtEmail.EmlUrl
				
			Case &EmlUrl5.IsEmpty()
				&EmlUrl5 = &ItemSdtEmail.EmlUrl
				
			Case &EmlUrl6.IsEmpty()
				&EmlUrl6 = &ItemSdtEmail.EmlUrl
				
			Otherwise
				Exit
		EndCAse
	EndFor
	&SdtEmail.Clear()

EndSub

Sub 'carregacte'

	For each order EmpCod,FilCod,CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &MDFeCteFilCod
		Where CteCod = &MDFeCteCod
		
		Do Case
			Case &FilEnvEml = EmailEnvolvidosCte.SomenteRemetente
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.Somentedestinatario
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.SomenteTomador
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.RemetenteDestinatario
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.RemetenteTomador
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.DestinatarioTomador
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.Todos
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)
		EndCase			
		
		Exit
	EndFor

EndSub

Sub 'CarregaNfe'

	For each order EmpCod,FilCod,NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &MDFeNFeFilCod
		Where NfeCod = &MdfeNfeCod
		RetornaEmailFaturamento.call(EmpCod, NfeCliCod, &SdtEmail)
		exit
	EndFor

EndSub


