      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	WizardStepDescription.Visible = 0
	retornaAutorizacao.Call('WWNOTAS', Status_SimNao.Sim, 2, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'Capa'
	&WizardStep.Title = 'Destino\Transp.'
	&WizardStep.Description = 'Destino\Transp.'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Produtos'
	&WizardStep.Title = 'Produtos'
	&WizardStep.Description = 'Produtos'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Totais'
	&WizardStep.Title = 'Cobrança/Totais'
	&WizardStep.Description = 'Cobrança/Totais'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Autorizar'
	&WizardStep.Title = 'Transmissão'
	&WizardStep.Description = 'Transmissão'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'Capa'
		&WebSession.Remove(&Pgmname + !'_Data')
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsUnderlineWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&Pgmname + !'_Data'))
	if &WizardData.Capa.NfeCod.IsEmpty()
		btnImprimir.Visible = 0
	Endif
	if not &WizardData.Capa.DeOndeVem.IsEmpty()
		&DeOndeVem = &WizardData.Capa.DeOndeVem.Trim() + '.aspx'
	Endif

EndEvent

Event 'DoMonitoraNFe'

	If &DeOndeVem.IsEmpty()
		wwNotas.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		link(&DeOndeVem)
	Endif

EndEvent

Event 'DoImprimir'

	WpEspelhoNota.Popup(&WizardData.Capa.EmpCod, &WizardData.Capa.FilCod, &WizardData.Capa.NfeCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'Capa'
			WizardStepWC.Object = wpNotaCapa.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Produtos'
			WizardStepWC.Object = wpNotaProdutos.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Totais'
			WizardStepWC.Object = wpNotaTotais.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Autorizar'
			WizardStepWC.Object = wpNotaAutorizar.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: AssignWizardStepDescription
	WizardStepDescription.Caption = ""
	&StepNumber = 1
	for &WizardStep in &WizardSteps
		if &WizardStep.Code = &CurrentStepAux
			if not &WizardStep.Description.IsEmpty()
				WizardStepDescription.Caption = Format("Step %1/%2 :: %3",&StepNumber.ToString().Trim(),&WizardSteps.Count.ToString().Trim(),&WizardStep.Description)
			endif
		else
			&StepNumber += 1
		endif
	endfor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
