      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	RetornaConfSistema_wpPessoa.Call(&Context.EmpCod, &Context.FilCod, &sdtConfig_wpPessoa)
	If &sdtConfig_wpPessoa.CLIENTE_AutNiv > 1
		&WPALTERAVENDEDORCLIENTE_AutNiv = &sdtConfig_wpPessoa.WPALTERAVENDEDORCLIENTE_AutNiv
		If &sdtConfig_wpPessoa.WPALTERAVENDEDORCLIENTE_AutNiv < 1
			tbCliente_Vendedor.Visible	= 0
		EndIf
	Else
		tbCliente_Vendedor.Visible	= 0
	EndIf
	
	&SdtClienteXls.FromXml(&webSession.Get('ATUALIZAGRUPOCLIENTE'))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&X.Visible = False
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	&AuxPesCodRazSugg = &PesCliTraCodRaz
	do 'GetPessoa'
	&PesCliTraIs = &AuxPesIsTra
	&PesCliTraCod = &AuxPesCod
		
	&AuxPesCodRazSugg = &PesCliTraCodSaiRaz
	do 'GetPessoa'
	&PesCliTraSaiIs = &AuxPesIsTra
	&PesCliTraSaiCod = &AuxPesCod

	&AuxPesCodRazSugg = &PesIntVenCodNom
	do 'GetPessoa'
	&PesIntIsVen = &AuxPesIsVen
	&PesIntVenCod = &AuxPesCod
	&PesIntVenIntExt = &AuxPesVenIntExt
	
	&AuxPesCodRazSugg = &PesExtVenCodNom
	do 'GetPessoa'
	&PesExtIsVen = &AuxPesIsVen 
	&PesExtVenCod = &AuxPesCod
	&PesExtVenIntExt = &AuxPesVenIntExt

	Do case
		case &IsAlterarCidade = true and &PesCidCod.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Nova Cidade" é de preenchimento obrigatório, quando "(Alterar Cidade)" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesCidCod.SetFocus()
		case &IsAlterarCep = true and &PesCep.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Novo CEP" é de preenchimento obrigatório, quando "(Alterar CEP)" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesCep.SetFocus()
		Case &IsAlterarRamoAtividade = true and &RatCod.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Novo Ramo Ativ." é de preenchimento obrigatório, quando "(Alterar Ramo Ativ.)" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&RatCod.SetFocus()
		case &IsAlterargrupoImposto = true and &GruImpCod.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Novo Grup. Imposto" é de preenchimento obrigatório, quando "(Alterar Grupo Imposto)" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&GruImpCod.SetFocus()
			
		Case &IsAlteraTranspRedesVenda	= True And &PesCliTraCodRaz.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Nova Transp. Redespacho Venda (NF)" é de preenchimento obrigatório, quando "(Alterar Trans. Saída p/Compras / Trans. Redes. Venda (NF))" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesCliTraCodRaz.SetFocus()
		Case &IsAlteraTranspRedesCompra	= True And &PesCliTraCodSaiRaz.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Nova Transp. Redespacho Compra (NF)" é de preenchimento obrigatório, quando "(Alterar Trans. Saída p/Venda / Trans. Redes. Compra (NF))" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesCliTraCodSaiRaz.SetFocus()
		Case &PesCliTraIs = false and &PesCliTraCod > 1 and not &PesCliTraCodRaz.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'Insira Uma Transportadora válida.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesCliTraCodRaz.SetFocus() 
			
		Case &IsAlterarVendedorExterno	= True And &PesExtVenCodNom.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Novo Vendedor Externo" é de preenchimento obrigatório, quando "(Alterar Vendedor Externo)" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesExtVenCodNom.SetFocus()
		Case &IsAlterarVendedorInterno	= True And &PesIntVenCodNom.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'O campo "Novo Vendedor Interno" é de preenchimento obrigatório, quando "(Alterar Vendedor Interno)" for marcado.' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesIntVenCodNom.SetFocus()
		Case (&PesIntVenCod > 1 and (&PesIntIsVen = false or &PesIntVenIntExt <> Status_internoExterno.INTERNO)) and (&sdtConfig_wpPessoa.WPALTERAVENDEDORCLIENTE_AutNiv > 0)
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'Insira um Vendedor Interno válido' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesIntVenCodNom.SetFocus()		
		Case (&PesExtVenCod > 1 and (&PesExtIsVen = false or &PesExtVenIntExt <> Status_internoExterno.EXTERNO)) and (&sdtConfig_wpPessoa.WPALTERAVENDEDORCLIENTE_AutNiv > 0)
			msg(DVMessageGetBasicNotificationMsg.Udp(!"ATENÇÃO!", 'Insira um Vendedor Externo válido' , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesExtVenCodNom.SetFocus()
			
		Otherwise
			AtualizaGrupoCliente.Call(&EmpCod, &SdtClienteXls, &IsAlterarCidade, &PesCidCod, &IsAlterarCep, &PesCep, &IsAlterarRamoAtividade, &RatCod, &IsAlterargrupoImposto, &GruImpCod, &IsAlteraTranspRedesVenda, &PesCliTraCod, &IsAlteraTranspRedesCompra, &PesCliTraSaiCod, &WPALTERAVENDEDORCLIENTE_AutNiv, &IsAlterarVendedorExterno, &IsAlterarVendedorInterno, &PesExtVenCod, &PesIntVenCod, &Context.UserName, &Context.PesCod)
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'O sistema obteve êxito em alterar os clientes.' , DVMessageType.success, "", DVMessageBoolean.True, ""))
	EndCase

