EndEvent

Event &PesCep.IsValid

	FormataCEP.Call(&PesCep, &PesCep)

EndEvent

Event &PesCidCod.IsValid

	If Not &PesCidCod.IsEmpty()
		For each order EmpCod, CidCod
			where EmpCod = &EmpCod
			where CidCod  = &PesCidCod
			&PesCidNom =  CidNom
			&PesCidUfeCod = UfeCod
			exit
		when none
			&PesCidCod.SetEmpty()
			&PesCidNom.SetEmpty()
			&PesCidUfeCod.SetEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "Cidade Inválida." , DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PesCidCod.SetFocus()
		EndFor
	EndIf

EndEvent

Sub 'GetPessoa'

	&AuxPesIsVen	= false
	&AuxPesIsTra	= false
	&AuxPesVenIntExt.SetEmpty()
	&AuxPesCod.SetEmpty()	
	For Each Order EmpCod, PesCodRazSugg
		Where EmpCod	= &EmpCod
		Where PesCodRazSugg	= &AuxPesCodRazSugg
		
		&AuxPesIsTra = PesIsTra
		&AuxPesCod   = PesCod
		
		&AuxPesVenIntExt	= PesVenIntExt
		&AuxPesIsVen	= PesIsVen

		Exit
	EndFor

EndSub


