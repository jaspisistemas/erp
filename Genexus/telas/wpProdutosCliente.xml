      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesCod.Visible = False
	&EmpCod.Visible = False
	&FilCod.Visible = False
	Grid.Rows = 30
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PedCliCodRaz = PesCodRaz
		Exit
	when none
		return
	EndFor
	
	&PedDtaFat_to = serverdate()
	
	&PedDtaFat 		= &PedDtaFat_to - 60
	&oldPedDtaFat 	= &PedDtaFat

EndEvent

Event Refresh

	if &PedDtaFat_to.IsEmpty()
		&PedDtaFat_to = serverdate()
		&PedDtaFat = &PedDtaFat_to - 60
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount
	&GridCurrentPage = grid.CurrentPage

EndEvent

Event Grid.Load

	For Each Order EmpCod, FilCod, PedCliCod, PedSts, LctGerFin, ProCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCliCod = &PesCod 
		Where PedSts = Status_Pedido.FECHADO
		Where LctGerFin = Status_SimNao.Sim
		Where LctAtuSal = Status_EntradaSaida.Saida
		Where PedDtaFat >= &PedDtaFat and PedDtaFat <= &PedDtaFat_to
		
		&ProCod = ProCod
		&ProRef = ProGraRef
		&ProNom = ProNomGra
		&PedQtd = 0 
		&PedQtdCan = 0 
		&PedVlrItm = 0 
		For Each Order EmpCod, FilCod, PedCliCod, PedSts, LctGerFin, ProCod, PedDtaFat
			&PedQtd    += PedQtd
			&PedQtdCan += PedQtdCan
			&PedVlrItm += PedVlrItmComDsc
		EndFor
		
		&actioDisplay.FromImage(ActionDisplay)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&actioDisplay.FromImage(ActionDisplay)
	&actioDisplay.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load        
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraTelevendas'

	Do Case
		CAse &DeOndeVem = 'WWCLIENTETELEVENDAS'
			wwClienteTelevendas.Link()
		CAse &DeOndeVem = 'WWCLIENTEREPRESENTANTES'
			wwClienterepresentantes.Link()
		Case &DeOndevem = 'WWCLIENTE'
			wwCliente.Link()
	EnDCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	RCOOpenWindow1.LinkOpen = RELJAS033.Link(&EmpCod, &FilCod, &PesCod, &PedDtaFat, &PedDtaFat_to, 'N', '')
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFiltrar'

	grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedDtaFat_to.IsValid

	grid.Refresh()

EndEvent

Event &PedDtaFat.IsValid

	If &PedDtaFat <> &oldPedDtaFat
		&oldPedDtaFat = &PedDtaFat
		grid.Refresh()
	EndIF

EndEvent

Event &actioDisplay.Click

	wpProdutosCliente1.Popup(&EmpCod, &FilCod, &PesCod, &PedDtaFat, &PedDtaFat_to, &ProCod)

EndEvent


]]></Source>
