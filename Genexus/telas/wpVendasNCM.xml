      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPVENDASNCM', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	&PesCod = &wwpContext.PesCod
	&LctAtuSal = Status_EntradaSaida.Saida
	&PedSts = Status_Pedido.FECHADO
	&LctGerFin = Status_SimNao.Sim
	
	&fimPedDtaEms = serverdate()
	&iniPedDtaEms = &fimPedDtaEms.AddDays(-30)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&sdtTipolancamento.Sort('LctCod')
    For &sdtTipolancamentoItem in &sdtTipolancamento
        &gridLctCod = &sdtTipolancamentoItem.LctCod
		&GridLctNom = &sdtTipolancamentoItem.LctCodNom

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	 load
    EndFor

EndEvent

Event Enter

	&webSession.Set('SALVATIPOLANCAMENTO', &sdtTipolancamento.ToXml())
	RCOOpenWindow1.LinkOpen = RELJAS122.Link(&EmpCod, &FilCod, &LctAtuSal, &LctGerFin, &iniPedDtaEms, &fimPedDtaEms, &PedSts, &ORdem)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event &AuxLctCod.IsValid

	&erro = 0
    if &AuxLctCod = 0   
        &LctNom = 'TODOS OS TIPOS LANCAMENTOS'
    else        
        For Each Order EmpCod, LctCod  //SICLCT
			Where EmpCod = &EmpCod
	        Where LctCod = &AuxLctCod
            &LctNom = LctNom
        when none
            &LctNom = 'TIPO LANCAMENTO NAO ENCONTRADO'
            &AuxLctCod.Setfocus()
            &erro = 1
        EndFor
    EndIf
 
    If &erro = 0 and &AuxLctCod <> 0                
		&Achou = 'N'
		For &sdtTipolancamentoItem in &sdtTipolancamento
			IF &sdtTipolancamentoItem.LctCod = &AuxLctCod
				&index = &sdtTipolancamento.IndexOf(&sdtTipolancamentoItem)
				&sdtTipolancamento.Remove(&index)
				&Achou = 'S'
				exit				   
			EndIf
		EndFor
		If &Achou = 'N' 
			&sdtTipolancamentoItem = new()
			&sdtTipolancamentoItem.LctCod = &AuxLctCod
			&sdtTipolancamentoItem.LctCodNom = &LctNom
			&sdtTipolancamento.Add(&sdtTipolancamentoItem)
		EndIF           
		&AuxLctCod = 0
		grid.Refresh()
		&AuxLctCod.Setfocus()
	EndIF

EndEvent


]]></Source>
