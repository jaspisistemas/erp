EndEvent

Event 'DoUserConfirmacao'

	prcAtivarAnexo.Call(&EmpCod, &AnxCod, &IsTemAtivarProduto, &AnxEmpCst, &AnxEmpClassTrib)
	
	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



