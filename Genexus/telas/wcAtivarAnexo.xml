EndEvent

Event 'DoUserFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'verificaProdutoCOmAnexo'

	For Each Order AnxCod
		Where AnxCod = &AnxCod
		&AnxDesc = AnxDesc
		&AnxCst = AnxCst
		&AnxClassTrib = AnxClassTrib
		Exit
	EndFor
		
	&IsTemUm = false
	For Each Order NcmCod, AnxCod
		Where AnxCod = &AnxCod
		
		For Each ORder EmpCod, ProCod
			Where EmpCod = &EmpCod
			
			&IsTemUm = true
			Exit
		EndFor
	
		if &IsTemUm = true
			exit
		Endif
	EndFor
	tbProdutos.Visible = &IsTemUm

EndSub


