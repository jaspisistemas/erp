      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItens.Rows = Page.Rows
	&GridItensCurrentPage = 1
	&GridItensCurrentPage.Visible = False
	&GridItensPageCount = -1
	GridItensPaginationBar.RowsPerPageSelectedValue = GridItens.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridItensPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	VerItmCodFmt.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridItensCurrentPage	= GridItens.CurrentPage
	&GridItensPageCount		= GridItens.PageCount

EndEvent

Event GridItens.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	Do Case
		Case VerItmTip = TipoItemDaVersao.IMPLEMENTACAO
			VerItmCodFmt.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case VerItmTip = TipoItemDaVersao.BUG
			VerItmCodFmt.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfoLight WWColumnTagInfoLightSingleCell'
		Otherwise
			VerItmCodFmt.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	VerItmCodFmt.TooltipText	= IIf(VerItmTip = TipoItemDaVersao.IMPLEMENTACAO, 'Implementação', 'Correção de BUG')

EndEvent

Event GridItensPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridItensPaginationBar.SelectedPage = !'Previous'
			&GridItensCurrentPage -= 1
			GridItens.PreviousPage()
		Case GridItensPaginationBar.SelectedPage = !'Next'
			&GridItensCurrentPage += 1
			GridItens.NextPage()
		Otherwise
			&PageToGo.FromString(GridItensPaginationBar.SelectedPage)
			&GridItensCurrentPage = &PageToGo
			GridItens.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridItensPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItens.Rows = GridItensPaginationBar.RowsPerPageSelectedValue
	&GridItensCurrentPage = 1
	GridItens.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
