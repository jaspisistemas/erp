      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	retornaAutorizacao.Call('WWPAGAMENTOFOLHAS', Status_SimNao.Sim, 2, &AutNiv)
	&BaseData = &Today
	&BaseData = &BaseData.AddMonths(-1)
	&FolAno = Year(&BaseData)
	&FolMes = Month(&BaseData)
	
	padraoUsuarioHora.Call('L', '#WPFECHAMENTOFOLHA#', &Context.PesCod, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	
	if &PadObs.IsEmpty() 
		&IsBonificacao =iif(Substr(&PadObs,1,1)= '1',true,false)
		&IsOutrosAcrescimos =iif(Substr(&PadObs,2,1)= '1',true,false)
		&IsInsalubridade =iif(Substr(&PadObs,3,1)= '1',true,false)
		&IsPericulosidade =iif(Substr(&PadObs,4,1)= '1',true,false)
		&IsValeTransporte =iif(Substr(&PadObs,5,1)= '1',true,false)
		&IsValeAlimentacao =iif(Substr(&PadObs,6,1)= '1',true,false)
		&IsAdiantamentos =iif(Substr(&PadObs,7,1)= '1',true,false)
	Else
		&IsBonificacao =true
		&IsOutrosAcrescimos =true
		&IsInsalubridade =true
		&IsPericulosidade =true
		&IsValeTransporte =true
		&IsValeAlimentacao =true
		&IsAdiantamentos =true
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserReturn'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PadObs = ''
	&PadObs += iif(&IsBonificacao =true, '1', '0')
	&PadObs += iif(&IsOutrosAcrescimos =true, '1', '0')
	&PadObs += iif(&IsInsalubridade =true, '1', '0')
	&PadObs += iif(&IsPericulosidade =true, '1', '0')
	&PadObs += iif(&IsValeTransporte =true, '1', '0')
	&PadObs += iif(&IsValeAlimentacao =true, '1', '0')
	&PadObs += iif(&IsAdiantamentos =true, '1', '0')
	
	padraoUsuarioHora.Call('G', '#WPFECHAMENTOFOLHA#', &Context.PesCod, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	FechamentoFolha.Call(&EmpCod,&MovFunCod,0, &FolAno, &FolMes, &isAdiantamentos,&IsValeTransporte,&IsValeAlimentacao,&IsInsalubridade,&IsPericulosidade,&IsBonificacao,&IsOutrosAcrescimos)
	wwpActions.WCPopup_Close('')

EndEvent


]]></Source>
