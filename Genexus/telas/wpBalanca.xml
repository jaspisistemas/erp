      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWBALANCA', Status_SimNao.Sim, 2, &AutNiv)
	
	&BlcCod = &inBlcCod
	
	For Each Order EmpCod, BlcCod
		Where EmpCod = &EmpCod
		Where BlcCod = &BlcCod
		&BlcNom = BlcNom
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &BlcNom.IsEmpty()
		msg('Informe um nome para o grupo de produtos da balança!')
	Else
		prcGravaCapaBalanca.Call(&EmpCod, &BlcCod, &BlcNom, &BlcCod)
		wpBalancaitens.Link(&EmpCod, &BlcCod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
