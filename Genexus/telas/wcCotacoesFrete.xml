      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWCOTACAOFRETE', Status_SimNao.Nao, 3, &AutNiv)
	retornaAutorizacao.Call('COTACOESFRETE', Status_SimNao.Nao, 3, &doisAutNiv)
	if &AutNiv < &doisAutNiv
		&AutNiv = &doisAutNiv
	EndIF	
	
	RetornaAutorizacao.Call('SELECIONARCOTACAO', Status_SimNao.Nao, 1, &AutNivSel)
	txtmsg.Caption = 'Nova Cotação do Pedido: '+ trim(str(&PedCod))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&PedCod.Visible = False
	&EmpCod.Visible = False
	&FilCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&AlteraReferencia = !'<i class="fa fa-pen"></i>'
	If (&AutNiv > 1)
		&AlteraReferencia.Class = !'Attribute'
	Else
		&AlteraReferencia.Class = !'Invisible'
	Endif
	&DeleteReferencia = !'<i class="fa fa-times"></i>'
	If (&AutNiv > 2)
		&DeleteReferencia.Class = !'Attribute'
	Else
		&DeleteReferencia.Class = !'Invisible'
	Endif
	&Selecionar = !'<i class="fas fa-check"></i>'
	If (&AutNivSel > 0)
		&Selecionar.Class = !'Attribute'
	Else
		&Selecionar.Class = !'Invisible'
	Endif
	&Imprim = !'<i class="far fa-file-pdf"></i>'

	&DataHora = trim(DtoC(CotDta)) + ' ' + trim(CotHor)
	RetornaTotalLiquidoBruto.Call(EmpCod, CotFilCod, CotPedCod, &PedVlrBrt, &PedVlrLiq)

&Percentual = 0
if &PedVlrLiq > 0 and CotVlr > 0
	&Percentual = (CotVlr / &PedVlrLiq) * 100
	if &Percentual < 0
		&Percentual = 0
	EndIF
EndIF

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if CotIs = true
		&Selecionar = !'<i class="fa fa-times"></i>'
		If (&AutNivSel > 0)
			&Selecionar.Class = !'Attribute'
		Else
			&Selecionar.Class = !'Invisible'
		Endif
	EndIF
	
	&GridCurrentPage = Grid.CurrentPage
	&GridPageSize = Page.Rows
	&GridRecordCount = Grid.RecordCount

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAddDocumento'

	if &AutNiv > 1
		CotacaoFrete.Popup(TrnMode.Insert, &EmpCod, 0, &PedCod)
		Refresh
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Add.Visible = (&AutNiv > 1)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &DeleteReferencia.Click

	if &AutNiv > 2
		CotacaoFrete.Popup(TrnMode.Delete, EmpCod, CotCod, &PedCod)
		Refresh
	EndiF

EndEvent

Event &AlteraReferencia.Click

	if &AutNiv > 1
		CotacaoFrete.Popup(TrnMode.Update, EmpCod, CotCod, &PedCod)
		Refresh
	EndIF

EndEvent

Event &Selecionar.Click

	if &AutNivSel > 0 and CotIs <> true
		SelecionarCotacaoFrete.Call('ADD', EmpCod, CotCod, CotPedCod)
		wpAlteraTransPed.Popup(&EmpCod, &FilCod, &PedCod, CotCod)
		Refresh
	Else
		SelecionarCotacaoFrete.Call('DEL', EmpCod, CotCod, CotPedCod)
		Refresh
	EndIF

EndEvent

Event &Imprim.Click

	RCOOpenWindow1.LinkOpen = RELJAS142.Link(EmpCod, CotCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


]]></Source>
