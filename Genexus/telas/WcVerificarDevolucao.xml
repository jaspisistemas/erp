      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_GridCapaDevolucao_DWC.Class = !'Invisible WCD_' + upper(GridCapaDevolucao.InternalName)
	GridCapaDevolucao.Rows = Page.Rows
	&GridCapaDevolucaoCurrentPage = 1
	&GridCapaDevolucaoCurrentPage.Visible = False
	&GridCapaDevolucaoPageCount = -1
	GridCapaDevolucaoPaginationBar.RowsPerPageSelectedValue = GridCapaDevolucao.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridCapaDevolucaoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCapaDevolucaoCurrentPage	= GridCapaDevolucao.CurrentPage
	&GridCapaDevolucaoPageCount		= GridCapaDevolucao.PageCount

EndEvent

Event GridCapaDevolucao.Load

	&AuxPedCliCod = CrePedCliCod
	Do 'LoadCliente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'

	
	if CreNovCliRaz_Formula.Length() > 30
		&GridDevolucaoCliente 				= substr(CreNovCliRaz_Formula, 1, 30) + '...'
		&GridDevolucaoCliente.TooltipText 	= CreNovCliRaz_Formula
	Else
		&GridDevolucaoCliente 				= CreNovCliRaz_Formula 
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridCapaDevolucaoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridCapaDevolucaoPaginationBar.SelectedPage = !'Previous'
			&GridCapaDevolucaoCurrentPage -= 1
			GridCapaDevolucao.PreviousPage()
		Case GridCapaDevolucaoPaginationBar.SelectedPage = !'Next'
			&GridCapaDevolucaoCurrentPage += 1
			GridCapaDevolucao.NextPage()
		Otherwise
			&PageToGo.FromString(GridCapaDevolucaoPaginationBar.SelectedPage)
			&GridCapaDevolucaoCurrentPage = &PageToGo
			GridCapaDevolucao.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridCapaDevolucaoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCapaDevolucao.Rows = GridCapaDevolucaoPaginationBar.RowsPerPageSelectedValue
	&GridCapaDevolucaoCurrentPage = 1
	GridCapaDevolucao.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DetailWebComponent.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCapaDevolucao_DWC.Object = WcItensDevolucao.Create(EmpCod, FilCod, CrePedCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadCliente'

	For Each Order EmpCod, PesCod
		Where EmpCod 			= &parmEmpCOD
		Where PesCod 			= &AuxPedCliCod
		
		&GridDevolucaoCliente 	= PesCodRazSugg
		
		Exit
	EndFor

EndSub


]]></Source>
