EndEvent

Event 'DoUserFechar'

	wwpActions.WCPopup_Close('S')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Visible = (1=2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &MovDoc.IsValid

	&MovDoc = &MovDoc.ToUpper()

EndEvent

Event scaProgressBar1.OnComplete

	ApagaProgress.Submit('', &ProgressId)
	wwpActions.WCPopup_Close('S')

EndEvent

Event Enter

	&MovDoc = &MovDoc.ToUpper()

	If not &MovDtaCon.IsEmpty()
		if not &MovDoc.IsEmpty()
			AtualizaNumeroPagamentoFolha.Call(&EmpCod,&FPagCod,&MovDoc)
		Endif
	
		RCOOpenWindow1.LinkOpen = RELJAS072_PagamentoFolha2.link(&EmpCod,&FolFunFilCod,&FolAno,&FolMes,&FolFunCod,&MovDtaCon,&MovDoc,0,&TipoFolha, &DiariaFolha) //falta folnrodoc
	
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		
		&Random = Random() * 10000000000
		&ProgressId = 'WPPgtoFolha' + trim(Str(&Random))
		
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		EsperaSegundos.Submit('', &ProgressId)
	Else
		msg('ATENÇÃO! A data de laçamento é obrigatório')
	EndIf

EndEvent

Sub 'Carregafolha'

	For each Order EmpCod,FPagCod
		Where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		&FolAno = FPagAno
		&FolMes = FPagMes
		&FolFunCod =FPagPesCod
		&FolFunFilCod = FPagFunFilCod
		if FPagTip = TipoPagamentoFolha.PagamentoDiarias
			&DiariaFolha = 'D'
		Else
			&DiariaFolha = 'F'
		EndIf
	
		&FolFunNom = trim(str(FPagPesCod))+'-'+trim(FPagPesRaz)
		exit
	EndFor

EndSub


]]></Source>
