      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWTRANSFPRODUTO', Status_SimNao.Sim, 2, &AutNiv)
	Msg.Caption = ''
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrsItmCod.Visible = False
	WCwcItensTransfe.Object = wcItensTransfe.Create(&EmpCod, &TrsCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	for Each Order EmpCod, TrsCod
		Where EmpCod = &EmpCod
		Where TrsCod = &TrsCod
		Where TrsSts = Status_Pedido.ABERTO
		&TrsDtaEms = TrsDtaEms
		&TrsSts = TrsSts
		Exit
	When none
		wwTransfProduto.Link()
	EndFor

	if &parTrsItmCod <> 0
		do 'loadItem'
	EndIF

EndEvent

Event 'DoMonitora'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWTransfProduto.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCapaTransf'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CapaTransf_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event CapaTransf_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcNovaTransferencia.Create('UPD', &EmpCod, &TrsCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event CapaTransf_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	RCOOpenWindow1.LinkOpen = RELJAS054.Link(&EmpCod, &TrsCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharTransferencia'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	FecharTransferencia_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FecharTransferencia_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcFechaTransferencia.Create(&EmpCod, &TrsCod, '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FecharTransferencia_Modal.Close

	wwTransfProduto.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'GravarF3'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLimpar'

	&TrsItmCod = 0
	&TrsEntProCod = 0
	&TrsEntProNom = ''
	&TrsEntPedQtd = 0
	&TrsEntProRef.SetEmpty()
	
	&TrsSaiProCod = 0
	&TrsSaiProRef.SetEmpty()
	&TrsSaiProNom = ''
	&TrsSaiPedQtd = 0
	
	wpTransfProduto.Link(&EmpCod, &TrsCod, 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'TeclaF3'

	3
	do 'GravarF3'

EndEvent

Event &TrsEntProRef.IsValid

	do 'loadProdutoEntrada'

EndEvent

Event &TrsSaiProRef.IsValid

	Msg.Caption = ''
	do 'loadProdutoSaida'

EndEvent

Sub 'GravarF3'

	do 'loadProdutoSaida'
	if &TrsEntProRef.IsEmpty() and &TrsEntPedQtd.IsEmpty()
		&TrsEntProRef = &TrsSaiProRef
		&TrsEntPedQtd = &TrsSaiPedQtd
	Endif
	do 'loadProdutoEntrada'
	
	Do CAse
		Case &IsErroEntrada = true
			&TrsEntProCod.SetFocus()
			
		Case &IsErroSaida = true
			&TrsSaiProRef.SetFocus()
			
		Otherwise
			
			GravaTransfProduto.Call(&EmpCod, &TrsCod, &TrsItmCod, &TrsEntProCod, &TrsEntProGraCod, &TrsEntPedQtd, &TrsSaiProCod, &TrsSaiProGraCod, &TrsSaiPedQtd, &NewTrsItmCod)
			if &TrsItmCod <> 0
				Msg.Caption = 'Item:' + trim(str(&TrsItmCod)) + ' atualizado com sucesso!'
				Msg.ForeColor = RGB(0,180,40)
			Else
				Msg.Caption = 'Novo item inserido com sucesso!'
				Msg.ForeColor = RGB(0,40,180)
			EndIF
			
			&TrsItmCod = 0
			&TrsEntProCod = 0
			&TrsEntProNom = ''
			&TrsEntPedQtd = 0
			&TrsEntProRef.SetEmpty()
			
			
			&TrsSaiProCod = 0
			&TrsSaiProNom = ''
			&TrsSaiPedQtd = 0
			&TrsSaiProRef.SetEmpty()
			WCwcItensTransfe.Refresh()
			
			&TrsSaiProRef.SetFocus()
	EndCase

EndSub

Sub 'loadItem'

	&TrsSaiProCod = 0
	
	For Each Order EmpCod, TrsCod, TrsItmCod
		Where EmpCod = &EmpCod
		Where TrsCod = &TrsCod
		Where TrsItmCod = &parTrsItmCod
		&TrsItmCod = &parTrsItmCod
		
		&TrsentPedQtd = TrsEntPedQtd
		&TrsentProCod = TrsEntProCod
		&TrsentProGraCod = TrsEntProGraCod
		
		&TrsSaiPedQtd = TrsSaiPedQtd
		&TrsSaiProCod = TrsSaiProCod
		&TrsSaiProGraCod = TrsSaiProGraCod
		
		do 'loadProdutoEntradaCod'
		do 'loadProdutoSaidaCod'
		Exit
	EndFor

EndSub

Sub 'loadProdutoSaida'

	&IsErroSaida = true
	&TrsSaiProCod = 0
	&TrsSaiProGraCod = 0
	&TrsSaiProNom = 'INFORME PRODUTO ORIGEM'
	
	RetornaprodutoReferencia_basico.Call(&EmpCod, &TrsSaiProRef, &TrsSaiProCod, &TrsSaiProGraCod, &TrsSaiProNom, &IsAchouProduto, &erroMensagem)
	
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &TrsSaiProCod
		Where ProGraCod = &TrsSaiProGraCod
		
		&TrsSaiProNom = ProNomGra
		&TrsSaiProCod = ProCod
		&TrsSaiProGraCod = ProGraCod
		&IsErroSaida = false
		Exit
	when none
		if not &TrsSaiProRef.IsEmpty()
			&TrsSaiProNom = UPPER('Produto origem não Localizado')
			Msg.Caption = 'Produto origem não Localizado!'
			Msg.ForeColor = RGB(180,40,0)
		EndiF
	EndFor

EndSub

Sub 'loadProdutoEntrada'

	&TrsEntProGraCod = 0
	&TrsEntProCod = 0
	&IsErroEntrada = true
	&TrsEntProNom = 'INFORME PRODUTO DESTINO'
	
	RetornaprodutoReferencia_basico.Call(&EmpCod, &TrsEntProRef, &TrsEntProCod, &TrsEntProGraCod, &TrsEntProNom, &IsAchouProduto, &erroMensagem)
	
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &TrsEntProCod
		Where ProGraCod = &TrsEntProGraCod
		
		&TrsEntProNom = ProNomGra
		&IsErroEntrada = false
		&TrsEntProCod = ProCod
		&TrsEntProGraCod = ProGraCod
		Exit
	when none
		if not &TrsEntProRef.IsEmpty()
			&TrsEntProNom = UPPER('Produto Destino não Localizado')
			Msg.Caption = 'Produto Destino não Localizado!'
			Msg.ForeColor = RGB(180,40,0)
		EndiF
	EndFor

EndSub

Sub 'loadProdutoSaidaCod'

	&IsErroSaida = true
	&TrsSaiProNom = 'INFORME PRODUTO ORIGEM'
		
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &TrsSaiProCod
		Where ProGraCod = &TrsSaiProGraCod
		
		&TrsSaiProNom = ProNomGra
		&TrsSaiProRef = ProGraRef
		&IsErroSaida = false
		Exit
	when none
		if &TrsSaiProCod <> 0
			&TrsSaiProNom = UPPER('Produto origem não Localizado')
			Msg.Caption = 'Produto origem não Localizado!'
			Msg.ForeColor = RGB(180,40,0)
		EndiF
	EndFor

EndSub

Sub 'loadProdutoEntradaCod'

	&IsErroEntrada = true
	&TrsEntProNom = 'INFORME PRODUTO DESTINO'
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &TrsEntProCod
		Where ProGraCod = &TrsEntProGraCod
		&TrsEntProNom = ProNomGra
		&TrsEntProRef = ProGraRef
		&IsErroEntrada = false
		
		Exit
	when none
		if &TrsEntProCod <> 0
			&TrsEntProNom = UPPER('Produto Destino não Localizado')
			Msg.Caption = 'Produto Destino não Localizado!'
			Msg.ForeColor = RGB(180,40,0)
		EndiF
	EndFor

EndSub


