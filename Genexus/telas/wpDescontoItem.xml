      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtTipoDesconto.ForeColor = RGB(200,150,0)
	RetornaAutorizacao.Call('VENDADESCONTOUNITARIO', Status_SimNao.Sim, 1, &AutNiv)
	do 'loadPedido'
	
	&TabColCod = &ParmTabColCod
	&DescontoTaxa = &RetPedItmDsc
	
	do 'DescontoTaxa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable2.Width = 450
	UnnamedTable1.Width = 500
	UnnamedTable9.Width = 450
	&PedDtaEms.Visible = False
	&TabPrmCod.Visible = False
	&EmpCod.Visible = False
	&PedQtd.Visible = False
	&auxTabPrc1.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadTabelaPromocao'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'ColunaSelecionada'
	do 'DescontoTaxa'
	do 'DescontoEmValor'
	
	&RetPedItmDsc = &NovDescontoTaxa
	
    return

EndEvent

Event &PedVlrUnt.IsValid

	If not &PedVlrUnt.IsEmpty()
		&DescontoTaxa = 0
	EndiF
	&NovDescontoTaxa = &DescontoTaxa
	
	do 'DescontoEmValor'

EndEvent

Event &DescontoTaxa.IsValid

	if not &DescontoTaxa.IsEmpty()
		&PedVlrUnt = 0
	EndIf

	&NovDescontoTaxa = &DescontoTaxa

	do 'DescontoTaxa'
	&PedVlrUnt.SetFocus()

EndEvent

Event &TabColCod.IsValid

	do 'ColunaSelecionada'
	&NovPedVlrUnt = &AuxTabPrc1
	&PedVlrUnt = &AuxTabPrc1

EndEvent

Sub 'DescontoEmValor'

	If not &UnitarioPedido.IsEmpty() and not &PedVlrUnt.IsEmpty()
		&NovDescontoTaxa = 100 - ((&PedVlrUnt / &UnitarioPedido) * 100)
	EndIF

EndSub

Sub 'DescontoTaxa'

	if &DescontoTaxa <> 0
		&novPedVlrUnt = &AuxTabPrc1 - ((&AuxTabPrc1 * &DescontoTaxa) / 100)
	EndIF

EndSub

Sub 'ColunaSelecionada'

	Do CAse
		CAse &TabColCod = 1               
			&AuxTabPrc1 = &TabPrc1 
		CAse &TabColCod = 2 
			&AuxTabPrc1 = &TabPrc2 
		Case &TabColCod = 3 
			&AuxTabPrc1 = &TabPrc3 
		Case &TabColCod = 4
			&AuxTabPrc1 = &TabPrc4 
		Otherwise
			&AuxTabPrc1 = &TabPrc5
	EndCAse

EndSub

Sub 'LoadTabelaPromocao'

	&IsPromocao = False
	
	For Each Order EmpCod, TabCod, TabColCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabPrmCod
		Where TabSts = StatusTabela.Promocao
		Where TabColCod <= 5
		Where (TabDtaIni <= &PedDtaEms or TabDtaIni.IsEmpty()) and (TabDtaFin >= &PedDtaEms or TabDtaFin.IsEmpty())
		
		For Each Order EmpCod, TabCod, ProCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			Where (TabProDtaIni <= &PedDtaEms or TabProDtaIni.IsEmpty()) and (TabProDtaFin >= &PedDtaEms or TabProDtaFin.IsEmpty())
			
			&ProCodNom = ProRefNom
			
			&IsPromocao = True
			
			&TabPrc1 = TabPrc1
			&TabPrc2 = TabPrc2
			&TabPrc3 = TabPrc3
			&TabPrc4 = TabPrc4
			&TabPrc5 = TabPrc5
			
			Do CAse
				CAse &ParmTabColCod = 1            
					&UnitarioPedido = TabPrc1
				CAse &ParmTabColCod = 2 
					&UnitarioPedido = TabPrc2
				Case &ParmTabColCod = 3 
					&UnitarioPedido = TabPrc3
				Case &ParmTabColCod = 4
					&UnitarioPedido = TabPrc4
				Otherwise
					&UnitarioPedido = TabPrc5
			EndCAse
		EndFor
	EndFor

   	If &IsPromocao = false
		Do 'LoadTabelaNormal'
	EndIF

EndSub

Sub 'LoadTabelaNormal'

	For Each Order EmpCod, TabCod, TabColCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		Where TabSts = StatusTabela.NormalAtiva
		Where TabColCod <= 5
		Where (TabDtaIni <= &PedDtaEms or TabDtaIni.IsEmpty()) and (TabDtaFin >= &PedDtaEms or TabDtaFin.IsEmpty())
		
		For Each Order EmpCod, TabCod, ProCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			Where (TabProDtaIni <= &PedDtaEms or TabProDtaIni.IsEmpty()) and (TabProDtaFin >= &PedDtaEms or TabProDtaFin.IsEmpty())
			
			&ProCodNom = ProRefNom
			
			&IsPromocao = True
			
			&TabPrc1 = TabPrc1
			&TabPrc2 = TabPrc2
			&TabPrc3 = TabPrc3
			&TabPrc4 = TabPrc4
			&TabPrc5 = TabPrc5
			
			Do CAse
				CAse &ParmTabColCod = 1            
					&UnitarioPedido = TabPrc1
				CAse &ParmTabColCod = 2 
					&UnitarioPedido = TabPrc2
				Case &ParmTabColCod = 3 
					&UnitarioPedido = TabPrc3
				Case &ParmTabColCod = 4
					&UnitarioPedido = TabPrc4
				Otherwise
					&UnitarioPedido = TabPrc5
			EndCAse
		EndFor
	When none
		Return
	EndFor

EndSub

Sub 'LoadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedDtaEms = PedDtaEms
		Exit
	When none
		Return
	EndFor

EndSub


]]></Source>
