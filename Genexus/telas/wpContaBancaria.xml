      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&PesConCod = &parPesConCod
	
	&sdtContasBancarias.FromJson(&WebSession.Get(&PESSOACONTAS))
	For &sdtContasBancariasItem in &sdtContasBancarias
		
		If &sdtContasBancariasItem.PesConCod = &PesConCod	
			&PesConBanCod = &sdtContasBancariasItem.PesConBanCod
			&PesConAge = &sdtContasBancariasItem.PesConAge
			&PesConTpo = &sdtContasBancariasItem.PesConTpo
			&PesCon = &sdtContasBancariasItem.PesCon
			&PesConFav = &sdtContasBancariasItem.PesConFav
			&PesConIsSel = &sdtContasBancariasItem.PesConIsSel
			&PesConPIX = &sdtContasBancariasItem.PesConPIX
		Endif
		
		&UltPesConCod = &sdtContasBancariasItem.PesConCod
	EndFor
	&WebSession.Remove(&PESSOACONTAS)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesConCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do case
		Case &PesCon.IsEmpty() and &PesConPix.IsEmpty()
			msg('Conta obrigatória ou informe o PIX!')
			&PesCon.SetFocus()
		Case &PesConBanCod.IsEmpty() and &PesConPix.IsEmpty()
			msg('Banco Obrigatório ou informe o PIX!')
			&PesConBanCod.SetFocus()
		Case &PesConFav.IsEmpty()
			msg('Nome do Favorecido Obrigatório!')
			&PesConFav.SetFocus()
		Otherwise
			
			if &PesConCod > 0
				For &sdtContasBancariasItem in &sdtContasBancarias
					If &sdtContasBancariasItem.PesConCod = &PesConCod	
						&sdtContasBancariasItem.PesConCod = &PesConCod	
						&sdtContasBancariasItem.PesConBanCod = 	&PesConBanCod
						&sdtContasBancariasItem.PesConAge = &PesConAge 
						&sdtContasBancariasItem.PesConTpo = &PesConTpo 
						&sdtContasBancariasItem.PesCon = &PesCon
						&sdtContasBancariasItem.PesConFav = &PesConFav 
						&sdtContasBancariasItem.PesConIsSel = &PesConIsSel 
						&sdtContasBancariasItem.PesConSts = Status_SimNao.Sim
						&sdtContasBancariasItem.PesConPIX = &PesConPIX
						Exit
					Endif
				EndFor
			Else
				&PesConCod = &UltPesConCod+1
				&sdtContasBancariasItem = new()
				&sdtContasBancariasItem.PesConCod = &PesConCod	
				&sdtContasBancariasItem.PesConBanCod = 	&PesConBanCod
				&sdtContasBancariasItem.PesConAge = &PesConAge 
				&sdtContasBancariasItem.PesConTpo = &PesConTpo 
				&sdtContasBancariasItem.PesCon = &PesCon
				&sdtContasBancariasItem.PesConFav = &PesConFav 
				&sdtContasBancariasItem.PesConIsSel = &PesConIsSel 
				&sdtContasBancariasItem.PesConSts = Status_SimNao.Sim
				&sdtContasBancariasItem.PesConPIX = &PesConPIX
				&sdtContasBancarias.Add(&sdtContasBancariasItem)
			Endif
			
			if &PesConIsSel = true
				For &sdtContasBancariasItem in &sdtContasBancarias
					If &sdtContasBancariasItem.PesConCod <> &PesConCod	
						&sdtContasBancariasItem.PesConIsSel = false
					Endif
				EndFor
			Endif
			
			&WebSession.Set(&PESSOACONTAS, &sdtContasBancarias.ToJson())
			return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
