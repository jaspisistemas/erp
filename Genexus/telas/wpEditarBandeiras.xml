      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&filtroBanCarCod = &BanCarCod
	do 'getNomeBandeira'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Group.GridInternalName = Grid.InternalName
	
	Grid.Rows = 0
	Grid_Empowerer.GridInternalName = Grid.InternalName
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' Adquirencias'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	BanItemCredDeb.ColumnHeaderClass = !'WWColumn'
	
	&Grid_GroupCaption.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Grid_GroupCaption = BanItemNom
	&Grid_GroupCaption = format('%1: %2', "Nome Bandeira", iif(BanItemNom.IsEmpty(), 'WWP_FilterEmpty', &Grid_GroupCaption))
	
	&UserUpdate = !'<i class="fas fa-pen"></i>'
	
	&UserRemove = !'<i class="fas fa-times"></i>'
	
	Do Case
		Case BanItemCredDeb.ToString().Trim() = !"C"
			BanItemCredDeb.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case BanItemCredDeb.ToString().Trim() = !"D"
			BanItemCredDeb.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Otherwise
			BanItemCredDeb.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	WWBandeiraCartoes.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &BanItemCredDeb = 'D' //DEBITO
		&BanItemPar = 1
	Endif

	Do Case
		Case &BanItemNom.IsEmpty()
			msg('Nome Bandeira não informada!')
			&BanItemNom.SetFocus()
			
		Case &BanItemTax.IsEmpty()
			msg('Taxa não informada!')
			&BanItemTax.SetFocus()
			
		Otherwise
			GravaBandeira.Call(&EmPCod, &BanCarCod, &BanItemNom, &BanItemCredDeb, &BanItemPar, &BanItemTax)
			&BanItemNom.Enabled = 1
			&BanItemCredDeb.Enabled = 1
			&BanItemPar.Enabled = 1
	
			grid.Refresh()
			&BanItemNom.SetFocus()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	&BanItemNom.Enabled = 1
	&BanItemCredDeb.Enabled = 1
	&BanItemPar.Enabled = 1
	&BanItemPar = 0
	&BanItemNom = ''
	&BanItemCredDeb = 'C'
	&BanItemPar = 0
	
	&BanItemNom.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"FILTROBANCARCOD"
				&filtroBanCarCod.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndSub

Sub 'SaveGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"FILTROBANCARCOD", "", not &filtroBanCarCod.IsEmpty(), 0, &filtroBanCarCod.ToString().Trim(), '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"BandeiraCartoes"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &UserUpdate.Click

	&BanItemNom = BanItemNom
	&BanItemCredDeb = BanItemCredDeb
	&BanItemPar = BanItemPar
	&BanItemTax = BanItemTax
	
	&BanItemNom.Enabled = 0
	&BanItemCredDeb.Enabled = 0
	&BanItemPar.Enabled = 0
	&BanItemTax.SetFocus()

EndEvent

Event &UserRemove.Click

	prcDeleteBandeira.Call(&EmPCod, &BanCarCod, BanItemNom, BanItemCredDeb, BanItemPar)
	grid.Refresh()

EndEvent

Sub 'getNomeBandeira'

	For Each Order EmpCod, BanCarCod
		Where EmpCod = &EmPCod
		Where BanCarCod = &BanCarCod
		&BanCarNom = BanCarNom
		Exit
	EndFor

EndSub


]]></Source>
