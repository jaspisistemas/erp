      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
//	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon127_MotivoPadraoInserirCheque, &TCon127_MotivoPadraoInserirCheque )
	
	//RETORNA FORMAS PAGAMENTOS
	RetornaFormasPagamento.Call(&Context.EmpCod, 'R', 'S', &Context.PesCod, &Context.TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	&PedTmpFrpPgtoCod.Clear()
	For &sdtFormasPagamentoItem in &sdtFormasPagamento	
		if &sdtFormasPagamentoItem.FrpPgtoTip = TipoDuplicata.CHEQUEP or  &sdtFormasPagamentoItem.FrpPgtoTip = TipoDuplicata.CHEQUEP
			&DescricaoVarchar = &sdtFormasPagamentoItem.FrpPgtoCodExib + ' - ' + &sdtFormasPagamentoItem.FrpPgtoNom
			&PedTmpFrpPgtoCod.AddItem(&sdtFormasPagamentoItem.FrpPgtoCod, &DescricaoVarchar)
		Endif
	EndFor
	//RETORNA FORMAS PAGAMENTOS
	
	do 'LoadLancamento'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CheTel.IsValid

	FormataFoNE.Call(&CheTel, &CheTel)

EndEvent

Event Enter

	&AlertaMensagem.SetEmpty()
	&ErroMensagem.SetEmpty()
	&SucessoMensagem.SetEmpty()
	
	if &OqueFazer = 'ADD'
		
		ValidaChequesTerceiros.call(&EmpCod, 0, &CheBanCod, &CheAgeCod, &CheCon, &CheNro, &ErroChequeMensagem, &AlertaMensagem)
	
		do 'ValidaCPF'
		FormataFoNE.Call(&CheTel, &CheTel)
		
		Do Case
			Case not &ErroChequeMensagem.IsEmpty()
				&ErroMensagem = &ErroChequeMensagem
				&SucessoMensagem.SetEmpty()
				
			Case &CheBanCod.IsEmpty()
				&Mensagem = 'Banco do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheBanCod.SetFocus()
			Case &CheAgeCod.IsEmpty()
				&Mensagem = 'Agência do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheAgeCod.SetFocus()
				
			Case &CheCon.IsEmpty()
				&Mensagem = 'Conta do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheCon.SetFocus()
				
			Case &CheNro.IsEmpty()
				&Mensagem = 'Número do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheNro.SetFocus()
				
			Case &CheVlr <= 0
				&Mensagem = 'Valor do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheVlr.SetFocus()
				
			Case &CheDtaEmi.IsEmpty()
				&Mensagem = 'Emissão do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheDtaEmi.SetFocus()
				
			Case &CheDtaVct.IsEmpty()
				&Mensagem = 'Vencimento do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheDtaVct.SetFocus()
				
			Case &CheTitNom.IsEmpty()
				&Mensagem = 'Titular do Cheque é obrigatório!'
				&TipoMensagem = 'ERRO'
				do 'Mensagem'
				&CheTitNom.SetFocus()
				
			Case &CpfErro = 1
				&CheTitCpf.SetFocus()
				
			Otherwise
				prcGravaChequeTabelaTemporariaPedido.Call('ADD', &EmpCod, &FilCod, &PedCod, &PedTmpDupCod, &CheBanCod, &CheAgeCod, &CheCon, &CheNro, &CheVlr, &CheDtaEmi, &CheDtaVct, &CheTitNom, &CheTitCpf, &CheTitRg, &CheTel, &CheObs, &ChePlanCod, &CheCtaBanCod, MotivoCheque.EMITIDO, &PedTmpFrpPgtoCod)
				if not &PedTmpDupCod.IsEmpty()
					Return
				Else
					
					
					&Mensagem = 'Cheque Nº: ' +trim(str(&CheNro))+ ' Valor:' +trim(toformattedString(&CheVlr))+ ' Adicionado com sucesso!'
					&TipoMensagem = 'OK'
					do 'Mensagem'
					
					&CheVlr.SetEmpty()
					&CheNro.SetEmpty()
					&CheBanCod.SetFocus()
				Endif	
		Endcase
	Else
		prcGravaChequeTabelaTemporariaPedido.Call('DEL', &EmpCod, &FilCod, &PedCod, &PedTmpDupCod, &CheBanCod, &CheAgeCod, &CheCon, &CheNro, &CheVlr, &CheDtaEmi, &CheDtaVct, &CheTitNom, &CheTitCpf, &CheTitRg, &CheTel, &CheObs, &ChePlanCod, 0, MotivoCheque.EMITIDO, &PedTmpFrpPgtoCod)
		Return
	EndIF

EndEvent

Event &CheAgeCod.IsValid

	do 'Conta'

EndEvent

Event &CheBanCod.IsValid

	do 'Conta'

EndEvent

Event &CheCon.IsValid

	do 'Conta'

EndEvent

Event &CheNro.IsValid

	do 'conta'

EndEvent

Event &CheTitCpf.IsValid

	do 'ValidaCPF'

EndEvent

Sub 'Conta'

	&SucessoMensagem.SetEmpty()
	&AlertaMensagem.SetEmpty()
	&ErroChequeMensagem.SetEmpty()
	
	if not &CheBanCod.IsEmpty() and not &CheAgeCod.IsEmpty() and Not &CheCon.IsEmpty() and not &CheNro.IsEmpty()
		ValidaChequesTerceiros.call(&EmpCod, 0, &CheBanCod, &CheAgeCod, &CheCon, &CheNro, &ErroMensagem, &AlertaMensagem)
	EndIf

EndSub

Sub 'Mensagem'

	Do CAse
		Case &TipoMensagem = 'OK'
			&SucessoMensagem = &Mensagem
			&ErroMensagem.SetEmpty()
		otherwise
			&ErroMensagem =  &Mensagem
			&SucessoMensagem.SetEmpty()
	EndCase

	//[ControlName].Msg(ToastrType, "Message", "Title")
	//Toastr1.Msg(ToastrType.Success, "My success message", "Title")
	//Toastr1.Msg(ToastrType.Info, "My info message", "Title")
	//Toastr1.Msg(ToastrType.Warning, "My warning message", "Title")

EndSub

Sub 'ValidaCPF'

	ValidaCpfCnpj.Call(&CheTitCpf, &CpfErro, 'N')
	if &CpfErro = 1
		&Mensagem = 'CPF/CNPJ Inválido!'
		&TipoMensagem = 'ERRO'
		do 'Mensagem'
	EndIF

EndSub

Sub 'LoadLancamento'

	//CONTA
	&CheCtaBanCod.Clear()
	&SdtContaBancaria = dpContaBancariaNomeFilial_EmpCod.Udp(&Context.EmpCod, &Context.PesCod, &Context.FilCod)
	For &SdtContaBancariaItem in &SdtContaBancaria
		if &SdtContaBancariaItem.CtaFunIsRec <> Status_SimNao.Nao
			&CheCtaBanCod.AddItem(&SdtContaBancariaItem.CtabanCod, &SdtContaBancariaItem.CtaBanCodNom)
		Endif
	EndFor
	
	For Each order EmpCod, FilCod, PedCod, PedTmpDupCod
		Where EmpCod = &EmpCod 
		Where FilCod = &FilCod 
		Where PedCod = &PedCod
		Where PedTmpDupCod = &PedTmpDupCod
		
		&PedTmpFrpPgtoCod = PedTmpFrpPgtoCod
		&CheBanCod = PedTmpBanCod
		&CheAgeCod = PedTmpAgeCod
		&CheCon = PedTmpConCod
		&CheNro = val(PedTmpDupNro)
		&CheVlr = PedTmpDupVlr
		&CheDtaEmi = PedTmpDtaEms
		&CheDtaVct = PedTmpDupVct
		&CheTitNom = PedTmpTitNom
		&CheTitCpf = PedTmpTitCpf
		&CheTitRg = PedTmpTitRg
		&CheTel = PedTmpTitFon
		&CheObs = PedTmpObs
		&ChePlanCod = PedTmpPlanCod
		&CheCtaBanCod = PedTmpCtaBanCod
			
		Exit
	When None	
		&CheDtaEmi = serverdate()
		&CheDtaVct = serverdate()
	EndFor

	if &OqueFazer = 'DEL'
		&CheBanCod.Enabled = 0
		&CheAgeCod.Enabled = 0
		&CheCon.Enabled = 0
		&CheNro.Enabled = 0
		&CheVlr.Enabled = 0
		&CheDtaEmi.Enabled = 0
		&CheDtaVct.Enabled = 0
		&CheTitNom.Enabled = 0
		&CheTitCpf.Enabled = 0
		&CheTitRg.Enabled = 0
		&CheTel.Enabled = 0
		&CheObs.Enabled = 0
		&ChePlanCod.Enabled = 0
	EndIF

EndSub


]]></Source>
