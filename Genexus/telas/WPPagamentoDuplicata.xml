      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	Do 'Duplicata'
	&MovCod.SetFocus()
	&erro = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 493
	&CrePagVlrDsc.TooltipText = "Caso seja informado descontos o valor do movimento será gravado como descontos"
	&CrePagVlrJur.TooltipText = "Caso seja informado juros o valor do movimento será gravado como juros"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &MovItmCod.IsValid

	Do 'Movimento'

EndEvent

Event &CrePagVlr.IsValid

	&TotCrePagVlr = ((&CrePagVlr - &CrePagVlrJur) + &CrePagVlrDsc)

EndEvent

Event Enter

	DO Case
		Case ((&CreRecPag = ReceberPagar.Receber) and (&MovCreDeb = 'D'))
			msg('Atenção! tipo da duplicata é RECEBER utilize um movimento de CRÉDITO para vincular e poder prossegui.')
		Case ((&CreRecPag = ReceberPagar.Pagar) and (&MovCreDeb = 'C'))
			msg('Atenção! tipo da duplicata é PAGAR utilize um movimento de DÉBITO para vincular e poder prossegui.')
		Case &CrePagVlr > &CrePagDis
			Msg('Atenção o Pagamento não pode ser maior que saldo disponível á vincular!')
		Case &TotCrePagVlr > &CreVlrSdo
			msg('ATENÇÃO! Valor pago '+&TotCrePagVlr.ToFormattedString()+' maior que o valor do saldo '+&CreVlrSdo.ToFormattedString()+' , informe juros e descontos corretamente.')
		OtherWise
			If &IsEncontrado = true
				GravaPagamentoAntecipado.Call(&EmpCod,&MovCod,&MovItmCod,&CreCod,&FilCod,&CrePagVlr,&CrePagVlrJur,&CrePagVlrDsc)
				return
			EndIf
	EndCase

EndEvent

Sub 'Movimento'

&IsEncontrado = False
&MovCtaBanCod = 0
	For Each Order EmpCod, MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		Where MovItmCod = &MovItmCod
		Where MovItmSts <> Status_Caixa.Cancelado or MovItmSts.IsEmpty() or MovItmSts.IsNull()
		Where MovSts <> Status_Caixa.Cancelado or MovSts.IsEmpty() or MovSts.IsNull()
		&MovCreDeb = MovCreDeb
		&MovDta = MovDta
		&MovDtaCon = MovDtaCon
		&MovCtaBanCod = MovCtaBanCod
		&MovCtaBanNom = MovCtaBanNom
		&MovVlr = MovItmVlr
		&IsEncontrado = true
		Exit
	When none 
		&CtaBanCodNom  = 'MOVIMENTO NÃO ENCONTRADO'
		&MovCtaBanCod = 0
	EndFor

	For each Order EmpCod,FilCod,CreCod, CreMovCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		Where CreMovCod = &MovCod
		&indCrePagVlr += CrePagVlr
	EndFor
	&CrePagDis = &MovVlr - &indCrePagVlr
	&CrePagVlr = &CrePagDis

EndSub

Sub 'Duplicata'

	For each Order EmpCod,FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		&CreDupNro = CreDupNro
		&CreDtaEms = CreDtaEms
		&CreDtaVct = CreDtaVct
		&CreRecPag = CreRecPag
		&CreVlrDup = CreVlrDup
		&CreVlrSdo = CreVlrSdo
		&CreCliCodRaz = CreCliCodRaz
		Exit
	EndFor

EndSub


]]></Source>
