        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPRECALCULAESTOQUE', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	
	&FilCodNom = trim(str(&Context.FilCod)) + ' - ' + trim(&Context.FilRaz)
	&FilCodNom2 = &FilCodNom
	&EmpCod = &Context.EmpCod
	&SomenteProducao = Status_SimNao.Nao

	

	//do 'loadInicio'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DorecaPedido'

	msg('Aguarde...')
	btnrecaPedido.Visible = 0
	&ProgressId = 'wpRecPedido' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	prcRecalculaPedido.Submit('PrcRecalculaPedido', &ProgressId, &Context.EmpCod, &Context.FilCod, &PedCod, &sdtEstoque)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DorecaLote'

	msg('Aguarde...')
	btnrecaLote.Visible = 0
	&ProgressId = 'wpRecEstoque' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	PrcRecalculaEstoqueLote.Submit('PrcRecalculaEstoqueLote', &ProgressId, &Context.EmpCod, &Context.FilCod, &ini2ProRef, &Fin2ProRef, &SetCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DorecaEsto'

	msg('Aguarde...')
	btnrecaEsto.Visible = 0
	&ProgressId = 'wpRecEstoque' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	PrcRecalculaEstoque.Submit('PrcRecalculaEstoque', &ProgressId, &Context.EmpCod, &Context.FilCod, &iniProRef, &FinProRef, &SetCod, &GrupHie, &SomenteProducao, &SomenteNotas)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		&sdtEstoque.FromXml(ProgressLogXml)
		Exit
	EndFor
		
	btnrecaEsto.Visible = 1
	btnrecaLote.Visible = 1
	btnrecaPedido.Visible = 1
	If &sdtEstoque.Count > 0
		msg(scaProgressBar1.ProcessId + ' Recálculo Completo!')
		RCOOpenWindow1.LinkOpen = RELJAS008.Link(&Context.EmpCod, &Context.FilCod, &ProgressId)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		msg(scaProgressBar1.ProcessId + ' Estoques estão Corretos. Nada precisou ser atualizado!')
	EndIF

EndEvent

Event &iniProRef.IsValid

	&IniProNom = 'INICIAR NO CODIGO INFORMADO!'
	if not &iniProRef.IsEmpty()
		For Each Order EmpCod, ProRef
			WHere EmpCod = &EmpCod
			Where ProRef = &iniProRef
			&IniProNom = ProNom
			Exit
		EndFor
	Endif

EndEvent

Event &FinProRef.IsValid

	&FimProNom = 'ATE O CODIGO INFORMADO!'
	if not &FinProRef.IsEmpty()
		For Each Order EmpCod, ProRef
			WHere EmpCod = &EmpCod
			Where ProRef = &FinProRef
			&FimProNom = ProNom
			Exit
		EndFor
	Endif

EndEvent

Event &ini2ProRef.IsValid

	&Ini2ProNom = 'INICIAR NO CODIGO INFORMADO!'
	if not &ini2ProRef.IsEmpty()
		For Each Order EmpCod, ProRef
			WHere EmpCod = &EmpCod
			Where ProRef = &ini2ProRef
			&Ini2ProNom = ProNom
			Exit
		EndFor
	Endif

EndEvent

Event &Fin2ProRef.IsValid

	&Fim2ProNom = 'ATE O CODIGO INFORMADO!'
	if not &Fin2ProRef.IsEmpty()
		For Each Order EmpCod, ProRef
			WHere EmpCod = &EmpCod
			Where ProRef = &Fin2ProRef
			&Fim2ProNom = ProNom
			Exit
		EndFor
	Endif

EndEvent


