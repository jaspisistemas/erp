        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&Guid = guid.NewGuid()
	&ProgressId = &Guid.ToString()
	
	tbProgresso.Visible = 0
	&IsEnviarLinkWhats = false
	&IsEnviarLinkEmail = false
				
	&IsServidorADM = true	
	do 'loadCotacao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSalvarTodosFornecedores'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_BtnSalvarTodosFornecedores.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_BtnSalvarTodosFornecedores.Close

	if DVelop_ConfirmPanel_BtnSalvarTodosFornecedores.Result = 'Yes'
		prcGravaFornecedorProdutos.Call(&EmPCod, &CotComCod)
		do 'loadCotacao'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Ask If DVelop_ConfirmPanel_BtnSalvarTodosFornecedores.Result = !'Yes'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	tbProgresso.Visible = 1
	tbenter.Visible = 0
	
	scaPrograssBar1.ProcessId = &ProgressId
	scaPrograssBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaPrograssBar1.Start()
	
	prcTransmiteDadosServidorAdm.Submit(&ProgressID, &ProgressID, &EmPCod, &CotComCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable5.Visible = (1=2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaPrograssBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		
		&SdtWbsRetorno.FromJson(ProgressLogXml)
		
		if &SdtWbsRetorno.sts = 'J200'
			
			//grava envio dos email
			For Each ORder EmpCod, CotComCod, CotComForCod
				Where EmpCod = &EmPCod
				Where CotComCod = &CotComCod
				Where not CotComForEmail.IsEmpty() and not CotComForEmail.IsNull()
				
				&EmlAss = 'COTAÇÃO DE PREÇOS: ' + padl(trim(str(CotComCod)),3,'0') + '.' + padl(trim(str(CotComVer)),3,'0')
				
				&SdtEmail.Clear()
				&ItemSdtEmail = new()
				&ItemSdtEmail.EmlUrl = CotComForEmail
				&SdtEmail.Add(&ItemSdtEmail)
				GravaEnvioEmail.Call(EmpCod, CotComFilCod, CotComCod, CotComForCod, TipoContaEmail.Email_Comercial, &EmlAss, TipoSolicitacao.CotacaoCompras, &wwpContext.PesCod, &Mensagem, &SdtEmail, &sdtBoleto)
				
			EndFor
		
			wwpActions.WCPopup_Close('')
		Else
			tbEnter.Visible = 0
			tbProgresso.Visible = 0
			tbAvisoerro.Visible = 1
			btnSalvarTodosFornecedores.Visible = 0
			txtAvisoErro.Caption = &SdtWbsRetorno.obs
			txtAvisoErro.ForeColor = rgb(255,0,0)
		EndIf
		
		Exit
		
	EndFor

EndEvent

Sub 'loadCotacao'

	&QtdFone = 0
	&QtdEmail = 0
	&QtdProdutos = 0
	tbAvisoerro.Visible  = 0
	tbEnter.Visible = 1
	
	For Each Order EmpCod, CotComCod
		Where EmpCod = &EmPCod
		Where CotComCod = &CotComCod
		
		if CotComSts <> StatusCotacao.Pendente and CotComSts <> StatusCotacao.Bloqueada
			wwpactions.WCPopup_Close('')
		Endif
		
		if CotComDtaLim <= serverdate()
			tbAvisoerro.Visible = 1
			txtAvisoErro.Caption = 'Cotação com data limite inferior ou igual a hoje, ajuste a data limite'
			txtAvisoErro.ForeColor = rgb(255,0,0)
			tbEnter.Visible = 0
		Endif
	
		For Each Order EmpCod, CotComCod, CotComForCod //fornecedores
			
			if not CotComForNum.IsEmpty() 
				&QtdFone += 1
				&IsEnviarLinkWhats = true
				&IsEnviarLinkWhats.Enabled = true
			Endif
			
			if not CotComForEmail.IsEmpty() 
				&QtdEmail += 1
				&IsEnviarLinkEmail = true
				&IsEnviarLinkEmail.Enabled = true
			Endif
			
			&QtdFornecedor += 1
		EndFor
		
		For Each ORder EmpCod, CotComCod, CotComItmCod //produtos			
			&QtdProdutos += 1
			
			&QtdFornecedorProduto = 0
			For Each ORder EmpCod, CotComCod, CotComItmCod, CotComProForCod //produtos fornecedor	
				&QtdFornecedorProduto += 1
			EndFor
			
			if &QtdFornecedorProduto = 0
				&IsErroCotacaoFornecedorProduto = true
				tbAvisoerro.Visible = 1
				txtAvisoErro.Caption = format('Produto: %1 - %2 não possui fornecedor nenhum fornecedor selecionado para a cotação!')
				txtAvisoErro.ForeColor = rgb(255,0,0)
				tbEnter.Visible = 0
			Endif
			
		EndFor
			
	EndFor
	
	Do CAse
		Case &QtdProdutos = 0
			tbAvisoerro.Visible = 1
			btnSalvarTodosFornecedores.Visible = 0
			txtAvisoErro.Caption = 'Nenhum produto informado na cotação!'
			txtAvisoErro.ForeColor = rgb(255,0,0)
			tbEnter.Visible = 0
			
		Case &QtdFornecedor = 0
			tbAvisoerro.Visible = 1
			btnSalvarTodosFornecedores.Visible = 0
			txtAvisoErro.Caption = 'Nenhum fornecedor informado na cotação!'
			txtAvisoErro.ForeColor = rgb(255,0,0)
			tbEnter.Visible = 0
			
		Otherwise			
			Do Case
				Case &QtdEmail = 0
					txtQtdEmail.Caption = 'Nenhum E-mail informado na cotação!'
					&IsEnviarLinkEmail = false
					&IsEnviarLinkEmail.Enabled = false
				
				Case &QtdEmail = 1
					txtQtdEmail.Caption = '(1) E-mail informado na cotação!'
				Case &QtdEmail > 1
					txtQtdEmail.Caption = Format('(%1) E-mails informados na cotação!', trim(toformattedString(&QtdEmail)))
			EndCAse
			
			Do Case
				Case &QtdFone = 0
					&IsEnviarLinkWhats = false
					&IsEnviarLinkWhats.Enabled = false
					txtQtdFone.Caption = 'Nenhum Fone informado na cotação!'
				Case &QtdFone = 1
					txtQtdFone.Caption = '(1) Fone informado na cotação!'
				Case &QtdFone > 1
					txtQtdFone.Caption = Format('(%1) Fones informados na cotação!', trim(toformattedString(&QtdFone)))
			EndCAse
	EndCase

EndSub


