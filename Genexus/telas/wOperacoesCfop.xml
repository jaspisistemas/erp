      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&AplicarTodas.Title = 'Aplicar'
	&OperacaoInversa.Title = 'Editar'
	RetornaSoNumeros.Call(&parCfoCod, &tmpCFOP)
	&CfoCod = format('%1.%2', substr(&tmpCFOP, 1, 1), substr(&tmpCFOP, 2, 3))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

EndEvent

Event Grid.Load

	&CfoEmpEntCod = ''
	&CfoEmpInvCod = ''
	
	&LctCod = LctCod
	do 'VerificaIsGravado'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&OperacaoInversa = !'<i class="fas fa-pen"></i>'
	
	&AplicarTodas = !'<i class="fas fa-list"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &OperacaoInversa.Click

	&LctCod = LctCod
	do 'VerificaIsGravado'
	
	If &iSGravado = true
		CfopEntrada.Popup(TrnMode.Update, &CfoCod, &EmpCod, &LctCod, 'E', '', &tmpEntCFOP)
	Else
		CfopEntrada.Popup(TrnMode.Insert, &CfoCod, &EmpCod, &LctCod, 'E', '', &tmpEntCFOP)
	EndIf

	Refresh

EndEvent

Event &AplicarTodas.Click

	wpAplicarTodasOperacoes.Call(LctCod)

EndEvent

Sub 'VerificaIsGravado'

	&iSGravado = false
	For Each Order CfoCod, CfoEmpCod, CfoLctCod
		Where CfoCod = &CfoCod
		Where CfoEmpCod = &EmpCod
		Where CfoLctCod = &LctCod
		
		&CfoEmpEntCod = CfoEmpEntCod
		&CfoEmpInvCod = CfoEmpInvCod
		
		&iSGravado = true
		Exit
	EndFor

EndSub


]]></Source>
