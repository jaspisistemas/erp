      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = 'Consulta de Zoop Pagamentos'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	ZoopTip.ColumnHeaderClass = !'WWColumn hidden-xs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Select = !'<i class="fas fa-check"></i>'
	
	Do Case
		Case ZoopTip.ToString().Trim() = !"B"
			ZoopTip.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case ZoopTip.ToString().Trim() = !"C"
			ZoopTip.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case ZoopTip.ToString().Trim() = !"D"
			ZoopTip.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			ZoopTip.ColumnClass = 'WWColumn hidden-xs'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&InOutZoopId = ZoopId
	&InOutZoopCreCod = ZoopCreCod
	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&InOutZoopId = ZoopId
		&ZoopCardId = ZoopCardId
		&ZoopCardNSU = ZoopCardNSU
		&ZoopCarBan = ZoopCarBan
		&ZoopNomCli = ZoopNomCli
		do 'atualizaDuplicata'
		Return
	endif

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'atualizaDuplicata'

	&WebSession.Set('wpEditDadosCArtao', 'S')
	For each Order EmpCod, FilCod, CreCod
		Where EmpCod = &InEmpCod
		Where FilCod = &InFilCod
		Where CreCod = &InOutZoopCreCod
		prcGravaDadosBandeiraDuplicata.Call(&InEmpCod, &InFilCod, &InOutZoopCreCod, CreCarArqc, CreCarBanCod, &ZoopCardId, &ZoopCardNSU, &ZoopCarBan, &ZoopNomCli, CreCarTax)
		
		Exit
	EndFor

	
	//TRANSACAO
	For Each Order EmpCod, FilCod, ZoopId
		Where EmpCod = &InEmpCod
		Where FilCod = &InFilCod
		Where ZoopId = &InOutZoopId
		&zoopEvent = new()
		&zoopEvent.FromJson(ZoopObs)
		prcGravaRegistroEntradaZoop.Call(EmpCod, FilCod, &zoopEvent, ZoopObs)
		
		//RECEBIVEIS
		For Each Order EmpCod, FilCod, ZoopId, ZoopHisDta
			&auxzoopEvent = new()
			&auxzoopEvent.FromJson(ZoopHisObs)
			prcGravaRegistroEntradaZoop_Recebimento.Call(EmpCod, FilCod, &auxzoopEvent, ZoopHisObs)
		EndFor
	EndFor

EndSub


]]></Source>
