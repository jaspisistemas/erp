      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 20
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadpedido'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&EditarLotes.ColumnHeaderClass = !'WWIconActionColumn'
	ProGraRef.ColumnHeaderClass = !'WWColumn'
	ProNomGra.ColumnHeaderClass = !'WWColumn'
	PedQtd.ColumnHeaderClass = !'WWColumn'
	PedLotTot.ColumnHeaderClass = !'WWColumn'
	PedItmCmpLot.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = grid.PageCount

EndEvent

Event Grid.Load

	VerificaLoteinformadoPedidoItem.Call(EmpCod, FilCod, PedCod, PedItmCod, &IsTodosInformadosAux, &Mensagem)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EditarLotes = !'<i class="fa fa-pen"></i>'

	Do Case
		Case PedLotTotOk  = false or &IsTodosInformadosAux = false
			&EditarLotes.ColumnClass = !'WWIconActionColumn WWColumnDanger WWColumnDangerFirstColumn'
			ProGraRef.ColumnClass = !'WWColumn WWColumnDanger'
			ProNomGra.ColumnClass = !'WWColumn WWColumnDanger'
			PedQtd.ColumnClass = !'WWColumn WWColumnDanger'
			PedLotTot.ColumnClass = !'WWColumn WWColumnDanger'
			PedItmCmpLot.ColumnClass = !'WWColumn WWColumnDanger'
		Case PedLotTotOk = true
			&EditarLotes.ColumnClass = !'WWIconActionColumn WWColumnSuccess WWColumnSuccessFirstColumn'
			ProGraRef.ColumnClass = !'WWColumn WWColumnSuccess'
			ProNomGra.ColumnClass = !'WWColumn WWColumnSuccess'
			PedQtd.ColumnClass = !'WWColumn WWColumnSuccess'
			PedLotTot.ColumnClass = !'WWColumn WWColumnSuccess'
			PedItmCmpLot.ColumnClass = !'WWColumn WWColumnSuccess'
		Otherwise
			&EditarLotes.ColumnClass = 'WWIconActionColumn'
			ProGraRef.ColumnClass = 'WWColumn'
			ProNomGra.ColumnClass = 'WWColumn'
			PedQtd.ColumnClass = 'WWColumn'
			PedLotTot.ColumnClass = 'WWColumn'
			PedItmCmpLot.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarCancelar'

	Do Case
		Case &DeOndeVem = 'WWPEDIDOVENDA'
			wwPedidoVenda.Link()
		Case &DeOndeVem = 'WWORDEMCARREGAMENTO'
			WWOrdemCarregamento.Link()
		Case &DeOndeVem = 'WWDEVOLUCAOCOMPRA'
			wwDevolucaoCompra.Link()
		Case &DeOndeVem = 'WWPEDIDOEMBALADO'
			WWPEDIDOEMBALADO.Link()
		Case &DeOndeVem = 'WWPEDIDOVENDAAGR'
			wwPedidoVendaAgr.Link()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharEstoque'

	VerificaLoteInformadoPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &IsTodosInformados, &Mensagem)
	if &IsTodosInformados = false
		msg(&Mensagem)
	Else
		wpFecharPedidoVendaIntegrado.Link(upper(&DeOndeVem), &EmpCod, &FilCod, &PedCod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	VerificaLoteInformadoPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &IsTodosInformados, &Mensagem)
	if &IsTodosInformados = false
		msg(&Mensagem)
	Else
		GravaNotaTemporariaVenda.Call(&EmpCod, &FilCod, &PedCod, '55')
				
		wpSelecionaProdutosNFe.Link(&DeOndeVem, &EmpCod, &FilCod, &PedCod)
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event PedItmCmpLot.Click

		wpLoteMultiplos.Popup(EmpCod, FilCod, PedCod, PedItmCod)
	Refresh

EndEvent

Event &EditarLotes.Click

	wpLoteMultiplos.Popup(EmpCod, FilCod, PedCod, PedItmCod)
	Refresh

EndEvent

Sub 'loadpedido'

	For Each order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedCliCodRaz = PedCliCodRaz
		
		Exit
	EndFor

	do case
		Case &DeOndeVem = 'WWDEVOLUCAOCOMPRA'
			&PedCliCodRaz.Caption = 'Fornec.'
		Case &DeOndeVem = 'WWPEDIDOCOMPRA'
			&PedCliCodRaz.Caption = 'Fornec.'
	EndCAse

EndSub


