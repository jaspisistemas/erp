Event Start

	&Context = LoadWWPContext()

	if &Context.Old_Perfil <> 3
		Dashboard()
	endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridLogInstancias.Rows = Page.Rows
	sdtInstanciaApps__WinAppGUID.Visible = False
	sdtInstanciaApps__WinAppInsGUID.Visible = False
	sdtInstanciaApps__WinAppInsSts.Visible = False
	sdtAplicativos__WinAppGUID.Visible = False
	sdtAplicativos__WinAppIsHabilitado.Visible = False
	sdtAplicativos__WinAppInsSts.Visible = False
	sdtAplicativos__WinAppQtdInsAtv.Visible = False
	sdtAplicativos__WinAppMaxIns.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridLogInstancias.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridInstancias.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do case
		case &sdtInstanciaApps.CurrentItem.WinAppInsSts = Status_instancia.ATIVO
			iconStatus.Caption = "<i class='ionline fas fa-circle'></i>"
			iconStatus.TooltipText = 'Ativo'
			BtnDoDesativar.Visible = true
			BtnDoDesativar.Enabled = true
			
		case &sdtInstanciaApps.CurrentItem.WinAppInsSts = Status_instancia.INATIVO
			iconStatus.Caption = "<i class='ioffline fas fa-circle'></i>"
			iconStatus.TooltipText = 'Inativo'
			BtnDoDesativar.Visible = false
			BtnDoDesativar.Enabled = false
			
		case &sdtInstanciaApps.CurrentItem.WinAppInsSts = Status_instancia.DESLIGAR
			iconStatus.Caption = "<i class='iwarning fas fa-circle'></i>"
			iconStatus.TooltipText = 'Desligar'
			BtnDoDesativar.Visible = false
			BtnDoDesativar.Enabled = false
	endcase

EndEvent

Event GridAplicativos.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &sdtAplicativos.CurrentItem.WinAppIsHabilitado
		BtnDoHabilitar.Visible = false
		BtnDoDesabilitar.Visible = true
		iconStatusApp.Caption = "<i class='ionline fas fa-circle'></i>"
		iconStatusApp.TooltipText = 'Habilitado'
	else
		BtnDoHabilitar.Visible = true
		BtnDoDesabilitar.Visible = false
		iconStatusApp.Caption = "<i class='ioffline fas fa-circle'></i>"
		iconStatusApp.TooltipText = 'Desabilitado'
	endif

	&QtdInstancias = trim(str(&sdtAplicativos.CurrentItem.WinAppQtdInsAtv)) + '/' + trim(str(&sdtAplicativos.CurrentItem.WinAppMaxIns))

EndEvent

Event 'DoDoRefreshLog'

	do 'LoadLog'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDoStop'

	&sdtInstanciaApp = &sdtInstanciaApps.CurrentItem
	prcWinApp('STP',&sdtInstanciaApp.WinAppGUID,&sdtInstanciaApp.WinAppInsGUID,&sdtInstanciaApp.WinAppInsPID,'','Parado via MonitoraInstância',&UserMessage)
	Msg(DVMessageGetBasicNotificationMsg(&UserMessage.title, &UserMessage.message, &UserMessage.type, '', DVMessageBoolean.True))
	refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDoDesativar'

	&sdtInstanciaApp = &sdtInstanciaApps.CurrentItem
	prcWinApp('DESAT',&sdtInstanciaApp.WinAppGUID,&sdtInstanciaApp.WinAppInsGUID,&sdtInstanciaApp.WinAppInsPID,'','Desativado via MonitoraInstância',&UserMessage)
	Msg(DVMessageGetBasicNotificationMsg(&UserMessage.title, &UserMessage.message, &UserMessage.type, '', DVMessageBoolean.True))
	refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDoRefreshInstancia'

	do 'LoadInstancias'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDoIniciar'

	&sdtApp = &sdtAplicativos.CurrentItem
	if &sdtApp.WinAppIsHabilitado
		prcWinApp('INI',&sdtApp.WinAppGUID,GUID.Empty(),0,&sdtApp.WinAppPath,'Iniciando manualmente', &UserMessage)
		
		Msg(DVMessageGetBasicNotificationMsg(&UserMessage.title, &UserMessage.message, &UserMessage.type, '', DVMessageBoolean.True))
		
		Refresh
	else
		Msg(DVMessageGetBasicNotificationMsg('Processo desabilitado', '', DVMessageType.information, '', DVMessageBoolean.True))
	endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDoDesabilitar'

	&sdtApp = &sdtAplicativos.CurrentItem
	if &sdtApp.WinAppIsHabilitado
		prcWinApp('DESAB',&sdtApp.WinAppGUID,GUID.Empty(),0,'','', &UserMessage)
		
		Msg(DVMessageGetBasicNotificationMsg(&UserMessage.title, &UserMessage.message, &UserMessage.type, '', DVMessageBoolean.True))
		
