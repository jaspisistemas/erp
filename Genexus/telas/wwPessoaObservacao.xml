      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWPESSOAOBSERVACAO', Status_SimNao.Sim, 1, &AutNiv)

	Do Case
		Case &DeOndeVem = 'WWFUNCIONARIO'
			TextBlockTitle.Caption = 'Observações do Funcionário'
			BtnMonitora.Caption = 'Monitora Funcionários'
			
		Case &DeOndeVem = 'WWVENDEDOR'
			TextBlockTitle.Caption = 'Observações do Vendedor'
			BtnMonitora.Caption = 'Monitora Vendedores'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	EmpCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	PesRaz.Link = VerCliente.Link(&DeOndeVem, EmpCod, PesCod)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&AlterarObs = !'<i class="fa fa-pen"></i>'
	
	&DeletaObservacao = !'<i class="fa fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&AlterarObs.Link = wpAdicionarObservacao.Link(&DeOndeVem, EmpCod, PesCod, PesFunObsCod)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DeletaObservacao.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_DeletaObservacao.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_DeletaObservacao.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_DeletaObservacao.Result = !'Yes'
		Do 'Do DeletaObservacao'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoaddObservacao'

	wpAdicionarObservacao.Link(&DeOndeVem, EmpCod, PesCod, 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitora'

	&link = &DeOndeVem.Trim() + '.aspx'
	link(&link)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do DeletaObservacao'

	retornaAutorizacao.Call('WWPESSOAOBSERVACAO', Status_SimNao.Nao, 3, &AutNiv)
	If &AutNiv < 3
		msg('Não Autorizado ao Nível de Eliminar Observação de Funcionários/Vendedore. [WWPESSOAOBSERVACAO]')
	Else
		EliminaObservacaoPessoa.Call(EmpCod, PesCod, PesFunObsCod)
		Refresh
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
