        <Source><![CDATA[
Event Start

	Compilacao.Call(false, &Compilacao, &IsExecutaUpdate, &DisEmpVer, &DisEmpCmp)
	If &IsExecutaUpdate = true
		AplicaAtualizacao.Link()
	EndIf

	loadWWPContext.Call(&Context)	
	CurrentRepository.Caption = format('v: %1/%2 e: %3',&DisEmpVer, trim(str(&DisEmpCmp)), trim(str(&Context.EmpCod)))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TbConfiguracoes.Width = 30

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event gridWid.Load

	&isWD_Mensagens = false
	&countWidget = 0
	
	For Each Order EmpCod, WidPesCod, WidIsSel, WidOrdUsr
		Where EmpCod = &Context.EmpCod
		Where WidPesCod = &Context.PesCod
		Where WidIsSel = true //or WidSync = 'WD_MENSAGENS'
		
		if not WidNom.IsEmpty()
			
			retornaAutorizacao.Call(WidSync, Status_SimNao.Nao, 1, &AutNiv)
			
			if &AutNiv >= 1 or WidSync = 'WD_MENSAGENS'
				&countWidget += 1 
				
				if &isWD_Mensagens = false and &countWidget > 2
					wcWidg1.Object = WidGet_Notificacoes.Create(&Context.EmpCod, &Context.FilCod, &Context.PesCod, &Context.Old_Perfil)  //Autorizaçao Rotina Empresa
					&isWD_Mensagens = true
					load
				Endif
				
				Do Case
					CAse WidSync = 'WD_AGENDA'
						wcWidg1.Object = wcPreviewAgenda.Create(&Context.EmpCod, &Context.PesCod)
						Load
						
					CAse WidSync = 'WD_EXTINTORES'
						wcWidg1.Object = wcPreviewExtintores.Create(&Context.EmpCod, &Context.PesCod)
						Load
					CAse WidSync = 'WD_TICKET'
						wcWidg1.Object = WidGet_Tiket.Create(&Context.EmpCod, &Context.FilCod)	//Autorizaçao Rotina Venda Balção					
						Load
						
					CAse WidSync = 'WD_RECEBERPAGARHJ'
						wcWidg1.Object = WidGet_ReceberPagarHJ.Create(&Context.EmpCod, &Context.FilCod)	//Autorizaçao Rotina Venda Balção				
						Load
						
					CAse WidSync = 'WD_GRAFICOVENDAS'
						wcWidg1.Object = WidGet_GraficoVendas.Create(&Context.EmpCod, &Context.FilCod)	//Autorizaçao Rotina Venda Balção					
						Load
						
					CAse WidSync = 'WD_FATURAMENTOFISCAL'
						wcWidg1.Object = WidGet_FaturamentoFiscalEntSai.Create(&Context.EmpCod, &Context.FilCod)	//Autorizaçao Rotina Monitora Nf-e				
						Load
						
					CAse WidSync = 'WD_ANIVERSARIANTES'
						wcWidg1.Object = WidGet_Aniversariantes.Create(&Context.EmpCod, &Context.PesCod) //Autorizaçao Rotina Cadastro Cliente					
						Load
						
					Case WidSync = 'WD_CARTAOBANDEIRA'
						wcWidg1.Object = Widget_CartaoBandeira.Create(&Context.EmpCod, &Context.FilCod) //Autorização MonitoraDuplicatas + Contas a Receber/Pagar
						Load
						
					case WidSync = 'WD_MENSAGENS' and &isWD_Mensagens = false
						wcWidg1.Object = WidGet_Notificacoes.Create(&Context.EmpCod, &Context.FilCod, &Context.PesCod, &Context.Old_Perfil)  //Autorizaçao Rotina Empresa
						&isWD_Mensagens = true
						load
						
				EndCase
			Endif
		EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndFor
	
	if &isWD_Mensagens = false
		wcWidg1.Object = WidGet_Notificacoes.Create(&Context.EmpCod, &Context.FilCod, &Context.PesCod, &Context.Old_Perfil)  //Autorizaçao Rotina Empresa
		&isWD_Mensagens = true
		load
	Endif

EndEvent

Event 'Dotestes'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMeusWidgets'

	wpMeusWidgets.PopUp(&Context.pesCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfiguracoes'

	&Ano = YEAR(&Today)
	&PadPesCod = &Context.PesCod*1000 + &Ano
	padraoUsuarioHora.Call('G', '#WidGet_GraficoVendas#', &PadPesCod, &Context.EmpCod, '', &PadDtaMod, &PadDtaHorMod, 'T')
	&PadPesCod = (&Context.PesCod*100) + (&Context.FilCod*3) + &Ano
	padraoUsuarioHora.Call('G', '#WidGet_FaturamentoFiscalEntSai#', &PadPesCod, &Context.EmpCod, '', &PadDtaMod, &PadDtaHorMod, 'T')
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


