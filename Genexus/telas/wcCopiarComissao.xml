      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&WwpContext)
	&EmpCod = &parEmpcod
	
	&OriLctCod = &parLCtCod
	&DstLctCod = &parLCtCod
	
	&OriPesCod = &parPesCod
	&DstPesCod = &parPesCod

	do 'getTipoLancamentoOrigem'
	do 'getTipoLancamentoDstino'
	do 'PessoaOrigem'
	do 'PessoaDestino'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&OriPesCod.SetFocus()

EndEvent

Event Enter

	do 'getTipoLancamentoOrigem'
	do 'getTipoLancamentoDstino'
	do 'PessoaOrigem'
	do 'PessoaDestino'
	
	Do Case 
		Case &OriLctCod = &DstLctCod and &OriPesCod = &DstPesCod
			txtSucessoFracasso.Caption = 'Dados inválidos!'
			txtSucessoFracasso.ForeColor = RGB(255,0,0)
			&OriPesCod.SetFocus()
			
		Case &OriLctCod.IsEmpty() and not &DstLctCod.IsEmpty()
			txtSucessoFracasso.Caption = 'Quando não informado Tipo lançamento Origem, não deve ser informado o Tipo Lançamento Destino!'
			txtSucessoFracasso.ForeColor = RGB(255,0,0)
			&OriLctCod.SetFocus()
		
		Case &OriPesCod.IsEmpty()
			txtSucessoFracasso.Caption = 'Pessoa Origem é obrigatório!'
			txtSucessoFracasso.ForeColor = RGB(255,0,0)
			&OriLctCod.SetFocus()
			
		Case &IsErroDstgemLctCod = true
			txtSucessoFracasso.Caption = 'Tipo Operação Destino inválido!'
			txtSucessoFracasso.ForeColor = RGB(255,0,0)
			
		Case &IsErroOrigemLctCod = true
			txtSucessoFracasso.Caption = 'Tipo Operação Origem inválido!'
			txtSucessoFracasso.ForeColor = RGB(255,0,0)
			
		Case &IsErroOrigemPesCod = true
			txtSucessoFracasso.Caption = 'Pessoa Origem inválida!'
			txtSucessoFracasso.ForeColor = RGB(255,0,0)
			
		Case &IsErroDestPesCod = true
			txtSucessoFracasso.Caption = 'Pessoa Destina inválida!'
			txtSucessoFracasso.ForeColor = RGB(255,0,0)
			
		otherwise
			
			For Each Order EmpCod, PesCod, ComLctCod
				Where EmpCod = &parEmpcod
				Where PesCod = &OriPesCod
				Where ComLctCod = &OriLctCod when not &OriLctCod = 0
				Where ComLctPagCom = Status_SimNao.Sim when &OriLctCod = 0
				
				&sdtComissaoVendedorDesconto.Item.Clear()
				
				//carrega dados
				prcCarregaDadosComissao.Call(EmpCod, PesCod, ComLctCod, &sdtComissaoVendedorDesconto)
				
				//grava Dados
				if &DstLctCod > 0
					gravaCopiaComissao.Call(&WwpContext, EmpCod, &DstPesCod, &DstLctCod, ComTabNor, ComTabPrm, &sdtComissaoVendedorDesconto)
				Else
					gravaCopiaComissao.Call(&WwpContext, EmpCod, &DstPesCod, 0, ComTabNor, ComTabPrm, &sdtComissaoVendedorDesconto)
				Endif			
					
			EndFor
			
			&OriPesCod.SetFocus()
			
			txtAviso.Caption = 'Dados Copiados com sucesso!'
			txtAviso.ForeColor = RGB(0,110,0)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wwpActions.WCPopup_Close('S')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &OriPesCod.IsValid

	txtAviso.Caption = ''
	do 'PessoaOrigem'

EndEvent

Event &DstPesCod.IsValid

	do 'PessoaDestino'

EndEvent

Event &DstLctCod.IsValid

	do 'getTipoLancamentoDstino'

EndEvent

Event &OriLctCod.IsValid

	do 'getTipoLancamentoOrigem'

EndEvent

Sub 'PessoaDestino'

	&IsErroDestPesCod = false
	For Each ORder EmpCod, PesCod
		Where EmpCod = &parEmpcod
		Where PesCod = &DstPesCod
		&DstPesRaz = PesRaz
		Exit
	When none
		&IsErroDestPesCod = true
		&DstPesRaz = 'NÃO LOCALIZADO'
	EndFor

EndSub

Sub 'PessoaOrigem'

	&IsErroOrigemPesCod = false
	For Each ORder EmpCod, PesCod
		Where EmpCod = &parEmpcod
		Where PesCod = &OriPesCod
		&OriPesRaz = PesRaz
		Exit
	When none
		&IsErroOrigemPesCod = true
		&OriPesRaz = 'NÃO LOCALIZADO'
	EndFor

EndSub

Sub 'getTipoLancamentoDstino'

	&IsErroDstgemLctCod = false
	For Each ORder EmpCod, LctCod
		Where EmpCod = &parEmpcod
		Where LctCod = &DstLctCod
		&DstLctNom = LctNom
		Exit
	When none
		if &DstLctCod > 0
			&IsErroDstgemLctCod = true
			&DstLctNom = 'NÃO LOCALIZADO OPERAÇÃO'
		Else
			&DstLctNom = 'TODAS OPERAÇÕES QUE GEREM COMISSÃO'
		Endif	
	EndFor

EndSub

Sub 'getTipoLancamentoOrigem'

	&IsErroOrigemLctCod = false
	For Each ORder EmpCod, LctCod
		Where EmpCod = &parEmpcod
		Where LctCod = &OriLctCod
		&OriLctNom = LctNom
		Exit
	When none
		if &OriLctCod > 0
			&IsErroOrigemLctCod = true
			&OriLctNom = 'NÃO LOCALIZADO'
		Else
			&OriLctNom = 'TODAS OPERAÇÕES QUE GEREM COMISSÃO'
		Endif	
	EndFor

EndSub


]]></Source>
