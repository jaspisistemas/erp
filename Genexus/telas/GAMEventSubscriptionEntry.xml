      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode <> TrnMode.Insert
		&EventSubscription.Load(&Id)
		&Description= &EventSubscription.Description		
		&Status		= &EventSubscription.Status
		&Event	  	= &EventSubscription.Event
		&FileName 	= &EventSubscription.FileName
		&ClassName	= &EventSubscription.ClassName		
		&MethodName = &EventSubscription.MethodName
		If &Mode <> TrnMode.Update	
			&Description.Enabled 	= False			
			&Event.Enabled 			= False
			&FileName.Enabled 		= False
			&ClassName.Enabled 		= False
			&MethodName.Enabled 	= False
		Endif
	else
		&Status		= GAMEventSubscriptionStatus.Unsubscribed
		BtnEnter.Caption = "Confirm"
	Endif
	if &Mode = TrnMode.Delete
		BtnEnter.Caption ="Delete"
		BtnEnter.Visible 	= True
	endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&EventSubscription.Load(&Id)	
	Do Case
		Case &Mode = TrnMode.Insert or &Mode = TrnMode.Update
			&EventSubscription.Description	= &Description
			&EventSubscription.Event.FromString(&Event)
			&EventSubscription.FileName		= &FileName
			&EventSubscription.ClassName		= &ClassName
			&EventSubscription.MethodName 	= &MethodName
			&EventSubscription.Save()
		Case &Mode = TrnMode.Delete
			&EventSubscription.Delete()
	EndCase

	If &EventSubscription.Success()
		Commit
		GAMWWEventSubscriptions.Link()
	Else
		&Errors = &EventSubscription.GetErrors()
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor
	Endif

EndEvent


]]></Source>
