      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWAUTORIZACOES', Status_SimNao.Sim, 2, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&AutGrpCod = &AuxAutGrpCod
	
	&IsAturoriza.Enabled = 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&AutGrpSts = Status_AtivoInativo.ATIVO
	For Each Order EmpCod, AutGrpCod
		Where EmpCod = &EmpCod
		Where AutGrpCod = &AutGrpCod
		&AutGrpNom = AutGrpNom
		Exit
	EndFor

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ConfAcesso.FromImage(GAMActionPermission)
	&ConfAcesso.TooltipText = "Perfis de Acesso."

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If PesSts = Status_AtivoInativo.ATIVO
		PesSts.ForeColor = RGB(0,0,0)
	Else
		PesSts.ForeColor = RGB(160,40,0)
	EndIF
	
	&PesCod = PesCod
	do 'VerificaUsuario'

EndEvent

Event 'DoConfirmar'

	For Each Line in grid
		GravaPerfilUsuario.Call(&EmpCod, PesCod, &AutGrpCod, &IsAturoriza)
	EndFor

	grid.Refresh()
	msg('Usuários do Perfil modificados com sucesso!')
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ConfAcesso.Click

	wwPerfisUsuario.Popup(PesCod)
	Refresh

EndEvent

Sub 'VerificaUsuario'

	For Each Order EmpCod, AutGrpCod, PesCod
		Where EmpCod = &EmpCod
		Where AutGrpCod = &AutGrpCod
		Where PesCod = &PesCod

		&IsAturoriza = true
		Exit
	When None
		&IsAturoriza = false
	EndFor

EndSub

//Event &AutGrpSts.Click
