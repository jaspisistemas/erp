      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	PadraoUsuario.Call('L', trim(str(&PedCod)), &Context.PesCod, &Context.EmpCod,  &PadObs, &PadDtaMod)
	&sdtPedidoProduto.fromJson(&PadObs)
	Do 'getPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 800
	GridsdtPedidoProdutos.Rows = Page.Rows
	&GridsdtPedidoProdutosCurrentPage = 1
	&GridsdtPedidoProdutosCurrentPage.Visible = False
	&GridsdtPedidoProdutosPageCount = -1
	GridsdtPedidoProdutosPaginationBar.RowsPerPageSelectedValue = GridsdtPedidoProdutos.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridsdtPedidoProdutosPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoProdutos.Load

&TotPedVlrItm = 0
	For &sdtPedidoProdutoItem in &sdtPedidoProduto
		if &sdtPedidoProdutoItem.PedQtdCre > 0
		&GridEmpCod = &sdtPedidoProdutoItem.EmpCod
		&GridFilCod = &sdtPedidoProdutoItem.FILCod
		&GridPedCod = &sdtPedidoProdutoItem.PedCod
		&GridPedItmCod = &sdtPedidoProdutoItem.PeditmCod
		&GridProGraRef = &sdtPedidoProdutoItem.ProGraRef
		&GridProNomGra = &sdtPedidoProdutoItem.ProNom
		&GridPedQtdCre = &sdtPedidoProdutoItem.PedQtdCre
		&GridPedVlrItm  = &sdtPedidoProdutoItem.PedVlrItm
		&TotPedVlrItm += &sdtPedidoProdutoItem.PedVlrItm

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
		EndIf
	EndFor

EndEvent

Event GridsdtPedidoProdutosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtPedidoProdutosPaginationBar.SelectedPage = !'Previous'
			&GridsdtPedidoProdutosCurrentPage -= 1
			GridsdtPedidoProdutos.PreviousPage()
		Case GridsdtPedidoProdutosPaginationBar.SelectedPage = !'Next'
			&GridsdtPedidoProdutosCurrentPage += 1
			GridsdtPedidoProdutos.NextPage()
		Otherwise
			&PageToGo.FromString(GridsdtPedidoProdutosPaginationBar.SelectedPage)
			&GridsdtPedidoProdutosCurrentPage = &PageToGo
			GridsdtPedidoProdutos.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoProdutosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoProdutos.Rows = GridsdtPedidoProdutosPaginationBar.RowsPerPageSelectedValue
	&GridsdtPedidoProdutosCurrentPage = 1
	GridsdtPedidoProdutos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&CreCobObs   = 'Crédito gerado ao canelar item pago no pedido: '+ trim(toFormattedString(&PedCod))
	GravaduplicataCredito.Call(&EmpCod,&FilCod,&TotPedVlrItm,'CREDITO',&PedCliCod,&CreCobObs,&pedCod)
	AtualizaQuantidadesPedido.Call(&EmpCod, &FiLCod, &PedCod, &sdtPedidoProduto, &wwpContext.UserName)
	return

EndEvent

Sub 'getPedido'

	For each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where PedCod = &PedCod
		
		&PedCliCodRaz = PedCliCodRaz
		&PedDtaEms = PedDtaEms
		&PedCliCod = PedCliCod
		&PedPrpCod = PedPrpCod
		&PedPrpNom = PedPrpNom
		&PedPrpEnd = PedPrpEnd
		&PedPrpEndDen = PedPrpDen
		&PedPrpIns = PedPrpIns
		exit
	EndFor

EndSub


]]></Source>
