EndEvent

Event Enter

	if &outAutGrpCod = &inAutGrpCod
		msg('Perfil de Autorização igual, ai não pode!')
	Else
		prcConfirmaCopiaAutorizacoes.Call(&EmpCod, &inAutGrpCod, &outAutGrpCod, &OqueFazer, &wwpContext.UserName)
		msg('Copia Realizada com sucesso!' + serverNow())
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



