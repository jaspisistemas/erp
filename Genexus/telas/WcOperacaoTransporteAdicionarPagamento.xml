      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&OpeDtaLib	= &Today
	&OpeNroCiot	= &parmOpeNroCiot.Trim()
	
	Do 'LoadOperacao'
	
	Do 'GetContas'
	Do 'VerificaConta'

EndEvent

Event 'DoAdicionarAoSDT'

	Do Case
		Case &OpePgtConTip = PefServiceTipoConta.Indefinido
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Deve ser informado o tipo da conta.', DVMessageType.regular, "", DVMessageBoolean.True,""))
		Case &OpePgtBan.IsEmpty()
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Deve ser informado uma instituição bancária.', DVMessageType.regular, "", DVMessageBoolean.True,""))		
		Case &OpePgtAge.IsEmpty() 
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Deve ser informado uma agência.', DVMessageType.regular, "", DVMessageBoolean.True,""))
		Case &OpePgtCon.IsEmpty()
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Deve ser informado uma conta bancária.', DVMessageType.regular, "", DVMessageBoolean.True,""))	
		OtherWise
			Do 'GetPagamentos'
			prcNovoEFrete_Login.Call(&Token, &ProtocoloServico, &StatusLogin)
			
			If &StatusLogin = 200
				EFrete_AdicionarPagamento.Call(&Token, &parmOpeCod, &OpePgtCod, &parmOpeNroCiot, &OpePgtNro, &OpeDtaLib, &OpePgtVal, &OpepgtTip, &OpePgtCat, &OpePgtDoc, &OpePgtBan, &OpePgtAge, 
				&OpePgtCon, &OpePgtConTip, &OpePgtInfAdd, &StatusLogOut)
				
				If &StatusLogOut = 200
					&OpeDtaLib		= &Today
					&OpePgtConTip	= PefServiceTipoConta.ContaCorrente
					&OpePgtBan.SetEmpty()
					&OpePgtAge.SetEmpty()
					&OpePgtCon.SetEmpty()
				EndIf

			Else
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &StatusLogin.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
			EndIf
			
			If not &Token.Trim().IsEmpty()
				prcNovoEFrete_Logout.Call(&Token, &StatusLogOut)
			EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

EndEvent

Event 'DoCancelar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CtabanCod.ControlValueChanged

	Do 'VerificaConta'

EndEvent

Sub 'GetContas'

	&CtabanCod.Clear()
	&CtabanCod.AddItem(0, '(SELECIONAR)')
	For Each Order EmpCod, CtabanCod
		Where EmpCod 	= &parmEmpCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO 
		Where CtaBanTip = TipoConta.BANCO
		
		&CtabanCod.AddItem(CtabanCod, CtaBanNom)
		
	EndFor

EndSub

Sub 'VerificaConta'

	For Each Order EmpCod, CtabanCod
		Where EmpCod 	= &parmEmpCod
		Where CtabanCod	= &CtabanCod
		
		&OpePgtBan 		= CtaBanBanCod
		&OpePgtAge		= CtaBanAgeCod
		If CtaBanCrtDig.IsEmpty()
			&OpePgtCon	= CtaBanCrt
		Else
			&OpePgtCon	= CtaBanCrt + '-' + CtaBanCrtDig
		EndIf
		Exit
	When None
		&OpePgtBan.SetEmpty()
		&OpePgtAge.SetEmpty()
		&OpePgtCon.SetEmpty()
	EndFor

EndSub

Sub 'LoadOperacao'

	For Each Order EmpCod, FilCod, OpeCod
		Where EmpCod 	= &parmEmpCod
		Where FilCod 	= &parmFilCod
		Where OpeCod 	= &parmOpeCod
		
		&OpeEmiGra		= OpeEmiGra
		&OpeTipVia		= OpeTipVia
		
		Exit
	EndFor

EndSub

Sub 'GetPagamentos'

	For Each Order (OpePgtCod), EmpCod, FilCod, OpeCod
		Where EmpCod 	= &parmEmpCod
		Where FilCod 	= &parmFilCod
		Where OpeCod 	= &parmOpeCod
		
		&OpePgtCod		= OpePgtCod + 1
		&OpepgtTip		= OpePgtTip
		&OpePgtDoc		= OpePgtDoc
		
		Exit
	EndFor

EndSub


]]></Source>
