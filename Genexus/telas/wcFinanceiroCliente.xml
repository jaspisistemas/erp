        <Source><![CDATA[
Event Start

	loadWwpContext.Call(&WwpContext)
	do 'LoadCliente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Fundacao.Visible = (&PesTip = TipoPessoa.JURIDICA)
	nascimento.Visible = (&PesTip = TipoPessoa.FISICA)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	GravaPEssoaFinanceiro.Call(&EmpCod, &WwpContext.FilCod, &PesCod, &PesEnvSpc,&PesProAtv,&PesResSpc,&PesResChe,&PesDtaCon ,&PesVenAprz,&PesClaTip,&PedCliCrd, &PesDtaFun, &PesDtaNas, &WwpContext.UserName)
	msg('Dados atualizados com sucesso!')

EndEvent

Sub 'LoadCliente'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PedCliCodRaz = PesCodRaz
		&PesEnvSpc = PesEnvSpc
		&PesProAtv = PesProAtv
		&PesResSpc = PesResSpc
		&PesResChe = PesResChe
		&PesDtaCon = PesDtaCon
		&PesVenAprz = PesVenAprz
		&PesClaTip = PesClaTip
		&PedCliCrd = PesCliCrd
		
		&PesTip = PesTip
		&PesDtaFun = PesDtaFun
		&PesDtaNas = PesDtaNas
	
		Exit
	EndFor

EndSub


]]></Source>
