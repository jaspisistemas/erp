      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	
	retornaConfiguracoesPastas.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtConfiguracoesPasta)
	&EmpCod = &wwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid1_DWC.Class = !'Invisible WCD_' + upper(Grid1.InternalName)
	UnnamedTable6.Width = 190
	UnnamedTable7.Width = 187
	Grid1.Rows = Page.Rows
	&Grid1CurrentPage = 1
	&Grid1CurrentPage.Visible = False
	&Grid1PageCount = -1
	&codigo.Visible = False
	Grid1PaginationBar.RowsPerPageSelectedValue = Grid1.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//atualiza pedidos 
	For Each Order EmpCod, MrkCod, MrkPedSku
		Where EmpCod = &EmpCod
		Where MrkNfeCod.IsEmpty() or MrkNfeCod.IsNull()
		Where MrkPedCod > 0
		Where MrkPedEtqDtaHor.IsEmpty() or MrkPedEtqDtaHor.isNull()
		
		prcAtualizaNfeCodPedidoMarketplace.Call(EmpCod, MrkPedFilCod, MrkPedCod)
		
		
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	//The variable '&Grid1PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	MrkPedStsEnv.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	&imagemmarketplace.FromImage(retornaImagemMarketplace.Udp(MrkTip))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'
	
	&GridActionGroup1.Clear()
	&GridActionGroup1.AddItem(0, 'WWP_ActionGroupCaption')
	If (MrkPedCod <= 0)
		&GridActionGroup1.AddItem(1, 'Gerar Pedido')
	Endif
	If (MrkPedCod > 0 and MrkNfeCod <= 0)
		&GridActionGroup1.AddItem(2, 'Emitir NFe')
	Endif
	If (MrkPedStsEnv = MarketplaceStatusPedido.ENVIAR_NOTA)
		&GridActionGroup1.AddItem(3, 'Enviar Nota')
	Endif
	If (MrkPedCod > 0)
		&GridActionGroup1.AddItem(4, 'Imprimir Etiqueta')
	Endif
	If &GridActionGroup1.Count = 1
		&GridActionGroup1.Class = !'Invisible'
	Else
		&GridActionGroup1.Class = !'Attribute'
	EndIf

	&MrkPedSts = MercadoLivreStatusPedido.Udp(TipoMarketplace.MercadoLivre, 'S', MrkPedSts)
	Do Case
		Case MrkPedSts = 'A'
			&MrkPedSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case MrkPedSts = 'X'
			&MrkPedSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case MrkPedSts = 'N'
			&MrkPedSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			&MrkPedSts.ColumnClass = 'WWColumn'
	EndCase
	Do Case
		Case MrkPedStsEnv = MarketplaceStatusPedido.GERAR_PEDIDO
			MrkPedStsEnv.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case MrkPedStsEnv = MarketplaceStatusPedido.EMITIR_NOTA
			MrkPedStsEnv.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case MrkPedStsEnv = MarketplaceStatusPedido.GERAR_ETIQUETA
			MrkPedStsEnv.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case MrkPedStsEnv = MarketplaceStatusPedido.DESPACHAR_PRODUTO
			MrkPedStsEnv.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case MrkPedStsEnv = MarketplaceStatusPedido.EM_TRANSPORTE
			MrkPedStsEnv.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case MrkPedStsEnv = MarketplaceStatusPedido.FINALIZADO
			MrkPedStsEnv.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case MrkPedStsEnv = MarketplaceStatusPedido.CANCELADO
			MrkPedStsEnv.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			MrkPedStsEnv.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid2.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&codigo = 1
	txtTitulo.Caption = 'Mensagens'
	txtTitulo1.Caption = 'Sem resposta'
	do 'somamensagenspendentes'
	
	if &Total > 0
		txtQtdMensagens.Class = 'badgeRed'
	Else
		txtQtdMensagens.Class = 'badgeBlack'
	Endif
	
	if &Total > 9
		txtQtdMensagens.Caption = trim(str(&Total))+'+'
	Else
		txtQtdMensagens.Caption = trim(str(&Total))
	Endif
	load //mensagenss
	
	&codigo = 2
	do 'somapedidosnaolancados'
	txtTitulo.Caption = 'Pedidos'
	txtTitulo1.Caption = 'Não lançados'
	if &Total > 0
		txtQtdMensagens.Class = 'badgeRed'
	Else
		txtQtdMensagens.Class = 'badgeBlack'
	Endif
	if &Total > 9
		txtQtdMensagens.Caption = trim(str(&Total))+'+'
	Else
		txtQtdMensagens.Caption = trim(str(&Total))
	Endif
	load //pedidos
	
	&Total = 0
	&codigo = 3
	do 'somapedidosSemEtiquetas'
	txtTitulo.Caption = 'Etiquetas'
	txtTitulo1.Caption = 'Não impressas'
	if &Total > 0
		txtQtdMensagens.Class = 'badgeRed'
	Else
		txtQtdMensagens.Class = 'badgeBlack'
	Endif
	if &Total > 9
		txtQtdMensagens.Caption = trim(str(&Total))+'+'
	Else
		txtQtdMensagens.Caption = trim(str(&Total))
	Endif
	load //pedidos
	
	
	&Total = 0
	&codigo = 4
