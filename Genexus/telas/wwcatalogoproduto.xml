      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	If &HttpRequest.Method = HttpMethod.Get
		For Each Order EmpCod,CtlCod
			Where EmpCod = &EmpCod
			Where CtlCod = &CtlCod
			&CtlNom = CtlNom
			&TabCod = TabCod
		When None
			msg('Registro não encontrado')
		EndFor

		Do 'getprodutos'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TabCod.TooltipText = "Tabela vazia pega todos os cadastros"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCatalogo'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWCatalogo.Call('')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoTabelaPreco'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWTabelaPreco.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRightAll'

	Do 'AssociateAll'
	Do 'UpdateAssociationVariables'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRight'

	Do 'AssociateSelected'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Doleft'

	Do 'DisassociateSelected'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Doleftall'

	Do 'AssociateAll'	
	&NotAddedKeyList = &AddedKeyList.Clone()
	&NotAddedDscList = &AddedDscList.Clone()
	&AddedDscList.Clear()
	&AddedKeyList.Clear()
	Do 'SaveLists'
	Do 'UpdateAssociationVariables'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLimpar'

	&AddedKeyList.Clear()
	&AddedDscList.Clear()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	Do 'UpdateAssociationVariables'

EndEvent

Event &AssociatedRecords.DblClick

	Do 'DisassociateSelected'

EndEvent

Event &NotAssociatedRecords.DblClick

	Do 'AssociateSelected'

EndEvent

Event &GrupHie.Click

	If &oldGrupHie <> &GrupHie
		Do 'getProdutos'
		&OldGrupHie = &GrupHie
	EndIf

EndEvent

Event &GrupHie.IsValid

	If &oldGrupHie <> &GrupHie
		Do 'getProdutos'
		&OldGrupHie = &GrupHie
	EndIf

EndEvent

Event &ProTipDef.IsValid

	do 'getProdutos'

EndEvent

Event &TabCod.IsValid

	If &oldTabCod <> &TabCod
		do 'getProdutos'
		&oldTabCod = &TabCod
	EndIf

EndEvent

Event &ProDtaCad.IsValid

	Do 'getprodutos'

EndEvent

Event Enter

	Do 'LoadLists'
	&i = 1
	&Success = true
	For &ProCod in &AddedKeyList
		If &Success
			&Exist = false
			For Each order EmpCod,CtlCod,ProCod
				Where EmpCod = &EmpCod
				Where CtlCod = &CtlCod
				Where ProCod = &ProCod
				&Exist = true
			EndFor
			If not &Exist
				&CatalogoProduto = new()
				&CatalogoProduto.EmpCod = &EmpCod
				&CatalogoProduto.CtlCod = &CtlCod
				&CatalogoProduto.ProCod = &ProCod
				&CatalogoProduto.Save()
				If not &CatalogoProduto.Success()
					&Success = false
				EndIf
			EndIf
		EndIf
		&i += 1
	EndFor
	&i = 1
	For &ProCod in &NotAddedKeyList
		If &Success
			&Exist = false
			For Each order EmpCod,CtlCod,ProCod
				Where EmpCod = &EmpCod
				Where CtlCod = &CtlCod
				Where ProCod = &ProCod
				&Exist = true
			EndFor
			If &Exist
				&CatalogoProduto = new()
				&CatalogoProduto.Load(&EmpCod,&CtlCod,&ProCod)
				If &CatalogoProduto.Success()
					&CatalogoProduto.Delete()
				EndIf
				If not &CatalogoProduto.Success()
					&Success = false
				EndIf
			EndIf
		EndIf
		&i += 1
	EndFor
	If &Success
		Commit
		msg('Gravado com sucesso')
	else
		Do 'Show Error Messages'
	EndIf

EndEvent

Event &auxProCod.isValid

	If &oldProCod <> &auxProCod
		Do 'getProdutos'
		&oldProCod = &auxProCod
	EndIf

EndEvent

Event &MarCod.IsValid

	If &oldMarCod <> &MarCod
		Do 'getProdutos'
		&oldMarCod = &MarCod
	EndIf

EndEvent

Sub 'SaveLists'

	If &AddedKeyList.Count > 0
		&AddedKeyListXml = &AddedKeyList.ToXml()
		&AddedDscListXml = &AddedDscList.ToXml()
	else
		&AddedKeyListXml = ''
		&AddedDscListXml = ''
	EndIf
	If &NotAddedKeyList.Count > 0
		&NotAddedKeyListXml = &NotAddedKeyList.ToXml()
		&NotAddedDscListXml = &NotAddedDscList.ToXml()
	else
		&NotAddedKeyListXml = ''
		&NotAddedDscListXml = ''
	EndIf

EndSub

Sub 'UpdateAssociationVariables'

	Do 'LoadLists'
	&AssociatedRecords.Clear()
	&NotAssociatedRecords.Clear()
	&i = 1
	For &ProCod in &AddedKeyList
		&Description = &AddedDscList.Item(&i)
		&AssociatedRecords.AddItem(&ProCod, &Description.Trim())
		&i += 1
	EndFor
	&i = 1
	For &ProCod in &NotAddedKeyList
		&Description = &NotAddedDscList.Item(&i)
		&NotAssociatedRecords.AddItem(&ProCod, &Description.Trim())
		&i += 1
	EndFor

EndSub

Sub 'LoadLists'

	If not &AddedKeyListXml.IsEmpty()
		&AddedDscList.FromXml(&AddedDscListXml)
		&AddedKeyList.FromXml(&AddedKeyListXml)
	EndIf
	If not &NotAddedKeyListXml.IsEmpty()
		&NotAddedKeyList.FromXml(&NotAddedKeyListXml)
		&NotAddedDscList.FromXml(&NotAddedDscListXml)
	EndIf

EndSub

Sub 'AssociateAll'

	Do 'LoadLists'
	&i = 1
	&InsertIndex = 1
	For &ProCod in &NotAddedKeyList
		&Description = &NotAddedDscList.Item(&i)
		Do while &InsertIndex <= &AddedDscList.Count AND &AddedDscList.Item(&InsertIndex) < &Description
			&InsertIndex = &InsertIndex + 1
		Enddo
		&AddedKeyList.Add(&ProCod, &InsertIndex)
		&AddedDscList.Add(&Description, &InsertIndex)
		&i = &i + 1
	EndFor
	&NotAddedKeyList.Clear()
	&NotAddedDscList.Clear()
	Do 'SaveLists'

EndSub

Sub 'AssociateSelected'

	Do 'LoadLists'
	&i = 1
	For &ProCod in &NotAddedKeyList
		If &ProCod = &NotAssociatedRecords
			Exit
		EndIf
		&i = &i + 1
	EndFor
	If &i <= &NotAddedKeyList.Count
		&Description = &NotAddedDscList.Item(&i)
		&InsertIndex = 1
		Do while &InsertIndex <= &AddedDscList.Count AND &AddedDscList.Item(&InsertIndex) < &Description
			&InsertIndex = &InsertIndex + 1
		Enddo
		&AddedKeyList.Add(&NotAssociatedRecords, &InsertIndex)
		&AddedDscList.Add(&Description, &InsertIndex)
		&NotAddedKeyList.Remove(&i)
		&NotAddedDscList.Remove(&i)
		Do 'SaveLists'
	EndIf
	Do 'UpdateAssociationVariables'

EndSub

Sub 'DisassociateSelected'

	Do 'LoadLists'
	&i = 1
	For &ProCod in &AddedKeyList
		If &ProCod = &AssociatedRecords
			exit
		EndIf
		&i = &i + 1
	EndFor
	If &i <= &AddedKeyList.Count
		&Description = &AddedDscList.Item(&i)
		&InsertIndex = 1
		Do while &InsertIndex <= &NotAddedDscList.Count AND &NotAddedDscList.Item(&InsertIndex) < &Description
			&InsertIndex = &InsertIndex + 1
		Enddo
		&NotAddedKeyList.Add(&AssociatedRecords, &InsertIndex)
		&NotAddedDscList.Add(&Description, &InsertIndex)
		&AddedKeyList.Remove(&i)
		&AddedDscList.Remove(&i)
		Do 'SaveLists'
	EndIf
	Do 'UpdateAssociationVariables'

EndSub

Sub 'getProdutos'

	&NotAddedKeyList.Clear()
	&NotAddedDscList.Clear()
	If &TabCod.IsEmpty()
		
		For Each Order EmpCod,ProSts,ProCod
			Where EmpCod = &EmpCod
			Where ProSts = Status_Produto.ATIVO
			Where ProRef = &auxProCod when not &auxProCod.IsEmpty()
			Where (GrupHie like &GrupHie or GrupHie = &GrupHie) or &GrupHie.IsEmpty()
			where ProDtaCad >= &ProDtaCad when not &ProDtaCad.IsEmpty()
			Where MarCod = &MarCod when not &MarCod.isempty()
//			Where ProNom like &auxProNom or ProBar like &auxProNom or ProRef like &auxProNom or (ProBarRef_Comp like '%'+&uxProNom) or (ProNomApl like '%'+&auxProNom)  when not &auxProNom.IsEmpty()
			Where ProTipDef = &ProTipDef when not &ProTipDef.IsEmpty()
			
			&Exist = false
			For Each order EmpCod,CtlCod
				Where CtlCod = &CtlCod
				&Exist = true
			EndFor
			&Description = ProRefNom
			If &Exist
				&AddedKeyList.Add(ProCod)
				&AddedDscList.Add(&Description)
			Else
				&NotAddedKeyList.Add(ProCod)
				&NotAddedDscList.Add(&Description)
			EndIf			
		EndFor
		Do 'SaveLists'
	Else
		For Each Order EmpCod,TabCod,ProSts,ProCod
			Where EmpCod = &EmpCod
			Where TabCod = &TabCod
			Where ProSts = Status_Produto.ATIVO
			Where ProRef = &auxProCod when not &auxProCod.IsEmpty()
			Where (GrupHie like &GrupHie or GrupHie = &GrupHie) or &GrupHie.IsEmpty()
			where ProDtaCad >= &ProDtaCad when not &ProDtaCad.IsEmpty()
			Where MarCod = &MarCod when not &MarCod.isempty()
//			Where ProNom like &auxProNom or ProBar like &auxProNom or ProRef like &auxProNom or (ProBarRef_Comp like '%'+&uxProNom) or (ProNomApl like '%'+&auxProNom)  when not &auxProNom.IsEmpty()
			Where ProTipDef = &ProTipDef when not &ProTipDef.IsEmpty()
			&Exist = false
			For Each order EmpCod,ProCod,CtlCod
				Where CtlCod = &CtlCod
				&Exist = true
			EndFor
			&Description = ProRefNom
			If &Exist
				&AddedKeyList.Add(ProCod)
				&AddedDscList.Add(&Description)
			Else
				&NotAddedKeyList.Add(ProCod)
				&NotAddedDscList.Add(&Description)
			EndIf			
		EndFor
		Do 'SaveLists'
	EndIf
	Do 'UpdateAssociationVariables'

EndSub

Sub 'Show Error Messages'

	For &Message in &CatalogoProduto.GetMessages()
		If &Message.Type = MessageTypes.Error
			msg(&Message.Description)
		EndIf
	EndFor

EndSub


