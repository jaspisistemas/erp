      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	If Not(&NfsTipNF <> 'S')
		If &GoingBack
			wpNFS(!'Itens', !'DadosNFSE', true, &SessionGuid)
		Else
			wpNFS(!'Itens', !'Totais', false, &SessionGuid)
		Endif
	Endif

	UnnamedTable9.Width = 150
	&NfsItmProCod.Visible = False
	&NfsItmProGraCod.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

EndEvent

Event Grid.Load

	&NfsItmProGraRef.SetEmpty()
	&ProCod = NfsItmProCod
	&ProGraCod = NfsItmProGraCod
	do 'GetReferencia'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UpdateUser = !'<i class="fas fa-pen"></i>'
	
	&DeleteUser = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		wpNFS(!'Itens', !'Totais', false, &SessionGuid)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		Do cAse
			CAse &NfsItmQtd.IsEmpty()
				msg('Informar a quantidade!')
				&NfsItmQtd.SetFocus()
			Case &ProRef.IsEmpty() or &NfsItmProCod.IsEmpty()
				msg('Informar Codigo do serviço!')
				&ProRef.SetFocus()
			Case &NfsItmProNom.IsEmpty()
				msg('Informar Codigo Descrição do Serviço!')
				&NfsItmProNom.SetFocus()	
				
			Case &NfsItmValUnt.IsEmpty()
				msg('Informar Valor do Serviço!')
				&NfsItmValUnt.SetFocus()		
			Otherwise
				Do 'SaveVariablesToWizardData'
				prcGravaItemNFSe.Call(&EmpCod, &NfsCod, &WizardData)
				Grid.Refresh()
				Do 'LimpaCampo'
				&ProRef.SetFocus()
		EndCase
	Endif

EndEvent

Event 'DoCapa'

	wpNFS(!'Itens', !'Capa', true, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDados'

	wpNFS(!'Itens', !'DadosNFSE', true, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoTotais'

	wpNFS(!'Itens', !'Totais', false, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoTransmitir'

	if &NfsSts <> Status_nFe.Autorizada and &NfsSts <> Status_Nfe.Cancelada 
		prcGravaTotaisNFs.Call(&EmpCod, &NfsCod, &WizardData)
		prcNotaServicoTransmitida.Call(&EmpCod, &NfsCod)
		GeraXmlNFSe.Call(&EmpCod, &NfsFiLCod, &NfsCod, 'S', &WwpContext.PesCod, &SolCod)
		
		&WizardData.Totais.SolCod = &SolCod
		&WebSession.Set(&WebSessionKey, &WizardData.ToJson())
		wpNFS(!'Totais', !'Transmitir', false, &SessionGuid)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&NfsItmProCod = &WizardData.Itens.NfsItmProCod
	&NfsItmProGraCod = &WizardData.Itens.NfsItmProGraCod
	&NfsItmValTot = &WizardData.Itens.NfsItmValTot
	&NfsItmEmbUnd = &WizardData.Itens.NfsItmEmbUnd
	&NfsItmValUnt = &WizardData.Itens.NfsItmValUnt
	&NfsItmQtd = &WizardData.Itens.NfsItmQtd
	&NfsItmProNom = &WizardData.Itens.NfsItmProNom
	&ProRef = &WizardData.Itens.ProRef
	&NfsItmCod = &WizardData.Itens.NfsItmCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&EmpCod = &WizardData.Capa.EmpCod
		&NfsCod = &WizardData.Capa.NfsCod
		
		if &NfsCod = 0
			wwNotasServico.Link()
		Else
			For Each Order EmpCod, NfsCod
				Where EmpCod = &EmpCod
				Where NfsCod = &NfsCod
				
				&NfsTipNF = NfsTipNF
				&NfsFilCod = NfsFilCod
				
				//				&NfsCNAE = NfsCNAE
				//				&NfsCnaeSer = NfsCnaeSer
				//				&NfsDisSer = NfsDisSer
				&NfsSts = NfsSts
				if &NfsSts = Status_nFe.Autorizada or &NfsSts = Status_Nfe.Cancelada 
					BtnTransmitir.Visible = 0
					btnEnter.Visible = 0
				Endif
				
				Exit
			EndFor
		
			RetornaTabelaFilial.Call(&EmpCod, &NfsFilCod, &FilTabCod)
		EndIf		
	
	Endif

EndSub

Sub 'SaveVariablesToWizardData'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Itens.NfsItmProCod = &NfsItmProCod
	&WizardData.Itens.NfsItmProGraCod = &NfsItmProGraCod
	&WizardData.Itens.NfsItmValTot = &NfsItmValTot
	&WizardData.Itens.NfsItmEmbUnd = &NfsItmEmbUnd
	&WizardData.Itens.NfsItmValUnt = &NfsItmValUnt
	&WizardData.Itens.NfsItmQtd = &NfsItmQtd
	&WizardData.Itens.NfsItmProNom = &NfsItmProNom
	&WizardData.Itens.ProRef = &ProRef
	&WizardData.Itens.NfsItmCod = &NfsItmCod
	&WizardData.Itens.Grid.Clear()
	For Each Line in Grid
		&GridItem = new()
		&GridItem.NfsItmProGraRef = &NfsItmProGraRef

		&WizardData.Itens.Grid.Add(&GridItem)
	EndFor
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&WizardData.Itens.NfsItmProCod = &NfsItmProCod
		&WizardData.Itens.NfsItmProGraCod = &NfsItmProGraCod
		&WizardData.Itens.NfsItmValTot = &NfsItmValTot
		&WizardData.Itens.NfsItmEmbUnd = &NfsItmEmbUnd
		&WizardData.Itens.NfsItmValUnt = &NfsItmValUnt
		&WizardData.Itens.NfsItmQtd = &NfsItmQtd
		&WizardData.Itens.NfsItmProNom = &NfsItmProNom
		&WizardData.Itens.ProRef = &ProRef
		&WizardData.Itens.NfsItmCod = &NfsItmCod
//		&WizardData.Itens.Grid.Clear()
//		For Each Line in Grid
//			&GridItem = new()
//			&GridItem.NfsItmProGraRef = &NfsItmProGraRef
//			
//			&WizardData.Itens.Grid.Add(&GridItem)
//		EndFor
		&WebSession.Set(&WebSessionKey, &WizardData.ToJson())
	Endif

EndSub

Event &ProRef.IsValid

	Do 'GetProduto'

EndEvent

Event &NfsItmQtd.IsValid

	Do 'TotalizaItem'

EndEvent

Event &NfsitmValUnt.IsValid

	Do 'TotalizaItem'

EndEvent

Event &DeleteUser.Click

	prcRemoveItem.Call(EmpCod, NfsCod, NfsItmCod)
	grid.Refresh()

EndEvent

Event &UpdateUser.Click

	&NfsItmProCod = NfsItmProCod
	&NfsItmProGraCod = NfsItmProGraCod
	&NfsItmValTot = NfsItmValTot
	&NfsItmEmbUnd = NfsItmEmbUnd
	&NfsItmValUnt = NfsItmValUnt
	&NfsItmQtd = NfsItmQtd
	&NfsItmProNom = NfsItmProNom
	&ProRef = &NfsItmProGraRef
	&NfsItmCod = NfsItmCod
	&ProRef.SetFocus()

EndEvent

Sub 'LimpaCampo'

	&NfsItmProCod.SetEmpty()
	&NfsItmProGraCod.SetEmpty()
	&NfsItmValTot.SetEmpty()
	&NfsItmEmbUnd.SetEmpty()
	&NfsItmValUnt.SetEmpty()
	&NfsItmQtd.SetEmpty()
	&NfsItmProNom.SetEmpty()
	&ProRef.SetEmpty()
	&NfsItmCod.SetEmpty()

EndSub

Sub 'TotalizaItem'

	&NfsItmValTot = &NfsItmQtd * &NfsItmValUnt

EndSub

Sub 'GetProduto'

	&NfsItmProCod.SetEmpty()
	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &NfsItmProCod, &NfsItmProGraCod, &NfsItmProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &NfsItmProCod
		WHere ProGraCod = &NfsItmProGraCod
		
		
		RetornaPrecoUnitarioVenda.Call(&EmpCod, &FilTabCod, '', &NfsItmProCod, &NfsItmProGraCod, 1, NfsDtaEms, &PedDtaVct, &NfsItmValUnt)
		Exit
	EndFor

	if &NfsItmQtd.IsEmpty()
		&NfsItmQtd = 1
	EndIf

EndSub

Sub 'GetReferencia'

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		&NfsItmProGraRef = ProGraRef
		Exit
	EndFor

EndSub


