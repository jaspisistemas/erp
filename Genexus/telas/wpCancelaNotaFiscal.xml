      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&xJust = 'NOTA EMITIDA COM DIVERGENCIA DE INFORMACOES, CANCELAMENTO SOLICITADO'
	loadWWPContext.Call(&Context)
	&tmpNfeEnvEml = true
	&tmpCancelarDuplicatas = False
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon179_MarcarCancelaFinanceiro, &TCon179_MarcarCancelaFinanceiro)
	TableFinanceiro.Visible = false
	&PermiteCancelarFinanceiro = RetornaAutorizacao.UDP('CANCELARFINANCEIROPELANFE', Status_SimNao.Nao, 1)	
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		&NfeCliRaz = trim(str(NfeCliCod)) + ' - ' + trim(NfeCliRaz)
		&NfeNum = NfeNum
		&NfeDtaEms = NfeDtaEms
		&FilCodNom = FilCodNom
		&NfeVlrTot = NfeVlrTot
		&NfeChv = NfeChv
		&NfeAutNumPro = NfeAutNumPro
		&NfePedCod =  NfePedCod
		
		
		if not NfeCliEml.IsEmpty()
			&PesEml  = NfeCliEml
		EndIF
		
		If NfeChv.IsEmpty()
			msg('NFe não possui a chave da NFe.')
		EndIF
		
		If &PermiteCancelarFinanceiro > 0
			//##################################### FINANCEIRO DA NFE ########################################
			
			&DinCreVlrDup = 0
			&DupCreVlrDup = 0
			&CarCreVlrDup = 0
			&CarDebVlrDup = 0
			&TotCreVlrDup = 0 
			
			&Totalpagas = 0
			//Carrega os valores por forma de pgto na NFE
			For each Order EmpCod, FilCod, NfeCod,NfeDupItmCod
				&TotCreVlrDup += NfeDupVlr
				Do Case
					Case NfeDupFrpPgtoTip = TipoDuplicata.DINHEIRO
						&DinCreVlrDup += NfeDupVlr
						
					Case NfeDupFrpPgtoTip = TipoDuplicata.CARTAOC
						&CarCreVlrDup += NfeDupVlr
						
					Case NfeDupFrpPgtoTip = TipoDuplicata.CARTAOD
						&CarDebVlrDup += NfeDupVlr
						
					otherwise			
						&DupCreVlrDup += NfeDupVlr
				EndCase
				
				if not NfeDupCreSeq.IsEmpty() and Not NfeDupCreSeq.IsNull()
					&NfePedTmpSts = Status_SimNao.Nao
					RetornaStatusDuplicata.call(EmpCod, NfeDupFiLCod, NfeDupCreSeq, &NfePedTmpSts)
					If &NfePedTmpSts = Status_SimNao.Sim //se a duplicata esta paga soma 1 qtde
						&Totalpagas+=1
					EndIF
					
				EndIf
				
			When none
				//Carrega os valores por forma de pgto nO PEDIDO caso não tenha na nfe
				Do 'BuscaDuplicatasdoPedido'
			EndFor
			
			If &TotCreVlrDup > 0 and &NfePedCod <> 0 //variavel somada em pedidoduplicata e notaduplicata
				TableFinanceiro.Visible = true
				
				If &Totalpagas > 0
					Pagamento.visible = true
					&PagamentoMensagem = 'ATENÇÃO! Existem ' +&Totalpagas.ToFormattedString()+' duplicata(s) paga(s), ao cancelar o financeiro TAMBÉM vai cancelar o pagamento.'
				else
					Pagamento.visible = false
				EndIf
				
				If &TCon179_MarcarCancelaFinanceiro = 'S'  // configuraçao padrão para ja trazer marcado ou não.
					&tmpCancelarDuplicatas = true
				Else
					&tmpCancelarDuplicatas = False
				EndiF
			EndIf
			//################################################################################################
		EndIf
		
		Exit
	EndFor
	
	obs.ForeColor = RGB(0,0,150)
	tbAvisoBoleto.Visible = &tmpCancelarDuplicatas

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbAvisoBoleto.Height = 40

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	if &DeOndeVem = 'WWNOTAS'
		wwNotas.Link()
	Else
		wwNotasNFCe.Link()
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	loadWWPContext.Call(&Context)
	&xJust = retiraCaracteresEspeciais.Udp(&xJust)
	Do 'Verifica_especial'
	
	Do Case
		Case &NfeChv.IsEmpty()
			msg('NFe não possui a chave da NFe, só pode cancelar uma Nota se a Mesma Estiver Autorizada!')
		Case &NfeAutNumPro.IsEmpty()
			msg('NFe não possui número do Protocolo, Consulte a Nota no SEFAZ!')
		Case &erro = 0
			GeraXmlCancelamento.Call(&EmpCod, &FilCod, &NfeCod, &xJust, &Context.PesCod, &tmpNfeEnvEml,&tmpCancelarDuplicatas, &SolCod)
			
			wpCancelaNotaFiscalRecepcao.Link(&DeOndeVEm, &EmpCod, &FilCod, &NfeCod, &xJust, &SolCod)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &tmpCancelarDuplicatas.ControlValueChanged

	tbAvisoBoleto.Visible = &tmpCancelarDuplicatas

EndEvent

Sub 'BuscaDuplicatasdoPedido'

	&TotCreVlrDup = 0
	if &NfePedCod <> 0
		For each Order EmpCod, FilCod, CrePedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CrePedCod = &NfePedCod
			
			&TotCreVlrDup += CreVlrDup
			Do Case
				Case CreFrpPgtoTip = TipoDuplicata.DINHEIRO
					&DinCreVlrDup += CreVlrDup
					
				Case CreFrpPgtoTip = TipoDuplicata.CARTAOC
					&CarCreVlrDup += CreVlrDup
					
				Case CreFrpPgtoTip = TipoDuplicata.CARTAOD
					&CarDebVlrDup += CreVlrDup
					
				otherwise			
					&DupCreVlrDup += CreVlrDup
			EndCase
			
			&NfePedTmpSts = Status_SimNao.Nao
			
			if CreVlrDup <> CreVlrSdo
				&NfePedTmpSts = Status_SimNao.Sim
			EndIf
			
			If &NfePedTmpSts = Status_SimNao.Sim //se a duplicata esta paga soma 1 qtde
				&Totalpagas+=1
			EndIF
			
		EndFor
	Endif

EndSub

Sub 'Verifica_especial'

    &erro = 0 
    &Tamanho = len(&xJust)
    if &tamanho < 15 or &tamanho > 255
        msg('Tamanho da justificativa tem que ficar entre 15 e 255')
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&xJust,&Posicao,1) < ' '  or (substr(&xJust,&Posicao,1) > 'z'  ))
                msg('Caracter especial '+  substr(&xJust,&Posicao,1) + 'Não é permitido' ) 
                &erro = 1
            Endif
        EndFor
    EndIf

EndSub


