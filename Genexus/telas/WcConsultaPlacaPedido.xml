      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TbTotal.Width = 500
	Cell_GridPedidosPlaca_DWC.Class = !'Invisible WCD_' + upper(GridPedidosPlaca.InternalName)
	GridPedidosPlaca.Rows = Page.Rows
	&GridPedidosPlacaCurrentPage = 1
	&GridPedidosPlacaCurrentPage.Visible = False
	&GridPedidosPlacaPageCount = -1
	GridPedidosPlacaPaginationBar.RowsPerPageSelectedValue = GridPedidosPlaca.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPedidosPlacaPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPedidosPlacaCurrentPage	= GridPedidosPlaca.CurrentPage
	&GridPedidosPlacaPageCount		= GridPedidosPlaca.PageCount

EndEvent

Event GridPedidosPlaca.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'
	
	&ImprimirPedido = !'<i class="far fa-file-pdf"></i>'

	&PedNovCliRaz = iif(PedCliCodRaz_Nov.Length() > 30, Substr(PedCliCodRaz_Nov,1,30)+'...', PedCliCodRaz_Nov)
	&AuxFin = UPPER(Substr(PedStsFin.EnumerationDescription(), 1,3))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PedTotVlrLiq 	+= PedVlrLiq
	&AuxEmpCod 		= EmpCod
	&AuxFilCod		= FilCod
	&AuxPedCod		= PedCod
	Do 'VerificaQtdItens'
	
	If &TotPedItmCod >= 1
		&DetailWebComponent.Visible = 1
	Else
		&DetailWebComponent.Visible = 0
	EndIf

	Do Case
		Case PedStsFin = Status_Financeiro.CANCELADO
			&AuxFin.ForeColor = RGB(255, 132, 0)
		Case PedStsFin = Status_Financeiro.ABERTO
			if PedStsFinIsPar = true
				&AuxFin.ForeColor = RGB(205, 100, 0)
			Else
				&AuxFin.ForeColor = RGB(0, 100, 200)
			Endif
			
		Otherwise
			&AuxFin.ForeColor = RGB(0, 0, 0)
	EndCase

EndEvent

Event GridPedidosPlacaPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPedidosPlacaPaginationBar.SelectedPage = !'Previous'
			&GridPedidosPlacaCurrentPage -= 1
			GridPedidosPlaca.PreviousPage()
		Case GridPedidosPlacaPaginationBar.SelectedPage = !'Next'
			&GridPedidosPlacaCurrentPage += 1
			GridPedidosPlaca.NextPage()
		Otherwise
			&PageToGo.FromString(GridPedidosPlacaPaginationBar.SelectedPage)
			&GridPedidosPlacaCurrentPage = &PageToGo
			GridPedidosPlaca.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPedidosPlacaPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPedidosPlaca.Rows = GridPedidosPlacaPaginationBar.RowsPerPageSelectedValue
	&GridPedidosPlacaCurrentPage = 1
	GridPedidosPlaca.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DetailWebComponent.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPedidosPlaca_DWC.Object = WcConsultaPlacaPedidoItem.Create(EmpCod, FilCod, PedCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ImprimirPedido.Click

	wpImprimirPedidoVenda.Popup(EmpCod, FilCod, PedCod)

EndEvent

Sub 'VerificaQtdItens'

	&TotPedItmCod	= 0
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where EmpCod = &AuxEmpCod
		Where FilCod = &AuxFilCod
		Where PedCod = &AuxPedCod
		
		&TotPedItmCod += 1
		
	EndFor

EndSub


]]></Source>
