      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWDECLARACAOEXPORTACAO', Status_SimNao.Sim, 2, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&DecDta = serverdate()
	do 'loadOld'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grideleme.Rows = 1000
	GridNcm.Rows = 1000

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Produtos.Visible = 0
	&IsGerar.Enabled = 1

EndEvent

Event Grideleme.Load

	for &sdtElementoItem in &sdtElemento
		
		&DecNcmCod = &sdtElementoItem.DecNcmCod
		&DecNcmDes = &sdtElementoItem.DecNcmDes
		&DecNcmVlr = &sdtElementoItem.DecNcmVlr

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
	EndFOr

EndEvent

Event GridNcm.Load

	For &sdtNcmItem in &sdtNcm
		&IsGerar = &sdtNcmItem.IsSelect
		&NcmCod = &sdtNcmItem.NcmCod
		&QtdProdutos = &sdtNcmItem.NcmQtd
		&PrcProCod =  &sdtNcmItem.PrcProCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load
	EndFor

EndEvent

Event 'Dofcancelar'

	wwDeclaracaoExportacao.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCarregaNCMs'

	do 'Pedido'
	Produtos.Visible = 1
	gridncm.Refresh()

EndEvent

Event &DecFunCod.IsValid

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &DecFunCod
		&DecFunRaz = PesRaz
	When none
		&DecFunRaz = ''
	EndFor

EndEvent

Event &DecPedCod.IsValid

	if &OldDecPedCod <> &DecPedCod
		do 'Pedido'
		Produtos.Visible = 1
		gridncm.Refresh()
	EndIF
	
	&OldDecPedCod = &DecPedCod

EndEvent

Event Enter

	&sdtNcm.Clear()
	For Each line in gridNcm
		&sdtNcmItem = new()
		&sdtNcmItem.IsSelect = &IsGerar
		&sdtNcmItem.NcmCod = &NcmCod
		&sdtNcmItem.PrcProCod = &PrcProCod
		&sdtNcmItem.NcmQtd = &QtdProdutos
		&sdtNcm.Add(&sdtNcmItem)
	EndFor

	&sdtElemento.Clear()
	For Each line in grideleme
		&sdtElementoItem = new()
		&sdtElementoItem.DecNcmCod = &DecNcmCod
		&sdtElementoItem.DecNcmDes = &DecNcmDes
		&sdtElementoItem.DecNcmVlr = &DecNcmVlr
		&sdtElemento.Add(&sdtElementoItem)
	EndFor


	For &sdtNcmItem in &sdtNcm
		If &sdtNcmItem.IsSelect = true
			&IsUmSelecionado = true
			Exit
		EndIF
	
	EndFOr
	
	if &IsUmSelecionado = true
		Do Case
			Case &DecDta.IsEmpty()
				msg('Informe uma Data para emissão')
				&DecDta.SetFocus()
			Case &DecFunCod.IsEmpty()
				msg('Informe um Responsável')
				&DecFunCod.SetFocus()
			Otherwise
				GravaDeclaracoes.Call(&EmpCod, &FilCod, &DecDta, &DecFilCod, &DecFunCod, &DecPedCod, &DecDolMin, &DecDolMax, &sdtNcm, &DecProcProd, &sdtElemento)
				wwDeclaracaoExportacao.Link()
		EndCase
	
	Else
		msg('Selecione ao menos um Grupo de NCMs')
	EndIF

EndEvent

Sub 'loadOld'

	&sdtElemento.Clear()
	For Each Order EmpCod, (DecCod)
		Where EmpCod = &EmpCod
		&DecFilCod = DecFilCod
		&DecDolMax = DecDolMax
		&DecDolMin = DecDolMin
		&DecFunCod = DecFunCod
		&DecFunRaz = DecFunRaz
		&DecProcProd = DecProcProd
		
		For Each Order EmpCod, DecCod, DecNcmItmCod
			&sdtElementoItem = new()
			&sdtElementoItem.DecNcmCod = DecNcmCod
			&sdtElementoItem.DecNcmDes = DecNcmDes
			&sdtElementoItem.DecNcmVlr = DecNcmVlr
			&sdtElemento.Add(&sdtElementoItem)
		EndFor
	
		Exit
	EndFor
	
	for &Count = 1 to 10
		&sdtElementoItem = new()
		&sdtElementoItem.DecNcmCod = 0
		&sdtElementoItem.DecNcmDes = ''
		&sdtElementoItem.DecNcmVlr = 0
		&sdtElemento.Add(&sdtElementoItem)
	EndFor

EndSub

Sub 'Pedido'

	&sdtNcm.Clear()
	For Each Order EmpCod, FilCod, PedCod, NcmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &DecPedCod
			
		&IsNCM = false
		For &sdtNcmItem in &sdtNcm
			if &sdtNcmItem.NcmCod = NcmCod and &sdtNcmItem.PrcProCod = PrcProCod
				&IsNCM = true
				&sdtNcmItem.NcmQtd += 1
				Exit
			EndIF		
		EndFor
		if &IsNCM = false
			&sdtNcmItem = new()
			&sdtNcmItem.IsSelect = true
			&sdtNcmItem.NcmCod = NcmCod
			&sdtNcmItem.PrcProCod = PrcProCod
			&sdtNcmItem.NcmQtd = 1
			&sdtNcm.Add(&sdtNcmItem)
		EndIf
	EndFor

EndSub


]]></Source>
