      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Descricao = Status_SimNao.Sim
	&Estoque = Status_SimNao.Sim
	&Media = Status_SimNao.Sim
	&CurvaRentabilidade = Status_SimNao.Sim
	&TotalIncidente = Status_SimNao.Sim		
	&Markup = Status_SimNao.Sim
	
	&CustoIndireto = Status_SimNao.nao
	&CurvaQuantidade = Status_SimNao.nao
	&DespesasVenda = Status_SimNao.nao		
	&DespesaAdministrativa = Status_SimNao.nao
	&DespesaFinanceira = Status_SimNao.nao		
	

	LoadWWPContext.Call(&Context)
	PadraoUsuario.call('L', 'WPSELECCOLUMOPLANI', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		if &PadObs.Substring(1,1) <> 'S'
			&Descricao = Status_SimNao.nao
		EndIF	
		if &PadObs.Substring(2,1) <> 'S'
			&Estoque = Status_SimNao.nao
		EndIf
		if &PadObs.Substring(3,1) <> 'S'
			&Media = Status_SimNao.Nao
		EndIf
		if &PadObs.Substring(4,1) = 'S'
			&CustoIndireto = Status_SimNao.Sim
		EndIf
		if &PadObs.Substring(5,1) <> 'S'
			&CurvaRentabilidade = Status_SimNao.Nao
		EndIf
		if &PadObs.Substring(6,1) = 'S'
			&CurvaQuantidade = Status_SimNao.Sim
		EndIf
		if &PadObs.Substring(7,1) = 'S'
			 &DespesasVenda = Status_SimNao.Sim
		EndIf
		if &PadObs.Substring(8,1) = 'S'
			 &DespesaAdministrativa = Status_SimNao.Sim
		EndIf
		if &PadObs.Substring(9,1) = 'S'
			 &DespesaFinanceira = Status_SimNao.Sim
		EndIf
		if &PadObs.Substring(10,1) <> 'S'
			 &TotalIncidente = Status_SimNao.Nao
		EndIf
		if &PadObs.Substring(11,1) <> 'S'
			 &Markup = Status_SimNao.Nao
		EndIf
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableAttributes.Width = 500

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDefault'

	PadraoUsuario.call('G', 'WPSELECCOLUMOPLANI', &Context.PesCod, &Context.EmpCod, '', &PadDtaMod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PadObs = ''
	if &Descricao = Status_SimNao.Sim
		&PadObs = 'S'
	Else
		&PadObs = 'N'
	EndIF	
	if &Estoque = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF	
	if &Media = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF
	if &CustoIndireto = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF	
	if &CurvaRentabilidade = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF	
	if &CurvaQuantidade = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF	
	if &DespesasVenda = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF

	if &DespesaAdministrativa = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF	
	if &DespesaFinanceira = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF
	if &TotalIncidente = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF
	if &Markup = Status_SimNao.Sim
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF

	PadraoUsuario.call('G', 'WPSELECCOLUMOPLANI', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

EndEvent


]]></Source>
