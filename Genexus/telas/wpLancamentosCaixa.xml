Sub 'LoadGridState'

if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"CXITMTIP"
				&CxItmTip.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"CXPDVCOD"
				&CxPdvCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"CXCOD"
				&CxCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"CXITMCMP"
				&CxItmCmp.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"CXITMVLR"
				&CxItmVlr.FromString(&GridStateFilterValue.Value)
				&CxItmVlrOperator = &GridStateFilterValue.Operator
			Case &GridStateFilterValue.Name = !"CXITMVLREXT"
				&CxItmVlrExt.FromString(&GridStateFilterValue.Value)
				&CxItmVlrExtOperator = &GridStateFilterValue.Operator
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Endif

EndSub

Sub 'SaveGridState'

if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"CXITMTIP", "", not &CxItmTip.IsEmpty(), 0, &CxItmTip, '')
	WWP_GridStateAddFilterValue(&GridState, !"CXPDVCOD", "", not &CxPdvCod.IsEmpty(), 0, &CxPdvCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"CXCOD", "", not &CxCod.IsEmpty(), 0, &CxCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"CXITMCMP", "", not &CxItmCmp.IsEmpty(), 0, &CxItmCmp, '')
	WWP_GridStateAddFilterValue(&GridState, !"CXITMVLR", "", not &CxItmVlr.IsEmpty(), &CxItmVlrOperator, &CxItmVlr.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"CXITMVLREXT", "", not &CxItmVlrExt.IsEmpty(), &CxItmVlrExtOperator, &CxItmVlrExt.ToString().Trim(), '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Endif

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"CAIXA"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'dadosCAixa'

	For Each Order EmpCod, PdvCod
		Where EmpCod = &EmpCod
		Where PdvCod = &CxPdvCod
		TextBlockTitle.Caption = PdvId.Trim()
		Exit
	EndFor

EndSub


