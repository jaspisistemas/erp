      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&SdtPagamentoDuplicata.FromJson(&webSession.Get(&Randam))
	&webSession.Remove(&Randam)		
	If &SdtPagamentoDuplicata.Count.IsEmpty()
		return
	Else
		padraoUsuario.Call('L', 'HAVERSERLECIONADO_CTR', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		&sdtPagamentoDuplicataHAVER.FromJson(&PadObs)	
		padraoUsuario.Call('G', 'HAVERSERLECIONADO_CTR', &Context.PesCod, &Context.EmpCod, '', &PadDtaMod)
		
		padraoUsuario.Call('L', 'CONTAHAVERSERLECIONADO_CTR', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		&HaverCtabanCod = val(&PadObs)
	EndIf
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&GeraRecibo = Substr(&PadObs, 1, 1)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 500

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PadObs = &GeraRecibo
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	//GRAVA FINANCEIRO	
	GravaFinanceiroDuplicata.Call(&Context.EmpCod, &CtabanCod, &Hoje,&MovDtaCon,&MovTip,&MovCplMan,&RcbCreVlrTot,&IsDescontada,&SdtPagamentoDuplicata,&RcbTip, &outMovCod)
	&TotalCreditoMoeda = 0
	if &sdtPagamentoDuplicataHAVER.Count > 0
		For &sdtPagamentoDuplicataHAVERitem in &sdtPagamentoDuplicataHAVER
			&TotalCreditoMoeda += &sdtPagamentoDuplicataHAVERitem.CreVlrPgt
		EndFor
		if &TotalCreditoMoeda > 0
			GravaFinanceiroDuplicata.Call(&Context.EmpCod, &HaverCtabanCod, &Hoje,&MovDtaCon,TipoMovimento.DevolucaoCredito,&MovCplMan,&TotalCreditoMoeda,false,&SdtPagamentoDuplicataHAVER,TipoRecibo.Pagar, &HaveroutMovCod)
		Endif
	EndIf
	
	if &GeraRecibo = '1' or &GeraRecibo = '2'
		wpImpressaoRecibo.Link('', &GeraRecibo, &Randam, &Context.EmpCod, &Context.FilCod, &outMovCod, 0)
	Else
		Return
	Endif

EndEvent


]]></Source>
