Sub 'montaComboCaixa'

	For each Order EmpCod,CtaBanSts
		Where EmpCod = &Context.EmpCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO
		
		&auxCtaBanCod = CtabanCod
		If &Context.PesCod > 0
			Do 'ValidaPermisaoConta'
		Else
			&IsAutorizado = True
		EndIf
		
		If &IsAutorizado = True
			&CtabanCod.AddItem(CtabanCod, CtaBanCodNom)
		EndIf
		
	EndFor

EndSub

Sub 'ValidaPermisaoConta'

	&IsAutorizado = False
	For each Order EmpCod,CtabanCod
		Where EmpCod = &Context.EmpCod
		Where CtabanCod = &auxCtaBanCod
		Where CtaFunCod = &Context.PesCod
		Where CtaFunIsCx  <> Status_SimNao.Nao
		&IsAutorizado = True
		exit
	EndFor

EndSub

Sub 'LoadResumo'

	&ResFecCod.Clear()
	&count = 0
	&ResFecCod.AddItem(0,'Caixa Aberto')
	For each Order EmpCod,CtabanCod,FecSts,(FecCod) //pega o ultimo fechamento da conta
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		Where FecDta = &DataSaldo
		Where FecSts = FechaAbre.FecharNOVO
		
		&FecCod = FecCod + 1
		&IsAberto = RetornaProximoFechamentoAberto.Udp(EmpCod, CtabanCod, &FecCod)
	
		&Mensagem = 'Ult.Fec. '+TtoC(FecHor,8,8)
		if &IsAberto = true
			&Mensagem += ' - REABERTO'
		Endif
		&ResFecCod.AddItem(FecCod,&Mensagem)   
	When none
		For each Order EmpCod,CtabanCod,FecSts,(FecCod) //pega o ultimo fechamento da conta
			Where EmpCod = &EmpCod
			Where CtabanCod = &CtaBanCod
			Where FecDta <= &DataSaldo
			Where FecSts = FechaAbre.FecharNOVO	
			
			&FecCod = FecCod + 1
			&IsAberto = RetornaProximoFechamentoAberto.Udp(EmpCod, CtabanCod, &FecCod)
		
			&Mensagem = 'Ult.Fec. '+TtoC(FecHor,8,8)
			if &IsAberto = true
				&Mensagem += ' - REABERTO'
			Endif
			&ResFecCod.AddItem(FecCod,&Mensagem)   
			Exit			
		EndFor
	EndFor

EndSub

