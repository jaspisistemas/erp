        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('PDVM_CAIXA', Status_SimNao.Nao, 2, &AutNiv)
	if &AutNiv < 1
		retornaAutorizacao.Call('WPCAIXA', Status_SimNao.Sim, 2, &AutNiv)
	Endif

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesRaz = &Context.PesRaz

	do 'montaComboCaixa'
	&CtaBanCod = &Context.CtaBanCod	
	
	&DataSaldo = serverdate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbSa.Width = 250
	tbDe.Width = 250
	tbCre.Width = 250
	tbAn.Width = 250
	tbbutto.Width = 350
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 10
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	btnNovaVEnda.SetFocus()

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesRaz = &Context.PesRaz
	
	Do 'LoadResumo'
	do 'loadSaldo'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&Eliminar.ColumnHeaderClass = !'WWIconActionColumn'
	&ActionUpdat.ColumnHeaderClass = !'WWIconActionColumn'
	MovCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	MovDtaCon.ColumnHeaderClass = !'WWColumn'
	MovTip.ColumnHeaderClass = !'WWColumn'
	MovCplTot.ColumnHeaderClass = !'WWColumn'
	MovDoc.ColumnHeaderClass = !'WWColumn hidden-xs'
	MovVlr.ColumnHeaderClass = !'WWColumn hidden-xs'
	&Imprimir.ColumnHeaderClass = !'WWIconActionColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Eliminar = !'<i class="fas fa-times"></i>'
	If (MovSts.IsEmpty() or MovSts.IsNull() or MovSts <> Status_Caixa.Cancelado)
		&Eliminar.Class = !'Attribute'
	Else
		&Eliminar.Class = !'Invisible'
	Endif
	&ActionUpdat = !'<i class="fas fa-pen"></i>'
	
	&Imprimir = !'<i class="far fa-file-pdf"></i>'

	&Eliminar.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWIconActionColumn WWColumnLineThrough WWColumnLineThroughFirstColumn', !'WWIconActionColumn')
	&ActionUpdat.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWIconActionColumn WWColumnLineThrough', !'WWIconActionColumn')
	MovCod.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	MovDtaCon.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	MovTip.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	MovCplTot.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	MovDoc.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	MovVlr.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	&Imprimir.ColumnClass = iif(MovSts = Status_Caixa.CANCELADO, !'WWIconActionColumn WWColumnLineThrough', !'WWIconActionColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If MovCreDeb = 'C'
		MovVlr.ForeColor = RGB(0,0,255)
	Else
		MovVlr.ForeColor = RGB(255,0,0)
	EndIf

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovaVEnda'

 2
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon086_SolicitarClientePDV, &TCon086_SolicitarClientePDV)
	if &TCon086_SolicitarClientePDV = 'S'
