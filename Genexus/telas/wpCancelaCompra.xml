      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProcessando.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableAttributes.Height = 250

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadPedido'

EndEvent

Event 'DoConfirmarCancelamento'

	do 'loadPedido'
	If &IsPodeEliminar = true
		tbConfirmar.Visible = 0
		tbProcessando.Visible = 1
		
		&ProgressId = trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&PedCod)) + 'CANCELA'
		apagaProgress.Call(&ProgressId)
		scaProgressBar.ProcessId = &ProgressId
		scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar.Start()
		
		AtualizaEstoqueGerencialCompra_submit.Submit(&ProgressId, &ProgressId, 0,0, &EmpCod, &FilCod, &PedCod, &PedDtaFat, &Context.PesCod,  Status_Pedido.CANCELADO, false)
		
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ScaProgressBar.OnComplete

	wwpActions.WCPopup_Close('')

EndEvent

Sub 'loadPedido'

	&IsPodeEliminar = true
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		If PedSts = Status_Pedido.CANCELADO
			wwpActions.WCPopup_Close('')
		EndIF
		
		If PedStsFin = Status_Pedido.FECHADO or PedStsFinIsPar = true
			Msg('Pedido não pode ser Cancelado, Possui parte Financeira!')
			&IsPodeEliminar = false
		EndIf
		
		If PedSts <> Status_Pedido.ABERTO
			Msg('Pedido não pode ser Cancelado, É preciso abrir o Estoque do pedido!')
			&IsPodeEliminar = false
		EndIf
	
		&FilCodNom = FilCodNom
		&PedCliRaz = PedCliRaz
		Exit
	When none
		&IsPodeEliminar = false
	EndFor

EndSub


]]></Source>
