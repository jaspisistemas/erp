      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPMALADIRETA', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	
	&EmpCod = &Context.EmpCod
	
	&iniPesUltVenDta = serverdate()
	&finPesUltVenDta = &iniPesUltVenDta 
	&PesDtaCad = &iniPesUltVenDta
	&PesIsCli = true
	
	&EliminarSelecionados = Status_SimNao.Nao
	
	&MalTabCod = retornaTabelaFilial.Udp(&EmpCod, &Context.FilCod)
	&NewMalTabCod = &MalTabCod
	
	
	padraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&EliminarSelecionados.FromString(Substr(&PadObs,1,1))
	&SomenteNaoCompraram = Substr(&PadObs, 2,1)
	&OqueFazer = Substr(&PadObs, 3,5)

	if &SomenteNaoCompraram.IsEmpty()
		&SomenteNaoCompraram = 'S'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&MalTabCod.TooltipText = "Será Impresso a Tabela de Preço Selecionada."
	&NewMalTabCod.TooltipText = "Os Clientes serão Adicionados à Tabela informada."
	&PesCliTabCod.TooltipText = "Filtrar Clientes que ainda não possuem a tabela Informada, ou deixe em Branco para Geral."
	&PesDtaCad.TooltipText = "Localizar Clientes apartir de uma Data. Data Vazia Todas as Datas."

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	GridImpressao_Empowerer.GridInternalName = GridImpressao.InternalName
	GridImpressao.Rows = Page.Rows
	&GridImpressaoCurrentPage = 1
	&GridImpressaoCurrentPage.Visible = False
	&GridImpressaoPageCount = -1
	GridImpressaoPaginationBar.RowsPerPageSelectedValue = GridImpressao.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridImpressaoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod
	
	&GridImpressaoCurrentPage = GridImpressao.CurrentPage
	&GridImpressaoRecordCount = GridImpressao.RecordCount
	&GridImpressaoPageCount = gridimpressao.PageCount

EndEvent

Event GridImpressao.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Remover.FromImage(ActionDelete)
	&Remover.TooltipText = "Eliminar Registro"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = MalPesCod
		&gridPesCidNom = PesCidNom
		&gridPesCidUfeCod = PesCidUfeCod
		&gridPesCodRaz = PesCodRaz
		&gridPesDtaCad = PesDtaCad
		&gridPesUltVenDta = PesUltVenDta
		
		Exit
	EndFor

EndEvent

Event GridImpressaoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridImpressaoPaginationBar.SelectedPage = !'Previous'
			&GridImpressaoCurrentPage -= 1
			GridImpressao.PreviousPage()
		Case GridImpressaoPaginationBar.SelectedPage = !'Next'
			&GridImpressaoCurrentPage += 1
			GridImpressao.NextPage()
		Otherwise
			&PageToGo.FromString(GridImpressaoPaginationBar.SelectedPage)
			&GridImpressaoCurrentPage = &PageToGo
			GridImpressao.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridImpressaoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridImpressao.Rows = GridImpressaoPaginationBar.RowsPerPageSelectedValue
	&GridImpressaoCurrentPage = 1
	GridImpressao.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirEtiqueta'

	&PadObs = &EliminarSelecionados.tostring() + &SomenteNaoCompraram + &OqueFazer
	padraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	//Imprimir Etiqueta e Gravar Tabela nos Clientes:A, 
	//Somente Imprimir Etiqueta:B, 
	//Somente Gravar Tabela nos Clientes:C
	if &MalTabCod.IsEmpty() or &MalTabCod = '0'
		msg('Informe a Tabela de Preço que será Enviada!')
	Else
		If &OqueFazer = 'A' or &OqueFazer = 'C'
			GravaTabelaClientes.Call(&EmpCod, &MalTabCod)
		EndIF
		
		if &OqueFazer = 'A' or &OqueFazer = 'B'
			//retornaConfiguracoesPastas.Call(&Context.EmpCod, &Context.FilCod, &sdtConfiguracoesPasta)
			
			&Random = (Random() * 10000000)
			&CaminhoFisico = 'EtiqMalaDireta' + trim(&MalTabCod) + trim(str(&Random)) + '.pdf'
			//&CaminhoVirtual = &sdtConfiguracoesPasta.PastaDiretorioTempVir + 'EtiqMalaDireta' + trim(&MalTabCod) + trim(str(&Random)) + '.pdf'
			
			&File.source = &CaminhoFisico
			If &File.Exists()
				&File.Delete()
			EndIF
						
			//AlteraPDFReport.Call('E')
			//RELJAS046.call(&EmpCod, &MalTabCod, &CaminhoFisico)
			//AlteraPDFReport.Submit('AlteraPDFReport', '')
			
			//RCOOPenWindow1.LinkOpen = Link(&CaminhoVirtual)
			//RCOOPenWindow1.LinkOpen = RELJAS046.Link(&EmpCod, &MalTabCod, &CaminhoFisico)
			//RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			&Window.Url = RELJAS046.Link(&EmpCod, &MalTabCod, &CaminhoFisico)
			&window.Open()
		EndiF
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdicionarClientes'

 9

	&PadObs = &EliminarSelecionados.tostring() + &SomenteNaoCompraram + &OqueFazer
	padraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	If &NewMalTabCod <> '0' and not &NewMalTabCod.IsEmpty()
		GravarClientesMalaDireta.Call(&EmpCod, &PesCod, &PesDtaCad, &iniPesUltVenDta, &finPesUltVenDta, &ExcPesCidUfeCod, &SomenteNaoCompraram, &NewMalTabCod, &PesIsCli, &PesCidUfeCod, &ExcPesCidUfeCod, &RatCod, &EliminarSelecionados, &PesCliTabCod)
		gridImpressao.Refresh()
		&PesCod.SetFocus()
	Else
		msg('Informe a Tabela de Preço que será Enviada para os Clientes')
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&SomenteNaoCompraram = 'S' or &SomenteNaoCompraram = 'C')
		&iniPesUltVenDta.Visible = False
		iniPesUltVenDta_Cell.Class = !'Invisible'
		TextBlockiniPesUltVenDta_Cell.Class = !'Invisible'
	Else
		&iniPesUltVenDta.Visible = True
		iniPesUltVenDta_Cell.Class = !'MergeDataCell'
		TextBlockiniPesUltVenDta_Cell.Class = !'col-sm-3 MergeLabelCell'
	EndIf
	If Not (&SomenteNaoCompraram = 'S' or &SomenteNaoCompraram = 'C')
		&finPesUltVenDta.Visible = False
		finPesUltVenDta_Cell.Class = !'Invisible'
	Else
		&finPesUltVenDta.Visible = True
		finPesUltVenDta_Cell.Class = !'DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &MalTabCod.IsValid

	&NewMalTabCod = &MalTabCod
	
	gridImpressao.Refresh()

EndEvent

Event &NewMalTabCod.IsValid

	&MalTabCod = &NewMalTabCod

EndEvent

Event &SomenteNaoCompraram.IsValid

Do 'AttributesSecurityCode'

EndEvent

Event &Remover.Click

	RemoveRegistroMalaDireta.Call(EmpCod, MalPesCod, MalTabCod)
	gridImpressao.Refresh()

EndEvent


]]></Source>
