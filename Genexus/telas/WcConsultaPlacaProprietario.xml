      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridHistoricoProprietario.Rows = Page.Rows
	&GridHistoricoProprietarioCurrentPage = 1
	&GridHistoricoProprietarioCurrentPage.Visible = False
	&GridHistoricoProprietarioPageCount = -1
	GridHistoricoProprietarioPaginationBar.RowsPerPageSelectedValue = GridHistoricoProprietario.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridHistoricoProprietarioPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridHistoricoProprietarioCurrentPage	= GridHistoricoProprietario.CurrentPage
	&GridHistoricoProprietarioPageCount		= GridHistoricoProprietario.PageCount

EndEvent

Event GridHistoricoProprietario.Load

	&AuxEmpCod = EmpCod
	&AuxPesCod = PesCod
	&AuxVeiCod = VeiCod
	
	Do 'LoadInformacoes'
	
	If VeiSts = Status_SimNao.Sim
		&GridAtualAntigo 			= 'ATUAL'
		&GridAtualAntigo.ForeColor 	= RGB(34,139,34)
		&GridAtualAntigo.FontBold	= True
	Else
		&GridAtualAntigo			= 'ANTIGO'
		&GridAtualAntigo.ForeColor	= RGB(255,0,0)
		&GridAtualAntigo.FontBold	= True
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridHistoricoProprietarioPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridHistoricoProprietarioPaginationBar.SelectedPage = !'Previous'
			&GridHistoricoProprietarioCurrentPage -= 1
			GridHistoricoProprietario.PreviousPage()
		Case GridHistoricoProprietarioPaginationBar.SelectedPage = !'Next'
			&GridHistoricoProprietarioCurrentPage += 1
			GridHistoricoProprietario.NextPage()
		Otherwise
			&PageToGo.FromString(GridHistoricoProprietarioPaginationBar.SelectedPage)
			&GridHistoricoProprietarioCurrentPage = &PageToGo
			GridHistoricoProprietario.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridHistoricoProprietarioPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridHistoricoProprietario.Rows = GridHistoricoProprietarioPaginationBar.RowsPerPageSelectedValue
	&GridHistoricoProprietarioCurrentPage = 1
	GridHistoricoProprietario.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadInformacoes'

	&GridPesRaz.SetEmpty()
	&GridPesCPFCNPJ.SetEmpty()
	&GridPesFonNum.SetEmpty()
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &AuxEmpCod
		Where PesCod = &AuxPesCod
		
		If PesRaz.IsEmpty()
			&GridPesRaz = 'N/A'
		Else
			&GridPesRaz	= PesRaz
		EndIf
		
		If PesCpf.IsEmpty()
			&GridPesCPFCNPJ = PesCnpj
		Else
			&GridPesCPFCNPJ = PesCpf
		EndIf
		
		If &GridPesCPFCNPJ.IsEmpty()
			&GridPesCPFCNPJ = 'N/A'
		EndIf
		
		If PesFonNum.IsEmpty()
			&GridPesFonNum = 'N/A'
		Else
			&GridPesFonNum = PesFonNum
		EndIf
		
		Exit
	EndFor

	For Each Order EmpCod, VeiCod
		Where EmpCod = &AuxEmpCod
		Where VeiCod = &AuxVeiCod
		
		&GridVeiPla = VeiPla
		
		Exit
	EndFor

EndSub


]]></Source>
