      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TipSerItmCod.Visible = False
	&TipSerEmpIsUse.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'carregaCombos'
	do 'carregaTiposServico'
	do 'validaNBS'

EndEvent

Event Enter

	do 'validaNBS'
	
	if not &TipSerNbsPad.IsEmpty() and &IsErroNCM = true
		msg('NBS informado inválido!')
		&TipSerNbsPad.SetFocus()
	Else
		prcGravaTaxasTiposServico.Call(&TipSerCod, &EmpCod,&TipSerFilCod, &TipSerLctCod,&TipSerIssqnRet,&TipSerIssqnTax,&TipSerPisCofCst,&TipSerPisTax,&TipSerCofTax,&TipSerPisCofRet,&TipSerCpTax,&TipSerIrrfTax,&TipSerCsllTax, &TipSerPerFed,&TipSerPerEst,&TipSerPerMun, &TipSerNbsPad)
		wcativarinativarservico.Link(&TipSerCod)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wcativarinativarservico.Link(&TipSerCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &TipSerNbsPad.ControlValueChanged

	do 'validaNBS'

EndEvent

Sub 'validaNBS'

	ValidaNcm.Call(&TipSerNbsPad, &NcmDes, &IsErroNCM)

EndSub

Sub 'carregaTiposServico'

	&TipSerPisCofCst = PisCofinsServico.CST00
	&TipSerPisCofRet = TipoRetencaoPisCofins.PisCofinsNaoRetido
	&TipSerIssqnRet = TipoRetencaoIssqn.NaoRetido
	
	For Each Order TipSerCod
		Where TipSerCod = &TipSerCod		
		
		&TipSerNom = TipSerNom
		
		For Each Order TipSerCod, TipSerItmCod
			Where TipSerItmCod = &TipSerItmCod
			
			&TipSerFilCod = TipSerFilCod
			&TipSerLctCod = TipSerLctCod
		
			
			&TipSerIssqnRet = TipSerIssqnRet
			&TipSerIssqnTax = TipSerIssqnTax
			
			&TipSerPisCofCst = TipSerPisCofCst
			&TipSerPisTax = TipSerPisTax
			&TipSerCofTax = TipSerCofTax
			&TipSerPisCofRet = TipSerPisCofRet
			
			&TipSerCpTax = TipSerCpTax
			&TipSerIrrfTax = TipSerIrrfTax
			&TipSerCsllTax = TipSerCsllTax
			
			&TipSerPerFed = TipSerPerFed
			&TipSerPerEst = TipSerPerEst
			&TipSerPerMun = TipSerPerMun
			
			&TipSerNbsPad = TipSerNbsPad
			
			Exit			
		EndFor
		
		Exit
	EndFor

EndSub

Sub 'carregaCombos'

	&TipSerFilCod.AddItem(0, 'X - ABRANGIR TODAS FILIAIS, EXCETO AS CONFIGURADAS DE FORMA ESPECIFICA')
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		
		&TipSerFilCod.AddItem(FilCod, FilCodNom)
		
	EndFor

	&TipSerLctCod.AddItem(0, 'X - ABRANGIR TODOS TIPOS LANCAMENTOS, EXCETO AS CONFIGURADAS DE FORMA ESPECIFICA')
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctAtuSal = Status_EntradaSaida.Saida
		
		&TipSerLctCod.AddItem(LctCod, LctCodNom)
		
	EndFor

EndSub


]]></Source>
