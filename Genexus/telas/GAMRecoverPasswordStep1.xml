      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Form.Backcolor = rgb(238,238,238)
	LayoutMainTable.Class = ThemeClass:MainContainer
	LoadWWPContext(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 270

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

//	TableError.Visible = false

EndEvent

Event Enter

	&User = GAMRepository.GetUserByLogin(&UserAuthTypeName, &UserName, &Errors)
	If &Errors.Count = 0	
		&KeyToChangePassword = &User.RecoverPasswordByKey(&Errors)
		
		&UserName.Enabled = False
		Do 'BuscaEmailTamplate'
		
		&Application = GAMApplication.Get()
		WWPBaseObjects.WWP_GetParameter.Text("Notification_BaseURL", &LinkURL)
		&BaseURL = &LinkURL + GAMRecoverPasswordStep2.Link(&IDP_State, &KeyToChangePassword, &UserName)
		
		&WWPMailBody = &WWPMailBody.Replace(!"[LINK]", &BaseURL)
		&WWPMailBody = &WWPMailBody.Replace(!"[LOGOFILIAL]", &AuxFilImg_LogErp)
		&WWPMailBody = &WWPMailBody.Replace(!"[LOGOJASPI]", 'https://i.postimg.cc/zBxK6z1W/Logo-JASPI.png')
		
		&Mail.To.Clear()
		&Mail.To.New(Format("%1 %2", &User.FirstName, &User.LastName), &User.EMail)
		&Mail.Subject = 'Alteração de Senha'
		
		WWPBaseObjects.WWP_GetParameter.Text(!"SMTP_Host", &TextParameter)
		&Host 		= &TextParameter
		&SMTP.Host 	= &TextParameter
		
		WWPBaseObjects.WWP_GetParameter.Integer(!"SMTP_Port", &IntegerParameter)
		&SMTP.Port = &IntegerParameter
		
		WWPBaseObjects.WWP_GetParameter.Text(!"SMTP_Username", &TextParameter)
		&SMTP.UserName = &TextParameter
		&SMTP.Sender.Address = !"suportejaspilocal@gmail.com"
		
		WWPBaseObjects.WWP_GetParameter.Text(!"SMTP_Password", &TextParameter)
		&SMTP.Password = &TextParameter
		
		WWPBaseObjects.WWP_GetParameter.Boolean(!"SMTP_Authentication", &BooleanParameter) //## True
		If &BooleanParameter
			&SMTP.Authentication = 1
		Else
			&SMTP.Authentication = 0
		EndIf
		
		WWPBaseObjects.WWP_GetParameter.Boolean(!"SMTP_Secure", &BooleanParameter)	//## C# True, Js False
		If &BooleanParameter
			&SMTP.Secure = 1
		Else	
			&SMTP.Secure = 0
		EndIf
	 
	 	WWPBaseObjects.WWP_GetParameter.Integer(!"SMTP_Timeout", &IntegerParameter)	//## 30 
		&SMTP.Timeout = &IntegerParameter
		
		&Mail.HTMLText = &WWPMailBody
		
		&IsOk = &SMTP.Login()
		If &SMTP.ErrCode = 0
			&SMTP.Send(&Mail)
			
			If &SMTP.ErrCode <> 0
				&Message = Format('Falha ao enviar o e-mail: %1 (%2)', &SMTP.ErrDescription, &SMTP.ErrCode)
			EndIf
			
			&SMTP.Logout()
			
		Else
			&Message = Format("Falha ao iniciar a sessão de e-mail: %1 (%1)", &SMTP.ErrDescription, &Ret)
			
		EndIf
		
		If &Message.IsEmpty()
			Msg('Um e-mail para ' + Trim(&User.EMail) + ' foi enviado com instruções para alterar a senha. Verifique a sua caixa de Spam, por precaução.')
		Else
			Msg(&Message.ToString())
		EndIf
		
	Else
		Do 'DisplayMessages'
		
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarLogin'

	If GAMRepository.IsRemoteAuthentication(&IDP_State)
		GAMRemoteLogin(&IDP_State)
	Else
		Login('', '')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub

Sub 'BuscaEmailTamplate'

	For Each Order WWPMailTemplateName
		Where WWPMailTemplateName = 'MailAlterarSenha'
		
		&WWPMailBody = WWPMailTemplateBody
		
		Exit
	EndFor

	For Each Order EmpCod, FilCod
		Where EmpCod = &Context.EmpCod
		Where FilCod = &Context.FilCod
		
		if not FilImg_LogERP.IsEmpty()
			&FilImg_LogErp = FilImg_LogERP
		EndIf
		
		Exit
	EndFor

EndSub


]]></Source>
