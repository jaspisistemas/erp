        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = Page.Rows
	GridsdtPedidossPaginationBar.RowsPerPageSelectedValue = GridsdtPedidoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&Context) //Crrega o Contexto da Sessão
	&EmpCod		= &Context.EmpCod //Empresa
	
	padraoUsuarioHora.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	
	&PlanCod = val(&PadObs)
	&sdtPedidos.FromXml(&WebSession.Get('CONFFECHARFINCTE')) //Carrega o(s) dado(s) da(s) CT-e 
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod) //Carrega o Local de Cobrança padrão
	If not &PadObs.IsEmpty() 
		&CbrCod = Val(SubStr(&PadObs,1,8))
	EndIf

	&PedDtaVct = &Today //Dia de hoje (por padrão)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtPedidossCurrentPage = GridsdtPedidoss.CurrentPage
	&GridsdtPedidossPageCount = GridsdtPedidoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Previous'
			GridsdtPedidoss.PreviousPage()
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtPedidoss.CurrentPage
			&PageToGo += 1
			GridsdtPedidoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtPedidossPaginationBar.SelectedPage)
			GridsdtPedidoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = GridsdtPedidossPaginationBar.RowsPerPageSelectedValue
	GridsdtPedidoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAjuda'

	innewWindow.Target = 'https://ajuda.jaspi.com.br/index.aspx?802f0c8d-2233-4d23-9cc6-c2b26bd4bf48'
	inNewWindow.Name = '_blank'
	innewWindow.OpenWindow()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PadObs = trim(Str(&PlanCod))
	padraoUsuarioHora.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	prcFecharFinanceiroCTe.Call(&Context.EmpCod, &Context.FilCod, &CbrCod, &sdtPedidos, &Context.PesCod, &PlanCod, &PedDtaVct) //Fecha o financeiro e gera uma duplicata
	Return

EndEvent


