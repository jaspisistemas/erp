Event 'DotbAtualizaTabela'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProOriCod.IsValid

	RetornaNomeProduto.Call(&EmpCod, &ProOriCod, &ProOriNom)

EndEvent

Event &ProCod.IsValid

	RetornaNomeProduto.Call(&EmpCod, &ProCod, &ProNom)

EndEvent

Event Enter

	RetornaNomeProduto.Call(&EmpCod, &ProCod, &ProNom)
	RetornaNomeProduto.Call(&EmpCod, &ProOriCod, &ProOriNom)
	
	Do CAse
		CAse &ProNom.IsEmpty()
			msg('Informe Código do Produto!')
			&ProCod.SetFocus()
		Case &ProOriNom.IsEmpty()
			msg('Informe Código do Produto Origem!')
			&ProOriCod.SetFocus()
		Otherwise
			prcAtualizaCodOrigem.Call(&EmpCod, &ProCod, &ProOriCod)
			&ProCod.SetEmpty()
			&ProOriCod.SetEmpty()
			&ProCod.SetFocus()
	EndCase

EndEvent


