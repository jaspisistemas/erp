      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&grid1Mensagem.ForeColor = RGB(255,0,0)
	LoadWWPContext.Call(&wwpContext)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&RenCod.Visible = False
	Grid2.Rows = 0
	Grid1.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid2.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&grid2CreFrpPgtoNom = CreFrpPgtoNom
	&Grid2CreDupNro = CreDupNro
	&grid2CreRenDta = CreRenDta
	&grid2CreVlrDup = CreVlrDup
	&grid2CreRenVlr = CreRenVlr

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ContaCliente += &grid2CreRenVlr

EndEvent

Event Grid1.Load

	&grid1Mensagem.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&Grid1CreDupNro = CreDupNro

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ValorRenegociado += CreVlrDup
	
	if CreVlrDup <> CreVlrSdo
		&grid1Mensagem = 'Duplicata Possui Pagamentos.'
	Endif

EndEvent

Event Refresh

	&ContaCliente = 0
	&ValorRenegociado = 0

	&Grid1PageCount = grid1.PageCount
	&Grid1CurrentPage = grid1.CurrentPage
	
	&Grid2PageCount = grid2.PageCount
	&Grid2CurrentPage = grid2.CurrentPage

EndEvent

Event Enter

	do 'VerificaDuplicatasRenegociadas'

	//DELETA DUPLICATAS RENEGOCIADAS.
	
	
	if &IsErro = true //se tem alguma com pgto
		if &EmpCod = 1
			CancelarRengociacaoReceberComPgto.Call(&EmpCod,&RenCod,&Mensagem)
			if &Mensagem.IsEmpty()
				return 
			else
				msg(&Mensagem)
			EndIf
		EndIf
	else //ñ tem nenhuma com pgto
		prcCancelarRenegociacaoReceber.call(&EmpCod, &RenCod)
		Return
	EndIf

EndEvent

Sub 'VerificaDuplicatasRenegociadas'

	&IsErro = false
	//Verifica DELETA RENEGOCIACOES
	For Each order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where CreRenDstCod = &RenCod
		Where CreVlrDup <> CreVlrSdo
		&IsErro = true	
		&Mensagem = 'Há Duplicatas renegociadas com pagamentos efetuados. É preciso remover os pagamentos para poder cancelar a Renegociação! ' 
		
		Exit
	EndFor

EndSub


]]></Source>
