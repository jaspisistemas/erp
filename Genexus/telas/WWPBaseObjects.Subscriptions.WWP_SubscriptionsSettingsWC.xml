      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WWPNotificationDefinitionId.Visible = False
	&WWPSubscriptionId.Visible = False
	&WWPSubscriptionEntityRecordId.Visible = False
	&WWPSubscriptionEntityRecordDescription.Visible = False

	Grid.Rows = Page.Rows
	Do 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&WWPSubscriptionRoleIdCollection = WWPBaseObjects.WWP_GetLoggedUserRoles()
	&GridRecordCount = 0
	For Each WWPBaseObjects.Notifications.Common.WWP_NotificationDefinition
		Where WWPEntityId = &WWPEntityId
		Where WWPNotificationDefinitionAllowUserSubscription

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the data

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&WWPNotificationDefinitionId = WWPNotificationDefinitionId
		&WWPNotificationDescriptionBase = WWPNotificationDefinitionDescription
		&WWPNotificationDescription = &WWPNotificationDescriptionBase
		&IncludeNotification = False
		&SubscriptionLoaded = False
		&WWPSubscriptionId = 0
		For Each WWPBaseObjects.Subscriptions.WWP_Subscription
			Where (WWPUserExtendedId = WWP_GetLoggedUserId() And WWPSubscriptionSubscribed = True) Or WWPSubscriptionRoleId In &WWPSubscriptionRoleIdCollection
			&WWPSubscriptionId = WWPSubscriptionId
			
			If WWPNotificationDefinitionAppliesTo <> WWPBaseObjects.Notifications.WWP_NotificationAppliesTo.AnyRecord
				If WWPSubscriptionEntityRecordId <> '' //Es una suscripción asociada a un registro
					&WWPSubscriptionEntityRecordDescription = WWPSubscriptionEntityRecordDescription
					&WWPSubscriptionEntityRecordId = WWPSubscriptionEntityRecordId
					
					&WWPNotificationDescription = Format("%1 (%2)", &WWPNotificationDescriptionBase, &WWPSubscriptionEntityRecordDescription)
					&GridRecordCount += 1
					&IncludeNotification = True
					&SubscriptionLoaded = True
					Load
				EndIf	
			Else
				&GridRecordCount += 1
				&IncludeNotification = True
				If Not WWPSubscriptionRoleId.IsEmpty()
					&IncludeNotification = WWPBaseObjects.Subscriptions.WWP_CheckUserIsNotUnsubscribed(&WWPNotificationDefinitionId, &WWPSubscriptionId)
				EndIf
				If Not &SubscriptionLoaded
					Load
				EndIf
				&SubscriptionLoaded = True
			Endif
		EndFor
		
		
		If Not &SubscriptionLoaded And Not &IncludeNotification And WWPNotificationDefinitionAppliesTo <> WWPBaseObjects.Notifications.WWP_NotificationAppliesTo.SpecificRecord And Not &NotifShowOnlySubscribedEvents
			&GridRecordCount += 1
			Load
		EndIf
		
		
	EndFor
	&GridPageCount = &GridRecordCount/Grid.Rows + iif(Mod(&GridRecordCount, Grid.Rows) > 0, 1, 0)

EndEvent

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event TableSubscriptionItem.Click

	&IncludeNotification = not &IncludeNotification
	WWPBaseObjects.Subscriptions.WWP_UserUpdateSubscription(&IncludeNotification, &WWPSubscriptionId, &WWPNotificationDefinitionId, &WWPSubscriptionEntityRecordId, &WWPSubscriptionEntityRecordDescription)

	If 1 = 0
		For Each line 
			//Dummy
		EndFor
	EndIf

EndEvent


]]></Source>
