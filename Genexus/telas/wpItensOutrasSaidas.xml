Sub 'loadItemPedido'

	For Each Order EmpCod, FilCod, PedCod, ProCod, ProGraCod
		Where EmpCod = &Empcod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		&PedItmCod = PedItmCod
		&PedQtd = PedQtd
		Exit
	endFor

EndSub

Sub 'GravarProduto'

	&sdtProdutoLote.Clear()
	if &ProSolLot = SolicitarLote.SIM_CONTROLAR and (&PedItmCod = 0 or &AuxsdtProdutoLote.Count <= 1)			
		
		if &ProdutoNaoSolicitaLote <> true
			if not &PedProEstLotCod.IsEmpty() or not &PedProEstLotVct.IsEmpty()
				&sdtProdutoLoteItem = New()
				&sdtProdutoLoteItem.PedProEstLotCod = &PedProEstLotCod
				&sdtProdutoLoteItem.PedProEstLotVct = &PedProEstLotVct
				&sdtProdutoLoteItem.PedProEstLotFab = &PedProEstLotFab
				&sdtProdutoLoteItem.PedProEstLotQtd = &PedQtd
				&sdtProdutoLote.Add(&sdtProdutoLoteItem)
			EndiF
		Else
			&PedProEstLotVct.SetEmpty()
			
			&sdtProdutoLoteItem = New()
			&sdtProdutoLoteItem.PedProEstLotCod = '#SEM_LOTE'
			&sdtProdutoLoteItem.PedProEstLotQtd = &PedQtd
			&sdtProdutoLote.Add(&sdtProdutoLoteItem)
		Endif
	Else
		&sdtProdutoLote = &AuxsdtProdutoLote
	EndIf

	If &Erro = 0 and &ProCod <> 0
		if (&ProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &ProGraCod = 1)
			GravaItemOUtrasSaidas.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &PedItmCod, &ProCod, &ProGraCod, &PedQtd, &PedVlrUnt, &PedItmAcr, &PedItmDsc, &PedItmIpi, &PedItmIcmSt, &PedItmIcm, &PedQtdEmb, &ProForQtdEmb, &PedItmCmp, &sdtProdutoLote, &inseridoMensagem, &AlteradoMensagem, &wwpContext.UserName)
			
			If not &inseridoMensagem.IsEmpty()
				text.Caption = &inseridoMensagem
				text.ForeColor = RGB(0,0,255)
			EndIF
			
			If not &AlteradoMensagem.IsEmpty()
				text.Caption = &AlteradoMensagem
				text.ForeColor = RGB(0,102,0)
			EndIF
			
			if &IsGravarPeloLote <> true
				&ProRef.SetEmpty()
				&PedItmCod = 0
				&ProCod = 0
				&ProNom = '<-- INFORME O PRODUTO'
				
				do 'limpaCampos'
				Grid.Refresh()
			Endif		
			
		Else
			&mensagem = 'Produto com Variação, é preciso inserir a Variação do Produto!'
			msg( &mensagem)

		EndIf		
	EndIF
	
	RetornaTotalLiquidoBruto.Call(&EmpCod, &FilCod, &PedCod, &PedVlrBrt, &PedVlrLiq)
	
	&ProRef.SetFocus()

EndSub

Sub 'LoadProduto'

	&ProIsGra = false
	retornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &isAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &mensagem)
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&ProIsGra = ProIsGra
		&ProSolLot = ProSolLot
		Exit
	When none
		If &ProCod <> 0
			&Erro = 1
			&ProNom = 'PRODUTO NÃO ENCONTRADO'
		EndIF
	EndFor

EndSub

Sub 'LimpaCampos'

	&PedQtd = 0
	&PedVlrItm = 0
	&PedVlrUnt = 0
	&ProNom = '<-- INFORME O PRODUTO'
//	&MarCodNom = ''
//	&UltPedVlrUnt = 0
//	
//	&PedItmAcr = 0
//	&PedItmDsc = 0
//	&PedItmIcmSt = 0
//	&PedItmIcm = 0
//	&PedItmIpi = 0
//	
//	&PedItmVlrAcr = 0
//	&PedItmVlrDsc = 0
//	&PedItmVlrIcm = 0
//	&PedItmVlrIcmSt = 0
//	&PedItmVlrIpi = 0
	&PedProEstLotFab.SetEmpty()
	&PedProEstLotVct.SetEmpty()
	&PedProEstLotCod.SetEmpty()
	ttbLoteProduto.Visible = 0
	AdicionandoProduto.Visible = 0
	
	&inseridoMensagem.SetEmpty()
	&AlteradoMensagem.SetEmpty()
	
	&AuxsdtProdutoLote.Clear()
	&ProdutoNaoSolicitaLote = false
	&sdtProdutoLote.Clear()

EndSub


