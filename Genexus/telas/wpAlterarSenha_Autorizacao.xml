      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	btnConfirmarUser.Visible =0
	loadWWPContext.Call(&wwpContext)
	if &PesCod <> &wwpContext.PesCod
		wwpactions.WCPopup_Close('')
	Endif

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&UserName = PesCodRaz
		Exit
	When none
		wwpactions.WCPopup_Close('')
	EndFor	
	&UserPasswordNew	= ""
	&UserPasswordNewConf= ""
	&SenAtu.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	ConfirmarUser_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmarUser'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ConfirmarUser_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ConfirmarUser_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = ExibeSenhaMaster.Create(&linkVirtual)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ConfirmarUser_Modal.Close

	wwpactions.WCPopup_Close('')

EndEvent

Event Enter

	If &UserPasswordNew = &UserPasswordNewConf 
		if &PesSenChvCmp.IsEmpty()
			prcGeraSenhaMaster.Call(&EmpCod, &wwpContext.FilCod, &PesSenChvCmp, &linkVirtual, &linkFisico)
		Endif
	
		prcGravaSenhaAutorizacao.Call('ALTERAR', &EmpCod, &PesCod, &UserPasswordNew, &UserPasswordNewConf, &SenAtu, &PesSenChvCmp, &Mensagem)
		if &Mensagem.IsEmpty()
			//ExibeSenhaMaster.Link(&linkVirtual)
			ConfirmarUser_Modal.Confirm()
			
		Else
			msg(&Mensagem)
		Endif
	Else
		Msg("A nova Senha e a Confirmação não Conferem.")
	Endif

EndEvent


]]></Source>
