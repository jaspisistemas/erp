	&VarCharIMC.TooltipText = "% Markup Informado no Cadastro / % Markup Calculado com o Preço Coluna 1."
	&EstABC_Ren.TooltipText = "Curva ABC de Rentabilidade. D - Não Calculado ou sem Movimento."

	Do 'AttributesSecurityCode'
