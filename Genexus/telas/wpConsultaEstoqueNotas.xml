Sub 'DadosProduto'

	if not &ProCod.IsEmpty()
		RetornaProdutoReferencia.Call(&EmpCod, &ProCod, &OutProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	EndIF
	
	&EstUltSai.SetEmpty()
	&EstSug.SetEmpty()
	&EstSdo = 0
	&EstPrd = 0
    &EstQtd = 0 
	&EstABC_Ren = 'D'
	&EstABC_Qtd = 'D'
	&EstLoc = ''
	&TabCod = ''
	&ProIsGra = false
	&VarCharIMC = ''
	&ProIMC = 0
	&ProSolLot = SolicitarLote.NAO_CONTROLAR
	&OutProCodEstCod.SetEmpty()
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &OutProCod
		Where ProGraCod = &ProGraCod
		
		&ProIsGra = ProIsGra
		&ProSolLot = ProSolLot
		&ProNom = ProNomGra
		&ProTipDef = ProTipDef
		&ProIMC = ProIMC
		&ProVlrCus = ProVlrCus
		&OutProCodEstCod = ProEstProCod
		
		For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
		    Where FilCod = &FilCod
			
//			&EstSdo = EstSdo => qtd - sum(qtdEmNotasDigitando)
			&EstQtd = EstQtdFis
			Do 'loadSaldo'
			&EstPrd = EstPrd
			&EstABC_Qtd = EstABC_Qtd
			&EstABC_Ren = EstABC_Ren
			
			If Not EstLoc.IsEmpty()
				&EstLoc = EstLoc
			Else
				&EstLoc = 'SEM LOCACAO'
			EndIF
			
			&EstMin = EstMin
			&EstSug = EstSug
			
			&TabCod = FilTabCod
			
			&EstUltEnt = EstUltEnt
			&EstUltFab = EstUltFab
			&EstUltSai = EstUltSai
			
//			&txtVenda = EstVen --loadSaldo
//			&txtCompra = EstCom -- loadSaldo
		When none
			iniciaEstoque.Call( &EmpCod, &FilCod, &OutProCod, &ProGraCod)
	    EndFor
		
	When none
		&ProNom = 'PRODUTO NÃO LOCALIZADO'
	EndFor

	tbOutroProduto.Visible = 0
	if &OutProCodEstCod <> &OutProCod
		For Each Order EmpCod, ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &OutProCodEstCod
			Where ProGraCod = &ProGraCod
			
			txtOutro.Caption = 'ESTOQUE DO PRODUTO: ' + trim(ProGraRef)
			tbOutroProduto.Visible = 1
		
			For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
			    Where FilCod = &FilCod
				
//				&EstSdo = EstSdo => qtd - sum(qtdEmNotasDigitando)
				&EstQtd = EstQtdFis
				Do 'loadSaldo'
				exit
			When none
				iniciaEstoque.Call( &EmpCod, &FilCod, &OutProCodEstCod, &ProGraCod)
		    EndFor
			Exit
		EndFor
	Endif

	If &EstABC_Ren.IsEmpty()
		&EstABC_Ren = 'D'
	EndIF

	If &EstABC_Qtd.IsEmpty()
		&EstABC_Qtd = 'D'
	EndIf
	
    &CalcProIMC = 0 
	&auxTabPrc1 = 0
	&TabPrc1.Clear()
    For Each Order EmpCod, TabCod, ProCod, ProGraCod, (TabAltCod)
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
	    Where ProCod = &OutProCod
		Where ProGraCod = &ProGraCod
		
		&Mensagem = 'Coluna 1: ' + trim(toformattedString(TabPrc1))
		&TabPrc1.AddItem(1, &Mensagem)
		
		&Mensagem = 'Coluna 2: ' + trim(toformattedString(TabPrc2))
        &TabPrc1.AddItem(2, &Mensagem)
		
		&Mensagem = 'Coluna 3: ' + trim(toformattedString(TabPrc3))
		&TabPrc1.AddItem(3, &Mensagem)
		
		&Mensagem = 'Coluna 4: ' + trim(toformattedString(TabPrc4))
		&TabPrc1.AddItem(4, &Mensagem)
		
		&Mensagem = 'Coluna 5: ' + trim(toformattedString(TabPrc5))
		&TabPrc1.AddItem(5, &Mensagem)
		
		&TabPrc1 = 1
		&auxTabPrc1 = TabPrc1
		Exit
	When none
		&Mensagem = 'Preço não Cadastrado'
		&TabPrc1.AddItem(1, &Mensagem)
    EndFor

    if &auxTabPrc1 <> 0 
        &CalcProIMC = 100 - ((&ProVlrCus /&auxTabPrc1) * 100)
    EndIf

	&VarCharIMC = trim(toformattedString(&ProIMC)) + ' / ' + trim(ToformattedString(&CalcProIMC))
	&posEstQtd = &EstQtd
	&negEstQtd = &EstQtd
	
	GXUITabsPanel_abaDadosEstoque.HideTab(2)
	GXUITabsPanel_abaDadosEstoque.HideTab(3)
	If &ProIsGra = true
		
		wcEstoqueVariacao.Object = wcEstoqueVariacoes.Create(&EmpCod, &FilCod, &OutProCod, &ProGraCod)
		GXUITabsPanel_abaDadosEstoque.ShowTab(2)
		GXUITabsPanel_abaDadosEstoque.SelectTab(2)
	EndIF
	
	If &ProSolLot = SolicitarLote.SIM_CONTROLAR
		wwcLotesdoProduto.Object = wcEstoqueLotes.Create(&EmpCod, &FilCod, &OutProCod, &ProGraCod)
		GXUITabsPanel_abaDadosEstoque.ShowTab(3)
	Endif

	wcEstoqueFiscal.Object = wcEstoqueNotas.Create(&EmpCod, &FilCod, &OutProCod, &ProGraCod)
	do 'AttributesSecurityCode'

EndSub

Sub 'loadSaldo'

	&sdtEstoque.Clear()
	&EstSdo.SetEmpty()
	&TotNfeProQtd.SetEmpty()
	&txtCompra.SetEmpty()
	&txtVenda.SetEmpty()
	CarregaSDT_EstoqueFiscal.Call(&EmpCod,&FilCod,&OutProCod,&ProGraCod,&sdtEstoque)
	For &sdtEstoqueItem in &sdtEstoque
		//&TotNfeProQtd  += &sdtEstoqueItem.NfeProQtd
		//&EstSdo = &EstQtd - &TotNfeProQtd
		Do case
			case &sdtEstoqueItem.LctAtuEst = 'E'
				&txtCompra += &sdtEstoqueItem.NfeProQtd
			case &sdtEstoqueItem.LctAtuEst = 'S'
				&txtVenda += &sdtEstoqueItem.NfeProQtd
		EndCase
	EndFor
	&EstSdo = &EstQtd + &txtCompra - &txtVenda

EndSub


