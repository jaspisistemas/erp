        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 550
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&usrDelete = !'<i class="fa fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ProCod= GrupProCod
	do 'GetProduto'

EndEvent

Event &usrDelete.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_usrDelete.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Refresh

EndEvent

Event DVelop_ConfirmPanel_usrDelete.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_usrDelete.Result = !'Yes'
		Do 'Do usrDelete'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInserir'

	wpCategoriasprodutosAdd.Popup(&empCod, &GrupCod , 'P') //COMPLEMENTO
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do usrDelete'

	prcGravaObservacaoCategoria.Call('DEL', EmpCod, &GrupCod, 0, GrupProCod, 'P')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'GetProduto'

	&ProRef.SetEmpty()
	&ProNom.SetEmpty()
	For Each Order EmpCod, ProCod
		Where EmpCod = &empCod
		Where ProCod = &ProCod
		&ProRef = ProRef
		&ProNom = ProNom
		Exit
	EndFor

EndSub


