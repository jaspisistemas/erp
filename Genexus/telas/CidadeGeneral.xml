Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)
	Do 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CidAreNom.Link = ViewArea.Link(EmpCod, CidAreCod, '')

	EmpCod.Visible = False
	CidAreCodNom.Visible = False
	CidTraCodRaz.Visible = False
	CidCodSync.Visible = False

	// Security check for 'Actions'
	&IsAuthorized_Update = SecGAMIsAuthByFunctionalityKey.Udp(!'<Check_Is_Authenticated>')
	If not (&IsAuthorized_Update)
		BtnUpdate.Visible = False
	Endif
	&IsAuthorized_Delete = SecGAMIsAuthByFunctionalityKey.Udp(!'<Check_Is_Authenticated>')
	If not (&IsAuthorized_Delete)
		BtnDelete.Visible = False
	Endif
	 

	// Visible Conditions
	If Not (CidWs = Status_WsUsu.WebService)
		CidWs.Visible = False
		CidWs_Cell.Class = !'Invisible'
	Else
		CidWs.Visible = True
		CidWs_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUpdate'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&IsAuthorized_Update)
		Cidade.Call(TrnMode.Update, EmpCod, CidCod)
	Else
		msg("WWP_ActionNoLongerAvailable")
		BtnUpdate.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDelete'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&IsAuthorized_Delete)
		Cidade.Call(TrnMode.Delete, EmpCod, CidCod)
	Else
		msg("WWP_ActionNoLongerAvailable")
		BtnDelete.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = False
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"Cidade"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


