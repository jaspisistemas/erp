	GridValorTotalBruto.Caption = trim(ToformattedString(&PedVlrBrt))
	GridValorTotalBruto.ForeColor = RGB(0,100,255)	
	LOAD
	
	GridTitulo.Caption = 'DINHEIRO R$'
	GridValorTotalBruto.Caption = trim(ToformattedString(&TotalDinheiro))
	GridValorTotalBruto.ForeColor = RGB(50,170,50)
	Load
	
	
	for &SdtGridPagamentosItem in &SdtGridPagamentos
		GridValorTotalBruto.ForeColor = RGB(50,170,50)
		BtnRemover.Visible = 1
		GridTitulo.Caption = &SdtGridPagamentosItem.PedTmpMensagem
		GridValorTotalBruto.Caption = trim(ToformattedString(&SdtGridPagamentosItem.PedTmpDupVlr))
		&PedTmpDupCod = &SdtGridPagamentosItem.PedTmpDupCod
		&PedTmpFrpPgtoTip = &SdtGridPagamentosItem.PedTmpFrpPgtoTip
	BtnRemover.Visible = false
	if &SdtGridPagamentosItem.PedTmpDupVlr > 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

		Load
	EndFor
	
	BtnRemover.Visible = 0
	GridTitulo.Caption = 'DESC. GLOBAL R$'
	GridValorTotalBruto.Caption = trim(ToformattedString(&PedVlrDscGlb))
	GridValorTotalBruto.ForeColor = RGB(230,10,10)
	LOAD
	
	if &PedVlrDscSpm > 0
		GridTitulo.Caption = 'DESC. TABELA R$'
		GridValorTotalBruto.Caption = trim(ToformattedString(&PedVlrDscSpm))
		LOAD
	Endif
	if &PedVlrDscPrm > 0
		GridTitulo.Caption = 'DESC. PROMOÇÃO R$'
		GridValorTotalBruto.Caption = trim(ToformattedString(&PedVlrDscPrm))
		LOAD
	Endif

EndEvent

