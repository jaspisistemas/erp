Event 'DoRemover'

	do Case
		CAse &PedTmpDupCod  > 0
			ApagaTemporariaPedidoVenda_EmpresaCodigo.Call(&EmpCod, &FilCod, &PedCod, &Context.PesCod, &PedTmpDupCod)
			
		Otherwise
			ApagaTemporariaPedidoDuplicata.Call(&EmpCod, &FilCod, &PedCod, &Context.PesCod, &PedTmpFrpPgtoTip)
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (1=2)
		BtnVAIPRALA.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wb3.Visible = (&TotalDescontos > 0)
	wb71.Visible = (&ErroMensagem > '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	txtMensagemErro.Caption = &ErroMensagem

EndSub

Event &varTotalMoeda.IsValid

	&varTotalMoeda = RetornaSoNumeros.Udp(&varTotalMoeda)
	
	&TotalRecebido = val(&varTotalMoeda)// * 100
	&TotalRecebido = &TotalRecebido / 100
	
	If &TotalRecebido <= 0
		&varTotalMoeda = ''
	Else
		&varTotalMoeda = padL(trim(&TotalRecebido.ToFormattedString()), 15, ' ')
	Endif

	do 'troco'
	
	&varTotalMoeda.SetFocus()

EndEvent

Event 'eventFinalizaVenda10'

 10
	do 'FinalizaVenda'

EndEvent

Event 'eventFinalizaVenda'

 11
	do 'FinalizaVenda'

EndEvent

Sub 'PlanoContas'

	retornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &ValorConfiguracao)
	For Each Order EmpCod, PlanCod
		Where EmpCod = &EmpCod
		Where PlanHie = &ValorConfiguracao
		&PlanCod = PlanCod
		Exit
	When none
		btnEnter.Visible = 0
		btnDescontos.Visible = 0
		
		&ErroMensagem = 'Não Localizado Plano Contas Recebimento Padrão!'
		txtMensagemErro.Caption = &ErroMensagem
		do 'AttributesSecurityCode'
	EndFor

EndSub

Sub 'Pedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedSts = Status_Pedido.ABERTO
		//Where PedVenCod = &Context.PesCod
		
		&PedCliCod = PedCliCod
		
		retornaTotalTemporariaDP1.Call(&EmpCod, &FilCod, &PedCod, &TotalCrediario, &TotMovItmVlrMoeda,&TotalCartao,&CarMovItmJurMoeda,&CarMovItmDesMoeda, &TotChequeTerceirosMoeda, &TotChequeProPrioMoeda, &PixMoeda, &DepositoMoeda)
		
//	&TotalCrediario = RetornaTotalDuplicata.Udp(&EmpCod, &FilCod, &PedCod)
//	&TotalCartao = RetornaTotalCartao.Udp(&EmpCod, &FilCod, &PedCod)
		
		&PedVlrBrt = PedVlrBrt
		
		&TotalDinheiro = PedVlrLiq - (&TotalCrediario+&TotalCartao)
		if &TotalDinheiro < 0
			&TotalDinheiro = 0
		EndIF
		
		&PedVlrLiq = PedVlrLiq - (&TotalCrediario+&TotalCartao)
		&TotalPedido = PedVlrLiq
		
		&PedVlrDscPrm = PedVlrDscPrm
		&PedVlrDscSpm = PedVlrDscSpm
		&PedVlrDscGlb = PedVlrDscGlb
		
		&TotalDescontos = PedVlrDscGlb + PedVlrDscPrm + PedVlrDscSpm
		
		&PedVlrLiqPendente = PedVlrLiq
		Exit
	When None
		pdv_m.Link()
	EndFor
	
	sdtRetornaGridPagamentos.Call(&EmpCod, &FilCod, &PedCod, &SdtGridPagamentos)
	
	do 'troco'
	Do 'AttributesSecurityCode'

EndSub

Sub 'troco'

	&TotalTroco = &TotalRecebido - &PedVlrLiq

EndSub

Sub 'FinalizaVenda'

	&TotalInformado = &TotalCrediario + &TotalDinheiro + &TotalCartao
	
	if &TotalInformado <> &TotalPedido
		&ErroMensagem = 'Total informado difere do valor do Pedido!'
		txtMensagemErro.Caption = &ErroMensagem
		do 'AttributesSecurityCode'
	Else
		if &TotalRecebido >= 0
			GravaTroco.Call(&EmpCod, &FilCod, &PedCod, &TotalRecebido)
		EndIF
		
		if &TotalDinheiro > 0 //GRAVA O DINHEIRO
			&sdtPgto = new()
			&sdtPgto.FrpPgtoCod = 2
			&sdtPgto.FrpPgtoTip = TIPODuplicata.DINHEIRO //Deve ser preenchido
			
			&sdtPgto.PedDtaFat = serverdate()
			&sdtPgto.PedTmpCreCliCod = 0
			&sdtPgto.FunPesCod = 0
			&sdtPgto.PlanCod = &PlanCod
			&sdtPgto.IsPago = true
			&sdtPgto.CreCbrCod = 0			
			&sdtPgto.CtaBanCod = &Context.CtaBanCod
			&sdtPgto.creVlrDup = &TotalDinheiro
			&sdtPgto.CreDupNro = ''
			&sdtPgto.CrePagDta = serverdate()
			&sdtPgto.CreDtaVct = serverdate()
			MontaDuplicatasPedidoVenda01_JDF.Call('ADD', &EmpCod, &FilCod, &PedCod, &sdtPgto)
		Endif
		
		&PedDtaFat = serverdate()
		AtualizaEstoqueGerencialVenda.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &Context.PesCod, Status_Pedido.FECHADO)
		
		GravaDuplicatasAReceber1.Call(&EmpCod, &FilCod, &PedCod)
		CriticasPedido.Call(&EmpCod, &FilCod, &PedCod, TipoCriticaPedido.FechadoFinanceiro, &Context.PesCod)
		
		GravaNotaTemporariaVenda.Call(&EmpCod, &FilCod, &PedCod, '65')
		
		&tmpNFeCod = trim(str(&EmpCod)) + trim(Str(&FilCod)) + trim(str(&PedCod))
		pdvm_emiteNFCe.Link(&EmpCod, &FilCod, &PedCod, &tmpNFeCod)
	EndIF

EndSub


