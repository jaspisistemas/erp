      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	//VERIFICAR SE EH O SUPORTE.JASPI
	
//	Do Case
//		Case &Mode = TrnMode.Delete
//			retornaAutorizacao.Call('WWCADASTROUSUARIOS', Status_SimNao.Sim, 3, &AutNiv)
//			
//		Case &Mode = TrnMode.Insert
//			retornaAutorizacao.Call('WWCADASTROUSUARIOS', Status_SimNao.Sim, 2, &AutNiv)
//			
//		Case &Mode = TrnMode.Update
//	EndCase

	&Repository = GAMRepository.Get()
	
	//User Authentication Type
	User_AuthenticationTypeName.Clear()
	&AuthenticationTypes = GAMRepository.GetEnabledAuthenticationTypes(&Language, &Errors)
	For &AuthenticationTypesIns in &AuthenticationTypes
		User_AuthenticationTypeName.AddItem(&AuthenticationTypesIns.Name,&AuthenticationTypesIns.Description)
	EndFor
			
	If &Mode = TrnMode.Insert
		&User.AuthenticationTypeName = !"local"
		
		&Repository 		  =  GAMRepository.Get()
		&User.NameSpace 		  = &Repository.NameSpace
	Else
		&User.Load(&UserId)
		
		//&UserName.Enabled = 0
		&UserPassword   = &User.Password
		&UserFirstName  = &User.FirstName
		&UserName 		= &User.Name
		&UserEmail 		= &User.EMail
		
		&IsBloqueado 		= &User.IsBlocked
		&IsAtivo 			= &User.IsActive
		&IsPodeAlterarSenha = &User.CannotChangePassword
		&IsTrocarSenha 		= &User.MustChangePassword
		&UserName.Enabled = 0
		
	Endif
	
	&User.SecurityPolicyId = 1
	
	if &IsAtivo = true and &mode = TrnMode.Update
		&IsAtivo.Enabled = 0
	EndIF
	
	If &Context.PesCod = &SupCod
		&IsBloqueado.Enabled = 0
	EndIF
	
	If &Mode = TrnMode.Display
		BtnEnter.Visible = False
		&UserName.Enabled 		= False
		&UserEmail.Enabled 		= False
		&IsBloqueado.Enabled	= False
		&IsAtivo.Enabled 	= False
		&IsPodeAlterarSenha.Enabled 	= False
		&IsTrocarSenha.Enabled				= False
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	User_DateLastAuthentication.TooltipText = "Ultimo Login Realizado pelo Usuário."

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'getDadosUsuario'

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &UserName.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Usuário'), DVMessageType.error, &UserName.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&Mode = TrnMode.Insert) AND &UserPassword.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Senha'), DVMessageType.error, &UserPassword.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If (&Mode = TrnMode.Insert) AND &PasswordConf.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Confirma Senha'), DVMessageType.error, &PasswordConf.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if Substr(&UserName, 1, 8 ) <> 'SUPORTE.' and Substr(&UserName, 1, 8 ) <> 'suporte.'
		Msg('Obrigatório usuario começar com "SUPORTE."')
		&CheckRequiredFieldsResult = False
	Endif

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&Mode = TrnMode.Insert)
		&UserPassword.Visible = False
		UserPassword_Cell.Class = !'Invisible'
	Else
		&UserPassword.Visible = True
		UserPassword_Cell.Class = !'col-xs-12 RequiredDataContentCell'
	EndIf
	If Not (&Mode = TrnMode.Insert)
		&PasswordConf.Visible = False
		PasswordConf_Cell.Class = !'Invisible'
	Else
		&PasswordConf.Visible = True
		PasswordConf_Cell.Class = !'col-xs-12 RequiredDataContentCell'
	EndIf
	If Not (&Mode <> GAMAPiMode.Insert)
		User_DateLastAuthentication.Visible = False
		User_DateLastAuthentication_Cell.Class = !'Invisible'
	Else
		User_DateLastAuthentication.Visible = True
		User_DateLastAuthentication_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&Mode <> GAMAPiMode.Insert)
		User_ActivationDate.Visible = False
		User_ActivationDate_Cell.Class = !'Invisible'
	Else
		User_ActivationDate.Visible = True
		User_ActivationDate_Cell.Class = !'DataContentCell'
	EndIf
	If &UserPassword.Visible = False
		AND &PasswordConf.Visible = False
		AND User_DateLastAuthentication.Visible = False
		UnnamedTable2.Visible = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &IsPodeAlterarSenha.Click

	If &IsPodeAlterarSenha = true
		&IsTrocarSenha = false
	EndIf

EndEvent

Event &IsTrocarSenha.Click

	If &IsTrocarSenha = true
		&IsPodeAlterarSenha = false
	EndIf

EndEvent

Event Enter

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult
		If &mode <> TrnMode.Insert
			&User.Load(&UserId)		
		EndIF
	
		&PasswordIsOK = True
		Do Case
			Case &Mode = TrnMode.Insert or &Mode = TrnMode.Update
				&User.Password = &UserPassword
				&User.FirstName = &UserFirstName
				&User.Name = &UserName
				&User.EMail = &UserEmail
				
				&User.IsBlocked = &IsBloqueado
				&User.IsActive = &IsAtivo
				&User.CannotChangePassword = &IsPodeAlterarSenha
				&User.MustChangePassword = &IsTrocarSenha
				 
				If &Mode = TrnMode.Insert
					If &UserPassword <> &PasswordConf
						&PasswordIsOK = False
						Msg("A Senha e a Confirmação da Senha não Conferem.")
					Endif
				Endif
				
				If &PasswordIsOK = true
					If &Mode = TrnMode.Insert
						&SupExtID = geraPesExtCod.Udp()
						GravaSupExtID.Call(&SupCod, &SupExtID,&UserEmail)						
						&User.ExternalId = trim(str(&SupExtID))
					EndIf
					
					&User.Password = &UserPassword
					&User.Save()				
				Endif
				
			Case &Mode = GAMAPiMode.Delete
				&User.Delete()
		EndCase
		
		If &PasswordIsOK = true
			If &User.Success()
				Commit
				return
			Else
				&Errors = &User.GetErrors()
				For &Error in &Errors
					Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
				EndFor
			Endif
		Endif
	EndIf

EndEvent

Sub 'getDadosUsuario'

	For Each Order SupCod
		Where SupCod = &SupCod
		
		&UserFirstName = trim(SupNom)
		&UserEmail = SupEmail	
		Exit
	EndFor

EndSub


]]></Source>
