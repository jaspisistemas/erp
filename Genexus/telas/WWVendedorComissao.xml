      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&AplicarComissao.Title = 'Aplicar'
	&Alte.Title = 'Editar'
	
	RetornaAutorizacao.Call('WWVENDEDORCOMISSAO', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	&PesSts = nullvalue(&PesSts)
	&IncluirDemitidos = 'N'
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = 'Comissão Vendedor'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Alte = !'<i class="fa fa-pen"></i>'
	
	&AplicarComissao = !'<i class="fas fa-percent"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Alte.Link = wpComissaoDesconto.Link(EmpCod, PesCod)
	PesVenAreNom.Link = ViewArea.Link(EmpCod, PesVenAreCod, '')
	PesRaz.Link = verCliente.Link('WWVEndedorComissao', EmpCod, PesCod)

EndEvent

Event 'DoInserir'

	wpComissaoDesconto.Link(&Context.EmpCod, 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoExport'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Generate Excel spreadsheet and download it.
	Do 'LoadGridState'
	ExportWWVendedorComissao.Call(&ExcelFilename, &ErrorMessage)
	If (&ExcelFilename <> "")
		Link(&ExcelFilename)
	Else
		msg(&ErrorMessage)
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoExportReport'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Generate PDF file.
	Do 'LoadGridState'
	InNewWindow1.Target = ExportReportWWVendedorComissao.Link()
	InNewWindow1.Height = !'600'
	InNewWindow1.Width = !'800'
	InNewWindow1.OpenWindow()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"PESSTS"
				&PesSts.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PESCOD"
				&PesCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PESRAZ"
				&PesRaz.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"INCLUIRDEMITIDOS"
				&IncluirDemitidos.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PESCOMULTLCT"
				&PesComUltLct.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"PESSTS", "", not &PesSts.IsEmpty(), 0, &PesSts, '')
	WWP_GridStateAddFilterValue(&GridState, !"PESCOD", "", not &PesCod.IsEmpty(), 0, &PesCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"PESRAZ", "", not &PesRaz.IsEmpty(), 0, &PesRaz, '')
