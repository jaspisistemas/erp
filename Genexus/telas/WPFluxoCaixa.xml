        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&Data = ServerDate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtFluxos.Rows = 50
	GridSdtFluxosPaginationBar.RowsPerPageSelectedValue = GridSdtFluxos.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'InitializeTotalizersGridSdtFluxos'
	Do 'CalculateTotalizersGridSdtFluxos'	
	&GridSdtFluxosCurrentPage = GridSdtFluxos.CurrentPage
	&GridSdtFluxosPageCount = GridSdtFluxos.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtFluxos.Load

	SdtFluxo__Data.ColumnClass = iif(&SdtFluxo.CurrentItem.data < &Data , !'WWColumn hidden-xs WWColumnOrange WWColumnOrangeSingleCell',!'WWColumn hidden-xs')
	SdtFluxo__BanVlrTot.ColumnClass = iif(&SdtFluxo.CurrentItem.data < &Data , !'WWColumn hidden-xs WWColumnOrange WWColumnOrangeSingleCell',!'WWColumn hidden-xs')
	SdtFluxo__TotGer.ColumnClass = iif(&SdtFluxo.CurrentItem.TotGer > 0 , !'WWColumn hidden-xs WWColumnBlue WWColumnBlueSingleCell',!'WWColumn hidden-xs WWColumnRed WWColumnRedSingleCell')
	SdtFluxo__CtaPagar.ColumnClass = iif(&SdtFluxo.CurrentItem.CtaPagar > 0 , !'WWColumn hidden-xs WWColumnRed WWColumnRedSingleCell',!'WWColumn hidden-xs')
	SdtFluxo__CtaFolPg.ColumnClass = iif(&SdtFluxo.CurrentItem.CtaFolPg > 0 , !'WWColumn hidden-xs WWColumnRed WWColumnRedSingleCell',!'WWColumn hidden-xs')
	SdtFluxo__CtaReceber.ColumnClass = iif(&SdtFluxo.CurrentItem.CtaReceber > 0 ,!'WWColumn hidden-xs WWColumnGreen WWColumnGreenSingleCell',!'WWColumn hidden-xs')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&diasemana = Substr(cdow(&SdtFluxo.CurrentItem.data), 1, 3)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtFluxosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSdtFluxosPaginationBar.SelectedPage = !'Previous'
			GridSdtFluxos.PreviousPage()
		Case GridSdtFluxosPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridSdtFluxos.CurrentPage
			&PageToGo += 1
			GridSdtFluxos.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridSdtFluxosPaginationBar.SelectedPage)
			GridSdtFluxos.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtFluxosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtFluxos.Rows = GridSdtFluxosPaginationBar.RowsPerPageSelectedValue
	GridSdtFluxos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoPrinter'

	&WebSession.Set('SDTFLUXODIARIO',&SdtFluxo.ToXml())
	RCOOpenWindow1.LinkOpen = RELJAS106.link(&EmpCod,&context.FilCod,&Data)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAtualizar'

	Do 	'CarregarDados'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'InitializeTotalizersGridSdtFluxos'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TotGridSdtFluxos_CtaPagar = 0
	&TotGridSdtFluxos_CtaReceber = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CalculateTotalizersGridSdtFluxos'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For &SdtFluxoItem in &SdtFluxo
		&TotGridSdtFluxos_CtaPagar += &SdtFluxoItem.CtaPagar
		&TotGridSdtFluxos_CtaReceber += &SdtFluxoItem.CtaReceber
	EndFor
	
	&TotValueGridSdtFluxos_CtaPagar = &TotGridSdtFluxos_CtaPagar.ToFormattedString()
	&TotValueGridSdtFluxos_CtaReceber = &TotGridSdtFluxos_CtaReceber.ToFormattedString()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CarregarDados'

	CarregarFluxoCaixa.Call(&EmpCod,&Data,&MostrarVazio,&SdtFluxo)
	GridSdtFluxos.Refresh()

EndSub


