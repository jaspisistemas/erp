      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPADIANTAMENTOSPORPERIODO', Status_SimNao.Sim, 1, &AutNiv)
	&DtaIni = &Today
	&DtaFin = &Today
	&MovFunRaz = 'TODOS OS FUNCIONÁRIOS.'
	&MovFunMes = Month(&Today)
	&MovFunAno = Year(&Today)
	&MostrarObs = Status_SimNao.Sim

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsSintetico.TooltipText = "Marque esta opção para mostrar o relatório no modo sintético, caso contrário o mesmo já sai analítico."

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLancamentodeadiantamento'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWAdiantamento.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&tipo = 2)
		&DtaIni.Visible = False
		DtaIni_Cell.Class = !'Invisible'
	Else
		&DtaIni.Visible = True
		DtaIni_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&tipo = 2)
		&DtaFin.Visible = False
		DtaFin_Cell.Class = !'Invisible'
	Else
		&DtaFin.Visible = True
		DtaFin_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&Tipo = 1)
		&MovFunAno.Visible = False
		MovFunAno_Cell.Class = !'Invisible'
	Else
		&MovFunAno.Visible = True
		MovFunAno_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&Tipo = 1)
		&MovFunMes.Visible = False
		MovFunMes_Cell.Class = !'Invisible'
	Else
		&MovFunMes.Visible = True
		MovFunMes_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event &tipo.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event &MovFunCod.IsValid

	Do 'Funcionario'

EndEvent

Event 'Prompt'

	4
	PromptFuncionario.Popup(&EmpCod,&MovFunCod)

EndEvent

Event Enter

	&Status_AbertoFechado.FromString(&MovFunSts)
	RCOOpenWindow1.LinkOpen = RELJAS028.link(&EmpCod,&context.FilCod,&DtaIni,&DtaFin,&MovFunCod,&IsSintetico,&MovFunMes,&Status_AbertoFechado,&Tipo,&MovFunAno,&MostrarObs)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'Funcionario'

	If &MovFunCod = 0 
		&MovFunRaz = 'Todos os Fucionários.'
	Else
		For each Order EmpCod,PesCod,PesSts,PesIsFun
			Where EmpCod = &EmpCod
			Where PesCod = &MovFunCod
			Where PesIsFun = True
			Where PesSts = Status_AtivoInativo.ATIVO
			&MovFunRaz = PesRaz		
			Exit
		When none
			msg('Esta pessoa não é um funcionário, ou não esta ativo, Verifique!')
			&MovFunCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
