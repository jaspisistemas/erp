      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&NomeTemporario = 'IMPXML' + trim(str(&Context.EmpCod)) + trim(Str(&Context.PesCod)) + '-'
	
	do 'loadTemporaria'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 900
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&NomeTemporario = 'IMPXML' + trim(str(&Context.EmpCod)) + trim(Str(&Context.PesCod)) + '-'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = grid.CurrentPage
	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount

EndEvent

Event Grid.Load

	&tmpProRef = tmpProRef
	&tmpCFOP = tmpEntCFOP

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&addProduto.FromImage(IconVermelho)
	&addProduto.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if tmpProCod.IsEmpty() or tmpProCod.IsNull()
		&addProduto.FromImage(IconVermelho)
		&addProduto.TooltipText = "Produto não Cadastrado"
	Else
		&addProduto.FromImage(IconVerde)
		&addProduto.TooltipText = "Produto Vinculado"
	EndiF
	
	&TmpNfeProEmbQtd = tmpProQtdCmpEmb

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For Each Line in grid
		FornecedorProduto_AtualizaCodBarras.Call(&NomeTemporario, &EmpCod, &ForCNPJ, tmpProForCod, tmpNfeProBar, &tmpProRef, &tmpCFOP,tmpCFOP, &TmpNfeProEmbQtd,0,0)
	EndFor
	
	Refresh

EndEvent

Event &addProduto.Click

	&sdtGravaProduto.ProRef = tmpProForCod
	&sdtGravaProduto.ProNom = tmpProNom
	&sdtGravaProduto.ProNcmCod = tmpNcmCod
	&sdtGravaProduto.ProBar = tmpNfeProBar
	RetornaPrimeiraEmbalagemUnidade.call(&EmpCod, tmpUnd, &EmbCod)
	&sdtGravaProduto.ProEmbCod = &EmbCod
	&sdtGravaProduto.IsPoupop = true	
	&WebSession.Set('DADOSDEFAUT_PRODUTO', &sdtGravaProduto.ToXml())
	
	
	Produtos.Popup('RETURN', TrnMode.Insert, &Context.EmpCod, 0, &ProRef)

EndEvent

Sub 'loadTemporaria'

	For Each Order tmpNFeCod
		WHere tmpNFeCod = &tmpNFeCod
			if tmpPedCliCnpj.IsEmpty()
				&ForCNPJ = tmpPedCliCpf
			Else
				&ForCNPJ = tmpPedCliCnpj
			EndIF
		Exit
	EndFor

EndSub


]]></Source>
