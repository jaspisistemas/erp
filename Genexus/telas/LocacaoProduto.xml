      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

//	&ExtEstLoc.Enabled = 1
	retornaAutorizacao.Call('LOCACAOPRODUTO', Status_SimNao.Sim, 1, &AutNiv)
	
	GravaNaoGrava.Caption = ''
	GravaNaoGrava.ForeColor = RGB(0,40,160)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	
	&FilCodNom = trim(str(&Context.FilCod)) + ' - ' + &Context.FilRaz
	&ProGraCod = 1
	&ProCod = &parmProCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 500
	&EmpCod.Visible = False
	&ProCod.Visible = False
	&ProGraCod.Visible = False
	&FilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if 1=2
		AbreLocacaoProduto.Link()
	EndIF

	if &parmProCod > 0		
		For Each Order EmpCod, ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &parmProCod
			&CodigoProduto = ProRef.Trim()
			Exit
		When none
			&CodigoProduto = trim(str(&parmProCod))
		EndFor
	
	EndIF
	
	
	Do 'LoadEstoque'
	do 'loadGridProdutos'
	
//	&CodigoProduto.SetFocus()

EndEvent

Event 'DoImprimir'

	&EtqCod = trim(str(&Context.EmpCod)) + trim(str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&sdtLocacao.Clear()
	
	&sdtLocacaoItem = new()
	&sdtLocacaoItem.EstLoc = &EstLoc
	&sdtLocacaoItem.EstQtd = 1
	&sdtLocacaoItem.EstOrd = 1
	&sdtLocacao.add(&sdtLocacaoItem)
	
	&PadObs = &sdtlocacao.ToJson()
	padraoUsuario.Call('G', &EtqCod, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	wpEtiquetaLocacao.Popup(false)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &EstLoc.IsValid

	do 'loadGridProdutos'

EndEvent

Event 'f4'

 4
	
	PromptProdutoRef.Popup(&EmpCod, &ProCod, &CodigoProduto)
	&CodigoProduto.SetFocus()

EndEvent

Event Enter

	&IsErro = false
	For Each Order EmpCod, ProCod
		Where EmpCod = &Context.EmpCod
		Where ProCod = &ProCod
		&ProNom = ProNom
	When none
		&ProNom = 'PRODUTO NÃO LOCALIZADO'
		&IsErro = true
	EndFor
	
	If &IsErro = false
		
		&sdtLocacaoExtra.Clear()
		If not &EstLocExt1.IsEmpty()
			&sdtLocacaoExtraItem = new()
			&sdtLocacaoExtraItem.EstLocExt = &EstLocExt1
			&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		EndIf
		If not &EstLocExt2.IsEmpty()
			&sdtLocacaoExtraItem = new()
			&sdtLocacaoExtraItem.EstLocExt = &EstLocExt2
			&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		Endif
		If not &EstLocExt3.IsEmpty()
			&sdtLocacaoExtraItem = new()
			&sdtLocacaoExtraItem.EstLocExt = &EstLocExt3
			&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		Endif
		If not &EstLocExt4.IsEmpty()
			&sdtLocacaoExtraItem = new()
			&sdtLocacaoExtraItem.EstLocExt = &EstLocExt4
			&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		Endif
		If not &EstLocExt5.IsEmpty()
			&sdtLocacaoExtraItem = new()
			&sdtLocacaoExtraItem.EstLocExt = &EstLocExt5
			&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		Endif
		If not &EstLocExt6.IsEmpty()
			&sdtLocacaoExtraItem = new()
			&sdtLocacaoExtraItem.EstLocExt = &EstLocExt6
			&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		Endif
		If not &EstLocExt7.IsEmpty()
			&sdtLocacaoExtraItem = new()
			&sdtLocacaoExtraItem.EstLocExt = &EstLocExt7
			&sdtLocacaoExtra.Add(&sdtLocacaoExtraItem)
		Endif
		
		GravaLocacao.Call(&Context.EmpCod, &Context.FilCod, &ProCod, &ProGraCod, &EstLoc, &sdtLocacaoExtra)
		GravaNaoGrava.Caption = 'Locação do Produto:' + trim(&CodigoProduto) + ' Atualizada com Sucesso!'
	Else
		msg('Produto não Localizado!')
	EndIF

	&CodigoProduto.SetFocus()

EndEvent

Event &CodigoProduto.IsValid

	&CodigoProduto = trim(&CodigoProduto)
	&NovoProBar = trim(Substr(&CodigoProduto,1, 18))
	RetornaProdutoReferencia.Call(&EmpCod, &NovoProBar, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &mensagemErro)

	do 'LoadEstoque'
	
	do 'loadGridProdutos'
	
//	&EstLoc.SetFocus()

EndEvent

Sub 'loadGridProdutos'

	if &EstLoc.IsEmpty()
		&AuxEstLoc = 'JEAN FAE YEAH'
	Else
		&AuxEstLoc = &EstLoc
	Endif
	
	wcccProduto.Object = wcProdutosDaLocacao.Create(&AuxEstLoc)

EndSub

Sub 'LoadEstoque'

	&sdtLocacaoExtra.Clear()
	
	GravaNaoGrava.Caption = ''
	&IsErro = false
	For Each Order EmpCod, ProCod
		Where EmpCod = &Context.EmpCod
		Where ProCod = &ProCod
		
		&ProNom = ProNom
		
		For each Order EmpCod, FilCod, ProCod, ProGraCod
			Where FilCod = &Context.FilCod
			Where ProGraCod = &ProGraCod
			&EstLoc = EstLoc
			Exit
		EndFor	
		
		&EstLocExt1.SetEmpty()
		&EstLocExt2.SetEmpty()
		&EstLocExt3.SetEmpty()
		&EstLocExt4.SetEmpty()
		&EstLocExt5.SetEmpty()
		&EstLocExt6.SetEmpty()
		&EstLocExt7.SetEmpty()
		
		For each Order EmpCod, FilCod, ProCod, ProGraCod, EstLocExt
			Where FilCod = &Context.FilCod
			Where ProGraCod = &ProGraCod	
			
			do Case
				Case &EstLocExt1.IsEmpty()
					&EstLocExt1 = EstLocExt
				Case &EstLocExt2.IsEmpty()
					&EstLocExt2 = EstLocExt
				Case &EstLocExt3.IsEmpty()
					&EstLocExt3 = EstLocExt
				Case &EstLocExt4.IsEmpty()
					&EstLocExt4 = EstLocExt
				Case &EstLocExt5.IsEmpty()
					&EstLocExt5 = EstLocExt
				Case &EstLocExt6.IsEmpty()
					&EstLocExt6 = EstLocExt
				Case &EstLocExt7.IsEmpty()
					&EstLocExt7 = EstLocExt
			EndCase
		EndFor

	When none
		&ProNom = 'PRODUTO NÃO LOCALIZADO'
		&IsErro = true
	EndFor

EndSub

//Event Refresh
//
//	LoadWWPContext.Call(&Context)
//	&EmpCod = &Context.EmpCod
//	&FilCod = &Context.FilCod
//	
////	do 'loadGridProdutos'
//
//EndEvent
]]></Source>
