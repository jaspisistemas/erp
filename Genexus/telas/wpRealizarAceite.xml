		do 'sair'
	EndIf
	
	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	&TotalMoeda = 0
	&TotaQtd = &SdtPagamentoDuplicata.Count
	For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
		&TotalMoeda += &SdtPagamentoDuplicataItem.CreVlrSdo
	EndFor
	
	txtQtd.Caption = format('Qtd Duplicatas: %1', trim(&TotaQtd.ToFormattedString()))
