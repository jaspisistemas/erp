      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&Context)
	PadraoUsuario.Call('L','MSGCERTIFICADODIGITAL',&Context.PesCod,&Context.EmpCod,&Mensagem,&PadDtaMod)
	&IsSalvarPadrao = true
	Do 'loadFone'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &IsSalvarPadrao = true
		PadraoUsuario.Call('G','MSGCERTIFICADODIGITAL',&Context.PesCod,&Context.EmpCod,&Mensagem,&Today)
	EndIf
	RetornaSoNumeros.Call(&PesFonNum,&PesFonNum)
	&Mensagem += '%0D%0D' 
	//wa.me
//	Open.Target = "https://wa.me/55" + trim(&PesFonNum) + "/?text=" + trim(&Mensagem) + Trim(&Mensagem2) //%0D = Quebra de linha, %20 = Espaço
//	Open.OpenWindow()

	//https://web.whatsapp.com/send?phone=554497538680&text=Ol%C3%A1%20boa%20tarde%21%20Sou%20o%20Agente%20de%20Registro%0DHenrique%20Holtz%20da%20JASPI%20SISTEMAS%20e%20estou%20entrando%20em%20contato%20para%20avisar%20que%20o%20certificado%20digital%20da%20sua%20empresa%20vence%20em%20breve%20conforme%20descrito%20abaixo.%20Precisa%20vir%20o%20administrador%20pessoalmente%2c%20e%20trazer%20um%20documento%20com%20foto%20%28RG%20ou%20CNH%29.%20Ideal%20renovar%20com%20pelo%20menos%202-3%20dias%20antes%20do%20vencimento.%0dRAZ%C3%83O%20SOCIAL%3a%20%2aJASPI%20SISTEMAS%20DE%20INFORMATICA%20LTDA%2a%2c%20%20%20CNPJ%3a%20%2a21.826.923%2f0001-77%2a%2c%20%20VENCIMENTO%20DO%20CERTIFICADO%20DIGITAL%3a%20%2a19%2f11%2f2020%2a&source=&data=&app_absent=
	Open.Target = "https://web.whatsapp.com/send?phone=55" + trim(&PesFonNum) + "&text=" + trim(&Mensagem) + Trim(&Mensagem2) //%0D = Quebra de linha, %20 = Espaço
	Open.OpenWindow()

EndEvent

Sub 'loadFone'

	&Mensagem2.SetEmpty()
	For each order EmpCod, PesCod, PesFonCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		where PesFonCod = &PesFonCod
		if PesTip = 'J'
			&Mensagem2 += 'RAZÃO SOCIAL: *' + PesRaz + '*,   CNPJ: *' + PesCnpj + '*'
		else
			&Mensagem2 += 'NOME: *' + PesRaz + '*,  CPF: *' + PesCpf + '*'
		EndIf
		&Mensagem2 += ',  VENCIMENTO DO CERTIFICADO DIGITAL: *' + PesDtaVctCer.ToFormattedString() + '*'
		&PesFonCon = PesFonCon
		&PesFonConTip = PesFonConTip
		&PesFonNum = PesFonNum
		&PesFonOpe = PesFonOpe
		&PesFonTpo = PesFonTpo
		exit
	EndFor

EndSub


]]></Source>
