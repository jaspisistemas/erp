      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Insert
		&TypeId.RemoveItem("GAMLocal")
		&TypeId.Enabled	= True
	Else
		&TypeId	= GAMAuthenticationTypes.Convert(&TypeIdDsp)
		&TypeId.Enabled	= False		
	Endif
	Do "WCEntry"

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &TypeId.Click

	Do "WCEntry"

EndEvent

Sub "WCEntry"

	Do case	
		Case &TypeId = GAMAuthenticationTypes.Oauth20
			WCEntryPanel.Object = GAMWCAuthenticationTypeEntryOauth20.Create(&Mode, &Name, GAMAuthenticationTypes.Convert(&TypeId))
		Case &TypeId = GAMAuthenticationTypes.Saml20
			WCEntryPanel.Object = GAMWCAuthenticationTypeEntrySaml20.Create(&Mode, &Name, GAMAuthenticationTypes.Convert(&TypeId))
		Otherwise
			If not &TypeId.IsEmpty()
			  WCEntryPanel.Object = GAMWCAuthenticationTypeEntryGeneral.Create(&Mode, &Name, GAMAuthenticationTypes.Convert(&TypeId))
			EndIf
	EndCase

EndSub


]]></Source>
