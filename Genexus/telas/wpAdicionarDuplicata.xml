      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	//RETORNA FORMAS PAGAMENTOS
	RetornaFormasPagamento.Call(&wwpContext.EmpCod, 'R', '', &wwpContext.PesCod, &wwpContext.TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	&PedFrpPgtoCod.Clear()
	For &sdtFormasPagamentoItem in &sdtFormasPagamento	
		&DescricaoVarchar = &sdtFormasPagamentoItem.FrpPgtoCodExib + ' - ' + &sdtFormasPagamentoItem.FrpPgtoNom
		&PedFrpPgtoCod.AddItem(&sdtFormasPagamentoItem.FrpPgtoCod, &DescricaoVarchar)
	EndFor
	//RETORNA FORMAS PAGAMENTOS	
	
	&Codigo3 = 1
	&NfeDupVct = serverdate()
	
//	&Diferenca = 0
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		&NfeNum = NfeNum
		&NfeVlrTot = NfeVlrTot
		Exit
	EndFor

	RetornaTotalDuplicatasNFe.Call(&EmpCod, &FilCod, &NfeCod, &TotMovItmVlr, &CarMovItmVlr, &TotDebVlrDup, &TotCreVlrDup, &TotalMoeda )
	&Diferenca = &NfeVlrTot - &TotalMoeda
//	Endif

	&NfeDupVlr = &Diferenca

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable3.Width = 600

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'ValidaFormaPagamento'
	
	NovaDUplicataNfe_Tipo.Call('ADD', &EmpCod, &FilCod, &NfeCod, 0, '', &NfeDupVct, &NfeDupVlr, &NfeCbrCod, &Codigo3, &PedFrpPgtoCod)
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedFrpPgtoCod.IsValid

	do 'ValidaFormaPagamento'

EndEvent

Sub 'ValidaFormaPagamento'

//	&Codigo3.Enabled = 1
//	Do CAse
//		Case &PedFrpTip = '2' //DINHEIRO
//			&Codigo3 = 1
//			&Codigo3.Enabled = 0
//			
//	EndCase

	if &Codigo3.IsEmpty()
		&Codigo3 = 1
	Endif

EndSub


]]></Source>
