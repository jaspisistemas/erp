        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable7.Width = 190
	UnnamedTable8.Width = 187
	GridMensagens.Rows = Page.Rows
	&GridMensagensCurrentPage = 1
	&GridMensagensCurrentPage.Visible = False
	&GridMensagensPageCount = -1
	&codigo.Visible = False
	GridMensagensPaginationBar.RowsPerPageSelectedValue = GridMensagens.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridMensagensPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	MrkMenSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridMensagensPageCount = gridmensagens.PageCount
	&GridMensagensCurrentPage = gridmensagens.CurrentPage

EndEvent

Event GridMensagens.Load

	&imagemmarketplacemsg.FromImage(retornaImagemMarketplace.Udp(MrkTip))
	&MrkNom = MrkNom

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&selecionaMensagem.FromImage(DDOMultiselOption)
	&selecionaMensagem.TooltipText = ""
	
	&GridActionGroup2.Clear()
	&GridActionGroup2.AddItem(0, 'WWP_ActionGroupCaption')
	&GridActionGroup2.AddItem(1, 'Responder Usuário')
	&GridActionGroup2.AddItem(2, 'Ignorar Pergunta')

	Do Case
		Case MrkMenSts = MarketplaceStatusMensagem.Pendente
			MrkMenSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case MrkMenSts = MarketplaceStatusMensagem.Respondida
			MrkMenSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case MrkMenSts = MarketplaceStatusMensagem.Ignorada
			MrkMenSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			MrkMenSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid2.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&codigo = 1
	txtTitulo.Caption = 'Mensagens'
	txtTitulo1.Caption = 'Sem resposta'
	do 'somamensagenspendentes'
	
	if &Total > 0
		txtQtdMensagens.Class = 'badgeRed'
	Else
		txtQtdMensagens.Class = 'badgeBlack'
	Endif
	
	if &Total > 9
		txtQtdMensagens.Caption = trim(str(&Total))+'+'
	Else
		txtQtdMensagens.Caption = trim(str(&Total))
	Endif
	load //mensagenss
	
	&codigo = 2
	do 'mensagensRespondidasUltimos30dias'
	txtTitulo.Caption = 'Repondidas'
	txtTitulo1.Caption = 'Últimos 30 dias'
	if &Total > 0
		txtQtdMensagens.Class = 'badgeRed'
	Else
		txtQtdMensagens.Class = 'badgeBlack'
	Endif
	if &Total > 9
		txtQtdMensagens.Caption = trim(str(&Total))+'+'
	Else
		txtQtdMensagens.Caption = trim(str(&Total))
	Endif
	load //pedidos
	
	&Total = 0
	&codigo = 3
	do 'mensagensIgnoradasUltimos30dias'
	txtTitulo.Caption = 'Ignoradas'
	txtTitulo1.Caption = 'Últimos 30 dias'
	if &Total > 0
		txtQtdMensagens.Class = 'badgeRed'
	Else
		txtQtdMensagens.Class = 'badgeBlack'
	Endif
	if &Total > 9
		txtQtdMensagens.Caption = trim(str(&Total))+'+'
	Else
		txtQtdMensagens.Caption = trim(str(&Total))
	Endif
	load //pedidos
	
	
//	&Total = 0
////	do 'somapedidosnaolancados'
//	txtTitulo.Caption = 'Pedidos'
//	txtTitulo1.Caption = 'À enviar'
//	if &Total > 0
//		txtQtdMensagens.Class = 'badgeRed'
//	Else
//		txtQtdMensagens.Class = 'badgeBlack'
//	Endif
//	if &Total > 9
//		txtQtdMensagens.Caption = trim(str(&Total))+'+'
//	Else
//		txtQtdMensagens.Caption = trim(str(&Total))
//	Endif
//	load //pedidos

EndEvent

Event GridMensagensPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridMensagensPaginationBar.SelectedPage = !'Previous'
			&GridMensagensCurrentPage -= 1
			GridMensagens.PreviousPage()
		Case GridMensagensPaginationBar.SelectedPage = !'Next'
			&GridMensagensCurrentPage += 1
			GridMensagens.NextPage()
		Otherwise
			&PageToGo.FromString(GridMensagensPaginationBar.SelectedPage)
			&GridMensagensCurrentPage = &PageToGo
			GridMensagens.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridMensagensPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridMensagens.Rows = GridMensagensPaginationBar.RowsPerPageSelectedValue
	&GridMensagensCurrentPage = 1
	GridMensagens.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &GridActionGroup2.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &GridActionGroup2 = 1
			Do 'Do userResponder'
		Case &GridActionGroup2 = 2
			Do 'Do userIgnorar'
	EndCase
	&GridActionGroup2 = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event userResponder_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcResponder.Create(EmpCod, MrkCod, MrkMenId)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

