Sub 'Do userResponder'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	userResponder_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do userIgnorar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'mensagensIgnoradasUltimos30dias'

	&MrkMenDtaHorResp = serverNow()
	&MrkMenDtaHorResp = &MrkMenDtaHorResp.AddDays(-30)
	&Total = 0
	For Each count 10
		Where EmpCod = &EmpCod
		Where MrkMenDtaHorResp >= &MrkMenDtaHorResp
		Where MrkMenSts = MarketplaceStatusMensagem.Ignorada
		
		&Total += 1
	EndFor

EndSub

Sub 'mensagensRespondidasUltimos30dias'

	&MrkMenDtaHorResp = serverNow()
	&MrkMenDtaHorResp = &MrkMenDtaHorResp.AddDays(-30)
	&Total = 0
	For Each count 10
		Where EmpCod = &EmpCod
		Where MrkMenDtaHorResp >= &MrkMenDtaHorResp
		Where MrkMenSts = MarketplaceStatusMensagem.Respondida	
		
		&Total += 1
	EndFor

EndSub

Sub 'somamensagenspendentes'

	&Total = 0
	For Each count 10
		Where EmpCod = &EmpCod
		Where MrkMenSts = MarketplaceStatusMensagem.Pendente
		&Total += 1
	EndFor

EndSub


