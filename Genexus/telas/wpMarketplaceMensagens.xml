	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction2'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpMarketplaces.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DouserPedidos'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpMarketplacePedidos.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DouserSincronizar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	userSincronizar_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event userSincronizar_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

