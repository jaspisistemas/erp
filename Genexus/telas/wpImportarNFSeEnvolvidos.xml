      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	UnnamedTable6.Width = 90
	&FilCod.Visible = False
	&PropriaTerceiros.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult AND not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		wpImportarNFSe(!'Envolvidos', !'Servicos', false, &SessionGuid)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	wpImportarNFSe(!'Envolvidos', !'SelecioneXML', true, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAddDestinatario'

	&sdtPessoa.Clear()
	&webSession.Remove('NOVAPESSOA')
	NotaTemporariaCarregaPessoaNFSe.call(&tmpNFeCod, 'DEST', &sdtPessoa)

	wpNovaPessoa.Popup('CLI', 0, &NomePequeno10)
	wpImportarNFSe(!'Envolvidos', !'Envolvidos', true, &SessionGuid)
	
	do 'LoadTemporaria'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoaddEmitente'

	&sdtPessoa.Clear()
	&webSession.Remove('NOVAPESSOA')
	NotaTemporariaCarregaPessoaNFSe.call(&tmpNFeCod, 'EMIT', &sdtPessoa)

	wpNovaPessoa.Popup('FOR', 0, &NomePequeno10)
	wpImportarNFSe(!'Envolvidos', !'Envolvidos', true, &SessionGuid)
	
	do 'LoadTemporaria'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (&tmpDestxCod = 0)
		BtnAddDestinatario.Visible = False
	Endif 
	If not (&tmpEmixCod = 0)
		BtnaddEmitente.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadVariablesFromWizardData'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&tmpDestxNom = &WizardData.Envolvidos.tmpDestxNom
	&tmpDestxCNPJ = &WizardData.Envolvidos.tmpDestxCNPJ
	&tmpDestxCod = &WizardData.Envolvidos.tmpDestxCod
	&tmpEmixNom = &WizardData.Envolvidos.tmpEmixNom
	&tmpEmixCpfCnpj = &WizardData.Envolvidos.tmpEmixCpfCnpj
	&tmpEmixCod = &WizardData.Envolvidos.tmpEmixCod
	&FilCod = &WizardData.Envolvidos.FilCod
	&PropriaTerceiros = &WizardData.Envolvidos.PropriaTerceiros
	&LctCod = &WizardData.Envolvidos.LctCod
	&NfeNum = &WizardData.Envolvidos.NfeNum
	&NfeDtaEms = &WizardData.Envolvidos.NfeDtaEms
	&NfeChv = &WizardData.Envolvidos.NfeChv

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif
	
	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&tmpNFeCod = &WizardData.SelecioneXML.tmpNFeCod
	
	do 'LoadTemporaria'

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Envolvidos.tmpDestxNom = &tmpDestxNom
	&WizardData.Envolvidos.tmpDestxCNPJ = &tmpDestxCNPJ
	&WizardData.Envolvidos.tmpDestxCod = &tmpDestxCod
	&WizardData.Envolvidos.tmpEmixNom = &tmpEmixNom
	&WizardData.Envolvidos.tmpEmixCpfCnpj = &tmpEmixCpfCnpj
	&WizardData.Envolvidos.tmpEmixCod = &tmpEmixCod
	&WizardData.Envolvidos.FilCod = &FilCod
	&WizardData.Envolvidos.PropriaTerceiros = &PropriaTerceiros
	&WizardData.Envolvidos.LctCod = &LctCod
	&WizardData.Envolvidos.NfeNum = &NfeNum
	&WizardData.Envolvidos.NfeDtaEms = &NfeDtaEms
	&WizardData.Envolvidos.NfeChv = &NfeChv
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	prcAtualizaOperacaoNotaTemporariaNFse.Call(&EmpCod, &tmpNFeCod, &LctCod)

EndSub

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &LctCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Tipo Lcto.'), DVMessageType.error, &LctCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'VerificaNotaPropria'

	&PropriaTerceiros = 'P'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		
		retornaSoNumeros.Call(FilCpj, &FilCpj)
		
		Do CAse
			CAse &FilCpj = &tmpEmixCpfCnpj 
				&PropriaTerceiros = 'P'
				&FilCod = FilCod
				Exit
				
			Case &FilCpj = &tmpDestxCNPJ
				&PropriaTerceiros = 'T'
				&FilCod = FilCod
				Exit
		EndCase
	EndFor

	//Carrega Tipos Lancamentos
	if &LctCod.Count = 0
		For Each ORder EmpCod, LctCod
			Where EmpCod = &EmpCod
			Where ((LctTip = TipoLancamento.EntradaMercadoria and &PropriaTerceiros = 'T') or (LctTip = TipoLancamento.SaidaMercadoria and &PropriaTerceiros = 'P'))
			&LctCod.AddItem(LctCod, LctCodNom)
		EndFor
	Endif

EndSub

Sub 'Loadtemporaria'

	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNFeCod
		&NfeChv = tmpNfeChv
		&NfeDtaEms = tmpNfeDtaEms
		&NfeNum = tmpNfeNum
		//		&NfeSer = tmpNfeSer
		&LctCod = tmpLctCod
		
		&tmpEmixCpfCnpj = tmpEmixCpfCnpj
		
		
		&tmpEmixNom.Link = ''
		&tmpDestxNom.Link = ''
		&tmpEmixNom.LinkTarget = '_blank'
		&tmpDestxNom.LinkTarget = '_blank'
		
		&tmpEmixCod = tmpEmixCod
		&tmpEmixNom = tmpEmixNom
		
		if tmpEmixCod.IsEmpty()
			txtEmitente.Caption = "Prestador NÃO cadastrado!"
		Else
			&tmpEmixNom.Link = verCliente.Link('DashBoard', tmpEmpCod, tmpEmixCod)
			txtEmitente.Caption = ""
		EndIF
		
		//DESTINATARIO
		&tmpDestxCod = tmpDestxCod
		&tmpDestxNom = tmpDestxNom
		If not tmpDestxCNPJ.Trim().IsEmpty()
			&tmpDestxCNPJ = tmpDestxCNPJ
		Else
			&tmpDestxCNPJ = tmpDestxCpf
		EndiF
		
		do 'VerificaNotaPropria'
		if tmpDestxCod.IsEmpty()
			txtDestinatario.Caption = "Tomador NÃO Cadastrado"
		Else
			&tmpDestxNom.Link = verCliente.Link('DashBoard', tmpEmpCod, tmpDestxCod)
			txtDestinatario.Caption = ""
		EndIF
		
		
		//		//TRANSPORTADORA
		//		&tmpTraxCod = tmpTraxCod
		//		&tmpTraxNom = tmpTraxNom
		//		if tmpTraxCod.IsEmpty()
		//			if not tmpTraxNom.IsEmpty()
		//				txtTransportadora.Caption = "Transportadora NÃO Cadastrada"
		//			Else
		//				txtTransportadora.Caption = ""
		//			Endif
		//		Else
		//			&tmpTraxNom.Link = verCliente.Link('DashBoard', tmpEmpCod, tmpTraxCod)
		//			txtTransportadora.Caption = ""
		//		EndIF
		
		txtNota.Caption = ''
		If tmpStsNF = 'S'
			txtNota.Caption = 'NFe Já Lançada! SISTEMA IRÁ ATUALIZAR A NOTA JÁ LANÇADA!'
		EndiF
		
		//		btnWizardNext.Visible = 1
		//		If tmpEmixCod.IsEmpty() or tmpDestxCod.IsEmpty() //or tmpStsNF = 'S'
		//			btnWizardNext.Visible = 0
		//		EndIF
		Exit
	When None
		wwNotasServico.Link()
	EndFor

EndSub


