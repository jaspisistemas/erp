        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	&PedDtaDsp = serverdate()
	&PedHorDsp = servertime()
	&sdtPedidos.FromXml(&WebSession.Get('wpDespachar'))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 10
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridRecordCount = Grid.RecordCount

EndEvent

Event Grid.Load

	For &sdtPedidosItem in &sdtPedidos
		&gridPedCod = &sdtPedidosItem.PedCod
		&gridPesRaz = &sdtPedidosItem.PedCliCodRaz

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
	EndFor
	
	&GridPageCount = Grid.PageCount
	&GridRecordCount = Grid.RecordCount

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PedDtaDsp.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Data Despacho'), DVMessageType.error, &PedDtaDsp.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PedHorDsp.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Hora'), DVMessageType.error, &PedHorDsp.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &PedHorDsp.IsValid

	FormataHORA.call(&PedHorDsp,&PedHorDsp)

EndEvent

Event Enter

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = True
		For &sdtPedidosItem in &sdtPedidos
			GravaDataDespa.Call(&sdtPedidosItem.EmPCod, &sdtPedidosItem.FiLCod, &sdtPedidosItem.PedCod, &PedDtaDsp, &PedHorDsp, &Context.PesCod, &Context.UserName)
		EndFor
		Return
	Endif

EndEvent


]]></Source>
