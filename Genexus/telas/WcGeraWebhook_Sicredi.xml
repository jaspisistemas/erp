      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWpContext.Call(&Context)
	&OqueFazer	= 'R'
	&url	= 'https://adm.jaspi.com.br/webhookSicrediRecebimento.aspx'
	&urlPix	= 'https://adm.jaspi.com.br/webhooksicredirecebimento_pix.aspx'
	Do 'GetLocalCobranca'
	
	&CbrCtaBanAgeCod	= PadL(&parmCbrCtaBanAgeCod, 4, '0')
	&CbrCtaBanAgeDig	= PadL(&parmCbrCtaBanAgeDig, 2, '0')
	&CbrCtaBanCrt		= &parmCbrCtaBanCrt

	&ContaRegistro		= 'Cooperativa: ' + &CbrCtaBanAgeCod + '; Posto: ' + &CbrCtaBanAgeDig + '; codBeneficiario: ' + &CbrCtaBanCrt
	&nomeResponsavel	= 'JASPI Sistemas'
	&eMailResponsavel	= 'contato@jaspi.com.br'
	&numeroResponsavel	= '44 998457962'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Width = 350
	WWPActions.Mask_Apply(&numeroResponsavel.InternalName, !"AA AAAAAAAAA", False, False)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	WWpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCadastrarWebhookPix'

	&IsWebhookCadastrado	= False
	Do Case
		Case &CtaBanPix.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório informar a chave pix da conta.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
			&CtaBanPix.SetFocus()
			
		OtherWise
			&PixPutWebhook.webhookUrl	= &urlPix
			PIXCriaWebhook.Call(&EmpCod, &WWpContext.PesCod, &CbrCod, &CtaBanPix, &PixPutWebhook, &IsWebhookCadastrado, &Mensagem)
			If &IswebhookCadastrado = True
				msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'Webhook cadastrado!', DVMessageType.success, "", DVMessageBoolean.True, ""))
				WWpActions.WCPopup_Close('')
			Else
				msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &Mensagem, DVMessageType.error, "", DVMessageBoolean.True, ""))
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCadastrarWebhook'

	&IsWebhookCadastrado = False
	Do Case
		Case &parmCbrCtaBanAgeCod.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Informação sobre a cooperativa, está vazia.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
		Case &parmCbrCtaBanAgeDig.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Informação sobre o posto, está vazio.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
		Case &parmCbrCtaBanCrt.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Informação sobre a conta, está vazia.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )	
		Case &url.IsEmpty()
			&url.SetFocus()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório informar a url do webhook.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
		Case &nomeResponsavel.IsEmpty()
			&nomeResponsavel.SetFocus()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório informar o nome do responsável.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
		Case &eMailResponsavel.IsEmpty()
			&eMailResponsavel.SetFocus()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório informar o email do responsável.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
		Case &numeroResponsavel.IsEmpty()
			&numeroResponsavel.SetFocus()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório informar o número do responsável.' ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
			
		OtherWise
			If &OqueFazer	= 'R'//registrar
				prcCriaWebhookBoleto_Sicredi.Call(&EmpCod, &CbrCod, &Context.PesCod, &CbrCtaBanAgeCod, &CbrCtaBanAgeDig, &CbrCtaBanCrt, &url, &nomeResponsavel, &eMailResponsavel, &numeroResponsavel, &IsWebhookCadastrado)
				If &IswebhookCadastrado = True
					msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'Webhook cadastrado!', DVMessageType.success, "", DVMessageBoolean.True, ""))
					WWpActions.WCPopup_Close('')
				EndIf
			Else				
				prcAtualizaWebhookBoleto_Sicredi.Call(&EmpCod, &CbrCod, &Context.PesCod, &CbrCtaBanAgeCod, &CbrCtaBanAgeDig, &CbrCtaBanCrt, &url, &nomeResponsavel, &eMailResponsavel, &numeroResponsavel, &IsWebhookCadastrado)
				If &IswebhookCadastrado = True
					msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'Webhook atualizado!', DVMessageType.success, "", DVMessageBoolean.True, ""))
					WWpActions.WCPopup_Close('')
				EndIf
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &OqueFazer.ControlValueChanged

	If &OqueFazer	= 'R'
		btnCadastrarWebhook.Caption	= 'Cadastrar Webhook'
	Else
		btnCadastrarWebhook.Caption	= 'Atualizar Webhook'
	EndIf

EndEvent

Event GXUITabsPanel_Tabs.TabChanged

	If GXUITabsPanel_Tabs.ActivePage	= 1
		If &IsPossuiWebhook	= True
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O sistema já possui um webhook, para estas operações, cadastrado.',DVMessageType.regular, "", DVMessageBoolean.True,"") )
		EndIf
	Else
		If &IsPossuiWebhookPix	= True
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O sistema já possui um webhook, para estas operações, cadastrado.',DVMessageType.regular, "", DVMessageBoolean.True,"") )
		EndIf
	EndIf

EndEvent

Sub 'GetLocalCobranca'

	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&CtaBanPix	= CbrCtaBanPix
		If Not CbrWebhook.IsEmpty()
			&IsPossuiWebhook	= True
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O sistema já possui um webhook, para estas operações, cadastrado. Webhook: ' + Trim(CbrWebhook) ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
			&url	= CbrWebhook
			&OqueFazer	= 'A'
			btnCadastrarWebhook.Caption	= 'Atualizar Webhook'
		EndIf
	
		If Not CbrWebhookPix.IsEmpty()
			&IsPossuiWebhookPix	= True
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O sistema já possui um webhook, para estas operações, cadastrado. Webhook: ' + Trim(CbrWebhookPix) ,DVMessageType.regular, "", DVMessageBoolean.True,"") )
			&urlPix	= CbrWebhookPix
		EndIf
		
		Exit
	EndFor

EndSub


]]></Source>
