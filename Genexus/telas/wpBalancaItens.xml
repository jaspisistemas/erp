Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&BlcCod.Visible = False
	wcItens.Object = wcItensBalanca.Create(&EmpCod, &BlcCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharBal'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWBalanca.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnImprimir'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CodigoProduto.IsValid

	RetornaProdutoReferencia.Call(&EmpCod, &CodigoProduto, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	do 'loadBalanca'

EndEvent

Event Enter

	RetornaProdutoReferencia.Call(&EmpCod, &CodigoProduto, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	if &IsAchouProduto = true
		prcGravaProdutoBalanca.Call(&EmpCod, &BlcCod, &ProCod, &ProGraCod, &BlcQtdVal, &BlcPesUnit, &Mensagem)
		wcItens.Refresh()
		
		&BlcqtdVal = 0
		&CodigoProduto.SetEmpty()
		&CodigoProduto.SetFocus()
	
	else
		msg('Produto não Localizado')
		&CodigoProduto.SetFocus()
	Endif

EndEvent

Sub 'loadBalanca'

	&BlcQtdVal = 0
	&BlcPesUnit = 'P'
	For Each Order EmpCod, BlcCod
		Where EmpCod = &EmpCod
		Where BlcCod = &BlcCod
		Where BlcProCod = &ProCod
		Where BlcProGraCod = &ProGraCod

		&BlcPesUnit = BlcPesUnit
		&BlcQtdVal = BlcQtdVal
		Exit
	EndFor

EndSub


]]></Source>
