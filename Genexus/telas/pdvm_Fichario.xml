Event Refresh

	LoadWWPContext.Call(&Context)
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon020_ClientePadraoVista, &CfgVlr)
	&VisPedCliCod = iif(&CfgVlr = '', 1, val(&CfgVlr))
	
	do 'loadPedido'

EndEvent

Sub 'validaClienteVar'

	&mensagemErro = ''
	&IsClienteErro = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		&PedCliRaz = PesRaz
	
		&PesCodRazSugg = PesCodRazSugg
		
		&PesRaz = PesRaz
		&PesTip = PesTip
		&PesCnpj = PesCnpj
		&PesCpf = PesCpf
		If PesVenAprz = 'S'
			&IsVenderaPrazo = True
		Else
			&IsVenderaPrazo = False
		EndIf
		&PesCliCrd = PesCliCrd
		
		 Do Case
		 	Case PesSts = Status_AtivoInativo.INATIVO
				&mensagemErro = 'Cliente com cadastro inativado, verifique!'
				&IsClienteErro = true
			//Case 
				
		EndCase
		
		&CodigoClienteVar = trim(Str(PesCod))
		
		Exit
	When none
		&IsClienteErro = true
		if &PedCliCod = 0
			&PedCliRaz = 'CLIENTE NÃO INFORMADO'
		Else
			&PedCliRaz = 'CLIENTE NÃO LOCALIZADO'
			&mensagemErro = &PedCliRaz
		EndIF
	Endfor
	
	&NomeCliente = RetornaMesmoValor.udp(&PesCodRazSugg, &EmpCod)
	
	do 'CreditoDisponivel'

EndSub

Sub 'CreditoDisponivel'

	//	&UtilizadoPesCliCrd = RetornaCreditoDisponivelCliente.Udp(&EmpCod, &FilCod, &PedCliCod)
	
	RetornaCreditoCliente.Call(&EmpCod, &PedCliCod, ReceberPagar.Pagar, &CreditoMensagem, &ValorHaverMoeda)
	RetornaCreditoCliente.Call(&EmpCod, &PedCliCod, ReceberPagar.Receber, &CreditoMensagem, &UtilizadoPesCliCrd)
	
	&DisponivelPesCliCrd = (&PesCliCrd + &ValorHaverMoeda) - &UtilizadoPesCliCrd
	//	&UtilizadoPesCliCrd = RetornaCreditoDisponivelCliente.Udp(&EmpCod, &FilCod, &PedCliCod)
	
	&DisponivelPesCliCrd.ForeColor = RGB(0,0,0)
	if &DisponivelPesCliCrd < 0 or &DisponivelPesCliCrd < &PedVlrLiq
		&DisponivelPesCliCrd.ForeColor = RGB(255,0,0)
	Endif

EndSub

Sub 'Confirma'

	&CodigoClienteVar = RetornaSonumeros.Udp(&CodigoClienteVar)
	&PedCliCod = val(&CodigoClienteVar)
	
	do 'validaClientevar'
	If &IsClienteErro = false
		if &SdtConfig_wwpVendas_3.TCon133_BloqPedDebCliente = Status_SimNao.Sim 
			&IsDevendo = false
			&ValorDevendo.SetEmpty()
			RetornaDuplicatasVencidasPDV.Call(&EmpCod,&PedCliCod,&IsDevendo,&ValorDevendo) //depois que validou cliente	
		EndIf
	EndIf

	Do case
		Case &IsClienteErro = true
			&CodigoClienteVar.SetFocus()
			tbConfirmar.Visible = 0
			tbtAutorizacao.Visible = 1
			
		Case &DisponivelPesCliCrd < &PedVlrLiq and &PesCliCrd > 0
			Msg('Limite de Crédito Atingido!, Venda não Autorizada!')
			&mensagemErro = 'Limite de Crédito Atingido!, Venda não Autorizada!'
			tbConfirmar.Visible = 0
			tbtAutorizacao.Visible = 1
			
		case &SdtConfig_wwpVendas_3.Tcon133_BloqPedDebCliente = Status_SimNao.Sim and &IsDevendo = true and &ValorDevendo > 0
			Msg('Cliente com débitos no valor de ' + &ValorDevendo.ToString() + ' ! Venda não autorizada!')
			&mensagemErro = 'Cliente com débitos no valor de ' + &ValorDevendo.ToString() + ' ! Venda não autorizada!'
			tbConfirmar.Visible = 0
			tbtAutorizacao.Visible = 1
			
		Case &IsVenderaPrazo = True // Se pode vender a prazo deixa fechar no crediário
			do 'AprovadoFechamento'
			
		Otherwise
			tbConfirmar.Visible = 0
			tbtAutorizacao.Visible = 1
			&CodigoClienteVar.SetFocus()
			msg('NÃO permitido vender a prazo para cliente informado!')
			&mensagemErro = 'NÃO permitido vender a prazo para cliente informado!'
	Endcase
	
	do 'AttributesSecurityCode'

EndSub

Sub 'AprovadoFechamento'

//	GravaClientePagamento.Call(&EmpCod, &FilCod, &PedCod, 1, &PedCliCod, &PedVlrLiq, &CreDtaVct, 'DEL', 9999)
	
	AlteraCapaPedidoPDV.Call(&EmpCod, &FilCod, &PedCod, &PedCliCod, &NovPesRaz, &NovPesTip, &NovPesCnpj, &PedFicCod,&PedVlrLmt, &Context.UserName)
	&PedDtaFat = serverdate()
	&CreDtaVct = &PedDtaFat + 30
	
//	GravaClientePagamento.Call(&EmpCod, &FilCod, &PedCod, 1, &PedCliCod, &PedVlrLiq, &CreDtaVct, 'ADD', 0)
	
	&sdtPgto = new()
	&sdtPgto.FrpPgtoCod = 1
	&sdtPgto.FrpPgtoTip = TIPODuplicata.DUPLICATA //Deve ser preenchido
	&sdtPgto.OpcaoFechamento = 'U' //UNICA
	&sdtPgto.PedDtaFat = serverdate()
	&sdtPgto.PedTmpCreCliCod = &PedCliCod
	&sdtPgto.FunPesCod = 0
	&sdtPgto.PlanCod = &PlanCod
	&sdtPgto.IsPago = false
	&sdtPgto.CreCbrCod = 0	
	&sdtPgto.creVlrDup = &PedVlrLiq
	&sdtPgto.CreDupNro = ''
	&sdtPgto.CreDtaVct = &CreDtaVct
	MontaDuplicatasPedidoVenda01_JDF.Call('ADD', &EmpCod, &FilCod, &PedCod, &sdtPgto)
	
	AtualizaEstoqueGerencialVenda.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &Context.PesCod, Status_Pedido.FECHADO)
	
	GravaDuplicatasAReceber1.Call(&EmpCod, &FilCod, &PedCod)
	CriticasPedido.Call(&EmpCod, &FilCod, &PedCod, TipoCriticaPedido.FechadoFinanceiro, &Context.PesCod)
	
	GravaNotaTemporariaVenda.Call(&EmpCod, &FilCod, &PedCod, '65')
	
	&tmpNFeCod = trim(str(&EmpCod)) + trim(Str(&FilCod)) + trim(str(&PedCod))
	pdvm_emiteNFCe.Link(&EmpCod, &FilCod, &PedCod, &tmpNFeCod)

EndSub

Sub 'LoadPedido'

	For Each order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedFicCod = PedFicCod
		&CodigoClienteVar = trim(Str(PedCliCod))
		&PesRaz = PedCliRaz
		&PesTip = PedCliTip
		&PesCnpj = PedCliCnpj
		&PesCpf = PedCliCpf
		&PedVlrLiq = PedVlrLiq
		&PedVlrLmt = PedVlrLmt
		
		
		Exit
	When none
	
		&CodigoClienteVar = iif(&SdtConfig_wwpVendas_3.TCon020_ClientePadraoVista.IsEmpty(), '', str(&SdtConfig_wwpVendas_3.TCon020_ClientePadraoVista))
		
	EndFor
	
	&PedCliCod = val(&CodigoClienteVar)
	do 'validaClientevar'

EndSub


