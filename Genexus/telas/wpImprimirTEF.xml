      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each ORder EmpCod, TefCod
		Where EmpCod = &EmpCod
		Where TefCod = &TefCod
		&TefBanCarCod = TefBanCarCod
		Exit
	EndFor

	For Each Order EmpCod, BanCarCod
		Where EmpCod = &EmpCod
		Where BanCarCod = &TefBanCarCod
		&BanCarIsTEF = BanCarIsTEF
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	RetornaTefAutorizado.call(&EmpCod, &TefCod, &TefMsg)
	if not &TefMsg.IsEmpty()
		Do Case
			CAse &BanCarIsTEF = 'L' //LINX
				RCOOpenWindow1.LinkOpen = TEF_LInX.Link(&EmpCod, &TefCod)
				RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			Otherwise				
				RCOOpenWindow1.LinkOpen = TEF_COmPROVANTE_0.Link(&EmpCod, &TefCod)
				RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		EndCase
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirA4'

	RetornaTefAutorizado.call(&EmpCod, &TefCod, &TefMsg)
	if not &TefMsg.IsEmpty()
		RCOOpenWindow1.LinkOpen = TEF_COmPROVANte_A4.Link(&EmpCod, &TefCod)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


