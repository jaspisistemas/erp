Sub 'getProduto'

	&ProNom = ''
	For Each Order EmpCod, ProCod
		where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProNom = ProNom
		if &ProRef.IsEmpty()
			&ProRef = ProRef
		EndIF
	
		exit
	When none
		&IsErroProduto = true
