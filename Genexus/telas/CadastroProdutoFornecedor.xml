      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPFORNECEDORPRODUTO', Status_SimNao.Sim, 2, &AutNiv)
	loadwwPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	mensagem.Caption = ''
	Mensagem.ForeColor = RGB(0,160, 40)
	&ProCod = &parmProCod
	&ProForCod = &parmProForCod
	
	do 'loadCadastroFornecedor'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ProForIcm.TooltipText = "ICMS não soma no custo, utilizado somente para lançamento de Nota Fiscal de Compra."
	&ProForProCod.TooltipText = "Código do Produto no Fornecedor"
	&EmpCod.Visible = False
	&ProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	do Case
		CAse &DeOndeVem = 'P'	
			wpFornecedorProduto.Link(&parmProCod, &DeOndeVem)
		CAse &DeOndeVem = 'R'
			return
		Otherwise
			wpProdutoFornecedor.Link(&parmProForCod)
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event &ProForCod.IsValid

	mensagem.Caption = ''
	&ProForRaz = ''
	&IsErroFornecedor = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &ProForCod
		If PesIsFor = true
			&ProForRaz = PesRaz
		Else
			&IsErroFornecedor = true
			msg('Pessoa informada não está cadastrada como Fornecedor')
		EndIF
		
		exit
		
	When none
		&IsErroFornecedor = true
		msg('Fornecedor não Localizado!')
	EndFor
	
	do 'loadCadastroFornecedor'

EndEvent

Event Enter

	Do Case
		Case &IsErroFornecedor = true
			msg('Fornecedor não Localizado ou não está cadastrada como Fornecedor!')
		Case &IsErroProduto = true
			msg('Produto não Localizado!')
		Otherwise
			GravaProdutoFornecedor.Call(&EmpCod, &ProCod, &ProForCod, &ProForIcmSt, &ProForDsc, &ProForQtdEmb, &ProForVlrCus, &ProForProCod, &ProForProBar, &ProForAcr, &ProForIpi, &ProForIcm, &ProForRatDsc, &ProForRatAcr, &mensagem)
			ProVlrCus_Produto.Submit('ProVlrCus', &EmpCod, &ProCod)
			
			mensagem.Caption = &mensagem
			
			do 'limpaCampos'
	EndCase

EndEvent

Event &ProForVlrCus.IsValid

	do 'totaliza'

EndEvent

Event &ProForQtdEmb.IsValid

	do 'totaliza'

EndEvent

Event &ProForAcr.IsValid

	do 'totaliza'

EndEvent

Event &ProForDsc.IsValid

	do 'totaliza'

EndEvent

Event &ProForIpi.IsValid

	do 'totaliza'

EndEvent

Event &ProForIcmSt.IsValid

	do 'totaliza'

EndEvent

Event &ProForIcm.IsValid

	do 'totaliza'

EndEvent

Event &ProRef.IsValid

	RetornaProdutoReferenciaCapa.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &isAChouProduto, &ErroMensagem)
	
	&IsErroProduto = false
	do 'getProduto'
	
	do 'loadCadastroFornecedor'

EndEvent

Event &ProForProCod.IsValid

	do 'loadCadastroFornecedorCodigoFornecedor'

EndEvent

Sub 'totaliza'

	If &ProForQtdEmb.IsEmpty()
		&ProForQtdEmb = 1
	EndIf	
	
	if &ProForDsc <> 0
		&ProForVlrDsc = (&ProForVlrCus * (&ProForDsc/100))
	Else
		&ProForVlrDsc = 0 
	EndiF
	
	if &ProForAcr <> 0
		&ProForVlrAcr = (&ProForVlrCus * (&ProForAcr/100)) 
	Else
		&ProForVlrAcr = 0
	EndIF

	if &ProForRatDsc <> 0
		&ProForRatVlrDsc = (&ProForVlrCus * (&ProForRatDsc/100))
	Else
		&ProForRatVlrDsc = 0 
	EndiF
	
	if &ProForRatAcr <> 0
		&ProForRatVlrAcr = (&ProForVlrCus * (&ProForRatAcr/100)) 
	Else
		&ProForRatVlrAcr = 0
	EndIF
	
	If &ProForIcmSt <> 0
		&ProForVlrIcmSt = (&ProForVlrCus * (&ProForIcmSt/100)) 
	Else
		&ProForVlrIcmSt = 0 
	EndIF
	
	If &ProForIcm <> 0
		&ProForVlrIcm = (&ProForVlrCus * (&ProForIcm/100)) 
	Else
		&ProForVlrIcm = 0 
	EndIF
	
	If &ProForIpi <> 0
		&ProForVlrIpi = (&ProForVlrCus * (&ProForIpi/100)) 
	Else
		&ProForVlrIpi = 0 
	EndIF
	
	Do CAse
		Case &ProForQtdEmb > 0
			&ProForVlrCusTot = round(((&ProForVlrCus + &ProForVlrIpi + &ProForVlrIcmSt + &ProForVlrAcr + &ProForRatVlrAcr) - (&ProForVlrDsc + &ProForRatVlrDsc) )/ &ProForQtdEmb,5)
		Case &ProForQtdEmb < 0
			&ProForVlrCusTot = round(((&ProForVlrCus + &ProForVlrIpi + &ProForVlrIcmSt + &ProForVlrAcr + &ProForRatVlrAcr) - (&ProForVlrDsc + &ProForRatVlrDsc) ) * (&ProForQtdEmb*-1),5)
		Otherwise
			&ProForVlrCusTot = round(((&ProForVlrCus + &ProForVlrIpi + &ProForVlrIcmSt + &ProForVlrAcr + &ProForRatVlrAcr) - (&ProForVlrDsc + &ProForRatVlrDsc) ),5)
	EndCAse

EndSub

