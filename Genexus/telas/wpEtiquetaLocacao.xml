        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPETIQUETALOCACAO', Status_SimNao.Sim, 1, &AutNiv)
	
	loadwwpContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Gridsdtlocacaos.Rows = Page.Rows
	GridsdtlocacaosPaginationBar.RowsPerPageSelectedValue = Gridsdtlocacaos.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EtqCod = trim(str(&Context.EmpCod)) + trim(str(&Context.FilCod)) + trim(Str(&Context.PesCod))

	if &IsClear = true
		padraoUsuario.Call('G', &EtqCod, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	EndIf

	if 1=2
		abrewpEtiquetaLocacao.Link()
	Endif

EndEvent

Event Refresh

	padraoUsuario.Call('L', &EtqCod, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&sdtlocacao.FromJson(&PadObs)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtlocacaosCurrentPage = Gridsdtlocacaos.CurrentPage
	&GridsdtlocacaosPageCount = Gridsdtlocacaos.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Gridsdtlocacaos.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Remove.FromImage(ActionDelete)
	&Remove.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtlocacaosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtlocacaosPaginationBar.SelectedPage = !'Previous'
			Gridsdtlocacaos.PreviousPage()
		Case GridsdtlocacaosPaginationBar.SelectedPage = !'Next'
			&PageToGo = Gridsdtlocacaos.CurrentPage
			&PageToGo += 1
			Gridsdtlocacaos.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtlocacaosPaginationBar.SelectedPage)
			Gridsdtlocacaos.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtlocacaosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Gridsdtlocacaos.Rows = GridsdtlocacaosPaginationBar.RowsPerPageSelectedValue
	Gridsdtlocacaos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	if &sdtlocacao.Count > 0
//		&Random = (Random() * 10000000)
//		&ArquivoFisico  =  'EtiqPro' + trim(&EtqCod) + trim(str(&Random)) + '.pdf'
		
		&PadObs = &sdtlocacao.ToJson()
		padraoUsuario.Call('G', &EtqCod, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

		RCOOpenWindow1.LinkOpen = RELJAS110.Link(&Context.EmpCod, &Context.FilCod, &Context.PesCod, &EtqCod)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
			
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRemoverEtiquetas'

	&sdtlocacao.Clear()
	&PadObs = &sdtlocacao.ToJson()
	padraoUsuario.Call('G', &EtqCod, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &EstLoc.IsValid

	if &EstQtd = 0
		&Estqtd = 1
	Endif
	&Estqtd.SetFocus()

EndEvent

Event Enter

	&sdtlocacaoItem = new()
	&sdtlocacaoItem.EstLoc = &EstLoc
	&sdtlocacaoItem.EstQtd = &EstQtd
	&sdtlocacao.Add(&sdtlocacaoItem)

	&PadObs = &sdtlocacao.ToJson()
	padraoUsuario.Call('G', &EtqCod, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	&EstLoc.SetFocus()

EndEvent

Event &Remove.Click

	For &sdtlocacaoItem in &sdtlocacao
		if &sdtlocacaoitem.EstLoc = &sdtlocacao.CurrentItem.EstLoc and &sdtlocacaoitem.EstOrd = &sdtlocacao.CurrentItem.EstOrd
			&Index = &sdtlocacao.IndexOf(&sdtlocacaoItem)
			&sdtlocacao.Remove(&index)
		EndIF
	EndFor
	
	&PadObs = &sdtlocacao.ToJson()
	padraoUsuario.Call('G', &EtqCod, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	&EstLoc.SetFocus()

EndEvent


]]></Source>
