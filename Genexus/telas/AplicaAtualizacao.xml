      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbAtualizacao.Width = 500

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Compilacao.Call(true, &Compilacao, &IsExecutaUpdate, &DisEmpVer, &DisEmpCmp)
	if &IsExecutaUpdate = true
		scaProgressBar1.ProcessId = 'UpdateSistema'
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link('UpdateSistema')
		scaProgressBar1.Start()
		
		JaspiReorg.Submit('UpdateSistema', 'UpdateSistema', true, &Compilacao)
	Else
		do 'login'
	EndIf

EndEvent

Event scaProgressBar1.OnComplete

	do 'login'

EndEvent

Sub 'login'

	Login.Link('','')

EndSub


]]></Source>
