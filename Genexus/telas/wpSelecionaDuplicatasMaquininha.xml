Event &btnAdiciona.Click

	&adicionado = false
	
	for &sdtDuplicataItem in &sdtConciliacaoItem.Duplicatas
		if &sdtDuplicataItem.CreCod = CreCod
			&adicionado = true
			exit
		endif
	endfor
	
	if &adicionado
		msg('Duplicata Nº ' + CreDupNro + ' já adicionada à lista!')
		&btnAdiciona.Visible = false
	else
