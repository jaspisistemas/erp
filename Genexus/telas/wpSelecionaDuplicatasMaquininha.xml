		&sdtDuplicataItem.CreCarNroAut  = CreCarNroAut
		&sdtDuplicataItem.CreCarBanNom  = &CreCarBanNom
		&sdtConciliacaoItem.Duplicatas.Add(&sdtDuplicataItem)
		&btnAdiciona.Visible = false
		GridDuplicatasSelecionadas.Refresh()
	endif

EndEvent

Event &botao.Click

	for &sdtDuplicataItem in &sdtConciliacaoItem.Duplicatas
		if &sdtDuplicataItem.CreCod = &gridCreCod
			&sdtConciliacaoItem.Duplicatas.Remove(&sdtConciliacaoItem.Duplicatas.IndexOf(&sdtDuplicataItem))
			exit
		endif
	endfor
	
	GridDuplicatasSugestao.Refresh()
	refresh

EndEvent


