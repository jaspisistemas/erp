      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid_DWC.Class = !'Invisible WCD_' + upper(Grid.InternalName)
	Grid.Rows = 30
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Deletar.Visible = (&Mode = TrnMode.Delete)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&Deletar.ColumnHeaderClass = !'WWIconActionColumn'
	CrePagCod.ColumnHeaderClass = !'WWColumn hidden-xs'
	CrePagDta.ColumnHeaderClass = !'WWColumn'
	CrePagTip.ColumnHeaderClass = !'WWColumn hidden-xs'
	CrePagVlr.ColumnHeaderClass = !'WWColumn hidden-xs'
	CrePagVlrDsc.ColumnHeaderClass = !'WWColumn hidden-xs'
	CrePagVlrJur.ColumnHeaderClass = !'WWColumn hidden-xs'
	CrePagVlrTar.ColumnHeaderClass = !'WWColumn'
	&CreMovCodAux.ColumnHeaderClass = !'WWColumn'
	&DetailWebComponent.ColumnHeaderClass = !'WWIconActionColumn WCD_ActionColumn'
	&CreMovPlanNom.ColumnHeaderClass = !'WWColumn'
	&CreMovCplItem.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar = !'<i class="fas fa-times"></i>'
	
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'

	&Deletar.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWIconActionColumn WWColumnLineThrough WWColumnLineThroughFirstColumn', !'WWIconActionColumn')
	CrePagCod.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	CrePagDta.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough', !'WWColumn')
	CrePagTip.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	CrePagVlr.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	CrePagVlrDsc.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	CrePagVlrJur.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough hidden-xs', !'WWColumn hidden-xs')
	CrePagVlrTar.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&CreMovCodAux.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&DetailWebComponent.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWIconActionColumn WCD_ActionColumn WWColumnLineThrough', !'WWIconActionColumn WCD_ActionColumn')
	&CreMovPlanNom.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&CreMovCplItem.ColumnClass = iif(CrePagSts = Status_CAixa.Cancelado, !'WWColumn WWColumnLineThrough', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CreMovCod = CreMovCod
	&CreMovItmCod  = CreMovItmCod
	&CreMovCodAux = CreMovCod.ToString() + '/' + CreMovItmCod.ToString()
	&Deletar.Visible = (CrePagSts <> Status_CAixa.Cancelado)
	&DetailWebComponent.Visible = (CrePagSts <> Status_CAixa.Cancelado)
	do 'LocalizaLancamentoCaixa'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DetailWebComponent.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_DWC.Object = wcDadosLancamentoNota.Create(EmpCod, CreMovCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Deletar.Click

	wpConfirmaRemocaoPagamento.Popup(EmpCod,FilCod,CreCod,CrePagCod)
	Refresh

EndEvent

Sub 'LocalizaLancamentoCaixa'

	&CreMovCplItem.SetEmpty()
	&CreMovPlanCod.SetEmpty()
	&CreMovPlanNom.SetEmpty()
	
	if not &CreMovCod.IsEmpty()
		For Each Order EmpCod, MovCod, MovCreCod
			Where EmpCod = &EmpCod
			Where MovCod = &CreMovCod
			Where MovCreCod = &CreCod
			
			&CreMovPlanCod = PlanCod
			&CreMovPlanNom = PlanHie.Trim() + ' - ' + PlanNom.Trim()
			&CreMovCplItem = MovCplMan.Trim() + ' ' + MovItmCpl.Trim()
			&CreMovCplItem = &CreMovCplItem.Trim()
			Exit
		When none
			For Each Order EmpCod, MovCod
				Where EmpCod = &EmpCod
				Where MovCod = &CreMovCod
				//Where MovCreCod = &MovCreCod
				
				&CreMovPlanCod = PlanCod
				&CreMovPlanNom = PlanHie.Trim() + ' - ' + PlanNom.Trim()
				&CreMovCplItem = MovCplMan.Trim() + ' ' + MovItmCpl.Trim()
				&CreMovCplItem = &CreMovCplItem.Trim()
				Exit
			EndFor
			
		EndFor
	EndIf

EndSub

//Event &Deletar.Click
