      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FiLCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&DeOndeVem = &WizardData.SelecionarXML.DeOndeVem
	If &DeOndeVem.IsEmpty()
		Dashboard.Link()
	EndIF

	&NomeTemporario = &DeOndeVem.Trim() + 'IMPXMLCOMPRA' + trim(str(&Context.EmpCod)) + trim(Str(&Context.PesCod)) + '-'
	&tmpNFeCod = &NomeTemporario + '1'
	
	do 'loadTemporaria'

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		ImportarXmlCompra(!'Totais', !'GravaNf', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	ImportarXmlCompra(!'Totais', !'Produtos', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&tmpTotNFe = &WizardData.Totais.tmpTotNFe
	&tmpTotPro = &WizardData.Totais.tmpTotPro
	&tmpNfePesBrt = &WizardData.Totais.tmpNfePesBrt
	&tmpNfePesLiq = &WizardData.Totais.tmpNfePesLiq
	&tmpNfeQtdVol = &WizardData.Totais.tmpNfeQtdVol
	&tmpNfeEspVol = &WizardData.Totais.tmpNfeEspVol
	&tmpNfeVlrFrt = &WizardData.Totais.tmpNfeVlrFrt
	&tmpTotFrt = &WizardData.Totais.tmpTotFrt
	&tmpNfePerDsc = &WizardData.Totais.tmpNfePerDsc
	&tmpNfeVlrDsc = &WizardData.Totais.tmpNfeVlrDsc
	&tmpTotBasIcm = &WizardData.Totais.tmpTotBasIcm
	&tmpTotBasSt = &WizardData.Totais.tmpTotBasSt
	&tmpVlrSt = &WizardData.Totais.tmpVlrSt
	&tmpTotIpi = &WizardData.Totais.tmpTotIpi
	&tmpTotSeg = &WizardData.Totais.tmpTotSeg
	&tmpTotOut = &WizardData.Totais.tmpTotOut
	&tmpTotDsc = &WizardData.Totais.tmpTotDsc
	&tmpTotPed = &WizardData.Totais.tmpTotPed
	&tmpManNfeDadAdi = &WizardData.Totais.tmpManNfeDadAdi

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Totais.tmpTotNFe = &tmpTotNFe
	&WizardData.Totais.tmpTotPro = &tmpTotPro
	&WizardData.Totais.tmpNfePesBrt = &tmpNfePesBrt
	&WizardData.Totais.tmpNfePesLiq = &tmpNfePesLiq
	&WizardData.Totais.tmpNfeQtdVol = &tmpNfeQtdVol
	&WizardData.Totais.tmpNfeEspVol = &tmpNfeEspVol
	&WizardData.Totais.tmpNfeVlrFrt = &tmpNfeVlrFrt
	&WizardData.Totais.tmpTotFrt = &tmpTotFrt
	&WizardData.Totais.tmpNfePerDsc = &tmpNfePerDsc
	&WizardData.Totais.tmpNfeVlrDsc = &tmpNfeVlrDsc
	&WizardData.Totais.tmpTotBasIcm = &tmpTotBasIcm
	&WizardData.Totais.tmpTotBasSt = &tmpTotBasSt
	&WizardData.Totais.tmpVlrSt = &tmpVlrSt
	&WizardData.Totais.tmpTotIpi = &tmpTotIpi
	&WizardData.Totais.tmpTotSeg = &tmpTotSeg
	&WizardData.Totais.tmpTotOut = &tmpTotOut
	&WizardData.Totais.tmpTotDsc = &tmpTotDsc
	&WizardData.Totais.tmpTotPed = &tmpTotPed
	&WizardData.Totais.tmpManNfeDadAdi = &tmpManNfeDadAdi
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'loadTemporaria'

	For Each Order tmpNFeCod
		WHere tmpNFeCod = &tmpNFeCod
		if tmpPedCliCnpj.IsEmpty()
			&ForCNPJ = tmpPedCliCpf
		Else
			&ForCNPJ = tmpPedCliCnpj
		EndIF
		&NfeChv = tmpNfeChv
		&tmpEmixCod = tmpEmixCod
		&tmpEmixNom = tmpEmixNom
		&tmpNfeVlrDsc = tmpNfeVlrDsc
		&tmpNfePerDsc = tmpNfePerDsc
		&tmpNfePesBrt = tmpNfePesBrt
		&tmpNfePesLiq = tmpNfePesLiq
		&tmpNfeQtdVol = tmpNfeQtdVol
		&tmpNfeEspVol = tmpNfeEspVol
		&tmpNfeVlrFrt = tmpNfeVlrFrt
		&tmpManNfeDadAdi = tmpManNfeDadAdi
		&tmpTotPro = tmpTotPro
		&tmpTotBasIcm = tmpTotBasIcm
		&tmpTotBasSt = tmpTotBasSt 
		&tmpVlrSt = tmpVlrSt
		&tmpTotFrt = tmpTotFrt
		&tmpTotSeg = tmpTotSeg
		&tmpTotOut = tmpTotOut 
		&tmpTotDsc = tmpTotDsc
		&tmpTotPed = tmpTotPed
		&tmpTotIpi = tmpTotIpi
		&tmpTotNFe = tmpTotNFe
		Exit
	EndFor

EndSub


