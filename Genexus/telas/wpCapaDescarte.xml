Event Start

	RetornaAutorizacao.Call('WWDESCARTE', Status_SimNao.Sim, 2, &AutNiv)
	
	&Empcod = &parEmpCod
	&FilCod = &parFiLCod
	&PedCod = &parPedCod
	
	LoadWWPContext.Call(&WwpContext)	
	tbfilialLancamento.Visible = 0	
	
	if &parPedCod.IsEmpty()
		btnItensPedido.Visible = 0
		btnImprimir.Visible = 0
		
		if &WwpContext.FilialLancamento.Count > 1
			for &FilialLancamento in &WwpContext.FilialLancamento
				if &FilialLancamento.PesFilAce = &FilCod
					tbFilialLancamento.Visible = 1
					txtFilialLancamento.Caption = &FilialLancamento.PesFilRaz
					txtFilialLancamento.ForeColor = RGB(255,0,0)
					Exit
				Endif
			EndFor
		ENdif
	
		&Empcod = &WwpContext.EmpCod
		&FilCod = &WwpContext.FilCod
		&PedDtaEms = serverdate()
		&PedVenCod = &WwpContext.PesCod
		
		//CLIENTE DA FILIAL
		For Each ORder EmpCod, FilCod
			Where EmpCod = &Empcod
			Where FilCod = &FilCod
			
			&PedCliCod = FilPesCod			
			&TabCod = FilTabCod
			&TabPrmCod = FilTabPrmCod	
			&TabColCod = FilTabColCod		
			Exit
			
		EndFor		
	
		Do 'LoadCliente'
	Else
		Do 'loadPedido'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PedVlrOutCus.TooltipText = "Custo pago pela Empresa, não acrescido no valor do pedido."
	tbCliente.Width = 600
	UnnamedTable8.Width = 400
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	&LctCod.Visible = False
	Do 'LoadComboLctCod'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraTelevendas'

	wwDescarte.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

