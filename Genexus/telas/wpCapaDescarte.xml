	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Combo_LctCod.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&LctCod.FromString(Combo_LctCod.SelectedValue_get)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadComboLctCod'

	For Each Order EmpCod, LctTip, LctCod
		Where EmpCod = &EmpCod
		Where LctTip = TipoLancamento.OutrasSaidas
		&Combo_DataItem = new()
		&Combo_DataItem.ID = LctCod.ToString().Trim()
		&Combo_DataItem.Title = LctCodNom
		&LctCod_Data.Add(&Combo_DataItem)
		if &LctCod = 0
			&LctCod = LctCod
		Endif
	EndFor
	Combo_LctCod.SelectedValue_set = iif(&LctCod.IsEmpty(), '', &LctCod.ToString().Trim())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//&LctCod initial value has to be loaded manually at the beginning of this Subrutine
	//&LctCod_Data has to be loaded manually at the beginning of this Subrutine
	Combo_LctCod.SelectedValue_set = iif(&LctCod.IsEmpty(), '', &LctCod.ToString().Trim())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &PedCliCodVar.IsValid

	retornaSoNumeros.Call(&PedCliCodVar, &PedCliCodVar)
	&PedCliCod = val(&PedCliCodVar)
	
	if &PedCliCod <> 0
		do 'LoadCliente'
	Else
		&PesRazVar = ''
	Endif

EndEvent

Event &PesRazVar.IsValid

	RetornaCodigoPEssoaSugestNome.Call(&EmpCod, &PesRazVar, &PedCliCod)
	if &PesRazVar.IsEmpty() //and not &PedCliCodVar.IsEmpty()
		&PedCliCod = 0
		&PedCliCodVar = ''
	Else
		do 'loadCliente'
	Endif

EndEvent

Event Enter

	do 'GravarPedidoVendas'

EndEvent

Sub 'GravarPedidoVendas'

	Do Case
		CAse &OqueFazer = 'INS'
			&mode = TrnMode.Insert
		Case &OqueFazer = 'UPD'
			&mode = TrnMode.Update
	EndCase
	
	do 'CarregaSdt'
	
	GravaPedidovenda.Call(&Mode, &Empcod, &FilCod, &PedCod, &SdtGravaPedido, &WwpContext.PesCod, &WwpContext.UserName)
	
	wpItensOutrasSaidas.Link(&Empcod, &FilCod, &PedCod)

EndSub

