Sub 'LoadCliente'

	&IsErroCliente = false
	&PesCodRazSugg = ''
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		
		&PesCodRazSugg = PesCodRazSugg
		&PedCliCodVar = trim(str(&PedCliCod))
		
		Exit
	When none
		&IsErroCliente = true
		&mensagem = 'Cliente é obrigatório!'
		do 'mensagemErro'
	EndFor
	
	&PesRazVar = &PesCodRazSugg

EndSub

Sub 'mensagemErro'

	if &IsNoMensagem <> true
		Msg( &mensagem)
	Endif

EndSub

Sub 'loadPedido'

	CarregaSdtPedidoVenda.Call(&Empcod, &FilCod, &PedCod, &SdtGravaPedido)

	&PedCliCod = &SdtGravaPedido.PedCliCod
	&PedDtaEms = &SdtGravaPedido.PedDtaEms
	&LctCod = &SdtGravaPedido.LctCod
	&PedObsGer = &SdtGravaPedido.PedObsGer
	&PedVlrOut = &SdtGravaPedido.PedVlrOut
	&PedFrtFix = &SdtGravaPedido.PedFrtFix
	&PedVlrDscGlb = &SdtGravaPedido.PedVlrDscGlb
	&PedVlrOutCus = &SdtGravaPedido.PedVlrOutCus
	&PedVenCod = &SdtGravaPedido.PedVenCod
	&PedCliCod = &SdtGravaPedido.PedCliCod
	
	&TabCod = &SdtGravaPedido.TabCod
	&TabPrmCod = &SdtGravaPedido.TabPrmCod	
	&TabColCod = &SdtGravaPedido.TabColCod		
			
	Do 'LoadCliente'

EndSub


