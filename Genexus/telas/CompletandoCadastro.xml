      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each Order EmpCod 
		Where EmpCod = &EmpCod
		
		&EmpStsImp = EmpStsImp
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable4.Width = 800
	UnnamedTable3.Width = 800
	UnnamedTable3.Height = 40
	TableContent.Width = 800
	TableContent.Height = 150
	UnnamedTable2.Width = 800
	UnnamedTable2.Height = 100
	UnnamedTable1.Width = 800
	UnnamedTable1.Height = 50

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &EmpStsImp < 100
		&Random = Random() * 1000000000
		&ProgressId = 'CompletaCadastro' + trim(str(&EmpCod)) + trim(str(&Random))
		&ProgressId = &ProgressId.trim()
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		PrcCadastroPadrao.Submit(&ProgressId, &ProgressId, &EmpCod, &EmpCodSec)
	Else
		TudoPronto.Link(&EmpCod, &EmpCodSec)
	EndIF

EndEvent

Event scaProgressBar1.OnComplete

	apagaProgress.call(&ProgressId)
	TudOPronto.Link(&EmpCod, &EmpCodSec)

EndEvent


]]></Source>
