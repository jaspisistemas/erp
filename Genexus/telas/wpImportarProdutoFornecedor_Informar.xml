      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SdtProdutoFornecedor.FromJson(&WebSession.Get('LISTWPPRODUTFORNECEDOR'))
	&SdtProdutoFornecedorOK.FromJson(&WebSession.Get('LISTWPPRODUTFORNECEDOR_OK'))
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesCodRaz = PesCodRaz
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	do 'localizaproduto'

EndEvent

Event Enter

	do 'localizaproduto'
	if &IsErro = false
		GravaProdutoFornecedor.Call(&EmpCod, &ProCod, &PesCod, 0,0,1,0,&ProForProCod,&ProForProBar, 0,0,0,0,0,&mensagem)
		For &SdtProdutoFornecedorItem in &SdtProdutoFornecedor
			If &SdtProdutoFornecedorItem.ProForProCod = &ProForProCod
				
				&SdtProdutoFornecedorOKItem = new()
				&SdtProdutoFornecedorOKItem.ProNom = &ProNom
				&SdtProdutoFornecedorOKItem.ProRef = &ProRef
				&SdtProdutoFornecedorOKItem.ProCod = &ProCod
				&SdtProdutoFornecedorOKItem.ProRefPadL = &ProRefPadL
				&SdtProdutoFornecedorOKItem.Erro = 'N'
				&SdtProdutoFornecedorOKItem.Mensagem = ''
				&SdtProdutoFornecedorOKItem.EmpCod       = &SdtProdutoFornecedorItem.EmpCod
				&SdtProdutoFornecedorOKItem.ProForProCod = &SdtProdutoFornecedorItem.ProForProCod
				&SdtProdutoFornecedorOKItem.ProForProNom = &SdtProdutoFornecedorItem.ProForProNom
				&SdtProdutoFornecedorOKItem.ProForVlrCus = &SdtProdutoFornecedorItem.ProForVlrCus
				&SdtProdutoFornecedorOKItem.ProForQtdEmb = &SdtProdutoFornecedorItem.ProForQtdEmb
				&SdtProdutoFornecedorOKItem.ProForDsc    = &SdtProdutoFornecedorItem.ProForDsc
				&SdtProdutoFornecedorOKItem.ProForAcr    = &SdtProdutoFornecedorItem.ProForAcr
				&SdtProdutoFornecedorOKItem.ProForRatDsc    = &SdtProdutoFornecedorItem.ProForRatDsc
				&SdtProdutoFornecedorOKItem.ProForRatAcr    = &SdtProdutoFornecedorItem.ProForRatAcr
				&SdtProdutoFornecedorOKItem.ProForIcmSt  = &SdtProdutoFornecedorItem.ProForIcmSt
				&SdtProdutoFornecedorOKItem.ProForIpi    = &SdtProdutoFornecedorItem.ProForIpi
				&SdtProdutoFornecedorOK.Add(&SdtProdutoFornecedorOKItem)
				
				&Index = &SdtProdutoFornecedor.IndexOf(&SdtProdutoFornecedorItem)
				&SdtProdutoFornecedor.Remove(&index)
				Exit
			EndiF
		EndFor
	
		&WebSession.Set('LISTWPPRODUTFORNECEDOR', &SdtProdutoFornecedor.ToJson())
		&WebSession.Set('LISTWPPRODUTFORNECEDOR_OK', &SdtProdutoFornecedorOK.ToJson())
		
		Return
	EndIF

EndEvent

Sub 'localizaproduto'

	&ProNom.SetEmpty()
	&ProCod.SetEmpty()
	&ProRefPadL.SetEmpty()
	
	&IsErro = false
	For Each Order EmpCod,ProForCod, ProRef, ProCod
		Where EmpCod = &EmpCod
		Where ProForCod = &PesCod
		Where ProRef = &ProRef
		Where ProForProCod <> &ProForProCod
		&ProNom = ProNom
		&IsErro = true
		msg('Produto: ' + trim(&ProRef) + ' já cadastrado no fornecedor com o código: ' + trim(ProForProCod))
		Exit
	When none
		
		For Each order EmpCod, ProCod
			Where EmpCod = &EmpCod
			Where ProRef = &ProRef
			where ProSts <> Status_Produto.EXCLUIDO
			&ProNom = ProNom
			&ProCod = ProCod
			&ProRefPadL = ProRefPadL
			
			If ProSts = Status_Produto.INATIVO
				msg('Produto código: '+trim(ProRef)+ ' Inativo!')
				&IsErro = true
			EndIf
			
			Exit
		When none
			msg('Produto código: '+trim(&ProRef)+ ' Não Localizado!')
			&IsErro = true
		EndFor
	
	EndFor

EndSub


]]></Source>
