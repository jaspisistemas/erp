      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	&TcpAno = &parTcpAno 
	&TcpMes = &parTcpMes
	&TcpForCod = &ParTcpForCod
	
	if &TcpAno.IsEmpty()
		&TcpAno = Year(serverDate())
		&TcpMes = month(serverdate())
	EndIf

	do 'loadDadosProducao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TcpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &TcpAno < 2010 or &TcpAno > Year(ServerDate())
		msg('Ano inferior à 2010 e superior ao Ano Atual!')
	Else
		GravaDadosCustoProducao.Call(&EmpCod, &TcpAno, &TcpMes, &TcpForCod, &TcpQtdFun,&TcpVlrCus,&TcpDias)
		
		if &parTcpAno.IsEmpty()
			msg('Salvo com sucesso!')
			&TcpAno.SetFocus()
		Else
			return
		EndIf
	EndIf

EndEvent

Event &TcpForCod.IsValid

	do 'LoadDadosProducao'
	RetornaTotalRateado.Call(&EmpCod, &TcpAno, &TcpMes, &TcpForCod, &FinVlr)

EndEvent

Sub 'loadDadosProducao'

	For Each Order EmpCod, TcpCod
		Where EmpCod = &EmpCod
		Where TcpAno = &TcpAno
		Where TcpMes = &TcpMes
		Where TcpForCod = &TcpForCod
		&TcpQtdFun = TcpQtdFun
		&TcpVlrCus = TcpVlrCus
		&TcpDias = TcpDias
		Exit
	EndFor

EndSub


]]></Source>
