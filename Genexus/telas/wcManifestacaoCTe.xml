      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	ManNro.ColumnHeaderClass = !'WWColumn'
	ManTip.ColumnHeaderClass = !'WWColumn'
	ManSitNFe.ColumnHeaderClass = !'WWColumn'
	ManSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridCurrentPage = Grid.currentPage

EndEvent

Event Grid.Load

	&PesCnpj = ManCpfCnpj
	&FormatadoPesCnpj = ManCpfCnpj
	RetornaSoNumeros.Call(&PesCnpj, &PesCnpj)
	if not &FormatadoPesCnpj.IsEmpty()
		ValidaCpfCnpj.Call(&FormatadoPesCnpj, &Erro, 'N')
	EndIF
	do 'getFornecedor'
	&CteNum = ManNro
	&varManCod = trim(str(ManModCod))
	
	VerificaCteJahLancado.Call(EmpCod, ManFilCod, &NfeCliCod, &CteNum, ManSer, &varManCod,  &CteCod )

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&groupaction.Clear()
	&groupaction.AddItem(0, 'WWP_ActionGroupCaption')
	If (ManXmlNfe.trim().IsEmpty())
		&groupaction.AddItem(1, 'Download XML')
	Endif
	If (not ManXmlNfe.trim().IsEmpty())
		&groupaction.AddItem(2, 'Imprimir NFe')
	Endif
	If (not ManXmlNfe.trim().IsEmpty())
		&groupaction.AddItem(3, 'Exporta Xml')
	Endif
	&groupaction.AddItem(4, 'Chave do CTe')
	&groupaction.AddItem(5, 'Excluir registro')

	ManNro.ColumnClass = iif(&CTeCod > 0, !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell', !'WWColumn')
	Do Case
		Case ManTip = EntradaSaida.Entrada
			ManTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case ManTip = EntradaSaida.Saida
			ManTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Otherwise
			ManTip.ColumnClass = 'WWColumn'
	EndCase
	Do Case
		Case ManSitNFe = Situacao_Nfe.AUTORIZADO
			ManSitNFe.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case ManSitNFe = Situacao_Nfe.DENEGADA
			ManSitNFe.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case ManSitNFe = Situacao_Nfe.CANCELADA
			ManSitNFe.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			ManSitNFe.ColumnClass = 'WWColumn'
	EndCase
	Do Case
		Case ManSts = Status_DFe.NaoManifestado
			ManSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case ManSts = Status_DFe.Confirmacao
			ManSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case ManSts = Status_DFe.Desconhecido
			ManSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case ManSts = Status_DFe.Ciencia
			ManSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case ManSts = Status_DFe.NaoRealizada
			ManSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			ManSts.ColumnClass = 'WWColumn'
	EndCase
	&ManCodWithTags.HorizontalAlignment = !'Right'
	&ManCodWithTags = trim(ManCod.ToFormattedString())
	If ManXmlNfe.trim().IsEmpty()
		&ManCodWithTags = format(!"<i class='fa fa-circle FontColorIconDanger FontColorIconSmall TagBeforeText BootstrapTooltipTop' title='%1'></i>", "Sem Xml") + &ManCodWithTags
	EndIf
	If Not ManXmlNfe.trim().IsEmpty()
		&ManCodWithTags = format(!"<i class='fa fa-circle FontColorIconSuccess FontColorIconSmall TagBeforeText BootstrapTooltipTop' title='%1'></i>", "Com Xml") + &ManCodWithTags
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &groupaction.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &groupaction = 1
			Do 'Do SincronizarIndividual'
		Case &groupaction = 2
			Do 'Do GeraNota'
		Case &groupaction = 3
			Do 'Do ExportarXml'
		Case &groupaction = 4
			Do 'Do Chave'
		Case &groupaction = 5
			Do 'Do ExcluirRegistro'
	EndCase
	&groupaction = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_ExcluirRegistro.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_ExcluirRegistro.Result = !'Yes'
		Do 'Do Action ExcluirRegistro'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do SincronizarIndividual'

	GeraXmlSincroManifestIndividualCte.Call(EmpCod,&ManFilCod,'S',ManCod,ManCha,&SolCod)
	Tablepercent.Visible = true
	tbResult.Visible = false
	&Random = random()* 10
	&ProgressId = 'SincroDFe' + trim(Str(&wwpContext.EmpCod)) + trim(Str(&wwpContext.FilCod)) + trim(Str(&wwpContext.PesCod)) + trim(str(&Random))
	&ProgressId = &ProgressId.trim()
	scaProgressBar2.ProcessId = &ProgressId
	scaProgressBar2.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar2.Start()
	
	RecepcaoDFe.Submit('RecepcaoDFe', &ProgressId, &EmpCod, &ManFilCod, &ManFilCod, &SolCod)
	txtMsg.Caption = ''

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do GeraNota'

	&CteArqXml = RetornaXmlManifestacao.udp(EmpCod, ManCod)
	If not &CteArqXml.IsEmpty() 		
		
		GeraPdfDacte_Manifestacao.Call(EmpCod, ManCod, &UrlPDF, &UrlFisico)
		RCOOpenWindow1.LinkOpen = link(&UrlPDF)// RELJAS085.Link(EmpCod, FilCod, CteCod,'DACTE')
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)		
	
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do ExportarXml'

	&CteArqXml = RetornaXmlManifestacao.udp(EmpCod, ManCod)
	If not &CteArqXml.Trim().IsEmpty()
		&NomArq = &SdtConfiguracoesPasta.PastaDiretorioTempFis+ trim(ManCha)+'.xml'
		
		&file.Source = &NomArq
		
		If  &file.Exists() 
			&file.Delete()
		EndIf
		&ResultadoAbertura = DfwOpen(&NomArq,'','', 0, 'ISO-8859-1') 
		&ResultadoNext =  dfwptxt(&CteArqXml)// Grava Linha 			
		&ResultadoNext = DFWNext()
		&ResultadoAbertura = dfwclose()
		&link = &SdtConfiguracoesPasta.PastaDiretorioTempVir+ trim(ManCha)+'.xml'
		link(&link)
	Else
		Msg('ATENÇÃO! Arquivo Xml vazio contate o suporte.')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do Chave'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ChaveNfe.PopUp(ManCha)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do ExcluirRegistro'

	&EmpCod_Selected = EmpCod
	&ManCod_Selected = ManCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_ExcluirRegistro.Confirm()

