        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPSELECIONARFATURAR', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&PedDtaEmsFin = serverdate()
	&PedDtaFatFin = serverdate()
	&PedDtaEmsIni = &PedDtaEmsFin.AddMonths(-6)
	&PedDtaFatIni = &PedDtaEmsFin.AddMonths(-6)
	&PedSts.SetEmpty()
	&PedStsFin.SetEmpty()
	&PedidosComNF = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = Page.Rows
	GridsdtPedidossPaginationBar.RowsPerPageSelectedValue = GridsdtPedidoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtPedidossCurrentPage = GridsdtPedidoss.CurrentPage
	&GridsdtPedidossPageCount = GridsdtPedidoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionSelecione.FromImage(DDOMultiselSelOption)
	&ActionSelecione.TooltipText = ""
	
	&Imprimir = !'<i class="far fa-file-pdf"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &sdtPedidos.CurrentItem.Localizado = 'N'
		&ActionSelecione.FromImage(DDOMultiselOption)
	Endif
	
	prcStatusPedidoRGB.Call(&EmpCod, &sdtPedidos.CurrentItem.PedNovStsFinNom, &R, &G, &B )
	sdtPedidos__PedNovStsFinNom.ForeColor = RGB(&R, &G, &B)
	
	prcStatusPedidoRGB.Call(&EmpCod, &sdtPedidos.CurrentItem.PedNovStsNom, &R, &G, &B )
	sdtPedidos__PedNovStsNom.ForeColor = RGB(&R, &G, &B)

EndEvent

Event GridsdtPedidossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Previous'
			GridsdtPedidoss.PreviousPage()
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtPedidoss.CurrentPage
			&PageToGo += 1
			GridsdtPedidoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtPedidossPaginationBar.SelectedPage)
			GridsdtPedidoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = GridsdtPedidossPaginationBar.RowsPerPageSelectedValue
	GridsdtPedidoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEmitirNFe'

//	&AuxSdtPedidos = &sdtPedidos
//	&IsUmSelecionado = false
	
//	For &AuxSdtPedidosItem in &AuxSdtPedidos
//		If &AuxSdtPedidosItem.Localizado <> 'S'
//			&Index = &AuxSdtPedidos.IndexOf(&AuxSdtPedidosItem)
//			&AuxSdtPedidos.Remove(&Index)
////		Else
////			&IsUmSelecionado = true
//		Endif
//	EndFor
	
//	if &AuxSdtPedidos.Count > 1
//		msg('Nenhum Pedido selecionado para emissão!')
//	Else		
		GravaagrupamentoTotal_Faturar.Call(&sdtPedidos, &wwpContext.PesCod, &wwpContext.UserName, &Mensagem, &IsErroPedido, &destinoPedCod)		
		
		if &destinoPedCod > 0 //and &IsErroPedido = false
			wpSelecionarFaturar_Capa.Link('WPSELECIONARFATURAR', &wwpContext.EmpCod, &wwpContext.FilCod, &destinoPedCod)
		Else
			msg(&Mensagem)
		EndIf
	
//	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMarcar'

	For Each line in gridsdtPedidoss
		&sdtPedidos.CurrentItem.Localizado = 'S'
		&ActionSelecione.FromImage(DDOMultiselSelOption)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndFor
	
	do 'Totaliza'

EndEvent

Event Enter

	prcSelecionaPedidos.Call(&EmpCod, &wwpContext.FilCod, &PesCod, &PedDtaEmsIni, &PedDtaEmsFin, &PedDtaFatIni, &PedDtaFatFin, &PedSts, &PedStsFin, &TipoPedido, &LCtCod, &PedidosComNF, &sdtPedidos)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event limpar_campo.Click

	&AuxSdtPedidos = &sdtPedidos
	For &AuxSdtPedidosItem in &AuxSdtPedidos
		If &AuxSdtPedidosItem.Localizado = 'S'
			&AuxSdtPedidosItem.Localizado = 'N'
		Endif
	EndFor
	&sdtPedidos = &AuxSdtPedidos
	
	do 'Totaliza'
	refresh

EndEvent

Event &LCtCod.IsValid

	&LctNom = 'TODOS TIPOS LANCAMENTOS'
	if &LCtCod > 0
		For Each Order EmpCod, LctCod
			Where EmpCod = &EmpCod
			Where LctCod = &LCtCod
			&LctNom = LctNom
			Exit
		When none 
			&LctNom = 'TIPO LANÇAMENTO NÃO LOCALIZADO'
		EndFor
	EndIf

EndEvent

Event &PesCod.IsValid

	do 'NomeCliente'

EndEvent

Event &ActionSelecione.Click

	if &sdtPedidos.CurrentItem.Localizado = 'N'
		&ActionSelecione.FromImage(DDOMultiselSelOption)
		&sdtPedidos.CurrentItem.Localizado = 'S'
	Else
		&sdtPedidos.CurrentItem.Localizado = 'N'
		&ActionSelecione.FromImage(DDOMultiselOption)
	Endif
	
	do 'Totaliza'

EndEvent

Sub 'Totaliza'

	&Count = 0
	&PedVlrLiq = 0
	&AuxSdtPedidos = &sdtPedidos
	For &AuxSdtPedidosItem in &AuxSdtPedidos
		If &AuxSdtPedidosItem.Localizado = 'S'
			&Count += 1
			&PedVlrLiq += &AuxSdtPedidosItem.PedVlrLiq
		Endif
	EndFor
	PedidosSelecionados.Caption = trim(str(&count)) + ' - Pedidos Selecionados R$:' + trim(toformattedString(&PedVlrLiq))

EndSub

Sub 'NomeCliente'

	&PesRaz = 'INFORME O CLIENTE'
	
	if &PesCod > 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			&PesRaz = PesRaz
			Exit
		When none
			&PesRaz = 'CLIENTE NÃO LOCALIZADO'
		EndFor
	Endif

EndSub


