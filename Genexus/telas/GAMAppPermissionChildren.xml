      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&GAMApplication.Load(&ApplicationId)
	&AppPermissionParent = &GAMApplication.GetPermissionByGUID(&PermissionId, &Errors)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows

	If &HTTPRequest.Method = HttpMethod.Get
		Do 'LoadSavedFilters'
	EndIf
	Form.Caption = 'WWP_GAM_PermissionApplicationChildren'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Form.Caption = Format("WWP_GAM_PermissionsOfPermission", &AppPermissionParent.Name.Trim(), &GAMApplication.Name.trim())
	TextBlockTitle.Caption = Form.Caption

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do Case
		Case &ManageFiltersExecutionStep = 1
			&ManageFiltersExecutionStep = 2
		Case &ManageFiltersExecutionStep = 2
			&ManageFiltersExecutionStep = 0
			Do 'LoadSavedFilters'
	EndCase
	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	//&GridPageCount has to be loaded manually

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&Filter.Name	= &FilName
	&AppPermissions=&GAMApplication.GetPermissionChildren(&PermissionId, &Filter, &Errors)
	If &AppPermissions.Count = 0
		&GridPageCount = 0
	Else
		&GridPageCount = (&AppPermissions.Count / Page.Rows) + 1
	Endif
	For &AppPermission in &AppPermissions
		&Id			= &AppPermission.GUID
		&Name 		= &AppPermission.Name
		&Dsc 		= &AppPermission.Description
		&AccessType	= GAMPermissionAccessTypeDefault.Convert(&AppPermission.AccessType)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the data
	
	//Sample conditions to be added manually:
	//Where <Attribute> like &FilName when not &FilName.IsEmpty()
	
	&Delete = !'<i class="fa fa-times"></i>'
	
	&BtnChildren = !'<i class="fa fa-lock"></i>'
	&BtnChildren.Link = GAMAppPermissionChildren.Link(&ApplicationId, &Id)
	&Name.Link = GAMAppPermissionEntry.Link(GAMAPiMode.Display, &ApplicationId, &ID)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Grid.Load()
	EndFor

EndEvent

Event ddo_ManageFilters.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case ddo_ManageFilters.ActiveEventKey = !'<#Clean#>'
			Do 'CleanFilters'
			Grid.FirstPage()
		Case ddo_ManageFilters.ActiveEventKey = !'<#Save#>'
			Do 'SaveGridState'
			SaveFilterAs.Popup(!'GAMAppPermissionChildrenFilters', &PgmName + !"GridState")
			&ManageFiltersExecutionStep = 2
			Refresh
		Case ddo_ManageFilters.ActiveEventKey = !'<#Manage#>'
			ManageFilters.Popup(!'GAMAppPermissionChildrenFilters')
			&ManageFiltersExecutionStep = 2
			Refresh
		Otherwise
			&ManageFiltersXml = GetFilterByName(!'GAMAppPermissionChildrenFilters', ddo_ManageFilters.ActiveEventKey)
			If &ManageFiltersXml.IsEmpty()
				msg('WWP_FilterNotExist')
			Else
				Do 'CleanFilters'
				SaveGridState.Call(&PgmName + !"GridState",  &ManageFiltersXml)
				&GridState.FromXml(&ManageFiltersXml)
				Do 'LoadRegFiltersState'
				Grid.FirstPage()
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoClose'

	GAMWWAppPermissions(&ApplicationId)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GAMAppPermissionSelect.Call(&ApplicationId, &PermissionId)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadSavedFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ManageFiltersData = WWP_ManageFiltersLoadSavedFilters(!'GAMAppPermissionChildrenFilters', '', '', False)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CleanFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&FilName.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	
	Do 'LoadRegFiltersState'
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadRegFiltersState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"FILNAME"
				&FilName.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"FILNAME", "", not &FilName.IsEmpty(), 0, &FilName, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Delete.Click

	&GAMApplication.Load(&ApplicationId)
	&isOK = &GAMApplication.DeletePermissionChild(&PermissionId, &Id, &Errors)
	If &isOK
		Commit
	Else
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor	
	Endif
	Refresh

EndEvent


]]></Source>
