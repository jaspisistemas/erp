      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LayoutMainTable.Class = ThemeClass:MainContainerNoBackground
	&User = GAMRepository.GetUserToOTPAuthentication(&AuthenticationTypeName, &UseTwoFactorAuthentication, &Errors)
	If &Errors.Count > 0
		&UserPassword.Visible	= False
		BtnEnter.Visible			= False
		Do 'DisplayMessages'
	Else
		//Gets last error in the GAM 
		&Errors = GAMRepository.GetLastErrors()
		For &Error in &Errors
			Msg(&Error.Message)
		EndFor
		&UserName 		= &User.Name
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&URL.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&User = GAMRepository.GetUserToOTPAuthentication(&AuthenticationTypeName, &UseTwoFactorAuthentication, &Errors)
	If &Errors.Count = 0
		&AdditionalParameter.AuthenticationTypeName 	= &AuthenticationTypeName
		&AdditionalParameter.UseTwoFactorAuthentication	= &UseTwoFactorAuthentication
		&AdditionalParameter.OTPStep					= 2
		&AdditionalParameter.IDPState					= &IDP_State
		&LoginOK = GAMRepository.Login(&UserName, &UserPassword, &AdditionalParameter, &Errors )
		If &LoginOK
			If &IDP_State.IsEmpty()
				&URL = GAMRepository.GetLastErrorsURL()
				If &URL.IsEmpty()
					GAMHome()
				Else
					Link(&URL)
				Endif
			Endif
		Else
			If &Errors.Count > 0 
				Do Case
				Case &Errors.Item(1).Code = GAMErrorMessages.UserMissingRequiredData
					//Webpanel to Complete User data
					GAMUpdateRegisterUser(&IDP_State)
				Otherwise
					&UserPassword.SetEmpty()
					Do 'DisplayMessages'
				EndCase
			Endif
		Endif
	Else
		Do 'DisplayMessages'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event BackToLogin.Click

	If GAMRepository.IsRemoteAuthentication(&IDP_State)
		GAMRemoteLogin(&IDP_State)
	Else
		Login('', '')
	Endif

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


]]></Source>
