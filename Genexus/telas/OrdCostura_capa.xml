      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&OcsCod = &parOcsCod
	do 'LoadCostura'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWOrdemCostura.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoItens'

	OrdCostura_item.Link(&EmpCod, &OcsCod, 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpImprimeFicha.PopUp(&EmpCod, &OcsCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (&parOcsCod > 0)
		BtnItens.Visible = False
	Endif
	If not (&OcsCod > 0)
		BtnImprimir.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	do 'loadFornecedor'
	do Case
		Case &PesRaz.IsEmpty()
			msg('Informe o Fornecedor!')
			&OcsCliCod.SetFocus()
		Otherwise
			
			//&OcsFilCod, &OcsNfeCod
			
			prcOrdCostura_capa.Call(&EmpCod, &parOcsCod, &OcsDta, &OcsFilCod, &OcsNfeCod, &OcsNfeNum, &OcsCliCod, &OcsCod)
			OrdCostura_item.Link(&EmpCod, &OcsCod, 0)
	Endcase

EndEvent

Event &OcsCliCod.IsValid

	do 'loadFornecedor'

EndEvent

Sub 'loadFornecedor'

	RetornaNomePessoa.Call(&EmpCod, &OcsCliCod, &PesRaz)

EndSub

Sub 'LoadCostura'

	For Each Order EmpCod, OcsCod
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		&OcsDta = OcsDta
		&OcsNfeNum = OcsNfeNum
		&OcsCliCod = OcsCliCod
		&OcsFilCod = OcsFilCod
		&OcsNfeCod = OcsNfeCod
		
		Exit
	When None
		&OcsDta = serverdate()
	EndFor
	
	do 'loadFornecedor'

EndSub


]]></Source>
