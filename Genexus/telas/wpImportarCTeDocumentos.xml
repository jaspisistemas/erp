Sub 'VerificaIsGravado'

	&AuxCteCfopFor = &CteCfopFor
	RetornaSoNumeros.Call(&AuxCteCfopFor, &AuxCteCfopFor)
	&CteCfopFor = format('%1.%2', substr(&AuxCteCfopFor, 1, 1), substr(&AuxCteCfopFor, 2, 3))	
	
	&iSGravado = false
	For Each Order CfoCod, CfoEmpCod, CfoLctCod
		Where CfoCod = &CteCfopFor
		Where CfoEmpCod = &EmpCod
		Where CfoLctCod = &CteLctCod
		
		&iSGravado = true
		Exit
	EndFor

EndSub


