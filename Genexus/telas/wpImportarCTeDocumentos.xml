Sub 'SaveVariablesToWizardData'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Documentos.CteImpCst = &CteImpCst
	&WizardData.Documentos.CteCfop = &CteCfop
	&WizardData.Documentos.CteDtaSai = &CteDtaSai
	&WizardData.Documentos.CTeDtaEms = &CTeDtaEms
	&WizardData.Documentos.Grid.Clear()
	For Each Line in Grid
		&GridItem = new()
		&GridItem.GridCteDocNro = &GridCteDocNro
		&GridItem.GridCteDocSer = &GridCteDocSer
		&GridItem.GridCteDocChvNfe = &GridCteDocChvNfe
		&GridItem.GridCteDocTipOri = &GridCteDocTipOri
		&GridItem.GridCteDocDta = &GridCteDocDta
		&GridItem.GridCteDocVlrTotNtf = &GridCteDocVlrTotNtf
		&GridItem.GridEmpCod = &GridEmpCod
		&GridItem.GridFilCod = &GridFilCod
		&GridItem.GridCteCod = &GridCteCod
		&GridItem.GridCteDocCod = &GridCteDocCod
		&GridItem.GridCteDocTip = &GridCteDocTip
		&GridItem.GridCteDocTotPso = &GridCteDocTotPso

		&WizardData.Documentos.Grid.Add(&GridItem)
	EndFor
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

