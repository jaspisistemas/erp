Sub 'getProduto'

	For Each Order EmpCod, ProCod, ProGraCod, ProBarRef
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		where ProGraCod = &ProGraCod
		Where ProBarQtd = &EtqVolPedQtd
		
		&EtqVolCodBar = ProBarRef
		Exit
	When none
		For Each Order EmpCod, ProCod, ProGraCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			where ProGraCod = &ProGraCod
			
			&EtqVolCodBar = ProGraBar
			Exit
		EndFor
	EndFor

EndSub

Sub 'Pedido'

	Do 'AttributesSecurityCode'
	&NfeNum.SetEmpty()
	
	If &PedCod <> 0
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			RetornaNotaAutorizadaPedido.Call(EmpCod, FilCod, PedCod, &NfeNum)
			&IsExitePedido = true
			&PedCliCod = PedCliCod
			&PedCliRaz = PedCliRaz
			&PedTraRedCod = PedTraRedCod
//			&PedTraRedRaz = PedTraRedRaz
			&PedTraSaiCod = PedTraSaiCod
//			&PedTraSaiRaz = PedTraSaiRaz
			
			&PedEspVol = PedEspVol
			&PedQtdVol = PedQtdVol
			
			if not PedDtaEmb.IsEmpty() and not PedDtaEmb.IsNull()
				&PedDtaEmb = PedDtaEmb
			EndIF
			
			//If not PedPesTot.IsEmpty()
			//				&PedPesTot = PedPesTot
			//Else
			//&PedPesTot = PedPesTotPro
			//			EndIF
			
			Exit
		When none
			&IsExitePedido = false
			&PedCliCod = 0
			&PedCliRaz = ''
//			&PedTraRedCod = 0
//			&PedTraRedRaz = ''
			&PedEspVol = ''
			&PedQtdVol = 0
			msg('Pedido não Localizado!')
		EndFor
	Else
		&IsExitePedido = False
	EndIF
	
	If &IniPedQtdVol.IsEmpty()
		&IniPedQtdVol = 1
	EndIF
	
	if &PedEspVol.IsEmpty()
		if &AuxPedEspVol.IsEmpty()	
			&PedEspVol = 'CAIXAS'
		Else
			&PedEspVol = &AuxPedEspVol
		EndIF
	EndIF

EndSub

Sub 'FinVolume'

	&FinPedQtdVol = &IniPedQtdVol + &PedQtdVol -1
	TextFinQtd.Caption = ' à ' + trim(str(&FinPedQtdVol))

EndSub

Sub 'Cliente'

	&PedCliRaz = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		&PedCliRaz = PesRaz
		Exit
	When none
		&PedCliRaz = 'CLIENTE NÃO LOCALIZADO'
		msg(&PedCliRaz)
	EndFor

EndSub


