		if &ProNEwBar.IsEmpty()
			GravaCodigoProduto.Call(&EmpCod, &ProCod, &ProGraCod, &EtqVolCodBar, 'E', &EtqVolPedQtd, 0, 999, &Mensagem, &IsErro)
