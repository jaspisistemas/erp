EndEvent

Event 'DoImprimir'

	RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
	do 'FinVolume'
	
	&PadObs = PadL(&ModeloEtiqueta,3, ' ')
	&PadObs += PadR(trim(&PedEspVol),20, '')
	PadraoUsuario.Call('G', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod,&PadObs, &PadDtaMod)
	
	If &PedCod <> 0
//		GravaDataEtiquetado.Call(t('', &EmpCod, &FilCod, &PedCod, &PedQtdVol, &PedPesTot, &PedDtaEmb, &PedEspVol, &PedTraSaiCod,&PedTraRedCod, &wwpContext.PesCod)
	EndIF

	&Random = (Random() * 10000000)
	&ArquivoFisico  = &sdtConfiguracoesPasta.PastaDiretorioTempFis + 'EtiqVol' + trim(str(&PedCod)) + trim(str(&wwpContext.PesCod)) + trim(str(&Random)) + '.pdf'
	&File.source = &ArquivoFisico
	If &File.Exists()
		&File.Delete()
	EndIF

	Do Case
		
		Case &FinPedQtdVol < &IniPedQtdVol
			msg('Sequência Final do Volume não pode ser menor que a Inicial!')
			
		Case &IsExitePedido = false and &PedCod.IsEmpty()
			msg('Pedido não Localizado!')
			
		Case &ModeloEtiqueta = 'A' //Impressao para Volume MODELO 1 A4
			InNewWindow1.Target = RELJAS128.Link(&EmpCod, &FilCod, &PedCod, &NfeNum, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico)
			InNewWindow1.Height = !'600'
			InNewWindow1.Width = !'800'
			InNewWindow1.Fullscreen = true
			InNewWindow1.OpenWindow()
			
		Case &ModeloEtiqueta = 'B' //Impressao para Volume MODELO 2 A4
			InNewWindow1.Target = RELJAS128_A.Link(&EmpCod, &FilCod, &PedCod, &NfeNum, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico)
			InNewWindow1.Height = !'600'
			InNewWindow1.Width = !'800'
			InNewWindow1.Fullscreen = true
			InNewWindow1.OpenWindow()
			
		Case &ModeloEtiqueta = 'C' //Impressao para Volume MODELO 1 RIBON
			InNewWindow1.Target = RELJAS128_B.Link(&EmpCod, &FilCod, &PedCod, &NfeNum, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico)
			InNewWindow1.Height = !'600'
			InNewWindow1.Width = !'800'
			InNewWindow1.Fullscreen = true
			InNewWindow1.OpenWindow()
		Case &ModeloEtiqueta = 'D' //Impressao para Volume MODELO 2 RIBON
			InNewWindow1.Target = RELJAS128_C.Link(&EmpCod, &FilCod, &PedCod, &NfeNum, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico)
			InNewWindow1.Height = !'600'
			InNewWindow1.Width = !'800'
			InNewWindow1.Fullscreen = true
			InNewWindow1.OpenWindow()
			
		Case &ModeloEtiqueta = 'E' //Impressao para Volume MODELO 3 RIBON
			InNewWindow1.Target = RELJAS128_D.Link(&EmpCod, &FilCod, &PedCod, &NfeNum, &PedCliCod, &PedTraSaiCod, &ModeloEtiqueta, &ArquivoFisico)
			InNewWindow1.Height = !'600'
			InNewWindow1.Width = !'800'
			InNewWindow1.Fullscreen = true
			InNewWindow1.OpenWindow()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



