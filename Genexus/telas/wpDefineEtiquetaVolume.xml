	prcGravaVolumeProduto.Call(&EmpCod, &FilCod, &PedCod, &NfeNum, &EtqVolNro, &ProRef, &EtqVolPedQtd, &EtqVolNovRefCod, &EtqVolNovProNom, &EtqVolCodBar)
	
	&ProNEwBar = ''
