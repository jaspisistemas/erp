      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	padraousuarioHora.Call('L', '#URLTERMINALACESSO#', 1, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	&sdtUrlTerminal.FromJson(&PadObs)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtUrlTerminals.Rows = Page.Rows
	GridsdtUrlTerminalsPaginationBar.RowsPerPageSelectedValue = GridsdtUrlTerminals.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtUrlTerminalsCurrentPage = GridsdtUrlTerminals.CurrentPage
	&GridsdtUrlTerminalsPageCount = GridsdtUrlTerminals.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtUrlTerminals.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&delete = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtUrlTerminalsPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtUrlTerminalsPaginationBar.SelectedPage = !'Previous'
			GridsdtUrlTerminals.PreviousPage()
		Case GridsdtUrlTerminalsPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtUrlTerminals.CurrentPage
			&PageToGo += 1
			GridsdtUrlTerminals.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtUrlTerminalsPaginationBar.SelectedPage)
			GridsdtUrlTerminals.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtUrlTerminalsPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtUrlTerminals.Rows = GridsdtUrlTerminalsPaginationBar.RowsPerPageSelectedValue
	GridsdtUrlTerminals.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	&sdtUrlTerminalitem = new()
	&sdtUrlTerminalitem.UrlHost = &UrlAcesso
	&sdtUrlTerminal.Add(&sdtUrlTerminalitem)
	
	&PadObs = &sdtUrlTerminal.ToJson()
	padraousuarioHora.Call('G', '#URLTERMINALACESSO#', 1, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &delete.Click

	&index = &sdtUrlTerminal.IndexOf(&sdtUrlTerminal.CurrentItem)
	&sdtUrlTerminal.Remove(&index)
	
	&PadObs = &sdtUrlTerminal.ToJson()
	padraousuarioHora.Call('G', '#URLTERMINALACESSO#', 1, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')

EndEvent


]]></Source>
