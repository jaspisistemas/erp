      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&NomePadraoUsuarioGrava = 'WPIMPRIMEFICHA_200'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadOrdem'

EndEvent

Event Enter

	do 'loadFuncionario'
	
	if &IsErro = false
		&PadObs = &sdtTipEtq.ToJson()
		padraoUsuario.Call('G', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)

		RCOOpenWindow1.LinkOpen = RELJAS091_Corte.link(&NomePadraoUsuarioGrava, &context.EmpCod,&context.FilCod, &OcsCod, &OcsProNroCor)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Endif

EndEvent

Event &OcsProNroCor.IsValid

	do 'loadProduto'

EndEvent

Event &PesCod.IsValid

	do 'loadFuncionario'

EndEvent

Sub 'loadOrdem'

	For Each order EmpCod, OcsCod
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		&OcsCliRaz = OcsCliRaz
		&OcsNfeNum = OcsNfeNum
		Exit
	When none
		return
	EndFor

EndSub

Sub 'loadFuncionario'

	&IsErro = false
	&PesRaz.SetEmpty()
	&sdtTipEtq.Clear()
	
	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesRaz = PesRaz
		
		&sdtTipEtqitem =new()
		&sdtTipEtqitem.CD = &PesCod.ToFormattedString()
		&sdtTipEtqitem.DES = PesRaz.Trim()
		&sdtTipEtq.Add(&sdtTipEtqitem)
		
		Exit
	When none
		if &PesCod <> 0
			msg('Costureira não Localizada!')
			&IsErro = true
		Else
			For Each ORder EmpCod, PesCod
				Where EmpCod = &EmpCod
				Where PesIsFun = true
				Where PesDtaDem.IsEmpty() or PesDtaDem.IsNull()
				
				&sdtTipEtqitem =new()
				&sdtTipEtqitem.CD = PesCod.ToFormattedString()
				&sdtTipEtqitem.DES = PesRaz.Trim()
				&sdtTipEtq.Add(&sdtTipEtqitem)
			EndFor
		EndIF

	EndFor

EndSub

Sub 'loadProduto'

	&OcsProGraNom.SetEmpty()
	&OcsItm.SetEmpty()
	
	For Each Order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsProNroCor = &OcsProNroCor
		
		&OcsItm = OcsItm
		&OcsProGraNom = OcsProGraNom
		Exit
	EndFor

EndSub


]]></Source>
