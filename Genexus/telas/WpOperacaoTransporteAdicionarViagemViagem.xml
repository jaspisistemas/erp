      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&OpeTotOutCre.Visible = False
	&OpeTotOutDeb.Visible = False
	&OpeTotOutCreJus.Visible = False
	&OpeTotOutDebJus.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WpOperacaoTransporteAdicionarViagem(!'Viagem', !'DocFiscais', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		
		Do Case
			Case &OpeNroDoc.IsEmpty()
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório preencher o documento de viagem.', DVMessageType.regular, "", DVMessageBoolean.True,""))
				&OpeNroDoc.SetFocus()
				
			Case &OpeOricidCep.IsEmpty() Or &OpeOriCidCod.IsEmpty() Or &OpeOriCidUfe.IsEmpty()
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório preencher todas as informações de origem.', DVMessageType.regular, "", DVMessageBoolean.True,""))
				&OpeOricidCep.SetFocus()

			Case &OpeDstCidCep.IsEmpty() Or &OpeDstCidCod.IsEmpty() Or &OpeDstCidUfe.IsEmpty()
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório preencher todas as informações de destino.', DVMessageType.regular, "", DVMessageBoolean.True,""))
				&OpeDstCidCep.SetFocus()
				
			OtherWise
				Do 'SaveVariablesToWizardData'
				prcOperacaoAdicionaViagemTAC.Call(&WebSessionKey, &OpeViaCod)
				Do 'SaveVariablesToWizardData'
				WpOperacaoTransporteAdicionarViagem(!'Viagem', !'DocFiscais', false)
		EndCase
		
	EndIf

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (not &GoingBack)
		BtnWizardFirstPrevious.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadVariablesFromWizardData'

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&OpeTotAdi = &WizardData.Viagem.OpeTotAdi
	&OpeTotPed = &WizardData.Viagem.OpeTotPed
	&OpeTotCom = &WizardData.Viagem.OpeTotCom
	&OpeTotSeg = &WizardData.Viagem.OpeTotSeg
	&OpeTotQui = &WizardData.Viagem.OpeTotQui
	&OpeTotOutCre = &WizardData.Viagem.OpeTotOutCre
	&OpeTotOutDeb = &WizardData.Viagem.OpeTotOutDeb
	&OpeTotOutCreJus = &WizardData.Viagem.OpeTotOutCreJus
	&OpeTotOutDebJus = &WizardData.Viagem.OpeTotOutDebJus
	&OpeDstCidCod = &WizardData.Viagem.OpeDstCidCod
	&OpeDstCidUfe = &WizardData.Viagem.OpeDstCidUfe
	&OpeDstCidCep = &WizardData.Viagem.OpeDstCidCep
	&OpeOriCidCod = &WizardData.Viagem.OpeOriCidCod
	&OpeOriCidUfe = &WizardData.Viagem.OpeOriCidUfe
	&OpeOricidCep = &WizardData.Viagem.OpeOricidCep
	&OpeNroDoc = &WizardData.Viagem.OpeNroDoc
	&OpeTipPgt = &WizardData.Viagem.OpeTipPgt
	&OpeNroCiot = &WizardData.Viagem.OpeNroCiot
	&EmpCod = &WizardData.Viagem.EmpCod
	&FilCod = &WizardData.Viagem.FilCod
	&OpeCod = &WizardData.Viagem.OpeCod
	&OpeViaCod = &WizardData.Viagem.OpeViaCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		LoadWWPContext.Call(&Context)
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&EmpCod		= &WizardData.Viagem.EmpCod
		&FilCod 	= &WizardData.Viagem.FilCod
		&OpeCod 	= &WizardData.Viagem.OpeCod
		&OpeNroCiot = &WizardData.Viagem.OpeNroCiot
		&OpeViaCod	= &WizardData.Viagem.OpeViaCod
		
		&OpeOriCidUfe = 'AC'
		&Estado = 1
		Do 'CarregaCidades'
		
		&OpeDstCidUfe = 'AC'
		&Estado = 2
		Do 'CarregaCidades'	
		
		If &OpeViaCod <> 0
			Do 'GetViagem'
		Else
			Do 'VerificaUltimaViagem'
		EndIf
		
	EndIf

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Viagem.OpeTotAdi = &OpeTotAdi
	&WizardData.Viagem.OpeTotPed = &OpeTotPed
	&WizardData.Viagem.OpeTotCom = &OpeTotCom
	&WizardData.Viagem.OpeTotSeg = &OpeTotSeg
	&WizardData.Viagem.OpeTotQui = &OpeTotQui
	&WizardData.Viagem.OpeTotOutCre = &OpeTotOutCre
	&WizardData.Viagem.OpeTotOutDeb = &OpeTotOutDeb
	&WizardData.Viagem.OpeTotOutCreJus = &OpeTotOutCreJus
	&WizardData.Viagem.OpeTotOutDebJus = &OpeTotOutDebJus
	&WizardData.Viagem.OpeDstCidCod = &OpeDstCidCod
	&WizardData.Viagem.OpeDstCidUfe = &OpeDstCidUfe
	&WizardData.Viagem.OpeDstCidCep = &OpeDstCidCep
	&WizardData.Viagem.OpeOriCidCod = &OpeOriCidCod
	&WizardData.Viagem.OpeOriCidUfe = &OpeOriCidUfe
	&WizardData.Viagem.OpeOricidCep = &OpeOricidCep
	&WizardData.Viagem.OpeNroDoc = &OpeNroDoc
	&WizardData.Viagem.OpeTipPgt = &OpeTipPgt
	&WizardData.Viagem.OpeNroCiot = &OpeNroCiot
	&WizardData.Viagem.EmpCod = &EmpCod
	&WizardData.Viagem.FilCod = &FilCod
	&WizardData.Viagem.OpeCod = &OpeCod
	&WizardData.Viagem.OpeViaCod = &OpeViaCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &OpeDstCidUfe.ControlValueChanged

	&OpeDstCidCep.SetEmpty()
	&OpeDstCidCod.SetEmpty()
	&Estado = 2
	Do 'CarregaCidades'

EndEvent

Event &OpeOriCidUfe.ControlValueChanged

	&OpeOricidCep.SetEmpty()
	&OpeOriCidCod.SetEmpty()
	&Estado = 1
	Do 'CarregaCidades'

EndEvent

Event &OpeOricidCep.ControlValueChanged

	&Estado 		= 1
	Do 'CarregaCidades'
	
	ConsultaCepOperacaoTransporte.Call(&EmpCod, &OpeOricidCep, &OpeOriCidUfe, '', &RetOpeOriCidCod)
	Do 'CarregaCidades'
	&OpeOriCidCod 	= &RetOpeOriCidCod

EndEvent

Event &OpeDstCidCep.ControlValueChanged

	&Estado 		= 2
	Do 'CarregaCidades'
	
	ConsultaCepOperacaoTransporte.Call(&EmpCod, &OpeDstCidCep, &OpeDstCidUfe, '', &RetOpeDstCidCod)
	Do 'CarregaCidades'
	&OpeDstCidCod 	= &RetOpeDstCidCod

EndEvent

Sub 'VerificaUltimaViagem'

	For Each Order EmpCod, FilCod, OpeCod 
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		For Each Order (OpeViaCod), EmpCod, FilCod, OpeCod 
			Where OpeViaSts	= Status_Autorizado.NAO_AUTORIZADO
			
			&OpeDstCidUfe	=	OpeDstCidUfe
			&Estado 		= 2
			Do 'CarregaCidades'	
			&OpeDstCidCod	=	OpeDstCidCod
			&OpeDstCidCep	=	OpeDstCidCep
			
			&OpeOriCidUfe	=	OpeOriCidUfe
			&Estado 		= 1
			Do 'CarregaCidades'	
			&OpeOriCidCod	=	OpeOriCidCod
			&OpeOricidCep	=	OpeOricidCep
			
			&OpeNroDoc		=	OpeNroDoc
			&OpeTipPgt		=	OpeTipPgt
			
			&OpeViaCod		= 	OpeViaCod
			
			For Each Order EmpCod, FilCod, OpeCod, OpeViaCod, OpeValCod
				Where OpeViaCod	= &OpeViaCod
				&OpeTotAdi	=	OpeTotAdi
				&OpeTotQui	=	OpeTotQui
				&OpeTotCom	=	OpeTotCom
				&OpeTotPed	=	OpeTotPed
				&OpeTotSeg	=	OpeTotSeg
				
				Exit
			EndFor
			
			Exit
		EndFor
	
		Exit
	EndFor

EndSub

Sub 'GetViagem'

	For Each Order EmpCod, FilCod, OpeCod
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&OpeEmiGra		= OpeEmiGra
		For Each Order EmpCod, FilCod, OpeCod, OpeViaCod
			Where OpeViaCod	= &OpeViaCod
			
			&OpeDstCidUfe 	= OpeDstCidUfe
			&Estado 		= 2
			Do 'CarregaCidades'	
			&OpeDstCidCod	=	OpeDstCidCod
			&OpeDstCidCep	=	OpeDstCidCep
			
			&OpeOriCidUfe 	= OpeOriCidUfe
			&Estado 		= 1
			Do 'CarregaCidades'		
			&OpeOriCidCod	=	OpeOriCidCod
			&OpeOricidCep	=	OpeOricidCep
			
			&OpeNroDoc		=	OpeNroDoc
			&OpeTipPgt		=	OpeTipPgt
			
			For Each Order EmpCod, FilCod, OpeCod, OpeViaCod, OpeValCod
				
				&OpeTotAdi	=	OpeTotAdi
				&OpeTotQui	=	OpeTotQui
				&OpeTotCom	=	OpeTotCom
				&OpeTotPed	=	OpeTotPed
				&OpeTotSeg	=	OpeTotSeg
				
				Exit
			EndFor
		
			Exit
		EndFor
		
		If &OpeTipPgt.IsEmpty()
			If &OpeEmiGra = True
				&OpeTipPgt = Efrete_TipoPagamento.Transferenciabancaria
			Else
				&OpeTipPgt = Efrete_TipoPagamento.EFrete
			EndIf
		EndIf
	
		Exit
	EndFor

EndSub

Sub 'CarregaCidades'

	Do Case 
		Case &Estado = 1
			&UfeCod	 = &OpeOriCidUfe
			&OpeOriCidCod.Clear()
		Case &Estado = 2
			&UfeCod	 = &OpeDstCidUfe
			&OpeDstCidCod.Clear()
	EndCase
	
	For Each Order EmpCod, CidCod, UfeCod
		Where EmpCod = &EmpCod
		Where UfeCod = &UfeCod
		
		Do Case 
			Case &Estado = 1
				&OpeOriCidCod.AddItem(CidIBGE, CidNom)
			Case &Estado = 2
				&OpeDstCidCod.AddItem(CidIBGE, CidNom)
		EndCase
	EndFor

EndSub


