      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&WwpContext)
	retornaAutorizacao.Call('WWPRODUTO', Status_SimNao.Nao, 2, &EditarProdutoAutNiv)
	
	padraoUsuarioHora.Call('L', '#SIMILARSOMENTEESTOQUE#', &WwpContext.PesCod, &WwpContext.EmpCod, &PadObs, &PadDtaMOd, &PadDtaHorMod, 'P')
	&SomenteComEstoque = iif(&PadObs = '1', true, false)
	
	prcRetornaQuantidadeEstoqueSimilares.Call(&EmpCod, &WwpContext.FilCod, &ProCod, &TotSdtSimilares)
	do 'ApagaOsSemEstoque' 
			
	tbsimilares.Visible = &TotSdtSimilares.Produtos.Count > 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable4.Width = 180
	UnnamedTable3.Width = 170
	GridsdtSimilares_Produtoss.Rows = 5
	GridsdtSimilares_ProdutossPaginationBar.RowsPerPageSelectedValue = GridsdtSimilares_Produtoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//	tbDetalhamentoMaisCodigos.Visible = 0

EndEvent

Event Refresh

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&AplicacaoProduto = ProNomApl.ToUpper()
		&ProRef = ProRef
		&ProBar = ProBar
		
		&NcmCod = NcmCod
		&PrograBar = ProGraBar
		&ProPesLiq = ProPesLiq
		
		Exit
	EndFor

	&MaisCodigos = &ProRef.Trim() + ' | ' + trim(&ProBar)		
	ReTornaCodigoCadastroProduto.Call(&EmpCod, &ProCod, &EmpCnpj, &OutrosCodigosMensagem, &txtCodigoBarrasCaixa)		
	&MaisCodigos += &OutrosCodigosMensagem
	
	if &AplicacaoProduto.IsEmpty()
		&AplicacaoProduto = 'SEM_APLICACOES'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtSimilares_ProdutossCurrentPage = GridsdtSimilares_Produtoss.CurrentPage
	&GridsdtSimilares_ProdutossPageCount = GridsdtSimilares_Produtoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtSimilares_Produtoss.Load

	if &sdtSimilares.Produtos.CurrentItem.EstLoc.IsEmpty()
		&Locacao = 'SEM_LOCACAO'
	Else
		&Locacao = &sdtSimilares.Produtos.CurrentItem.EstLoc
	EndiF
	&Estoque = RetiraZerosDepoisVirgulaxCasas.Udp(0, &sdtSimilares.Produtos.CurrentItem.SimQtd.ToFormattedString())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtSimilares_ProdutossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtSimilares_ProdutossPaginationBar.SelectedPage = !'Previous'
			GridsdtSimilares_Produtoss.PreviousPage()
		Case GridsdtSimilares_ProdutossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtSimilares_Produtoss.CurrentPage
			&PageToGo += 1
			GridsdtSimilares_Produtoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtSimilares_ProdutossPaginationBar.SelectedPage)
			GridsdtSimilares_Produtoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtSimilares_ProdutossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtSimilares_Produtoss.Rows = GridsdtSimilares_ProdutossPaginationBar.RowsPerPageSelectedValue
	GridsdtSimilares_Produtoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &SomenteComEstoque.Click

	if &SomenteComEstoque = true
		padraoUsuarioHora.Call('G', '#SIMILARSOMENTEESTOQUE#', &WwpContext.PesCod, &WwpContext.EmpCod, '1', &PadDtaMOd, &PadDtaHorMod, 'P')
	Else
		padraoUsuarioHora.Call('G', '#SIMILARSOMENTEESTOQUE#', &WwpContext.PesCod, &WwpContext.EmpCod, '0', &PadDtaMOd, &PadDtaHorMod, 'P')
	Endif
	do 'ApagaOsSemEstoque'

EndEvent

Event &Locacao.Click

	locacaoProduto.Popup(true, &sdtSimilares.Produtos.CurrentItem.SimProCod)
	prcRetornaQuantidadeEstoqueSimilares.Call(&EmpCod, &WwpContext.FilCod, &ProCod, &TotSdtSimilares)
	do 'ApagaOsSemEstoque' 
	Refresh

EndEvent

Event &MaisCodigos.Click

	if &EditarProdutoAutNiv > 1
	wpCodigoCaixas.Popup(&EmpCod, &ProCod, 1, 'A')
	refresh
	Else
		msg('Não autorizado a Editar Produtos!')
	Endif

EndEvent

Event &txtCodigoBarrasCaixa.Click

	if &EditarProdutoAutNiv > 1
	wpCodigoCaixas.Popup(&EmpCod, &ProCod, 1, 'C')
	Refresh
	Else
		msg('Não autorizado a Editar Produtos!')
	Endif

EndEvent

Event &AplicacaoProduto.Click

	if &EditarProdutoAutNiv > 1
		wpAplicacoesProduto.Popup(&EmpCod, &ProCod)	
		Refresh
	Else
		msg('Não autorizado a Editar Produtos!')
	Endif

EndEvent

Sub 'ApagaOsSemEstoque'

	&sdtSimilares.Produtos.Clear()
//	&auxSdtSimilares = &TotSdtSimilares
//	if &SomenteComEstoque = true
		For &AuxSdtSimilaresItem in &TotSdtSimilares.Produtos
			if &SomenteComEstoque = true
				if &AuxSdtSimilaresItem.SimQtd > 0 
					&sdtSimilares.Produtos.Add(&AuxSdtSimilaresItem)
				EndIf
			Else
				&sdtSimilares.Produtos.Add(&AuxSdtSimilaresItem)
			Endif
		
		EndFor
//	EndIf
//	&sdtSimilares = &auxSdtSimilares

EndSub


]]></Source>
