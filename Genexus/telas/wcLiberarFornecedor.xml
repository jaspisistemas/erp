      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&Guid = guid.NewGuid()
	&ProgressId = &Guid.ToString()
	
	tbProgresso.Visible = 0
	tbEmail.Visible = 0
	
	do 'getCotacaoFornecedor'
	Do CAse
		CAse &OqueFazer = 'L' //Liberar
			txtObs.Caption = 'Ao LIBERAR a cotação ao fornecedor sistema vai criar um link novo de acesso à cotação e irá enviar por e-mail ao fornecedor!'
			wwpActions.WCPopup_UpdateTitle('LIBERAR Cotação do fornecedor')
			tbEmail.Visible = 1
			txtObs.ForeColor = rgb(25, 113, 0)
			
		CAse &OqueFazer = 'S' //Suspender
			txtObs.Caption = 'Ao SUSPENDER, Fornecedor fica bloqueado de iniciar ou continuar a cotação até uma nova liberação, nessa nova liberação um novo link de acesso será disponibilizado!'
			wwpActions.WCPopup_UpdateTitle('SUSPENDER Cotação do fornecedor')
			txtObs.ForeColor = rgb(255, 0, 0)
			
		CAse &OqueFazer = 'R' //Reenviar
			&CotComForEmail.Enabled = false
			&CotComForNum.Enabled = false
			tbEmail.Visible = 1
			txtObs.Caption = 'REENVIA o link de acesso à cotação para o e-mail informado!'
			wwpActions.WCPopup_UpdateTitle('REENVIAR Cotação ao fornecedor')
			
		CAse &OqueFazer = 'N' //Reiniciar/Criar novo link
			txtObs.Caption = 'REINICIAR uma Cotação finalizada, apagando os valores preenchidos pelo fornecedor e gerando um novo link de acesso!'
			wwpActions.WCPopup_UpdateTitle('REINICIAR Cotação do fornecedor')
			txtObs.ForeColor = rgb(255, 0, 0)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &OqueFazer = 'L' or &OqueFazer = 'N'
		do 'ValidaFone'
		do 'ValidaEmail'
	EndIf
	
	Do Case
		CAse &IsErrorFone = true and (&OqueFazer = 'L' or &OqueFazer = 'N')
			msg(' Número de telefone inválido!')
			&CotComForNum.SetFocus()
			
		Case &IsErrorEmail = true and (&OqueFazer = 'L' or &OqueFazer = 'N')
			msg('Endereço de E-mail não coincide com o padrão especificado!')
			&CotComForEmail.SetFocus()
			
		Case &CotComForEmail.IsEmpty() and (&OqueFazer = 'L' or &OqueFazer = 'N')
			msg('Endereço de E-mail Obrigatório!')
			&CotComForEmail.SetFocus()
			
		Otherwise			
			tbProgresso.Visible = 1
			tbenter.Visible = 0
						
			Do CAse
				CAse &OqueFazer = 'L' or &OqueFazer = 'N' or &OqueFazer = 'S'
					scaPrograssBar1.ProcessId = &ProgressId
					scaPrograssBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
					scaPrograssBar1.Start()
					
					prcAlterarStatusFornecedor.Submit(&ProgressID, &ProgressID, &EmPCod, &CotComCod, &CotComForCod, &OqueFazer)
				Case &OqueFazer = 'R'
					//grava envio dos email
					For Each ORder EmpCod, CotComCod, CotComForCod
						Where EmpCod = &EmPCod
						Where CotComCod = &CotComCod
						where CotComForCod = &CotComForCod
						Where not CotComForEmail.IsEmpty() and not CotComForEmail.IsNull()
						
						&EmlAss = 'COTAÇÃO DE PREÇOS: ' + padl(trim(str(CotComCod)),3,'0') + '.' + padl(trim(str(CotComVer)),3,'0')
						
						&SdtEmail.Clear()
						&ItemSdtEmail = new()
						&ItemSdtEmail.EmlUrl = CotComForEmail
						&SdtEmail.Add(&ItemSdtEmail)
						GravaEnvioEmail.Call(EmpCod, CotComFilCod, CotComCod, CotComForCod, TipoContaEmail.Email_Comercial, &EmlAss, TipoSolicitacao.CotacaoCompras, &wwpContext.PesCod, &Mensagem, &SdtEmail, &sdtBoleto)
						
						Exit
					EndFor
					wwpActions.WCPopup_Close('')
			EndCAse
		
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CotComForNum.IsValid

	do 'ValidaFone'

EndEvent

Event &CotComForEmail.IsValid

	do 'ValidaEmail'

EndEvent

Event scaPrograssBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		&SdtWbsRetorno.FromJson(ProgressLogXml)
		
		if &SdtWbsRetorno.sts = 'J200'
			wwpActions.WCPopup_Close('')
		Else
			tbEnter.Visible = 1
			tbProgresso.Visible = 0
			tbAvisoerro.Visible = 1

			txtAvisoErro.Caption = &SdtWbsRetorno.obs
		EndIf
		
		Exit		
	EndFor

EndEvent

Sub 'ValidaEmail'

	&IsErrorEmail = false	
	if not &CotComForEmail.IsEmpty()
		&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
		if (&EmailVerificacao.IsMatch(&pattern) = false)
			
			&IsErrorEmail = True
		EndIf
	Endif

EndSub

Sub 'ValidaFone'

	FormataFONE.Call(&CotComForNum,&CotComForNum)
	&IsErrorFone = false
	RetornaSoNumeros.Call(&CotComForNum, &Varchar)
	if (&Varchar.Length() >= 10 and &Varchar.Length() < 13) or &Varchar.IsEmpty()
	else
		&IsErrorFone = true
	EndIf

EndSub

Sub 'getCotacaoFornecedor'

	&CotComForEmail = ''
	&CotComForNum = ''
	For Each ORder EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmPCod
		Where CotComCod = &CotComCod
		Where CotComForCod = &CotComForCod
		
		txtFornecedor.Caption = format('Fornecedor: %1 - %2', trim(str(CotComForCod)), trim(CotComForRaz))
		
		&CotComForEmail = CotComForEmail
		&CotComForNum = CotComForNum
		Exit
	EndFor

EndSub


