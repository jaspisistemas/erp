      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FiLCod = &Context.FilCod
	&PesCod = &Context.PesCod
	&FilTabCod = '1'
	RetornaAutorizacao.Call('RELATORIOESTOQUEDISPONIVEL', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaNomePessoa.Call(&EmpCod, &ProPadForCod, &ProPadForRaz)
	if &ProPadForRaz.IsEmpty()
		&ProPadForRaz = 'TODOS OS FORNECEDORES'
	Endif

	RetornaNomeProduto.Call(&EmpCod,&ProCod,&ProNom)
	If &ProNom.Trim().IsEmpty()
		&ProNom = 'TODOS OS PRODUTOS'
	EndIf

	&PossuiModuloIND_SETOR = RetornaEmpresaModulo.Udp(&Context.EmpCod, ModuloSistema.IND_SETOR)
	tbClassificacaoProducao.Visible = (&PossuiModuloIND_SETOR = 'S')

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProPadForCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &ProPadForCod, &ProPadForRaz)
	if &ProPadForRaz.IsEmpty()
		&ProPadForRaz = 'TODOS OS FORNECEDORES'
	Endif

EndEvent

Event &ProCod.IsValid

	RetornaNomeProduto.Call(&EmpCod,&ProCod,&ProNom)
	If &ProNom.Trim().IsEmpty()
		&ProNom = 'TODOS OS PRODUTOS'
	EndIf

EndEvent

Event Enter

	Do case
		case &ProSts = Status_AtivoInativo.ATIVO
			&AuxProSts = Status_Produto.ATIVO
		case &ProSts = Status_AtivoInativo.INATIVO
			&AuxProSts = Status_Produto.INATIVO
		otherwise
			&AuxProSts = nullvalue(&AuxProSts)
	EndCase

	RCOOpenWindow1.LinkOpen = RELJAS133.Link(&EmpCod,&FilCod,&GrupHie,&ProSetCod,&ProClsPrdCod,&EstLoc,&SomenteComLocacao,&ProCod,&ProPadForCod,&AuxProSts,&ProTipDef,&ComSaldo,&OrdemExibicao, &MarCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


]]></Source>
