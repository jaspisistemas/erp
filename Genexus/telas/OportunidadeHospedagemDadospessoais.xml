        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&OptCidCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult AND not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		OportunidadeHospedagem(!'Dadospessoais', !'DadosHospedagem', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (not &GoingBack)
		BtnWizardFirstPrevious.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&OptMail = &WizardData.Dadospessoais.OptMail
	&OptFone = &WizardData.Dadospessoais.OptFone
	&OptCon = &WizardData.Dadospessoais.OptCon
	&OptCnpj = &WizardData.Dadospessoais.OptCnpj
	&OptRaz = &WizardData.Dadospessoais.OptRaz
	&Optcep = &WizardData.Dadospessoais.Optcep
	&OptLog = &WizardData.Dadospessoais.OptLog
	&OptNro = &WizardData.Dadospessoais.OptNro
	&OptBai = &WizardData.Dadospessoais.OptBai
	&OptCpl = &WizardData.Dadospessoais.OptCpl
	&OptCidCod = &WizardData.Dadospessoais.OptCidCod
	&PesCidCodNom = &WizardData.Dadospessoais.PesCidCodNom

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Dadospessoais.OptMail = &OptMail
	&WizardData.Dadospessoais.OptFone = &OptFone
	&WizardData.Dadospessoais.OptCon = &OptCon
	&WizardData.Dadospessoais.OptCnpj = &OptCnpj
	&WizardData.Dadospessoais.OptRaz = &OptRaz
	&WizardData.Dadospessoais.Optcep = &Optcep
	&WizardData.Dadospessoais.OptLog = &OptLog
	&WizardData.Dadospessoais.OptNro = &OptNro
	&WizardData.Dadospessoais.OptBai = &OptBai
	&WizardData.Dadospessoais.OptCpl = &OptCpl
	&WizardData.Dadospessoais.OptCidCod = &OptCidCod
	&WizardData.Dadospessoais.PesCidCodNom = &PesCidCodNom
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &OptCnpj.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','CNPJ | CPF'), DVMessageType.error, &OptCnpj.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OptRaz.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nome'), DVMessageType.error, &OptRaz.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &Optcep.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','CEP'), DVMessageType.error, &Optcep.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OptLog.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Endereço'), DVMessageType.error, &OptLog.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OptNro.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Número'), DVMessageType.error, &OptNro.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OptBai.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Bairro'), DVMessageType.error, &OptBai.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PesCidCodNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Cidade'), DVMessageType.error, &PesCidCodNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OptMail.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','E-mail'), DVMessageType.error, &OptMail.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OptFone.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Telefone'), DVMessageType.error, &OptFone.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OptCon.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Contato'), DVMessageType.error, &OptCon.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &OptCnpj.IsValid

	ValidaCpfCnpj.Call(&OptCnpj, &ErroCnpj, 'N') 
	
	IF &ErroCnpj = 1
		If &OptCnpj.Length() > 14
			Msg('ATENÇÃO! CNPJ Inválido! Obrigatório CNPJ') 
		Else
			Msg('ATENÇÃO! CPF Inválido! Obrigatório CPF') 
		EndIf
	EndIf
	
	if not &OptCnpj.IsEmpty() and &OptCnpj.Length() > 14
		ConsultaRFB.call(1, &OptCnpj,&AuxPesRaz,&AuxPesFan,&AuxPesCep,&AuxPesLog,&AuxPesNro,&AuxPesBai,&AuxPesCidUfeCod,&AuxPesCidCod,&AuxPesEml, &AuxPesFonNum,&HttpClient)
		if not &AuxPesRaz.IsEmpty()
			&OptRaz = &AuxPesRaz
		EndiF
		
		if not &AuxPesCep.IsEmpty()
			&OptCep = &AuxPesCep
		EndiF
		if not &AuxPesLog.IsEmpty()
			&OptLog = &AuxPesLog
		EndiF
		if not &AuxPesNro.IsEmpty()
			&OptNro = &AuxPesNro
		EndiF
		if not &AuxPesBai.IsEmpty()
			&OptBai = &AuxPesBai
		EndiF
		if not &AuxPesCidCod.IsEmpty()
			&OptCidCod = &AuxPesCidCod
			if &OptCidCod <> 0
				do 'Cidade'
			EndIf
		EndiF
		
		if &AuxPesEml.IsEmpty()
			&OptMail = &AuxPesEml
		EndIF
		if &AuxPesFonNum.IsEmpty()
			&OptFone = &AuxPesFonNum
		EndIF
	EndiF

EndEvent

Event &OptFone.IsValid

	FormataFone.Call(&OptFone, &OptFone)

EndEvent

Event &OptCep.IsValid

	FormataCEP.Call(&OptCep, &OptCep)

EndEvent

Sub 'Cidade'

	For each Order EmpCod,CidCod
		Where EmpCod = 1
		Where CidCod = &OptCidCod
		&AuxPesCidCodNom = CidCodNomUfe
		Exit
	EndFor

	&PesCidCodNom = &AuxPesCidCodNom

EndSub

