      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPRODIZIOVENDEDORES', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	
	Do 'loadRodizio'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&RodExtVen.TooltipText = "Quantos dias um Cliente pode Ficar sem Vendas."
	&RodExtLig.TooltipText = "Quantos dias um Cliente pode Ficar sem Visita."
	&EmpCod.Visible = False
	&FilCod.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For &sdtPessoaItem in &sdtPessoa
		
		&RodExcVenCod = &sdtPessoaItem.pesCod
		
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &sdtPessoaItem.PesCod
			
			&gridPesRaz = PesRaz
			Exit
		EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ex.FromImage(ActionDelete)
	&ex.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Doadd'

	GravaRodizioVendedor.Call(&EmpCod, &FilCod, &RodExt, &RodExtLig, &RodExtVen, &RodInt, &RodIntLig, &RodIntVen, &sdtPessoa, &RotIntSemVda, &RotIntSemVdaDias)
	msg('Dados Atualizados com Sucesso!')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'loadFuncionario'
	
	if &IsErroFuncionario = false
		&IsJahAdicionou = false
		For &sdtPessoaItem in &sdtPessoa
			If &sdtPessoaItem.PesCod = &PesCod
				&IsJahAdicionou = true
				Exit
			EndIf
		EndFor
		
		if &IsJahAdicionou = false
			
			&sdtPessoaItem = new()
			&sdtPessoaItem.PesCod = &PesCod
			&sdtPessoa.Add(&sdtPessoaItem)
			Grid.Refresh()
		EndIf
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PesCod.IsValid

	do 'loadFuncionario'

EndEvent

Event &ex.Click

	For &sdtPessoaItem in &sdtPessoa
		If &sdtPessoaItem.PesCod = &RodExcVenCod
			&Index = &sdtPessoa.IndexOf(&sdtPessoaItem)
			&sdtPessoa.Remove(&Index)
		EndIf
	EndFor

	grid.Refresh()

EndEvent

Sub 'loadFuncionario'

	&IsErroFuncionario = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesCod > 0
		Where PesIsVen = true
		&PesRaz = PesRaz
		Exit
	When none
		&IsErroFuncionario = true
		&PesRaz = 'VENDEDOR NÃO ENCONTRADO'
	EndFor

EndSub

Sub 'loadRodizio'

	&sdtPessoa.Clear()
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		
		&FilCodNom = EmpCodNom
		&RodInt = RodInt
		&RodIntLig = RodIntLig
		&RodIntVen = RodIntVen
		&RodExt = RodExt
		&RodExtLig = RodExtLig
		&RodExtVen = RodExtVen
		&RotIntSemVdaDias = RotIntSemVdaDias
		&RotIntSemVda = RotIntSemVda
		
		For Each Order EmpCod, RodExcVenCod
			&sdtPessoaItem = new()
			&sdtPessoaItem.PesCod = RodExcVenCod
			&sdtPessoa.add(&sdtPessoaItem)
		EndFor
	
		Exit
	EndFor

EndSub


]]></Source>
