      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[parm(in:&ChaveVarchar, in:&dataAno, in:&dataMes);
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
      </Part>
      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Data = yMDtoD(&dataAno, &dataMes, 1)
	tbProgresso.Visible = 0
	tbbotoes.Visible= 1
	
	&PadObs = &WebSession.Get(&ChaveVarchar)
	&sdtPedidos.FromJson(&PadObs)
	
	if &sdtPedidos.Count = 0
		msg('Nenhuma mensalidade selecionada para envio!')
		btnEnter.Visible = 0
	Endif

	
	loadwwpContext.Call(&wwpContext)
	
	For Each Order EmpCod
		WHere EmpCod = &wwpContext.EmpCod
		Where FilCod = &wwpContext.FilCod
		
		&FilNom = iif(FilNom.IsEmpty() or FilNom.IsNull(), FilRaz, FilNom)
		&EmlAss = 'Cobrança mensal: '+ upper(cmonth(&Data, 'pt')) + '/'+ trim(str(&dataAno))+ ' da '+ &FilNom
		
		Exit
	EndFor
	
	RetornaTemplatePadraoWhatsPorTipo(&wwpContext.EmpCod,TipoTemplateWhatsapp.MENSALIDADE,&MensagemWhats)
//	&MensagemWhats = 'Segue cópia da Nota Fiscal: XXXX, no valor de R$: XXX,XX'
	&Mensagem = 'Em anexo segue a nota fiscal e o boleto, referente a cobranca mensal: ' + cmonth(&Data, 'pt') + '/'+ trim(str(&dataAno))
	&Mensagem = &Mensagem.ToUpper()
		
	padraousuarioHora.Call('L', '#REMETENTE_MENSALIDADE#', &wwpContext.PesCod, &wwpContext.EmpCod, &NovoCorpoRemetente, &PadDtaMod, &PadDtaHorMod, 'P')
	padraousuarioHora.Call('L', '#OBSAUTOMATICA_MENSALIDADE#', &wwpContext.PesCod, &wwpContext.EmpCod, &ObsAutomatica, &PadDtaMod, &PadDtaHorMod, 'P')
//	padraousuarioHora.Call('L', '#ABASELECIONADA_MENSALIDADE#', &wwpContext.PesCod, &wwpContext.EmpCod, &AbaSelecionada, &PadDtaMod, &PadDtaHorMod, 'P')

	padraoUsuarioHora.Call('L', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')

	

	&IsEnviarEmail = iif(Substr(&PadObs, 1, 1) = '1', true, false)
	&IsEnviarWhats = iif(Substr(&PadObs, 2, 1) = '1', true, false)
	&EnviarTodosEmail = Substr(&PadObs, 3, 1)
	&EnviarTodosWhats = Substr(&PadObs, 4, 1)
	if &IsEnviarEmail = false and &IsEnviarWhats = false
		&IsEnviarEmail = true
		&IsEnviarWhats = true
	Endif
	do 'Mostra'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserFechar'

	wwpactions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &IsEnviarWhats.ControlValueChanged

	do 'Mostra'

EndEvent

Event &IsEnviarEmail.ControlValueChanged

	do 'Mostra'

EndEvent

Event Enter

	if &IsEnviarEmail = true or &IsEnviarWhats = true
		&PadObs = ''
		if &IsEnviarEmail = true
			&PadObs += '1'
		Else
			&PadObs += '0'
		EndIf
		if &IsEnviarWhats = true
			&PadObs += '1'
		Else
			&PadObs += '0'
		EndIf
		&PadObs += &EnviarTodosEmail
		&PadObs += &EnviarTodosWhats
		padraoUsuarioHora.Call('G', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
		
		btnEnter.Visible = 0
		
		tbBotoes.Visible = 0
		tbProgresso.Visible = 1
		
		&GUID = GUID.newGuid()
		&ProgressId = &GUID.ToString()
		
		&Varchar = cmonth(&Data, 'pt') + '/'+ trim(str(&dataAno))
		prcEnviaTodosEmail.Submit(&ProgressId, &ProgressId, &Varchar.ToUpper(), &IsEnviarEmail, &IsEnviarWhats, &sdtPedidos, &EmlAss, &EnviarTodosEmail, &EnviarTodosWhats, &Mensagem, &NovoCorpoRemetente, &ObsAutomatica, &wwpContext.PesCod)
		
		scaProgressBar.ProcessId = &ProgressId
		scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar.Start()
	Else
		msg('Marque alguma coisa para enviar!')
	EndIf

EndEvent

Event scaProgressBar.OnComplete

	msg('Envios realizados!')
	wwpActions.WCPopup_Close('')

EndEvent

Sub 'Mostra'

	tbEmail.Visible = &IsEnviarEmail
	tbWhats.Visible = &IsEnviarWhats

EndSub


]]></Source>
