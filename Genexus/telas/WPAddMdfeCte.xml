        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&FilCpj.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &MDFeCteChv.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Chave'), DVMessageType.error, &MDFeCteChv.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &MDFeCteVlrTot.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Valor Serviço'), DVMessageType.error, &MDFeCteVlrTot.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &MDfeCteCidCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Cidade Término'), DVMessageType.error, &MDfeCteCidCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &MDfeCtePso.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Peso'), DVMessageType.error, &MDfeCtePso.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &MDFeCteChv.IsValid

	ValidaChaveNota.Call(&MDFeCteChv,&IsErro)
	If &IsErro = False
		&TipEms = val(Substr(&MDFeCteChv,35,1))
	EndIf

EndEvent

Event &MdfeCteUfeCod.IsValid

	Do 'CarregaCidades'

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	Do Case
		Case &CheckRequiredFieldsResult = False
			msg('ATENÇÃO! Não foi possível adicionar Documento. Verifique!')
		Case &IsErro = true
			msg('ATENÇÃO! Não foi possível adicionar esta chave de nota pois a mesma não é válida. Verifique!')
		Case (&MDFeCteChv2.Trim().IsEmpty() and (&TipEms = 2 or &TipEms = 5))
			msg('ATENÇÃO! Esta chave de nota esta e MODO  EMISSÃO FS, favor informar segunda chave. Verifique!')
		OtherWise
			MDFE_CTE.Call('ADD', &EmpCod, &FilCod, &MDFeCod, 0, 0, 0,&MDFeCteChv,&MDFeCteChv2,&MDfeCteCidCod,'',&MdfeCteUfeCod,&MDFeCteVlrTot,&MDfeCtePso,'','')
			&MDFeCteChv = ''
			&MDFeCteVlrTot = 0
			&MDfeCtePso = 0
			
	EndCase

EndEvent

Sub 'CarregaCidades'

	For each Order EmpCod, UfeCod
		Where EmpCod = &EmpCod
		Where UfeCod = &MdfeCteUfeCod		
		&MDfeCteCidCod.AddItem(CidIBGE,CidNom)
	EndFor

EndSub


]]></Source>
