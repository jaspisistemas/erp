Event Start

	loadwwpContext.Call(&WWPContext)
	if &WWPContext.Old_Perfil < 3
		dashboard.Link()
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Page.Rows
	&Grid1CurrentPage = 1
	&Grid1CurrentPage.Visible = False
	&Grid1PageCount = -1
	Grid1PaginationBar.RowsPerPageSelectedValue = Grid1.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&Grid1PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case Grid1PaginationBar.SelectedPage = !'Previous'
			&Grid1CurrentPage -= 1
			Grid1.PreviousPage()
		Case Grid1PaginationBar.SelectedPage = !'Next'
			&Grid1CurrentPage += 1
			Grid1.NextPage()
		Otherwise
			&PageToGo.FromString(Grid1PaginationBar.SelectedPage)
			&Grid1CurrentPage = &PageToGo
			Grid1.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Grid1PaginationBar.RowsPerPageSelectedValue
	&Grid1CurrentPage = 1
	Grid1.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	For Each ORder ProgressId
		Where ProgressId = &ProgressId
		
		&ProgressIni = ProgressIni
		&ProgressLogXml = ProgressLogXml
		&ProgressValue = ProgressValue
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


