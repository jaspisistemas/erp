      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	&IsVisible = false

	tableMain.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&PedCod.Visible = False
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&IsVisible.Visible = False
	Grid.Rows = 10

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	If &PadObs = 'B'
		&actioUpda.Visible = 0
	EndIF

	&Qtd = 0
	For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where ProTipDef = Definicao.SERVICO when &ProdutoServico = 'SERVICO'
		Where ProTipDef <> Definicao.SERVICO when &ProdutoServico = 'PRODUTO'
		&GridEmpCod = EmpCod
		&GridFilCod = FilCod
		&GridPedCod = PedCod
		&ProCod = ProCod
		&ProGraRef = ProGraRef
		&PedItmCod = PedItmCod
		&ProNom = PedProNom
		&PedVlrItm = PedVlrItm
		&PedItmDsc = PedItmDsc
		&PedCodOciRefItm = PedCodOciRefItm
		
		&PedVlrUntComDsc = PedVlrUntComDsc
		tableMain.Visible = 1
		&PedQtd = PedQtd
		&PedItmDsc = PedItmDsc

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&actioUpda = !'<i class="fa fa-pen"></i>'
	
	&EliminarItem = !'<i class="fa fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		//&DeOndeVem = 'WWOFICINAMECANICA' or &DeOndeVem = 'WWORDEMSERVICO' JDF, SO TEM 1 BALCAO AGORA
		//&actioUpda.Link = wwpVendas2.Link(&DeOndeVem, 1, EmpCod, FilCod, PedCod, PedItmCod)
		&actioUpda.Link = wwpVendas_3.Link(&DeOndeVem, EmpCod, FilCod, PedCod, PedItmCod)
	
		Do case
			Case PedItmPrm = domPedItmPrm.PROMOCAO
				&PedVlrUntComDsc.ForeColor = RGB(200,0,0)
				&PedVlrItm.ForeColor = RGB(200,0,0)
				
			Case PedItmPrm = domPedItmPrm.DESCONTO
				&PedVlrUntComDsc.ForeColor = RGB(200,0,0)
				&PedVlrItm.ForeColor = RGB(200,0,0)
				
			Otherwise
				&PedVlrUntComDsc.ForeColor = RGB(0,0,0)
				&PedVlrItm.ForeColor = RGB(0,0,0)
		EndCase
		
		&ProNom.Link = VerProduto.Link('DashBoard', EmpCod, ProCod)
		&ProNom.LinkTarget = '_blank'
		
		
		&MarNom = MarNom
		&Mecanico = ''
		If PedItmVenCod > 0
			RetornaNomeFuncionario.Call(EmpCod, PedItmVenCod, &PesIsFun, &PesRaz)
			&Mecanico = trim(str(PedItmVenCod)) + ' - ' + trim(&PesRaz)
		EndIF
		
		&Qtd += 1
		load
		if &Qtd >= 7
			Exit
		EndIF
	
	EndFor

EndEvent

Event 'DoCancelar'

	&IsVisible = false
	
	do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbGridProdutos.Visible = (&IsVisible = false)
	tbRemoverItem.Visible = (&IsVisible = true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	loadwwpContext.Call(&Context)
	
	padraoUsuario.Call('L', 'MODOINSERCAOVENDA', &Context.PesCod, &EmpCod, &padObs, &PadDtaMod)

	If &PadObs = 'B'
		&actioUpda.Visible = 0
	EndIF
	do 'servicoProduto'

EndEvent

Event &EliminarItem.Click

	&IsVisible = true
	&gridPedItmCod = &PedItmCod
	txtRemove.Caption = 'Deseja Remover o Produto: ' + trim(&ProGraRef) + newLine() + &ProNom.Trim()
	+ NewLIne() + 'R$ ' + trim(toformattedString(&PedVlrItm))
	
	do 'AttributesSecurityCode'

EndEvent

Event Enter

	DeletaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &gridPedItmCod)

	//Case &DeOndeVem = 'WWOFICINAMECANICA' or &DeOndeVem = 'WWORDEMSERVICO' or &DeOndeVem = 'WWPEDIDOBALCAO'
	//wwpVendas2.Link(&DeOndeVem, 1, &EmpCod, &FilCod, &PedCod, &PedItmCod)
	wwpVendas_3.Link(&DeOndeVem, &EmpCod, &FilCod, &PedCod, &PedItmCod)

EndEvent

Sub 'servicoProduto'

	if &ProdutoServico = 'SERVICO'
		&ProNom.Title = 'Descrição do Serviço'
		&ProCod.Title = 'Serviço'
		&MarNom.Visible = 0
		&PedItmDsc.Visible = 0
	Else
		&ProNom.Title = 'Descrição do Produto'
		&ProCod.Title = 'Produto'
		&Mecanico.Visible = 0
	EndIF

EndSub


]]></Source>
