      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&RemoveUsuario = True
	&InativaFuncionario = True
	
	TbInfoUsu.Visible = &RemoveUsuario
	TxtInforma.Visible = &RemoveUsuario
	
	
	Do 'BuscaUsuGam'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TbUsuario.Width = 300
	TbGUID.Width = 300

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmarInativar'

		If &InativaFuncionario = True
			prcInativaFuncionarioAoDemitir.Call(&EmpCod, &wwpContext.FilCod, &PesCod, &wwpContext.UserName)
		Endif
	
		if &RemoveUsuario = True
			&User.Load(&GamGUID)
			&User.IsActive = False
			&User.IsBlocked = True
			&User.Save()
			If &User.Success()
				commit
			Else
				msg('Erro')
				&Errors = &User.GetErrors()
				For &Error in &Errors
					Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
				EndFor
			Endif
			
		Endif
	
	GravaRecrutamento.Call(&mode,&EmpCod,&PesCod,&PesRecCod,&PesRecCodMax,&PesRecDtaAdm,&PesRecDtaReg,&PesRecDtaDem,&Obs, &wwpContext.PesCod)
	AtualizaEnderecoCliente.Call(&EmpCod, &PesCod)
	
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnCancelar'

	Return

EndEvent

Event &RemoveUsuario.ControlValueChanged

	TbInfoUsu.Visible = &RemoveUsuario
	TxtInforma.Visible = &RemoveUsuario

EndEvent

Sub 'BuscaUsuGam'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PesExtCod = PesExtCod
		
		Exit
	EndFor
	
	&Filter.ExternalId = trim(str(&PesExtCod)) //## Define o filtro que será usado no GetUser ##\\
	
	For &User in GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors) //## Procura o GAMGUID do usuário e envia a notificação para o mesmo ##\\
		&GamGUID 		= 	&User.GUID
		&UserNome 		= 	&User.FirstName
		&UserUsuario	= 	&User.Name
		&UserEmail		= 	&User.EMail
		Exit
	EndFor

EndSub


]]></Source>
