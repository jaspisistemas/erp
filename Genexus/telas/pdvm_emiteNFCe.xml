Sub 'loadTemporaria'

	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNFeCod
		
		//if tmpMarDesMar = false
		//	BtnMarcarDesmarcar.Caption = 'Marcar Todos'
		//else
		//	BtnMarcarDesmarcar.Caption = 'Desmarcar Todos'
		//Endif
		&PedVlrLiq = tmpTotNFe
		&FatFilCod = tmpNfeFatFilCod
		&PesRaz = tmpPedCliNom
		&PesCpf = tmpPedCliCpf
		&PesCnpj = tmpPedCliCnpj
		&PesTip = tmpPedCliTip
		
		&tmpTotOut = tmpTotOut
		Exit
	EndFor

EndSub

Sub 'AtualizaNotaTemporaria'

	AtualizaCapaNotaTemporariaVendaImpacta.Call(&tmpNFeCod, &EmpCod, &FilCod, &FatFilCod, &PedCod, &tmpNfeVlrFrt, &tmpTotOut, &IsDescontoImpresso, &tmpNfeVlrDsc, &tmpNfePerDsc, &TipoDesconto,'9',false)
	refresh

EndSub

Sub 'GravaCliente'

	GravaClienteTemporariaModelo65.Call(&tmpNFeCod, &PesTip, &PesCnpj, &PesCpf, &PesRaz)

EndSub

Sub 'confirmaEmissaoNFCe'

	If &FilAmbEms = TAmb.Producao
		ValidaCpfCnpj.Call(&PesCnpj, &CnpjStatus, 'N')	
		ValidaCpfCnpj.Call(&PesCpf, &CpfStatus, 'N')
		
		Do CAse
			Case (&CpfStatus = 1 and &PesTip = TipoPessoa.FISICA) 
				msg('CPF Informado é inválido!')
				
			Case (&CnpjStatus = 1 and &PesTip = TipoPessoa.JurIDICA)
				msg('CNPJ Informado é inválido!')
				
			Otherwise
				if &PedVlrLiq > 0
					do 'GravaCliente'
					
					validacoesNFCe.Call(&tmpNFeCod, &EmpCod, &FilCod, &PedCod, &validacaoMensagem)
					
					if &validacaoMensagem.IsEmpty()				
						&EmitirConferir = 'E'
						&TelaOrigem = 'PDV_M'
						GravaNotaFiscalModelo65.Call(&TelaOrigem, &EmpCod, &FilCod, &PedCod, &tmpNFeCod, &EmitirConferir, &Context.PesCod, &PesEml)
					Else
						msg(&validacaoMensagem)
					EndIf
					
				Else
					pdv_m.Link()
				ENdiF
				
		EndCase
	Else
		msg('Empresa Em de Nota fiscal em HOMOLOGACAO!')
	EndIf

EndSub

Sub 'Pedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&FilAmbEms = FilAmbEms
		&LctBasImpCod = LctBasImpCod
		&PedCliCidUfeCod = PedCliCidUfeCod
		&PedCliGruImpCod = PedCliGruImpCod
		Exit
	EndFor

EndSub


