Sub 'loadNFCe'

	btnTransmitirNFCe.Visible = 0
	
	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&FilCod = &WizardData.CapaNFCe.FilCod
	&NfeCod = &WizardData.CapaNFCe.NfeCod
	&EmpCod = &WizardData.CapaNFCe.EmpCod
	If &NfeCod = 0
		wwNotasNFce.Link()
	EndIF

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&NfeVlrTotPro = NfeVlrTotPro
		&NfeVlrTotFrt = NfeVlrTotFrt
		&NfeVlrTotIpi = NfeVlrTotIpi
		&NfeVlrTotSeg = NfeVlrTotSeg
		&NfeVlrTotOutDsp = NfeVlrTotOutDsp
		&NfeVlrTotDsc = NfeVlrTotDsc
		&NfeVlrTotPdg = NfeVlrTotPdg
		&NfeVlrTotBasIcms = NfeVlrTotBasIcms
		&NfeVlrTotIcms = NfeVlrTotIcms
		&NfeVlrTotBasIcmsSt = NfeVlrTotBasIcmsSt
		&NfeVlrTotIcmsSt = NfeVlrTotIcmsSt
		&NfeVlrTot = NfeVlrTot
		&NfeVlrTotApxTrib = NfeVlrTotApxTrib


		&NfeSts = NfeSts
		&IsAutorizada = false
		if NfeSts <> Status_Nfe.Digitando and NfeProTer = Nota_ProPriaTerceira.PROPRIA
			&IsAutorizada = true			
			&ActionDele.Visible = 0
			btnaddParcela.Visible = 0
		Endif
		
		If NfeSts = Status_NFe.Digitando and NfeVlrTot > 0
			btnTransmitirNFCe.Visible = 1
		EndiF
	
		Exit
	EndFor

EndSub

Sub 'AtualizaDuplicata'

	NovaDuplicataNFe.Call('ALT', &EmpCod, &FilCod, &NfeCod, &gridNfeDupItmCod, &gridNfeDupNro, NfeDupVct, &gridNfeDupVlr, &gridNfeCbrCod)
	RetornaTotalDuplicatasNFe.Call(&EmpCod, &FilCod, &NfeCod, &TotMovItmVlr, &CarMovItmVlr, &TotDebVlrDup, &TotCreVlrDup, &TotalMoeda )
	&Diferenca = &NfeVlrTot - &TotalMoeda

EndSub


