      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWCATEGORIAPRODUTOS', Status_SimNao.Sim, 1, &AutNiv)
	
	do 'LoadObs'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 493
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EditarDescricao = !'<i class="fa fa-pen"></i>'
	
	&ActionSelecione.FromImage(DDOMultiselSelOption)
	&ActionSelecione.TooltipText = ""

	&IsSelecionado = RetornaObsCategoriaProduto.Udp(EmpCod, &GrupCod, OGrupCod, 0, 'O')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &IsSelecionado <> true
		&ActionSelecione.FromImage(DDOMultiselOption)
	Endif

EndEvent

Event 'DoAddObservaca'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ObservacoesCategoria.PopUp(TrnMode.Insert, &EmpCod, 0)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &EditarDescricao.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ObservacoesCategoria.PopUp(TrnMode.Update, EmpCod, OGrupCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ActionSelecione.Click

	if &IsSelecionado = true
		&ActionSelecione.FromImage(DDOMultiselOption)
		&IsSelecionado = false
		prcGravaObservacaoCategoria.Call('DEL', EmpCod, &GrupCod, OGrupCod, 0, 'O')
	Else
		&ActionSelecione.FromImage(DDOMultiselSelOption)
		&IsSelecionado = true
		prcGravaObservacaoCategoria.Call('ADD', EmpCod, &GrupCod, OGrupCod, 0, 'O')
	Endif

EndEvent

Sub 'LoadObs'

	For Each Order EmpCod, GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &GrupCod
		&GrupNom = GrupNom
		Exit
	EndFor

EndSub


]]></Source>
