Event Start

	retornaAutorizacao.Call('WPDEMONSTRATIVORESULTADO', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&PedDtaFat = yMDtoD(year(&Today),month(&Today),1)
	&PedDtaFat_Go = eoM(&Today)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS096.link(&EmpCod,&FilCod,&PedDtaFat,&PedDtaFat_Go,&MostrarPlanosSemDre)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


]]></Source>
