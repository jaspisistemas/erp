        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	retornaAutorizacao.Call('WWCONFIGERPFOCAVENDAS', Status_SimNao.Sim, 1, &AutNiv)
	prcInicializaConfiguracoesApp.Call(&Context.EmpCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 157
	UnnamedTable5.Height = 9
	UnnamedTable3.Height = 9
	
	AppCod.Visible = False
	EmpCod.Visible = False

	Grid.Rows = Page.Rows
	Form.Caption = ' Configuracoes App Off-Line Força Vendas'

	Do 'PrepareTransaction'
	Do 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&AppCod = AppCod
	Do CAse
		CAse AppCod = TipOAplicativo.MESAS
			&AppDescricao = 'MÓDULO ADICIONAL para controle de vendas em mesas, restaurante, lanchonetes!'
		CAse AppCod = TipOAplicativo.FORCAVENDAS
			&AppDescricao = 'MÓDULO ADICIONAL ao Aplicativo ERP, permite aos vendedores externos continuarem a vender mesmo sem internet!'
			
	EndCAse

	
	btnUserUsuarios.Visible = 1
	if AppCod <> TipoAplicativo.FORCAVENDAS
		btnUserUsuarios.Visible = 0 
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DouserModificar'

	ConfigErpForcaVendas.Popup(TrnMode.Update, EmpCod, AppCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserUsuarios'

	wwConfiguracoesUsuarios.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtnAndroid'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	BtnAndroid_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event BtnAndroid_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcAppERP.Create()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"EMPCOD"
				&EmpCod.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndSub

Sub 'SaveGridState'

	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"EMPCOD", "", not &EmpCod.IsEmpty(), 0, &EmpCod.ToString().Trim(), '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"ConfigErpForcaVendas"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event TabbAndroid.Click

	BtnAndroid_Modal.Confirm()

EndEvent


