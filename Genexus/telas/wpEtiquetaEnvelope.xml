      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPETIQUETAENVELOPE', Status_SimNao.Sim, 1, &AutNiv)
	&DadosRemetente = Status_SimNao.Sim
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&AuxPesCod = &Context.PesCod

	PadraoUsuario.Call('L', 'wpEtiquetaEnvelope', &Context.PesCod, &Context.EmpCod, &Padobs, &PadDtaMod)
	if not &Padobs.IsEmpty()
		&OqueFazer = Substr(&Padobs, 1, 1)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBuscar'

	do 'localizaCliente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'F4'

 4
	PromptCliente.Popup(&EmpCod, &PesCod)
	&PesCod.SetFocus()

EndEvent

Event Enter

	&Padobs = &OqueFazer
	PadraoUsuario.Call('G', 'wpEtiquetaEnvelope', &Context.PesCod, &Context.EmpCod, &Padobs, &PadDtaMod)
	
	&Random = (random() * 1000000)
	Do case
		CAse &OqueFazer = 'A' //RIBOM
			&Window.Url = RELJAS071.Link(&Random, &EmpCod, &FilCod, &PesCod, &DadosRemetente, &PesEntCep, &PesRaz, &PesEntBai, &PesEntCidNom, &PesEntLogNro, &PesRef, &PesFonNum)
			&Window.Open()
			
		Case &OqueFazer = 'B' //A4
			&Window.Url = RELJAS071_A4.Link(&Random, &EmpCod, &FilCod, &PesCod, &DadosRemetente, &PesEntCep, &PesRaz, &PesEntBai, &PesEntCidNom, &PesEntLogNro, &PesRef, &PesFonNum)
			&Window.Open()
	EndCase

EndEvent

Event &PesCod.IsValid

	if &OldPesCod <> &PesCod
		do 'localizaCliente'
		&OldPesCod = &PesCod
	EndIF

EndEvent

Event &PesFonNum.IsValid

	FormataFONE.Call(&PesFonNum, &PesFonNum)

EndEvent

Sub 'localizaCliente'

	&PesRaz.SetEmpty()
	&PesEntCep.SetEmpty()
	&PesEntBai.SetEmpty()
	&PesEntCidNom.SetEmpty()
	&PesEntLogNro.SetEmpty()
	&PesRef.SetEmpty()	
	&PesFonNum.SetEmpty()
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesRaz = PesRaz
		&PesEntCep = PesEntCep
		&PesEntBai = PesEntBai.Trim()
		&PesEntCidNom = PesEntCidNom.Trim() +' - '+ trim(PesEntUfeCod)
		&PesEntLogNro = PesEntLogNro
		&PesRef = PesRef
		For Each Order EmpCod, PesCod, PesFonCod
			&PesFonNum = PesFonNum
			Exit
		EndFor
		
		Exit
	EndFor

EndSub


]]></Source>
