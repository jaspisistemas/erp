Event Start

	pro.Visible = 1
	funcaoAutorizada.Visible = 0
	Sucesso.Visible = 0
	
	Falha.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&CteCod.Visible = False
	&CteArqXml.Visible = False
	&MDFeCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&Context)
	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&EmpCod = &WizardData.Geral.EmpCod
	&FilCod = &WizardData.Geral.FilCod
	&CteCod = &WizardData.Geral.CteCod
	&SolCod = &WizardData.Geral.SolCod
	
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CteChv = CteChv
		if CteSts = Status_NFe.Digitando
			&Random = random()* 10
			&ProgressId = 'autoCTe' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			RecepcaoCte.Submit('RecepcaoCTe', &ProgressId, &EmpCod, &FilCod, &CteCod, &SolCod)
			txtMsg.Caption = ''
		Else
			WWCte.Link()
		EndIF
		
		Exit
		
	When none
		WWCte.Link()
	EndFor

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCapaCte'

	WPCte(!'Capa', !'Geral', false)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRetransmitir'

7
	//GRAVA XML AUTORIZACAO
	GeraXmlCteModelo57.Call(&EmpCod, &FilCod, &CteCod,'S',&Context.PesCod,&SolCod)
	&WizardData.Geral.EmpCod = &EmpCod
	&WizardData.Geral.FilCod = &FilCod
	&WizardData.Geral.CteCod = &CteCod
	&WizardData.Geral.SolCod = &SolCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())
	WPCte(!'Avancado', !'Transmitir', false)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConsultarCte'

	GravaConsultaSefazCte.Call('WWCTE', &EmpCod, &FilCod,&CteCod, &Context.PesCod, &SolCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovoCte'

	2

	&WebSession.Remove(&WebSessionKey)
	WPCte.Call(&PreviousStep, &CurrentStep, &GoingBack)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoReimprimir'

8

	Do 'ImprimeCte'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEmitirmdfe'

	GravaMdfe_Cte.Call(&EmpCod,&FilCod, &CteCod, &MdfeCod)
	Do 'PegaPlacaeValida'
	If &IsMdfeAberto = True
		wpencerramentoMDFeTransmitir.call(&EmpCod,&FilCod,&MdfeCod,&MDFeVeiPla,&OldFilCod,&OldMdfeCod,&WebSessionKey)
	Else
		ValidaCteMdfe.Call(&EmpCod, &FilCod, &CteCod, &IsAchou)
		If &IsAchou = False
			&WebSession.Remove('WPMDFE01_Data')
			&MdfWizardData.Mdfe.EmpCod = &EmpCod
			&MdfWizardData.Mdfe.FilCod = &FilCod
			&MdfWizardData.Mdfe.MdfeCod = &MdfeCod
			&WebSession.Set('WPMDFE01_Data', &MdfWizardData.ToJson())
			wpMDFe01.Call('', 'Mdfe', false)
		Else
			Msg('ATENÇÃO! Já existe um MDFe com status AUTORIZADO utilizando este CT-e, verifique e adicione um MDFe pelo monitora.')
		EndIf
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAverbaCte'

	Do 'ValidaUsuario' 
	
	If &IsValido = True and not &CteArqXml.IsEmpty()
		TransmiteAverbacao.call(&EmpCod,&FilCod,&CteCod,&SdtAtm,&IsSucesso)
	Else
		Msg('Não foi Possível transmitir a averbação, pois usuário e senha inválido ou documento não autorizado!')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&EmpCod = &WizardData.Transmitir.EmpCod
	&FilCod = &WizardData.Transmitir.FilCod
	&CteCod = &WizardData.Transmitir.CteCod
	&CteArqXml = &WizardData.Transmitir.CteArqXml
	&MDFeCod = &WizardData.Transmitir.MDFeCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Transmitir.EmpCod = &EmpCod
	&WizardData.Transmitir.FilCod = &FilCod
	&WizardData.Transmitir.CteCod = &CteCod
	&WizardData.Transmitir.CteArqXml = &CteArqXml
	&WizardData.Transmitir.MDFeCod = &MDFeCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'FinishWizard'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	pro.Visible = 0
	
	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		
		txtMsg.ForeColor = RGB(210,130,0)
		txtMsg.Caption = ProgressLogXml.Trim()
		
		do 'ImprimeCte'
		Exit
	EndFor

EndEvent

Sub 'ImprimeCte'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CteArqXml = CteArqXml
		If not CteArqXml.IsEmpty() and CteSts = Status_NFe.Autorizada
			
			funcaoAutorizada.Visible = 1
			Sucesso.Visible = 1
			
			GravarStatusIMpressaoCte.Submit('GravarStatusIMpressaoCte', EmpCod, FilCod, CteCod,0)
			txtMsg.ForeColor = RGB(0,210,25)
			
			GeraPdfDacte_web.Call(EmpCod, FilCod, CteCod, &UrlPDF, &UrlFisico)
		
			
			RCOOpen.LinkOpen = link(&UrlPDF)
			RCOOpen.OpenWindow(True, 500, 500, True, 0, 0, False)
			
			
		Else
			Falha.Visible = 1
		EndIF
	
		
		Exit
	EndFor

EndSub

Sub 'PegaPlacaeValida'

	&MDFeVeiPla = ''
	&IsMdfeAberto = False
	For each Order EmpCod,FilCod,MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		&MDFeVeiPla = MDFeVeiPla
		Exit
	EndFor
	If Not &MDFeVeiPla.IsEmpty()
		Do 'ValidaMdfeNaoEncerrado'
	EndIf

EndSub

Sub 'ValidaMdfeNaoEncerrado'

	For each Order EmpCod,MDFeCod
		Where EmpCod = &EmpCod
		Where MDFeCod <> &MDFeCod
		Where MDFeVeiPla = &MDFeVeiPla
		Where MDFeSts = Status_Mdfe.Autorizado
		&OldFilCod = FilCod
		&OldMdfeCod = MDFeCod
		&IsMdfeAberto = True
		Exit
	When none
		//nao achou por placa pega, mdfe com mais de 15 dias autorizado.
		&MDFeDtaEms = &Today-15
		For each Order EmpCod,MDFeCod
			Where EmpCod = &EmpCod
			Where MDFeCod <> &MDFeCod
			Where MDFeDtaEms <= &MDFeDtaEms
			Where MDFeSts = Status_Mdfe.Autorizado
			&OldFilCod = FilCod
			&OldMdfeCod = MDFeCod
			&IsMdfeAberto = True
			Exit
		EndFor
	EndFor

EndSub

Sub 'validaUsuario'

	&IsValido = False
	For each Order EmpCod,FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		&SdtAtm.codigoatm = FilAtmCod
		&SdtAtm.senha   = FilAtmSen
		&SdtAtm.usuario = FilAtmUsu
		
		&FilAtmCod = FilAtmCod
		&FilAtmUsu = FilAtmUsu
		&FilAtmSen = FilAtmSen
		exit
	EndFor
	If not &FilAtmCod.Trim().IsEmpty() and not &FilAtmUsu.Trim().IsEmpty() and not &FilAtmSen.Trim().IsEmpty()
		&IsValido = True
	EndIf

EndSub


