      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWCADASTROUSUARIOS', Status_SimNao.Sim, 3, &AutNiv)
	
	&User.Load(&UserId)
	If not &User.Success()
		Return
		//Msg("User not found.")
		TableAttributes.Visible = False
	Else
		TableAttributes.Visible = True
		&UserName 			= &User.Name
		&UserPasswordNew	= ""
		&UserPasswordNewConf= ""
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &UserPasswordNew = &UserPasswordNewConf 
		&User.Load(&UserId)
		If &User.Success()
			&IsChanged = &User.SetPassword(&UserPasswordNew, &Errors)
			If &IsChanged = true
				Commit
				&UserPasswordNew.Enabled 	= False
				&UserPasswordNewConf.Enabled= False
				BtnEnter.Visible = False
				Msg("Senha Modificada com Sucesso.")
			Else
				//&Errors = &User.GetErrors()
				//Msg("erro1.")
				Do 'DisplayMessages'
			Endif
			
		Else
			&Errors = &User.GetErrors()
			Do 'DisplayMessages'
			//Msg("erro2.")
		Endif
	Else
		Msg("A Nova Senha e a Confirmação de Senha não Correspondem.")
	Endif

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


]]></Source>
