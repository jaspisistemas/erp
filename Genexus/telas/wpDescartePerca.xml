      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpcontext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	padraousuarioHora.Call('L', '#WPDESCARTEPERCA#', &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PAdDtaMod, &PadDtaHorMod, 'P')
	&BaseLctCod.FromString(&PadObs)
	do 'loadComboBox'
	do 'loadProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PadObs = trim(str(&LctCod))
	padraousuarioHora.Call('G', '#WPDESCARTEPERCA#', &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PAdDtaMod, &PadDtaHorMod, 'P')
	
	Do Case
		CAse &LctCod.IsEmpty() 
			msg('Informe Operação a ser realizada!')
			&LctCod.SetFocus()
			
		Case &PedQtd <= 0
			msg('Informe Quantidade a ser retirada!')
			&PedQtd.SetFocus()
		
		Case &PedQtd > &EstQtd
			msg('Quantidade Menor que a disponivel no estoque!')
			&PedQtd.SetFocus()
			
		Case &LctCod > 0  and &PedQtd > 0
			prcGravaOutrasSaidas.Call(&EmpCod, &FilCod, &PrOCod, &ProGraCod, &LctCod, &PedQtd)
			Return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'loadComboBox'

	For Each Order EmpCod, LctTip, LctCod
		Where EmpCod = &EmpCod
		Where LctTip = TipoLancamento.OutrasSaidas
		
		&LctCod.AddItem(LctCod, LctCodNom)
		
		if &BaseLctCod.IsEmpty()
			&BaseLctCod = LctCod
		Endif
	EndFor
	
	&LctCod = &BaseLctCod

EndSub

Sub 'loadProduto'

	For Each ORder EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &PRoGraCod
		
		&ProEmbUnd = ProEmbUnd
		&ProNom = ProNomGra
		&MarNom = MarNom
		
		Exit
	EndFor
	
	For Each order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&Estqtd 	= EstQtd
		
		Exit
	EndFor

EndSub


]]></Source>
