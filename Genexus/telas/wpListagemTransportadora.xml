      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPLISTAGEMTRANSPORTADORA', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&AcePesCod = &Context.PesCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&RelacaoPedidos.TooltipText = "Fazer impressão da listagem de Pedidos ou Separados por transportadoras."
	&TipoRelatorio.TooltipText = "Filtrar Pedidos pela Transportadora de Saída ou de Redespacho?"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&iniPedDtaEmb = serverdate()
	&finPedDtaEmb = &iniPedDtaEmb
	&finPedDtaDsp = &iniPedDtaEmb
	&finPedDtaFat = &iniPedDtaEmb
	&LctAtuEst = Status_EntradaSaida.Saida
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&TipoRelatorio = trim(Substr(&PadObs,1,1))
		&RelacaoPedidos = trim(Substr(&PadObs,2,1))
	EndIf
	
	do 'LoadTransportadora'
	do 'LoadCliente'
	do 'LoadVendedor'

EndEvent

Event 'DoEtiquetasVolume'

	wpGeraEtiquetaVolume.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedVenCod.IsValid

	do 'LoadVendedor'

EndEvent

Event &PedCliCod.IsValid

	do 'LoadCliente'

EndEvent

Event &PedTraSaiCod.IsValid

	do 'LoadTransportadora'

EndEvent

Event Enter

	&PadObs = &TipoRelatorio + &RelacaoPedidos
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod,&Context.EmpCod, &PadObs, &PadDtaMod)
	
	do 'LoadTransportadora'
	do 'LoadCliente'
	do 'LoadVendedor'
	
	if &IsErroTransportadora = false and &IsErroCliente = false and &IsErroVendedor = FALSE
		If &RelacaoPedidos = 'S'
			RCOOpenWindow1.LinkOpen = RELJAS018.Link(&EmpCod, &FilCod, &PedCliCod, &PedVenCod, &iniPedDtaEmb, &finPedDtaEmb, &iniPedDtaDsp, &finPedDtaDsp, &iniPedDtaFat, &finPedDtaFat, &PedTraSaiCod, &TipoRelatorio, &LctAtuEst, &OrdemExibicao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Else
			RCOOpenWindow1.LinkOpen = RELJAS017.Link(&EmpCod, &FilCod, &PedCliCod, &PedVenCod, &iniPedDtaEmb, &finPedDtaEmb, &iniPedDtaDsp, &finPedDtaDsp, &iniPedDtaFat, &finPedDtaFat, &PedTraSaiCod, &TipoRelatorio, &LctAtuEst, &OrdemExibicao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		EndIF
	EndiF

EndEvent

Sub 'LoadTransportadora'

	&IsErroTransportadora = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedTraSaiCod
		Where PesIsTra = true
		&PedTraSaiRaz = PesRaz
		Exit
	When none
		If &PedTraSaiCod = 0
			&PedTraSaiRaz = 'TODAS AS TRANSPORTADORAS'
		Else
			&PedTraSaiRaz = 'TRANSPORTADORA NÃO ENCONTRADA'
			msg(&PedTraSaiRaz)
			&IsErroTransportadora = true
		EndIF
	EndFor

EndSub

Sub 'LoadCliente'

	&IsErroCliente = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		&PedCliRaz = PesRaz
		Exit
	When none
		If &PedCliCod = 0
			&PedCliRaz = 'TODOS OS CLIENTES'
		Else
			&PedCliRaz = 'CLIENTE NÃO ENCONTRADO'
			msg(&PedCliRaz)
			&IsErroCliente = true
		EndIF
	EndFor

EndSub

Sub 'LoadVendedor'

	&IsErroVendedor = FALSE
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedVenCod
		Where PesIsVen = true
		&PedVenRaz = PesRaz
		Exit
		
	When None
		If &PedVenCod <> 0
			&PedVenRaz = 'VENDEDOR NÃO LOCALIZADO'
			msg(&PedVenRaz)
			&IsErroVendedor = TRUE
		Else
			&PedVenRaz = 'TODOS OS VENDEDORES'
		EndIF
	EndFor

EndSub


]]></Source>
