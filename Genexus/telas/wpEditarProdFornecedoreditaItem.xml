      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	TableMain.Height = 400

	Do 'AttributesSecurityCode'
	&tmpNFeCod.Visible = False
	&tmpNfeItmCod.Visible = False
	&PesCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each ORder tmpNFeCod, tmpNfeItmCod
		Where tmpNFeCod = &tmpNFeCod
		Where tmpNfeItmCod = &tmpNfeItmCod
		&AuxtmpProForCod = tmpProForCod.Trim()
		&PesCod = tmpEmixCod
		&DateTime = ServerNow()
		DateTimeToTimestamp.Call(&DateTime, &Timestamp)
		if &Timestamp < 0
			&Timestamp = &Timestamp * -1
		Endif
		&AuxtmpProForCod += '-J' + trim(&Timestamp.ToString())
		Explanation.Caption = format('Nessa etapa para fazer o ajuste vamos gravar o código do fornecedor + um "-J" + Random, ex: veio na nota do produto o codigo %1. O ERP JASPI vai gravar %2', tmpProForCod.Trim(), &AuxtmpProForCod)
		Exit
	EndFor

EndEvent

Event Enter

	Do Case
		CAse &Opcao = 'A'
			prcAtualizaCodigoFornecedor.Call(&wwpContext.EmpCod, &tmpNFeCod, &tmpNfeItmCod, &AuxtmpProForCod, '')
			return
			
		CAse &Opcao = 'B'
			if not &produtojaLancado.IsEmpty() and not &Procod.IsEmpty() and not &ProNom.IsEmpty()
				prcAtualizaCodigoFornecedor.Call(&wwpContext.EmpCod, &tmpNFeCod, &tmpNfeItmCod, &produtojaLancado, &ProRef)
				return
			else
				msg('Produto não selecionado!')
			Endif
		
		Case &Opcao = 'NAO TEMPOCAO'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCAse

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	wpEditarProdFornecedor(!'editaItem', !'BemVindo', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UserAction1_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event UserAction1_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = promptProdutoFornecedor.Create(&PesCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event UserAction1_Modal.Close

	&ProRef = &WebSession.Get('wpeditacodigoproref')
	&WebSession.Remove('wpeditacodigoproref')
	
	&Varchar = &WebSession.Get('wpeditacodigoprocod')
	&Procod = val(&Varchar)
	&WebSession.Remove('wpeditacodigoprocod')
	
	&ProNom = &WebSession.Get('wpeditacodigopronom')
	&WebSession.Remove('wpeditacodigopronom')
	
	&produtojaLancado = &WebSession.Get('wpeditacodigoprojalancado')
	&WebSession.Remove('wpeditacodigoprojalancado')
	
	txtProduto.Caption = format('PRODUTO SELECIONADO: %1 - %2 - %3', &produtojaLancado, trim(&ProRef), &ProNom.Trim())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&Opcao = &WizardData.editaItem.Opcao
	&tmpNFeCod = &WizardData.editaItem.tmpNFeCod
	&tmpNfeItmCod = &WizardData.editaItem.tmpNfeItmCod
	&PesCod = &WizardData.editaItem.PesCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &WizardData.editaItem.tmpNFeCod.IsEmpty() or &WizardData.editaItem.tmpNFeCod.IsEmpty()
		return
	Endif
	
	&Opcao = 'E'

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.editaItem.Opcao = &Opcao
	&WizardData.editaItem.tmpNFeCod = &tmpNFeCod
	&WizardData.editaItem.tmpNfeItmCod = &tmpNfeItmCod
	&WizardData.editaItem.PesCod = &PesCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'FinishWizard'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableInfo.Visible = (&Opcao = 'A')
	TableInfo1.Visible = (&Opcao = 'B')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	BtnWizardLastNext.Visible = &Opcao <> 'E'

EndSub

Event &Opcao.IsValid

	do 'AttributesSecurityCode'

EndEvent


]]></Source>
