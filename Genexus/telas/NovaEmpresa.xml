      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	WizardStepDescription.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'BemVindo'
	&WizardStep.Title = 'Bem Vindo'
	&WizardStep.Description = 'Bem Vindo'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'CodigoAcesso'
	&WizardStep.Title = 'Código Acesso'
	&WizardStep.Description = 'Código Acesso'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'NovoUsuario'
	&WizardStep.Title = 'Novo Usuário'
	&WizardStep.Description = 'Novo Usuário'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'BemVindo'
		&WebSession.Remove(&Pgmname + !'_Data')
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsUnderlineWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'BemVindo'
			WizardStepWC.Object = NovaEmpresaBemVindo.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'CodigoAcesso'
			WizardStepWC.Object = NovaEmpresaCodigoAcesso.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'NovoUsuario'
			WizardStepWC.Object = NovaEmpresaNovoUsuario.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: AssignWizardStepDescription
	WizardStepDescription.Caption = ""
	&StepNumber = 1
	for &WizardStep in &WizardSteps
		if &WizardStep.Code = &CurrentStepAux
			if not &WizardStep.Description.IsEmpty()
				WizardStepDescription.Caption = Format("Step %1/%2 :: %3",&StepNumber.ToString().Trim(),&WizardSteps.Count.ToString().Trim(),&WizardStep.Description)
			endif
		else
			&StepNumber += 1
		endif
	endfor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
