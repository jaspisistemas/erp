      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &DeOndeVem = 'WWFUNCIONARIO'
		retornaAutorizacao.Call('WWFUNCIONARIO', Status_SimNao.Sim, 2, &AutNiv)
	Else
		retornaAutorizacao.Call('WWVENDEDOR', Status_SimNao.Sim, 2, &AutNiv)
	EndIF

	&PesRecDtaDem.SetEmpty()
	&PesRecDtaAdm.SetEmpty()
	&PesRecDtaReg.SetEmpty()
	&PesRecCodMax = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableDate.Width = 600
	&PesRecCod.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'PegaRegistro'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	PesRecDtaAdm.ColumnHeaderClass = !'WWColumn'
	PesRecDtaReg.ColumnHeaderClass = !'WWColumn'
	PesRecDtaDem.ColumnHeaderClass = !'WWColumn'

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&deleta = !'<i class="fas fa-times"></i>'
	If (PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsNull() or PesRecSts.IsEmpty())
		&deleta.Class = !'Attribute'
	Else
		&deleta.Class = !'Invisible'
	Endif

	PesRecDtaAdm.ColumnClass = iif(PesRecSts <> Status_AtivoInativo.ATIVO and not PesRecSts.IsNull() and not PesRecSts.IsEmpty(), !'WWColumn WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn')
	PesRecDtaReg.ColumnClass = iif(PesRecSts <> Status_AtivoInativo.ATIVO and not PesRecSts.IsNull() and not PesRecSts.IsEmpty(), !'WWColumn WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn')
	PesRecDtaDem.ColumnClass = iif(PesRecSts <> Status_AtivoInativo.ATIVO and not PesRecSts.IsNull() and not PesRecSts.IsEmpty(), !'WWColumn WWColumnLineThrough WWColumnLineThroughSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &deleta.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_deleta.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_deleta.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_deleta.Result = !'Yes'
		Do 'Do deleta'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do deleta'

	EliminaRecrutamento.Call(EmpCod, PesCod, PesRecCod)
	
	wpRecrutamento.Link(&DeOndeVem, &EmpCod, &PesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PesRecDtaAdm.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Admissão'), DVMessageType.error, &PesRecDtaAdm.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if not &PesRecDtaReg.IsEmpty() and &PesRecDtaReg < &PesRecDtaAdm
		msg('Data do registro não pode ser inferior a data da Admissão!')
	Endif

EndSub

Event Enter

	If &PesRecCod = 0
		&mode = TrnMode.Insert
	else
		&mode = TrnMode.Update
	EndIf
	
	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult = True
		
		If Not &PesRecDtaDem.IsEmpty()
			
			WpConfirmaInativaExcluiUsuario.Popup(&EmpCod, &PesCod, &mode, &PesRecCod, &PesRecCodMax, &PesRecDtaAdm, &PesRecDtaReg, &PesRecDtaDem, &Obs)
			
			If &DeOndeVem = 'WWFUNCIONARIO'
				
				WWFuncionario.Call()
				
			Else
				
				WWvendedor.Call()
				
			EndIF
			
		Else
			
			GravaRecrutamento.Call(&mode,&EmpCod,&PesCod,&PesRecCod,&PesRecCodMax,&PesRecDtaAdm,&PesRecDtaReg,&PesRecDtaDem,&Obs, &Context.PesCod)
			AtualizaEnderecoCliente.Call(&EmpCod, &PesCod)
			If &DeOndeVem = 'WWFUNCIONARIO'
				WWFuncionario.Call()
			Else
				WWvendedor.Call()
			EndIF
			
		EndIf
		
	EndIf

EndEvent

Sub 'PegaRegistro'

	For each Order EmpCod,PesCod // 1
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesCodRaz = PesCodRaz
		&PesRecCodMax = PesRecCodMax + 1
		For each Order EmpCod,PesCod,(PesRecCod)
			Where PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsEmpty() or PesRecSts.IsNull()
			Do Case
				Case PesRecDtaAdm.IsEmpty()
					&PesRecDtaDem.Enabled = 0
					&PesRecDtaAdm.Enabled = 1 
					&PesRecDtaReg.Enabled = 1
					
				Case PesRecDtaDem.IsEmpty()					
					&PesRecCod = PesRecCod
					&PesRecDtaAdm = PesRecDtaAdm		
					&PesRecDtaReg = PesRecDtaReg
					&PesRecDtaDem = PesRecDtaDem
					&PesRecDtaDem.Enabled = 1
					&PesRecDtaAdm.Enabled = 1
					&PesRecDtaReg.Enabled = 1
				OtherWise
					&PesRecCod = 0
					&PesRecDtaDem.Enabled = 0					
					&PesRecDtaAdm.Enabled = 1 
					&PesRecDtaReg.Enabled = 1
			EndCase	
			Exit
		When none
			&PesRecCod = 0
			&PesRecDtaDem.Enabled = 0
			&PesRecDtaAdm.Enabled = 1 
			&PesRecDtaReg.Enabled = 1
			
		EndFor
		Exit
	EndFor

EndSub


