      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&WwpContext)
	&FilCOd = &WwpContext.FilCod
	RetornaAutorizacao.Call('WWTRANSFPRODUTO', Status_SimNao.Sim, 2, &AutNiv)
	Progress.Visible = 0
	nota.Visible = 0
	
	do 'loadTransferencia'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 150

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DouserCancel'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&ProgressLogXml = '')
		DVPanel_TableAttributesa_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributesa_Cell.Class = !'col-xs-12'
	EndIf
	If not(&ProgressLogXml <> '')
		DVPanel_Retorno_Cell.Class = !'Invisible'
	Else
		DVPanel_Retorno_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	do 'loadTransferencia'

EndEvent

Event scaProgressBar1.OnComplete

	if (&TrsTip = 'R' or &TrsTip = 'D') and &TrsSts = Status_Pedido.ABERTO and &OqueFazer <> 'C'
		nota.Visible = 1
		Progress.Visible = 0
		PadraoUsuarioHora.Call('L', 'EMITIRNFE', &WwpContext.PesCod, &EmpCod, &PadObs, &PAdDtaMod, &PAdDtaHorMod, 'T')
		&SdtNotaTransmissao.FromJson(&PadObs)
		
		if &SdtNotaTransmissao.NfeFilCod > 0 and &SdtNotaTransmissao.NfeCod > 0 and &SdtNotaTransmissao.SolCod > 0
			&GUID = GUID.NewGuid()
			&ProgressId = &GUID.ToString()
			scaProgressBar2.ProcessId = &ProgressId
			scaProgressBar2.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar2.Start()
			
			RecepcaoNFe.Submit('RecepcaoNFe', &ProgressId, &EmpCod, &SdtNotaTransmissao.NfeFilCod, &SdtNotaTransmissao.NfeCod, &SdtNotaTransmissao.SolCod)
		Else
			wwpActions.WCPopup_Close('')
		Endif
	Else
		wwpActions.WCPopup_Close('')
	Endif

EndEvent

Event scaProgressBar2.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId		
		
		&ProgressLogXml = ProgressLogXml
		txtMsg.Caption = &ProgressLogXml
		
		btnuserCancel.Visible = 1
		
		prcTrataRetorno.Call('NFE', ProgressLogXml, &erroMensagem)
		
		Do CAse
			CAse ProgressLogXml.ToUpper() like '%204%' and ProgressLogXml.ToUpper() like '%DUPLICIDADE%'  //or ProgressLogXml.ToUpper() like '%STATUS%204'//JDF AJUDANDO O CLIENTE A RESOLVER PROBLEMAS IDIOTAS QUE O CLIENTE NAO CONSEGUE
//				GravaConsultaSEFAZ.Call(&TelaOrigem, &EmpCod, &FilCod, &NfeCod, &Context.PesCod, &SolCod)
//				wpAutorizaNotaRecepcao.Link(&TelaOrigem, &EmpCod, &FilCod, &NfeCod, &SolCod)
				
			Case not &erroMensagem.IsEmpty()
//				tbComoSolucionar.Visible= 1
//				txtComoSolucionar.Caption= &erroMensagem
//				
			Otherwise				
				do 'imprimenota'
		EndCase
	
		Exit
	EndFor
	
	Do 'AttributesSecurityCode'
	
	ApagaProgress.Submit('', &ProgressId)

EndEvent

Event Enter

	if &TrsSts = Status_Pedido.ABERTO and &OqueFazer <> 'C' and (&TCon_TransDestinoProduto.IsEmpty() or &TCon_TransOrigemProduto.IsEmpty())
		//PEDIDO ABERTO, NAO É CANCELAR
		msg('Configurações de tipo lançamento não cadastradas na tabela de configurações')
	Else
		If &IsMovimentarEstoque = true
			btnuserCancel.Visible = 0
			BtnEnter.Visible = 0
			Progress.Visible = 1
			&ProgressId = 'wpFechaTrans' + trim(Str(&WwpContext.EmpCod)) + trim(Str(&WwpContext.FilCod)) + trim(Str(&WwpContext.PesCod))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			if &TrsSts = Status_Pedido.FECHADO
				AbreTransferenciaProduto.Submit('wpFechaTrans', &ProgressId, &EmpCod, &FilCod, &WwpContext.PesCod, &trsCod)
			Else
				FechaTransferenciaProduto.Submit('wpFechaTrans', &ProgressId, &EmpCod, &FilCod, &WwpContext.PesCod, &trsCod)
			EndiF
		Else
			AbreCancelaTransferenciaProduto.Call(&EmpCod, &trsCod)
			wwpActions.WCPopup_Close('')
		Endif
	Endif

EndEvent

Sub 'imprimenota'

	//ATAULIZA TRANSFERENCIA
	For Each ORder EmpCod, TrsCod
		WherE EmpCod = &EmpCod
		Where TrsCod = &trsCod
		
		&NfeCod = TrsSaiNfeCod 
		&FilCod = TrsSaiFilCod
		
		Exit
	EndFor

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		If not NfeArqXml.IsEmpty() and NfeSts = Status_NFe.Autorizada //and NfeRctPen <> Status_simNao.Sim
			GravarStatusIMpressao.Submit('GravarStatusIMpressao', EmpCod, FilCod, NfeCod, 0)
			
			&Random = random() * 100000000
			&URLFisico = trim(str(&Random))+ NfeChv.Trim()
			
			
			if ModCod <> '55'
				RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon067_ModeloNFCe, &TCon067_ModeloNFCe)
				
				
				Do CAse	
					case &TCon067_ModeloNFCe = 'B' 			
						&Window.Url = RELJAS057_ToSreenA5.Link(EmpCod, FilCod, NfeCod, &URLFisico)
						&Window.Height = 800
						&Window.Width = 800
						&Window.Open()
						
					Otherwise			
						&Window.Url = RELJAS057_ToSreen.Link(EmpCod, FilCod, NfeCod, &URLFisico)
						&Window.Height = 800
						&Window.Width = 800
						&Window.Open()
				EndCase
			Else
				&Window.Url = RELJAS043_ToScreen.LInk(EmpCod, FilCod, NfeCod, &URLFisico)		
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
			Endif
			
		EndIF
		
		Exit
	EndFor

EndSub

Sub 'loadTransferencia'

	&IsMovimentarEstoque = false
	For Each Order EmpCod, TrsCod 
		Where EmpCod = &EmpCod
		Where TrsCod = &trsCod
		&TrsSts = TrsSts
		&TrsTip = TrsTip
		txtComunicadoNota.Caption = ''
		
		Do Case
			Case TrsSts = Status_Pedido.FECHADO
				wwpActions.WCPopup_UpdateTitle('ABRIR Transferência')
				TextBlockTitle.Caption = 'Deseja ABRIR a transferência, movimentando os Estoques de entrada/saída?'
				&IsMovimentarEstoque = true
				
				Do CAse
					Case TrsTip = 'I'
						TxtTipoTransferencia.Caption = 'TRANSFERENCIA INTERNA'
						TxtTipoTransferencia.ForeColor = RGB(255,0,0)
						txtComunicadoNota.Caption = ''
						
					Case TrsTip = 'D' //REMESSA
						TxtTipoTransferencia.Caption = 'REMESSA FILIAL/DEPOSITO'
						TxtTipoTransferencia.ForeColor = RGB(0,255,0)
						txtComunicadoNota.Caption = 'CANCELANDO A TRANSFERÊNCIA A NOTA NÃO SERA CANCELADA, CASO PRECISE ACESSE O MONITORA NOTAS E SOLICITE O CANCELAMENTO! AO REALIZAR O NOVO FECHAMENTO NOVA NOTA SERA GERADA!'
						
					Case TrsTip = 'R' //RETORNO
						TxtTipoTransferencia.Caption = 'RETORNO DE ESTOQUE'
						TxtTipoTransferencia.ForeColor = RGB(0,0,255)
						txtComunicadoNota.Caption = 'CANCELANDO A TRANSFERÊNCIA A NOTA NÃO SERA CANCELADA, CASO PRECISE ACESSE O MONITORA NOTAS E SOLICITE O CANCELAMENTO! AO REALIZAR O NOVO FECHAMENTO NOVA NOTA SERA GERADA!'
						
				EndCase
				
			Case TrsSts = Status_Pedido.ABERTO
				if &OqueFazer = 'C'
					wwpActions.WCPopup_UpdateTitle('CANCELAR Transferência')
					TextBlockTitle.Caption = 'Deseja CANCELAR a transferência?'
				Else
					&IsMovimentarEstoque = true
					wwpActions.WCPopup_UpdateTitle('FECHAR Transferência')					
					TextBlockTitle.Caption = 'Deseja FECHAR a transferência, movimentando os Estoques de entrada/saída?'
					
					Do CAse
						Case TrsTip = 'I'
							TxtTipoTransferencia.Caption = 'TRANSFERENCIA INTERNA'
							TxtTipoTransferencia.ForeColor = RGB(255,0,0)
							txtComunicadoNota.Caption = ''
							
							retornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod, domConfSistema.TCon047_TransOrigemProduto, &Varchar)
							&TCon_TransOrigemProduto.FromString(&Varchar)
							retornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod, domConfSistema.TCon048_TransDestinoProduto, &Varchar)
							&TCon_TransDestinoProduto.FromString(&Varchar)
							
						Case TrsTip = 'D' //REMESSA
							TxtTipoTransferencia.Caption = 'REMESSA FILIAL/DEPOSITO'
							TxtTipoTransferencia.ForeColor = RGB(0,255,0)
							txtComunicadoNota.Caption = 'EMITIR NOTA FISCAL DE REMESSA'
							
							retornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod, domConfSistema.TCon197_TransOrigemRemessa, &Varchar)
							&TCon_TransOrigemProduto.FromString(&Varchar)
							retornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod, domConfSistema.TCon198_TransDestinoRemessa, &Varchar)
							&TCon_TransDestinoProduto.FromString(&Varchar)
						Case TrsTip = 'R' //RETORNO
							TxtTipoTransferencia.Caption = 'RETORNO DE ESTOQUE'
							TxtTipoTransferencia.ForeColor = RGB(0,0,255)
							txtComunicadoNota.Caption = 'EMITIR NOTA FISCAL DE RETORNO'
							
							retornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod, domConfSistema.TCon199_TransOrigemRetorno, &Varchar)
							&TCon_TransOrigemProduto.FromString(&Varchar)
							retornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod, domConfSistema.TCon200_TransDestinoRetorno, &Varchar)
							&TCon_TransDestinoProduto.FromString(&Varchar)
					EndCase
				Endif
				
			Case TrsSts = Status_Pedido.CANCELADO				
				wwpActions.WCPopup_UpdateTitle('REABRIR Transferência')					
				TextBlockTitle.Caption = 'Deseja REABRIR a transferência Cancelada?'
				
		EndCase
	
		Exit
	EndFor

EndSub


]]></Source>
