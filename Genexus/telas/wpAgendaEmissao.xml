      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Hora = '00:00:00'
	loadwwpContext.Call(&wwpContext)
	wctele.Object = wcTelefones.Create(&wwpContext.EmpCod, &PesCod)
	wcEmail.Object = wcEmailContato.Create(&wwpContext.EmpCod, &PesCod)
	//wcClientesVinculo.Object = wcClientesVinculos.Create(&wwpContext.EmpCod, &PesVinCod)
	//wcdadosad.Object = wcDadosComerciais.Create(&wwpContext.EmpCod, &PesCod)
	//wcDupCliente.Object = wcDuplicatasCliente.Create(&wwpContext.EmpCod, &wwpContext.FilCod, &PesCod)
	wcHistorico.Object = wcObservacaoesSac.Create(&wwpContext.EmpCod, &PesCod, 5)
	do 'CarregaFuncionarios'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	FormataHORA.Call(&Hora, &Hora)
	if &Hora.IsEmpty()
		&Hora = '00:00:00'
	endif

	&PrxPesSacPrxLig = &PesSacPrxLig 
	&Hor = val(Substr(&Hora, 1, 2))
	&min = val(Substr(&Hora, 4, 2))
	&Seg = val(Substr(&Hora, 7, 2))
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddHours(&Hor)
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddMinutes(&min)
	&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddSeconds(&Seg)
	
	&sdtClientes.Clear()
	for Each order EmpCod, PesCod
		Where EmpCod = &wwpContext.EmpCod
		Where PesCod = &VendedorPesCod when not &VendedorPesCod.IsEmpty()
		Where PesIsFun = true
		
		&sdtClientesItem = New()
		&sdtClientesItem.CreCliCod = PesCod
		&sdtClientesItem.IsSelect = true
		&sdtClientes.Add(&sdtClientesItem)
	EndFor

	&sdtClientesItem = New()
	&sdtClientesItem.CreCliCod = -1
	&sdtClientesItem.IsSelect = true
	&sdtClientes.Add(&sdtClientesItem)
		
	Do Case
		Case &PesSacDlg.IsEmpty()
			msg('Escreva o conteúdo da conversa para poder agendar uma Emissão!')
			&PesSacDlg.Setfocus()
			
//		Case &PrxPesSacPrxLig > &MaximaData
//			&Mensagem = 'Não é Permitido o Agendamento para uma data superior à ' + trim(str(&valor)) + ' dias! [CONF197]'
//			msg(&Mensagem)
//			&PesSacDlg.Setfocus()
			
			//		Case &HojeDataHora > &PrxPesSacPrxLig 
			//			msg('Não é possível agendar uma data inferior à Hoje!')
			//			&PesSacDlg.Setfocus()
			
		Otherwise
			//RetornaIsVendedor.Call(&wwpContext.EmpCod, &VendedorPesCod, &PesIsVen, &PesVenIntExt)
			
//			Do CAse
//				Case &PesSacTipObs = true
//					&auxPesSacTipObs = 'A'
//				CAse &PesIsVen = true and &PesVenIntExt = Status_InternoExterno.INTERNO
//					&auxPesSacTipObs = 'I'
//				CAse &PesIsVen = true and &PesVenIntExt = Status_InternoExterno.EXTERNO
//					&auxPesSacTipObs = 'E'
//				Otherwise
					&auxPesSacTipObs = 'A'
//			EndCAse	
			&PesSacDlg = &PesSacDlg.ToUpper()
			GravaLigacaoTelevendas.Call(&wwpContext.EmpCod, &PesCod, &wwpContext.PesCod, &PesIsVen, &PesVenIntExt, &PesSacDlg, &PrxPesSacPrxLig, &auxPesSacTipObs, &wwpContext.PesCod)
			
		
			if not &PesSacPrxLig.IsEmpty()
				RetornaDestaque.call(&wwpContext.EmpCod, 'EMISSAO CERTIFICADO', &DstCod)
				RetornaNomePessoa.Call(&wwpContext.EmpCod, &PesCod, &PesRaz)
				&AuxPesSacDlg = '['+trim(substr(&PesRaz,1,20))+ '] ' + &PesSacDlg.Trim()
				GravaCompromissoAgenda.Call(&wwpContext.EmpCod, 0, 'P', &PesSacPrxLig, &Hora, &AuxPesSacDlg, &DstCod, &wwpContext.PesCod, 0,0, &sdtClientes, &wwpContext.UserName)
			Endif
			
			return
			
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Hora.IsValid

	FormataHORA.Call(&Hora, &Hora)

EndEvent

Sub 'CarregaFuncionarios'

	&VendedorPesCod.Clear()
	&VendedorPesCod.AddItem(0, 'TODOS USUARIOS')
	for Each order EmpCod, PesCod
		Where EmpCod = &wwpContext.EmpCod
		Where PesIsFun = true
		
		
		&VendedorPesCod.AddItem(PesCod, Substr(PesCodRaz,1,20))
	EndFor

	&VendedorPesCod = 0

EndSub


]]></Source>
