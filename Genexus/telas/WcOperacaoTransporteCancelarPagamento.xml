      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'GetCIOT'

EndEvent

Event 'DoAdicionar'

	Do Case
		Case &OpePgtMotCan.IsEmpty()
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O motivo do Cancelamento é obrigatório.', DVMessageType.regular, "", DVMessageBoolean.True,""))
			
		OtherWise
			
			prcNovoEFrete_Login.Call(&Token, &ProtocoloServico, &StatusLogin)
			
			If &StatusLogin = 200
				prcNovoEFrete_PEFCancelarPagamento.Call(&Token, &parmOpeCod, &OpeNroCiot, &parmOpePgtCod, &OpePgtNro, &OpePgtMotCan, &StatusLogOut)
				
				If &StatusLogOut = 200
					WWPActions.WCPopup_Close('')
				EndIf

			Else
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &StatusLogin.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
			EndIf
			
			If not &Token.Trim().IsEmpty()
				prcNovoEFrete_Logout.Call(&Token, &StatusLogOut)
			EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

EndEvent

Event 'DoCancelar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'GetCIOT'

	For Each Order EmpCod, FilCod, OpeCod, OpePgtCod
		Where EmpCod	= &parmEmpCod
		Where FilCod	= &parmFilCod
		Where OpeCod	= &parmOpeCod
		Where OpePgtCod	= &parmOpePgtCod
		
		&OpeNroCiot		= Trim(OpeNroCiot)
		&OpePgtVal		= OpePgtVal
		&OpePgtNro		= OpePgtNro
		
		Exit
	EndFor

EndSub


]]></Source>
