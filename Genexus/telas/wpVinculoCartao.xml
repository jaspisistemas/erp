        <Source><![CDATA[
Event Start

	txtMensagem.Caption = ''
	txtMensagem.ForeColor = RGB(0,150,0)
	
	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilPedDtaEms = serverdate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&CreCarNroAut.Enabled = 1
	For &sdtDuplicatasItem in &sdtDuplicatas
		
		&PedCod 		= &sdtDuplicatasItem.CrePedCod		
		&PedDtaEms 		= &sdtDuplicatasItem.CreDtaEms
		&PedHorEms 		= &sdtDuplicatasItem.CreHorEms
		&PedCod 		= &sdtDuplicatasItem.CrePedCod
		&creVlrDup 		=  &sdtDuplicatasItem.CreVlrDup
		&CreCarNroAut 	=  &sdtDuplicatasItem.CreCarNroAut
		&CreCarBanCod   =  &sdtDuplicatasItem.CrecarBanCod
		&PedDeviceRandon = &sdtDuplicatasItem.CreCbrNom
		&CreCod 		= &sdtDuplicatasItem.CreCod
		&FiLCod 		= &sdtDuplicatasItem.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load
	endFor

EndEvent

Event 'DoGravarModificacoes'

	&sdtDuplicatas.Clear()
	For EAch line in grid
		
		&sdtDuplicatasItem = new()
		
		&sdtDuplicatasItem.CreCod = &CreCod		
		&sdtDuplicatasItem.FilCod = &FiLCod
		&sdtDuplicatasItem.CrePedCod = &PedCod
		&sdtDuplicatasItem.CreDtaEms = &PedDtaEms
		&sdtDuplicatasItem.CreHorEms = &PedHorEms
		&sdtDuplicatasItem.CrePedCod = &PedCod
		&sdtDuplicatasItem.CreVlrDup = &creVlrDup
		&sdtDuplicatasItem.CreCarNroAut = &CreCarNroAut		
		&sdtDuplicatasItem.CrecarBanCod = &CrecarBanCod
		&sdtDuplicatas.Add(&sdtDuplicatasItem)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndFor

	prcGravaAUtorizacao.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtDuplicatas)
	txtMensagem.Caption = 'Duplicatas Gravadas com sucesso! ' + serverTime()
	msg('Duplicatas Gravadas com sucesso!')

EndEvent

Event 'DoLocalizar'

	txtMensagem.Caption = ''
	SdtRetornaPedidosCaixa.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &PdvId, &FilPedDtaEms, &sdtDuplicatas)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


