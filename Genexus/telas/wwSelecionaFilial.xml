      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	&PesCod = &wwpContext.PesCod
	
	do 'addCombo'
	
	Form.HeaderRawHTML = '<link rel="shortcut icon" href="Resources/jaspi.png" type="image/x-icon">'
	Form.HeaderRawHTML += '<link rel="icon" href="Resources/jaspi.png" type="image/x-icon">'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	SubMain.Width = 500

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Welcome.Caption = 'Bem Vindo, ' + trim(&wwpContext.UserName)

EndEvent

Event 'DoCarregar'

	ProcLoadInicio.Call(0, &FilCod, &IsLicenciado, &IsOkAcesso)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

//	If &URL.IsEmpty()
		
		Dashboard.Call()
//	Else
//		Link(&URL)
//	Endif

EndEvent

Sub 'addCombo'

	For each order EmpCod, PesCod, PesFilAce
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesFilAceNiv > 1
		&FilCod.AddItem(PesFilAce, PesFilAceNom)
	EndFor

EndSub


]]></Source>
