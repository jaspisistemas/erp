	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'loadProduto'

	For Each ORder EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &PRoGraCod
		
		&ProNom = ProNomGra
		&MarNom = MarNom
		
		Exit
	EndFor

	For Each order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&Estqtd 	= EstQtd
		&NovEstQtd  = EstQtd
		Exit
	EndFor

EndSub


