      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Progress.Visible = 0
	RetornaAutorizacao.Call('WPSINTEGRA', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&PesEml = FilCtaEml
		Exit
	EndFor
	
	&NotasTransporte = Status_SimNao.Sim
	&EnviaPdfCte = Status_SimNao.Nao
	&EnviaPdfNota = Status_SimNao.Nao
	&SomenteNotasAutorizadas = Status_SimNao.Sim
	&RegistroInventario  = Status_SimNao.Nao
	&EnviarRelatorioProdutos = false
	
	&FinalidadeGeracao = '1'
	&EnviarSintegra = true
	&EnviarXml = true
	&Data = serverdate()
	&Data = &Data.AddMonths(-1)
	&dia = day(&Data)
	&Ano = Year(&Data)
	&Mes = month(&Data)
	&TipoNota = 'P'
	
	do 'loadConfiguracoes'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAgendarEnvio'

	InicializaAgendador.Call(&Context.EmpCod, TipoAgendamento.EnviarXmlEscritorio, &FilCod, &AgdCod)
	wpAgendaOpc.Popup(&Context.EmpCod, &AgdCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FilCod.IsValid

	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&PesEml = FilCtaEml
		Exit
	EndFor

EndEvent

Event scaProgressBar1.OnComplete

	for Each Order ProgressId
		Where ProgressId = &ProgressId
		If not ProgressLogXml.IsEmpty()
			msg(ProgressLogXml)
		EndIF
		Exit
	EndFor

	btnCancel.Visible = 1
	btnEnter.Visible = 1
	Progress.Visible = 0

EndEvent

Event Enter

	&NomeFinalArquivo = serverTime()
	&NomeFinalArquivo = RetornaSoNumeros.udp(&NomeFinalArquivo)
		
	If &Ano.IsEmpty()
		msg('Informe o Ano para a Exportação do Arquivo!')
		
	Else
		retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
		
		&iniNfeDtaEms = YMDTOD(&Ano,&Mes,1)
		&finNfeDtaEms = EOM(&iniNfeDtaEms)
		
		&NomeArquivo += 'sintegra'+ &NomeFinalArquivo.Trim() + '.txt'
		
		&ProgressId = 'Sintegra' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()
	EndIF
	
	
	&AntigoiniNfeDtaEms = &Data.AddMonths(-6)
	if &EnviaPdfNota = Status_SimNao.Sim and &iniNfeDtaEms < &AntigoiniNfeDtaEms
		msg('Não é possivel enviar arquivos com a opcao de enviar os pdf com mais de 6 meses!, caso precise muito comunique o suporte!')
	Else
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		Progress.Visible = 1
		
		If not &PesEml.IsEmpty()
			btnCancel.Visible = 0
			btnEnter.Visible = 0
		Else
			&PesEml = ''
		EndIf
		
		EnviaSintegra_Web.Submit('ExportaSintegra', &ProgressId, &EmpCod, &FilCod, &sdtConfiguracoesPasta, &iniNfeDtaEms, &finNfeDtaEms, &RegistroInventario, &NotasTransporte, &FinalidadeGeracao, &SomenteNotasAutorizadas, &TipoNota, &NomeFinalArquivo, &PesEml, &Context.PesCod,&Context.PesRaz, &IsExecutou,&EnviaPdfCte,&EnviaPdfNota, &EnviarRelatorioProdutos)
	Endif

EndEvent

Sub 'loadConfiguracoes'

	InicializaAgendador.Call(&Context.EmpCod, TipoAgendamento.EnviarXmlEscritorio, &FilCod, &AgdCod)
	
	For Each Order EmpCod, AgdCod
		Where EmpCod = &EmpCod
		Where AgdCod = &AgdCod
		
		&sdtAgendadorFiltros.FromXml(AgdFiltro)
		
		Do Case
			Case AgdTip = TipoAgendamento.EnviarXmlEscritorio
				For &sdtAgendadorFiltrosItem in &sdtAgendadorFiltros
					Do Case							
						Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_AUTOR'
							if &sdtAgendadorFiltrosItem.AgdValue = 'S'
								&SomenteNotasAutorizadas = Status_SimNao.Sim
							Else
								&SomenteNotasAutorizadas = Status_SimNao.Nao
							EndIF
							//ENVIA CONHECIMENTOS CTE PDF POR EMAIL
						Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_PDF_CTE'
							if &sdtAgendadorFiltrosItem.AgdValue = 'S'
								&EnviaPdfCte = Status_SimNao.Sim
							Else
								&EnviaPdfCte = Status_SimNao.Nao
							EndIF							
							
							//ENVIA NOTAS NFE PDF POR EMAIL
						Case &sdtAgendadorFiltrosItem.AgdFiltro =  'SIN_PDF_NFE'
							if &sdtAgendadorFiltrosItem.AgdValue = 'S'
								&EnviaPdfNota = Status_SimNao.Sim
							Else
								&EnviaPdfNota = Status_SimNao.Nao
							EndIF
							
						Case &sdtAgendadorFiltrosItem.AgdFiltro =  'SIN_PRODUTOS_PERIODO'
							if &sdtAgendadorFiltrosItem.AgdValue = 'S'
								&EnviarRelatorioProdutos = true
							Else
								&EnviarRelatorioProdutos = false
							EndIF
							
						case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_NFTERCEIROS'
							//TERCEIROS
							if &sdtAgendadorFiltrosItem.AgdValue = 'S'
								&TipoNota.SetEmpty()
							Else
								&TipoNota = 'P'
							EndIF
					EndCase
				EndFor
		EndCase
		Exit
	EndFor

EndSub


