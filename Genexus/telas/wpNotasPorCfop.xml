      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWpContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	RetornaAutorizacao.Call('WPNOTASPORCFOP', Status_SimNao.Sim, 1, &AutNiv)
	&NfeDtaEms_to = serverdate()
	&NfeDtaEms = &NfeDtaEms_to - 30
	
	
	&NfeProTer = Nota_ProPriaTerceira.PROPRIA

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TabelCnae.Visible = (&Tipo = 2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	do 'GetCfop'
	do 'GetPessoa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &LctCod.IsValid

	RetornaNomeTipoLancamento.Call(&EmpCod, &LctCod, &LctNom)

EndEvent

Event Enter

	Do case
		Case &Tipo = 1  //nfe e nfc-e
			AtualizaDataFaturadoNotas.Call(&EmpCod, &FilCod, &NfeDtaEms, &NfeDtaEms_to)
			RCOOpenWindow1.LinkOpen = RELJAS039_new.Link(&EmpCod, &FilCod, &NfeDtaEms, &NfeDtaEms_to, &NfeCliCod, &CfoCod, &NfeProTer, &AgruparTipoLancamento, &LctAtuSal, &NfeLctCod)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		OtherWise
			RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtCOnfiguracoesPasta)
			&UrlPDF = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'RelatorioNfse.pdf'  //diretorio para gerar
			&UrlPDFVir = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim()+ 'RelatorioNfse.pdf'//diretorio para abrir e tela
			
			&File.Source = &UrlPDF
			If &File.Exists()
				&File.Delete()
			EndIF 
			&File.Close()
	
			RELJAS161_ToFile.Call(&EmpCod, &FilCod, &NfeDtaEms, &NfeDtaEms_to,&NfeCliCod,0,0,&NfsCNAE,'',&UrlPDF,'S')
			RCOOpenWindow1.LinkOpen = link(&UrlPDFVir)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent

Event &CfoCod.IsValid

	do 'GetCfop'

EndEvent

Event &NfeCliCod.IsValid

	do 'GetPessoa'

EndEvent

Sub 'GetPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NfeCliCod
		&NfeCliRaz = PesRaz
	When none
		If &NfeCliCod = 0
			&NfeCliRaz = 'TODAS AS PESSOAS'
		Else
			&NfeCliRaz = 'PESSOA NÃO LOCALIZADA'
		EndIf
	EndFor

EndSub

Sub 'GetCfop'

	For Each Order CfoCod
		Where CfoCod = &CfoCod
		&CfoNom = CfoNom
		Exit
	When none
		If &CfoCod = ''
			&CfoNom = 'TODOS OS CFOPS'
		Else
			&CfoNom = 'CFOP NÃO LOCALIZADO'
		EndiF
	EndFor

EndSub


]]></Source>
