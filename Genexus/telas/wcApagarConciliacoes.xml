      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbProgresso.Visible = 0
	retornaAutorizacao.Call('APAGARCONCILIACAO', Status_SimNao.Sim, 1, &AutNiv)

	LoadWWPContext.Call(&Context)	
	
	&now = now()
	For &i = year(&now) - 1 to year(&now) step 1 
		&dataAno.AddItem(&i,str(&i))
	Endfor

	&ctabanCod.Clear()
	for &sdtContaItem in CarregaContaBancariaTipo(&Context.EmpCod, &Context.PesCod, 0)
		if &sdtContaItem.CtaFunIsCx = Status_SimNao.Sim
			&ctabanCod.AddItem(&sdtContaItem.CtabanCod, &sdtContaItem.CtaBanCodNom)
		Endif
	endfor

	&ctabanCod = &parCtaBanCod
	&dataAno = &ParAno
	&dataMes = &ParMes
	&dataDia = &ParDia
	do 'AtualizaDia'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnConfirmar'

	&GUID = GUID.NewGuid()
	&ProgressID = &GUID.ToString()
	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	prcApagarConciliacao.Submit(&ProgressID, &ProgressID, &Context.EmpCod, &CtabanCod, &dataAno, &dataMes, &dataDia)
	tbBotoes.Visible = false
	tbProgresso.Visible = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &dataAno.ControlValueChanged

	do 'AtualizaDia'

EndEvent

Event &dataMes.ControlValueChanged

	do 'AtualizaDia'

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId 
		where ProgressId = &ProgressID
		txtResultado.Caption = ProgressLogXml
		Exit
	EndFor

	ApagaProgress.Submit('', &ProgressId)
	
	tbBotoes.Visible = true
	tbProgresso.Visible = false

EndEvent

Sub 'AtualizaDia'

	&dataAux = YMDtoD(&dataAno, &dataMes, 1)
	&data = EoM(&dataAux)
	
	&dataDia.clear()
	&dataDia.AddItem(0,'MÊS INTEIRO')
	For &i = 1 to &data.Day()
		&dataDia.AddItem(&i,str(&i))
	Endfor

EndSub


]]></Source>
