      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &RoleId.IsEmpty() or &ApplicationId.IsEmpty()
		return
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows

	If &HTTPRequest.Method = HttpMethod.Get
		Do 'LoadSavedFilters'
	EndIf
	Form.Caption = 'WWP_GAM_SelectPermissionsRole'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GAMRole.Load(&RoleId)
	&GAMApplication.Load(&ApplicationId)
	Form.Caption = Format("WWP_GAM_AddPermissionsToRole", &GAMRole.Name.Trim(), &GAMApplication.Name.Trim())
	TextBlockTitle.Caption = Form.Caption

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do Case
		Case &ManageFiltersExecutionStep = 1
			&ManageFiltersExecutionStep = 2
		Case &ManageFiltersExecutionStep = 2
			&ManageFiltersExecutionStep = 0
			Do 'LoadSavedFilters'
	EndCase
	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	//&GridPageCount has to be loaded manually

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

  &GAMRole.Load(&RoleId)
	&AppId = &ApplicationId
	&PermissionFilter.ApplicationId = &AppId
	&PermissionFilter.Name			= &FilName
	&PermissionFilter.AccessType.FromString(&PermissionAccessType)
	&PermissionFilter.Inherited.FromString(&BoolenFilter)
	&GamPermissions = &GAMRole.GetUnassignedPermissions(&PermissionFilter, &Errors) 
	if &GamPermissions.count=0
		&GridPageCount=0
	else
		&GridPageCount=(&GamPermissions.count/Page.Rows)+1
	endif
	&GridRecordCount = &GamPermissions.Count
	If not &AppId.IsEmpty()
		For &Permission in &GamPermissions
			&Select	= False
			&Id		= &Permission.GUID
			&Name 	= &Permission.Name
			&Dsc 	= &Permission.Description

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the data
	
	//Sample conditions to be added manually:
	//Where <Attribute> like &FilName when not &FilName.IsEmpty()
	//Where <Attribute> = &PermissionAccessType when not &PermissionAccessType.IsEmpty()
	//Where <Attribute> = &BoolenFilter when not &BoolenFilter.IsEmpty()
	
	&Name.Link = GAMAppPermissionEntry.Link(GAMAPiMode.Display, &ApplicationId, &Id)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			Grid.Load()
		EndFor
	Endif

EndEvent

Event ddo_ManageFilters.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case ddo_ManageFilters.ActiveEventKey = !'<#Clean#>'
			Do 'CleanFilters'
			Grid.FirstPage()
		Case ddo_ManageFilters.ActiveEventKey = !'<#Save#>'
			Do 'SaveGridState'
			SaveFilterAs.Popup(!'GAMRolePermissionSelectFilters', &PgmName + !"GridState")
			&ManageFiltersExecutionStep = 2
			Refresh
		Case ddo_ManageFilters.ActiveEventKey = !'<#Manage#>'
			ManageFilters.Popup(!'GAMRolePermissionSelectFilters')
			&ManageFiltersExecutionStep = 2
			Refresh
		Otherwise
			&ManageFiltersXml = GetFilterByName(!'GAMRolePermissionSelectFilters', ddo_ManageFilters.ActiveEventKey)
			If &ManageFiltersXml.IsEmpty()
				msg('WWP_FilterNotExist')
			Else
				Do 'CleanFilters'
				SaveGridState.Call(&PgmName + !"GridState",  &ManageFiltersXml)
				&GridState.FromXml(&ManageFiltersXml)
				Do 'LoadRegFiltersState'
				Grid.FirstPage()
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdd'

	&GAMRole.Load(&RoleId)	
	For each line
		If &Select
			&PermissionAdd.ApplicationId= &AppId
			&PermissionAdd.GUID		  	= &Id
			&PermissionAdd.Type.FromString(&Access)
			&isOK = &GAMRole.AddPermission(&PermissionAdd, &Errors)
			If not &isOK
				For &Error in &Errors
					Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
				EndFor	
				Exit
			Endif		
		Endif
	EndFor
	If &isOK
		Commit
		GAMWWRolePermissions(&RoleId, &ApplicationId)
	Else
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor		
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadSavedFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ManageFiltersData = WWP_ManageFiltersLoadSavedFilters(!'GAMRolePermissionSelectFilters', '', '', False)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CleanFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&FilName.SetEmpty()
	&PermissionAccessType.SetEmpty()
	&BoolenFilter.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	
	Do 'LoadRegFiltersState'
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadRegFiltersState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"FILNAME"
				&FilName.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PERMISSIONACCESSTYPE"
				&PermissionAccessType.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"BOOLENFILTER"
				&BoolenFilter.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"FILNAME", "", not &FilName.IsEmpty(), 0, &FilName, '')
	WWP_GridStateAddFilterValue(&GridState, !"PERMISSIONACCESSTYPE", "", not &PermissionAccessType.IsEmpty(), 0, &PermissionAccessType, '')
	WWP_GridStateAddFilterValue(&GridState, !"BOOLENFILTER", "", not &BoolenFilter.IsEmpty(), 0, &BoolenFilter, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
