        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	RetornaNomeEmpresa.Call(&wwpContext.EmpCod, &AuxEmpRaz)
	prcGetDadosBanco.Call(&EmpBDerp, &EmpBDAudit)
	
	do 'CarregaLog'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = 0
	wwItensRelacionadas.Object = wwItensRelacionadas.Create(&LogErpEmpCod, &LogErpTabCod, &LogErpRegKey)
	WCwwItensHistorico.Object = wwItensHistorico.Create(&LogErpEmpCod, &LogErpTabCod, &LogErpRegKey, &LogErpRegGUID)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	prcRetornaNomeAtributo.Call(LogErpTabAtrCod, &LogErpTabAtrNom)
	&LogErpRegItmNew = LogErpRegItmNew
	&LogErpRegItmOld = LogErpRegItmOld
	&LogErpTabAtrCod = LogErpTabAtrCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	if not &EmpBDAudit.IsEmpty()  and &EmpBdErp <> &EmpBdAudit
		&SQLSentence = 'USE ' + trim(&EmpBDAudit)
		SQL [!&SqlSentence!]
	Endif

	&Grid1PageCount = grid1.PageCount
	&Grid1CurrentPage = Grid1.currentPage

EndEvent

Sub 'CarregaLog'

	if not &EmpBDAudit.IsEmpty() and &EmpBdErp <> &EmpBdAudit
		&SQLSentence = 'USE ' + trim(&EmpBDAudit)
		SQL [!&SqlSentence!]
	Endif

	For Each Order LogErpRegGUID
		Where LogErpRegGUID = &LogErpRegGUID 
		
		&LogErpEmpCod = LogErpEmpCod
		&LogErpRegCod1 = LogErpRegCod1
		&LogErpRegCod2 = LogErpRegCod2
		&LogErpRegCod3 = LogErpRegCod3
		&LogErpRegKey = LogErpRegKey
		&LogErpRegTip = LogErpRegTip
		&LogErpUsuGuid = LogErpUsuGuid
		
		&LogErpDtaHorMod = LogErpDtaHorMod
		&LogErpFilCod = LogErpFilCod
		&LogErpTabCod = LogErpTabCod
		&LogErpTabNom = LogErpTabNom
		&LogErpExt = LogErpExt		
		
		&EmpRaz = trim(Str(LogErpEmpCod)) + ' - ' + &AuxEmpRaz.Trim()
		
		
		Exit
	EndFor

EndSub


]]></Source>
