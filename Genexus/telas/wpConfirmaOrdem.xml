      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	if not &PadObs.IsEmpty()
		&SomenteComQuantidade.FromString(substr(&PadObs, 1,1))
		&MateriaPrimaNecessaria.FromString(substr(&PadObs, 2,1))
	Endif
	
	For Each Order EmpCod, FilCod, OrdCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where OrdCod = &OrdCod
		
		&OrdSts = OrdSts
		
		If OrdSts <> Status_Producao.Aguardando
			&OqueFazer = 'N'
			&OqueFazer.Enabled = 0
			tbTipoOrdem.Visible = 0
		EndIF
	
		&AuxTpPrdCodNom = TpPrdCodNom
		
		Exit
	EndFor
	
	&Ordem = &ParOrdem
	If &ParOrdem > 7
		&Ordem = 6
	EndIF
	
	&TpPrdCodNom = &AuxTpPrdCodNom
	&SomenteComQuantidade = Status_SimNao.Sim
	&MateriaPrimaNecessaria = Status_SimNao.Sim

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'GetCodigoClassificacao'
	&PadObs = &SomenteComQuantidade
	&padObs += &MateriaPrimaNecessaria
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	If &OrdSts <> Status_Producao.Aguardando
		prcGravaClassificacaoProducao.Call(&EmpCod, &FilCod, &OrdCod, &TpPrdCod)
	Endif

	If &OqueFazer = 'S' //GERAR ORDEM PRODUCAO
		msg('Aguarde...')
		BtnEnter.Visible = 0
		&OqueFazer = 'N'
		&OqueFazer.Enabled = 0
		
		&ProgressId = 'ConfOrd' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		FechaOrdemProducao.Submit('', &ProgressId, &EmpCod, &FilCod, &Context.PesCod, &OrdCod)
	Else
		
		RCOOpenWindow1.LinkOpen = RELJAS007.Link(&EmpCod, &FilCod, &OrdCod, &SomenteComQuantidade, &MateriaPrimaNecessaria, Status_simNao.Nao, &Ordem)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIf

EndEvent

Event scaProgressBar1.OnComplete

	BtnEnter.Visible = 1
	msg('Ordem Número ' + trim(str(&OrdCod)) + ' gerada com sucesso!')
	
	RCOOpenWindow1.LinkOpen = RELJAS007.Link(&EmpCod, &FilCod, &OrdCod, &SomenteComQuantidade, &MateriaPrimaNecessaria, Status_simNao.Nao, &Ordem)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'GetCodigoClassificacao'

	For Each ORder EmpCod, TpPrdCod
		Where EmpCod = &EmpCod
		Where TpPrdCodNom = &TpPrdCodNom
		
		&TpPrdCod = TpPrdCod
		Exit
	EndFor

EndSub


]]></Source>
