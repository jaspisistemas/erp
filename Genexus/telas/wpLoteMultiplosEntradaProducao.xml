      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &parPrdItmCod < 0
		Return
	Endif

	do 'loadEntradaproducaoproduto'

EndEvent

Sub 'loadEntradaproducaoproduto'

	For Each order EmpCod, FilCod, PrdCod, (PrdItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PrdCod = &PrdCod
		Where PrdItmCod = &parPrdItmCod when Not &parPrdItmCod.IsEmpty()
		
		TextBlockTitle.Caption = 'PROD: ' + trim(ProGraRef) + ' - ' + trim(ProNomGra)
		&PrdItmCod = PrdItmCod
		
		Exit
	When none
		Return
	EndFor
	
	EntradaProducaoProdutoLotes.Link(TrnMode.Update, &EmpCod, &FilCod, &PrdCod, &PrdItmCod)

EndSub


]]></Source>
