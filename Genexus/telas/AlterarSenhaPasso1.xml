        <Source><![CDATA[
Event Start

	Form.Backcolor = rgb(238,238,238)
	LayoutMainTable.Class = ThemeClass:MainContainer
	LoadWWPContext(&Context)
	
	&UserName = &ParmUserName

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 270

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarLogin'

	If GAMRepository.IsRemoteAuthentication(&IDP_State)
		GAMRemoteLogin(&IDP_State)
	Else
		Login('', '')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&User = GAMRepository.GetUserByLogin(&UserAuthTypeName, &UserName, &Errors)	//## Busca um usuário. Caso ocorra algum erro durante a busca, os erros são armazenados na variável &Errors
	If &Errors.Count = 0	//## Se não houver erros
		&KeyToChangePassword = &User.RecoverPasswordByKey(&Errors)	//## Tenta recuperar a senha do usuário
		
		Do 'BuscaEmailTamplate'	//## Busca um modelo de e-mail para alteração de senha
		
		&Application = GAMApplication.Get()	//## Obtém uma instância de Aplicação
		WWPBaseObjects.WWP_GetParameter.Text("Notification_BaseURL", &LinkURL)	//## Obtém a URL base da aplicação
		&UsuarioCripto = encrypt64(&UserName, 'E1D89B0D44CD35AFC9CF69E7E556A97B')
		
		&BaseURL = &LinkURL + AlterarSenhaPasso2.Link(&IDP_State, &KeyToChangePassword, &UsuarioCripto)	//## Concatena a URL de base da aplicação com a URL da página de alteração de senha
		
		//## ALTERA O CORPO DO E-MAIL ##\\
		&WWPMailBody = &WWPMailBody.Replace(!"[LINK]", &BaseURL)
		&WWPMailBody = &WWPMailBody.Replace(!"[LOGOFILIAL]", Trim(&FilWebLogo))
		&WWPMailBody = &WWPMailBody.Replace(!"[LOGOJASPI]", 'https://i.postimg.cc/zBxK6z1W/Logo-JASPI.png')
		&WWPMailBody = &WWPMailBody.Replace(!"[EMAILUSUARIO]", &User.EMail)
		&WWPMailBody = &WWPMailBody.Replace(!"[FILIALALT]", &EmpRaz)
		//##############################\\
		
		//## CONFIGURA AS INFORMAÇÕES DO SERVIDOR SMTP E DO REMETENTE DO E-MAIL ##\\
		&Mail.To.Clear()
		&Mail.To.New(Format("%1 %2", &User.FirstName, &User.LastName), &User.EMail)
		&Mail.Subject = 'Alteração de Senha'
		
		WWPBaseObjects.WWP_GetParameter.Text(!"SMTP_Host", &TextParameter)
		&Host 		= &TextParameter
		&SMTP.Host 	= &TextParameter
		
		WWPBaseObjects.WWP_GetParameter.Integer(!"SMTP_Port", &IntegerParameter)
		&SMTP.Port = &IntegerParameter
		
		WWPBaseObjects.WWP_GetParameter.Text(!"SMTP_Username", &TextParameter)
		&SMTP.UserName = &TextParameter
		&SMTP.Sender.Address = !"suportejaspilocal@gmail.com"
		
		WWPBaseObjects.WWP_GetParameter.Text(!"SMTP_Password", &TextParameter)
		&SMTP.Password = &TextParameter
		
		WWPBaseObjects.WWP_GetParameter.Boolean(!"SMTP_Authentication", &BooleanParameter) //## True
		If &BooleanParameter
			&SMTP.Authentication = 1
		Else
			&SMTP.Authentication = 0
		EndIf
		
		WWPBaseObjects.WWP_GetParameter.Boolean(!"SMTP_Secure", &BooleanParameter)	//## C# True, Js False
		If &BooleanParameter
			&SMTP.Secure = 1
		Else	
			&SMTP.Secure = 0
		EndIf
	 
	 	WWPBaseObjects.WWP_GetParameter.Integer(!"SMTP_Timeout", &IntegerParameter)	//## 30 
		&SMTP.Timeout = &IntegerParameter
		
		&Mail.HTMLText = &WWPMailBody
		
		&IsOk = &SMTP.Login()
		//########################################################################\\

		If &SMTP.ErrCode = 0	//## Se não houver erros na configuração do servidor
			&SMTP.Send(&Mail)	//## Tenta enviar o e-mail
			
			If &SMTP.ErrCode <> 0	//## Se o envio não for bem sucedido
				&Message = Format('Falha ao enviar o e-mail: %1 (%2)', &SMTP.ErrDescription, &SMTP.ErrCode)	//## Adiciona uma mensagem de erro.
			EndIf
			
			&SMTP.Logout()	//## Encerra a sessão
			TbConfirmar.Visible = 0
			&UserName.Enabled = False	//## Desabilita o campo de nome de usuário
			
		Else
			&Message = Format("Falha ao iniciar a sessão de e-mail: %1 (%1)", &SMTP.ErrDescription, &Ret) //## Adiciona uma mensagem de erro.
			
		EndIf
		
		If &Message.IsEmpty()	//## Se o envio for bem sucedido
			Msg('Um e-mail para ' + Trim(&User.EMail) + ' foi enviado com instruções para alterar a senha. Verifique a sua caixa de Spam, por precaução. Caso não seja o E-mail correto, comunique o Suporte!')	//## Exibe uma mensagem informando o envio do e-mail
		Else
			Msg(&Message.ToString())	//## Exibe as mensagens de erro
		EndIf
		
	Else
		Do 'DisplayMessages'
		
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub

Sub 'BuscaEmailTamplate'

	&PesExtCod.FromString(&User.ExternalId)
	
	For Each Order EmpCod, PesCod
		Where PesExtCod = &PesExtCod
		
		&AuxEmpCod 	= EmpCod
		&EmpRaz		= EmpRaz
		
		Exit
	EndFor
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &AuxEmpCod
		Where Not FilWebLogo.IsEmpty()
		
		&FilWebLogo = FilWebLogo
		
		Exit
	EndFor
	
	&WWPMailTemplateName = 'MailAlterarSenha-Emp-' + Trim(Str(&AuxEmpCod))
	
	prcRetornaLayoutEmail.Call(&WWPMailTemplateName, 'AlterarSenha',&WWPMailBody)

EndSub


]]></Source>
