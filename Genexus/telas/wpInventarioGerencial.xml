      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPINVENTARIOGERENCIAL', Status_SimNao.Sim, 1, &AutNiv)
	 
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&FiLCod = &Context.FilCod
	&Gerar = 'P'
	&PrecoVenda = true
	&PrecoCusto = false
	
	RetornaConfiguracoesPastas.Call(&Context.EmpCod, &Context.FilCod, &SdtConfiguracoesPasta)
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilTabCod = FilTabCod
		&TabColCod = TabColCod
		Exit
	EndFor
		
	&Mes = Month(Serverdate())
	&Ano = Year(Serverdate())
	
	RetornaAutorizacao.Call('WWPEDIDOCOMPRA', Status_SimNao.Nao, 1, &AutNiv)
	if &AutNiv < 1
		&PrecoCusto.Visible = 0
	EndIF
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	if not &PadObs.IsEmpty()
		&FiltrarProdutos = Substr(&PadObs, 1, 1)
		&OrdemExibicao = Substr(&PadObs, 2, 1)
	EndIF
	
	if &FiltrarProdutos.IsEmpty()
		&FiltrarProdutos ='B'
	Endif
	if &OrdemExibicao.IsEmpty()
		&OrdemExibicao = 'G'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaNomePessoa.Call(&EmpCod, &ProPadForCod, &ProPadForRaz)
	if &ProPadForRaz.IsEmpty()
		&ProPadForRaz = 'TODOS OS FORNECEDORES'
	Endif

	RetornaNomePessoa.Call(&EmpCod, &impProPadForCod, &impProPadForRaz)
	if &impProPadForRaz.IsEmpty()
		&impProPadForRaz = 'FORNECEDOR NÃO INFORMADO'
	Endif

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbTabela.Visible = (&PrecoVenda = true)
	tbCliFor.Visible = (&ListarCodigos = 'F')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &PrecoVenda.Click

	Do 'AttributesSecurityCode'

EndEvent

Event &PrecoVenda.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event Enter

	btnEnter.visible = 0
	btnCancel.Visible = 0
	
	&PadObs = &FiltrarProdutos + &OrdemExibicao
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	&NomeArquivo = serverTime()
	if &ListarCodigos <> 'F'
		&impProPadForCod = 0
	Endif
	Do case
		case &ProSts = Status_AtivoInativo.ATIVO
			&AuxProSts = Status_Produto.ATIVO
		case &ProSts = Status_AtivoInativo.INATIVO
			&AuxProSts = Status_Produto.INATIVO
		otherwise
			&AuxProSts = nullvalue(&AuxProSts)
	EndCase
	
	if &Gerar = 'P'
		&Random = Random() * 10000000000
		//&ProgressId = 'wpImpPedido' + trim(Str(&Random))
		&ProgressId = 'WPINVFISCAL' + trim(str(&Context.EmpCod)) + trim(str(&Context.PesCod))
		do 'verificaInventarioAndamento'
		
		if &IsOk = true
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			&Gerou = 'P'
			&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'Inventario' + trim(str(&Random)) + '.pdf'
			&VirtualDiretorio = &SdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + 'Inventario' + trim(str(&Random)) + '.pdf'
			RELJAS082.Submit(&ProgressId, &ProgressId, &NomeArquivo, &EmpCod, &FilCod, &Ano, &Mes, &PrecoCusto, &PrecoVenda, &FilTabCod, &TabColCod, &GrupHie, &ConsiderarPedidosAbertos, &FiltrarProdutos, &OrdemExibicao, &ProTipDef, &ProSetCod, &ProPadForCod, &impProPadForCod, &AuxProSts, &Context.PesRaz, &MarCod)
		Else
			msg('Já existe um inventario em andamento, Favor Aguardar a finalização ou esperar '+trim(str(&Minutos))+'min!')
			btnEnter.visible = 1
			btnCancel.Visible = 1
		Endif
		
	Else
		&Random = Random() * 10000000000
		//&ProgressId = 'wpImpPedido' + trim(Str(&Random))
		&ProgressId = 'WPINVFISCAL' + trim(str(&Context.EmpCod)) + trim(str(&Context.PesCod))
		do 'verificaInventarioAndamento'
		
		if &IsOk = true
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			&Gerou = 'E'
			&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'Inventario' + trim(str(&Random)) + '.xlsx'
			&VirtualDiretorio = &SdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + 'Inventario' + trim(str(&Random)) + '.xlsx'
			RELJAS082_export.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &Ano, &Mes, &PrecoCusto, &PrecoVenda, &FilTabCod, &TabColCod, &GrupHie, &ConsiderarPedidosAbertos, &FiltrarProdutos, &OrdemExibicao, &ProTipDef, &ProSetCod, &VirtualDiretorio, &NomeArquivo, &impProPadForCod, &AuxProSts, &MarCod)
		Else
			msg('Já existe um inventario em andamento, Favor Aguardar a finalização ou esperar '+trim(str(&Minutos))+'min!')
			btnEnter.visible = 1
			btnCancel.Visible = 1
		Endif
			

	EndIF

EndEvent

Event &ProPadForCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &ProPadForCod, &ProPadForRaz)
	if &ProPadForRaz.IsEmpty()
		&ProPadForRaz = 'TODOS OS FORNECEDORES'
	Endif

EndEvent

Event &impProPadForRaz.IsValid

	RetornaNomePessoa.Call(&EmpCod, &impProPadForCod, &impProPadForRaz)
	if &impProPadForRaz.IsEmpty()
		&impProPadForRaz = 'FORNECEDOR NÃO INFORMADO'
	Endif

EndEvent

Event &ListarCodigos.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event scaProgressBar1.OnComplete

	for Each Order ProgressId
		Where ProgressId = &ProgressId
		
		btnEnter.visible = 1
		btnCancel.Visible = 1
		
		if &Gerou = 'P'
			RCOOpenWindow1.LinkOpen = &VirtualDiretorio
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Else
			Link(&VirtualDiretorio)
		Endif
	
		Exit
	EndFor

	ApagaProgress.Submit('', &ProgressId)

EndEvent

Sub 'verificaInventarioAndamento'

	&IsOk = false
	&ProgressIni = serverNow()
	
	For each Order ProgressId
		where ProgressId = &ProgressId
		
		&Segundos = tdiff(&Progressini, ProgressIni)
		Do Case 
			Case ProgressValue = 100
				&IsOk = true
			Case &Segundos > 600
				&IsOk = true
		EndCAse
		
		Exit
	When None
		&IsOk = true
	Endfor
	&Minutos = (600 - &Segundos)
	if &Minutos > 0
		&Minutos = &Minutos /60
	else
		&IsOk = true
		&Minutos = 0
	Endif

EndSub


