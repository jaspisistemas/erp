Event GridsdtFichaEstoquesPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtFichaEstoquesPaginationBar.SelectedPage = !'Previous'
			GridsdtFichaEstoques.PreviousPage()
		Case GridsdtFichaEstoquesPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtFichaEstoques.CurrentPage
			&PageToGo += 1
			GridsdtFichaEstoques.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtFichaEstoquesPaginationBar.SelectedPage)
			GridsdtFichaEstoques.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtFichaEstoquesPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtFichaEstoques.Rows = GridsdtFichaEstoquesPaginationBar.RowsPerPageSelectedValue
	GridsdtFichaEstoques.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&AuxQtd = &Qtd
	&AuxTipo = &Tipo
