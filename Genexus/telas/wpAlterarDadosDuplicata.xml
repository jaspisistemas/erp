      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&FilCod = &wwpContext.FilCod
	
	RetornaConfSistema.Call(&wwpContext.EmpCod, &wwpContext.FilCod, domConfSistema.TCon063_PgtoComVale, &CfgVlr)
	&PlanHie = trim(&cfgVlr)
	&ValePlanCod = 0
	RetornaCodigoPlanoContas.Call(&EmpCod, &PlanHie, &ValePlanCod)
	
	&SdtPagamentoDuplicata.FromXml(&Websession.Get('WWDuplicataReceber'))
	For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
		if &SdtPagamentoDuplicataItem.CreCod = &CreCod
			//RetornaPlanCodNomVir.Call(&EmpCod, &SdtPagamentoDuplicataItem.CrePLancod, &PlanNom)
			&MovFunCod = &SdtPagamentoDuplicataItem.MovFunCod
			&CrePLancod = &SdtPagamentoDuplicataItem.CrePlanCod
			RetornaNomePessoa.Call(&EmpCod, &MovFunCod, &MovFunRaz)
			Exit
		EndIf
	EndFor
	
	For Each Order EmpCod, PlanCod
		Where EmpCod = &EmpCod
		Where PlanCod = &CrePLancod
		&PlanHie = PlanHie
		Exit
	EndFor

	&CrePlanCodNomVir = &PlanHie
	
	tbFuncionario.Visible = (&CrePLancod = &ValePlanCod and &ValePlanCod > 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 200
	&EmpCod.Visible = False
	&CreRecPag.Visible = False
	&AuxPlanCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	retornaCodigoPlanoContas.Call(&EmpCod, &CrePlanCodNomVir, &CrePLancod)
	RetornaPlanCodNomVir.Call(&EmpCod, &CrePLancod, &PlanNom)
	
	For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
		if &SdtPagamentoDuplicataItem.CreCod = &CreCod
			&SdtPagamentoDuplicataItem.crePlanCodNomVir = &PlanNom
			&SdtPagamentoDuplicataItem.CrePLancod = &CrePLancod
			
			if &ValePlanCod = &CrePlanCod and &MovFunCod > 0
				&SdtPagamentoDuplicataItem.MovFunCod = &MovFunCod
			Else
				&SdtPagamentoDuplicataItem.MovFunCod = 0
			Endif
		
			Exit
		EndIf
	EndFor
	
	&WebSession.Set('WWDuplicataReceber',&SdtPagamentoDuplicata.Toxml())
	
	if &ValePlanCod = &CrePlanCod and &MovFunCod = 0
		msg('Plano de Contas, solicita código funcionário!')
		&MovFunCod.SetFocus()
	Else
		Return
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CrePlanCodNomVir.IsValid

	retornaCodigoPlanoContas.Call(&EmpCod, &CrePlanCodNomVir, &CrePLancod)
	tbFuncionario.Visible = (&CrePLancod = &ValePlanCod and &ValePlanCod > 0)

EndEvent

Event &MovFunCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &MovFunCod, &MovFunRaz)

EndEvent


]]></Source>
