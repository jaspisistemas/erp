      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each Order EmpCod
		retornaConfiguracoesPastas.Call(EmpCod, FilCod, &SdtConfiguracoesPasta)		
		
		&Varchar = RetornaSoNumeros.Udp(EmpVerSmartNew)
		txtBuild.Caption = format('build: %1', trim(&Varchar))
			
		if EmpSmartLink = 'G' //GOOGLE
			&link = 'https://play.google.com/store/apps/details?id=jaspi.com.erp&pcampaignid=web_share'
			tbConfiguracao.Visible = 0
			
			&NomeCodigoBarras = 'erpgoogleplay'
			btnUserAction1.Visible = 0
			
			downloadGooglePlay.Link = &link
			downloadGooglePlay.LinkTarget = '_blank'
			downloadGooglePlay.Visible = 1
		Else
			tbConfiguracao.Visible = 1
			btnUserAction1.Visible = 1
			downloadGooglePlay.Visible = 0
			
			&linkConfig = EmpDirVirSmart.Trim()
			
			//geraQrCode
			&NomeCodigoBarras = 'servidorapp'
			&TipoCodigoBarras = TipoCodigoBarras.QRCODE
			
			&Caminho = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + trim(&TipoCodigoBarras.ToString()) + &NomeCodigoBarras.Trim() + '.png'
			&UrlImg = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + trim(&TipoCodigoBarras.ToString()) + &NomeCodigoBarras.Trim() + '.png'
			&File.Source = &Caminho
			if &File.Exists()
				&File.Delete()
			Endif		
			ExeCodigoBarrasWinWeb_qrCode.Call(&SdtConfiguracoesPasta, &TipoCodigoBarras, &NomeCodigoBarras, &linkConfig )
			&File.Close()
			
			&ImgDownloadConfig.FromURL(&UrlImg)
			
			&link = format('https://app.jaspi.com.br/appjaspi/app/erp/android_build%1.apk', &Varchar.Trim())
			&NomeCodigoBarras = format('build%1', trim(&Varchar))
			
		Endif
	
		//geraQrCode
		&TipoCodigoBarras = TipoCodigoBarras.QRCODE
		
		&Caminho = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + trim(&TipoCodigoBarras.ToString()) + &NomeCodigoBarras.Trim() + '.png'
		&UrlImg = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + trim(&TipoCodigoBarras.ToString()) + &NomeCodigoBarras.Trim() + '.png'
		&File.Source = &Caminho
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&SdtConfiguracoesPasta, &TipoCodigoBarras, &NomeCodigoBarras, &link )
		Endif
		&File.Close()
		
		&ImgDownloadBuild.FromURL(&UrlImg)
	
		
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable8.Width = 10

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	link(&link)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
