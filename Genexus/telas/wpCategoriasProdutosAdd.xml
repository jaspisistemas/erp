        <Source><![CDATA[
Event Start

	if &ComposicaoComplemento = 'P'
		form.Caption = 'Adicionar Produto - Complemento'
	Else
		form.Caption = 'Adicionar Produto - Composição'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)

EndEvent

Event Enter

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)
	
	if &ProCod > 0
		prcGravaObservacaoCategoria.Call('ADD', &EmpCod, &GrupCod, 0, &ProCod, &ComposicaoComplemento)
		Return
	Else
		msg(&Mensagem)
	Endif

EndEvent


