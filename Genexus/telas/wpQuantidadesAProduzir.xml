        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	&DataProducao = serverdate()
	&HoraProducao = serverTime()
	&FinalHoraProducao = serverTime()
	&FinalDataProducao = serverdate()
	
	&MateriaPrimaNecessaria = Status_SimNao.Sim
	&OrdProQtd.Enabled = 1
	do 'loadOrdem'
	validaOrdemProducaoPedidos.Call(&EmpCod, &FilCod, &OrdCod, &IsProblema)
	if &IsProblema = true
		&OqueFazer.Enabled = 0
		&OqueFazer  = 'N'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPedid.Rows = Page.Rows
	Grid.Rows = 200

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'DiaSemanaPrevisao'

EndEvent

Event GridPedid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&OrdProQtd = OrdProPrd
	&OrdProEstQtd = 0
	&OrdSemEstQtd = 0
	&OrdProQtdSem = OrdProPrd - OrdProQtdSem
	if &OrdProQtdSem < 0
		&OrdProQtdSem = 0
	EndIF

	if OrdProEstQtd > 0
		&OrdProEstQtd = OrdProEstQtd
	EndiF	
	if OrdSemEstQtd > 0
		&OrdSemEstQtd = OrdSemEstQtd
	EndiF
		
	&EstSug = OrdProEstVen - (&OrdSemEstQtd + &OrdProEstQtd)

	if &EstSug < 0
		&EstSug = 0
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionDelete = !'<i class="fa fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnCancelar'

	&Link = &DeOndeVEm.Trim() + '.aspx'
	link(&link)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFinalizaProducao'

	&PAdObs = trim(str(&QtdLinhasImprimir))
	padraousuario.Call('G', 'WPQUANTIDADESAPRODUZIRLINHAS', &Context.PesCod, &Context.EmpCod, &PAdObs, &PadDtaMod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	FormAtaHORA.Call(&HoraProducao, &HoraProducao)
	FormAtaHORA.Call(&FinalHoraProducao, &FinalHoraProducao)
	
	Do Case
		Case &OqueFazer = 'S' //GERAR ORDEM PRODUCAO
			Do Case
				Case &FinalDataProducao.IsEmpty() or &FinalDataProducao < &DataProducao
					msg('Data Produção Final não pode ser menor que a Inicial')
				Case &OrdDtaPrd.IsEmpty() or &OrdDtaPrd < serverdate()
					msg('Informe data de Previsão dos Pedidos')					
				Case &DataProducao <  serverdate()
					msg('Informe data da Produção')
				Otherwise				
					CarregaSdtProducaoPedido.Call('', &EmpCod, &FilCod, &OrdCod , Definicao.FABRICADO, 2, TipoOrdem.OrdemProducao, &sdtOrdemProducao, &newProSetCod)
					GravaOrdemProducaoNovoPedidos.Call('', &EmpCod, &FilCod, &sdtOrdemProducao, TipoOrdem.OrdemProducao, &DataProducao, &HoraProducao, &FinalDataProducao, &FinalHoraProducao, &OrdCod, &SetCod, &OrdObs)
					
					msg('Aguarde...')
					BtnFinalizaProducao.Visible = 0
					btnimprimirPedidos.Visible = 0
					
					&OqueFazer = 'N'
					&OqueFazer.Enabled = 0
					&Random = random() * 10000000000
					&ProgressId = 'gOrd' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
					&ProgressId = &ProgressId.trim()
					
					scaProgressBar1.ProcessId = &ProgressId
					scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
					scaProgressBar1.Start()
					
					FechaOrdemProducaoPedido.Submit('', &ProgressId, &EmpCod, &FilCod, &Context.PesCod, &OrdCod, &OrdDtaPrd, &DataProducao, &HoraProducao, &FinalDataProducao, &FinalHoraProducao)
					
			EndCase
			
		CAse &OqueFazer = 'N' //SOMENTE IMPRIMIR
			CarregaSdtProducaoPedido.Call('', &EmpCod, &FilCod, &OrdCod , Definicao.FABRICADO, 2, TipoOrdem.OrdemProducao, &sdtOrdemProducao, &newProSetCod)
			GravaOrdemProducaoNovoPedidos.Call('', &EmpCod, &FilCod, &sdtOrdemProducao, TipoOrdem.OrdemProducao, &DataProducao, &HoraProducao, &FinalDataProducao, &FinalHoraProducao, &OrdCod, &SetCod, &OrdObs)
			
			RCOOpenWindow1.LinkOpen = RELJAS069.Link(&EmpCod, &FilCod, &OrdCod, &MateriaPrimaNecessaria, &QtdLinhasImprimir)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
	EndCAse
	
	Grid.Refresh()

EndEvent

Event 'DoImprimirPedidos'

	do 'pegaPedidos'
	
	if &SdtPedidos.Count > 0
		&WebSession.Set('VARIOSPEDIDOSVENDA', &SdtPedidos.ToJson())
		&NomeArquivo = 'PedidoSeparacao' + trim(str(&PedCod))
		RCOOpenWindow1.LinkOpen = RELJAS029.Link(&EmpCod, &FilCod, 0, &Context.PesCod, &NomeArquivo, '', ServerTime(),false,false)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		msg('Nenhum pedido para ser impresso!')
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &OrdDtaPrd.IsValid

	do 'DiaSemanaPrevisao'

EndEvent

Event &DataProducao.IsValid

	do 'DiaSemanaPrevisao'

EndEvent

Event &FinalDataProducao.IsValid

	do 'DiaSemanaPrevisao'

EndEvent

Event &HoraProducao.IsValid

	FormAtaHORA.Call(&HoraProducao, &HoraProducao)

EndEvent

Event &FinalHoraProducao.IsValid

	FormAtaHORA.Call(&FinalHoraProducao, &FinalHoraProducao)

EndEvent

Event &OrdProQtd.IsValid

	GravaFabricarPedidos.Call('A', &EmpCod, &FilCod, &OrdCod, OrdProCod, OrdProGraCod, &OrdProQtd)

EndEvent

Event scaProgressBar1.OnComplete

	BtnFinalizaProducao.Visible = 1
	btnimprimirPedidos.visible = 1
					
	Do Case
		Case &OqueFazer = 'A'
			msg('Ordem Número ' + trim(str(&OrdCod)) + ' Agendada com sucesso!')
		CAse &OqueFazer = 'S'
			msg('Ordem Número ' + trim(str(&OrdCod)) + ' gerada com sucesso!')
	EndCase
	
	RCOOpenWindow1.LinkOpen = RELJAS069.Link(&EmpCod, &FilCod, &OrdCod, &MateriaPrimaNecessaria, &QtdLinhasImprimir)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event &ActionDelete.Click

	GravaFabricarPedidos.Call('D', &EmpCod, &FilCod, &OrdCod, OrdProCod, OrdProGraCod, &OrdProQtd)
	refresh

EndEvent

Event Refresh

	loadWwpContext.Call(&Context)
	padraousuario.Call('L', 'WPQUANTIDADESAPRODUZIRLINHAS', &Context.PesCod, &Context.EmpCod, &PAdObs, &PadDtaMod)
	&QtdLinhasImprimir = val(&PAdObs)

EndEvent

Event &SetCod.IsValid

	RetornaUltimaProducao.Call(&EmpCod, &FilCod, &SetCod, &UltimaProducaoMensagem)

EndEvent

Sub 'pegaPedidos'

	&SdtPedidos.Clear()
	
	For Each Order EmpCod, FilCod, OrdCod, OrdPedItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where OrdCod = &OrdCod
		
		&SdtPedidosItem = New()
		&sdtPedidosItem.EmPCod = EmpCod
		&sdtPedidosItem.FiLCod = OrdPedFilCod
		&sdtPedidosItem.PedCod = OrdPedCod
		
		&SdtPedidos.Add(&sdtPedidosItem)
		
	EndFor

EndSub

Sub 'DiaSemanaPrevisao'

	&Mensagem = &OrdDtaPrd.DayOfWeekName()
	txtPrevisao.Caption = &Mensagem.Trim() + ' (Previsão para os Pedidos)'
	
	&Mensagem = &DataProducao.DayOfWeekName()
	txtInicioProducao.Caption = Substr(&Mensagem ,1,3)
	
	&Mensagem = &FinalDataProducao.DayOfWeekName()
	txtFinalProducao.Caption = Substr(&Mensagem ,1,3)

EndSub

Sub 'loadOrdem'

	For Each Order EmpCod, FilCod, OrdCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where OrdCod = &OrdCod
		
		&OrdObs = OrdObs
		
		&OrdDtaPrd = serverdate() + 7
		&SetCod = OrdSetCod
		If OrdSts <> Status_Producao.Aguardando
			wpPedidosOrdem.Link()
		EndIF
		Exit
	EndFor
	do 'DiaSemanaPrevisao'
	RetornaUltimaProducao.Call(&EmpCod, &FilCod, &SetCod, &UltimaProducaoMensagem)

EndSub


