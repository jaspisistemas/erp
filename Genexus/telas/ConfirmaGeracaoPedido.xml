      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	do 'loadPedido'
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon019_LctoOrcamento, &CfgVlr)
	&VendaLctCod = val(&CfgVlr)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	prcAtualizaCapaPedido.Call(&EmpCod, &FilCod, &PedCod, &PedCliCod, &PedVenCod, &PedDtaEms, &PedDtaPrv, &TabCod, &TabPrmCod, &TabColCod, &PedPraCod, &PedPraParNom, &VendaLctCod, &PedRspCod, &PedNovCliRaz, &PedNovCliCpfCnpj, &Context.UserName,&PedFatFilCod)
	//GRAVA VENDEDOR DUPLICATAS
	AtualizaDuplicatasPedido.Call(&EmpCod, &FilCod, &PedCod, &PedVenCod, &PedCliCod, &PedFatFilCod)
		
	//RetornaCodigoStatusPedido.Call(&EmpCod, 'CONDICIONAL', &StsCod)
	//GravaStatusPedido.Call(&EmpCod, &FilCod, &PedCod, &StsCod, '', 0)
	GravaDataCondicional.Call(&EmpCod, &FilCod, &PedCod, &PedDtaPrv, &PedDtaEve, &PedDtaFat, &Context.UserName)
	AtualizaPrecosPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, false)
//	&Salvar = 'S' + trim(str(&PedCod))
	//IMprimir pedido
//	&WebSession.Set('wpFecCondImprimeCondicional', &Salvar)
//	wwpedidobalcao.Link()
	//wpVendas.Link(0, &EmpCod, &FilCod, &PedCod, 0)

	return

EndEvent

Sub 'loadPedido'

	For Each order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedNovCliRaz = PedNovCliRaz
		&PedNovCliCpfCnpj = PedNovCliCpfCnpj
		&PedCliCod = PedCliCod
		&PedVenCod = PedVenCod
		&PedDtaEms = PedDtaEms
		&PedDtaPrv = PedDtaPrv
		&TabCod = TabCod
		&TabPrmCod = TabPrmCod
		&TabColCod = TabColCod
		&PedPraCod = PedPraCod
		&PedPraParNom = PedPraParNom
		&VendaLctCod = LctCod
		&PedRspCod = PedRspCod
		&PedFatFilCod = PedFatFilCod
		
		&PedDtaEve = PedDtaEve
		&PedDtaPrv = PedDtaPrv
		
		Exit
	When None
		return
	EndFor

EndSub


]]></Source>
