Sub 'limpaSelecionados'

	if &SdtProdutos.Count > 0  or &Count > 0
		&SdtProdutos.Clear()
		&Count = 0
		Do 'TotalizaCount'
		Refresh
	EndIf

EndSub

Sub 'addSDTSelecionados'

	&IsAchou = false
	For &SdtProdutosItem in &SdtProdutos
		If &SdtProdutosItem.ProCod = &AuxProCod
			&IsAchou = True
			Exit
		EndIF				
	EndFor

	if &IsAchou = false
		&SdtProdutosItem = New()
		&SdtProdutosItem.ProCod = &AuxProCod
		&SdtProdutosItem.ProRef = &AuxProRef
		&SdtProdutosItem.ProNom = &AuxProNom
		&SdtProdutos.Add(&SdtProdutosItem)		
	EndIf

EndSub

Sub 'loadSDT'

	if &Selecionado = false
		&SdtProdutosItem = New()
		&SdtProdutosItem.ProCod = &AuxProCod
		&SdtProdutosItem.ProRef = &AuxProRef
		&SdtProdutosItem.ProNom = &AuxProNom
		&SdtProdutos.Add(&SdtProdutosItem)		
	else //esta true
		For &SdtProdutosItem in &SdtProdutos
			If &SdtProdutosItem.ProCod = &AuxProCod
				&Index = &SdtProdutos.IndexOf(&SdtProdutosItem)
				&SdtProdutos.Remove(&Index)		
				Exit
			EndIF				
		EndFor
	EndIf
	
	Do 'TotalizaCount'
	Refresh

EndSub


