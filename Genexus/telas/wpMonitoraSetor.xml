Event Grid.Load

	RetirazerosDepoisVirgulaxCasas.Call(0,EstQtd.ToFormattedString(), &EstQtdVarchar)
	&EstQtdVarchar  = trim(&EstQtdVarchar)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionSelecione.FromImage(DDOMultiselSelOption)
	&ActionSelecione.TooltipText = ""
	
	&USerUpdate = !'<i class="fas fa-pen"></i>'
	
	&Ajustar = !'<i class="fas fa-plus"></i>'
	
	&StatusProduto.FromImage(WarningIcon)
	&StatusProduto.TooltipText = ""
	
	&EditarEstoque = !'<i class="fas fa-cube"></i>'
	
	&Transfe = !'<i class="fas fa-sync"></i>'
	
	&SaidaDescarte = !'<i class="fas fa-trash"></i>'

	Do Case
		Case ProSts = Status_Produto.ATIVO
			ProSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case ProSts = Status_Produto.INATIVO
			ProSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case ProSts = Status_Produto.EXCLUIDO
			ProSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			ProSts.ColumnClass = 'WWColumn'
	EndCase
	ProGraRef.ColumnClass = iif(ProSts = Status_Produto.INATIVO	, !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell', !'WWColumn')
	&EstQtdVarchar.ColumnClass = iif(EstQtd < 0, !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if ProSts = Status_Produto.ATIVO
		&Ajustar = !'<i class="fas fa-times"></i>'
	Else
		&Ajustar = !'<i class="fas fa-plus"></i>'
	EndIf

	&Selecionado = false
	&ActionSelecione.FromImage(DDOMultiselOption)
	
	For &SdtProdutosItem in &SdtProdutos
		If &SdtProdutosItem.ProCod = ProCod
			&Selecionado = true
			&ActionSelecione.FromImage(DDOMultiselSelOption)	
			exit//se achou sai do for do sdt
		Endif
	EndFor

EndEvent

