      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	do 'loadOperacao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'loadCFOPDentro'
	do 'loadCFOPFora'
	If &IsInvalidoDentro = false and &IsInvalidoFora = false
		prcAplicarTodasOperacoes.Call(&EmpCod, &LctCod, &CfoCodDentro, &CfoCodFora)
		Return
	Else
		&CfoCodDentro.SetFocus()
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CfoCodDentro.IsValid

	do 'loadCFOPDentro'

EndEvent

Event &CfoCodFora.IsValid

	do 'loadCFOPFora'

EndEvent

Sub 'loadOperacao'

	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = 	&LctCod
		
		&LctCodNom = LctCodNom 
		
		Exit
	EndFor

EndSub

Sub 'loadCFOPFora'

	ValidaCfOP.Call(&CfoCodFora, &IsInvalidoFora, &Mensagem)
	if &IsInvalidoFora = true or substr(&CfoCodFora, 1, 1) <> '2'
		&IsInvalidoFora = true
		msg('CFOP Entrada Fora da UF, Inválido!')
	Endif

EndSub

Sub 'loadCFOPDentro'

	ValidaCfOP.Call(&CfoCodDentro, &IsInvalidoDentro, &Mensagem)
	if &IsInvalidoDentro = true or substr(&CfoCodDentro, 1, 1) <> '1'
		&IsInvalidoDentro = true
		msg('CFOP Entrada dentro da UF, Inválido!')
	Endif

EndSub


]]></Source>
