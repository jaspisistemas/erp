      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWpContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	RetornaAutorizacao.Call('WPCTEPORCFOP', Status_SimNao.Sim, 1, &AutNiv)
	&CteDtaEms_to = serverdate()
	&CteDtaEms = &CteDtaEms_to - 30
	&CteNum_to = 999999999

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&AgrPre = 1)
		&Status_SimNao.Visible = False
		Status_SimNao_Cell.Class = !'Invisible'
	Else
		&Status_SimNao.Visible = True
		Status_SimNao_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&AgrPre = 2)
		&AgrTip.Visible = False
		AgrTip_Cell.Class = !'Invisible'
	Else
		&AgrTip.Visible = True
		AgrTip_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	do 'GetCfop'
	do 'GetPessoa'
	do 'GetTomador'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AgrPre.Click

	do 'AttributesSecurityCode'

EndEvent

Event Enter

	Do case
		Case &AgrPre = 1 //Normal
			RCOOpenWindow1.LinkOpen = RELJAS086.Link(&EmpCod, &FilCod, &CteDtaEms, &CteDtaEms_to, &CteTomCod,&CteDesCod, &CteNum, &CteNum_to, &CfoCod,&CtePlc,&CtePlcTra,&Status_SimNao,&CteDocTra, &Tipo,&CteCpfMot)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Case &AgrPre = 2 //Por Prestacao
			RCOOpenWindow1.LinkOpen = RELJAS088.Link(&EmpCod, &FilCod, &CteDtaEms, &CteDtaEms_to, &CteTomCod, &CteDesCod, &CteNum, &CteNum_to, &CfoCod,&AgrTip,&CtePlc,&CtePlcTra,&CteDocTra,&CteCpfMot)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Case &AgrPre = 3 //Por Finalidade + Cpl
			RCOOpenWindow1.LinkOpen = RELJAS147.Link(&EmpCod, &FilCod, &CteDtaEms, &CteDtaEms_to, &CteTomCod,&CteDesCod, &CteNum, &CteNum_to, &CfoCod,&CtePlc,&CtePlcTra,&Status_SimNao,&CteDocTra,&CteCpfMot)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent

Event &CfoCod.IsValid

	do 'GetCfop'

EndEvent

Event &CteDesCod.IsValid

	do 'GetPessoa'

EndEvent

Event &CtePlc.IsValid

	FormataPLACA.Call(&EmpCod,&CtePlc,&CtePlc)
	&CtePlc = &CtePlc.ToUpper()

EndEvent

Event &CteCpfMot.IsValid

	&CteCpfMot = trim(&CteCpfMot) 
	if not &CteCpfMot.trim().IsEmpty()
		ValidaCpfCnpj.Call(&CteCpfMot, &erroc, 'N')
		if &erroc = 0	
			Do 'Motorista'
		Else
			msg('CPF inválido!')
		EndIF
	EndIF

EndEvent

Event &CteTomCod.IsValid

	do 'GetTomador'

EndEvent

Sub 'GetPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CteDesCod
		&CteDesRaz = PesRaz
	When none
		If &CteDesCod = 0
			&CteDesRaz = 'TODAS AS PESSOAS'
		Else
			&CteDesRaz = 'DESTINATÁRIO NÃO LOCALIZADA'
		EndIf
	EndFor

EndSub

Sub 'GetTomador'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CteTomCod
		&CtetomRaz = PesRaz
	When none
		If &CteTomCod = 0
			&CtetomRaz = 'TODAS AS PESSOAS'
		Else
			&CtetomRaz = 'TOMADOR NÃO LOCALIZADA'
		EndIf
	EndFor

EndSub

Sub 'GetCfop'

	For Each Order CfoCod
		Where CfoCod = &CfoCod
		&CfoNom = CfoNom
		Exit
	When none
		If &CfoCod = ''
			&CfoNom = 'TODOS OS CFOPS'
		Else
			&CfoNom = 'CFOP NÃO LOCALIZADO'
		EndiF
	EndFor

EndSub

Sub 'Motorista'

	For each order EmpCod,PesCpf
		Where EmpCod = &EmpCod
		Where PesCpf = &CteCpfMot	
		&CteNomMot = PesRaz
		Exit
	EndFor

EndSub


]]></Source>
