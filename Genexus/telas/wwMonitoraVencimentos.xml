      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWMONITORAVENCIMENTOS', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadwwpContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod
	&FilCod = &WwpContext.FilCod
	&ProVctDta = serverdate()
	&DiasAFiltro = 15
	
	&Editar.Title = 'Editar'
	&RemoverItem.Title = 'Remover'
	&MarcarComoAjustado.Title = 'Conferido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtVencimentosProdutoss.Rows = Page.Rows
	GridsdtVencimentosProdutossPaginationBar.RowsPerPageSelectedValue = GridsdtVencimentosProdutoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtVencimentosProdutossCurrentPage = GridsdtVencimentosProdutoss.CurrentPage
	&GridsdtVencimentosProdutossPageCount = GridsdtVencimentosProdutoss.PageCount
	sdtVencimentosProdutos__Mensagem.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtVencimentosProdutoss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Editar = !'<i class="fa fa-pen"></i>'
	
	&RemoverItem = !'<i class="fa fa-times"></i>'
	
	&MarcarComoAjustado = !'<i class="fas fa-check"></i>'

	Do Case
		Case &sdtVencimentosProdutos.CurrentItem.Status in ('30','20','15')
			sdtVencimentosProdutos__Mensagem.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case &sdtVencimentosProdutos.CurrentItem.Status in ('10', '05')
			sdtVencimentosProdutos__Mensagem.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case &sdtVencimentosProdutos.CurrentItem.Status = '02'
			sdtVencimentosProdutos__Mensagem.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case &sdtVencimentosProdutos.CurrentItem.Status in ('01', '00', '-01')
			sdtVencimentosProdutos__Mensagem.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case &sdtVencimentosProdutos.CurrentItem.Status = '-02'
			sdtVencimentosProdutos__Mensagem.ColumnClass = !'WWColumn WWColumnBold WWColumnBoldSingleCell'
		Otherwise
			sdtVencimentosProdutos__Mensagem.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&MarcarComoAjustado.Visible = &sdtVencimentosProdutos.CurrentItem.Status = '-02'

EndEvent

Event GridsdtVencimentosProdutossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtVencimentosProdutossPaginationBar.SelectedPage = !'Previous'
			GridsdtVencimentosProdutoss.PreviousPage()
		Case GridsdtVencimentosProdutossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtVencimentosProdutoss.CurrentPage
			&PageToGo += 1
			GridsdtVencimentosProdutoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtVencimentosProdutossPaginationBar.SelectedPage)
			GridsdtVencimentosProdutoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtVencimentosProdutossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtVencimentosProdutoss.Rows = GridsdtVencimentosProdutossPaginationBar.RowsPerPageSelectedValue
	GridsdtVencimentosProdutoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCadastrar'

	wpAdicionarVencimentos.Popup(0, 0, 0, 0, 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	&WebSession.Set('wwMonitoraVencimentosImprimir', &sdtVencimentosProdutos.ToJson())
	wpImprimirVencimentos.Popup()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	prcRetornaProdutosVencimentos.Call(&EmpCod, &FilCod, &ProVctDta, &Filtrar, &DiasAFiltro, &ProSetCod, &sdtVencimentosProdutos)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFiltrarProdutoEspecifico'

	&sdtVencimentosProdutos.Clear()
	if not &ProRef.IsEmpty() or not &ProRefNom.IsEmpty()
		prcRetornaProdutosVencimentosProduto.Call(&EmpCod, &FilCod, &ProVctDta, &Filtrar, &DiasAFiltro, &ProRef, &ProRefNom, &sdtVencimentosProdutos)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Editar.Click

	wpAdicionarVencimentos.Popup(&sdtVencimentosProdutos.CurrentItem.EmpCod, &sdtVencimentosProdutos.CurrentItem.filCod, &sdtVencimentosProdutos.CurrentItem.ProCod, &sdtVencimentosProdutos.CurrentItem.PrograCod, &sdtVencimentosProdutos.CurrentItem.ProVctCod)

EndEvent

Event &MarcarComoAjustado.Click

	wpMarcarComoConferido.Popup(&sdtVencimentosProdutos.CurrentItem.EmpCod, &sdtVencimentosProdutos.CurrentItem.filCod, &sdtVencimentosProdutos.CurrentItem.ProCod, &sdtVencimentosProdutos.CurrentItem.PrograCod,&sdtVencimentosProdutos.CurrentItem.ProVctCod)

EndEvent


