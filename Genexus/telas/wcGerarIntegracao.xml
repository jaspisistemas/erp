      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&PdvRandon.Visible = 0
	if &PdvCod > 0
		For Each Order EmpCod, PdvCod 
			Where EmpCod = &EmpCod
			Where PdvCod = &PdvCod
			
			&pdvValidacao = PdvValidacao //= &GUID.ToString() //esse é o random instalacao
			&PdvRandon = PdvRandon //PdvRandon = &GUID.ToString() //esse é random comunicacao
			
			if &PdvRandon.IsEmpty()
				tbKeyGerada.Visible = 0
				TextBlock13.Visible = 0
				TextBlock12.Visible = 0
				TextBlock1.Visible = 0
			ENdif
			
			Exit
		EndFor
	Else
		For Each Order EmpCod, MonCod
			Where EmpCod = &EmpCod
			Where MonCod = &MonCod
			
			&pdvValidacao = MonValidacao //= &GUID.ToString() //esse é o random instalacao
			&PdvRandon = MonRandon //PdvRandon = &GUID.ToString() //esse é random comunicacao
			
			&MonTip = MonTip
			&PdvRandon.Visible = (MonTip = TipoApp.BI)
			&pdvValidacao.Visible = (MonTip <> TipoApp.BI)
			
			if &PdvRandon.IsEmpty()
				tbKeyGerada.Visible = 0
				TextBlock13.Visible = 0
				TextBlock12.Visible = 0
				TextBlock1.Visible = 0
			ENdif
			
			Exit
		EndFor
		
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserNovaGeracao'

	btnUserNovaGeracao.Visible = 0
	
	prcGravaAutorizacaoInstalacao.Call(&EmpCod, &PdvCod, &MonCod, &IsSucesso, &Mensagem)
	
	if &IsSucesso = true		
		tbKeyGerada.Visible = 1
		tbkeyGerar.Visible = 0
		if &MonTip = TipoApp.BI
			&PdvRandon = &Mensagem
		Else
			&PdvValidacao = &Mensagem
		Endif
	else
		msg(&Mensagem)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
