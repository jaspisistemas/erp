      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&PesCod = &Context.PesCod
	
	&collFilCod.Clear()
	DpFilialAcesso.Call(&Context.EmpCod, &Context.PesCod, &sdtFilialAcesso)
	for &sdtFilialAcessoItem in &sdtFilialAcesso
		&collFilCod.Add(&sdtFilialAcessoItem.PesFilAce)
	EndFor

	&OqueFazer.Clear()
	&OqueFazer.AddItem('1', 'VISUALIZAR PEDIDO - SEM LOGOMARCA')
	&OqueFazer.AddItem('4', 'VISUALIZAR PEDIDO - COM LOGOMARCA')
		
//	padraoUsuario.Call('L', 'PEDIDOVENDA_IMPRESSAODIRETA', &Context.PesCod, &Context.EmpCod, &PadOBs, &PAdDtaMod)
	
	&ModeloPedido = 'IMPRESSÃO DIRETA - MATRICIAL'
	For Each Order EmpCod, EmpImpPC, EmpImpNom
		Where EmpCod = &Context.EmpCod
		where EmpImpTip = domTipoImpressora.MATRICIAL or EmpImpTip = domTipoImpressora.MATRICIAL2
		Where EmpImpFilCod.IsEmpty() or EmpImpFilCod.IsNull() or EmpImpFilCod in &collFilCod
		
		&Mensagem = &ModeloPedido + '|' + EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
		&CodigoImpressora = '3A   ' + PadL(str(EmpImpCod), 8, ' ')
		&OqueFazer.AddItem(&CodigoImpressora, &Mensagem)
	EndFor
	
	&ModeloPedido = 'IMPRESSÃO DIRETA - TICKET'
	For Each Order EmpCod, EmpImpPC, EmpImpNom
		Where EmpCod = &Context.EmpCod
		where EmpImpTip = domTipoImpressora.CUPOM1 or EmpImpTip = domTipoImpressora.CUPOM2
		Where EmpImpFilCod.IsEmpty() or EmpImpFilCod.IsNull() or EmpImpFilCod in &collFilCod
		
		&Mensagem = &ModeloPedido + '|' + EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
		&CodigoImpressora = '3B   ' + PadL(str(EmpImpCod), 8, ' ')
		&OqueFazer.AddItem(&CodigoImpressora, &Mensagem)
	EndFor
	
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&OqueFazer = trim(Substr(&PadObs, 1, 5))
		&Ordem = Substr(&PadObs, 6, 1)
		if Substr(&PadObs, 7, 1) = '1'
			&DestacarImpostos = true
		Else
			&DestacarImpostos = false
		EndIF
	EndIF
	
	do 'loadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 200

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&OqueFazer = '1' or &OqueFazer = '4')
		&DestacarImpostos.Visible = False
		DestacarImpostos_Cell.Class = !'Invisible'
	Else
		&DestacarImpostos.Visible = True
		DestacarImpostos_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	
	tbuss.Visible = (1=2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &OqueFazer.Click

	do 'AttributesSecurityCode'

EndEvent

Event &OqueFazer.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event Enter

	btnEnter.Visible = 0
	&EmpImpCod1 = val(Substr(&OqueFazer, 6, 8))
	
	&PadObs = PadR(trim(Substr(&OqueFazer, 1, 5)), 5, ' ') + trim(&Ordem) 
	If &DestacarImpostos = true
		&PadObs += '1' + Substr(&OqueFazer, 6, 8)
	Else
		&PadObs += '0' + Substr(&OqueFazer, 6, 8)
	EndiF
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&Varchar = ServerTime()
	
	Do Case
		Case Substr(&OqueFazer, 1, 2) = '1' //IMPRESSÃO PEDIDO COMPRA
			&NomeArquivo = 'PedidoCompra' + trim(str(&PedCod))
			RCOOpenWindow1.LinkOpen = RELJAS003.Link(&EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, &Varchar, &DestacarImpostos,false)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		
		Case Substr(&OqueFazer, 1, 2) = '4' //IMPRESSÃO PEDIDO COMPRA - MODELO02
			&NomeArquivo = 'PedidoCompra' + trim(str(&PedCod))
			RCOOpenWindow1.LinkOpen = RELJAS076.Link(&EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, &Varchar, &DestacarImpostos,false)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case Substr(&OqueFazer, 1, 2) = '3A' //IMPRESSAO MATRICIAL
			prcGravaImpressao.Call(&EmpCod, &EmpImpCod1, 'RELJAS124', &FilCod, &PedCod, &Context.PesCod, '', 0, &FiDtaIni)

		Case Substr(&OqueFazer, 1, 2) = '3B' //IMPRESSAO TICKET
			prcGravaImpressao.Call(&EmpCod, &EmpImpCod1, 'RELJAS124_B', &FilCod, &PedCod, &Context.PesCod, '', 0, &FiDtaIni)
	EndCase


	&ProgressId = 'wpImprimePed' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	EsperaSegundos.Submit('', &ProgressId)

EndEvent

Event scaProgressBar1.OnComplete

	Return

EndEvent

Sub 'loadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		Do Case
			Case LctTip = TipoLancamento.DevolucaoCompra
				Form.Caption = 'Impressão Pedido Devolução Compra'
				
			Case  LctTip = TipoLancamento.DevolucaoVenda
				Form.Caption = 'Impressão Pedido Devolução Venda'
		EndCAse
		Exit
	EndFor

EndSub


]]></Source>
