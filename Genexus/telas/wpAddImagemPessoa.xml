      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	retornaAutorizacao.Call('WPUPLOADARQUIVOS', Status_SimNao.Sim, 2, &AutNiv)
	
	retornaAutorizacao.Call('WWTIPOSANEXOS', Status_SimNao.Nao, 2, &AutorizadoTiposAnexos)
	
	&PesAnxTipCod.Clear()	
	RetornaTipoAnexo.Call(&EmpCod, '#IMAGEM_PESSOA#', &PesAnxTipCod)
	&PesAnxTipCod.AddItem(&PesAnxTipCod, '#IMAGEM_PESSOA#')
	
	&AddPesAnxCod = &PesAnxCod
	For Each Order EmpCod, PesCod, PesAnxCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesAnxCod = &PesAnxCod
		&PesAnxTipCod = PesAnxTipCod
		&PesAnxDsc = PesAnxDsc
		
		&PesAnxMod = PesAnxMod
		Exit
	When none
		&PesAnxTipCod.SetEmpty()
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesAnxDsc.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGravar'

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = true
		if &FileUploadDataColl.Count = 0 and &AddPesAnxCod = 0
			Msg('Arquivo é obrigatório')
		Else
			if &FileUploadDataColl.Count = 0 and &AddPesAnxCod <> 0
				GravaAnexoUpload.Call('ADD', &EmpCod, &Context.FilCod, &PesCod, &AddPesAnxCod, &PesAnxTipCod, &PesAnxDsc, '', '', '', &Context.UserName, &Mensagem)
				Return
			Else
				For &FileUploadData in &FileUploadDataColl
					if not &FileUploadData.File.IsEmpty()
						&File.Source=&FileUploadData.File
						&NomeArquivoVarchar = &File.GetAbsoluteName() /// Pega o local temporario
						&File.Close()
						
						&PesAnxExt = &FileUploadData.Extension
						&PesAnxNom = &FileUploadData.Name
						
						GravaAnexoUpload.Call('ADD', &EmpCod, &Context.FilCod, &PesCod, &AddPesAnxCod, &PesAnxTipCod, &PesAnxDsc, &PesAnxNom, &PesAnxExt, &NomeArquivoVarchar, &Context.UserName, &Mensagem)
						
						&PesAnxDsc.SetEmpty()
						&PesAnxDsc.SetFocus()
						&AddPesAnxCod.SetEmpty()
						
						Exit
					Endif
				EndFor
				
				Return
			Endif
		Endif
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	If &PesAnxTipCod.IsEmpty() or &PesAnxTipCod = 0
		Msg('Tipo Anexo é obrigatório.')
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PesAnxTipCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Tipo Anexo'), DVMessageType.error, &PesAnxTipCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
