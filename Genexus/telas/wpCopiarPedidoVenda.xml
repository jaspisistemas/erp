        <Source><![CDATA[parm(in:&DeOndeVem, in:&EmpCod, in:&FilCod, in:&PedCod);


prompt(promptFornecedores, &EmpCod, &NovPedCliCod);
Prompt(promptTipoLancamento, &EmpCod, &NovLctCod);
prompt(promptVendedor, &EmpCod, &NovPedVenCod);
prompt(promptTabelaPrecop, &EmpCod, &NOvTabCod);
prompt(promptTabelaPrecop, &EmpCod, &NOvTabPrmCod);
]]></Source>
