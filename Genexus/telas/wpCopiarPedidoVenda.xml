      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	TextBlockTitle.Caption = 'Copiar Pedido: ' + trim(str(&PedCod))
	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'getPedido'
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon020_ClientePadraoVista, &CfgVlr)
	&VistaPedCliCod = iif(&CfgVlr = '', 1, val(&CfgVlr))
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon021_BloquearVendaAreaDiferente, &TCon021_BloquearVendaAreaDiferente)
	&TrocarVendedorAutNiv = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon092_AutorizaCopiarPedidoFechado, &TCon092_AutorizaCopiarPedidoFechado)

	&AutorizadoPedidoFechado = 1
	if &TCon092_AutorizaCopiarPedidoFechado = 'S'
		RetornaAutorizacao.Call('VENDACOPIARPEDIDOFATURADO', Status_SimNao.Nao, 1, &AutorizadoPedidoFechado)
		
		if &AutorizadoPedidoFechado < 1 and &PedSts = Status_Pedido.FECHADO
			msg('Usuário Não Autorizado a Copiar Pedido Faturado!')
			btnEnter.Enabled = 0
		Endif
	Endif

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &NovPedCliCod.IsValid

	do 'loadCliente'

EndEvent

Event &NovLctCod.IsValid

	do 'CodigoLancamento'

EndEvent

Event &NovPedVenCod.IsValid

	do 'vendedor'

EndEvent

Event &NovTabCod.IsValid

	do 'loadTabelaColuna'

EndEvent

Event &NovTabColCod.IsValid

	do 'loadTabelaColuna'

EndEvent

Event &NovTabPrmCod.IsValid

	do 'loadTabelaColuna'

EndEvent

Event Enter

	do 'loadCLiente'
	do 'CodigoLancamento'
	do 'vendedor'
	do 'loadTabelaColuna'
	do 'validaPedidoTabela'
	
	loadWWPContext.Call(&Context)
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon092_AutorizaCopiarPedidoFechado, &TCon092_AutorizaCopiarPedidoFechado)

	&AutorizadoPedidoFechado = 1
	if &TCon092_AutorizaCopiarPedidoFechado = 'S'
		RetornaAutorizacao.Call('VENDACOPIARPEDIDOFATURADO', Status_SimNao.Nao, 1, &AutorizadoPedidoFechado)
	Endif

	Do Case
		Case &AutorizadoPedidoFechado < 1 and &PedSts = Status_Pedido.FECHADO
			msg('Usuário Não Autorizado a Copiar Pedido Faturado!')
			
		Case &NovPedDtaEms.IsEmpty()
			msg('Informe data de Emissão!')
			&NovPedDtaEms.SetFocus()
			
		case &IsErroCliente = true
			&NovPedCliCod.SetFocus()
			
		case &IsErroVendedor = true
			&NovPedVenCod.SetFocus()
			
		Case &IsOkOperacao = true
			msg(&OperacaoMensagem)
			&NovLctCod.SetFocus()
			
		Case &IsColunaErro = true
			&NovTabCod.SetFocus()
			
		case &ValidacaoPedido = true
			&NovPedCliCod.SetFocus()
			
		Otherwise
			&PedStsDigBlk = false
			if &DeOndeVem = 'WWPEDIDOTELEVENDAS'
				RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon058_DigitandoPedido, &TCon058_DigitandoPedido)
				If &TCon058_DigitandoPedido = 'S'
					&PedStsDigBlk = true
				EndIF
			EndIF
		
			CopiaPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, &NovLctCod, &NovPedCliCod, &NovPedDtaEms, &NovPedVenCod, &NovTabCod, &NovTabPrmCod, &NovTabColCod, &Context.PesCod, &PedStsDigBlk, &NovoPedCod, &Mensagem)
			if not &Mensagem.IsEmpty()
				Do Case
					CAse &DeOndeVem = 'WWPEDIDOVENDA'
						PedidoVendas.Link(TrnMode.Update, &EmpCod, &FilCod, &NovoPedCod, 'PEDIDOVENDA')
					Case &DeOndeVem = 'WWPEDIDOFATURAMENTO'
						PedidoVendas.Link(TrnMode.Update, &EmpCod, &FilCod, &NovoPedCod, 'PEDIDOFATURAMENTO')					
					CAse &DeOndeVem = 'WWPEDIDOTELEVENDAS'
						PedidoVendas.Link(TrnMode.Update, &EmpCod, &FilCod, &NovoPedCod, 'PEDIDOTELEVENDAS')
					Otherwise
						return
				EndCase
			EndIf
	EndCase

EndEvent

Sub 'loadTabelaColuna'

	&IsColunaErro = false
	For Each Order EmpCod, TabCod, TabColCod
		Where EmpCod = &EmpCod
		Where TabCod = &NovTabCod
		Where TabColCod = &NovTabColCod
		Exit
	When none
		&IsColunaErro = true
	EndFor
	
	if &NovTabPrmCod <> ''
		For Each Order EmpCod, TabCod
			Where EmpCod = &EmpCod
			Where TabCod = &NovTabPrmCod
			Exit
		When none
			&IsColunaErro = true
		EndFor
	EndIF

EndSub

Sub 'validaPedidoTabela'

	&ValidacaoPedido = false
	
	If (&novTabColCod = 0 or &novTabColCod > 5)
		msg('Coluna de Preço Inválida!')
		&ValidacaoPedido = true
	EndIF
	
	if &TCon021_BloquearVendaAreaDiferente = 'S' and (&PedCliCidAreCod <> &PedVenAreCod) and (&PedCliCidAreCod <> 0)
		msg('Vendedor não autorizado a vender na área ' +trim(str(&PedCliCidAreCod))+ '!')
		&ValidacaoPedido = true
	EndIF
	
	if ((&PedVenIntExt = Status_InternoExterno.INTERNO and &NovPedVenCod <> &PedCliIntVenCod and &PedCliIntVenCod <> 1)
		or (&PedVenIntExt = Status_InternoExterno.EXTERNO and &NovPedVenCod <> &PedCliExtVenCod and &PedCliExtVenCod <> 1)) and &NovPedCliCod <> 1 and &NovPedCliCod <> &VistaPedCliCod and &TrocarVendedorAutNiv < 1
		
		msg('Vendedor atual é o Televendas: ' +trim(str(&PedCliIntVenCod))+ ' e o Vendedor: ' +trim(str(&PedCliExtVenCod))+ '. Com o informado não pode!')
		&ValidacaoPedido = true
	EndIF

	TestaTabelasPedidoVenda.Call(&EmpCod, &FilCod,  &NovTabCod, StatusTabela.NormalAtiva, &PedCliCidUfeCod, &NovPedDtaEms, &PedCliCidAreCod, &TabelaNormalMensagem)
	
	If not &TabelaNormalMensagem.IsEmpty()
		msg(&TabelaNormalMensagem)
		&ValidacaoPedido = true
	else
		TestaTabelasPedidoVenda.Call(&EmpCod, &FilCod, &NovTabPrmCod, StatusTabela.Promocao, &PedCliCidUfeCod, &NovPedDtaEms, &PedCliCidAreCod, &TabelaNormalMensagem)
		If not &TabelaNormalMensagem.IsEmpty()
			msg(&TabelaNormalMensagem)
			&ValidacaoPedido = true
		EndIf
	EndIf

EndSub

Sub 'vendedor'

	&IsErroVendedor = false
	&NovPedVenRaz = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NovPedVenCod
		Where PesIsVen = true
		&NovPedVenRaz = PesRaz
		&PedVenAreCod = PesVenAreCod
		&PedVenIntExt  = PesVenIntExt
		Exit
	When none
		&NovPedVenRaz = 'Vendedor não Encontrado!'
		&IsErroVendedor = true
	EndFor

EndSub

Sub 'loadCliente'

	&IsErroCliente = false
	&PesRaz = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NovPedCliCod
		
		If PesSts <> Status_AtivoInativo.ATIVO
			msg('Cliente com Cadastro inativado!')
			&IsErroCliente = true
		EndiF
	
		&PedCliIntVenCod = PesIntVenCod
		&PedCliCidUfeCod = PesCidUfeCod
		&PesRaz = PesRaz
		&PedCliCidAreCod = PesCidAreCod
		&PedCliExtVenCod = PesExtVenCod
		Exit
	When none
		&IsErroCliente = true
		&PesRaz = 'CLIENTE NÃO ENCONTRADO'
	EndFor

EndSub

Sub 'CodigoLancamento'

	&IsOkOperacao = true
	&OperacaoMensagem = ''
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &NovLctCod
		Where LctTip in (TipoLancamento.SaidaMercadoria, TipoLancamento.OrcamentoVenda)
		&IsOkOperacao = false
		&LctNom	= LctNom
		Exit
	When none
		&OperacaoMensagem = 'Operação Informada não Corresponde à uma venda!'
	EndFor

EndSub

Sub 'getPedido'

    For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
	    Where FilCod = &FilCod
	    Where PedCod = &PedCod
		&FilCodNom 		= FilCodNom
		&PedCliCodRaz 	= PedCliCodRaz
		&PesRaz			= PedCliRaz
		&PedVlrLiq 		= PedVlrLiq
		&PedVenCodRaz 	= PedVenCodRaz
		&PedSts 		= PedSts
		&PedDtaEms 		= PedDtaEms
		&LctCodNom 		= LctCodNom
		&LctNom			= LctNom
		&NovLctCod 		= LctCod
		&NovPedCliCod 	= PedCliCod
		&NovPedVenCod 	= PedVenCod
		&NovPedVenRaz 	= PedVenRaz
		&NovTabCod 		= TabCod
		&NovTabColCod 	= TabColCod
		&NovTabPrmCod 	= TabPrmCod
		&NovPedDtaEms = serverdate()
	    Exit
    EndFor

EndSub


]]></Source>
