	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'verificaProdutoCOmAnexo'

	For Each Order AnxCod
		Where AnxCod = &AnxCod
		&AnxDesc = AnxDesc
		Exit
	EndFor
		

	For Each ORder EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProAnxCod = &AnxCod
			tbProdutos.Visible = 1	
		Exit
	When None
		tbProdutos.Visible = 0
	EndFor

EndSub


