      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&PesHerCod = &parPesHerCod
	
	&sdtFilhos.FromJson(&WebSession.Get(&PESSOAFILHOS))
	For &sdtFilhosItem in &sdtFilhos
		If &sdtFilhosItem.PesHerCod = &PesHerCod	
			&PesHerNom = &sdtFilhosItem.PesHerNom
			&PesHerDtaNas = &sdtFilhosItem.PesHerDtaNas
			Exit
		Endif
		
		&UltPesHerCod = &sdtFilhosItem.PesHerCod
	EndFor
	&WebSession.Remove(&PESSOAFILHOS)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do case
		Case &PesHerNom.IsEmpty()
			msg('Nome do Filho obrigatório!')
			&PesHerNom.SetFocus()
		Case &PesHerDtaNas.IsEmpty()
			msg('Data Nascimento Obrigatório!')
			&PesHerDtaNas.SetFocus()
		Otherwise
			
			if &PesHerCod > 0
				For &sdtFilhosItem in &sdtFilhos
					If &sdtFilhosItem.PesHerCod = &PesHerCod	
						&sdtFilhosItem.PesHerNom = &PesHerNom
						&sdtFilhosItem.PesHerDtaNas = &PesHerDtaNas
						&sdtFilhosItem.PesHerSts = Status_SimNao.Sim
						Exit
					Endif
				EndFor
			Else
				&PesHerCod = &UltPesHerCod+1
				&sdtFilhosItem = new()
				&sdtFilhosItem.PesHerCod = &PesHerCod	
				&sdtFilhosItem.PesHerNom = &PesHerNom
				&sdtFilhosItem.PesHerDtaNas = &PesHerDtaNas
				&sdtFilhosItem.PesHerSts = Status_SimNao.Sim
				&sdtFilhos.Add(&sdtFilhosItem)
			Endif
						
			&WebSession.Set(&PESSOAFILHOS, &Sdtfilhos.ToJson())
			return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
