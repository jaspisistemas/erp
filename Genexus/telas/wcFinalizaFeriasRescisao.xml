      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&Pescod = &wwpContext.PesCod
	&Ano = year(Serverdate())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS170.Link(&EmpCod, 0, &wwpContext.FilCod, &FilCod, &FunCod, &Ano, &TipoPagamento)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FunCod.IsValid

	Do 'Funcionario'

EndEvent

Sub 'funcionario'

	If &FunCod = 0
		&FunNom = 'Todos os funcionários'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &FunCod
			&FunNom = PesRaz
			Exit
		When none
			&FunNom = 'Pessoa não encontada Verifique!'
			&FunCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
