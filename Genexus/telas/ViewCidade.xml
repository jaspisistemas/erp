      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)
	WorkWithLink.Link = WWCidade.Link()

	For each Cidade
		where EmpCod = &EmpCod and CidCod = &CidCod
		Form.Caption = CidNom.ToString()
		&Exists = True

	When none
		Form.Caption = "WWP_RecordNotFound"
		&Exists = False
	Endfor

	If (&Exists)
		&SelectedTabCode = &TabCode
		Tabs.ActivePageControlName = &SelectedTabCode
		Do 'LoadTabs'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Tabs.TabChanged

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&SelectedTabCode = Tabs.ActivePageControlName
	&LoadAllTabs = false
	Do 'LoadTabs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadTabs'

	For Each
		Where EmpCod = &EmpCod and CidCod = &CidCod
		&CidAreCod = CidAreCod
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For Each Cidade
		Where EmpCod = &EmpCod and CidCod = &CidCod
	If &LoadAllTabs OR &SelectedTabCode = '' OR &SelectedTabCode = !"General"
		GeneralWC.Object = CidadeGeneral.Create(&EmpCod, &CidCod)
	EndIf
		If CidAreCod <> 0
	If &LoadAllTabs OR &SelectedTabCode = !"wcVendedoresdaArea"
		wcVendedoresdaAreaWC.Object = wcVendedoresdaArea.Create(&CidAreCod)
	EndIf
		Else
			Tabs.HideTab(2)
		EndIf
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
