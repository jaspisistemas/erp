        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('VENDAFECHAESTOQUE', Status_SimNao.Sim, 1, &AutNiv)
	
	TextBlockTitle.Caption = 'Liberar Estoque, Pedido: ' + trim(Str(&PedCod))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&PedSts.Visible = False
	&PedStsCrd.Visible = False
	&LctAtuSal.Visible = False
	&LctAtuEst.Visible = False
	&LctGerFin.Visible = False
	&FilCodNom.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon009_FecharComEstoque, &TCon009_FecharComEstoque)
	
	padraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&LiberarEstoqueAjustarPedido = Substr(&PadObs, 1,1)
	if &LiberarEstoqueAjustarPedido.IsEmpty()
		&LiberarEstoqueAjustarPedido = 'S'
	EndIF

	Do 'CapaPedido'
	
	RetornaPercentualEstoquePedido.Call(&EmpCod, &FilCod, &PedCod, &PedVlrBrt, &ComEstPedVlrBrt, &SemEstPedVlrBrt, &ComEstTaxa)
	
	Do Case
		Case &ComEstTaxa <= 50
			&ComEstTaxa.ForeColor = RGB(250,30,0)
			
		Case &ComEstTaxa > 50 and &ComEstTaxa < 90
			&ComEstTaxa.ForeColor = RGB(200,150,0)
			
		Otherwise
			&ComEstTaxa.ForeColor = RGB(0,175,0)			
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'AttributesSecurityCode'
	
	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&EstQtd_Formatado = EstQtd
	if EstLoc.IsEmpty()
	&EstLoc = 'SEM_LOCACAO'
Else
	&EstLoc = EstLoc
EndiF
	&PedQtd = PedQtd

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	ProNomGra.Link = VerProduto.Link('DashBoard', EmpCod, ProCod)
	ProNomGra.LinkTarget = '_blank'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

