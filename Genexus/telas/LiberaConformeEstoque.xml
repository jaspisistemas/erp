EndEvent

Event 'DoAlterarPedido'

	If &DeOndeVem = 'WWPEDIDOVENDA'
		PedidoVendas.Link(TrnMode.Update, &EmpCod, &FilCod, &PedCod, 'PEDIDOVENDA')
	Else
		PedidoVendas.Link(TrnMode.Update, &EmpCod, &FilCod, &PedCod, 'PEDIDOFATURAMENTO')
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEmitirNFe'

	do 'CapaPedido'
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon010_LiberarCreditoPedido, &LiberaCreditoPedido)
	
	//if &ControleExpedicao = 'S' and PedStsExp <> 'L'
	// MSG('Pedido ainda Não Liberado para a Expedição!')
	&AutNiv = RetornaAutorizacao.UDP('VENDAFECHAESTOQUE', Status_SimNao.Nao, 1)
		
	If &AutNiv > 0
		&IsSemEstoque = false
		If &TCon009_FecharComEstoque = 'S' //FECHA PEDIDO SOMENTE COM ESTOQUE
			&IsSemEstoque = VerificaProdutoSemEstoque.Udp(&EmpCod, &FilCod, &PedCod)
		EndIf
		
		Do Case
			Case &TCon009_FecharComEstoque = 'S' and &IsSemEstoque = true
				msg('No pedido existe produtos que não possuem estoque suficiente! [TCon009_FecharComEstoque]')
				
			Case (&LiberaCreditoPedido = 'S' or &LiberaCreditoPedido = 'X') and (&PedStsCrd <> Status_Autorizado.AUTORIZADO and &LctGerFin = Status_SimNao.Sim)//Não Liberado Para Faturamento
				msg('Pedido não liberado para Faturamento! Falta Liberação do Crédito! [CONF23]')
				
			Case &LctAtuSal = Status_EntradaSaida.Nenhum
				msg('Pedido em Operação que não atualiza saldos, não permitido para fazer nota!')
				
			Case (&PedSts <> Status_Pedido.ABERTO) And (&PedSts <> Status_Pedido.SEPARANDO)
				msg('Somente pedidos com o status estoque "ABERTO" ou "SEPARANDO" pode fazer nota!')
				
			Otherwise				
				GravaNotaTemporariaVenda.Call(&EmpCod, &FilCod, &PedCod, '55')
				
				wpSelecionaProdutosNFe.Link(&Pgmname, &EmpCod, &FilCod, &PedCod)
				
		EndCase
	Else
		msg('Não Autorizado ao Nível de Fechar Estoque Pedido Venda. [VENDAFECHAESTOQUE]')
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLiberarEstoque'

	if &LiberarEstoqueAjustarPedido = 'S'
		DVelop_ConfirmPanel_BtnLiberarEstoque.ConfirmationText = 'Deseja Alterar o status desse pedido para SEPARAÇÃO, baixando assim seus produtos do Estoque?'
		DVelop_ConfirmPanel_BtnLiberarEstoque.Title = 'Alterar Status SEPARAÇÃO'
	Else
		DVelop_ConfirmPanel_BtnLiberarEstoque.ConfirmationText = 'Deseja Alterar o Pedido conforme as quantidades disponíveis em Estoque?'
		DVelop_ConfirmPanel_BtnLiberarEstoque.Title = 'Alterar Pedido conforme Quantidade Estoque'
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_BtnLiberarEstoque.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_BtnLiberarEstoque.Close

	If DVelop_ConfirmPanel_BtnLiberarEstoque.Result = !'Yes'
		&IsSemEstoque = false
		if &LiberarEstoqueAjustarPedido = 'S' and &TCon009_FecharComEstoque = 'S'
			&IsSemEstoque = VerificaProdutoSemEstoque.Udp(&EmpCod, &FilCod, &PedCod)
		Endif
	
	 	If &IsSemEstoque = true
			msg('No pedido existe produtos que não possuem estoque suficiente! [TCon009_FecharComEstoque]')
		Else
			//ajusta estoque
			LiberarEstoquePedido.Call(&EmpCod, &FilCod, &PedCod, &Context.PesCod, &LiberarEstoqueAjustarPedido)
			
			if &LiberarEstoqueAjustarPedido = 'S'
				msg('Pedido Alterado para SEPARANDO!')
			Else
				msg('Pedido Ajustado!')
			EndIF
			
			//do 'CapaPedido'
			Do 'AttributesSecurityCode'
			&PedSts = Status_Pedido.SEPARANDO
			do 'CheckSecurityForActions'
			
			&PadObs = &LiberarEstoqueAjustarPedido
			padraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
			
			wpimprimirPedidoVenda.Popup(&EmpCod, &FilCod, &PedCod)
			
		Endif
	
		if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Ask If DVelop_ConfirmPanel_BtnLiberarEstoque.Result = !'Yes'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Endif
	EndIF

EndEvent

Sub 'CheckSecurityForActions'

	BtnLiberarEstoque.Visible = true
	BtnImprimirPedido.Visible = true
	BtnImprimirFaltas.Visible = true
	BtnAlterarPedido.Visible = true
	BtnEmitirNFe.Visible = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (&PedSts = Status_pedido.ABERTO)
		BtnLiberarEstoque.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	&PedCliObs.Enabled = 0
	&PedObsEst.Enabled = 0
	&PedObsGer.Enabled = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &PedCliObs.IsEmpty())
		&PedCliObs.Visible = False
		PedCliObs_Cell.Class = !'Invisible'
	Else
		&PedCliObs.Visible = True
		PedCliObs_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (Not &PedObsGer.IsEmpty())
		&PedObsGer.Visible = False
		PedObsGer_Cell.Class = !'Invisible'
	Else
		&PedObsGer.Visible = True
		PedObsGer_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (Not &PedObsEst.IsEmpty())
		&PedObsEst.Visible = False
		PedObsEst_Cell.Class = !'Invisible'
	Else
		&PedObsEst.Visible = True
		PedObsEst_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	
	tbLiberar.Visible = (&PedSts = Status_pedido.ABERTO)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &EstLoc.Click

	locacaoproduto.Popup(true, ProCod)

EndEvent

Sub 'CapaPedido'

	For Each Order EmpCod, FilCod, PedCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		Where PedCod = &PedCod
		&FilCodNom = FilCodNom
		&PedCliCodRaz = PedCliCodRaz
		
		&PedCliObs = PedCliObsCli
		If &PedCliObs.IsEmpty()
			&PedCliObs.Visible = 0
		EndIF
		
		&PedObsEst = PedObsEst
		If PedObsEst.IsEmpty()
			&PedObsEst.Visible = 0
		EndIF
		
		&PedObsGer = PedObsGer
		If PedObsGer.IsEmpty()
			&PedObsGer.Visible = 0
		EndIF
		
		&PedStsCrd = PedStsCrd
		&PedSts = PedSts
		&LctGerFin  = LctGerFin
		
		&LctAtuSal = LctAtuSal
		Exit
	EndFOr

	Do 'AttributesSecurityCode'
	do 'CheckSecurityForActions'

EndSub


