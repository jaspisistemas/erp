      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&context)
	padraoUsuario.Call('L', &PadRotLin, &Context.PesCod, &Context.EmpCod, &PadOBs, &PadDtaMod)
	&sdtAtualizaPreco.FromJson(&PadObs)
	
	for Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		&TabUltAlt = TabUltAlt
		Exit
	EndFor
	if &TabUltAlt <= 0
		&TabUltAlt = 1
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtAtualizaPrecos.Rows = Page.Rows
	GridsdtAtualizaPrecosPaginationBar.RowsPerPageSelectedValue = GridsdtAtualizaPrecos.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtAtualizaPrecosCurrentPage = GridsdtAtualizaPrecos.CurrentPage
	&GridsdtAtualizaPrecosPageCount = GridsdtAtualizaPrecos.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtAtualizaPrecos.Load

	&ProCod = &sdtAtualizaPreco.CurrentItem.ProCod
	&PRoGraCod = &sdtAtualizaPreco.CurrentItem.ProGraCod
	&ProRef.SetEmpty()
	&ProNomGra.SetEmpty()
		
	Do 'GetCodigoNome'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtAtualizaPrecosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtAtualizaPrecosPaginationBar.SelectedPage = !'Previous'
			GridsdtAtualizaPrecos.PreviousPage()
		Case GridsdtAtualizaPrecosPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtAtualizaPrecos.CurrentPage
			&PageToGo += 1
			GridsdtAtualizaPrecos.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtAtualizaPrecosPaginationBar.SelectedPage)
			GridsdtAtualizaPrecos.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtAtualizaPrecosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtAtualizaPrecos.Rows = GridsdtAtualizaPrecosPaginationBar.RowsPerPageSelectedValue
	GridsdtAtualizaPrecos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For &sdtAtualizaPrecoItem in &sdtAtualizaPreco
		GravaProdutoNaTabela.Call(&EmpCod, &TabCod, &TabUltAlt, &sdtAtualizaPrecoItem.ProCod, &sdtAtualizaPrecoItem.ProGraCod, 'DEL', &TabProDtaIni, &TabProDtaFin, &TabPrc1, &TabPrc2, &TabPrc3, &TabPrc4, &TabPrc5, &TabPrc6,&TabPrc7,&TabPrc8,&TabPrc9, &Context.UserName)
	EndFor
	
	padraoUsuario.Call('G', &PadRotLin, &Context.PesCod, &Context.EmpCod, '', &PadDtaMod)
	Return

EndEvent

Sub 'GetCodigoNome'

	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &PRoGraCod
		&ProRef = ProGraRef
		&ProNomGra = ProNomGra
		Exit
	EndFor

EndSub


]]></Source>
