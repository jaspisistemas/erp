        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPRASTREAMENTOCONFERE', Status_SimNao.Sim, 1, &AutNiv)
	
	RCOOpen.Visible = 0
	LoadWWPContext.Call(&Context)
	
	&finRasDtaEms = serverdate()
	&finRasDtaEnc = &finRasDtaEms
	
	&Ordem = 'B'
//	&iniRasDtaEms = &finRasDtaEms - 90
	&iniRasDtaEnc = &finRasDtaEms - 90
	&Agrupar = false

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS075.Link(&Context.EmpCod, &Context.FilCod, &RasPedVenCod,&RasPedCliCod,&iniRasDtaEms, &finRasDtaEms, &iniRasDtaEnc, &finRasDtaEnc, &Ordem, &Agrupar)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	
	&Random = Random() * 10000000000
	&ProgressId = 'wpRastConf' + trim(Str(&Random))
	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	EsperaSegundos.Submit('', &ProgressId)

EndEvent

Event scaProgressBar1.OnComplete

	ApagaProgress.Submit('', &ProgressId)
	Return

EndEvent


]]></Source>
