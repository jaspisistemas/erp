      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&SdtPagamentoDuplicata.FromXml(&WebSession.Get('AnuenciaDP'))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount

EndEvent

Event Grid.Load

		For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
			
			&CreCod = &SdtPagamentoDuplicataItem.CreCod
			&CreDupNro = &SdtPagamentoDuplicataItem.CreDupNro
			&CreDtaEms = &SdtPagamentoDuplicataItem.CreDtaEms
			&CreEnvSpc = &SdtPagamentoDuplicataItem.CreEnvSpc
			&CreVlrDup = &SdtPagamentoDuplicataItem.CreVlrPgt
			&CreDtaPrt = &SdtPagamentoDuplicataItem.CreDtaPrt
			&CreDtaCrt = &SdtPagamentoDuplicataItem.CreEnvSpc

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			Load
		EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
		&auxCreCod = &SdtPagamentoDuplicataItem.CreCod
		&auxEmpCod = &SdtPagamentoDuplicataItem.EmpCod
		&auxFilCod = &SdtPagamentoDuplicataItem.FilCod
		&CreCobObs = 'CARTA DE ANUÊNCIA GERADA'
		&CreMetCod = 1
		&CreResCob = 1
	 GravaCobranca.call(&auxEmpCod,&auxFilCod,&auxCreCod,&CreCobObs,&CreMetCod,&CreResCob,&CrePrmPag, &CrePrmPagHor, TipoObservacaoDuplicata.INTERNA)
	EndFor
	RCOOpenWindow1.LinkOpen = RELJAS062.link(&EmpCod,&context.FilCod,&FilCod,&TipoImpressao)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


]]></Source>
