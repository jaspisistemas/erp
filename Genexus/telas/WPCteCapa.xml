Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	Tbmsg.Height = 40

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WPCte(!'Capa', !'Geral', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUpload'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Upload_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Upload_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = WPCteImport.Create(&EmpCod, &FilCod, &Tipo)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Upload_Modal.Close

	Do Case
		Case Upload_Modal.Result = 'OK'
			WPCte(!'Capa', !'Geral', false)
		Case Upload_Modal.Result = 'xls'
			wwCTe.Call()
		Otherwise

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

