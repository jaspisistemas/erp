      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	AtualizaWidgetsPessoa.Call(&Context.EmpCod, &UsuarioPesCod)
//	&img3.FromImage(WD_AGENDA)
//	&img4.FromImage(WD_AGENDA)
	&WidIsSel.Enabled = 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 700
	TableContent.Width = 700
	Grid.Rows = 30

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For Each Order EmpCod, WidPesCod, (WidIsSel), WidOrdUsr
	Where EmpCod = &Context.EmpCod
	Where WidPesCod = &UsuarioPesCod
	
	RetornaAutorizacao.Call(WidSync, Status_SimNao.Nao, 1, &AutNiv)
	if &AutNiv > 0 or WidSync = 'WD_MENSAGENS'
		
		&WidIsSel = WidIsSel
		&WidNom = WidNom
		&WidSync = WidSync

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionSelecione.FromImage(DDOMultiselOption)
	&ActionSelecione.TooltipText = ""
	
	&Subir = !'<i class="fa fa-arrow-up"></i>'
	
	&Descer = !'<i class="fa fa-arrow-down"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		if WidIsSel = true
			&ActionSelecione.FromImage(DDOMultiselSelOption)
		Endif
		
		&ActionSelecione.Enabled = 1
		if WidSync = 'WD_MENSAGENS'
			&ActionSelecione.Enabled = 0
		Endif
	
		Load
	EndIF

	EndFor

EndEvent

Event &ActionSelecione.Click

	if &WidIsSel = true
		&WidIsSel = false
	Else
		&WidIsSel = true
	Endif
	prcGravaWidget.Call(&Context.EmpCod, &UsuarioPesCod, &WidSync, &WidIsSel)
	
	Refresh

EndEvent

Event &Subir.Click

	OrdenarWidget.Call('SUBIR', &Context.EmpCod, &UsuarioPesCod, &Context.UserName, &WidSync)
	Refresh

EndEvent

Event &Descer.Click

	OrdenarWidget.Call('DESCER', &Context.EmpCod, &UsuarioPesCod, &Context.UserName, &WidSync)
	Refresh

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)

EndEvent


]]></Source>
