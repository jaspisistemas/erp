      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&PedDtaEms_to = serverdate()
	&IsApagarDuplicatas = true
	&IsApagarPedidos = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PEsCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &PEsCod, &PesRaz)

EndEvent

Event Enter

	If &IsApagarDuplicatas = true or &IsApagarPedidos = true
		msg('Aguarde...')
		BtnEnter.Visible = 0
		&ProgressId = 'Apaga' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		ApagaCAncelados.Submit('ApagaCAncelados', &ProgressId, &Context.EmpCod, &Context.FilCod, &IsApagarDuplicatas, &IsApagarPedidos, &PedDtaEms, &PedDtaEms_to, &PEsCod)
	Else
		msg('Selecione pelo menos alguma coisa para apagar!')
	EndIF

EndEvent

Event scaProgressBar1.OnComplete

	BtnEnter.Visible = 1
	For Each Order ProgressId
		Where ProgressId = &ProgressId
		msg(ProgressLogXml)
		Exit
	EndFor

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)

EndEvent


]]></Source>
