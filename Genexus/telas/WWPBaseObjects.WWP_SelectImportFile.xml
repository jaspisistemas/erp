      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUCancel'

	msg(!'<#CLEAR#>')
	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&FilterToUploadExt = &FilterToUpload.FileName
	&FilterToUploadExt = iif(&FilterToUploadExt.IndexOf(!'.') > 0, &FilterToUploadExt.Substring(&FilterToUploadExt.LastIndexOf(!".") + 1, &FilterToUploadExt.Length() - &FilterToUploadExt.LastIndexOf(!".")),'')
	&BlobId = &FilterToUpload.ToString()
	&BlobRef = &BlobId.Replace(!"gxupload:", "")
	&Cache = Cache.GetCache(!"FL")
	&BlobData.FromJson(&Cache.Get(&BlobRef))
	&BlobPath = &BlobData.Path
	msg(!'<#CLEAR#>')
	If not &FilterToUpload.IsEmpty()
		If (&FilterToUploadExt.ToUpper() = !'CSV' and &ImportType = !'CSV') OR (&FilterToUploadExt.ToUpper() = !'XLSX' and &ImportType = !'Excel')
			&ResultMsg = ''
			If WWPBaseObjects.WWP_ImportData(&TransactionName, &ImportType, &BlobPath, &ExtraParmsJson, &ErrorMsgs)
				&LastErrorType = MessageTypes.Info
				For &Message in &ErrorMsgs
					If not &ResultMsg.IsEmpty()
						&ResultMsg += newline()
						If &LastErrorType = MessageTypes.Warning AND &Message.Type = MessageTypes.Info
							&ResultMsg += newline()
						EndIf
					EndIf
					&LastErrorType = &Message.Type
					&ResultMsg += &Message.Description
				EndFor
				msg(DVMessageGetBasicNotificationMsg('WWP_ImportFile_ImportSuccessTitle', &ResultMsg, DVMessageType.success, '', DVMessageBoolean.NoSpecify, ''))
        WWPActions.WCPopup_Close(&ResultMsg)
			Else
				&FilterToUpload.SetEmpty()
				For &Message in &ErrorMsgs
					If not &ResultMsg.IsEmpty()
						&ResultMsg += newline()
						If &Message.Id = !'WWP_LineId'
							&ResultMsg += newline()
						EndIf
					EndIf
					&ResultMsg += &Message.Description
				EndFor
				msg(DVMessageGetBasicNotificationMsg('WWP_ImportFile_ErrorImportingTitle', &ResultMsg, DVMessageType.error, '', DVMessageBoolean.False, ''))
			EndIf
		Else
			&FilterToUpload.SetEmpty()
			&ResultMsg = format('WWP_ImportFile_ExpectedFileType', iif(&ImportType = !'CSV', !'csv', !'xlsx'))
			msg(DVMessageGetBasicNotificationMsg('WWP_ImportFile_ErrorImportingTitle', &ResultMsg, DVMessageType.error, '', DVMessageBoolean.NoSpecify, ''))
		Endif
	Else
		msg(Format('WWP_RequiredAttribute', 'File'))
	EndIf

EndEvent


]]></Source>
