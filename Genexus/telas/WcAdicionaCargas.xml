      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable6.Width = 207
	UnnamedTable5.Width = 207
	UnnamedTable4.Width = 207
	UnnamedTable3.Width = 300
	UnnamedTable1.Width = 300
	UnnamedTable11.Width = 255
	UnnamedTable10.Width = 100
	UnnamedTable13.Width = 255
	UnnamedTable12.Width = 100
	UnnamedTable7.Width = 400
	UnnamedTable14.Width = 100

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//Carrega as informações e habilita os campo
	
	&UfeCod 	= 'AC'
	&Estado 	= 1
	&ViaCarCidCodOri.Clear()
	Do 'CarregaCidades'
	
	&UfeCod 	= 'AC'
	&Estado 	= 2
	&ViaCarCidCodDst.Clear()
	Do 'CarregaCidades'
	
	Do 'CarregaCarga'
	Do 'HabilitaCampos'

EndEvent

Event 'DoFechar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ViaCarTip.ControlValueChanged

	Do 'HabilitaCampos'

EndEvent

Event &ViaCarCteDstCod.IsValid

	If Not &ViaCarCteDstCod.IsEmpty()
		Do 'ProcuraPessoa'
	EndIf

EndEvent

Event &ViaCarCteChv.IsValid

	If Not &ViaCarCteChv.IsEmpty() Or Not &CteCod.IsEmpty()
		Do 'BuscaCTE'
		
		Do 'VerificaCte'
		If &IsAuthorized = False
			If &AuxViaCod = &ViaCod
				Msg('Este CT-e já está vinculado a carga: '+ Trim(Str(&AuxViaCarCod)) + ' desta viagem.')
			Else
				Msg('Este CT-e já está vinculado a carga: '+ Trim(Str(&AuxViaCarCod)) + ' da Viagem: ' + Trim(Str(&AuxViaCod)) + '.')
			EndIf
		EndIf
	
	EndIf

EndEvent

Event &ViaCarUfeOri.ControlValueChanged

	&UfeCod 	= &ViaCarUfeOri
	&Estado 	= 1
	&ViaCarCidCodOri.Clear()
	Do 'CarregaCidades'

EndEvent

Event &ViaCarUfeDst.ControlValueChanged

	&UfeCod 	= &ViaCarUfeDst
	&Estado 	= 2
	&ViaCarCidCodDst.Clear()
	Do 'CarregaCidades'

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	If 	&CheckRequiredFieldsResult = True And &IsAuthorized = True
		prcMovimentaCargaViagem.Call('INS', &EmpCod, &FilCod, &ViaCod, 0, &ViaCarTip, &ViaCarCteChv, &ViaCarProPre, &ViaCarCteVol, &ViaCarCteQtd, &ViaCarCteTotPes, &ViaCarUfeOri, &ViaCarCidCodOri, &ViaCarCteTomSer,&ViaCarCteDstCod, &ViaCarUfeDst, &ViaCarCidCodDst, '', &ViaCarVlrFreBrt, &ViaCarVlrFreLiq)
		WWPActions.WCPopup_Close('Ok')
	EndIf

EndEvent

Sub 'CheckRequiredFields'

	//Verifica se não há erros
	&CheckRequiredFieldsResult = True
	Do Case
		Case &ViaCarTip = 'C'
			If &ViaCarCteChv.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','A chave do CT-e'))
				&CheckRequiredFieldsResult = False
			EndIf
			
		Case &ViaCarTip = 'M'
			If &ViaCarCteDstCod.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','O destinatário'))
				&CheckRequiredFieldsResult = False
			EndIf
		
			If &ViaCarUfeDst.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','A UF'))
				&CheckRequiredFieldsResult = False
			EndIf
			
			If &ViaCarCidCodDst.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','A cidade'))
				&CheckRequiredFieldsResult = False
			EndIf
		
			If &ViaCarProPre.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','Uma descrição para o produto'))
				&CheckRequiredFieldsResult = False
			EndIf
	EndCase

EndSub

Sub 'CarregaCidades'

	//Carrega as cidades com base na uf e código IBGE
	For each Order EmpCod, UfeCod
		Where EmpCod 	= &EmpCod
		Where UfeCod 	= &UfeCod
		
		Do Case
			Case &Estado = 1	//Cidade de Origem
				&ViaCarCidCodOri.AddItem(CidIBGE, CidNom)
			Case &Estado = 2	//Cidade de Destino
				&ViaCarCidCodDst.AddItem(CidIBGE, CidNom)
		EndCase
	EndFor

EndSub

Sub 'VerificaCte'

	//Verifica se o CT-e já está sendo usado em outra Viagem
	For Each Order EmpCod, FilCod, ViaCod, ViaCarCod
		Where EmpCod 		= &EmpCod
		Where FilCod 		= &FilCod
		Where ViaCarCteChv	= &ViaCarCteChv
		Where ViaCarSts		<> 'C'
		
		&IsAuthorized = False
		&AuxViaCod 	  = ViaCod
		&AuxViaCarCod = ViaCarCod
		
		Exit
		
	When None
		
		&IsAuthorized = True
		
	EndFor

EndSub

Sub 'BuscaCTE'

	//Busca as informações do CT-e
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteChv = &ViaCarCteChv 	When Not 	&ViaCarCteChv.IsEmpty()
		Where CteCod = &CteCod 			When 		&ViaCarCteChv.IsEmpty()
		
		If &ViaCarCteChv.IsEmpty()
			&ViaCarCteChv 	= CteChv
		EndIf
		
		&ViaCarCteDstCod 	= CteRemCod
		&ViaCarCteTomSer	= CteTomSer
		
		&ViaCarUfeOri		= CteIniUfe
		&UfeCod				= CteIniUfe
		&Estado 			= 1
		&ViaCarCidCodOri.Clear()
		Do 'CarregaCidades'
		&ViaCarCidCodOri	= CteIniCidCod

		&ViaCarUfeDst		= CteDesUfe
		&UfeCod				= CteDesUfe
		&Estado 			= 2
		&ViaCarCidCodDst.Clear()
		Do 'CarregaCidades'
		&ViaCarCidCodDst	= CteDesCidCod
		
		&ViaCarVlrFreLiq 	= CteVlrRecSer
		&ViaCarVlrFreBrt	= CteVlrTotPreSer
		
		&ViaCarProPre		= CteCarProPre
		For each order EmpCod, FilCod, CteCod, CteCarCod
			If CteCarUnd = UnidadeMedidaCte.UNIDADE AND CteCarTip = 'UNIDADE'
				&ViaCarCteQtd = CteCarQtd
			EndIf			
			
			If CteCarUnd = UnidadeMedidaCte.M3 and CteCarTip = 'METROS CUBICOS'
				&ViaCarCteVol = CteCarQtd
			EndIf
			
			If CteCarUnd = UnidadeMedidaCte.KG and CteCarTip = 'PESO BRUTO'
				&ViaCarCteTotPes = CteCarQtd
			EndIf
			
			If CteCarUnd = UnidadeMedidaCte.KG and CteCarTip = 'PESO LIQUIDO'
				&ViaCarCteTotPes = CteCarQtd
			EndIf
		EndFor

		If Not &ViaCarCteDstCod.IsEmpty()
			Do 'ProcuraPessoa'
		EndIf
	
		TbDadosGerais.Visible 	= 1
		tbCarga.Visible			= 1
		
		Exit
		
	When None
		
		Msg('CT-e não econtrado/Transmitido.')
		
	EndFor

EndSub

Sub 'CarregaCarga'

	//Carrega as informações da carga
	For Each Order EmpCod, FilCod, ViaCod, ViaCarCod
		Where EmpCod 	= &EmpCod	//empresa
		Where FilCod 	= &FilCod	//filial
		Where ViaCod 	= &ViaCod	//viagem
		Where ViaCarCod = &ViaCarCod//Carga
		
		&ViaCarTip			= ViaCarTip	//Tipo do Preenchimento
		
		&ViaCarCteChv 		= ViaCarCteChv	//Chave do CT-e
		
		
		&ViaCarUfeOri		= ViaCarUfeOri
		&UfeCod				= ViaCarUfeOri
		&Estado 			= 1
		&ViaCarCidCodOri.Clear()
		Do 'CarregaCidades'
		&ViaCarCidCodOri	= ViaCarCidCodOri

		
		&ViaCarUfeDst		= ViaCarUfeDst
		&UfeCod				= ViaCarUfeDst
		&Estado 			= 2
		&ViaCarCidCodDst.Clear()
		Do 'CarregaCidades'
		&ViaCarCidCodDst	= ViaCarCidCodDst
		&ViaCarCteDstCod 	= ViaCarCteDstCod	//Código do Destinatário		
		
		&ViaCarCteTomSer	= ViaCarCteTomSer	//Tipo do Tomador
		
		&ViaCarProPre		= ViaCarProPre	//Produto predominante
		&ViaCarCteQtd		= ViaCarCteQtd	//Quantidade deste produto
		&ViaCarCteVol		= ViaCarCteVol	//Quantidade em M³ do produto
		&ViaCarCteTotPes	= ViaCarCteTotPes	//Quantidade em KG do produto
		
		&ViaCarVlrFreBrt	= ViaCarVlrFreBrt
		&ViaCarVlrFreLiq	= ViaCarVlrFreLiq
		
		If Not &ViaCarCteDstCod.IsEmpty()
			Do 'ProcuraPessoa'
		EndIf
		
		TbDadosGerais.Visible 	= 1
		tbCarga.Visible			= 1
		
	When None
		
		TbDadosGerais.Visible 	= 0
		tbCarga.Visible			= 0
		
	EndFor

EndSub

Sub 'HabilitaCampos'

	Do Case 
		Case &ViaCarCod.IsEmpty() Or &ViaCarCod = 0
			If &ViaCarTip = 'C'
				&ViaCarCteDstCod.Enabled 	= 0
				&ViaCarUfeDst.Enabled 		= 0
				&ViaCarProPre.Enabled		= 0
				&ViaCarCteQtd.Enabled		= 0
				&ViaCarCteVol.Enabled		= 0
				&ViaCarCteTotPes.Enabled	= 0
				&ViaCarVlrFreBrt.Enabled	= 0
				&ViaCarVlrFreLiq.Enabled	= 0
				&ViaCarUfeOri.Enabled		= 0
				&ViaCarCidCodOri.Enabled	= 0
				&ViaCarCidCodDst.Enabled	= 0
				tbCte.Visible				= 1
				TbDadosGerais.Visible 		= 0
				tbCarga.Visible				= 0
			Else
				&ViaCarCteDstCod.Enabled 	= 1
				&ViaCarUfeDst.Enabled 		= 1
				&ViaCarCidCodDst.Enabled	= 1
				&ViaCarProPre.Enabled		= 1
				&ViaCarCteQtd.Enabled		= 1
				&ViaCarCteVol.Enabled		= 1
				&ViaCarCteTotPes.Enabled	= 1
				&ViaCarCidCodOri.Enabled	= 1
				&ViaCarUfeOri.Enabled		= 1
				&ViaCarVlrFreBrt.Enabled	= 1
				&ViaCarVlrFreLiq.Enabled	= 1
				&ViaCarCteChv.SetEmpty()
				tbCte.Visible				= 0
				TbDadosGerais.Visible 		= 1
				tbCarga.Visible				= 1
				
			EndIf
			
		OtherWise
			
			&ViaCarCteDstCod.Enabled 	= 0
			&ViaCarUfeDst.Enabled 		= 0
			&ViaCarCidCodDst.Enabled	= 0
			&ViaCarProPre.Enabled		= 0
			&ViaCarCteQtd.Enabled		= 0
			&ViaCarCteVol.Enabled		= 0
			&ViaCarCteTotPes.Enabled	= 0
			&ViaCarCteChv.Enabled		= 0
			&ViaCarCidCodOri.Enabled	= 0
			&ViaCarVlrFreBrt.Enabled	= 0
			&ViaCarVlrFreLiq.Enabled	= 0
			&ViaCarUfeOri.Enabled		= 0
			&ViaCarTip.Enabled			= 0
			BtnEnter.Visible			= 0
			&ViaCarCteChv.Caption		= 'Chave da CT-e informada:'
			
	EndCase

EndSub

Sub 'ProcuraPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &ViaCarCteDstCod
		
		&PesRaz = PesRaz
		
		Exit
	EndFor

EndSub


