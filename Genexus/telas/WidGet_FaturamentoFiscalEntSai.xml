      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	&PesCod = &Context.PesCod
	&EmpCod = &ParmEmpCod
	&FilCod = &ParmFilCod
	
	&Month = Month(&Today)
	&NfeDtaFat_Ano = Year(&Today)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableChart2.Height = 427

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//ANALISAR A HORA DE ALTERACAO PARA PODER ATUALIZAR, E TAMBEM FILIAL LOGADA.
	&AuxPadDtaHorMod  = now()
	&AuxPadDtaHorMod  = &AuxPadDtaHorMod.AddMinutes(-10)
	&PadPesCod = (&Context.PesCod*100) + (&FilCod*3) + &NfeDtaFat_Ano
	
	padraoUsuarioHora.Call('L', '#WidGet_FaturamentoFiscalEntSai#', &PadPesCod, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'T')
	if &PadDtaHorMod < &AuxPadDtaHorMod or &PadObs.IsEmpty()
		prcTotalFaturadoNotasWidgets.Call(&EmpCod, &FilCod, &PadPesCod, &NfeDtaFat_Ano, &PadDtaHorMod, &sdtNotasFiscais)
	Endif
	
	do 'CarregaSDT'

EndEvent

Event &NfeDtaFat_Ano.ControlValueChanged

	&PadPesCod = (&Context.PesCod*100) + (&FilCod*3) + &NfeDtaFat_Ano
	prcTotalFaturadoNotasWidgets.Call(&EmpCod, &FilCod, &PadPesCod, &NfeDtaFat_Ano, &PadDtaHorMod, &sdtNotasFiscais)
	do 'CarregaSDT'

EndEvent

Event &FilCod.ControlValueChanged

	&PadPesCod = (&Context.PesCod*100) + (&FilCod*3) + &NfeDtaFat_Ano
	prcTotalFaturadoNotasWidgets.Call(&EmpCod, &FilCod,&PadPesCod, &NfeDtaFat_Ano, &PadDtaHorMod, &sdtNotasFiscais)
	do 'CarregaSDT'

EndEvent

Sub 'CarregaSDT'

	txtAtualizado.Caption = 'Atualizado: ' + trim(toformattedString(&PadDtaHorMod))
	
	&Parameters = New()
	// Numeric parameter
	&Parameter = New()
	&Parameter.Name = "EmpCod"
	&Parameter.Value = &EmpCod.ToString().Trim() 				// Or &Parameter.Value = &NumericVariable.ToString().Trim()
	&Parameters.Add(&Parameter)
	
	&Parameter = New()
	&Parameter.Name = "PadPesCod"
	&Parameter.Value = &PadPesCod.ToString().Trim() 				// Or &Parameter.Value = &NumericVariable.ToString().Trim()
	&Parameters.Add(&Parameter)
	
	// Numeric parameter
	&Parameter = New()
	&Parameter.Name = "FilCod"
	&Parameter.Value = &FilCod.ToString().Trim() 				// Or &Parameter.Value = &NumericVariable.ToString().Trim()
	&Parameters.Add(&Parameter)
	
	// Character parameter
	&Parameter = New()
	&Parameter.Name = "NfeDtaFat_Ano"
	&Parameter.Value = &NfeDtaFat_Ano.ToString().Trim()		// Or &Parameter.Value = &CharacterVariable
	&Parameters.Add(&Parameter)
	
	Grafico.ObjectName = 'dpGetTotalFaturadoMes'

EndSub


]]></Source>
