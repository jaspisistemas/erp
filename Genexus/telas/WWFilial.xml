      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&CertificadoDigital.Title = 'Cert.'
	RetornaAutorizacao.Call('WWFILIAL', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Form.Caption = ' Cadastro de Filiais'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaEmpresaModulo.Call(&Context.EmpCod, ModuloSistema.COOPERCU, &PossuiModuloCOOPERCU)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Delete = !'<i class="fa fa-times"></i>'
	If (&AutNiv > 2)
		&Delete.Link = Filial.Link(TrnMode.Delete, EmpCod, FilCod)
		&Delete.Class = !'Attribute'
	Else
		&Delete.Link = ""
		&Delete.Class = !'Invisible'
	Endif
	&Update = !'<i class="fa fa-pen"></i>'
	If (&AutNiv > 1)
		&Update.Link = Filial.Link(TrnMode.Update, EmpCod, FilCod)
		&Update.Class = !'Attribute'
	Else
		&Update.Link = ""
		&Update.Class = !'Invisible'
	Endif
	&groupad.Clear()
	&groupad.AddItem(0, 'WWP_ActionGroupCaption')
	&groupad.AddItem(1, 'Imagem Filial')
	If (&PossuiModuloCOOPERCU = 'S')
		&groupad.AddItem(2, 'Associados')
	Endif
	&groupad.AddItem(3, 'SPED Icms Proprio')
	&groupad.AddItem(4, 'Imoveis')
	
	&CertificadoDigital = !'<i class="fa fa-certificate"></i>'
	
	FilCidNom.Link = ViewCidade.Link(EmpCod, FilCidCod, '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &groupad.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &groupad = 1
			Do 'Do addimagem'
		Case &groupad = 2
			Do 'Do Associados'
		Case &groupad = 3
			Do 'Do IcmsProprio'
		Case &groupad = 4
			Do 'Do cadimoveis'
	EndCase
	&groupad = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Filial.Call(TrnMode.Insert, nullvalue(EmpCod), nullvalue(FilCod))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do addimagem'

	imagemFilial.Link(EmpCod, FilCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do Associados'

	wwAssociacao.Call(EmpCod, 0, FilCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do IcmsProprio'

	wwSpedEFDE110.Popup()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do cadimoveis'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWImoveis.Call(EmpCod, FilCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"FILCOD"
				&FilCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"FILRAZ"
				&FilRaz.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"FILCOD", "", not &FilCod.IsEmpty(), 0, &FilCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"FILRAZ", "", not &FilRaz.IsEmpty(), 0, &FilRaz, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"Filial"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &CertificadoDigital.Click

	wpCertificadoFilial.Popup(EmpCod, FilCod)

EndEvent


]]></Source>
