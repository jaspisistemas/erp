        <Source><![CDATA[
Event Start

	txtfinaliza.Caption = 'Foi finalizado a digitação da receita '+trim(str(&RctNum))+' ?'
	Do 'ValidaReceita'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoTerminado'

	Do Case
		Case &Itens > 5
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", "Não é permitido mais que 5 produtosna receita verifique!" ,DVMessageType.success, "", DVMessageBoolean.True,"") )
		Otherwise
			GravaStatusReceita.call(&empCod,&RctCod,Status_Receituario.Finalizado)
			Return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'ValidaReceita'

	&Itens = 0
	For Each Order EmpCod,RctCod,RctCodItm 
		Where EmpCod = &EmpCod
		Where RctCod = &RctCod
		&Itens+=1
	EndFor

EndSub


]]></Source>
