        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	Tb_Data.Visible = 0
	&OqueFazer = 'TODOS'
	Do 'LoadDuplicatas'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&Random = serverTime()	
	
	If &sdtGerarBoleto.Count > 0
		GerarBoleto.Call(&sdtGerarBoleto, true, &IsErro, &newSdtBoleto)		
		If &IsErro = false
			RCOOpenWindow1.LinkOpen = RELJAS045.Link(&EmpCod, &FilCod, &Random)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		EndIF
	Endif
		
	Do 'ChamaImpressao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbus.Visible = (1=2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &OqueFazer.IsValid

	if &OqueFazer = 'P'
		Tb_Data.Visible = 1
	else
		Tb_Data.Visible = 0
	EndIf

EndEvent

Sub 'ChamaImpressao'

//teste

EndSub

Sub 'loadDuplicatas'

	&IsErro = true
	&sdtGerarBoleto.Clear()
	&sdtGerarDuplicata.Clear()
	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreSerItmCod = &SerItmCod
		Where CreCbrImp in (TipoImpressao.GerarBoleto, TipoImpressao.ImprimirDuplicata, TipoImpressao.ImprimirBoleto)
		Where CreRecPag = ReceberPagar.Receber
		
		Do Case
			Case CreCbrImp = TipoImpressao.GerarBoleto and (CreFrpPgtoTip = TipoDuplicata.DUPLICATA )
				&sdtGerarBoletoItem = new()
				&sdtGerarBoletoItem.CreCod = CreCod
				&sdtGerarBoletoItem.CreEmpCod = EmpCod
				&sdtGerarBoletoItem.CreFilCod = FilCod
				&sdtGerarBoleto.Add(&sdtGerarBoletoItem)
				
			Case (CreCbrImp = TipoImpressao.ImprimirBoleto and CreBloNro <> '') and CreFrpPgtoTip = TipoDuplicata.DUPLICATA
				&sdtGerarBoletoItem = new()
				&sdtGerarBoletoItem.CreCod = CreCod
				&sdtGerarBoletoItem.CreEmpCod = EmpCod
				&sdtGerarBoletoItem.CreFilCod = FilCod
				&sdtGerarBoleto.Add(&sdtGerarBoletoItem)
				
			Case CreCbrImp = TipoImpressao.ImprimirDuplicata and (CreFrpPgtoTip = TipoDuplicata.DUPLICATA or CreVlrSdo > 0)
				&sdtGerarDuplicataItem = new()
				&sdtGerarDuplicataItem.CreCod = CreCod
				&sdtGerarDuplicataItem.EmpCod = EmpCod
				&sdtGerarDuplicataItem.FilCod = FilCod
				&sdtGerarDuplicata.Add(&sdtGerarDuplicataItem)
				
			case CreCbrImp = TipoImpressao.ImprimirDuplicata and CreFrpPgtoTip = TipoDuplicata.DINHEIRO
				
		EndCase
	EndFor

	//Contagem de boletos gerados - inutilizado	
	/*txtBoleto.Caption = trim(str(&sdtGerarBoleto.Count)) + ' - Boletos Gerados.' 
	txtduplicata.Caption = trim(str(&sdtGerarDuplicata.Count)) + ' - Duplicatas Geradas.'*/

EndSub


]]></Source>
