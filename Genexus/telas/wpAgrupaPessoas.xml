      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPAGRUPAPESSOAS', Status_SimNao.Sim, 4, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	do 'LocalizaPessoaOrigem'
	do 'LocalizaPessoaDestino'

	Do Case
		Case &IsOriExiste = false
			&OriPesCod.SetFocus()
		Case &IsDstExiste = false
			&DstPesCod.SetFocus()
		Otherwise
			DVelop_ConfirmPanel_Confirmar.ConfirmationText = 'ATENÇÃO!!! Você Realmente quer transferir todos os Cadastros e Referencias da Pessoa Origem: ' + trim(str(&OriPesCod)) + ' - ' + trim(&OriPesRaz) + ' para a Pessoa Destino: ' + trim(str(&DstPesCod)) + ' - ' + trim(&DstPesRaz) + ' e ELIMINAR o cadastro da Pessoa Origem: ' + trim(str(&OriPesCod))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	&Random = Random() * 10000000000
	&ProgressId = 'agrPess' + trim(Str(&Random))
	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	AgrupaPessoas.Submit('', &ProgressId, &EmpCod, &OriPesCod, &DstPesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		where ProgressId = &ProgressId
		msg(ProgressLogXml)
		Exit
	EndFor

EndEvent

Event &OriPesCod.IsValid

	do 'LocalizaPessoaOrigem'

EndEvent

Event &DstPesCod.IsValid

	do 'LocalizaPessoaDestino'

EndEvent

Sub 'LocalizaPessoaOrigem'

	&IsOriExiste = false
	For Each Order EmpCod PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &OriPesCod
		
		&OriPesRaz = PesRaz
		&OriPesIsCli = PesIsCli
		&OriPesIsFor = PesIsFor
		&OriPesIsFun = PesIsFun
		&OriPesIsTra = PesIsTra
		&OriPesIsVen = PesIsVen
		
		&IsOriExiste = true
		Exit
	When none
		&OriPesRaz = 'PESSOA NÃO ENCONTRADA'
	EndFor

EndSub

Sub 'LocalizaPessoaDestino'

	&IsDstExiste = false
	For Each Order EmpCod PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &DstPesCod
		
		&DstPesRaz = PesRaz
		&DstPesIsCli = PesIsCli
		&DstPesIsFor = PesIsFor
		&DstPesIsFun = PesIsFun
		&DstPesIsTra = PesIsTra
		&DstPesIsVen = PesIsVen
		
		&IsDstExiste = true
		Exit
	When none
		&DstPesRaz = 'PESSOA NÃO ENCONTRADA'
	EndFor

EndSub


]]></Source>
