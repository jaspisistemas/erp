      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	EmbPage1.Height = 300
	EmbPage1.width = 700
	com.ForeColor  = RGB(0,160,40)
	com1.ForeColor = RGB(0,160,40)
	loadWWPContext.Call(&Context)
	
	&ProgressId = 'ProgressoCCe' + trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&Context.PesCod)) + trim(Str(&NfeCod)) + trim(Str(&NfeCceCod))
	
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	RecepcaoNFe.Submit('ProgressoCCe', &ProgressId, &EmpCod, &FilCod, &NfeCceCod, &SolCod)

	

	EmbPage1.Visible = 0
	btnBtn1.Visible = 0
	btnBtn2.Visible = 0
	btnBtn3.Visible = 0
	btnBtn5.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn1'

	if &DeOndeVem.IsEmpty()
		wpCartasCorrecao.Link(&EmpCod, &FilCod, &NfeCod)
	Else
		&link = &DeOndeVem.Trim()+'.aspx'
		link(&link)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn2'

	wwNotas.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn4'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpGeraEtiquetaVolume.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn3'

	For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeCCeCod = &NfeCceCod
		
		If not NfeCCeArqXml.IsEmpty() and NfeCCeSts = Status_NFe.Autorizada
			GerapdfCCe.Call(EmpCod, FilCod, NfeCod, NfeCCeCod, &UrlPDF, &UrlFisico)
		EndIF
	EndFor

	If not &UrlPDF.IsEmpty()
		RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn5'

	wpEnviaCce.Popup(&EmpCod, &FilCod, &NfeCod, &NfeCceCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		msg(ProgressLogXml)
		
		btnBtn1.Visible = 1
		btnBtn2.Visible = 1	
		do 'imprimeCCe'
		
		Exit
	EndFor

EndEvent

Sub 'imprimeCCe'

	For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeCCeCod = &NfeCceCod
		
		GravarStatusIMpressao.Call( EmpCod, FilCod, NfeCod, NfeCCeCod)
		
		If not NfeCCeArqXml.IsEmpty() and NfeCCeSts = Status_NFe.Autorizada
		
			&Random = random() * 100000000
			&URLFisico = trim(str(&Random))+ NfeChv.Trim() + '_' + padL(trim(Str(NfeCCeEvtCod)), 2, '0')
			
			btnbtn3.Visible = 1
			btnbtn5.Visible = 1
			btnbtn3.Caption = 'Reimprimir CCe'
			
			EmbPage1.Source = RELJAS044Print.LInk(EmpCod, FilCod, NfeCod, NfeCCeCod, &URLFisico)
		EndIF
		
		Exit
	EndFor

EndSub


]]></Source>
