      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPLISTAGEMPRODUTOS', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&ListarSemPreco = false

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	do 'LoadFornecedor'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'LoadFornecedor'
	
	if &IsAchouFOrnecedor= true
		Do case
			case &ProSts = Status_AtivoInativo.ATIVO
				&AuxProSts = Status_Produto.ATIVO
			case &ProSts = Status_AtivoInativo.INATIVO
				&AuxProSts = Status_Produto.INATIVO
			otherwise
				&AuxProSts = nullvalue(&AuxProSts)
		EndCase
		
		if &ExcelPDF = 'P'
			RCOOpenWindow1.LinkOpen = RELJAS035.Link(&EmpCod, &FilCod, &AuxProSts, &ProPadForCod, &Ordem, &SetCod,&MarCod,&ProEmbCod, &ProCatCod, &GrupHie, &modelo, &ProTipDef, &PrecoVEnda, &ListarSemPreco, &ListarSomenteComLocacao, &iniProDtaCad, &finProDtaCad)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Else
			ExportProdutos.call(&EmpCod, &FilCod, &AuxProSts, &ProPadForCod, &Ordem, &SetCod,&MarCod,&ProEmbCod, &ProCatCod, &GrupHie, &modelo, &ProTipDef, &PrecoVEnda, &ListarSemPreco, &ListarSomenteComLocacao, &iniProDtaCad, &finProDtaCad ,&Filename,&ErrorMessage)
			If (&Filename <> "")
				Link(&Filename)
			Else
				msg(&ErrorMessage)
			Endif
		EndIF
	Endif

EndEvent

Event &ProPadForCod.IsValid

	do 'LoadFornecedor'

EndEvent

Event &ProEmbCod.IsValid

	If &ProEmbCod <> 0 
		RetornaEmbalagem.call(&EmpCod,&ProEmbCod,&ProEmbNom,&ProEmbUnd)
	Else
		&ProEmbNom = 'TODAS AS EMBALAGENS'
		&ProEmbUnd = ''		
	Endif

EndEvent

Sub 'LoadFornecedor'

	&IsAchouFOrnecedor= true
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &ProPadForCod
		Where PesIsFor = true
		&ProPadForRaz = PesRaz
		
		Exit
	When none
		if &PRoPadForCod.IsEmpty()
			&ProPadForRaz = 'TODOS OS FORNECEDORES'
		Else
			&ProPadForRaz = 'FORNECEDOR NÃO LOCALIZADO'
			msg(&ProPadForRaz)
			&IsAchouFOrnecedor = false
		EndIF
	
	EndFor

EndSub


]]></Source>
