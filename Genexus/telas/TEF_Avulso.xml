      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	
	do 'loadPlanoContas'
	do 'impressaoDireta'	
	
	//&TefPlanCod = &parmTefPlanCod
	&TefBanCarCod = &parmTefBanCarCod
	&TefCreDebVou = &parmTefCreDebVou
	&TefCrePar = &parmTefCrePar
	&TefVlr = &parmTefVlr
	
	&EmpCod = &WwpContext.EmpCod
	&FilCod = &WwpContext.FilCod
	txtAlerta.Caption = ''
	
	&TefBanCarCod.Clear()
	For Each Order EmpCod, BanCarCod
		Where EmpCod = &EmpCod
		Where BanCarIsTEF = 'J' //TEF - JASPI PAGAMENTOS
		
		&TefBanCarCod.AddItem(BanCarCod, BanCarNom)
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &TefCrePar < 1
		&TefCrePar = 1
	Endif
		
	if &TefCreDebVou = 'D'
		&TefCrePar = 1
		&IsAchouParcela = true
	Else
		do 'ValidaCartao'
	Endif
	
	Do Case
		CAse &IsAchouParcela = false
			txtAlerta.Caption = 'Parcelamento não Permitido!'
			&TefCrePar.SetFocus()
		Otherwise
		
			//&PadOBs = &OqueFazer1
			//padraoUsuario.Call('G', 'PEDIDOVENDA_IMPRESSAODIRETA', &Context.PesCod, &Context.EmpCod, &PadOBs, &PAdDtaMod)
			
			
			txtAlerta.Caption = ''
			if &TefVlr.IsEmpty()
				txtAlerta.Caption = 'Favor informar o valor da transação!'
				&TefVlr.SetFocus()
			Else
				prcIniciaNovoTEF.Call(&EmpCod, &FilCod, &PedCod, &TefVlr, &TefCreDebVou, &TefCrePar, &TefBanCarCod, &TefCod)
				TEF_Retorno.Popup('AVULSO', &EmpCod, &TefCod)
				return
			Endif
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	REturn

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'ValidaCartao'

	&IsAchouParcela = false
	
	if &CarParQtd > 1
		For each Order EmpCod,BanCarCod
			Where EmpCod = &EmpCod
			Where BanCarCod = &TefBanCarCod
			
			&BanCarVlrMinPar = &TefVlr / BanCarCrePar
			If  &BanCarVlrMinPar >= BanCarVlrMinPar and &TefCrePar = BanCarCrePar
				&IsAchouParcela = true
				Exit
			EndIf
		EndFor
	Else
		&TefCrePar = 1
		&IsAchouParcela = true
	Endif

EndSub

Sub 'loadPlanoContas'

	&TefPlanCod.Clear()
	&SdtPlanoConta =  dpPlanoAnaCre_EmpCod.Udp(&WwpContext.EmpCod)
	for &SdtPlanoContaItem in &SdtPlanoConta
		&TefPlanCod.AddItem(&SdtPlanoContaItem.PlanCod, &SdtPlanoContaItem.PlanCodNom)
	EndFor

EndSub

Sub 'impressaoDireta'

	padraoUsuario.Call('L', 'TEF_IMPRESSAODIRETATEF', &WwpContext.PesCod, &WwpContext.EmpCod, &PadOBs, &PAdDtaMod)
	
	&Istem_CUPOM1 = RetornaTemImpressora.Udp(&WwpContext.EmpCod, domTipoImpressora.CUPOM1, domTipoImpressora.CUPOM2)
	
	&OqueFazer1.clear()	
	if &Istem_CUPOM1 = true
		For Each Order EmpCod, EmpImpPC, EmpImpNom
			Where EmpCod = &WwpContext.EmpCod
			where EmpImpTip = domTipoImpressora.CUPOM1 or EmpImpTip = domTipoImpressora.CUPOM2
			
			&Mensagem = 'CUPOM | '+ EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
			&CodigoImpressora = '3B   ' + PadL(str(EmpImpCod), 8, ' ')
			if &Mensagem.Length() > 35
				&Mensagem = substr(&Mensagem, 1, 35) + '...'
			Endif
			&OqueFazer1.AddItem(&CodigoImpressora, &Mensagem)
		EndFor
		&OqueFazer1 = trim(Substr(&PadOBs, 1, 15))
	Endif
	&Mensagem.SetEmpty()

EndSub


]]></Source>
