      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&OpeImpCod.Visible = False
	&OpeImpOut.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &OpeTipVia = PefServiceTipoViagem.Padrao

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WPOperacaoTransporte(!'Impostos', !'Pgto', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		If not &HasValidationErrors
			Do 'SaveVariablesToWizardData'
			
			prcNovoEFrete_Login.Call(&Token, &ProtocoloServico, &StatusLogin)
			If &StatusLogin = 200	
				Do 'GravarProprietario'
			Else
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &StatusLogin.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
			EndIf
			
			If not &Token.Trim().IsEmpty()
				prcNovoEFrete_Logout.Call(&Token, &StatusLogOut)
			Endif
		EndIf
		
	EndIf

EndEvent

Event 'WizardPrevious'

 	If &WizardData.Inicio.OpeTipVia = PefServiceTipoViagem.Padrao

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	WPOperacaoTransporte(!'Impostos', !'DocFiscais', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		Do 'SaveVariablesToWizardData'
		WPOperacaoTransporte(!'Impostos', !'Viagem', true)
	EndIf

EndEvent

Sub 'LoadVariablesFromWizardData'

	iF 1 =2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&OpeImpCod = &WizardData.Impostos.OpeImpCod
	&OpeImpIRRF = &WizardData.Impostos.OpeImpIRRF
	&OpeImpSest = &WizardData.Impostos.OpeImpSest
	&OpeImpInss = &WizardData.Impostos.OpeImpInss
	&OpeImpIssqn = &WizardData.Impostos.OpeImpIssqn
	&OpeImpOut = &WizardData.Impostos.OpeImpOut

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&EmpCod = &WizardData.Inicio.EmpCod
		&FilCod = &WizardData.Inicio.FilCod
		&OpeCod = &WizardData.Inicio.OpeCod
		
		do 'GetImpostos'	
		
		If &OpeSts <> Status_Ciot.Digitando And &OpeTipVia = PefServiceTipoViagem.TAC_Agregado
			btnWizardNext.Visible	= 0
		Else
			btnWizardNext.Visible	= 1
		EndIf
	EndIf

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Impostos.OpeImpCod = &OpeImpCod
	&WizardData.Impostos.OpeImpIRRF = &OpeImpIRRF
	&WizardData.Impostos.OpeImpSest = &OpeImpSest
	&WizardData.Impostos.OpeImpInss = &OpeImpInss
	&WizardData.Impostos.OpeImpIssqn = &OpeImpIssqn
	&WizardData.Impostos.OpeImpOut = &OpeImpOut
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	GravaOperacaoTransporteImpostos.call(&EmpCod,&FilCod,&OpeCod,&OpeImpIRRF,&OpeImpSest,&OpeImpInss,&OpeImpIssqn,&OpeImpOut)

EndSub

Sub 'GravarProprietario'

	prcNovoEFrete_Proprietario.Call(&OpeConCod, &Token, &StatusRet)
	If &StatusRet = 200
		Do 'GravarVeiculos'
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", 'Operação incompleta por ERRO no proprietário.', DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf

EndSub

Sub 'GravarVeiculos'

	&IsVeiculosOk = True
	For Each Order EmpCod, FilCod, OpeCod, OpeVeiCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where OpeCod = &OpeCod
		
		&AuxVeiPla 	 = OpeVeiPla
		Do 'GetVeiculo'
		
		prcNovoEFrete_Veiculos.Call(&Token, &AuxVeiCod, &StatusRet)
		If &StatusRet = 0
			&IsVeiculosOk = False
		EndIf
		
	EndFor
	
	If &IsVeiculosOk = True
		Do 'GravarMotorista'
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", 'Operação incompleta por ERRO no(os) veículo(os).', DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf

EndSub

Sub 'GravarMotorista'

	prcNovoEFrete_Motorista.Call(&Token, &OpeMotCod, &StatusRet)
	If &StatusRet = 200
		prcNovoEFrete_PEF.Call(&Token, &OpeCod, &StatusRet, &Status)
		If &StatusRet = 200
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", 'Operação cadastrada com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))	
			WPOperacaoTransporte(!'Pgto', !'Obter', false)
		EndIf
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", 'Operação incompleta por ERRO no motorista.', DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf

EndSub

Sub 'GetVeiculo'

	For Each Order EmpCod, VeiCod
		Where EmpCod = &EmpCod
		Where VeiPla = &AuxVeiPla
		
		&AuxVeiCod	 = VeiCod
		
		Exit
	EndFor

EndSub

Sub 'GetImpostos'

	For Each Order EmpCod, FilCod, OpeCod
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&OpeTipVia			= OpeTipVia
		&OpeSts				= OpeSts
		TextCIOTStatus.Caption	= 'CIOT: ' + Trim(OpeNroCiot) + ' ' + UPPER(OpeSts.EnumerationDescription())
		&OpeConCod			= OpeConCod
		&OpeMotCod			= OpeMotCod
		
		For Each Order EmpCod, FilCod, OpeCod, OpeImpCod
			Where OpeImpCod = 1
			
			&OpeImpCod 		= OpeImpCod
			&OpeImpIRRF 	= OpeImpIRRF
			&OpeImpSest 	= OpeImpSest
			&OpeImpInss 	= OpeImpInss
			&OpeImpIssqn 	= OpeImpIssqn
			&OpeImpOut 		= OpeImpOut
			
			Exit
		EndFor
	EndFor

EndSub


