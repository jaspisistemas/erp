      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWCONTROLEFERIAS', Status_SimNao.Sim, 2, &AutNiv)
	txtErroFuncionario.Caption = ''
	txtErro.Caption = ''
	loadwwpContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod
	&PesCod.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'totaldiasSelecionado'
	do 'getComboSelecionado'
	Do Case
		CAse &FerItemIni.IsEmpty() or &FerItemIni > &FerItemFin
			txtErro.Caption = 'Data Inicial não pode ser superior a data final ou vazia!'
			txtErro.ForeColor = rgb(255,0,0)
			&FerItemIni.SetFocus()
			
		CAse &FerItemFin.IsEmpty()
			txtErro.Caption = 'Data Final precisa ser preenchida!'
			txtErro.ForeColor = rgb(255,0,0)
			&FerItemFin.SetFocus()
			
		case &PesDtaAdm.IsEmpty()
			txtErro.Caption = 'Funcionário sem data de admissão informada, inclua a data admissão ao cadastro do funcionário!'
			txtErro.ForeColor = rgb(255,0,0)
			&PesCod.SetFocus()
			
		Case &PesIsFun = false
			txtErro.Caption = 'Funcionário não está marcado como funcionário no seu cadastro!'
			txtErro.ForeColor = RGB(255,0,0)
			&PesCod.SetFocus()
			
		Case &FerItemDias.IsEmpty()
			txtErro.Caption = 'Quantidade de dias deve ser maior que zero!'
			txtErro.ForeColor = rgb(255,0,0)
			&FerItemFin.SetFocus()
			
		CAse &FerItemDias > &FerDiaPen
			txtErro.Caption = 'Quantidade de dias informado maior que a disponível para gozo no ano Base selecionado!'
			txtErro.ForeColor = rgb(255,0,0)
			&FerAnoBas.SetFocus()
			
		case &FerAnoBas.IsEmpty()
			txtErro.Caption = 'Ano base não selecionado!'
			txtErro.ForeColor = rgb(255,0,0)
			&FerAnoBas.SetFocus()
			
		case &FerItemTip.IsEmpty()
			txtErro.Caption = 'Selecione o Tipo de Férias!'
			txtErro.ForeColor = rgb(255,0,0)
			&FerItemTip.SetFocus()
			
		Otherwise
			prcGravaRegistroFerias.Call(&EmpCod, &PesCod, &PesRecCod,&FerAnoBas,&FerItemIni, &FerItemFin, &FerItemObs, &FerItemTip)
			
			txtErro.Caption = 'Férias registrada!'
			txtErro.ForeColor = rgb(0,130,0)
			do 'limpa'
			&PesCod.SetFocus()
			
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserReturn'

	wwpactions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FerItemIni.IsValid

	do 'totaldiasSelecionado'

EndEvent

Event &FerItemFin.IsValid

	do 'totaldiasSelecionado'

EndEvent

Event &FerAnoBas.IsValid

	do 'getComboSelecionado'

EndEvent

Event &PesCod.IsValid

	do 'getFuncionario'
	do 'motacomboano'

EndEvent

Sub 'limpa'

	&PesCod.SetEmpty()
	&PesRaz = upper('Selecione o funcionário')
	&PesDtaAdm.SetEmpty()
	&PesDtaReg.SetEmpty()
	&PesDtaDem.SetEmpty()

EndSub

Sub 'totaldiasSelecionado'

	&FerItemDias = 0
	if not &FerItemFin.IsEmpty() and &FerItemFin >= &FerItemIni and not &FerItemIni.IsEmpty()
		&FerItemDias = (&FerItemFin - &FerItemIni) + 1
	Endif

EndSub

Sub 'getComboSelecionado'

	For Each Order EmpCod, PesCod, FerAnoBas
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesRecCod = &PesRecCod
		where FerAnoBas = &FerAnoBas
		
		&FerDiaPen = FerDiaPen
		&FerDiaTot = FerDiaTot
		&FerDiaUsu = FerDiaUsu
		
		&FerDtaIni = FerDtaIni
		&FerDtaFin = FerDtaFin 
		Exit
	EndFor

EndSub

Sub 'motacomboano'

	&FerAnoBas.Clear()
	For Each Order EmpCod, PesCod, PesRecCod, FerAnoBas
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesRecCod = &PesRecCod
		where PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsNull() or PesRecSts.IsEmpty()
		where FerDiaPen > 0
		&DescricaoMensagem = trim(Str(FerAnoBas)) + ' | ' + trim(str(FerDiaPen)) + ' disponível para gozo'
		&FerAnoBas.AddItem(FerAnoBas, &DescricaoMensagem)
	when none
		&FerAnoBas.AddItem(0, 'NENHUM ANO BASE DISPONIVEL')
	EndFor

EndSub

Sub 'getFuncionario'

	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PesRaz= PesRaz
		&PesDtaAdm = PesDtaAdm
		&PesDtaDem = PesDtaDem
		&PesDtaReg = PesDtaReg				
		&PesIsFun = PesIsFun
		do case
			case PesDtaAdm.IsEmpty() or PesDtaAdm.IsNull()
				txtErroFuncionario.Caption = 'Funcionário sem data de admissão informada, inclua a data admissão ao cadastro do funcionário!'
				txtErroFuncionario.ForeColor = RGB(255,0,0)
			Case PesIsFun <> true
				txtErroFuncionario.Caption = 'Funcionário não está marcado como funcionário no seu cadastro!'
				txtErroFuncionario.ForeColor = RGB(255,0,0)
		EndCAse
	
		&PesRecCod = 0
		For EAch Order EmpCod, PesCod, (PesRecCod)
			Where PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsEmpty() or PesRecSts.IsNull()
			where not PesRecDtaAdm.IsEmpty() and not PesRecDtaAdm.IsNull()
			Where PesRecDtaDem.IsEmpty() or PesRecDtaDem.IsNull()
			&PesRecCod = PesRecCod
			Exit
		EndFor
		
		Exit
	EndFor

EndSub


]]></Source>
