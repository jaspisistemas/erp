      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	prcCarregaDadosComissao.Call(&EmpCod, &PesCod, &LctCod, &AuxSdtComissaoVendedorDesconto)
	
	&PesTipCom = &AuxSdtComissaoVendedorDesconto.PesTipCom
	
	Do Case
		CAse &AuxSdtComissaoVendedorDesconto.PesTipCom = 'S' //faturament
			&sdtComissaoVendedorFauramento = &AuxSdtComissaoVendedorDesconto
			
		CAse &AuxSdtComissaoVendedorDesconto.PesTipCom = 'N' //fixa
			for &AuxSdtComissaoVendedorDescontoItem in &AuxSdtComissaoVendedorDesconto.Item
				&ComTabNor = &AuxSdtComissaoVendedorDescontoItem.ComTabNor
				&ComTabPrm = &AuxSdtComissaoVendedorDescontoItem.ComTabPrm
				Exit
			EndFor
		
		CAse &AuxSdtComissaoVendedorDesconto.PesTipCom = 'D' //desconto
			&sdtComissaoVendedorDesconto = &AuxSdtComissaoVendedorDesconto
			
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	GridsdtComissaoFaturamento.Rows = 0
	GridsdtComissaoVendedor_Items.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtComissaoFaturamento.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

