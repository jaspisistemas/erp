	if &PIDApp.IsEmpty() and &PathApp.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('PID e App não podem set vazios', '', DVMessageType.error, '', DVMessageBoolean.True))
	else
		if &PIDApp.IsEmpty()
			&Resultado = &ProcessManager.StopProcessByFilePath(&PathApp).ToString()
