      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPRENTABILIDADE', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	RetornaConfiguracoesPastas.Call(&Context.EmpCod, &Context.FilCod, &SdtConfiguracoesPasta)
	
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&UsrCod = &Context.PesCod
	&AuxPesCod = &Context.PesCod //DpFilialAcesso
	Do 'Produto'
	Do 'Cliente'
	Do 'Vendedor'
	Do 'Lancamento'
	UserProgress.Visible = false
	&PedDtaFat = yMDtoD(Year(&Today),month(&Today),01)
	&PedDtaFat_Go = &Today

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmarExcel'

	&Data = serverdate()
	&Hora = serverTime()
	&mensagem = trim(toformattedString(&Data)) + trim(&Hora)
	&mensagem = RetornaSoNumeros.Udp(&mensagem)
		
	&LinkFisico  = &SdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'rentabilidade_'  + trim(&mensagem) + '.xlsx'
	&LingVirtual = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + 'rentabilidade_'  + trim(&mensagem) + '.xlsx'
	
	&ExcelPdf = 'XLSX'
	&ProgressId = 'Rentabilidade' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	ApagaProgress.Call(&ProgressId)
	UserProgress.Visible = true
	
	btnEnter.Visible = false
	btnConfirmarExcel.Visible = false
	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	Rentabilidade.Submit('Rentabilidade',&ProgressId,&EmpCod,&FilCod,&PedDtaFat,&PedDtaFat_Go,&ProCod,&GrupHie,&LctCod,&LctGerFin,&PesCod,&PedVenCod,&IsSintetico,&UsrCod, &TipoProduto, &Percentual)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProGraRef.IsValid

	Do 'Produto'

EndEvent

Event &PesCod.IsValid

	Do 'Cliente'

EndEvent

Event &PedVenCod.IsValid

	Do 'Vendedor'

EndEvent

Event &LctCod.IsValid

	Do 'Lancamento'

EndEvent

Event Enter

	&ExcelPdf = 'PDF'
	&ProgressId = 'Rentabilidade' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	ApagaProgress.Call(&ProgressId)
	UserProgress.Visible = true
	
	btnEnter.Visible = false
	btnConfirmarExcel.Visible = false
	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	Rentabilidade.Submit('Rentabilidade',&ProgressId,&EmpCod,&FilCod,&PedDtaFat,&PedDtaFat_Go,&ProCod,&GrupHie,&LctCod,&LctGerFin,&PesCod,&PedVenCod,&IsSintetico,&UsrCod, &TipoProduto, &Percentual)

EndEvent

Event scaProgressBar1.OnComplete

	UserProgress.Visible = true
	btnEnter.Visible = true
	btnConfirmarExcel.Visible = true
	
	For Each ORder ProgressId
		Where ProgressId = &ProgressID
		&ProgressLogXml = ProgressLogXml
		Exit
	EndFor
	If &ProgressLogXml.Trim().IsEmpty()
		msg('Completado com sucesso! ')
		if &ExcelPdf = 'PDF'
			RCOOpenWindow1.LinkOpen = RELJAS068.link(&EmpCod,&UsrCod, &Percentual)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Else
			RELJAS068_Excel.Call(&EmpCod,&UsrCod, &Percentual, &LinkFisico)
			Link(&LingVirtual)
		Endif
	
	Else
		Msg(&ProgressLogXml)
	EndIf
	
	ApagaProgress.Call(&ProgressId)

EndEvent

Sub 'Produto'

	If &ProGraRef.IsEmpty()
		&ProNom = 'TODOS OS PRODUTOS'
	Else
		RetornaProdutoReferencia.Call(&EmpCod, &ProGraRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
		
		For Each Order EmpCod, ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			Where ProSts = Status_Produto.ATIVO
			&ProNom = ProNomGra
			Exit
		When none
			&ProNom = 'Produto não encontrado, ou inativo. Verifique!'
			msg('ATENÇÃO! Produto não encontrado, ou inativo. Verifique!')
			&ProGraRef.SetFocus()
		EndFor
	EndIf

EndSub

Sub 'Cliente'

	If &PesCod = 0
		&PesRaz = 'TODOS OS CLIENTES'
	Else
		For Each Order EmpCod, PesSts, PesIsCli,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			Where PesIsCli = True
			Where PesSts = Status_AtivoInativo.ATIVO
			&PesRaz = PesRaz
			Exit
		When none
			&PesRaz = 'Cliente não encontrado, ou inativo. Verifique!'
			msg('ATENÇÃO! Cliente não encontrado, ou inativo. Verifique!')
			&PesCod.SetFocus()
		EndFor
	EndIf

EndSub

Sub 'Vendedor'

	If &PedVenCod = 0
		&PedVenRaz = 'TODOS OS VENDEDORES'
	Else
		For Each Order EmpCod, PesIsVen,PesSts,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PedVenCod
			Where PesIsVen = True
			Where PesSts = Status_AtivoInativo.ATIVO
			&PedVenRaz = PesRaz
			Exit
		When none
			&PedVenRaz = 'Vendedor não encontrado, ou inativo. Verifique!'
			msg('ATENÇÃO! Vendedor não encontrado, ou inativo. Verifique!')
			&PedVenCod.SetFocus()
		EndFor
	EndIf

EndSub

Sub 'Lancamento'

	If &LctCod = 0
		&LctNom = 'TODOS OS TIPOS DE LANÇAMENTO'
	Else
		For Each Order EmpCod, LctCod
			Where EmpCod = &EmpCod
			Where LctCod = &LctCod
			&LctNom = LctNom
			Exit
		When none
			&LctNom = 'Tipo de lançamento não encontrado. Verifique!'
			msg('ATENÇÃO! Tipo de lançamento não encontrado. Verifique!')
			&LctCod.SetFocus()
		EndFor
	EndIf

EndSub


