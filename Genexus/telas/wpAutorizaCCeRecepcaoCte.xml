      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	com.ForeColor  = RGB(0,160,40)
	com1.ForeColor = RGB(0,160,40)
	loadWWPContext.Call(&Context)
	
	&ProgressLogXml = ''
	txtMsg.Caption = ''
	txtMsg.ForeColor = RGB(210,130,0)
	
	&ProgressId = 'ProgressoCCeCte' + trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&Context.PesCod)) + trim(Str(&CteCod)) + trim(Str(&CteCceCod))
	
	&ProgressId = &ProgressId.trim()	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	scaProgressBar1.Visible = true
		
	RecepcaoCte.Submit('ProgressoCCe', &ProgressId, &EmpCod, &FilCod, &CteCceCod, &SolCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	btnBtn1.Visible = 0
	btnBtn2.Visible = 0
	btnBtn3.Visible = 0

EndEvent

Event 'DoBtn1'

	wpCartasCorrecaoCte.Link(&EmpCod, &FilCod, &CteCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn2'

	WWCTe.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn3'

	For Each Order EmpCod, FilCod, CteCod, CteCCeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteCCeCod = &CteCceCod
		
		If not CteCCeArqXml.IsEmpty() and CteCCeSts = Status_NFe.Autorizada
			GeraPdfCceCte_web.Call(EmpCod, FilCod, CteCod, CteCCeCod, &UrlPDF, &UrlFisico)
		EndIF
	EndFor

	If not &UrlPDF.IsEmpty()
		RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&ProgressLogXml <> '')
		DVPanel_Retorno_Cell.Class = !'Invisible'
	Else
		DVPanel_Retorno_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		&ProgressLogXml = ProgressLogXml
		txtMsg.Caption = &ProgressLogXml
		
		btnBtn1.Visible = 1
		btnBtn2.Visible = 1	
		do 'imprimeCCe'
		
		Exit
	EndFor

	do 'AttributesSecurityCode'
	scaProgressBar1.Visible = false

EndEvent

Sub 'imprimeCCe'

	For Each Order EmpCod, FilCod, CteCod, CteCCeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteCCeCod = &CteCceCod
		
		GravarStatusIMpressaoCte.Submit('', EmpCod, FilCod, CteCod, CteCCeCod)
		
		If not CteCCeArqXml.IsEmpty() and CteCCeSts = Status_NFe.Autorizada
		
			&Random = random() * 100000000
			&URLFisico = trim(str(&Random))+ CteChv.Trim() + '_' + padL(trim(Str(CteCCeCod)), 2, '0')
			
			btnbtn3.Visible = 1
			btnbtn3.Caption = 'Reimprimir CCe'
			

		EndIF
		
		Exit
	EndFor

EndSub


]]></Source>
