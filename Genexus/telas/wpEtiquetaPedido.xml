      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&ProDtaHorUltMod = serverNow()
	
	LoadWWPContext.Call(&Context)
	padraousuario.Call('L', '#QTDETIQUETASPEDIDO', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&GravaQuantasEtiquetas = Substr(&PadObs, 1, 1)
	&PedidoBalanco = Substr(&PadObs, 2, 1)
	
	If &auxPedCod <> 0 
		&PedidoBalanco = 'P'
		&PedCod = &auxPedCod
	EndIf
	if &PedidoBalanco.IsEmpty()
		&PedidoBalanco = 'P'
	Endif

	do 'Oculta'
	formataHORA.Call(&IniBalOrd, &IniBalOrd)
	formataHORA.Call(&FinBalOrd, &FinBalOrd)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 500

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &IniBalOrd.IsValid

	formataHORA.Call(&IniBalOrd, &IniBalOrd)

EndEvent

Event &FinBalOrd.IsValid

	formataHORA.Call(&FinBalOrd, &FinBalOrd)

EndEvent

Event &PedCod.IsValid

	if &PedCod > 0
		do 'localizaPedido'
	Endif

EndEvent

Event &PedidoBalanco.IsValid

	do 'Oculta'

EndEvent

Event Enter

	&PadObs = &GravaQuantasEtiquetas.Trim() + &PedidoBalanco.Trim()
	padraousuario.Call('G', '#QTDETIQUETASPEDIDO', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	if &IniBalOrd.IsEmpty()
		&IniBalOrd = '00:00'
	Endif
	if &FinBalOrd.IsEmpty()
		&FinBalOrd = '00:00'
	endif
	formataHORA.Call(&IniBalOrd, &IniBalOrd)
	formataHORA.Call(&FinBalOrd, &FinBalOrd)
	
	&IsLocalizado = false
	if &PedCod > 0 and &PedidoBalanco = 'P'
		do 'LocalizaPedido'
	Endif
	if &BalCod > 0 and &PedidoBalanco = 'B'
		do 'LocalizaPedidobalanco'
	Endif

	If &IsLocalizado = true or &PedidoBalanco = 'M'
		
		gravaProdutoEtiqueta.Call('DEL', &EtqCod, 0, '', 0, '', 0, '', '',0,'', 0, &EtqProObsAdi)
		
		Do CAse
			CASe &PedidoBalanco = 'P' //Pedido
				do 'GravaTabelaEtiqueta'
				
			Case &PedidoBalanco = 'B' //balanço
				do 'GravaTabelaEtiquetaBalanco'
				
			Case &PedidoBalanco = 'M' //modificados	
				do 'GetModificados'
		EndCase
	
		
		wwpActions.WCPopup_Close('S')
	EndIF

EndEvent

Sub 'GetModificados'

	For Each 
		Order EmpCod, ProGraRefPadL when &Ordem = 'C'
		Order EmpCod, ProNomGra when &Ordem = 'A'
		Order EmpCod, ProDtaHorUltMod when &Ordem = 'B'
		Where EmpCod = &EmpCod
		Where ProDtaHorUltMod >= &ProDtaHorUltMod
		Where ProSts = Status_Produto.ATIVO
		
		&sdtDadosAdicionaisEtiqueta = new()
		&sdtDadosAdicionaisEtiqueta.ProDesEtq1 = ProDesEtq1
		&sdtDadosAdicionaisEtiqueta.ProDesEtq2 = ProDesEtq2
		&sdtDadosAdicionaisEtiqueta.ProDesEtq3 = ProDesEtq3
		&EtqProObsAdi = &sdtDadosAdicionaisEtiqueta.ToJson()
		
//		if &GravaQuantasEtiquetas = 'A' //NESS MODO POR HORA SO 1 ETIQUETA
		if ProDesEtq.IsEmpty() or ProDesEtq.IsNull()
			&ProNom = ProNom
		Else
			&ProNom = ProDesEtq
		Endif
	
		gravaProdutoEtiqueta.Call('ADD', &EtqCod, 0, ProGraRef, ProCod, &ProNom, ProGraCod, ProGraBar, ProGraNom,ProQtdEmb,&ProNroLot, 1, &EtqProObsAdi)
	EndFor

EndSub

Sub 'GravaTabelaEtiqueta'

	For Each 
		Order EmpCod, FilCod,PedCod, PedItmCod when &Ordem = 'C'
		Order EmpCod, FilCod,PedCod, ProNomGra when &Ordem = 'A'
		Order EmpCod, FilCod,PedCod, ProGraRef when &Ordem = 'B'
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&sdtDadosAdicionaisEtiqueta = new()
		&sdtDadosAdicionaisEtiqueta.ProDesEtq1 = ProDesEtq1
		&sdtDadosAdicionaisEtiqueta.ProDesEtq2 = ProDesEtq2
		&sdtDadosAdicionaisEtiqueta.ProDesEtq3 = ProDesEtq3
		&EtqProObsAdi = &sdtDadosAdicionaisEtiqueta.ToJson()
		
		if &GravaQuantasEtiquetas = 'A'
			&PedQtd = 1
		Else
			&PedQtd = PedQtd
		Endif
		if ProDesEtq.IsEmpty() or ProDesEtq.IsNull()
			&ProNom = ProNom
		Else
			&ProNom = ProDesEtq
		Endif
	
		&ProGraRef = ProGraRef
		&ProCod = ProCod
		&ProGraCod = ProGraCod
		&ProGraBar = ProGraBar
		&ProGraNom = ProGraNom
		&ProQtdEmb = ProQtdEmb
		For Each Order EmpCod, FilCod,PedCod, PedItmCod,PedProEstLotCod
			Where PedProEstLotQtd > 0
			gravaProdutoEtiqueta.Call('ADD', &EtqCod, 0, &ProGraRef, &ProCod, &ProNom, &ProGraCod, &ProGraBar, &ProGraNom,&ProQtdEmb,PedProEstLotCod, PedProEstLotQtd, &EtqProObsAdi)
		When none
			gravaProdutoEtiqueta.Call('ADD', &EtqCod, 0, ProGraRef, ProCod, &ProNom, ProGraCod, ProGraBar, ProGraNom,ProQtdEmb,&ProNroLot, &PedQtd, &EtqProObsAdi)
		EndFor
	EndFor

EndSub

Sub 'GravaTabelaEtiquetaBalanco'

	&Varchar = Substr(&IniBalOrd, 1, 2)+ Substr(&IniBalOrd, 4, 2)
	&HoraInicialNumeric = val(trim(&Varchar))
		
	&Varchar = Substr(&FinBalOrd, 1, 2)+ Substr(&FinBalOrd, 4, 2)
	&HoraFinalNumeric = val(trim(&Varchar))	

	For Each 
		Order EmpCod, FilCod, PedCod, PedItmCod when &Ordem = 'C'
		Order EmpCod, FilCod, PedCod, ProNomGra when &Ordem = 'A'
		Order EmpCod, FilCod, PedCod, ProGraRefPadL when &Ordem = 'B'
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &BalPedCod
		where PedQtd <= 9999
		
		if (&HoraInicialNumeric > 0 or &HoraFinalNumeric > 0) //AND (not PedItmDtaAdd.IsEmpty() and not PedItmDtaAdd.IsNull())
			
			&Hora = PedItmDtaAdd.Hour()
			&minuto = PedItmDtaAdd.Minute()
			&Varchar = PadL(str(&Hora), 2, '0') + PadL(str(&minuto), 2, '0')
			
			&Numeric = val(trim(&Varchar))
		Else
			&Numeric = 0
		Endif

		if (&Numeric >= &HoraInicialNumeric or &HoraInicialNumeric = 0) and (&Numeric <= &HoraFinalNumeric or &HoraFinalNumeric = 0)
			&sdtDadosAdicionaisEtiqueta = new()
			&sdtDadosAdicionaisEtiqueta.ProDesEtq1 = ProDesEtq1
			&sdtDadosAdicionaisEtiqueta.ProDesEtq2 = ProDesEtq2
			&sdtDadosAdicionaisEtiqueta.ProDesEtq3 = ProDesEtq3
			&EtqProObsAdi = &sdtDadosAdicionaisEtiqueta.ToJson()
			
			if &GravaQuantasEtiquetas = 'A'
				&PedQtd = 1
			Else
				&PedQtd = PedQtd
			Endif
			if ProDesEtq.IsEmpty() or ProDesEtq.IsNull()
				&ProNom = ProNom
			Else
				&ProNom = ProDesEtq
			Endif
		
			gravaProdutoEtiqueta.Call('ADD', &EtqCod, 0, ProGraRef, ProCod, &ProNom, ProGraCod, ProGraBar, ProGraNom,ProQtdEmb,&ProNroLot, &PedQtd, &EtqProObsAdi)
		Endif
	EndFor

EndSub

Sub 'LocalizaPedido'

	&IsLocalizado = False
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedCliCodRaz = PedCliCodRaz
		&IsLocalizado = true
		Exit
	When none
		If &PedCod = 0
			&PedCliCodRaz = 'INFORME O CÓDIGO DO PEDIDO'
		Else
			&PedCliCodRaz = 'PEDIDO NÃO LOCALIZADO!'
			msg(&PedCliCodRaz)
		EndIF
	EndFor

EndSub

Sub 'LocalizaPedidoBalanco'

	&IsLocalizado = False
	For Each Order EmpCod, FilCod, BalCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where BalCod = &BalCod
		&BalPedCod = BalPedCod
		&IsLocalizado = true
		Exit
	When none
		If &BalCod = 0
			&PedCliCodRaz = 'INFORME O CÓDIGO DO BALANÇO'
			msg(&PedCliCodRaz)
		Else
			&PedCliCodRaz = 'BALANÇO NÃO LOCALIZADO!'
			msg(&PedCliCodRaz)
		EndIF
	EndFor

EndSub

Sub 'Oculta'

	tbEstoque.Visible = &PedidoBalanco = 'B'
	tbPedido.Visible = &PedidoBalanco = 'P'
	
	tbModificados.Visible = &PedidoBalanco = 'M'
	&GravaQuantasEtiquetas.Visible = &PedidoBalanco <> 'M'

EndSub


]]></Source>
