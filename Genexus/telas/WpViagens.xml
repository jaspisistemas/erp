Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Editar = !'<i class="fas fa-pen"></i>'
	If (ViaSts = 'T' or ViaSts = 'P')
		&Editar.Class = !'Attribute'
	Else
		&Editar.Class = !'Invisible'
	Endif
	&OqueFazer.Clear()
	&OqueFazer.AddItem(0, 'WWP_ActionGroupCaption')
	If (ViaSts = 'P')
		&OqueFazer.AddItem(1, 'Alterar para: "Em trânsito"')
	Endif
	If (ViaSts = 'P' or ViaSts = 'T')
		&OqueFazer.AddItem(2, 'Finalizar Viagem')
	Endif
	If (ViaSts = 'P' or ViaSts = 'T')
		&OqueFazer.AddItem(3, 'Cancelar Viagem')
	Endif
	&OqueFazer.AddItem(4, 'Relatório Financeiro')
	
	Do Case
		Case ViaSts = 'T'
			&ViaStsVarChar = 'Em Trânsito'
		
		Case ViaSts = 'P' 
			&ViaStsVarChar = 'Programada'
			
		Case ViaSts = 'F'
			&ViaStsVarChar = 'Finalizada'
			
		Case ViaSts = 'C'
			&ViaStsVarChar = 'Cancelada'
	EndCase
	&VeiPlaVarChar = VeiPla
	&PesRazVarChar = PesCodRaz
	If ViaSts = 'C'
		&Editar.ColumnClass = !'WWIconActionColumn WWColumnLineThrough WWColumnLineThroughFirstColumn'
		&ViaStsVarChar.ColumnClass = !'WWColumn WWColumnLineThrough'
		ViaCod.ColumnClass = !'WWColumn WWColumnLineThrough hidden-xs'
		&VeiPlaVarChar.ColumnClass = !'WWColumn WWColumnLineThrough'
		&PesRazVarChar.ColumnClass = !'WWColumn WWColumnLineThrough'
		ViaDtaSai.ColumnClass = !'WWColumn WWColumnLineThrough hidden-xs'
		ViaDtaChe.ColumnClass = !'WWColumn WWColumnLineThrough hidden-xs'
		ViaDes.ColumnClass = !'WWColumn WWColumnLineThrough'
		ViaValFre.ColumnClass = !'WWColumn WWColumnLineThrough'
		&OqueFazer.ColumnClass = !'WWActionGroupColumn WWColumnLineThrough'
	Else
		&Editar.ColumnClass = 'WWIconActionColumn'
		Do Case
			Case ViaSts = 'T'
				&ViaStsVarChar.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
			Case ViaSts = 'P'
				&ViaStsVarChar.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
			Case ViaSts = 'F'
				&ViaStsVarChar.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
			Case ViaSts = 'C'
				&ViaStsVarChar.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
			Otherwise
				&ViaStsVarChar.ColumnClass = 'WWColumn'
		EndCase
		ViaCod.ColumnClass = 'WWColumn hidden-xs'
		&VeiPlaVarChar.ColumnClass = 'WWColumn'
		&PesRazVarChar.ColumnClass = 'WWColumn'
		ViaDtaSai.ColumnClass = 'WWColumn hidden-xs'
		ViaDtaChe.ColumnClass = 'WWColumn hidden-xs'
		ViaDes.ColumnClass = 'WWColumn'
		ViaValFre.ColumnClass = 'WWColumn'
		&OqueFazer.ColumnClass = 'WWActionGroupColumn'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If (ViaSts = 'T' or ViaSts = 'P')
		&Editar = !'<i class="fas fa-pen"></i>'
	Else
		&Editar.Class = !'Attribute'
		&Editar = !'<i class="fas fa-search"></i>'
	EndIf

EndEvent

