Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"VIADTASAI"
				&ViaDtaSai.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"VIADTACHE"
				&ViaDtaChe.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"FILAUXVIASTS"
				&FilAuxViaSts.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PESNOM"
				&PesNom.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"VEIPLA"
				&VeiPla.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"FILVIASTS"
				&FilViaSts.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"VIADTASAI", "", not &ViaDtaSai.IsEmpty(), 0, &ViaDtaSai.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"VIADTACHE", "", not &ViaDtaChe.IsEmpty(), 0, &ViaDtaChe.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"FILAUXVIASTS", "", not &FilAuxViaSts.IsEmpty(), 0, &FilAuxViaSts, '')
	WWP_GridStateAddFilterValue(&GridState, !"PESNOM", "", not &PesNom.IsEmpty(), 0, &PesNom, '')
	WWP_GridStateAddFilterValue(&GridState, !"VEIPLA", "", not &VeiPla.IsEmpty(), 0, &VeiPla, '')
	WWP_GridStateAddFilterValue(&GridState, !"FILVIASTS", "", not &FilViaSts.IsEmpty(), 0, &FilViaSts, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"Viagens"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

