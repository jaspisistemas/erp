      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	if &Mode = TrnMode.Delete
		TextBlockTitle.Visible = 0
	EndIf

	do 'loadProduto'
	
	prcProduto_RetornaExisteProdutoEstoque.Call(&EmPCod, &ProCod, &PrincipalMensagem)
	if not &PrincipalMensagem.IsEmpty()
		&ProEstTip.Enabled = 0
		&ProEstProRef.Enabled = 0
		msg(&PrincipalMensagem)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 493

	Do 'AttributesSecurityCode'
	&ProEstProCod.Visible = False
	Grid.Rows = 25
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Updatee.FromImage(ActionUpdate)
	&Updatee.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&ProEstTip = TipoEstoque.ATUALIZAR_OUTRO_PRODUTO)
		DVPanel_ReferenciaEstoque_Cell.Class = !'Invisible'
	Else
		DVPanel_ReferenciaEstoque_Cell.Class = !'col-xs-12 CellMarginTop'
	EndIf
	If not(Not &PrincipalMensagem.IsEmpty())
		DVPanel_tbProdutos_Cell.Class = !'Invisible'
	Else
		DVPanel_tbProdutos_Cell.Class = !'col-xs-12 CellMarginTop'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &ProEstTip.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event &ProEstTip.Click

	Do 'AttributesSecurityCode'

EndEvent

Event Enter

	prcProduto_RetornaExisteProdutoEstoque.Call(&EmPCod, &ProCod, &PrincipalMensagem)
	
	testeErroMateriaPrimaCustoOutroProduto.Call(&EmpCod, &ProCod, &ProCod, &CustoOutroProdutoMensagem)
	
	If &ProEstTip = TipoEstoque.ATUALIZAR_OUTRO_PRODUTO
		do 'carregaMovimentoProduto'
	Else
		&ProEstProCod = &ProCod
	Endif
		
		
	Do Case
		Case not &PrincipalMensagem.IsEmpty()
			msg(&PrincipalMensagem)
			
		Case &ProEstTip <> TipoEstoque.ATUALIZAR_OUTRO_PRODUTO and &ProTipcus = TipoCusto.CustoProdutoEstoque
			msg('Tipo de Custo "CUSTO PRODUTO ATUALIZA ESTOQUE", não pode ser selecionado se o tipo de estoque for diferente de "ATUALIZAR OUTRO PRODUTO"')
			
		Case &ProTipcus = TipoCusto.CustoProdutoEstoque and not &CustoOutroProdutoMensagem.IsEmpty()
			msg(&CustoOutroProdutoMensagem)
			
		Case &IsNaoPode = false
			
			prcProduto_MovimentarEstoque.Call(&EmPCod, &ProCod, &ProEstTip, &ProEstProCod, &ProTipcus)
			
			//if &mode = TrnMode.Delete
			Return
			
				
	EndCase

EndEvent

Event &ProEstProRef.IsValid

	if &ProEstTip = TipoEstoque.ATUALIZAR_OUTRO_PRODUTO
		do 'carregaMovimentoProduto'
	Endif

EndEvent

Event &Updatee.Click

	wpProdutoEstoque.Popup(TrnMode.Delete, EmpCod, ProCod)
	Refresh

EndEvent

Sub 'carregaMovimentoProduto'

	&Mensagem.SetEmpty()
	&IsNaoPode = false
	For Each order EmpCod, ProRef
		Where EmpCod = &EmPCod
		Where ProRef = &ProEstProRef
		where ProSts <> Status_Produto.EXCLUIDO
		
		&ProEstProCod = ProCod
		&ProEstProNom = ProNom
		
		Do Case
			Case ProSts = Status_Produto.INATIVO
				//ATIVO 
				&IsNaoPode = true
				&Mensagem = 'PRODUTO RELACIONADO NÃO PODE ESTAR INATIVO!'
				
			Case ProEstTip = TipoEstoque.ATUALIZAR_OUTRO_PRODUTO or  ProEstTip = TipoEstoque.NAO_ATUALIZA
				//POSSUI TAMBEM UM PRODUTO PARA ESTOQUE
				&IsNaoPode = true
				&Mensagem = 'PRODUTO RELACIONADO TEM QUE SER DO TIPO ESTOQUE: MOVIMENTAR ESTOQUE'
		EndCase
		
		Exit
	when none
		&IsNaoPode = true
		&Mensagem = 'PRODUTO NÃO LOCALIZADO!'
	EndFor

	if not &Mensagem.IsEmpty()
		msg(&Mensagem)
	Endif

EndSub

Sub 'loadProduto'

	For Each order EmpCod, ProCod
		Where EmpCod = &EmPCod
		Where ProCod = &PrOCod
		where ProSts <> Status_Produto.EXCLUIDO
		&ProCodNom = ProCodNom
		&ProEstTip = ProEstTip
		&ProEstProRef = ProEstProRef
		&ProEstProCod = ProEstProCod
		&ProEstProNom = ProEstProNom
		&ProTipCus = ProTipCus
		Exit
	EndFor

EndSub


]]></Source>
