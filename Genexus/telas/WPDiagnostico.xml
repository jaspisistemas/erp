      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&TlvCod = &parTlvCod
	&InfCod = &parInfCod
	&TlvCod.Enabled = 1
	&InfCod.Enabled = 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&ProCod.Visible = False
	&DgnInfDosMax.Visible = False
	&DgnInfDosMin.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'CarregaDiagnostico'

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &TlvCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Cultura'), DVMessageType.error, &TlvCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &InfCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Infestação'), DVMessageType.error, &InfCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &Diagnostico.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Diagnóstico'), DVMessageType.error, &Diagnostico.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &DgnInfDosAlq.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Dose de Uso'), DVMessageType.error, &DgnInfDosAlq.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &DgnInfUniUsoCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Unidade de uso da dose'), DVMessageType.error, &DgnInfUniUsoCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &DgnQtdVol.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Volume em LTS ou KG p/ Und Comprada'), DVMessageType.error, &DgnQtdVol.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &DgnInfAplMax.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nro de aplicações'), DVMessageType.error, &DgnInfAplMax.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &ModalidadeEpoca.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Modalidade e Época de aplicação TERRESTRE (Siagro 550 Caracter)'), DVMessageType.error, &ModalidadeEpoca.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &Intevaloseguranca.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Intevalo de Segurança (Siagro 80 Caracter)'), DVMessageType.error, &Intevaloseguranca.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &Precaucoes.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Precauções de Uso (Siagro 550 Caracter)'), DVMessageType.error, &Precaucoes.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &EPI.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','EPI (Siagro 100 Caracter)'), DVMessageType.error, &EPI.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &TlvCod.IsValid

	do 'BuscaCultura'

EndEvent

Event &InfCod.IsValid

	Do  'BuscaInfestcao'

EndEvent

Event &ModalidadeEpoca.IsValid

	&ModalidadeEpoca = RetiraCaracteresEspeciaisExtras.Udp(&ModalidadeEpoca)

EndEvent

Event &ModalidadeEpocaAerea.IsValid

	&ModalidadeEpocaAerea = RetiraCaracteresEspeciaisExtras.Udp(&ModalidadeEpocaAerea)

EndEvent

Event &Intevaloseguranca.IsValid

	&Intevaloseguranca = RetiraCaracteresEspeciaisExtras.Udp(&Intevaloseguranca)

EndEvent

Event &Precaucoes.IsValid

	&Precaucoes = RetiraCaracteresEspeciaisExtras.Udp(&Precaucoes)

EndEvent

Event &EPI.IsValid

	&EPI = RetiraCaracteresEspeciaisExtras.Udp(&EPI)

EndEvent

Event &Orientacaomanejo.IsValid

	&Orientacaomanejo = RetiraCaracteresEspeciaisExtras.Udp(&Orientacaomanejo)

EndEvent

Event Enter

	DO 'CheckRequiredFields'
	If &CheckRequiredFieldsResult = True
		GravarDiagnostico.call(&EmpCod,&ProCod,&TlvCod,&InfCod,&DgnTlvAtv,&DgnInfDosAlq,&DgnInfSts,&DgnQtdVol,&DgnInfAplMax,&DgnInfDiaCar,&DgnInfUniUsoCod,&DgnInfUniUsoNom,&DgnInfDosMax,&DgnInfDosMin,&DgnInfTraSem,&Diagnostico,&EPI,&Intevaloseguranca,&ModalidadeEpoca,&ModalidadeEpocaAerea,&Orientacaomanejo,&OutrasInfo,&Precaucoes)
		Return
	EndIf

EndEvent

Sub 'CarregaDiagnostico'

	For each Order EmpCod,ProCod,TlvCod,InfCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where TlvCod = &TlvCod
		Where InfCod = &InfCod
		
		&ProCodNom = ProCodNom
		&TlvNom = TlvNom
		&InfNom = InfNom
		&DgnTlvAtv = DgnTlvAtv
		&DgnInfUniUsoCod = DgnInfUniUsoCod
		&DgnInfUniUsoNom = DgnInfUniUsoNom
		&DgnInfAplMax = DgnInfAplMax
		&DgnInfDiaCar = DgnInfDiaCar
		&DgnInfTraSem = DgnInfTraSem
		&DgnInfDosAlq = DgnInfDosAlq
		&DgnInfDosMax = DgnInfDosMax
		&DgnInfDosMin = DgnInfDosMin
		&DgnQtdVol = DgnQtdVol
		&DgnInfSts = DgnInfSts
		
		For each Order EmpCod,ProCod,TlvCod,InfCod,RcmCod
			
			Do Case
				Case RcmTip = Recomendacao.Diagnostico
					&Diagnostico = RcmNom
				Case RcmTip = Recomendacao.EPI
					&EPI = RcmNom
				Case RcmTip = Recomendacao.Intevaloseguranca
					&Intevaloseguranca = RcmNom
				Case RcmTip = Recomendacao.ModalidadeEpoca
					&ModalidadeEpoca = RcmNom
				Case RcmTip = Recomendacao.ModalidadeEpocaAerea
					&ModalidadeEpocaAerea = RcmNom
				Case RcmTip = Recomendacao.Orientacaomanejo
					&Orientacaomanejo = RcmNom
				Case RcmTip = Recomendacao.OutrasInfo
					&OutrasInfo = RcmNom
				Case RcmTip = Recomendacao.Precaucoes
					&Precaucoes = RcmNom
			EndCase
		EndFor
		
	When none
		For Each Order EmpCod,ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod			
			&ProCodNom = ProCodNom
			exit
		EndFor
		
	EndFor

EndSub

Sub 'BuscaCultura'

	For Each Order EmpCod,TlvCod
		Where EmpCod = &EmpCod
		Where TlvCod = &TlvCod
		&TlvNom = TlvNom
		exit
	EndFor

EndSub

Sub 'BuscaInfestcao'

	For each Order EmpCod,InfCod
		Where EmpCod = &EmpCod
		Where InfCod = &InfCod
		&InfNom = InfNom
		exit
	EndFor

EndSub


