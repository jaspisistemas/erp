        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = 0
	Grid1_TitlesCategories.GridInternalName = Grid1.InternalName

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	For Each Order EmpCod, MrkTip
		Where EmpCod = &EmpCod
		Where MrkStsInt = StatusMarketplace.Integrada
		Where MrkSts = Status_AtivoInativo.ATIVO
		
		if MrkTip <> &MrkTip
			&MrkTip = MrkTip
			&imagemMark.FromImage(retornaImagemMarketplace.Udp(MrkTip))
			&TipoMarketplace = TipoMarketplace.MercadoLivre
			&NomeLoja = MrkTip.EnumerationDescription().ToUpper()
			&NomeCategoria = ''
			&GrupMrkCatSku = ''
			
			do 'getCategoriaMarketplace'
			&UserLocalizar = !'<i class="fas fa-pen"></i>'
			&UserLocalizar.Link = wcAddCategoria.Link(&EmpCod, &GrupCod, &TipoMarketplace)
			
			load
		Endif
	
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserLocalizar = !'<i class="fas fa-pen"></i>'
	&UserLocalizar.Link = wcAddCategoria.Link(&EmpCod, &GrupCod, &TipoMarketplace)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'getCategoriaMarketplace'

	//	GrupMrkCatSku
	
	For Each Order EmpCod, GrupCod, GrupMrkApp
		Where EmpCod = &EmpCod
		Where GrupCod = &GrupCod
		Where GrupMrkApp = &TipoMarketplace
		
		&GrupMrkCatSku = GrupMrkCatSku
		
		Exit
	EndFor
	
	if not &GrupMrkCatSku.IsEmpty()
		do 'getNomeMarket'
	Endif

EndSub

Sub 'getNomeMarket'

	For Each ORder MrkCatApp, MrkCatCod
		Where MrkCatApp = &TipoMarketplace
		Where MrkCatCod = &GrupMrkCatSku
		
		&NomeCategoria = MrkCatNom
		Exit
	EndFor

EndSub


]]></Source>
