      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWpContext.Call(&Context) 
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	
	&Padobs = &PisCofins + &Tipo
	padraousuario.Call('G', 'WPNOTASPROPRODUTOS', &Context.PesCod, &Context.EmpCod, &Padobs, &PadDtamod)
	
	RetornaAutorizacao.Call('WPNOTASPORCFOP', Status_SimNao.Sim, 1, &AutNiv)
	&NfeDtaEms_to = serverdate()
	&NfeDtaEms = &NfeDtaEms_to - 30
	
	
	&NfeProTer = Nota_ProPriaTerceira.PROPRIA

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	do 'GetCfop'
	do 'GetPessoa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&Padobs = &PisCofins + &Tipo
	padraousuario.Call('G', 'WPNOTASPROPRODUTOS', &Context.PesCod, &Context.EmpCod, &Padobs, &PadDtamod)
//	Do Case
//		Case &TipoEstabelecimento = 'O' //OFICINA
			AtualizaDataFaturadoNotas.Call(&EmpCod, &FilCod, &NfeDtaEms, &NfeDtaEms_to)
			RCOOpenWindow1.LinkOpen = RELJAS039_Monofasicos.Link(&EmpCod, &FilCod, &NfeDtaEms, &NfeDtaEms_to, &NfeCliCod, &CfoCod, &NfeProTer,&NfeProCod, &PisCofins, &Tipo)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
//		Case &TipoEstabelecimento = 'M' //MERCADO
//			AtualizaDataFaturadoNotas.Call(&EmpCod, &FilCod, &NfeDtaEms, &NfeDtaEms_to)
//			RCOOpenWindow1.LinkOpen = RELJAS039_ProdutosMercado.Link(&EmpCod, &FilCod, &NfeDtaEms, &NfeDtaEms_to, &NfeCliCod, &CfoCod, &NfeProTer,&NfeProCod, &PisCofins)
//			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
//	EndCase

EndEvent

Event &CfoCod.IsValid

	do 'GetCfop'

EndEvent

Event &NfeCliCod.IsValid

	do 'GetPessoa'

EndEvent

Event &ProGraRef.IsValid

	Do 	'GetProduto'

EndEvent

Sub 'GetPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NfeCliCod
		&NfeCliRaz = PesRaz
	When none
		If &NfeCliCod = 0
			&NfeCliRaz = 'TODAS AS PESSOAS'
		Else
			&NfeCliRaz = 'PESSOA NÃO LOCALIZADA'
		EndIf
	EndFor

EndSub

Sub 'GetCfop'

	For Each Order CfoCod
		Where CfoCod = &CfoCod
		&CfoNom = CfoNom
		Exit
	When none
		If &CfoCod = ''
			&CfoNom = 'TODOS OS CFOPS'
		Else
			&CfoNom = 'CFOP NÃO LOCALIZADO'
		EndiF
	EndFor

EndSub

Sub 'GetProduto'

	if not &ProGraRef.IsEmpty()
		For Each Order EmpCod, ProGraRef
			Where EmpCod = &EmpCod
			Where ProGraRef = &ProGraRef
			&NfeProCod = ProCod
			&ProNom = ProNom
		When none
			If &ProGraRef.IsEmpty()
				&ProNom = 'TODAS OS PRODUTOS'
			Else
				&ProNom = 'PRODUTO NÃO LOCALIZADO'
			EndIf
		EndFor
	Endif

EndSub


]]></Source>
