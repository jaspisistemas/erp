      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	padraoUsuario.Call('L', '#WPRATEARCUSTO#', 0, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	&PesCod1 = val(subStr(&PadObs , 1, 8))
	&PesCod2 = val(subStr(&PadObs , 9, 8))
	&PesCod3 = val(subStr(&PadObs , 17, 8))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PesCod1.IsValid

	RetornaNomePessoa.Call(&EmpCod, &PesCod1, &PesRaz1)

EndEvent

Event &PesCod2.IsValid

	RetornaNomePessoa.Call(&EmpCod, &PesCod2, &PesRaz2)

EndEvent

Event &PesCod3.IsValid

	RetornaNomePessoa.Call(&EmpCod, &PesCod3, &PesRaz3)

EndEvent

Event &Percentual1.IsValid

	do 'Rateio'

EndEvent

Event &Percentual2.IsValid

	do 'Rateio'

EndEvent

Event &Percentual3.IsValid

	do 'Rateio'

EndEvent

Event Enter

	RetornaNomePessoa.Call(&EmpCod, &PesCod1, &PesRaz1)
	RetornaNomePessoa.Call(&EmpCod, &PesCod2, &PesRaz2)
	RetornaNomePessoa.Call(&EmpCod, &PesCod3, &PesRaz3)
	
	do 'Rateio'
	
	
	Do Case
		Case &PesRaz1.IsEmpty() and not &PesCod1.IsEmpty()
			MSg('Fornecedor 1 inválido')
		Case &PesRaz2.IsEmpty() and not &PesCod2.IsEmpty()
			MSg('Fornecedor 2 inválido')
		Case &PesRaz3.IsEmpty() and not &PesCod3.IsEmpty()
			MSg('Fornecedor 3 inválido')
		Case &Rateio > 0 and &Rateio < 100
			msg('Rateio precisa ser 0 ou 100!')
		Otherwise
			&Mensagem = str(&PesCod1)
			&PadObs = padL(&Mensagem, 8, '0') 
			&Mensagem = str(&PesCod2)
			&PadObs +=  padL(&Mensagem, 8, '0') 
			&Mensagem = str(&PesCod3)
			&PadObs +=  padL(&Mensagem, 8, '0') 	
			GravaFornecedorpadraopercentual.Call(&EmpCod, &FinAno, &FinMes, &PesCod1, &PesCod2, &PesCod3, 0, &Percentual1, &Percentual2, &Percentual3, 0, &OqueFazer)
			ZeraFornecedor.Call(&EmpCod, 0, &FinAno, &FinMes)
			padraoUsuario.Call('G', '#WPRATEARCUSTO#', &PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
			Return
	EndCase

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)

EndEvent

Sub 'Rateio'

	&rateio = 0
	If not &PesCod1.IsEmpty() and &Percentual1 > 0
		&rateio += &Percentual1
	EndIF
	If not &PesCod2.IsEmpty() and &Percentual2 > 0
		&rateio += &Percentual2
	EndIF
	If not &PesCod3.IsEmpty() and &Percentual3 > 0
		&rateio += &Percentual3
	EndIF

EndSub


]]></Source>
