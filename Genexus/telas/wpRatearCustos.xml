      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[parm(in:&EmpCod, in:&FinAno, in:&FinMes);


prompt(PromptFornecedores, &EmpCod, &PesCod1);
prompt(PromptFornecedores, &EmpCod, &PesCod2);
prompt(PromptFornecedores, &EmpCod, &PesCod3);
prompt(PromptFornecedores, &EmpCod, &PesCod4);
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
