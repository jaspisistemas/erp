      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&OqueFazer = 'T'
	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&OqueFazer.Enabled = 0
	
	do 'getFilial'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do CAse
		Case &FilCod.IsEmpty()
			msg('Filial\CD Estoque não selecionada')
			
		Case &OqueFazer = 'T'
			prcPedidoAmbulanteSaida.Submit(&ProgressId, &ProgressId, &wwpContext.empCod, &FilCod, &FilCodFat, &LctCod, &wwpContext.PesCod, &wwpContext.UserName)
			
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			BtnEnter.Visible = 0
			btn_Cancel.Visible = 0
		Otherwise
			msg('Opção não Disponivel')
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	ApagaProgress.Submit('', &ProgressId)
	Return

EndEvent

Sub 'getFilial'

	&FilCod.Clear()
	&FilCodFat.Clear()
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		
		if FilTip = FIlialTipo.VENDA_AMBULANTE //Exclusivo Venda AMbulante
			&FilCod.AddItem(FilCod, FilCodNom)
		Endif
	
		If FilAmbEms = TAmb.Producao
			&FilCodFat.AddItem(FilCod, FilCodNom)
		Endif
		
	EndFor

EndSub


]]></Source>
