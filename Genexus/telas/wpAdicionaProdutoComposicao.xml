      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&TabPrcCmpItmCod = &parTabPrcCmpItmCod
	
	if &OqueFazer = 'DEL'
		&CompProGraRef.Enabled = 0
		&CompTabPrcRecProQtd.Enabled = 0
	Endif

	do 'loadLancamento'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CompProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CompProGraRef.IsValid

	RetornaProdutoReferencia.Call(&EmpCod, &CompProGraRef, &CompProCod, &CompProGraCod, &CompProGraNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &erroMensagem)
	RetornaValorUnitarioComposicao.Call(&EmpCod, &TabCod, &CompProCod, &CompProGraCod, &CompTabPrc1)
	do 'TotalComposicao'

EndEvent

Event &CompTabPrcRecProQtd.IsValid

	do 'TotalComposicao'

EndEvent

Event Enter

	if &OqueFazer = 'DEL'
		&CompTabPrcRecProQtd = 0
	Endif

	RetornaProdutoReferencia.Call(&EmpCod, &CompProGraRef, &CompProCod, &CompProGraCod, &CompProGraNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &erroMensagem)
	if &IsAchouProduto = true
		GravaComposicaoPrecoVenda.Call(&EmpCod, &TabCod, &ProCod, &ProGraCod, &TabPrcCmpItmCod, &CompProCod, &CompProGraCod, &CompTabPrcRecProQtd, &wwpContext.UserName)
		if &TabPrcCmpItmCod > 0
			Return
		Else
			&TabPrcCmpItmCod = 0
			do 'loadLancamento'
			&CompProGraRef.SetFocus()
		Endif
	Else
		msg(&erroMensagem)
	Endif

EndEvent

Sub 'TotalComposicao'

	&CompTabPrcTotal = &CompTabPrc1 * &CompTabPrcRecProQtd

EndSub

Sub 'loadLancamento'

	&CompProCod.SetEmpty()
	&CompProGraCod.SetEmpty()
	&CompProGraRef.SetEmpty()
	&CompProGraNom.SetEmpty()
	&CompTabPrc1.SetEmpty()
	&CompTabPrcRecProQtd.SetEmpty()
	&CompTabPrcTotal.SetEmpty()
			
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod 
		
		&ProGraRef = ProGraRef
		&ProGraNom = ProNomGra
		Exit
	EndFor
	
	&TabPrcTotal = 0
	For Each Order EmpCod, TabCod, ProCod, ProGraCod, TabPrcCmpItmCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod 
				
		&TabPrcTotal += TabPrcRecTabPrcTot
		
		if &TabPrcCmpItmCod > 0 and &TabPrcCmpItmCod = TabPrcCmpItmCod	

			&CompProCod = TabPrcRecProCod
			&CompProGraCod = TabPrcRecProGraCod

			&CompProGraRef = TabPrcRecProGraRef
			&CompProGraNom = TabPrcRecProNomGra
			&CompTabPrc1 = TabPrcRecTabPrc1
			&CompTabPrcRecProQtd = TabPrcRecProQtd
			&CompTabPrcTotal = TabPrcRecTabPrcTot
			
		EndIF
	EndFor

EndSub


]]></Source>
