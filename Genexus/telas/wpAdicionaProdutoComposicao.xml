      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[parm(in:&OqueFazer, in:&EmpCod, in:&TabCod, in:&ProCod, in:&ProGraCod, in:&parTabPrcCmpItmCod);

prompt(PromptProdutoGradeRef, &EmpCod, &CompProCod, &ProGraCod, &CompProGraRef);
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
