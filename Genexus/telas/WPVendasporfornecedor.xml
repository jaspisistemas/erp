      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	RetornaAutorizacao.Call('WPVENDASPORFORNECEDOR', Status_SimNao.Sim, 1, &AutNiv)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	&PedDtaFat_Go = ServerDate()
	&PedDtaFat = YMDtoD(year(&PedDtaFat_Go),month(&PedDtaFat_Go),1)
	&LctGerFin = Status_SimNao.Sim
	&PedSts = Status_Pedido.FECHADO

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'getFornecedor'

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS099.link(&EmpCod,&FilCod,&ForCod,&ForRaz,&IsInativos,&PedDtaFat,&PedDtaFat_Go,&LctGerFin,&QtdTipo,&PedSts)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event &ForCod.IsValid

	Do 'getFornecedor'

EndEvent

Event Refresh

//	loadwwpContext.Call(&Context)
//	&EmpCod = &Context.EmpCod

EndEvent

Sub 'getFornecedor'

	If &ForCod = 0
		&ForRaz = 'Todos os fornecedores'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &ForCod
			&ForRaz = PesRaz
			Exit
		When none
			&ForRaz = 'Fornecedor não encontrado!'
			Msg('Fornecedor não encontrado!')
			&ForCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
