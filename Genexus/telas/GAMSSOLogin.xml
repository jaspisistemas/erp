      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	TBback.JSEvent('onclick','history.back()')
	//Used when multiple repository connections exist  ////////////////////////////
	&ConnectionInfoCollection = GeneXusSecurity.GAM.GetConnections()
	If &ConnectionInfoCollection.Count > 0 
		//The first connection found is established by default 
		&isOK = GeneXusSecurity.GAM.SetConnection(&ConnectionInfoCollection.Item(1).Name, &Errors)
	EndIf
	///////////////////////////////////////////////////////////////////////////////

	&isRedirect = False
	//Gets last error in the GAM /////////////////////////////
	&Errors = GAMRepository.GetLastErrors()
	If &Errors.Count > 0  AND  &Errors.Item(1).Code <> GAMErrorMessages.UserMustBeAuthenticated
		Do 'DisplayMessages'
	Else
		&SessionValid = GAMSession.IsValid(&Session, &Errors)
		If &SessionValid and not &Session.IsAnonymous
			&URL = GAMRepository.GetLastErrorsURL()
			If &URL.IsEmpty()
				GAMHome()
			Else
				Link(&URL)
			Endif
		Else
			GAMRepository.LoginGAMRemote()
			&Errors = GAMRepository.GetLastErrors()
			If &Errors.Count > 0
				Do 'DisplayMessages'
			Endif
		Endif
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		If &Error.Code <> GAMErrorMessages.SessionExpired
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		Endif
	EndFor

EndSub


]]></Source>
