      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWBALANCO', Status_SimNao.Sim, 3, &AutNiv)

	&EmpCod = &AuxEmpCod
	&FilCod = &AuxFiLCod
	&BalCod = &AuxBalCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 20
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadBalanco'

EndEvent

Event Refresh

	&EmpCod = &AuxEmpCod
	&FilCod = &AuxFiLCod
	&BalCod = &AuxBalCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar.FromImage(ActionDelete)
	&Deletar.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	ProNom.Link = VerProduto.Link('DashBoard', EmpCod, ProCod)
	ProNom.LinkTarget = '_blank'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDeletar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Deletar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Deletar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Deletar.Result = !'Yes'
		Do 'Do Deletar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharBal'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWBalanco.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnImprimir'

	wpImprimirBalanco.Popup(&EmpCod, &FilCod, &BalCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAbrirBalanco'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	AbrirBalanco_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event AbrirBalanco_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpAbrirEstoque.Create(&AuxEmpCod, &AuxFilCod, &AuxBalCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event AbrirBalanco_Modal.Close

	WWbALANco.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Deletar'

	&AutNiv = RetornaAutorizacao.UDP('FECHARBALANCOESTOQUE', Status_SimNao.Nao, 1)
		if &AutNiv > 0
			RemoveProdutoBalanco.Call(EmpCod, FilCod, BalCod, ProCod, ProGraCod, &RemovidoMensagem)
			If not &RemovidoMensagem.IsEmpty()
				Refresh
				msg(&RemovidoMensagem)
			EndIf
		Else
			msg('Não autorizado a Fechar Balanco entao nao pode remover item de Balanço Fechado!')
		Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'loadBalanco'

	For each Order EmpCod, FilCod, BalCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where BalCod = &BalCod
			&FilCodNom = FilCodNom
			&BalSts = BalSts
			If BalSts <> Status_Pedido.FECHADO
				wwbalanco.Link()
			EndIF
		Exit 
	EndFor

EndSub


]]></Source>
