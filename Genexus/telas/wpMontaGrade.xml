      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProCodNom  = ProRefNom
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 300
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount

EndEvent

Event Grid.Load

	For &sdtModalidadesItem in &sdtModalidades
		&gridMdpCod = &sdtModalidadesItem.MdpCod
		&MdpCodNom = &sdtModalidadesItem.MdpCodNom

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&BtnDelete.FromImage(ActionDelete)
	&BtnDelete.TooltipText = "Remover modalidade"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMontaGrade'

	&IsBloqueio = false
	&BloMdpCod = 0
	For &sdtModalidadesItem in &sdtModalidades
		if &sdtModalidadesItem.MdpBlq = true
			&BloMdpCod = &sdtModalidadesItem.MdpCod
			&IsBloqueio = true
			Exit
		EndIF
	EndFor
	
	Do Case
		CAse &IsBloqueio = true and &sdtModalidades.Count > 1
			msg('Modalidade não permite Alteração, então não é possível multiplas modalidades!')
		CAse &sdtModalidades.Count > 0
			do 'Redefinir'
			prcMontaGrade.Call(&EmpCod, &ProCod, &BloMdpCod, &sdtModalidades)
			
			wpEditaGrade.Link(&EmpCod, &ProCod, &DeOndeVem)
		Otherwise
			msg('Selecione pelo menos uma modalidades!')
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnCancelar'

	Do Case 
		CAse &DeOndeVem = 'Produto' or &DeOndeVem = 'Produtos'
			Produtos.Link('', TrnMode.Insert, &EmpCod, 0, '')
		CAse &DeOndeVem = 'ImpProduto'
	   		ImpProduto.Link(TrnMode.Insert, &EmpCod, 0)
		Case &DeOndeVem = 'WWIMPPRODUTO'
			wwImpProduto.Link()
		Case &DeOndeVem = 'WWPRODUTO'
			wwProduto.Link()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&IsExiste = false
	
	For &sdtModalidadesItem in &sdtModalidades
		If &sdtModalidadesItem.MdpCod = &MdpCod

	

			&IsExiste = true
			Exit
		EndIF
	EndFor
	
	If &IsExiste = false
		For Each Order EmpCod, MdpCod
			Where EmpCod = &EmpCod
			Where MdpCod = &MdpCod
			&sdtModalidadesItem = new()
			&sdtModalidadesItem.MdpCod = &MdpCod
			&sdtModalidadesItem.MdpCodNom = MdpCodNom
			&sdtModalidadesItem.MdpBlq = MdpBlq
			&sdtModalidades.Add(&sdtModalidadesItem)
			Exit
		EndFor	
		grid.Refresh()
	Else
		msg('Modalidade já selecionada!')
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &BtnDelete.Click

	For &sdtModalidadesItem in &sdtModalidades
		If &sdtModalidadesItem.MdpCod = &gridMdpCod
		
		&Index = &sdtModalidades.IndexOf(&sdtModalidadesItem)
		&sdtModalidades.Remove(&Index)
		Exit
		EndIf
	EndFor
	grid.Refresh()

EndEvent

Sub 'Redefinir'

	for Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod > 1
		
		RetornaIsPodeExcluirProdutoGrade.Call(&Context.EmpCod, &Context.FilCod, ProCod, ProGraCod, &IsEstaEmAlgumaReceita, &IsPossuiPedidos)
		
		DeletaProduto.Call(EmpCod, ProCod, ProGraCod, &IsPossuiPedidos,&Context.UserName)
	EndFor

EndSub


]]></Source>
