      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPREMOVERPESSOA', Status_SimNao.Sim, 3, &AutNiv)
	loadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&DstPesCod = FilPesCod
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &OriPesCod
		&OriPesRaz = PesRaz
		Exit
	EndFor

	Do 'PessoaDestino'

EndEvent

Event Enter

	if &OriPesCod = &Context.PesCod or &OriPesCod = 1 or &DstPesCod = 0
		msg('Não é possível excluir o seu próprio cadastro e nem o cadastro 1 e o destino não pode ser 0.')
	Else
		
		&Random = Random() * 10000000000
		&ProgressId = 'agrPess' + trim(Str(&Random))
		
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		AgrupaPessoas.Submit('agrupPesso', &ProgressId, &EmpCod, &OriPesCod, &DstPesCod)
		
		if 1=2 //JDF EM DESENVOLVIMENTO
			ExcluirPessoa.Call()
		Endif
	Endif

EndEvent

Event scaProgressBar1.OnComplete

	return

EndEvent

Event &DstPesCod.IsValid

	do 'PessoaDestino'

EndEvent

Sub 'PessoaDestino'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &DstPesCod
		&DstPesRaz = PesRaz
		Exit
	When none
		&DstPesCod.SetFocus()
		msg('ATENÇÃO, Pessoa não encontrada! Verifique.')
	EndFor

EndSub


]]></Source>
