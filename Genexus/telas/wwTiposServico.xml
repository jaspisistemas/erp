      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&WwpContext)
	RetornaTiposServicoSelecionado.Call(&WwpContext.EmpCod, &SdtTiposServico)
	&SomenteAtivos = (&sdtTiposServico.Count > 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 700

	Do 'AttributesSecurityCode'
	GridsdtTiposServicos_Empowerer.GridInternalName = GridsdtTiposServicos.InternalName
	GridsdtTiposServicos.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridsdtTiposServicosPaginationBar.RowsPerPageSelectedValue = GridsdtTiposServicos.Rows
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&StatusExtra = 'S'
	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtTiposServicosCurrentPage = GridsdtTiposServicos.CurrentPage
	&GridsdtTiposServicosPageCount = GridsdtTiposServicos.PageCount
	&StatusExtra.ColumnHeaderClass = !'WWColumn'
	
	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&Status.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTiposServicos.Load

	&StatusExtra = 'S'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserAction1 = !'<i class="fas fa-pen"></i>'
	&UserAction1.Link = wcAtivarInativarServico.Link(&sdtTiposServico.CurrentItem.TipSerCod)

	&StatusExtra.ColumnClass = iif(&StatusExtra.ToString().Trim() = !"S", !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&auxTipSerCod = TipSerCod
	
	do 'verificaEmpresa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserGrid = !'<i class="fas fa-pen"></i>'
	&UserGrid.Link = wcAtivarInativarServico.Link(TipSerCod)

	Do Case
		Case &Status.ToString().Trim() = !"X"
			&Status.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfoLight WWColumnTagInfoLightSingleCell'
		Case &Status.ToString().Trim() = !"N"
			&Status.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case &Status.ToString().Trim() = !"S"
			&Status.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Otherwise
			&Status.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTiposServicosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtTiposServicosPaginationBar.SelectedPage = !'Previous'
			GridsdtTiposServicos.PreviousPage()
		Case GridsdtTiposServicosPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtTiposServicos.CurrentPage
			&PageToGo += 1
			GridsdtTiposServicos.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtTiposServicosPaginationBar.SelectedPage)
			GridsdtTiposServicos.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTiposServicosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtTiposServicos.Rows = GridsdtTiposServicosPaginationBar.RowsPerPageSelectedValue
	GridsdtTiposServicos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	gridTodos.Visible = (&SomenteAtivos = false)
	GridSomenteAtivados.Visible = (&SomenteAtivos = true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &SomenteAtivos.ControlValueChanged

	Do 'AttributesSecurityCode'
	refresh

EndEvent

Sub 'verificaEmpresa'

	&Status = 'X'
	For Each Order TipSerCod, TipSerEmpCod
		WHere TipSerCod = &auxTipSerCod
		Where TipSerEmpCod = &WwpContext.EmpCod
		Where TipSerEmpIsUse = true
		&Status = 'S'
		Exit
	When None
		For Each Order TipSerCod, TipSerEmpCod
			WHere TipSerCod = &auxTipSerCod
			Where TipSerEmpCod = &WwpContext.EmpCod
			Where TipSerEmpIsUse = false
			&Status = 'N'
			Exit
		EndFor
	EndFor

EndSub


]]></Source>
