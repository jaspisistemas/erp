Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 700
	
	WWPNotificationId.Visible = False
	WWPNotificationLink.Visible = False
	WWPNotificationMetadata.Visible = False

	Grid.Rows = Page.Rows
	Form.Caption = 'Visualize todas as Notificações'

	Do 'PrepareTransaction'
	Do 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	NoNotifications.Visible = True
	Grid.Visible = False

EndEvent

Event Grid.Load

	NoNotifications.Visible = False
	Grid.Visible = True

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (Not WWPNotificationLink.IsEmpty())
		Visualize.Visible = True
	Else
		Visualize.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	NotificationItemIcon.Caption = Format(!"<i class='%1 %2'></i>", ThemeClass:NotificationFontIcon, WWPNotificationIcon)
	&WWPNotificationCreated = WWPNotificationCreated
	If WWPNotificationIsRead
		MarkAsRead.Caption = !'<i class="fas fa-envelope DiscussionsSendIcon"></i>'
		MarkAsRead.TooltipText = "Marcar como não lido"
		WWPNotificationTitle.Class = ThemeClass:SimpleCardAttributeTitleLight
	Else
		MarkAsRead.Caption = !'<i class="fas fa-envelope-open DiscussionsSendIcon"></i>'
		MarkAsRead.TooltipText = "Marcar como lido"
		WWPNotificationTitle.Class = ThemeClass:SimpleCardAttributeTitle
	EndIf

	Visualize.TooltipText = "Ver tela"

EndEvent

Event 'DoVisualize'

	WWPBaseObjects.Notifications.Common.WWP_VisualizeNotification(WWPNotificationId)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMarkAsRead'

	WWPBaseObjects.Notifications.Common.WWP_ChangeNotificationStatus.SetNotificationReadUnreadById(WWPNotificationId)
	GlobalEvents.Master_RefreshHeader()
	Grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMarkAllAsRead'

	WWPBaseObjects.Notifications.Common.WWP_ChangeNotificationStatus.SetAllNotificationsOfLoggedUserRead()
	GlobalEvents.Master_RefreshHeader()
	Grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

