      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	GridVeiculo.Rows = Page.Rows
	&GridVeiculoCurrentPage = 1
	&GridVeiculoCurrentPage.Visible = False
	&GridVeiculoPageCount = -1
	GridVeiculoPaginationBar.RowsPerPageSelectedValue = GridVeiculo.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext(&Context)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridVeiculoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridVeiculoPageCount	= GridVeiculo.PageCount
	&GridVeiculoCurrentPage	= GridVeiculo.CurrentPage
	&GridVeiculoRows		= GridVeiculo.Rows

EndEvent

Event GridVeiculo.Load

	&GridVeiculoPageCount	= 1
	&GridVeiculoRows		= GridVeiculo.Rows
	&Item					= 0
	
	For Each Order EmpCod, FilCod, OpeCod
		Where EmpCod	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&gridOpeVeiCod		= OpeVeiCod
		&gridOpeVeiUF		= OpeVeiUF
		&gridOpeVeiPla		= OpeVeiPla

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Eliminar = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&Item += 1
		If &Item	=	&GridVeiculoRows
			&GridVeiculoPageCount 	+= 1
			&Item 					= 0
		EndIf

		Load
	EndFor

EndEvent

Event GridVeiculoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridVeiculoPaginationBar.SelectedPage = !'Previous'
			&GridVeiculoCurrentPage -= 1
			GridVeiculo.PreviousPage()
		Case GridVeiculoPaginationBar.SelectedPage = !'Next'
			&GridVeiculoCurrentPage += 1
			GridVeiculo.NextPage()
		Otherwise
			&PageToGo.FromString(GridVeiculoPaginationBar.SelectedPage)
			&GridVeiculoCurrentPage = &PageToGo
			GridVeiculo.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridVeiculoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridVeiculo.Rows = GridVeiculoPaginationBar.RowsPerPageSelectedValue
	&GridVeiculoCurrentPage = 1
	GridVeiculo.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WpOperacaoTransporteRetificar(!'Retificar', !'Completo', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		Do Case
			Case &OpeTerRet = False
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Você deve estar ciente da retificação.', DVMessageType.regular, "", DVMessageBoolean.True,""))
				&OpeTerRet.SetFocus()
				
			OtherWise
				Do 'SaveVariablesToWizardData'
				prcNovoEFrete_Login.Call(&Token, &ProtocoloServico, &StatusLogin)
				If &StatusLogin = 200
					prcNovoEFrete_Retificar.Call(&WebSessionKey, &Token, &StatusRet)	
					If &StatusRet = 200
						Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", 'Operação retificada com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))
						WpOperacaoTransporteRetificar(!'Retificar', !'Completo', false)
					EndIf
				Else
					Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &StatusLogin.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
				EndIf
				If not &Token.Trim().IsEmpty()
					prcNovoEFrete_Logout.Call(&Token, &StatusLogOut)
				Endif
		EndCase
		
	EndIf

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	WpOperacaoTransporteRetificar(!'Retificar', !'Confirmar', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Doaddveiculo'

	FormataPLACA.Call(&EmpCod, &OpeVeiPla, &OpeVeiPla)
	Do 'VerificaVeiculoADD'
	
	If &VeiculoCadastrado	= 0
		OperacaoTransporte_Veiculo.Call('ADD', &EmpCod, &FilCod, &OpeCod, 0, &OpeVeiPla)
		
		&PadObs = &OpeVeiPla
		PadraoUsuario.Call('G', 'VEICULO_EFRETE', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		
		&OpeVeiPla.SetEmpty()
		GridVeiculo.Refresh()
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!",'Este veículo já está cadastrado na viagem.', DVMessageType.regular, "", DVMessageBoolean.True,""))
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&OpeVeiPla = &WizardData.Retificar.OpeVeiPla
	&OpeTerRet = &WizardData.Retificar.OpeTerRet
	&OpeNroCiot = &WizardData.Retificar.OpeNroCiot
	&EmpCod = &WizardData.Retificar.EmpCod
	&FilCod = &WizardData.Retificar.FilCod
	&OpeCod = &WizardData.Retificar.OpeCod
	&VeiCod = &WizardData.Retificar.VeiCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&EmpCod		=	&WizardData.Confirmar.EmpCod
		&FilCod		= 	&WizardData.Confirmar.FilCod
		&OpeCod		= 	&WizardData.Confirmar.OpeCod
		&OpeNroCiot	= 	&WizardData.Confirmar.OpeNroCiot
	EndIf

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Retificar.OpeVeiPla = &OpeVeiPla
	&WizardData.Retificar.OpeTerRet = &OpeTerRet
	&WizardData.Retificar.OpeNroCiot = &OpeNroCiot
	&WizardData.Retificar.EmpCod = &EmpCod
	&WizardData.Retificar.FilCod = &FilCod
	&WizardData.Retificar.OpeCod = &OpeCod
	&WizardData.Retificar.VeiCod = &VeiCod
	&WizardData.Retificar.GridVeiculo.Clear()
	For Each Line in GridVeiculo
		&GridVeiculoItem = new()
		&GridVeiculoItem.AuxVeiCod = &AuxVeiCod
