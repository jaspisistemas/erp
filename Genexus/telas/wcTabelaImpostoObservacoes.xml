        <Source><![CDATA[
Event Start

	&sdtObservacaoNota.FromJson(&ObservacaoLongVarchar)
	&sdtObservacaoNota.Sort('ObsSts')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtObservacaoNotas_Empowerer.GridInternalName = GridsdtObservacaoNotas.InternalName
	GridsdtObservacaoNotas.Rows = 50
	GridErro_Empowerer.GridInternalName = GridErro.InternalName
	GridErro.Rows = 50

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	GridErro.Visible = 0
	GridsdtObservacaoNotas.Visible = 0
	For &sdtObservacaoNotaItem in &sdtObservacaoNota
		if &sdtObservacaoNotaItem.ObsSts <> 'Z'
			GridsdtObservacaoNotas.Visible = 1
		Endif
		
		if &sdtObservacaoNotaItem.ObsSts = 'Z'
			GridErro.Visible = 1
		Endif
	
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ObsNom.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtObservacaoNotas.Load

	For &sdtObservacaoNotaItem in &sdtObservacaoNota
		if &sdtObservacaoNotaItem.ObsSts <> 'Z'			
			&ObsNom = &sdtObservacaoNotaItem.ObsNom			
			&ObsSts = &sdtObservacaoNotaItem.ObsSts

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	Do Case
		Case &ObsSts = 'X'
			&ObsNom.ColumnClass = !'WWColumn WWColumnLineThrough WWColumnLineThroughFirstColumn'
		Case &ObsSts = 'S'
			&ObsNom.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTag WWColumnTagWarningFirstColumn'
		Case &ObsSts = 'N'
			&ObsNom.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTag WWColumnTagInfoFirstColumn'
		Otherwise
			&ObsNom.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			Load
		EndIf		
	EndFor

EndEvent

Event GridErro.Load

	For &sdtObservacaoNotaItem in &sdtObservacaoNota
		if &sdtObservacaoNotaItem.ObsSts = 'Z'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			&Mensagem.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTag WWColumnTagDangerFirstColumn'
		
			&Mensagem = &sdtObservacaoNotaItem.ObsNom
			Load
		EndIf
	EndFor

EndEvent


