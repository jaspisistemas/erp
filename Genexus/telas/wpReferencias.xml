      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPREFERENCIASCOMERCIAIS', Status_SimNao.Nao, 3, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	&acoesSelecionarData = new()
	
	&acoesSelecionarDataItem = new()
	&acoesSelecionarDataItem.Title = 'Deletar Anexos Pedido'
	&acoesSelecionarDataItem.EventKey = !'Deletarrefenrencias'
	&acoesSelecionarDataItem.IsDivider = False
	&acoesSelecionarData.Add(&acoesSelecionarDataItem)
	
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'selecionados'

EndEvent

Event Refresh

	do 'selecionados'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&ActionSelecione.ColumnHeaderClass = !'WWActionColumn'
	&DeleteReferencia.ColumnHeaderClass = !'WWIconActionColumn'
	&AlteraReferencia.ColumnHeaderClass = !'WWIconActionColumn'
	PesRefEmpRaz.ColumnHeaderClass = !'WWColumn'
	PesRefDta.ColumnHeaderClass = !'WWColumn'
	PesRefVlrUltDta.ColumnHeaderClass = !'WWColumn'
	PesRefObs.ColumnHeaderClass = !'WWColumn'
	PesRefClaTip.ColumnHeaderClass = !'WWColumn'
	PesRefFon.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionSelecione.FromImage(DDOMultiselSelOption)
	&ActionSelecione.TooltipText = ""
	
	&DeleteReferencia = !'<i class="fa fa-times"></i>'
	If (&AutNiv > 0)
		&DeleteReferencia.Class = !'Attribute'
	Else
		&DeleteReferencia.Class = !'Invisible'
	Endif
	&AlteraReferencia = !'<i class="fa fa-pen"></i>'
	If (&AutNiv > 0)
		&AlteraReferencia.Class = !'Attribute'
	Else
		&AlteraReferencia.Class = !'Invisible'
	Endif

	&ActionSelecione.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWActionColumn WWColumnDanger WWColumnDangerFirstColumn', !'WWActionColumn')
	&DeleteReferencia.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWIconActionColumn WWColumnDanger', !'WWIconActionColumn')
	&AlteraReferencia.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWIconActionColumn WWColumnDanger', !'WWIconActionColumn')
	PesRefEmpRaz.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWColumn WWColumnDanger', !'WWColumn')
	PesRefDta.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWColumn WWColumnDanger', !'WWColumn')
	PesRefVlrUltDta.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWColumn WWColumnDanger', !'WWColumn')
	PesRefObs.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWColumn WWColumnDanger', !'WWColumn')
	PesRefClaTip.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWColumn WWColumnDanger', !'WWColumn')
	PesRefFon.ColumnClass = iif(PesRefClaTip = ClassificacaoReferencia.AVALIAR, !'WWColumn WWColumnDanger', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageSize = Page.Rows
	&GridRecordCount = Grid.RecordCount
	
	&PedAnxCod = PesRefCod
	do 'verificaSelecionado'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ddo_acoesSelecionar.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case ddo_acoesSelecionar.ActiveEventKey = !'Deletarrefenrencias'
			Do 'Do Deletarrefenrencias'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAddReferencia'

	if &AutNiv > 0
		wpCadastraReferencia.Popup(TrnMode.Insert, &EmpCod, &PesCod, 0)
		grid.SetFocus()
		Refresh
	else
		msg('Não Autorizado a Inserir Referencia Comercial!')
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Deletarrefenrencias'

	wpConfirmRemoveReferencia.Popup(EmpCod, PesCod, 0, &sdtAnexos.ToJson())
	&sdtAnexos.Clear()
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbadd.Visible = (&AutNiv > 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event PesRefEmpRaz.Click

	wpCadastraReferencia.Popup(TrnMode.Display, EmpCod, PesCod, PesRefCod)

EndEvent

Event &DeleteReferencia.Click

	if (&AutNiv <= 2 and (PesRefDta.IsEmpty() or PesRefDta.IsNull())) or &AutNiv > 2
		wpConfirmRemoveReferencia.Popup(EmpCod, PesCod, PesRefCod, '')
		Refresh
	Else
		msg('Não Autorizado a Eliminar, Data de Contato já preenchida!')
	EndIF

EndEvent

Event &AlteraReferencia.Click

//	if &AutNiv < 2 and not PesRefDta.IsEmpty()
//		msg('Não autorizado a Alterar, Data de Contato já preenchida!')
//	Else
		wpCadastraReferencia.Popup(TrnMode.Update, EmpCod, PesCod, PesRefCod)
		Refresh
//	EndiF

EndEvent

Event &ActionSelecione.Click

	if &AnexSel = true
		&ActionSelecione.FromImage(DDOMultiselOption)
		&AnexSel = false
		
		For &sdtAnexosItem in &sdtAnexos
			if &sdtAnexosItem.AnxCod = PesRefCod 
				&Index = &sdtAnexos.IndexOf(&sdtAnexosItem)
				&sdtAnexos.Remove(&Index)					
				Exit
			EndIF				
		EndFor			
	Else
		&ActionSelecione.FromImage(DDOMultiselSelOption)
		&AnexSel = true
		
		&sdtAnexosItem = new()
		&sdtAnexosItem.AnxCod = PesRefCod
		&sdtAnexos.Add(&sdtAnexosItem)
	Endif
	
	do 'selecionados'

EndEvent

Event limpar_campo.Click

	&sdtAnexos.Clear()
	tbAnexoSelecionado.Visible = &sdtAnexos.Count > 0
	refresh

EndEvent

Sub 'verificaSelecionado'

	&AnexSel = false
	&ActionSelecione.FromImage(DDOMultiselOption)
	For &sdtAnexosItem in &sdtAnexos
		if &sdtAnexosItem.AnxCod = &PedAnxCod 
			&AnexSel = true
			&ActionSelecione.FromImage(DDOMultiselSelOption)
			Exit
		Endif	
	EndFor

EndSub

Sub 'selecionados'

	tbAnexoSelecionado.Visible = &sdtAnexos.Count > 0
	
	AnexosSelecionados.Caption = format('(%1) selecionados', trim(str(&sdtAnexos.Count)))

EndSub


]]></Source>
