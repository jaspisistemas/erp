        <Source><![CDATA[
Event Start

	EmbeddedPage.Visible = 0
	txtMsg.ForeColor  = RGB(0,160,40)
	Sucesso.Visible = 0
	TableAttributes.Visible = 1
	txtMsg.Caption = ''
	
	loadWWPContext.Call(&Context)
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon067_ModeloNFCe, &TCon067_ModeloNFCe)

	&domBrowserVersao = &Context.BrowserVersion //USE SEMPRE ASSIM PARA LOCALIZAR FUTURAMENTE ONDE USA A VERSAO DO BROWSER ATRAVES DO DOMINIO

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable2.Height = 40
	TableAttributes.Height = 300
	Sucesso.Height = 300
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&domBrowserVersao.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Random = Random() * 1000000000
	&ProgressId = 'Aut_NFCe' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	RecepcaoNFe.Submit('RecepcaoNFe', &ProgressId, &EmpCod, &FilCod, &NfeCod, &SolCod)
	//BTnBtn1.Visible = 0
	//BTnBtn2.Visible = 0
	BTnBtn3.Visible = 0

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedVlrLiq = PedVlrLiq
		if PedSts <> Status_Pedido.ABERTO
			btnVoltarFechamento.Visible = 0
		Endif
	
		Exit
	EndFor

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCodFat
		Where NfeCod = &NfeCod
		&NfeNum = NfeNum
		Exit
	EndFor
	
	do 'impressaoDireta'

EndEvent

Event 'DoBtn1'

 2

	Do Case
		Case &TelaOrigem = 'PDV_M'
			GravaCapaPedidoPDV.Call(&Context.EmpCod, &Context.FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
			Pdvm_venda.Link(&AuxPedCod)
			
		Case &TelaOrigem = 'WWPEDIDOBALCAO' or &TelaOrigem = 'PEDIDOBALCAO'
			GravaCapaPedidoPDV.Call(&EmpCod, &FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
			wwpVendas_3.Link('WWPEDIDOBALCAO', &EmpCod, &FilCod, &AuxPedCod, 0)
			//wwpVendas2.Link('WWPEDIDOBALCAO', 2, &EmpCod, &FilCod, &AuxPedCod, 0)
			
		Case &TelaOrigem = 'WWORDEMSERVICO' or &TelaOrigem = 'ORDEMSERVICO'
			GravaCapaPedidoPDV.Call(&EmpCod, &FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
			//wwpVendas2.Link('WWORDEMSERVICO', 2, &EmpCod, &FilCod, &AuxPedCod, 0)
			wwpVendas_3.Link('WWORDEMSERVICO', &EmpCod, &FilCod, &AuxPedCod, 0)
		
		Case &TelaOrigem = 'WWOFICINAMECANICA' or &TelaOrigem = 'OFICINAMEC'
			GravaCapaPedidoPDV.Call(&EmpCod, &FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
			//wwpVendas2.Link('WWOFICINAMECANICA', 2, &EmpCod, &FilCod, &AuxPedCod, 0)
			wwpVendas_3.Link('WWOFICINAMECANICA', &EmpCod, &FilCod, &AuxPedCod, 0)
			
		Case &TelaOrigem = 'WWLOCACAOPRODUTOS'
			wwpvendasCliente.Call('WWLOCACAOPRODUTOS', &EmpCod, &FilCod, 0)
			
		Otherwise
			&Link = &TelaOrigem.Trim() + '.aspx'
			link(&Link)
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraPDV'

	Do Case
		Case &TelaOrigem = 'WWPEDIDOBALCAO' or &TelaOrigem = 'PEDIDOBALCAO'
			wwPedidoBalcao.Link()
		Case &TelaOrigem = 'WWORDEMSERVICO' or &TelaOrigem = 'ORDEMSERVICO'
			wwOrdemServico.Link()
		Case &TelaOrigem = 'WWOFICINAMECANICA' or &TelaOrigem = 'OFICINAMEC'
			wwOficinaMecanica.Link()
		Case &TelaOrigem = 'WWLOCACAOPRODUTOS'
			WWLOCACAOPRODUTOS.Link()
		Otherwise
			&Link = &TelaOrigem.Trim() + '.aspx'
			Link(&Link)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn2'

	wwnotasNFCe.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarFechamento'

	wppedidopedido_fechado.Link(&TelaOrigem, &EmpCod, &FilCod, &PedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn4'

 8
 
	if &OqueFazer1.Count > 0
	 	&PadOBs = &OqueFazer1
		padraoUsuario.Call('G', 'WPEMITENFCE_IMPRESSAODIRETA', &Context.PesCod, &Context.EmpCod, &PadOBs, &PAdDtaMod)
		&EmpImpCod1 = val(Substr(&OqueFazer1, 6, 8))
	 	do CAse
			Case Substr(&OqueFazer1, 1, 2) = '3B' // PEDIDO CUPOM DELIVERY
				prcGravaImpressao.Call(&EmpCod, &EmpImpCod1, 'RELJAS124_B', &FilCod, &PedCod, &Context.PesCod, '', 0, &FiDtaIni)
				
			Otherwise
				wpConfirmaImpressaoPedido.Popup(&EmpCod, &FilCod, &PedCod)
		EndCase
	Else
		wpConfirmaImpressaoPedido.Popup(&EmpCod, &FilCod, &PedCod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn3'

	9
	&IsVisualiza = false
	do 'imprimenota'
	
	btnBtn1.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVisualizar'

	&IsVisualiza = true
	do 'imprimenota'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
					
		txtMsg.Caption = ProgressLogXml
		if &ImpressaoAutomatica = 'S'
			&IsVisualiza = false
			do 'imprimenota'
		Endif
		Exit
	EndFor
	
	apagaProgress.Submit('', &ProgressId)
	btnBtn1.SetFocus()

EndEvent

Event Refresh

	btnbtn4.SetFocus()

EndEvent

Sub 'impressaoDireta'

	btnVisualizar.Visible = 0
	padraoUsuario.Call('L', 'WPEMITENFCE_IMPRESSAODIRETA', &Context.PesCod, &Context.EmpCod, &PadOBs, &PAdDtaMod)
	
	&Istem_CUPOM1 = RetornaTemImpressora.Udp(&Context.EmpCod, domTipoImpressora.CUPOM1, domTipoImpressora.CUPOM2)
	tbPedidoImpressaoDireta.Visible = 0
	&OqueFazer1.clear()
	
	if &Istem_CUPOM1 = true
		&collFilCod.Clear()
		DpFilialAcesso.Call(&Context.EmpCod,&Context.PesCod, &sdtFilialAcesso)
		for &sdtFilialAcessoItem in &sdtFilialAcesso
			&collFilCod.Add(&sdtFilialAcessoItem.PesFilAce)
		EndFor

		&ModeloPedido = 'IMPRESSÃO NFCE - TICKET'
		For Each Order EmpCod, EmpImpPC, EmpImpNom
			Where EmpCod = &Context.EmpCod
			where EmpImpTip = domTipoImpressora.CUPOM1 or EmpImpTip = domTipoImpressora.CUPOM2
			Where EmpImpFilCod.IsEmpty() or EmpImpFilCod.IsNull() or EmpImpFilCod in &collFilCod
			
			&Mensagem = &ModeloPedido + '|' + EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
			&CodigoImpressora = '3B   ' + PadL(str(EmpImpCod), 8, ' ')
			&OqueFazer1.AddItem(&CodigoImpressora, &Mensagem)
		EndFor
	
		tbPedidoImpressaoDireta.Visible = 1
		btnVisualizar.Visible = 1
		&OqueFazer1 = trim(Substr(&PadOBs, 1, 15))
	Endif
	&Mensagem.SetEmpty()
	
	&ImpressaoAutomatica = trim(Substr(&PadOBs, 16, 1))

EndSub

Sub 'imprimenota'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCodFat
		Where NfeCod = &NfeCod
						
		If not NfeArqXml.IsEmpty() and NfeSts = Status_NFe.Autorizada
			GravarStatusIMpressao.Submit('GravarStatusIMpressao', EmpCod, FilCod, NfeCod, 0)
			
			BTnBtn3.Visible = 1
			TableAttributes.Visible = 0
			&Rando = retornaSoNumeros.Udp(serverTime())
			&Documento =  'TICKET' + &Rando.Trim() //+ '.pdf'
			
			if &IsVisualiza = true or &OqueFazer1.Count <= 0
				do 'abreRCO'
			Else
				if &OqueFazer1.Count > 0
				 	&PadOBs = padl(trim(&OqueFazer1), 15, ' ')
					&PadOBs+= &ImpressaoAutomatica
					padraoUsuario.Call('G', 'WPEMITENFCE_IMPRESSAODIRETA', &Context.PesCod, &Context.EmpCod, &PadOBs, &PAdDtaMod)
					&EmpImpCod1 = val(Substr(&OqueFazer1, 6, 8))
				 	do CAse					
						
						Case Substr(&OqueFazer1, 1, 2) = '3B' // PEDIDO CUPOM DELIVERY
							prcGravaImpressao.Call(&EmpCod, &EmpImpCod1, 'RELJAS057', &FilCod, 0, &Context.PesCod, '', &NfeCod, &FiDtaIni)
							
						Otherwise
							do 'abreRCO'
					EndCase
				Else
					do 'abreRCO'
				Endif
			Endif
		
			Sucesso.Visible = 1
		EndIF
		
		Exit
	EndFor

EndSub

Sub 'AbreRCO'

	do Case
		case &TCon067_ModeloNFCe = 'B' and (&domBrowserVersao >= 50 and &domBrowserVersao <= 70)
			EmbeddedPage.Source = RELJAS057_ToPrintA5.Link(&EmpCod, &FilCodFat, &NfeCod, &Documento)
			
		case &TCon067_ModeloNFCe <> 'B' and (&domBrowserVersao >= 50 and &domBrowserVersao <= 70)
			EmbeddedPage.Source = RELJAS057_ToPrint.Link(&EmpCod, &FilCodFat, &NfeCod, &Documento)
			
		case &TCon067_ModeloNFCe = 'B' 			
			&Window.Url = RELJAS057_ToSreenA5.Link(&EmpCod, &FilCodFat, &NfeCod, &Documento)
			&Window.Height = 800
			&Window.Width = 800
			&Window.Open()
			
		Otherwise			
			&Window.Url = RELJAS057_ToSreen.Link(&EmpCod, &FilCodFat, &NfeCod, &Documento)
			&Window.Height = 800
			&Window.Width = 800
			&Window.Open()
			
		
	EndCase

EndSub


]]></Source>
