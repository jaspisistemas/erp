      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
			TextBlockTitle.Caption = 'Obtendo retorno, Autorização do CT-e: ' + trim(str(CteNum))
			&CteFilCod = FilCod
		Exit
	EndFor
	tbDuplicatas.Visible = false
//	Do 'loadDuplicatas'
	&Varchar = serverTime()
	
//	If &IsErro = false
//		embPageBoleto.Source = RELJAS045.Link(&EmpCod, &FilCod, &Varchar)
//	Else
//		gxUITabsPanel_imprBo.HideTab(1)
//	EndIF

//	If &sdtGerarDuplicata.Count > 0
//		&WebSession.Set('IMPRIMEDUPLICATA', &sdtGerarDuplicata.toXml())
//		EmbPageDuplicata.Source = RELJAS019.Link(&EmpCod, &FilCod, &Varchar)
//	Else
//		gxUITabsPanel_imprBo.HideTab(2)
//	EndIf

	com.ForeColor  = RGB(0,160,40)
	com1.ForeColor = RGB(0,160,40)
	&ProgressLogXml = ''
	txtMsg.Caption = ''
	txtMsg.ForeColor = RGB(210,130,0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Random = Random() * 1000000000
	&ProgressId = 'autoriCTe' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	RecepcaoCte.Submit('RecepcaoCTe', &ProgressId, &EmpCod, &FilCod, &CteCod, &SolCod)
	TableEmbPage.Visible = 0	

	BTnBtn3.Visible = 0

EndEvent

Event 'DoBtn2'

	EmbPage1.Source = ''
	
	WWCTe.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn3'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		If not CteArqXml.IsEmpty() and CteSts = Status_NFe.Autorizada
			GeraPdfDacte_web.Call(EmpCod, FilCod, CteCod, &UrlPDF, &UrlFisico)
		EndIF
		Exit
	EndFor
	
	If not &UrlPDF.IsEmpty()
		RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&ProgressLogXml = '')
		DVPanel_TableAttributes_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributes_Cell.Class = !'col-xs-12'
	EndIf
	If not(&ProgressLogXml <> '')
		DVPanel_Retorno_Cell.Class = !'Invisible'
	Else
		DVPanel_Retorno_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId		
		
		&ProgressLogXml = ProgressLogXml
		txtMsg.Caption = &ProgressLogXml
		do 'imprimenota'
		Exit
	EndFor
	
	Do 'AttributesSecurityCode'
	
	ApagaProgress.Submit('', &ProgressId)

EndEvent

Sub 'imprimenota'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		If not CteArqXml.IsEmpty() and CteSts = Status_NFe.Autorizada
			GravarStatusIMpressaoCte.Submit('GravarStatusIMpressao', EmpCod, FilCod, CteCod,0)
			
			&Random = random() * 100000000
			&URLFisico = trim(str(&Random))+ CteChv.Trim()
			
			BTnBtn3.Visible = 1
			If CteModCod = '57'
				EmbPage1.Source = RELJAS085.LInk(EmpCod, FilCod, CteCod, &URLFisico)
			Else
				EmbPage1.Source = RELJAS160_Print.link(EmpCod, FilCod, CteCod, &URLFisico)
			EndIF
			
		EndIF
		
		Exit
	EndFor

EndSub


]]></Source>
