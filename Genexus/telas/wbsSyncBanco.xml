        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&Context)

	For Each Order EmpCod
		Where EmpCod = &Context.EmpCod
		&EmpCodSec = EmpCodSec
		
		Exit
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod
		Where EmpCod = &Context.EmpCod
		&EmpCodSec = EmpCodSec
		
		Exit
	EndFor

EndEvent

Event Enter

	HostWebServiceJaspiADM.Call(&Context.EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	&Location = GetLocation('ppJASPI_Bancos') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost //servidor 
	&Location.Port = &EmpWebPor //porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	&Location.Secure = false //false 
	&Location.CancelOnError = 2 //tratar exceção do WS 	
	
	&ppJASPI_BancossdtEstruturaBanco = &ppJASPI_Bancos.Execute(&EmpCodSec)
	
	If GetSOAPErr()= 0 
		prcWbsBanco.Call(&Context.EmpCod, &EmpCodSec, &ppJASPI_BancossdtEstruturaBanco)
		msg('Cadastro Syncronizado com sucesso!')
	Else 
		&Msg = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&Msg += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&Msg) 
	EndIf

EndEvent


]]></Source>
