      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadwwpContext.Call(&Context)
	&PesCod = &Context.PesCod
	&FilCod = &ParFilCod
	
	&ImprimirExportarCatalago = &ExportarImprimir
	padraoUsuario.Call('L', upper(&Pgmname), &Context.PesCod, &Context.EmpCod, &PadObs, &PAdDtaMod)
	&OrdemImpressao = Substr(&PadObs, 1, 1)
	&Modelo = val(Substr(&PadObs, 2, 1))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&PesCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PadObs = &OrdemImpressao
	&PadObs += trim(str(&Modelo))
	
	padraoUsuario.Call('G', upper(&Pgmname), &Context.PesCod, &Context.EmpCod, &PadObs, &PAdDtaMod)
	Do Case
		Case &Modelo = 1 //Modelo colunas
			
			if &ImprimirExportarCatalago = 'I'		 //pdf
				RCOOpenWindow1.LinkOpen = RELJAS063.Link(&EmpCod, &FilCod, &CtlCod, &OrdemImpressao,&IsDestacaImposto,&LctCod,&GruImpCod,&UfeCod)
				RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			Else
				ExportCatalogo.call(&EmpCod,&FilCod, &CtlCod, &OrdemImpressao, &Filename,'',&IsDestacaImposto,&LctCod,&GruImpCod,&UfeCod,&ErrorMessage)
				If (&Filename <> "")
					Link(&Filename)
				Else
					msg(&ErrorMessage)
				Endif
			Endif
			
		Case &Modelo = 2 //Modelo Representante
			if &ImprimirExportarCatalago = 'I'		
				RCOOpenWindow1.LinkOpen = RELJAS175.Link(&EmpCod, &FilCod, &CtlCod,&IsDestacaImposto,&LctCod,&GruImpCod,&UfeCod, &OrdemImpressao)
				RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			Else
				ExportCatalogo.call(&EmpCod,&FilCod, &CtlCod, &OrdemImpressao, &Filename,'',&IsDestacaImposto,&LctCod,&GruImpCod,&UfeCod,&ErrorMessage)
				If (&Filename <> "")
					Link(&Filename)
				Else
					msg(&ErrorMessage)
				Endif
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TbImposto.Visible = (&IsDestacaImposto = Status_SimNao.Sim)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &IsDestacaImposto.IsValid

	Do 'AttributesSecurityCode'

EndEvent


]]></Source>
