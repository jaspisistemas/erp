      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&sdtAnexos.FromJson(&sdtAnexosLongVarchar)
	if &DelPesAnxCod = 0 and &sdtAnexos.Count > 1
		txtMsg.Caption = format('Deseja Remover os (%1) Anexos?', trim(str(&sdtAnexos.Count)))
	Endif

	loadWWPContext.Call(&wwpContext)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 350
	TableMain.Height = 150

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &DelPesAnxCod = 0
		For &sdtAnexosItem in &sdtAnexos
			GravaAnexoUpload.Call('DEL', &DelEmpCod, &wwpContext.FilCod, &DelPesCod, &sdtAnexosItem.AnxCod, 0, '', '', '', '', &wwpContext.UserName, &mensagem)
		EndFor
		
	Else	
		GravaAnexoUpload.Call('DEL', &DelEmpCod, &wwpContext.FilCod, &DelPesCod, &DelPesAnxCod, 0, '', '', '', '', &wwpContext.UserName, &mensagem)
	EndIf
	Return

EndEvent


]]></Source>
