Sub 'loadProduto'

	For Each ORder EmpCod, ProCod
		WHere EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProUltAtuCalMin = ProUltAtuCalMin
		
		For Each ORder EmpCod, ProCod, FilCod
			Where FilCod = &FilCod
			Where ProGraCod = 1
				&EstMinFin			 = EstMinFin
				&EstMinIni			 = EstMinIni
		Exit
		EndFor
	EndFor

EndSub


