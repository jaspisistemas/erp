      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each Order EmpCod 
		Where EmpCod = &EmpCod
		
		&EmpStsImp = EmpStsImp
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	legalleb.Width = 800
	UnnamedTable3.Width = 800
	UnnamedTable3.Height = 40
	TableContent.Width = 800
	TableContent.Height = 150
	UnnamedTable2.Width = 800
	UnnamedTable2.Height = 100
	UnnamedTable1.Width = 800
	UnnamedTable1.Height = 50

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	scaProgressBar2.Visible = 0
	if &EmpStsImp < 100
		CompletandoCadastro.Link(&EmpCod, &EmpCodSec)
	Else
		&ProgressId = 'completado' + trim(str(&EmpCod))
		&ProgressId = &ProgressId.trim()
		scaProgressBar2.ProcessId = &ProgressId
		scaProgressBar2.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar2.Start()
		
		primeiroLogin.Submit(&ProgressId, &ProgressId, &EmpCod)
	EndIF

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable4.Visible = (1=2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar2.OnComplete

dashboard.Link()

EndEvent


]]></Source>
