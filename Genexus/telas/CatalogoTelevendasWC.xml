      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&serverDate = ServerDate()
	&FilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For each Order EmpCod, CtlCod
		Where EmpCod = &EmpCod
		Where CtlSts = Status_AtivoInativo.ATIVO
		Where TabDtaIni <= &serverDate
		Where TabDtaFin >= &serverDate
		
		
		&GridCtlCod = CtlCod
		&GridCtlNom = CtlNom
		&GridCtlSts = CtlSts
		&GridEmpCod = EmpCod
		&GridTabCod = TabCod
		&GridCtlMar = CtlMar
		&GridCtlCol1 = CtlCol1
		&GridCtlCol2 = CtlCol2
		&GridCtlCol3 = CtlCol3
		&GridCtlCol4 = CtlCol4
		&GridCtlCol5 = CtlCol5

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ExportExcel.FromImage(ActionExportFile)
	&ExportExcel.TooltipText = "Exportar catatálogo em excel"
	
	&Imprimir.FromImage(ActionPrinter)
	&Imprimir.TooltipText = "Imprimir Catálogo em Tela"
	
	&Enviaremail.FromImage(ActionEmail)
	&Enviaremail.TooltipText = "Enviar Catálogo por Email"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
	EndFor

EndEvent

Event 'DoExportExcel'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ExportExcel_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ExportExcel_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpImprimirCatalogo.Create('E', &GridEmpCod, &FilCod, &GridCtlCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ExportExcel_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Imprimir_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Imprimir_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpImprimirCatalogo.Create('I', &GridEmpCod, &FilCod, &GridCtlCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Imprimir_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEnviaremail'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpenviacatalogo.PopUp(&GridEmpCod, &GridCtlCod, &pesCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
