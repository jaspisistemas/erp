      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable4.Width = 150
	tbHora.Width = 100
	&TipoPlanoVarchar.Visible = False
	&PlanCod.Visible = False
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//Carrega as informações e habilita os campos necessários
	tbAbastecimento.Visible	= 0
	tbKm.Visible			= 0
	TbPlanCon.Visible		= 0
	tbContaOrigem.Visible	= 0
	tbQtd.Visible			= 0
	tbHora.Visible			= 0
	tbUf.Visible			= 0
	tbContaDestino.Visible	= 0
	&ViaLanTip.Enabled 		= 0
	&ViaLanTip.Clear()
	&ViaLanOriCtaBanCod.Clear()
	&TipoPlanoVarchar		= 'D'
	&Mode 					= 'INS'
	&IsBuscaContasOrigem	= False
	
	Do 'CarregaLancamento'
	Do 'HabilitaCampos'
	Do 'ValidaThermoKing'

EndEvent

Event 'DoNovo'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WpNovaPessoa.PopUp('FOR', &ViaLanFor, '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ViaLanFor.IsValid

	//Busca informações do Fornecedor com base no código atribuido
	If Not &ViaLanFor.IsEmpty() and &ViaLanFor > 0 
		&AuxPesCod = &ViaLanFor
		Do 'BuscaPessoa'
	EndIf

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	
	If &CheckRequiredFieldsResult = True
		&Mode 					= 'INS'
		&IsAuthorized 			= TRUE	
		//Insere um novo lançamento
		prcMovimentaLancamentosViagem.Call(&Mode, &EmpCod, &FilCod, &ViaCod, &ViaLanTip, &ViaLanStsPag, &ViaLanVlr, &ViaLanObs, &ViaLanDta, &ViaLanHor, &ViaLanNumDoc, &ViaLanQtd, &ViaLanVeiKmCom, &ViaLanComUfeCod, &ViaLanComQtdC, &ViaLanComQtdT, &ViaLanComQtdA, &ViaLanFor, 0, &ViaLanOriCtaBanCod, &PlanCod, &ViaLanCtabanCodDest)
		Refresh
	EndIf

EndEvent

Event &ViaLanPlanCod.IsValid

	RetornaCodigoPlanoContas.Call(&EmpCod, &ViaLanPlanCod, &PlanCod)

EndEvent

Event Refresh

	If &Mode = 'ERR'
		Msg('ATENÇÃO! Não existe lançamentos referente há está viagem. Com isso não será possível completar o estorno! Lance algum adiantamento para prosseguir.')
	Else
		If 	&IsAuthorized = TRUE
			Return
		EndIf
	EndIf

EndEvent

Event &ViaLanComQtdC.ControlValueChanged

	Do 'ValidaThermoKing'

EndEvent

Sub 'ContaOrigem'

	For Each Order EmpCod,CtabanCod
		Where EmpCod  	= &EmpCod
		Where CtabanCod = &ViaLanOriCtaBanCod		when not &ViaLanOriCtaBanCod = 0
		Where CtaBanSts = Status_AtivoInativo.ATIVO
		Where CtaBanTip <> TipoConta.MOTORISTA 		When &parmViaLanTip = 'A'
		Where CtaMotCod = &CtaMotCod				When &parmViaLanTip = 'DE'
		
		&ViaLanOriCtaBanCod.AddItem(CtabanCod, CtaBanCodNom)
		
	EndFor
	
	If &IsBuscaContasOrigem = True
		For Each Order EmpCod, CtabanCod
			Where EmpCod = &EmpCod
			Where CtaBanSts = Status_AtivoInativo.ATIVO
			Where CtaBanTip <> TipoConta.MOTORISTA
			
			&ViaLanCtabanCodDest.AddItem(CtabanCod, CtaBanCodNom)
			
		EndFor
	EndIf

EndSub

Sub 'CheckRequiredFields'

	//Verifica se não há erros
	&CheckRequiredFieldsResult = True
	If &ViaLanObs.IsEmpty()
		Msg(Format('WWP_RequiredAttribute','Uma observação, ou descrição,'))
		&CheckRequiredFieldsResult = False
	EndIf
	
	If &ViaLanVlr.IsEmpty()
		Msg(Format('WWP_RequiredAttribute','O valor do Lançamento'))
		&CheckRequiredFieldsResult = False
	EndIf
	
	Do Case 
		Case &parmViaLanTip = 'DV' 
			If &ViaLanVeiKmCom.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','O KM do veículo na hora do lançamento'))
				&CheckRequiredFieldsResult = False
			EndIf
			
			If &ViaLanPlanCod.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','O Plano de Contas'))
				&CheckRequiredFieldsResult = False
			EndIf
			
		Case &parmViaLanTip = 'DA'
			If &ViaLanVeiKmCom.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','O KM do veículo, na hora do lançamento,'))
				&CheckRequiredFieldsResult = False
			EndIf
			
			If &ViaLanComQtdT = 0 And &ViaLanComQtdC = 0 And &ViaLanComQtdA = 0
				Msg(Format('WWP_RequiredAttribute','Pelo menos um abastecimento'))
				&CheckRequiredFieldsResult = False
			EndIf
			
			If &ViaLanComQtdC > 0 And &ViaLanHorTot = 0
				Msg(Format('WWP_RequiredAttribute','A quantidade de horas, quando o Thermo King é informado,'))
				&CheckRequiredFieldsResult = False
			EndIf

			If &ViaLanComUfeCod.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','A Uf do local de abastecimento'))
				&CheckRequiredFieldsResult = False
			EndIf
			
			If &ViaLanPlanCod.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','O Plano de Contas'))
				&CheckRequiredFieldsResult = False
			EndIf
			
		Case &parmViaLanTip = 'DM'
			If &ViaLanPlanCod.IsEmpty()
				Msg(Format('WWP_RequiredAttribute','O Plano de Contas'))
				&CheckRequiredFieldsResult = False
			EndIf
				
	EndCase

EndSub

Sub 'CarregaLancamento'

	//Carrega os dados de um lançamento
	For Each Order EmpCod, FilCod, ViaCod, ViaLanCod
		Where EmpCod 	= &EmpCod	//empresa
		Where FilCod 	= &FilCod	//filial
		Where ViaCod 	= &ViaCod	//viagem
		Where ViaLanCod	= &ViaLanCod//lançamento
		
		//ViaLanTip --> A = Adiantamento; DV = Despesas de Veículo; DM = Despesas do motorista; DA = Abastecimentos.
		
		//Desabilita os campos
		
		//Campos Gerais
		&ViaLanStsPag.Enabled 		= 0
		
		//Campos de Abastecimento
		&ViaLanComUfeCod.Enabled	= 0
		
		&ViaLanComQtdT.Enabled 		= 0 
		
		&ViaLanComQtdC.Enabled 		= 0

		&ViaLanComQtdA.Enabled 		= 0 
		
		//Campos de Complemento
		&ViaLanDta.Enabled 			= 0  	
		&ViaLanHor.Enabled 			= 0
		&ViaLanNumDoc.Enabled		= 0
		
		&ViaLanFor.Enabled			= 0
		
		&ViaLanQtd.Enabled 			= 0
		&ViaLanVlr.Enabled 			= 0  	
		&ViaLanVeiKmCom.Enabled 	= 0
	
		&ViaLanPlanCod.Enabled		= 0
		&ViaLanOriCtaBanCod.Enabled = 0
		
		&ViaLanObs.Enabled 			= 0		
		
		&ViaLanCtabanCodDest.Enabled= 0
		
		BtnEnter.Visible			= 0
		tbNovoForncedor.Visible		= 0
		
		//Atribui os Valores
		
		//Campos Gerais
		&ViaLanTip  			= ViaLanTip		//tipo do lançamento
		&ViaLanStsPag  			= ViaLanStsPag 	//Status do pagamento do lançamento
		
		//Campos de Abastecimento
		&ViaLanComUfeCod		= ViaLanComUfeCod	//Uf que foi abastecido
		
		&ViaLanComTipT  		= ViaLanComTipT		//Se a Tração foi abastecida
		&ViaLanComQtdT  		= ViaLanComQtdT		//Quantidade abastecida para a tração
		
		&ViaLanComTipC  		= ViaLanComTipC		//Se o Cavalo foi abastecido
		&ViaLanComQtdC  		= ViaLanComQtdC		//Quantidade abastecida para o cavalo
		
		&ViaLanComTipA  		= ViaLanComTipA		//Se a Arla foi abastecida
		&ViaLanComQtdA  		= ViaLanComQtdA		//Quantidade abastecida para a arla
		
		//Campos de Complemento
		&ViaLanDta  			= ViaLanDta		//Data do Lançamento
		&ViaLanHor  			= ViaLanHor		//Hora do Lançamento
		&ViaLanNumDoc			= ViaLanNumDoc	//Número do doc.
		
		&ViaLanFor  			= ViaLanFor		//Código do Favorecido
		&AuxPesCod 				= &ViaLanFor	//Código do Favorecido para a busca
		Do 'BuscaPessoa'						//busca favorecido
		
		&ViaLanQtd  			= ViaLanQtd		//Quantidade de itens
		&ViaLanVlr  			= ViaLanVlr		//Valor do Lançamento
		&ViaLanVeiKmCom			= ViaLanVeiKm	//Km do Veículo no momento do lançamento
		
		&ViaLanObs 				= ViaLanObs		//Observação/Finalidade
				
		Exit
	When None
		
		&ViaLanDta = ServerDate()
		
	EndFor

EndSub

Sub 'HabilitaCampos'

	Do Case
		Case &parmViaLanTip = 'A'
			&ViaLanTip.AddItem('A', 'Adiantamento')
			TbStatusPago.Visible	= 0
			TbFavorecido.Visible	= 0
			tbContaOrigem.Visible	= 1
			&ViaLanStsPag			= Status_SimNao.Nao
			Do 'ContaOrigem'
			
		Case &parmViaLanTip	= 'DE'
			&ViaLanTip.AddItem('DE', 'Devolução')
			TbStatusPago.Visible	= 0
			TbFavorecido.Visible	= 0
			tbContaOrigem.Visible	= 1
			tbContaDestino.Visible	= 1
			&ViaLanStsPag			= Status_SimNao.Nao
			Do 'BuscaMotorista'
			&IsBuscaContasOrigem	= True
			Do 'ContaOrigem'
			
		Case &parmViaLanTip = 'DA'
			&ViaLanTip.AddItem('DA', 'Abastecimento')
			tbAbastecimento.Visible	= 1
			tbKm.Visible			= 1
			tbPlanCon.Visible		= 1
			tbHora.Visible			= 1
			tbUf.Visible			= 1
			&ViaLanStsPag			= Status_SimNao.Nao
			&ViaLanFor.Caption		= 'Posto Abastecimento'
			&ViaLanHor 				= Time()
			
		Case &parmViaLanTip = 'DM'
			tbKm.Visible			= 0
			tbQtd.Visible			= 1
			TbPlanCon.Visible		= 1
			&ViaLanTip.AddItem('DM', 'Despesas do Motorista')
			&ViaLanStsPag			= Status_SimNao.Sim
			&ViaLanFor.Caption		= 'Empresa'
			
		Case &parmViaLanTip = 'DV'
			tbKm.Visible			= 1
			tbQtd.Visible			= 1
			TbPlanCon.Visible		= 1
			&ViaLanTip.AddItem('DV', 'Despesas de Veículo'	)
			&ViaLanStsPag			= Status_SimNao.Sim
			&ViaLanFor.Caption		= 'Empresa'
			
	EndCase

EndSub

Sub 'ValidaThermoKing'

	If &ViaLanComQtdC > 0
		TbHorasTotais.Visible = 1
	Else
		TbHorasTotais.Visible = 0
		&ViaLanHorTot.SetEmpty()
	EndIf

EndSub

Sub 'BuscaPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &AuxPesCod
		
		&PesCodRaz	= SubStr(PesRaz.Trim(), 1, 19)
		If PesRaz.Trim().Length() > 19
			&PesCodRaz += '...'
		EndIf
		
		If &parmViaLanTip = 'DA'
			&AuxCidCod = PesCidCod
			Do 'BuscaCidade'
		EndIf
	
		Exit
	EndFor

EndSub

Sub 'BuscaCidade'

	For Each Order EmpCod, CidCod
		Where EmpCod = &EmpCod
		Where CidCod = &AuxCidCod
		
		&ViaLanComUfeCod = UfeCod
		
		Exit
	EndFor

EndSub

Sub 'BuscaMotorista'

	For Each Order EmpCod, FilCod, ViaCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ViaCod = &ViaCod
		
		&CtaMotCod 			 	= PesCod
		
		Exit
	EndFor

EndSub


