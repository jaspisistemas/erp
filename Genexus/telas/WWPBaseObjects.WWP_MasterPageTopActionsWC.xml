        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	
	&UserName = &wwpContext.UserName
	&EmpRaz = gxGetMLi(&wwpContext.FilRaz, 1, 20)
			
	&CountEmpresa = RetTipNick.Udp(&wwpContext.PesExtCod.ToString()) // 1 Usuario 2 Contador
	if &wwpContext.TipoPerfil = 3 or &wwpContext.Old_Perfil = 3
		&CountEmpresa = 3
	Else
		RetQtdFilialAcesso.Call(&wwpContext.EmpCod, &wwpContext.PesCod, 2, &QuantasFiliais)
	Endif

	if &CountEmpresa < 2
		btnTrocarEmpresa.Visible = 0
	Endif

	if &QuantasFiliais < 2
		btnTrocarFilial.Visible = 0
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



