Event 'DoTrocarEmpresa'

	WWPActions.DropDownComponent_Close(TableMain.InternalName)
	Do CAse
		CAse &wwpContext.Old_Perfil = 3
			wwadmin.Link()
		CAse &wwpContext.Old_Perfil = 2
			WWContador.Link(&GAMUser.GetExternalId())
	EndCase

