prompt(PromptVendedor, &EmpCod, &PedVenCod);
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
      </Part>
      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	RetornaAutorizacao.Call('RELCOMISSAOPERIODO', Status_SimNao.Sim, 1, &AutNiv)
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&FilCodNom = trim(str(&Context.FilCod)) + ' - ' + trim(&Context.FilRaz)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsImpCtaBan.TooltipText = "Marque esta opção para mostrar a conta bancária do vendedor."
	&ImprimirDebitos.TooltipText = "Imprimir débitos para descontar da comissão do Vendedor!"
	&PedSts.TooltipText = "Para o Status Fechados será utilizado o Filtro através da Data de Faturamento. Os demais Status serão realizados pela data de Emissão dos Pedidos."

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ComAutNiv = RetornaAutorizacao.UDP('WWVENDEDORCOMISSAOOBS', Status_SimNao.Nao, 1)
	BtnComissaoObs.Visible = &ComAutNiv

	If &Context.PesIsVen = true
		&AutNiv = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
		&PedVenCod.Enabled = &AutNiv
		If &AutNiv < 1
			&PedVenCod = &Context.PesCod
		Else
			&PedVenCod     = val(SubStr(&PadObs,2,8))
			&PesVenIntExt  = SUBSTR(&PadObs,1,1)
		EndIF
	Else
		&PedVenCod     = val(SubStr(&PadObs,2,8))
		&PesVenIntExt  = SUBSTR(&PadObs,1,1)
	EndIF

	
	&PedSts        = SubStr(&PadObs,10,1)
	&PedDtaFat     = ctod(SubStr(&PadObs,11,10))
	&PedDtaFat_to  = ctod(SubStr(&PadObs,21,10))
	&TipoRelatorio = SubStr(&PadObs,31,1)
	&ColunaExtra   = SubStr(&PadObs,32,1)
	&ImprimirDebitos = SubStr(&PadObs,33,1)
	&IsImpCtaBan = Iif(SubStr(&PadObs,34,1) = '1',true,False)
	&TipoPeriodo = SubStr(&PadObs,35,1)
	
	do 'VisibleTabela'
	&ColunaExtra = Iif(&ColunaExtra.IsEmpty(),'N',&ColunaExtra)
	&PedSts = Iif(&PedSts.IsEmpty(),'F',&PedSts)
	&ImprimirDebitos = Iif(&ImprimirDebitos.IsEmpty(),'N',&ImprimirDebitos)
	
	IF &PedDtaFat.IsEmpty()
		&PedDtaFat_to = serverdate()
		&PedDtaFat = (&PedDtaFat_to - day(&PedDtaFat_to) + 1)
	EndIf

	&Ano = &PedDtaFat.Year()
	&Mes = &PedDtaFat.Month()

EndEvent

Event 'DoComissaoObs'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWVendedorComissaoObs.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAplicarComissao'

	wpAplicaComissao.Popup(&Context.EmpCod, &Context.FilCod, &PedVenCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (PesVenIntExt <> 'T')
		&PedVenCod.Visible = False
		PedVenCod_Cell.Class = !'Invisible'
		TextBlockPedVenCod_Cell.Class = !'Invisible'
	Else
		&PedVenCod.Visible = True
		PedVenCod_Cell.Class = !'MergeDataCell'
		TextBlockPedVenCod_Cell.Class = !'col-sm-3 MergeLabelCell'
	EndIf
	If Not (PesVenIntExt <> 'T')
		&PedVenRaz.Visible = False
		PedVenRaz_Cell.Class = !'Invisible'
	Else
		&PedVenRaz.Visible = True
		PedVenRaz_Cell.Class = !'DataContentCell'
	EndIf
	If Not (&TipoRelatorio = 'A')
		&TipoRelatorioProdutos.Visible = False
		TipoRelatorioProdutos_Cell.Class = !'Invisible'
	Else
		&TipoRelatorioProdutos.Visible = True
		TipoRelatorioProdutos_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod
	do 'loadNomeVendedor'

EndEvent

Event &TipoRelatorio.IsValid

	do  'AttributesSecurityCode'

EndEvent

Event &TipoPeriodo.IsValid

	do 'VisibleTabela'

EndEvent

Event &PedVenCod.IsValid

	do 'loadNomeVendedor'

EndEvent

Event Enter

	if &Ano > 2000 or &TipoPeriodo <> 'S'
		&AuxPedSts.SetEmpty()
		If &PedSts <> 'T'
			&AuxPedSts.FromString(&PedSts)
		EndIF
		
		if &TipoPeriodo = 'S'
			&PedDtaFat = yMDtoD(&Ano, &Mes, 1)
			&PedDtaFat_to = eoM(&PedDtaFat)
		Endif
		
		verificaDeveAplicaComissao.Call(&ProgressID, &Context.EmpCod, &Context.FilCod, &PedVenCod, &PedDtaFat, &PedDtaFat_to)
		
		if &TipoRelatorio = 'A' //ANALITICO
			Do Case 
				Case &TipoProduto = 'S'
					RCOOpenWindow1.LinkOpen = RELJAS011_Servicos.Link(&Context.EmpCod, &Context.FilCod, &PedVenCod, &AuxPedSts, &PesVenIntExt, &PedDtaFat, &PedDtaFat_to, &TipoRelatorio, &ColunaExtra, &ImprimirDebitos,&IsImpCtaBan, &TipoRelatorioProdutos)
					RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
				Case &TipoProduto = 'P'
					RCOOpenWindow1.LinkOpen = RELJAS011_Produtos.Link(&Context.EmpCod, &Context.FilCod, &PedVenCod, &AuxPedSts, &PesVenIntExt, &PedDtaFat, &PedDtaFat_to, &TipoRelatorio, &ColunaExtra, &ImprimirDebitos,&IsImpCtaBan, &TipoRelatorioProdutos)
					RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
				OtherWise
					RCOOpenWindow1.LinkOpen = RELJAS011.Link(&Context.EmpCod, &Context.FilCod, &PedVenCod, &AuxPedSts, &PesVenIntExt, &PedDtaFat, &PedDtaFat_to, &TipoRelatorio, &ColunaExtra, &ImprimirDebitos,&IsImpCtaBan, &TipoRelatorioProdutos)
					RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			EndCase
		Else
			Do Case 
				Case &TipoProduto = 'S'
					RCOOpenWindow1.LinkOpen = RELJAS011S_SERVICOS.Link(&Context.EmpCod, &Context.FilCod, &PedVenCod, &AuxPedSts, &PesVenIntExt, &PedDtaFat, &PedDtaFat_to, &TipoRelatorio, &ColunaExtra, &ImprimirDebitos,&IsImpCtaBan)
					RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
				Case &TipoProduto = 'P'
					RCOOpenWindow1.LinkOpen = RELJAS011S_PRODUTOS.Link(&Context.EmpCod, &Context.FilCod, &PedVenCod, &AuxPedSts, &PesVenIntExt, &PedDtaFat, &PedDtaFat_to, &TipoRelatorio, &ColunaExtra, &ImprimirDebitos,&IsImpCtaBan)
					RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
				OtherWise
					RCOOpenWindow1.LinkOpen = RELJAS011s.Link(&Context.EmpCod, &Context.FilCod, &PedVenCod, &AuxPedSts, &PesVenIntExt, &PedDtaFat, &PedDtaFat_to, &TipoRelatorio, &ColunaExtra, &ImprimirDebitos,&IsImpCtaBan)
					RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			EndCase
		EndiF
		
		&PadObs = &PesVenIntExt + PadL(trim(str(&PedVenCod)),8,'0') +&PedSts+dtoc(&PedDtaFat)+dtoc(&PedDtaFat_to)+&TipoRelatorio+&ColunaExtra+&ImprimirDebitos+iif(&IsImpCtaBan = true,'1','0')  + &TipoPeriodo
		PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	Else
		&Ano.SetFocus()
		msg('Deve se informar um "Ano maior que 2000"')
	Endif

EndEvent

Event 'PromptVendedor'

	4
	PromptVendedor.Popup(&EmpCod, &PedVenCod)

EndEvent

Sub 'VisibleTabela'

	tbDatas.Visible = &TipoPeriodo = 'P'
	tbMeses.Visible = &TipoPeriodo <> 'P'

EndSub

Sub 'loadNomeVendedor'

	For Each Order EmpCod, PesCod
		Where EmpCod = &Context.EmpCod
		Where PesCod = &PedVenCod
		Where PesIsVen = true
			&PedVenRaz = PesRaz
			Exit
	When none
		If &PedVenCod = 0
			&PedVenRaz = 'TODOS OS VENDEDORES'
		Else
			&PedVenRaz = 'VENDEDOR NAO LOCALIZADO'
		EndIf
	EndFor

EndSub


]]></Source>
