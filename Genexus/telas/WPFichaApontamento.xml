      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	retornaAutorizacao.Call('WPFICHAAPONTAMENTO', Status_SimNao.Sim, 1, &AutNiv)
	&EmpCod = &Context.EmpCod
	&NomePadraoUsuario = '#wpAptomento#'
	
	PadraoUsuario.Call('L', 'wpFichaApontamento', &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
	&Tipo = substr(&PadObs, 1, 1)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	GridsdtTipEtqs.Rows = Page.Rows
	GridsdtTipEtqsPaginationBar.RowsPerPageSelectedValue = GridsdtTipEtqs.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&Count = 0
	LoadWWPContext.Call(&Context)
	&NomePadraoUsuario = '#wpAptomento#'
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtTipEtqsCurrentPage = GridsdtTipEtqs.CurrentPage
	&GridsdtTipEtqsPageCount = GridsdtTipEtqs.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqs.Load

	&Count += 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&delete.FromImage(ActionDelete)
	&delete.TooltipText = ""

	Do Case
		Case &Count > 7
			&GridsdtTipEtqsBadge = !"<i class='fa fa-exclamation-circle FontColorIconDanger	'></i>"
		Otherwise
			&GridsdtTipEtqsBadge = ''
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqsPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtTipEtqsPaginationBar.SelectedPage = !'Previous'
			GridsdtTipEtqs.PreviousPage()
		Case GridsdtTipEtqsPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtTipEtqs.CurrentPage
			&PageToGo += 1
			GridsdtTipEtqs.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtTipEtqsPaginationBar.SelectedPage)
			GridsdtTipEtqs.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqsPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtTipEtqs.Rows = GridsdtTipEtqsPaginationBar.RowsPerPageSelectedValue
	GridsdtTipEtqs.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEntrada'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWApontamentos.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEtapas'

	RCOOpenWindow1.LinkOpen = RELJAS111.link(&EmpCod,&context.FilCod, &ProPadForCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNewImprimir'

	&PadObs = &Tipo
	PadraoUsuario.Call('G', 'wpFichaApontamento', &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
	
	
	&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
	If &Tipo = 'I'
		RCOOpenWindow1.LinkOpen = RELJAS091.link(&NomePadraoUsuarioGrava, &EmpCod,&context.FilCod)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		RCOOpenWindow1.LinkOpen = RELJAS094.link(&NomePadraoUsuarioGrava, &EmpCod,&context.FilCod, &HorCod)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbHorario.Visible = (&Tipo = 'G')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Tipo.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event Enter

	do 'ValidaFornecedor'
	do 'validaFuncionario'
	&IsChou = false
	
	if not &PesRaz.IsEmpty() and not &ProPadForRaz.IsEmpty()
		For &sdtTipEtqItem in &sdtTipEtq
			if &sdtTipEtqitem.CD = trim(str(&PesCod))
				&IsChou = true
				Exit
			EndIF
		EndFor
		
		if &IsChou = false
			&sdtTipEtqItem = new()
			&sdtTipEtqItem.CD = trim(Str(&PesCod))
			&sdtTipEtqItem.DES = &PesRaz
			&sdtTipEtq.Add(&sdtTipEtqItem)
		EndIF
		
		&PadObs = &sdtTipEtq.ToJson()
		&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
		padraoUsuario.Call('G', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
	Endif
	
	&PesCod.SetFocus()

EndEvent

Event &PesCod.IsValid

	do 'validaFuncionario'

EndEvent

Event &delete.Click

	do 'ValidaFornecedor'
	if not &ProPadForRaz.IsEmpty()
		For &sdtTipEtqItem in &sdtTipEtq
			if &sdtTipEtqItem.CD = &sdtTipEtq.CurrentItem.CD
				&index = &sdtTipEtq.IndexOf(&sdtTipEtqItem)
				&sdtTipEtq.Remove(&Index)
			EndIF
		EndFor
		
		&PadObs = &sdtTipEtq.ToJson()
		&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
		padraoUsuario.Call('G', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
	EndiF

EndEvent

Event &ProPadForCod.IsValid

	do 'ValidaFornecedor'
	&sdtTipEtq.Clear()
	&PadObs.SetEmpty()
	
	if not &ProPadForRaz.IsEmpty()
		&NomePadraoUsuarioGrava = &NomePadraoUsuario + trim(str(&ProPadForCod))
		padraoUsuario.Call('L', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
		&sdtTipEtq.FromJson(&PadObs)
	EndiF

EndEvent

Sub 'ValidaFornecedor'

	&ProPadForRaz.SetEmpty()
	For Each order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &ProPadForCod
		&ProPadForRaz = PesRaz
		Exit
	EndFor

EndSub

Sub 'validaFuncionario'

	&PesRaz.SetEmpty()

	For each Order EmpCod,PesCod
		Where EmpCod = &Context.EmpCod
		where PesCod = &PesCod
		Where PesIsFun = true
		&PesRaz = PesRaz
		Exit
	EndFor

EndSub


