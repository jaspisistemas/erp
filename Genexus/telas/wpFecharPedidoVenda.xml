      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProcessando.Visible = 0
	RetornaAutorizacao.Call('VENDAFECHAESTOQUE', Status_SimNao.Sim, 1, &AutNiv)
	
	loadWWPContext.Call(&Context)
	
	Aviso.ForeColor = RGB(0,0,150)
	&PedDtaFat = serverdate()
	
	do 'LoadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&PedCodOciRef.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &PedObsGer.IsEmpty())
		&PedObsGer.Visible = False
		PedObsGer_Cell.Class = !'Invisible'
	Else
		&PedObsGer.Visible = True
		PedObsGer_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (not &PedObsEst.IsEmpty())
		&PedObsEst.Visible = False
		PedObsEst_Cell.Class = !'Invisible'
	Else
		&PedObsEst.Visible = True
		PedObsEst_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (not &PedCliObs.IsEmpty())
		&PedCliObs.Visible = False
		PedCliObs_Cell.Class = !'Invisible'
	Else
		&PedCliObs.Visible = True
		PedCliObs_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	If &PedDtaFat >= &PedDtaEms
		&PedDtaFat.Enabled = 0
		
		tbConfirmar.Visible = 0
		tbProcessando.Visible = 1
		
		&ProgressId = trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&PedCod)) + 'FECHA'
		apagaProgress.Call(&ProgressId)
		scaProgressBar.ProcessId = &ProgressId
		scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar.Start()
		
		AtualizaEstoqueGerencialVenda_submit.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &PedCod, &PedDtaFat, &Context.PesCod,  Status_Pedido.FECHADO, false)
		
	Else
		msg('Data Faturamento do pedido não pode ser inferior a data de Emissão do Pedido!')
	EndIf

EndEvent

Event ScaProgressBar.OnComplete

	Return

EndEvent

Event Refresh

	do 'LoadPedido'

EndEvent

Sub 'LoadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&FilCodNom = FilCodNom
		&PedDtaEms = PedDtaEms
		
		&PedCliObs = PedCliObsCli
		If PedCliObsCli.IsEmpty()
			&PedCliObs.Visible = 0
		EndIF
	
		&PedObsEst = PedObsEst
		If PedObsEst.IsEmpty()
			&PedObsEst.Visible = 0
		EndIF
	
		&PedObsGer = PedObsGer
		If PedObsGer.IsEmpty()
			&PedObsGer.Visible = 0
		EndIF
	
		Aviso.Caption = ''
		If LctAtuEst = Status_EntradaSaida.Nenhum
			Aviso.Caption = 'ATENÇÃO. Pedido não atualiza Estoque. SOMENTE SERÁ ALTERADO O STATUS PARA FECHADO SEM MOVIMENTAR ESTOQUE.'
		EndIF
		&PedCodOciRef = 0
		if PedStsGer = Pedido_gerado.OrdemCarregamento
			&PedCodOciRef = PedCodOciRef
		EndIF
	
		Exit
	EndFor

EndSub


]]></Source>
