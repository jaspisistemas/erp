      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCarga.Rows = Page.Rows
	&GridCargaCurrentPage = 1
	&GridCargaCurrentPage.Visible = False
	&GridCargaPageCount = -1
	GridCargaPaginationBar.RowsPerPageSelectedValue = GridCarga.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If &ParCteInfUndTraTip <> 0 
		Do 'GetTransporte'
	EndIf

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridCargaPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SdtCte.FromXml(&webSession.get('CTE'))
	If &sdtCte.Tela = 'WPDocTraAddCar'
		&sdtEmpCod = &sdtCte.EmpCod
		&sdtFilCod = &sdtCte.FilCod
		&sdtCteCod = &sdtCte.CteCod
		&sdtCteDocCod = &sdtCte.CteDocCod 
		&sdtCteDocTip = &sdtCte.CteDocTip
		&sdtCteInfUndTraTip = &SdtCte.CteInfUndTraTip 

		Do 'GetTransporteReturn'
	EndIf

EndEvent

Event GridCarga.Load

&Udelete.JSEvent( "onclick", "confirm ( 'Tem certeza que deseja excluir esta carga?')")
	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		Where CteInfUndTraTip = &ParCteInfUndTraTip
		
		&CteInfUndTraCarTip = CteInfUndTraCarTip
		&CteInfUndTraCarIde = CteInfUndTraCarIde
		&CteInfUndTraCarQtd = CteInfUndTraCarQtd

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Udelete.FromImage(ActionDelete)
	&Udelete.TooltipText = "Deletar Carga"
	
	&UUpdate.FromImage(ActionUpdate)
	&UUpdate.TooltipText = "Editar"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
	EndFor

EndEvent

Event GridCargaPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridCargaPaginationBar.SelectedPage = !'Previous'
			&GridCargaCurrentPage -= 1
			GridCarga.PreviousPage()
		Case GridCargaPaginationBar.SelectedPage = !'Next'
			&GridCargaCurrentPage += 1
			GridCarga.NextPage()
		Otherwise
			&PageToGo.FromString(GridCargaPaginationBar.SelectedPage)
			&GridCargaCurrentPage = &PageToGo
			GridCarga.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridCargaPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCarga.Rows = GridCargaPaginationBar.RowsPerPageSelectedValue
	&GridCargaCurrentPage = 1
	GridCarga.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	&sdtCte.EmpCod = &EmpCod
	&sdtCte.FilCod = &FilCod
	&sdtCte.CteCod = &CteCod
	&sdtCte.CteDocCod = &CteDocCod
	&sdtCte.CteDocTip = &CteDocTip
	&sdtCte.Tela = 'WPDocAddTra'
	&websession.Set('CTE',&SdtCte.ToXml())
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUInsertCarga'

	If not &CteInfUndTraTip.IsEmpty()
		GravaTransporte.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndTraTip,&CteInfUndTraQtd,&CteInfUndTraIde)
		WPDocTraAddCar.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndTraTip,&CteInfUndTraCarTip)
	Else
		MSG('ATENÇÃO! Tipo do transporte não pode ser vazio.Favor Informe.')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If not &CteInfUndTraTip.IsEmpty()
		GravaTransporte.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndTraTip,&CteInfUndTraQtd,&CteInfUndTraIde)
	Else
		MSG('ATENÇÃO! Tipo do transporte não pode ser vazio.Favor Informe.')
	EndIf

EndEvent

Event &UUpdate.Click

	WPDocTraAddCar.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndTraTip,&CteInfUndTraCarTip)
	Refresh Keep

EndEvent

Event &Udelete.Click

	DeletaCteDocTransporteCarga.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndTraTip,&CteInfUndTraCarTip)
	Refresh Keep

EndEvent

Sub 'GetTransporte'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		Where CteInfUndTraTip = &ParCteInfUndTraTip
		&CteInfUndTraTip = CteInfUndTraTip
		&CteInfUndTraIde = CteInfUndTraIde
		&CteInfUndTraQtd = CteInfUndTraQtd
		
	EndFor

EndSub

Sub 'GetTransporteReturn'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip
		Where EmpCod = &sdtEmpCod
		Where FilCod = &sdtFilCod
		Where CteCod = &sdtCteCod
		Where CteDocCod = &sdtCteDocCod
		Where CteInfUndTraTip = &sdtCteInfUndTraTip
		&CteInfUndTraTip = CteInfUndTraTip
		&CteInfUndTraIde = CteInfUndTraIde
		&CteInfUndTraQtd = CteInfUndTraQtd
		
	EndFor

EndSub


]]></Source>
