Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ImprimirNFSe = !'<i class="far fa-file-pdf"></i>'
	If (not NfsArqXml.IsEmpty() and not NfsArqXml.IsNull())
		&ImprimirNFSe.Class = !'Attribute'
	Else
		&ImprimirNFSe.Class = !'Invisible'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do Case
		Case NfsSts = Status_NFe.Autorizada
			NfsSts.ForeColor = RGB(0,175,0)
			
		Case NfsSts = Status_NFe.Cancelada
			NfsSts.ForeColor = RGB(255,150,0)
			
		Case NfsSts = Status_NFe.Denegada
			NfsSts.ForeColor = RGB(0, 160,250)
			
		Case NfsSts = Status_NFe.Inutilizada
			NfsSts.ForeColor = RGB(250,30,0)
			
		Otherwise
			NfsSts.ForeColor = RGB(0,0,0)
	Endcase

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ImprimirNFSe.Click

	GeraPdfDanfeNFSe.Call(EmpCod, NfsCod, &UrlPDF, &UrlFisico)
	RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

