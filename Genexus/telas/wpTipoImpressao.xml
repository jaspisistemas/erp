      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	//##### Sessao 'wpTipoImpressao' em xml ######
	&SDTwpTipoImpressao.Clear()
	&SDTwpTipoImpressao.FromXml(&webSession.Get('wpTipoImpressao'))
	Do 'loadSDT'
	
	LoadWWPContext.Call(&wwpContext)
	PadraoUsuario.Call('L', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod) //Ler Padrão Usuario
	if &PadObs.Trim() = '1' //A4 = 1
		&TipoImpressao = 'A4'
	else //Ticket = 2
		&TipoImpressao = 'T'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&IsErro = false
	if not &TipoImpressao.IsEmpty()
		&ServerTime = ServerTime() //=Random !!!!?
		Do case
			case &RelatorioVarChar = 'RECIBO_AVULSO' and &TipoImpressao = 'A4'
				//RELJAS020.Link(&ServerTime,'AVULSO')  //JA VEM GRAVADO NA SESSAO
				&Window.Url = RELJAS020.Link(&ServerTime,'AVULSO')
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
				
			case &RelatorioVarChar = 'RECIBO_AVULSO' and &TipoImpressao = 'T'
				//RELJAS114C.Link(&EmpCod,&RcbCod)
				&Window.Url = RELJAS114C.Link(&EmpCod,&Codigo8_1)
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()				
				
			case &RelatorioVarChar = 'RECIBO_CARTAO' and &TipoImpressao = 'A4'
				&Window.Url = RELJAS135_002.Link(&EmpCod,&FilCod,&Codigo8_1)
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
				
			case &RelatorioVarChar = 'RECIBO_CARTAO' and &TipoImpressao = 'T'
				&Window.Url = RELJAS135.Link(&EmpCod,&FilCod,&Codigo8_1)
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
				
			case &RelatorioVarChar = 'RECIBO_RENEGOCIACAO' and &TipoImpressao = 'A4'
				&Window.Url = RELJAS136_002.Link(&EmpCod,&FilCod,&Codigo8_1) 
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
				
			case &RelatorioVarChar = 'RECIBO_RENEGOCIACAO' and &TipoImpressao = 'T'
				&Window.Url = RELJAS136.Link(&EmpCod,&FilCod,&Codigo8_1) 
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()				
				
			case &RelatorioVarChar = 'MOVIMENTO_MANUAL'  and &TipoImpressao = 'A4'
				//RELJAS020_001.Link(&Random, &EmpCod, &MovCod, 'MOVIMENTO')	
				&Window.Url = RELJAS020_001.Link(&ServerTime, &EmpCod, &Codigo8_1, 'MOVIMENTO')
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
				
			case &RelatorioVarChar = 'MOVIMENTO_MANUAL'  and &TipoImpressao = 'T'
				//RELJAS114.Link(&Random, &EmpCod, &FilCod, &MovCod, &CreCliCod, &Context.PesCod)
				&Window.Url = RELJAS114.Link(&VarChar_1, &EmpCod, &FilCod, &Codigo8_1, &Codigo8_2, &Codigo8_3)
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
				
			case &RelatorioVarChar = 'DUPLICATA' and &TipoImpressao = 'T'
				&Window.Url = RELJAS019_002.Link(&EmpCod,&FilCod,&VarChar_1)
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
				
			case &RelatorioVarChar = 'DUPLICATA' and &TipoImpressao = 'A4'
				&Window.Url = RELJAS019.Link(&EmpCod,&FilCod,&VarChar_1)
				&Window.Height = 800
				&Window.Width = 800
				&Window.Open()
			case &RelatorioVarChar = 'DUP_RECEBER' and &TipoImpressao = 'T'	
				&random = retornaSoNumeros.Udp(serverTime())
				&webSession.Set(&random, 'S')
				&window.Url = RELJAS114A.Link(&random, &EmpCod, &wwpContext.FilCod, &wwpContext.PesCod)
				&window.Width = 500
				&window.Height = 400
				&window.Open()
				
			Case  &RelatorioVarChar = 'DUP_RECEBER' and &TipoImpressao = 'A4'	

				&window.Url = RELJAS165.Link(SERVerTime(),'WWDUPLICATARECEBER')
				&window.Width = 500
				&window.Height = 400
				&window.Open()
				
			otherwise
				&IsErro = true
				msg('ATENÇÃO! Relatório não localizado. Entre em contato com o suporte JASPI!')
		EndCase		
	else
		&IsErro = true
		msg('ATENÇÃO! Selecione o tipo de Impressão.')
	EndIf

	if &IsErro = false	//Remove da Sessão, Grava padrão do usuário e volta (return)
		&webSession.Remove('wpTipoImpressao')
		if &TipoImpressao = 'A4' //A4=1
			&PadObs = '1'
		else //Ticket = 2
			&PadObs = '2'
		EndIf
		PadraoUsuario.Call('G', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
		return
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'loadSDT'

	For &SDTwpTipoImpressaoItem in &SDTwpTipoImpressao
		&RelatorioVarChar = &SDTwpTipoImpressaoItem.Relatorio
		&EmpCod = &SDTwpTipoImpressaoItem.EmpCod
		&FilCod = &SDTwpTipoImpressaoItem.FilCod
		&Codigo8_1 = &SDTwpTipoImpressaoItem.Codigo8_1
		&Codigo8_2 = &SDTwpTipoImpressaoItem.Codigo8_2
		&Codigo8_3 = &SDTwpTipoImpressaoItem.Codigo8_3
		&VarChar_1 = &SDTwpTipoImpressaoItem.VarChar_1
		&VarChar_2 = &SDTwpTipoImpressaoItem.VarChar_2
		&VarChar_3 = &SDTwpTipoImpressaoItem.VarChar_3
		exit
	EndFor

EndSub


]]></Source>
