Event Start

	txtFalha.Caption = ''
	do 'loadProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	do 'getProdutoVinculo'
	if &ProRef.IsEmpty() or &IsAchouProduto = false
		txtFalha.Caption = 'Produto não cadastrado!'
	Else
		prcGravaVinculo.Call(&EmpCod, &MrkCod, &MrkItmCod, &ProCod, &ProGraCod)
		wwpactions.WCPopup_Close('')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwpactions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLocalizar'

	promptProdutoRef.Popup(&EmpCod, &ProCod, &ProRef)
	&ProRef.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCadastrar'

	&sdtGravaProduto.ProRef = ''
	//	&sdtGravaProduto.tmpNfeItmCod = &tmpNfeItmCod
	//	&sdtGravaProduto.tmpNFeCod = &tmpNFeCod
	//	&sdtGravaProduto.ForCNPJ = &ForCNPJ
	//	&sdtGravaProduto.tmpProForCod = &tmpProForCod	
	
	&sdtGravaProduto.ProNom = &MrkProNom
	//	&sdtGravaProduto.ProNcmCod = &tmpNcmCod
	//	&sdtGravaProduto.ProBar = retornaSoNumeros.Udp(&tmpNfeProBar)
	//	RetornaPrimeiraEmbalagemUnidade.call(&EmpCod, &tmpUnd, &EmbCod)
	//	&sdtGravaProduto.ProEmbCod = &EmbCod
	//	If &tmpProSolLot = SolicitarLote.SIM_CONTROLAR and &TCon148_ControleLote = 'S' //so traz se controla lote
	//		&sdtGravaProduto.ProSolLot = solicitarLote.SIM_CONTROLAR
	//	EndIf
	&sdtGravaProduto.IsPoupop = true	
	&WebSession.Set('DADOSDEFAUT_PRODUTO', &sdtGravaProduto.ToXml())
	
	Produtos.Popup('RETURN', TrnMode.Insert, &EmpCod, 0, &ProRef)
	&ProRef.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	do 'getProdutoVinculo'

EndEvent

Sub 'getProdutoVinculo'

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqvlr, &ProReqQtd, &ProBarQtd, &erroMensagem)

EndSub

Sub 'loadProduto'

	For Each Order EmpCod, MrkCod, MrkItmCod
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		where MrkItmCod = &MrkItmCod
		&MrkProNom = MrkProNom
		&MrkProVlr = MrkProVlr
		
		&imagemProduto.FromURL(MrkUrlImgPri)
		
		Exit
	EndFor

EndSub


