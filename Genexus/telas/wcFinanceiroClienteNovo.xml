Event Start

	do 'LoadCliente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do Case
		Case (&PesPefQtd.IsEmpty() and &PesPefVlr > 0) or (&PesPefQtd > 0 and &PesPefVlr.IsEmpty())
			msg('Caso informar QUANTIDADE PEFIN deve informar VALOR PEFIN, e Vice Versa!')
		otherwise
			
//			GravaPessoaFinanceiroNovo.Call(&EmpCod, &PesCod, , &PesRefQtd, &PesRefVlr, &PesDivTot, &PesDivQtd,	&PesDivVlr,	&PesProAtv, &PesPrtQtd, &PesPrtVlr, &PesResChe, &PesResSpc, &PesDtaCon, &PesEnvSpc)
//			&PesDivTot = (&PesPefVlr + &PesRefVlr + &PesDivVlr + &PesPrtVlr)
			msg('Dados atualizados com sucesso!')
	EndCAse

EndEvent

Sub 'LoadCliente'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PedCliCodRaz = PesCodRaz
		&PesEnvSpc = PesEnvSpc
		
		&PesResSpc = PesResSpc
		&PesResChe = PesResChe
		&PesDtaCon = PesDtaCon
		
		&PesTip = PesTip
		
		//PEFIn
		&PesPefQtd = PesPefQtd
		&PesPefVlr = PesPefVlr
		
		//REFIN
		&PesRefQtd = PesRefQtd
		&PesRefVlr = PesRefVlr
		
		//DIVIDA
		&PesDivTot = PesDivTot
		&PesDivQtd = PesDivQtd
		&PesDivVlr = PesDivVlr
		
		//PROTESTO
		&PesProAtv = PesProAtv
		&PesPrtQtd = PesPrtQtd
		&PesPrtVlr = PesPrtVlr
		
		Exit
	EndFor

EndSub


]]></Source>
