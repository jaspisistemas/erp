      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UDelete = !'<i class="fas fa-times"></i>'
	
	&ActionUpdate = !'<i class="fas fa-pen"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do 'VerificaNFe'
	
	Do Case 
		Case &QtdNFe = 0
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'É obrigatório conter no mínimo um documento fiscal.', DVMessageType.regular, "", DVMessageBoolean.True,""))
			
		OtherWise

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WpOperacaoTransporteAdicionarViagem(!'DocFiscais', !'Pagamentos', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	WpOperacaoTransporteAdicionarViagem(!'DocFiscais', !'Viagem', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdicionarNfe'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	AdicionarNfe_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event AdicionarNfe_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = WPOPERACAO_ADDNFE.Create(&EmpCod, &FilCod, &OpeCod, 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event AdicionarNfe_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ActionUpdate.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ActionUpdate_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ActionUpdate_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = WPOPERACAO_ADDNFE.Create(EmpCod, FilCod, OpeCod, OpeNfeCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ActionUpdate_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&OpeNroCiot = &WizardData.DocFiscais.OpeNroCiot
	&EmpCod = &WizardData.DocFiscais.EmpCod
	&FilCod = &WizardData.DocFiscais.FilCod
	&OpeCod = &WizardData.DocFiscais.OpeCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		LoadWWPContext.Call(&Context)
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&EmpCod		= &WizardData.Viagem.EmpCod
		&FilCod 	= &WizardData.Viagem.FilCod
		&OpeCod 	= &WizardData.Viagem.OpeCod
	EndIf

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.DocFiscais.OpeNroCiot = &OpeNroCiot
	&WizardData.DocFiscais.EmpCod = &EmpCod
	&WizardData.DocFiscais.FilCod = &FilCod
	&WizardData.DocFiscais.OpeCod = &OpeCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &UDelete.Click

	prcOperacaoTransporteRemoveDocFiscal.Call(EmpCod, FilCod, OpeCod, OpeNfeCod)

EndEvent

Sub 'VerificaNFe'

	&QtdNFe = 0
	For Each Order EmpCod, FilCod, OpeCod, OpeNfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where OpeCod = &OpeCod
		
		&QtdNFe += 1
	EndFor

EndSub


