      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &FilRegTrib = RegimeTributario.RegimeNormal
		NfeSitCod.Title = 'CST'
	Else
		NfeSitCod.Title = 'CSOSN'
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 15
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Alterar = !'<i class="fas fa-pen"></i>'
	
	&Deleteprodu = !'<i class="fas fa-times"></i>'

	&NfeProQtd = NfeProQtd

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If NfeSts <> Status_NFe.Digitando and NfeProTer = Nota_ProPriaTerceira.PROPRIA
		&Deleteprodu.Visible = 0
	Endif

	if NfeFin = NotaFinalidade.EmissaoAjuste or NfeFin = NotaFinalidade.EmissaoComplementar
		&Alterar.Visible = 0
	Endif

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Alterar.Click

	if &ModCod = '55'
		
		&WizardData.FromJson(&WebSession.Get('wpNota_Data'))
		&WizardData.Capa.FilCod = FilCod
		&WizardData.Capa.NfeCod = NfeCod
		&WizardData.Capa.EmpCod = EmpCod
		
		&WizardData.Produtos.NfeItmCod = NfeItmCod
		&WizardData.Produtos.NfeProCod = NfeProCod
		&WizardData.Produtos.NfeProGraCod = NfeProGraCod
		&WizardData.Produtos.varNfeProCod = NfeProGraRef
		
		&WebSession.Set('wpNota_Data', &WizardData.ToJson())
		
		wpNota(!'Produtos', !'Produtos', true)
	Else
		&WizardDataNFCE.CapaNFCe.FilCod = FilCod
		&WizardDataNFCE.CapaNFCe.NfeCod = NfeCod
		&WizardDataNFCE.CapaNFCe.EmpCod = EmpCod
		
		&WizardDataNFCE.ProdutosNFCe.NfeItmCod = NfeItmCod
		&WizardDataNFCE.ProdutosNFCe.varNfeProCod = NfeProGraRef
		&WizardDataNFCE.ProdutosNFCe.NfeProCod = NfeProCod
		&WizardDataNFCE.ProdutosNFCe.NfeProGraCod = NfeProGraCod
		
		&WebSession.Set('wpEmiteNFCe_Data', &WizardDataNFCE.ToJson())
		
		wpEmiteNFCe(!'ProdutosNFCe', !'ProdutosNFCe', false)
	EndiF

EndEvent

Event &Deleteprodu.Click

	RemoveItemNF.Call(EmpCod, FilCod, NfeCod, NfeItmCod)
	if &ModCod = '55'
		wpNota(!'Produtos', !'Produtos', true)
	Else
		wpEmiteNFCe(!'ProdutosNFCe', !'ProdutosNFCe', false)
	EndiF

EndEvent


]]></Source>
