Sub 'GetContas'

	&CtabanCod.Clear()
	&CtabanCod.AddItem(0, '(SELECIONAR)')
	For Each Order EmpCod, CtabanCod
		Where EmpCod 	= &EmpCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO 
		Where CtaBanTip = TipoConta.BANCO
		
		&CtabanCod.AddItem(CtabanCod, CtaBanNom)
		
	EndFor

EndSub

Sub 'VerificaConta'

	For Each Order EmpCod, CtabanCod
		Where EmpCod 	= &EmpCod
		Where CtabanCod	= &CtabanCod
		
		&OpePgtBan 		= CtaBanBanCod
		&OpePgtAge		= CtaBanAgeCod
		If CtaBanCrtDig.IsEmpty()
			&OpePgtCon	= CtaBanCrt
		Else
			&OpePgtCon	= CtaBanCrt + '-' + CtaBanCrtDig
		EndIf
		Exit
	When None
		&OpePgtBan.SetEmpty()
		&OpePgtAge.SetEmpty()
		&OpePgtCon.SetEmpty()
	EndFor

EndSub


