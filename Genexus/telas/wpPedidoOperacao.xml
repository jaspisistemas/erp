	do 'Vendedor'
	do 'Operacao'
	do 'Cliente'
	do 'CidadeCliente'
	do 'RamoAtividade'
	Do Case
		Case &IsErroVendedor = true
			&PedVenCod.SetFocus()
			
		Case &IsOperacao = true
			&LctCod.SetFocus()
			
		Case &IsCliente = true
			&PedCliCod.SetFocus()
			
		Case &IsCidadeCliente = true
			&PedCliCidCod.SetFocus()
			
		case &IsErroRamo = true
			&RatCod.SetFocus()
			
		Case &finPedDtaFat < &iniPedDtaFat or &finPedDtaFat.IsEmpty()
			msg('Data Final não pode ser menor que Inicial e nem Vazia!')
			&iniPedDtaFat.SetFocus()
		Otherwise
			If &LctAtuSal <> Status_EntradaSaida.Saida
				&SeparaPedidoVendedor = false
			EndIF
				
			if &SeparaPedidoVendedor = false
				&SepararVendedor = Status_SimNao.Nao
			Else
				&SepararVendedor = Status_SimNao.Sim
			EndIF
		
			RCOOpenWindow1.LinkOpen = RELJAS027.Link(&EmpCod, &FilCod, &PedVenCod, &PedVenAreCod, &PedCliCod, &PedCliCidAreCod, &PedCliCidCod, &PedCliCidUfeCod, &TipoRelatorio, &LctCod, &PedSts,&PedNovStsCod, &LctAtuSal, &SepararVendedor, &SomenteComInconsistencia, &iniPedDtaFat, &finPedDtaFat, &LctGerFin, &RatCod,&PedFatFilCod)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent

Sub 'RamoAtividade'

	&IsErroRamo = false
	&RatNom = 'TODOS OS RAMOS'
	If &RatCod <> 0
		For Each Order EmpCod, RatCod
			Where EmpCod = &EmpCod
			Where RatCod = &RatCod
			&RatNom = RatNom
			Exit
		When none
			&RatNom = 'RAMO NÃO ENCONTRADO'
			msg(&RatNom)
			&IsErroRamo = true
			&RatCod.SetFocus()
		EndFor
	EndIF

EndSub

Sub 'CidadeCliente'

	&IsCidadeCliente = false
	&PedCliCidNom = 'TODAS AS CIDADES'
	If &PedCliCidCod <> 0
		For Each order EmpCod, CidCod
			Where EmpCod = &EmpCod
			Where CidCod = &PedCliCidCod
			&PedCliCidNom = CidNom
			Exit
		When none
			
			&PedCliCidNom = 'CIDADE NÃO ENCONTRADA'
			msg(&PedCliCidNom)
			&IsCidadeCliente = true
			&PedCliCidCod.SetFocus()
		EndFor
		
	EndIF

EndSub

Sub 'Cliente'

	&IsCliente = false
	&PedCliRaz = 'TODOS OS CLIENTES'
	If &PedCliCod <> 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			where PesCod = &PedCliCod
			//Where PesIsCli = true  //JDF Relatorio tambem Filtra Compras
			&PedCliRaz = PesRaz
			Exit
		When none
			&PedCliRaz = 'CLIENTE NÃO ENCONTRADO'
			msg(&PedCliRaz)
			&IsCliente = true
			&PedCliCod.SetFocus()
		EndFor
	EndIF

EndSub

Sub 'Operacao'

	&IsOperacao = false
	&LctNom = 'TODAS AS OPERAÇÕES'
	If &LctCod <> 0
		For Each Order EmpCod, LctCod
			Where EmpCod = &EmpCod
			Where LctCod = &LctCod
			&LctNom = LctNom
			Exit
		When None
			&LctNom = 'TODAS AS OPERAÇÕES'
			msg(&LctNom)
			&IsOperacao = true
		EndFor
	EndIF

EndSub

Sub 'Vendedor'

	&IsErroVendedor = false
	&PedVenRaz = 'TODOS OS VENDEDORES'
	If &PedVenCod <> 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			where PesCod = &PedVenCod
			Where PesIsVen = true
			&PedVenRaz = PesRaz
			Exit
		When none
			&PedVenRaz = 'VENDEDOR NÃO ENCONTRADO'
			msg(&PedVenRaz)
			&IsErroVendedor = true
		EndFor
	EndIF

EndSub


