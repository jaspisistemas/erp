      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	
	&CancelarDuplicatas = Status_SimNao.Sim
	&CancelarPagamentosDuplicatas = Status_SimNao.Sim
	&AlterarFinanceiro = Status_SimNao.Sim
	&IsAvisaBoleto	= False
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		If PedStsFin <> Status_Financeiro.FECHADO and (PedStsFinIsPar <> true or PedStsFinIsPar.IsNull() or PedStsFinIsPar.IsEmpty()) //FECHADO OU PARCIAL
			wwpActions.WCPopup_Close('')
		EndIF
		
		RetornaAlgumaOrdemCarregamentoFechada.call(EmpCod, FilCod, PedCod, &ObsCarregamentoMensagem)
		&ObsCarregamentoMensagem.ForeColor = RGB(0,0,255)
	EndFor

	For Each Order EmpCod, FilCod, CrePedCod
		Where EmpCod	= &EmpCod
		Where FilCod	= &FilCod
		Where CrePedCod	= &PedCod
		Where CreSts <> Status_Duplicata.CANCELADA
		
		If CreCbrTipBol = TipoBoleto.Hibrido And Not CreBloNro.IsEmpty() And Not CreDtaRet.IsEmpty()
			&IsAvisaBoleto	= True
		EndIf
	EndFor
	tbAvisoBoleto.Visible	= &IsAvisaBoleto

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbAvisoBoleto.Height = 40

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	wwpactions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do Case
		Case &ObsMensagem.IsEmpty()
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "Por Favor, informar um motivo para o cancelamento do fincanceiro!" ,DVMessageType.regular, "", DVMessageBoolean.True,""))
			&ObsMensagem.setFocus()
			
		Case not &ObsCarregamentoMensagem.IsEmpty()
			Msg(&ObsCarregamentoMensagem)
			
		Otherwise
			BtnEnter.Visible = 0
			
			CancelaStatusFinanceiroPedido.Call(&EmpCod, &FilCod, &PedCod, &ObsMensagem, &Context.PesCod)			
			
			wwpactions.WCPopup_Close('')
	EndCase

EndEvent


]]></Source>
