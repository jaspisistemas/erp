      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[parm(In:&EmpCod, In:&parCotComCod, In:&parCotComItmCod);


prompt(PromptProdutoRef, &EmpCod, &CotComProCod, &CotComProRef);



prompt(promptPessoaEmail, &newCotComForCod, &newCotComForEmail);
prompt(promptPessoaFone, &newCotComForCod, &newCotComForNum);
]]></Source>
