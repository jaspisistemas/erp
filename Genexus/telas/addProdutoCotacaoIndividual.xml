      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbAdicionarFornecedor.Visible = false
	&CotComCod = &parCotComCod
	&CotComItmCod = &parCotComItmCod
	if &CotComItmCod > 0
		do 'loadLancamento'
		&CotComProRef.Enabled = false
		do 'getFornecedoresProduto'
		grid1.Refresh()
	
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	for &sdtCotacaoCompraFornecedoresItem in &sdtCotacaoCompraFornecedores
		if &sdtCotacaoCompraFornecedoresItem.IsNaCotacao  = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionSelecione.FromImage(DDOMultiselOption)
	&ActionSelecione.TooltipText = ""
	
	&UserAddCotacao = !'<i class="fas fa-plus"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			&CotComForCod = &sdtCotacaoCompraFornecedoresItem.PesCod
			&CotComForRaz = &sdtCotacaoCompraFornecedoresItem.PesRaz
			&CotComForEmail = &sdtCotacaoCompraFornecedoresItem.PesEml
			&CotComForNum = &sdtCotacaoCompraFornecedoresItem.PesFonNum
			
			&IsSel = &sdtCotacaoCompraFornecedoresItem.IsSel
			if &sdtCotacaoCompraFornecedoresItem.IsSel = true
				&ActionSelecione.FromImage(DDOMultiselSelOption)
			Else
				&ActionSelecione.FromImage(DDOMultiselOption)
			Endif
			
			&ActionSelecione.Visible = true			
			&UserAddCotacao.Visible = false
			load
		Endif
		
	EndFor
	
	for &sdtCotacaoCompraFornecedoresItem in &sdtCotacaoCompraFornecedores
		if &sdtCotacaoCompraFornecedoresItem.IsNaCotacao  = false		
			&IsSel = false
			&CotComForCod = &sdtCotacaoCompraFornecedoresItem.PesCod
			&CotComForRaz = &sdtCotacaoCompraFornecedoresItem.PesRaz
			&CotComForEmail = &sdtCotacaoCompraFornecedoresItem.PesEml
			&CotComForNum = &sdtCotacaoCompraFornecedoresItem.PesFonNum
			
			&UserAddCotacao = !'<i class="fas fa-plus"></i>'
			
			&ActionSelecione.Visible = false			
			&UserAddCotacao.Visible = true
			load
		Endif
	EndFor

EndEvent

Event 'DoUserForneceSim'

	do 'getCotacao'
	do 'ValidaFone'
	do 'ValidaEmail'
	do 'validaJaCadastrado'
	Do CAse
		Case &IsExiste = true 
			msg('Fornecedor Já adicionado a Cotação de Compra!')
			//&CotComForCod.SetFocus()
		CAse &IsErrorFone = true
			msg(' Número de telefone inválido!')
			&newCotComForNum.SetFocus()
		Case &IsErrorEmail = true
			msg('Endereço de E-mail não coincide com o padrão especificado!')
			&newCotComForEmail.SetFocus()
		Otherwise
			prcAddFornecedorCotacao.Call('INS', &EmpCod, &CotComCod, &newCotComForCod, &newCotComForNum, &newCotComForEmail, &newIsAdicionarTodos)
			do 'getFornecedoresProduto'
			grid1.Refresh()
			
			tbAdicionarFornecedor.Visible = false
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserForneceNao'

	tbAdicionarFornecedor.Visible = false

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'getCotacao'
	&CotComProObs = upper(&CotComProObs)
	
	if &IsNaoCadastrado = true
		&CotComProCod = 0
		&CotComProGraCod = 0
	Endif
	
	do 'NavegaGrid'
	
	Do Case
		Case &IsAchouProduto = false and &IsNaoCadastrado = false
			msg('Produto não localizado.')
		Otherwise
			&CotComProRef.Enabled = true
			prcGravaProdutoNaCotacao.Call(&EmpCod, &CotComCod, &CotComItmCod, &CotComProCod, &CotComProGraCod, &CotComProRef, &CotComProNom, &CotComProObs, &CotComProQtd, &CotComProEmbCod, &CotComProDtaLim, &CotComProLctCod, &CotComProBar, &CotComProMarNom, &sdtCotacaoCompraFornecedores)
			do 'limpacampos'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserSair'

	wwpactions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &newCotComForNum.IsValid

	do 'ValidaFone'

EndEvent

Event &newCotComForEmail.IsValid

	do 'ValidaEmail'

EndEvent

Event &CotComProRef.IsValid

	do 'getProduto'
	do 'verificaSoLancado'
	do 'getFornecedoresProduto'
	grid1.Refresh()

EndEvent

Event &IsNaoCadastrado.IsValid

	do 'OcultaCodigoProduto'
	
	if &IsNaoCadastrado= true
		&CotComProCod = 0
		&CotComProGraCod = 0		
		do 'getFornecedoresProduto'
	Endif
	grid1.Refresh()

EndEvent

Event &UserAddCotacao.Click

	do 'verificaItensJaAdicionados'
	
	tbAdicionarFornecedor.Visible = true
	&newCotComForCod = &CotComForCod
	&newCotComForEmail = &CotComForEmail
	&newCotComForNum = &CotComForNum
	&newIsAdicionarTodos= true
	&newCotComForRaz = &CotComForRaz

EndEvent

Event &ActionSelecione.Click

	If &IsSel = true
		&IsSel = false
		&ActionSelecione.FromImage(DDOMultiselOption)
	Else
		&IsSel = true
		&ActionSelecione.FromImage(DDOMultiselSelOption)
	Endif

EndEvent

Sub 'validaJaCadastrado'

	&IsExiste = false
	For Each Order EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComForCod = &newCotComForCod
		&IsExiste = true
		Exit
	EnDfor

EndSub

Sub 'NavegaGrid'

	For Each Line in Grid1
		&ForPesCod = &CotComForCod
		&ForIsSel = &IsSel
		do 'verificaIsAddSdt'
	EndFor

EndSub

Sub 'getCotacao'

	For Each Order EmpCod, CotComCod
		Where EmpCod = &EmPCod
		Where CotComCod = &CotComCod		
		
		if CotComSts = statusCotacao.Finalizada or CotComSts = statusCotacao.Liberada
			wwpActions.WCPopup_Close('')
		EndIf
	
		Exit
	When None
		wwpActions.WCPopup_Close('')
	EndFor

EndSub

Sub 'verificaIsAddSdt'

	For &sdtCotacaoCompraFornecedoresItem in &sdtCotacaoCompraFornecedores
		if &sdtCotacaoCompraFornecedoresItem.PesCod = &ForPesCod
			&sdtCotacaoCompraFornecedoresItem.IsSel = &ForIsSel
		Endif
	EndFor

EndSub

Sub 'verificaItensJaAdicionados'

	tbJaexisteProduto.Visible = false
	&newIsAdicionarTodos = false
	For Each Order EmpCod, CotComCod, CotComItmCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		
		tbJaexisteProduto.Visible = true
		&newIsAdicionarTodos = true
		Exit
	EndFor

EndSub

Sub 'loadLancamento'

	For Each Order EmpCod, CotComCod, CotComItmCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod = &CotComItmCod
		
		if CotComProCod.IsEmpty() or CotComProCod.IsNull()
			&IsNaoCadastrado = true
		Endif
	
		&CotComProRef = CotComProRef
		&CotComProNom = CotComProNom
		&CotComProCod = CotComProCod
		&CotComProGraCod = CotComProGraCod
		&CotComProEmbCod = CotComProEmbCod
		&CotComProMarNom = CotComProMarNom
		&CotComProBar = CotComProBar
		&CotComProQtd = CotComProQtd
		&CotComProObs = CotComProObs
		
		Exit
	EndFor

EndSub

Sub 'verificaSoLancado'

	For Each Order EmpCod, CotComProRef
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComProRef = &CotComProRef
		
		&CotComItmCod = CotComItmCod
		Exit
	EndFor
	
	if &CotComItmCod > 0
		do 'loadLancamento'
	Endif

EndSub

Sub 'ValidaEmail'

	&IsErrorEmail = false	
	if not &newCotComForEmail.IsEmpty()
		&EmailVerificacao = &newCotComForEmail
		&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
		if (&EmailVerificacao.IsMatch(&pattern) = false)
			&IsErrorEmail = True
		EndIf
	Endif

EndSub

Sub 'ValidaFone'

	FormataFONE.Call(&newCotComForNum,&newCotComForNum)
	&IsErrorFone = false
	RetornaSoNumeros.Call(&newCotComForNum, &Varchar)
	if (&Varchar.Length() >= 10 and &Varchar.Length() < 13) or &Varchar.IsEmpty()
	else		
		&IsErrorFone = true
	EndIf

EndSub

Sub 'getFornecedoresProduto'

	loadFornecedoresProdutoCotacao.Call(&EmpCod, &CotComCod, &CotComItmCod, &CotComProCod, &sdtCotacaoCompraFornecedores)

EndSub

Sub 'getProduto'

	RetornaProdutoReferencia.Call(&EmpCod,&CotComProRef,&CotComProCod,&CotComProGraCod, &CotComProNom, &IsAchouProduto, &ProReqVlr, &ProReqQTd, &ProBarQtd, &ErroMensagem)
	
	if &IsAchouProduto = true
		For Each ORder EmpCod,ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &CotComProCod
			&CotComProEmbCod = ProEmbCod
			&CotComProMarNom = CotComProMarNom
			&CotComProBar = ProBar
			Exit
		EndFor
	Endif

EndSub

Sub 'OcultaCodigoProduto'

	tbProdutoCadastrado.Visible = (&IsNaoCadastrado = false)
	tbProdutoNaoCadastrado.Visible = (&IsNaoCadastrado = true)

EndSub

Sub 'limpacampos'

	tbAdicionarFornecedor.Visible= 0
	
	&CotComItmCod.SetEmpty()
	&CotComProCod = 0
	&CotComProGraCod = 0
	&CotComProRef.SetEmpty()
	&CotComProNom.SetEmpty()
	&CotComProEmbCod.SetEmpty()
	&CotComProMarNom.SetEmpty()
	&CotComProBar.SetEmpty()
	&CotComProQtd.SetEmpty()
	&CotComProObs.SetEmpty()
	&sdtCotacaoCompraFornecedores.Clear()
	
	if &IsNaoCadastrado = true
		&CotComProNom.SetFocus()
	Else
		&CotComProRef.SetFocus()
	Endif
	grid1.Refresh()

EndSub


