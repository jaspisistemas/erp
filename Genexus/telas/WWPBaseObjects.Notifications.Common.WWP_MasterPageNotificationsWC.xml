Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	SDTNotificationsData__NotificationId.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SDTNotificationsData = WWPBaseObjects.Notifications.Common.WWP_GetNotificationsForUser()

EndEvent

Event Refresh

	Do Case
		Case &SDTNotificationsData.Count = 0
			NotificationTitle.Caption = "WWP_Notifications_NoNewNotifications"
      GridSDTNotificationsDatas.Visible = False
		Case &SDTNotificationsData.Count = 1
			NotificationTitle.Caption = "WWP_Notifications_OneNewNotification"
      GridSDTNotificationsDatas.Visible = True
		Otherwise
      GridSDTNotificationsDatas.Visible = True
			NotificationTitle.Caption = Format("WWP_Notifications_NewNotifications", &SDTNotificationsData.Count.ToString().Trim())
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSDTNotificationsDatas.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	NotificationItemIcon.Caption = Format(!"<i class='%1'></i>", &SDTNotificationsData.CurrentItem.NotificationIconClass)

EndEvent

Event 'DoCheckAllNotif'

  WWPActions.DropDownComponent_Close(BtnCheckAllNotif.InternalName)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If (&IsAuthorized_CheckAllNotif)
		WWP_VisualizeAllNotifications.Call()
	Else
		msg("WWP_ActionNoLongerAvailable")
		Refresh
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsAuthorized_CheckAllNotif = SecGAMIsAuthByFunctionalityKey.Udp(!'<Check_Is_Authenticated>')
	If not (&IsAuthorized_CheckAllNotif)
		BtnCheckAllNotif.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event NotificationItem.Click

	WWPActions.DropDownComponent_Close(LayoutMainTable.InternalName)
	WWPBaseObjects.Notifications.Common.WWP_VisualizeNotification(&SDTNotificationsData.CurrentItem.NotificationId)

EndEvent


