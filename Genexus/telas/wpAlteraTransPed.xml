      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&wwpContextUserName = &Context.UserName

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CotCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&IsTrocarRedespacho = false
	&IsTrocarSaida = false
	
	For Each Order EmpCod, CotCod
		Where EmpCod = &EmpCod
		Where CotCod = &CotCod
		&CotTraCod = CotTraCod
		&CotTraRaz = CotTraRaz
		&CotNro = CotNro
		&CotVlr = CotVlr
		Exit
	EndFor

	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where PedCod = &PedCod
		
		&NomePadrao = 'WPALTERATRANSPED_' + trim(Str(LctCod))
		PadraoUsuario.Call('L', &NomePadrao, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
		If Substr(&PadObs, 1, 1) = 'S'
			&IsTrocarSaida = true
		EndIF
	
		If Substr(&PadObs, 2, 1) = 'S'
			&IsTrocarRedespacho = true
		EndIF
		&PedIsImpCot = PedIsImpCot
		&PedTraRedCod = PedTraRedCod
		&PedTraRedRaz = PedTraRedRaz
		&PedTraSaiCod = PedTraSaiCod
		&PedTraSaiRaz = PedTraSaiRaz
		Exit
	EndFor

EndEvent

Event Enter

	If &IsTrocarSaida = true
		&PadObs = 'S'
	Else
		&PadObs = 'N'
	EndIF

	If &IsTrocarRedespacho = true
		&PadObs += 'S'
	Else
		&PadObs += 'N'
	EndIF
	PadraoUsuario.Call('G', &NomePadrao, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	If &IsTrocarRedespacho = true
		&PedTraRedCod = &CotTraCod
	EndIF

	If &IsTrocarSaida = true
		&PedTraSaiCod = &CotTraCod
	EndIF

	GravaTransportadoras.Call(&EmpCod, &FiLCod, &PedCod, &PedTraRedCod, &PedTraSaiCod, &PedIsImpCot, &wwpContextUserName)
	Return

EndEvent


]]></Source>
