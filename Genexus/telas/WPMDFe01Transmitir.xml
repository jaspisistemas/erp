        <Source><![CDATA[
Event Start

	pro.Visible = 1
	funcaoAutorizada.Visible = 0
	Sucesso.Visible = 0
	Falha.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&Context)
	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&EmpCod = &WizardData.mdfe.EmpCod
	&FilCod = &WizardData.mdfe.FilCod
	&MdfeCod = &WizardData.mdfe.mdfeCod
	&SolCod = &WizardData.mdfe.SolCod
	
	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		
		If MDFeSts = Status_MDFe.Digitando
			&Random = random()* 10
			&ProgressId = 'autoMDFe' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			RecepcaoNFe.Submit('RecepcaoNFe', &ProgressId, &EmpCod, &FilCod, &MDFeCod, &SolCod)
			txtMsg.Caption = ''
		Else
			WWMdFe.Link()
		EndIF
		
		Exit
		
	When none
		WWMdFe.Link()
	EndFor

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCapaCte'

	WPMdfe01(!'BemVindo', !'Mdfe', false)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRetransmitir'

7
	//GRAVA XML AUTORIZACAO
	GeraXmlMdfe.Call(&EmpCod, &FilCod, &MDFeCod, &Context.PesCod, &SolCod)
	&WizardData.Mdfe.EmpCod = &EmpCod
	&WizardData.Mdfe.FilCod = &FilCod
	&WizardData.Mdfe.MdfeCod = &MdfeCod
	&WizardData.Mdfe.SolCod = &SolCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())
	WPMDFe01(!'Transporte', !'Transmitir', false)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConsultarCte'

	GravaConsultaSefazMDFE.Call(&EmpCod, &FilCod, &MDFeCod, &Context.PesCod, &SolCod)
	wpConsultaSefazMdfe.Link(&EmpCod, &FilCod, &MDFeCod, &SolCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovoCte'

	2

	&WebSession.Remove(&WebSessionKey)
	WPMdfe01.Call(&PreviousStep, &CurrentStep, &GoingBack)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoReimprimir'

8

	Do 'ImprimeMdfe'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEnviaremail'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpEnviaMdfe.PopUp(&EmpCod, &FilCod, &MdfeCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

