      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	&ModuloADM = ''
	RetornaEmpresaModulo.Call(&EmpCod,ModuloSistema.ADM_JASPI,&ModuloADM)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 12

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	if &ModuloADM = 'S'
		&PesDtaVctCer.Visible = true
		&PesEscCtbCod.Visible = true
//		&PesIntVenCod.Visible = false
//		&PesExtVenCod.Visible = false
	else
		&PesDtaVctCer.Visible = false
		&PesEscCtbCod.Visible = false
		&PesIntVenCod.Visible = true
		&PesExtVenCod.Visible = true
	EndIf
	for &sdtClientesItem in &sdtClientes
		&PesCodRaz = &sdtClientesItem.PesCodRaz
		&PesCod = &sdtClientesItem.PesCod
		&PesIsCli = &sdtClientesItem.PesIsCli
		&PesIsFor = &sdtClientesItem.PesIsFor
		&PesIsFun = &sdtClientesItem.PesIsFun
		&PesIsTra = &sdtClientesItem.PesIsTra
		&PesIsVen = &sdtClientesItem.PesIsVen
		&PesVinCod = &sdtClientesItem.PesVinCod
		&Localizou = &sdtClientesItem.Localizou
		&PesIntVenCod = &sdtClientesItem.PesIntVenCod
		&PesExtVenCod = &sdtClientesItem.PesExtVenCod
		&PesEscCtbCod = &sdtClientesItem.PesEscCtbCod
		&PesDtaVctCer = &sdtClientesItem.PesDtaVctCer

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&SelecionarImagem.FromImage(SelectRow)
	&SelecionarImagem.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&GridCurrentPage = Grid.CurrentPage
		&GridPageSize = Page.Rows
		&GridRecordCount = Grid.RecordCount
		&PageCount = Grid.PageCount
		Load
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event &PesFonNum.IsValid

	FormataFone.Call(&PesFonNum, &PesFonNum)
	
	do 'CarregaClientesSDT'

EndEvent

Event &CpfCnpj.IsValid

	do 'CarregaClientesSDT'

EndEvent

Event &PesEml.IsValid

	do 'CarregaClientesSDT'

EndEvent

Event &SelecionarImagem.Click

	&ParmPesCod =  &PesCod
	Return

EndEvent

Event Enter

	do 'CarregaClientesSDT'
	&PesFonNum.SetFocus()

EndEvent

Sub 'CarregaClientesSDT'

	retornaSDTClientesFone.Call(&EmpCod, &PesFonNum, &PesEml, &CpfCnpj, &sdtClientes)
	grid.FirstPage()
	Refresh

EndSub


]]></Source>
