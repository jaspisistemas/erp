	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&SegNom2.Visible = False
	&SegCnpj2.Visible = False
	Do Case
	Case &DynamicFiltersSelector2 = !'SEGNOM'
		&SegNom2.Visible = True
	Case &DynamicFiltersSelector2 = !'SEGCNPJ'
		&SegCnpj2.Visible = True
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'EnableDynamicFilters3'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&SegNom3.Visible = False
	&SegCnpj3.Visible = False
	Do Case
	Case &DynamicFiltersSelector3 = !'SEGNOM'
		&SegNom3.Visible = True
	Case &DynamicFiltersSelector3 = !'SEGCNPJ'
		&SegCnpj3.Visible = True
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'ResetDynFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&DynamicFiltersEnabled2 = False
	&DynamicFiltersSelector2 = !'SEGNOM'
	&SegNom2.SetEmpty()
	Do 'EnableDynamicFilters2'

	&DynamicFiltersEnabled3 = False
	&DynamicFiltersSelector3 = !'SEGNOM'
	&SegNom3.SetEmpty()
	Do 'EnableDynamicFilters3'

