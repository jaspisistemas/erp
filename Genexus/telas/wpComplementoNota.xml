      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	
	do 'loadNfe'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&NfeEmbUndTrib.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLimpar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'ValidaNCM'
	do  'validaCFOP'
	
	Do Case 
		CAse &NfeProNom.IsEmpty()
			msg('Informe a descrição do Produto, EX: COMPLEMENTO DE ICMS')
			&NfeProNom.SetFocus()
					
		Case &IsErroNCM = true
			&NfeNcmCod.SetFocus()			
			
		Case not &erroCFOPMensagem.IsEmpty() or &IsErroCFOP = true
			&NfeCfoCod.SetFocus()
			
		Case not &ErroCSTMensagem.IsEmpty()
			&NfeSitCod.SetFocus()
			
		Case &NfeProCod.IsEmpty()
			msg('Informe o Código do Produto!')
			&varNfeProCod.SetFocus()
			
		otherwise						
			if &NfeSts = Status_NFe.Digitando or UPPER(&Context.UserName) = 'SUPORTE.JASPI'
				
				
				GravaNotaFiscalModelo65_Item.Call(&EmpCod, &FilCod, &NfeCod, &NfeItmCod, &NfeProCod, &NfeProGraCod, &NfeProNom, &NfeProQtd, &NfeProVlrUnt, &NfeProVlrTot, &NfeEmbUnd, &NfeEmbUndTrib,&NfeSitCod, &ProOriTriCod, &NfeNcmCod, &NfeNcmCest, &NfeCfoCod, &NfeProDadAdi, &NfeProBasIcms,&NfeProTaxIcms,&NfeProVlrIcms,&NfeProTaxRedIcms,&NfeProBasIcmsSt,&NfeProVlrImcsSt,&NfeProTaxIcmsSt,&ImpAlqMVA,&NfeProTaxRedIcmsSt,&NfeProBasIpi,&NfeProTaxIpi,&NfeProTaxDif, &NfeProUFDest, &NfeProVlrIpi, &NfeCstIpi,nf_cstCofins.COF99, 0, nf_cstPIS.CST99, 0, &NfeProVlrDif, &NfeProII_Bas,&NfeProII_DspAdu,&NfeProII_IOF,&NfeProII_vlr,&NfeProCodAnp,&NfeProDscAnp,&NfeProPerGlp, &NfeProPerGni, &NfeProPerGnn, &NfeProVlrPar, &NfeProCBenef, 0, 0, 0, 0,Status_SimNao.Nao, 0, 0, 0, '', '', 9, &NfeIpiEnq,Status_SimNao.Nao)

				ObsAutomaticaNFe.call(&EmpCod, &FilCod, &NfeCod)
			EndIf
						
			return
	EndCase

EndEvent

Event &varNfeProCod.IsValid

	Do 'loadProduto'

EndEvent

Sub 'loadProduto'

	RetornaProdutoReferencia.Call(&EmpCod, &varNfeProCod, &NfeProCod, &NfeProGraCod, &NfeProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &erroMensagem )
	
	
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &NfeProCod
		Where ProGraCod = &NfeProGraCod
		
		&ProIsGra = ProIsGra
		if ProNomNF.IsEmpty() or ProNomNF.IsNull()
			&NfeProNom = ProNomGra
		Else
			&NfeProNom = ProNomNF
			IF ProGraCod > 1
				&NfeProNom += ' | ' +trim(ProGraNom)
			Endif
		Endif
		
		&NfeEmbUnd = ProEmbUnd
		&NfeProDadAdi = ProDetNfe
		
		If not ProUndTrib.IsEmpty() and not ProUndTrib.IsNull()
			&NfeEmbUndTrib = ProUndTrib
		Else
			&NfeEmbUndTrib = ProEmbUndTrib
		Endif
	EndFor

EndSub

Sub 'loadNfe'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod		
		
		&NfeSts = NfeSts
		For Each Order EmpCod, FilCod, NfeCod, NfeDocRefCod
			&NfeChvRef = NfeDocRefNfe
			Exit
		EndFor
	
		For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
			&NfeItmCod = NfeItmCod
			&varNfeProCod = NfeProGraRef
			&NfeEmbUnd = NfeEmbUnd
			&NfeEmbUndTrib = NfeEmbUndTrib
			&NfeProNom = NfeProNom
			&NfeProBasIcmsSt = NfeProBasIcmsSt
			&NfeProTaxIcmsSt = NfeProTaxIcmsSt
			&NfeProVlrImcsSt = NfeProVlrImcsSt
			
			&NfeProBasIcms = NfeProBasIcms
			&NfeProTaxIcms = NfeProTaxIcms
			&NfeProVlrIcms = NfeProVlrIcms
			
			&NfeProBasIpi = NfeProBasIpi  
			&NfeProTaxIpi = NfeProTaxIpi
			&NfeCstIpi = NfeCstIpi
			&NfeProVlrIpi = NfeProVlrIpi
			&NfeProCBenef = NfeProCBenef
			&NfeProQtd = NfeProQtd
			&NfeProVlrUnt = NfeProVlrUnt
			&NfeProVlrTot = NfeProVlrTot
			&NfeNcmCod = NfeNcmCod
			&NfeNcmCest = NfeNcmCest
			&NfeCfoCod = NfeCfoCod
			&NfeSitCod = val(NfeSitCod)
			
			&NfeIpiEnq = NfeIpiEnq
			
			Exit
		When none
			do 'GetPrimeiroProdutoNotaReferenciada'
		EndFor
		
		Exit
	EndFor

EndSub

Sub 'GetPrimeiroProdutoNotaReferenciada'

	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeChv = &NfeChvRef	
		
		&varNfeProCod = NfeProGraRef
		&NfeEmbUnd = NfeEmbUnd
		&NfeEmbUndTrib = NfeEmbUndTrib
		&NfeProNom = 'NOTA FISCAL COMPLEMENTAR'
		//			&NfeProBasIcmsSt = NfeProBasIcmsSt
		//			&NfeProTaxIcmsSt = NfeProTaxIcmsSt
		//			&NfeProVlrImcsSt = NfeProVlrImcsSt
		//			&NfeProQtd = NfeProQtd
		//			&NfeProVlrUnt = NfeProVlrUnt
//		&NfeProVlrTot = NfeProVlrTot
		&NfeNcmCod = NfeNcmCod
		&NfeNcmCest = NfeNcmCest
		&NfeCfoCod = NfeCfoCod
		&NfeSitCod = val(NfeSitCod)
		Exit
	EndFor

EndSub

