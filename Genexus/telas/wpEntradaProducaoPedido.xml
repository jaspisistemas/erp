        <Source><![CDATA[
Event Start

	txttitle2.ForeColor = RGB(255,100,0)
	txttitle.ForeColor = RGB(255,100,0)
	
	&OrdProPrd.Enabled = 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 200
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&OrdProPrd = OrdProPrd
	if &OrdProPrd < 0
		&OrdProPrd = 0
	EndIF
	&OrdSemEstQtd = OrdSemEstQtd

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFinalizaProducao'

	msg('Aguarde...')
	BtnFinalizaProducao.Visible = 0
	
	&ProgressId = 'FinalizaOrdem' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	FinalizaOrdemProducaoPedido.Submit('', &ProgressId, &EmpCod, &FilCod, &Context.PesCod, &OrdCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnCancelar'

	WWLancamentoOrdemProducaoPedido.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ScaProgressBar1.OnComplete

	WWLancamentoOrdemProducaoPedido.Link()

EndEvent


