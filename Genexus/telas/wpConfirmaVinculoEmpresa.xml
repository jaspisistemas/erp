      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtJaVinculadoOrigem.ForeColor = RGB(255,0,0)
	txtJaVinculadoDestino.ForeColor = RGB(255,0,0)
	txtAvisoVinculo.ForeColor = RGB(255,0,0)
	 
	RetornaNomeEmpresa.Call(&EmpCodOrigem, &EmpRazOrigem)
	RetornaNomeEmpresa.Call(&EmpCodDestino, &EmpRazDestino)
	
	RetornaNomeProduto.Call(&EmpCodOrigem, &ProCodOrigem, &Varchar)
	&ProNomOrigem = trim(&ProRefOrigem) + ' ' + &Varchar.Trim()
	&Varchar.SetEmpty()
	RetornaNomeProduto.Call(&EmpCodDestino, &ProCodDestino, &Varchar)
	&ProNomDestino = trim(&ProRefDestino) + ' ' + &Varchar.Trim()
	
	prcRetornaDadosEmpresaVinculo.Call(&EmpCodDestino, &EmpCodOrigem, &PesCodOrigem, &PesRazOrigem)
	prcRetornaDadosEmpresaVinculo.Call(&EmpCodOrigem, &EmpCodDestino, &PesCodDestino, &PesRazDestino)
	
	txtAvisoVinculo.Caption = ''
	&JaVinculadoProRefNom = ''
	txtJaVinculadoOrigem.Caption = &JaVinculadoProRefNom
	txtJaVinculadoDestino.Caption = &JaVinculadoProRefNom
	
	prcGetJaVinculadoProduto.call(&EmpCodDestino, &PesCodDestino, &ProRefOrigem, &JaVinculadoProRefNom)
	if not &JaVinculadoProRefNom.IsEmpty()
		txtJaVinculadoOrigem.Caption = 'VINCULO ATUAL: ' + &JaVinculadoProRefNom
		txtAvisoVinculo.Caption = 'Sistema irá vincular os produtos atuais, removendo os vínculos com outros produtos!'
		&JaVinculadoProRefNom = ''
	Endif
	
	prcGetJaVinculadoProduto.call(&EmpCodOrigem, &PesCodOrigem, &ProRefDestino, &JaVinculadoProRefNom)
//	prcGetJaVinculadoProduto.call(&EmpCodDestino, &PesCodDestino, &ProRefOrigem, &JaVinculadoProRefNom)
	if not &JaVinculadoProRefNom.IsEmpty()
		txtJaVinculadoDestino.Caption = 'VINCULO ATUAL: ' + &JaVinculadoProRefNom
		txtAvisoVinculo.Caption = 'Sistema irá vincular os produtos atuais, removendo os vínculos com outros produtos!'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesCodDestino.Visible = False
	&PesCodOrigem.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do Case
		CAse &PesCodDestino.IsEmpty()
			msg('Não Localizado cadastro da Empresa, na tabela de fornecedores da empresa '+trim(&EmpRazDestino)+'. Favor realizar um cadastro com o CNPJ da empresa origem!')
		CAse &PesCodOrigem.IsEmpty()
			msg('Não Localizado cadastro da Empresa, na tabela de fornecedores da empresa '+trim(&EmpRazOrigem)+'. Favor realizar um cadastro com o CNPJ da empresa Destino!')
		Otherwise			
			prcatualizaVinculoEmpresa.Call(&EmpCodDestino, &ProCodDestino, &PesCodDestino, &ProRefOrigem)
			prcatualizaVinculoEmpresa.Call(&EmpCodOrigem , &ProCodOrigem , &PesCodOrigem, &ProRefDestino)
			Return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
