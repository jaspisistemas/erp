      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon058_DigitandoPedido, &TCon058_DigitandoPedido)
	
	RetornaAutorizacao.call('DESCARTECANCELAR', Status_SimNao.Sim, 1, &AutNiv)
	
//	&PodeAlterarAutNiv = 1
//	if &Context.PesIsVen = true
//		&PodeAlterarAutNiv = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
//	EndIF
	
	do 'loadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbJustificativa.Height = 60
	&IsPodePodeExcluir.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'LoadPedido'
	
	if &IsPodePodeExcluir = true
		If &Mensagem.IsEmpty()
			msg('Só um porque do Cancelamento do pedido por favor!')
			&Mensagem.SetFocus()
		Else		
			wpConfirmaCancelamentoPedido.Popup(&EmpCod, &FilCod, &PedCod, &Mensagem)
			Return
		Endif
	
	Endif

EndEvent

Sub 'LoadPedido'

	LoadWWPContext.Call(&Context)
	
	&IsPodePodeExcluir = true
	BtnEnter.Visible = 1
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&FilCodNom = FilCodNom
		&PedCliCodRaz = PedCliCodRaz
		&PedDtaFat = PedDtaFat 
		
		If PedSts = Status_Pedido.CANCELADO
			Return
		EndIF
		
		If PedSts <> Status_Pedido.ABERTO
			msg('Somente Pedidos com Status ABERTO, podem ser Cancelados!')
			&IsPodePodeExcluir = false
			
			Exit
		EndiF
		
		If PedStsFin <> Status_Financeiro.ABERTO or PedStsFinIsPar = true
			msg('Somente Pedidos com Financeiro Aberto, podem ser Cancelados!')
			&IsPodePodeExcluir = false
			
			Exit
		EndiF
		
		Exit
	EndFor


	BtnEnter.Visible = &IsPodePodeExcluir

EndSub


]]></Source>
