Event Start

	Form.Backcolor = rgb(238,238,238)
	LayoutMainTable.Class = ThemeClass:MainContainer
	TableError.Visible = False

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&User = GAMRepository.GetUserByLogin(&UserAuthTypeName, &UserName, &Errors)
	If &Errors.Count = 0
		&KeyToChangePassword = &User.RecoverPasswordByKey(&Errors) // This code generates the KEY to recover password (*)
		If &Errors.Count = 0
			Do 'Host'
			// Send mail to User with instructions, for example:
			&Mail.To.Clear() //--> &Mail is MailMessage Data Type
			&Mail.To.New(Format("%1 %2",&User.FirstName, &User.LastName), &User.EMail)
			&Mail.Subject  = 'Alteração de senha ERPJASPI!'
			&Mail.HTMLText = Format('Para alterar a senha no ERP clique <a href="%1">aqui</a>.', 
			'smtp.gmail.com'+&BaseUrl + 'gamexamplerecoverpasswordstep2?' + &KeyToChangePassword.ToString())
			&SMTP.Host           = 'smtp.gmail.com'
			&SMTP.Port           = 465
			&SMTP.Authentication = 1
			&SMTP.Secure         = 1
			&SMTP.UserName       = 'tiagordig@gmail.com'
			&SMTP.Password       = 'tecchio300589'			
			&isOK = &SMTP.Login()
			If &SMTP.ErrCode = 0
				&SMTP.Send(&Mail)
				If &SMTP.ErrCode <> 0
					&Message = Format('Falha ao enviar e-mail: %1 (%2)', &Smtp.ErrDescription, &Smtp.ErrCode)
				Endif
				&SMTP.Logout()
			Else
				&Message = Format("Falha ao iniciar a sessão de correio: %1 (%2)", &SMTP.ErrDescription, &ret)
			Endif
			If &Message.IsEmpty()
				Msg('Um e-mail foi enviado com instruções para alterar a senha.')
			Else
				Msg(&Message)
			Endif
		Else
			Do 'DisplayMessages'
		EndIf
	Else
		Do 'DisplayMessages'
	EndIf

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub

Sub 'Host'

	&PesExtCod = val(&User.GetExternalId())
	
	For each order PesExtCod, EmpCod, PesCod   //Pessoa
		Where PesExtCod = &PesExtCod
		
		&EmpCod = EmpCod
		&PesCod = PesCod
		For Each Order EmpCod
			Where EmpCod = &EmpCod
			&BaseUrl = EmpDirVir
			Exit
		EndFor
		exit
	EndFor

EndSub

