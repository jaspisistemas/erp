      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaConfiguracoesPastas.Call(&EmPCod, &FilCod, &SdtConfiguracoesPasta)
	
	prcRetornaCamposEtiqueta.Call(&EmpCod, 'P', &sdtDesignerEtiquetas)
	
	For Each ORder EmpCod, TipEtqCod
		Where EmpCod = &EmpCod
		Where TipEtqCod = &TiPEtqCod
		
		&sdtDesignerConfig.FromJson(TipEtqJson)
		
		&nomeImagem = 'etiqueta'+padL(trim(str(EmpCod)), 8, '0') + '_'+ PadL(trim(str(TipEtqCod)), 8, '0')+'.jpg'
		Exit
	EndFor

	&Caminhocompleto = &SdtConfiguracoesPasta.PastadiretorioTempFis + &nomeImagem
	&file.Source = &Caminhocompleto
	if not &file.Exists()
		
		&sdtEtiquetaDiretaProdutos = new()	
		&sdtEtiquetaDiretaProdutos.TipEtqQtd = 1
		
		&sdtEtiquetaDiretaProdutos.TipEtqJson = &sdtDesignerConfig.ToJson()	
		&sdtEtiquetaDireta.produtos.Add(&sdtEtiquetaDiretaProdutos)
		
		&sdtEtiquetaDireta.TipEtqLocSal = &SdtConfiguracoesPasta.PastadiretorioTempFis
		&sdtEtiquetaTeste.fiRelInfAdi = &sdtEtiquetaDireta.ToJson()
		&sdtEtiquetaTeste.fiRelNam = 'arquivojson'
		&sdtEtiquetaTeste.fiRelCam = 'D:\PROJETOS\Flutter\gera_etiqueta\testeetiquetajson.json'

		&Nomeexe = 'D:\PROJETOS\GX17\ERP\CSharpModel\Web\bin\jaspi_geraetiquetajson.exe '+ 'arquivojson'
		&executa = shell(&Nomeexe, 0)
		
		padraousuario.Call('G', 'jaspi_geraetiquetajson', 1, 1, &sdtEtiquetaTeste.ToJson(), &PadDtaMod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
