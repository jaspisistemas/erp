      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPLISTAGEMCLIENTESREPETIDOS', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	&GErarFormato = 'P'
	
//	if &Context.PesIsVen = true
//		&PesIntVenCod = &Context.PesCod
//		&TrocarTelevendas = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
//	&PesIntVenCod.Enabled = &TrocarTelevendas
//	Endif
	
	
	Do 'Vendedor'
	
	&PesReg = 'T'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event &PesIntVenCod.IsValid

	do 'vendedor'

EndEvent

Event Enter

	If &GErarFormato = 'P' //PDF	
		RCOOpenWindow1.LinkOpen = RELJAS127.Link(&EmpCod, &TipoPessoaVar, &PesIntVenCod, &Validar)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else //XLSX
		ExportRelJAS056.Call(&EmpCod, &PesSts, &PesIntVenCod, &PesUltVenDta, &PesDtaCad, &PesEntCidCod, &PesEntUfeCod, &PesCidAreCod, &RatCod, &Ordenar, &NomeArquivo, &ErroMensagem,&PesUltVenDtaDia, &CnpjIE, &PesReg, &PesDtaUltCom)
		If (&NomeArquivo <> "")
			Link(&NomeArquivo)
		Else
			msg(&ErroMensagem)
		Endif
	EndiF

EndEvent

Sub 'vendedor'

	if &PesIntVenCod = 0
		&PesIntVenNom = 'TODOS OS VENDEDORES'
	Else
		RetornaNomePessoa.Call(&EmpCod, &PesIntVenCod, &PesIntVenNom)
		If &PesIntVenNom.IsEmpty()
			&PesIntVenNom = 'VENDEDOR NÃO LOCALIZADO'
			msg(&PesIntVenNom)
		EndIF
	EndIF

EndSub


]]></Source>
