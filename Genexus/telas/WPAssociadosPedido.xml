      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Mensagem = ''
	do 'VerificaNotaLancada'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For Each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		
		&GridEmpCod = EmpCod
		&GridFilCod = FilCod
		&GridPedCod = PedCod
		&GridPedAssCod = PedAssCod
		&GridPedAssNfeVlr = PedAssNfeVlr
		&GridPedAssPesCod = PedAssPesCod
		&GridPedAssPesCot = PedAssPesCot
		&GridPedAssNroNfp = PedAssNroNfp
		&GridPedAssEmsNfp =  PedAssEmsNfp
		&GridPedAssNfeCod = PedAssNfeCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&GravarItem.FromImage(ActionCancel)
	&GravarItem.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Do 'GetCliente'
		Load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardGoTo Capa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dosair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFaturar'

	&IsErro = False
	For each Order EmpCod, FilCod, PedCod, PedAssCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&tmpNFeCod = trim(str(EmpCod)) + trim(Str(FilCod)) + trim(str(PedCod))+Trim(str(PedAssCod))
		ValidacoesNFe.call(&tmpNFeCod, EmpCod, FilCod, PedCod, &validacaoMensagem)
		
		If Not &validacaoMensagem.IsEmpty()
			msg(&validacaoMensagem)
			&IsErro = True
			exit
		EndIf
	EndFor
	
	If &IsErro = False //Todas as Notas sem erro
		Do 'EmitirNotas'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &GravarItem.Click

	AtualizaPedidoassociado.call(&GridEmpCod,&GridFilCod,&GridPedCod, &GridPedAssCod,&GridPedAssNroNfp,&GridPedAssEmsNfp)

EndEvent

Event &GridPedAssNroNfp.IsValid

	AtualizaPedidoassociado.call(&GridEmpCod,&GridFilCod,&GridPedCod, &GridPedAssCod,&GridPedAssNroNfp,&GridPedAssEmsNfp)

EndEvent

Event &GridPedAssEmsNfp.IsValid

	AtualizaPedidoassociado.call(&GridEmpCod,&GridFilCod,&GridPedCod, &GridPedAssCod,&GridPedAssNroNfp,&GridPedAssEmsNfp)

EndEvent

Sub 'EmitirNotas'

	For each Order EmpCod, FilCod, PedCod, PedAssCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&tmpNFeCod = trim(str(EmpCod)) + trim(Str(FilCod)) + trim(str(PedCod))+Trim(str(PedAssCod))
		GravaNotaFiscalModelo55Remessa.Call('WPAssociadosPedido', EmpCod, FilCod, PedCod, &tmpNFeCod, 0, 'E')
	EndFor

EndSub

Sub 'VerificaNotaLancada'

	For Each Order EmpCod, NfeFilCod, NfePedCod, NfeSts
		Where EmpCod = &EmpCod
		Where NfeFilCod = &FilCod
		Where NfePedCod = &PedCod
		Where NfeSts in (Status_NFe.Autorizada, Status_NFe.Digitando)
		&Mensagem = 'ATENÇÃO. Esse pedido já possui uma nota Fiscal! Número: ' + trim(str(NfeNum)) + ' Filial :' + trim(str(FilCod)) + ' O sistema irá atualiza-la'
		Exit
	EndFor

EndSub

Sub 'GetCliente'

	For Each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &GridPedAssPesCod
		&GridPesRaz = PesRaz
		&GridPesEntLogNro = PesEntLogNro+' - '+PesEntBai
		&GridPesEntCidNom = PesEntCidNom
		If PesTip = TipoPessoa.FISICA
			&GridPesCnpj = PesCpf
		Else
			&GridPesCnpj = PesCnpj
		EndIf
		
		Do Case
			Case not PesCadPro.IsEmpty() and PesTip = tipoPessoa.FISICA
				&GridPesInsEst = PesCadPro
			Case not PesInsEst.IsEmpty() and PesTip = tipoPessoa.JURIDICA
				&GridPesInsEst = PesInsEst
			OtherWise
				&GridPesInsEst = 'ISENTO'
		EndCase
		
	EndFor

EndSub


]]></Source>
