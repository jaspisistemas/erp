      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWpContext.Call(&Context)
	&EmpCod	= &Context.EmpCod
	&FilCod	= &Context.FilCod
	&WWpContextUsername	= &Context.UserName
	&HojeData	= ServerNow()
	
	TextInformacao.Caption	= 'Os pedidos serão autorizados por ' + &Context.UserName + ' | ' + Trim(ToFormattedString(&HojeData))
	
	RetornaConfSistema.Call(&EmpCod, &Context.FilCod, domConfSistema.TCon211_ControleAceitePagamento, &TCon211_ControleAceitePagamento)
	tbAceite.Visible = &TCon211_ControleAceitePagamento = 'S'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = Page.Rows
	GridsdtPedidossPaginationBar.RowsPerPageSelectedValue = GridsdtPedidoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtPedidossCurrentPage = GridsdtPedidoss.CurrentPage
	&GridsdtPedidossPageCount = GridsdtPedidoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Previous'
			GridsdtPedidoss.PreviousPage()
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtPedidoss.CurrentPage
			&PageToGo += 1
			GridsdtPedidoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtPedidossPaginationBar.SelectedPage)
			GridsdtPedidoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = GridsdtPedidossPaginationBar.RowsPerPageSelectedValue
	GridsdtPedidoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	//prcAutorizaPedidosFechamento.Call(&EmpCod, &FilCod, Status_Autorizado.AUTORIZADO, &PedAutObs, &Context.PesCod, &Context.UserName, &sdtPedidos)
	For &sdtPedidositem in &sdtPedidos
		GravaLiberacaoCreditoPedido.Call(&EmpCod, &FilCod, &sdtPedidositem.PedCod, &Context.PesCod, &Context.UserName, 'AUT', &PedObsAna)
	EndFor

	msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", "O sistema obteve êxito em autorizar os pedidos.", DVMessageType.success, "", DVMessageBoolean.True, ""))
	WWpActions.WCPopup_Close('Ok')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNaoAutorizar'

//	prcAutorizaPedidosFechamento.Call(&EmpCod, &FilCod, Status_Autorizado.NAO_AUTORIZADO, &PedAutObs, &Context.PesCod, &Context.UserName, &sdtPedidos)
	For &sdtPedidositem in &sdtPedidos
		GravaLiberacaoCreditoPedido.Call(&EmpCod, &FilCod, &sdtPedidositem.PedCod, &Context.PesCod, &Context.UserName, 'DES', &PedObsAna)
	EndFor

	msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", "O sistema obteve êxito em não autorizar os pedidos.", DVMessageType.success, "", DVMessageBoolean.True, ""))
	WWpActions.WCPopup_Close('Ok')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	WWpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


