      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	&ProgressId2 = 'ImportarCatalogo' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	prcApagarImportarProdutos.Call(&ProgressId2)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TbMensagem.Height = 40
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	TableProgress1.Visible = 0
	TableProgress2.visible = 0
	TableGravar.visible = 0

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = Grid.currentPage
	&count = Grid.RecordCount
	Textmensagem.Caption = 'ENCONTRADO '+trim(str(&count)) +' PRODUTOS PARA IMPORTAR NO CATÁLOGO NRO '+trim(str(&CtlCod))  +'. DESEJA GRAVA-LOS?'

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGravaTabelaProdutos'

	TableProgress2.visible = 1
	btnGravaTabelaProdutos.Visible = 0
	&Isaguarde = true
	scaProgressBar1.ProcessId = &ProgressId2
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId2)
	scaProgressBar1.Start()
	
	GravaProdutosNoCatalogo.Submit(&ProgressId2, &ProgressId2, &EmpCod, &FilCod, &CtlCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FileUpload1.UploadComplete

	TableProgress1.Visible = 1
	loadWWPContext.Call(&Context)
	Do Case
		Case &PrimeiraLinha = 0
			msg('ATENÇÃO! Coluna código primeira Linha não pode ser vazio!')
		Otherwise			
			&sdtProdutosXls.Clear()
			
			For &FileUploadData in &FileUploadDataColl
				If not &FileUploadData.File.IsEmpty()
					&File.Source = &FileUploadData.File
					&selectedURL = &File.GetAbsoluteName() // Pega o local temporario
					&File.Close()
					
					
					//btnGravaTabelaProdutos.Visible = 0
					&Isaguarde = true
					&ProgressId2 = '2wpImportarProduto' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
					&ProgressId2 = &ProgressId2.trim()
					scaProgressBar2.ProcessId = &ProgressId2
					scaProgressBar2.UpdateProgressURL = retornaProgresso.Link(&ProgressId2)
					scaProgressBar2.Start()
					
					&sdtCamposImportacao.PrimeiraLinha = &PrimeiraLinha
					&sdtCamposImportacao.ColProCod = &ColProCod 
					ImportaProdutosXLS_Catalogo.Submit(&ProgressId2,  &ProgressId2, &EmpCod, &selectedURL, &sdtCamposImportacao)

				EndIf
			Endfor
	EndCase
	
	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent

Event ScaProgressBar2.OnComplete

	TableProgress1.Visible = 0
	Refresh
	TableGravar.visible = 1

EndEvent

Event scaProgressBar1.OnComplete

	&Isaguarde = false
	btnGravaTabelaProdutos.Visible = 1

EndEvent


]]></Source>
