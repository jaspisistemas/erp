      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[parm(in:&EmpCod, in:&ParFilCod, in:&parNfeCod, in:&parNfeCCeCod);
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
      </Part>
      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbDadosAdicionais.Visible = 0
	&NfeCod = &parNfeCod
	&NfeCCeCod = &parNfeCCeCod
	txtAviso.Caption = ''
	txtAviso1.Caption = ''
	&FilCod = &ParFilCod
	do 'Filial'
	PreencherCorrecao.Visible = 0
	
	do 'GetCCe'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DadosdaCCe.Height = 330
	&NfeCCeCor.TooltipText = "Descreva o que está errado na NFe emitida e o quais são os dados corretos. É preciso respeitar os dados do quadro acima."
	UnnamedTable3.Height = 40

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Mensagem = 'Condições de uso da Carta de Correção, informar a literal'
	&Mensagem1 = '"A Carta de Correção é disciplinada pelo 1°-A do art. 7º do Convênio S/N, de 15 de dezembro de 1970'
	+ newLine()+'e pode ser utilizada para regularização de erro ocorrido na emissão de Documentos Fiscais, desde que'
	+ newLine()+'o Erro não Esteja relacionado com:'
	&Mensagem2 = 'I - as variáveis que determinam o valor do imposto tais como: Base de Cálculo, Alíquota,' + newLIne() + 'Diferença de Preço, Quantidade, Valor da Operação ou da Prestação;'
	
	&Mensagem3 = 'II - a Correção de dados Cadastrais que implique mudança do remetente ou do Destinatário;'
	&Mensagem4 = 'III - a Data de Emissão ou de Saída;"'

EndEvent

Event 'DoFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGerarCCe'

	do 'carregaCCe'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&NfeCCeCor = trim(&NfeCCeCor)
	&NfeCCeCor = retiraCaracteresEspeciais.Udp(&NfeCCeCor)
	
	do 'verificaEspecial'
	
	If &erro = 0		
		GravaCCe.Call('G', &EmpCod, &FilCod, &NfeCod, &NfeCCeCod, &NfeCCeCor, &NfeCCeEvtCod, &outNfeCCeCod)
		
		loadWWPContext.Call(&WwpContext)
		RetornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod, domConfSistema.TCon142_LiberarAutorizacaoCCe, &TCon142_LiberarAutorizacaoCCe)
		//&Mensagem = trim(str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&NfeCod)) + trim(str(&outNfeCCeCod)) + &TCon142_LiberarAutorizacaoCCe
		//msg(&Mensagem)
		if &TCon142_LiberarAutorizacaoCCe = 'S'
			prcGravaLiberacaoCCe.Call(&EmpCod, &FilCod, &NfeCod, &outNfeCCeCod, false)
		Else
			prcGravaLiberacaoCCe.Call(&EmpCod, &FilCod, &NfeCod, &outNfeCCeCod, true)
		EndIf
		
		wwpactions.WCPopup_Close('')
	EndIF

EndEvent

Sub 'GetCCe'

    For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&NfeCliCodRaz = NfeCliCodRaz		
		&NfeVlrTot = NfeVlrTot
		&NfePesLiq = NfePesLiq
		&NfeQtdVol = NfeQtdVol
		&NfeTraRaz = NfeTraRaz
		&NfeTipFrt = NfeTipFrt
		
		tbDadosAdicionais.Visible = 1
		PreencherCorrecao.Visible = 1
		btnGerarCCe.Visible = 0
		&NfeNum.Enabled = 0
		&FilCod.Enabled = 0
		&NfeSer.Enabled = 0
		
		&NfeSer = NfeSer
		&NfeNum = NfeNum
		
		For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod
			Where NfeCCeCod = &NfeCCeCod
			&NfeCCeCor = NfeCCeCor.Trim()
			
			&NfeCCeEvtCod = NfeCCeEvtCod
	        If NfeCCeSts <> Status_NFe.Digitando
	            btnEnter.Enabled = 0
	            &NfeCCeCor.Enabled = 0
	        EndIF
		When none
			do 'GetEvento'
		EndFor
	
	    Exit
    When none
		Do 'GetEvento'
	EndFor

EndSub

Sub 'GetEvento'

    //Pega Ultima Sequencia Autorizada
    
	For Each Order EmpCod, FilCod, NfeCod, NfeCCeSts, (NfeCCeEvtCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
	    Where NfeCCeSts = Status_NFe.Autorizada
		
        &NfeCCeEvtCod = NfeCCeEvtCod
        &NfeCCeCor = NfeCCeCor
        Exit
	When none
		For Each Order EmpCod, FilCod, NfeCod, NfeCCeSts, (NfeCCeEvtCod)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
		    Where NfeCCeSts = Status_NFe.Digitando
			
	        &NfeCCeEvtCod = NfeCCeEvtCod
	        &NfeCCeCor = NfeCCeCor
			&NfeCCeCod = NfeCCeCod
	        Exit
	    EndFor
    EndFor

    &NfeCCeEvtCod += 1
	If &NfeCCeEvtCod > 20
		&NfeCCeEvtCod = 20
	EndIF

EndSub

Sub 'Filial'

	&FilCod.Clear()
	
	For Each ORder EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilAmbEms = TAmb.Producao
		&FilCod.AddItem(FilCod, FilCodNom)
	EndFor

EndSub

Sub 'carregaCCe'

	&NfeCliCodRaz = ''
	&IsErroNota = false
	txtAviso1.Caption = ''
	For Each ORder EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeNum = &NfeNum
		Where NfeSer = &NfeSer
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_Nfe.Autorizada
		
		&NfeCliCodRaz = NfeCliCodRaz
		&NfeCod = NfeCod
		&NfeVlrTot = NfeVlrTot
		&NfePesLiq = NfePesLiq
		&NfeQtdVol = NfeQtdVol
		&NfeTraRaz = NfeTraRaz
		&NfeTipFrt = NfeTipFrt
		
		tbDadosAdicionais.Visible = 1
		PreencherCorrecao.Visible = 1
		btnGerarCCe.Visible = 0
		&NfeNum.Enabled = 0
		&FilCod.Enabled = 0
		&NfeSer.Enabled = 0
		
		Do 'GetEvento'
		
		Exit
	When none 
		txtAviso1.Caption = 'Nota não Localizada!'
		txtAviso1.ForeColor = rgb(200,0,0)
		&IsErroNota = true
	EndFor

EndSub

Sub 'verificaEspecial'

    &erro = 0 
    &Tamanho = len(&NfeCCeCor)
    if &tamanho < 15 or &tamanho > 1000
        txtAviso.Caption = 'Tamanho da Correção tem que ficar entre 15 e 1000 caracteres'
		txtAviso.ForeColor = RGB(200,0,0)
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&NfeCCeCor, &Posicao,1) < ' '  or (substr(&NfeCCeCor,&Posicao,1) > 'z'  ))
				txtAviso.Caption = 'Caracter especial '+  substr(&NfeCCeCor,&Posicao,1) + 'Não é permitido'
				txtAviso.ForeColor = RGB(200,0,0)
                &erro = 1
            Endif
        EndFor
    EndIf

EndSub


]]></Source>
