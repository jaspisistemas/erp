      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&EmpCod = &parEmpCod
	&PadGrupCod = &parPadGrupCod
	&padGrupItmCod = &parpadGrupItmCod

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PadGrupFilCod = &Context.FilCod
	
	do 'loadPadrao'

	if &OqueFAzer = 'DEL'
		&PadGrupFilCod.Enabled = 0
		&PadGrupPesCod.Enabled = 0
		&PadGrupIsSel.Enabled = 0
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PadGrupPesCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &PadGrupPesCod, &PadGrupPesRaz)

EndEvent

Event Enter

	if &PadGrupNfePesCod.IsEmpty()
		&PadGrupNfePesCod = &PadGrupPesCod
	Endif

	RetornaNomePessoa.Call(&EmpCod, &PadGrupPesCod, &PadGrupPesRaz)
	RetornaNomePessoa.Call(&EmpCod, &PadGrupNfePesCod, &PadGrupNfePesRaz)
	
	if (not &PadGrupPesRaz.IsEmpty() and not &PadGrupNfePesRaz.IsEmpty()) or &OqueFAzer = 'DEL'
		
		GravaPadraoPedido.Call(&OqueFAzer, &EmpCod, &PadGrupCod, &padGrupItmCod, &PadGrupFilCod, &PadGrupPesCod, &PadGrupIsSel, &PadGrupNfePesCod, &PadGrupNfePesCpl, &PadGrupNfeVlr)
		Return
	Endif

EndEvent

Event &PadGrupNfePesCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &PadGrupNfePesCod, &PadGrupNfePesRaz)

EndEvent

Sub 'loadPadrao'

	For Each ORder EmpCod, PadGrupCod, padGrupItmCod
		Where EmpCod = &EmpCod
		Where PadGrupCod = &PadGrupCod
		Where padGrupItmCod = &padGrupItmCod
			
			&PadGrupNfeVlr = PadGrupNfeVlr
			&PadGrupPesCod = PadGrupPesCod 
			&PadGrupNfePesCod = PadGrupNfePesCod
			&PadGrupIsSel = PadGrupIsSel
			&PadGrupNfePesCpl = PadGrupNfePesCpl
			&PadGrupCod.Enabled = 0
			
			RetornaNomePessoa.Call(&EmpCod, &PadGrupPesCod, &PadGrupPesRaz)
			RetornaNomePessoa.Call(&EmpCod, &PadGrupNfePesCod, &PadGrupNfePesRaz)
		Exit
	EndFor

EndSub


]]></Source>
