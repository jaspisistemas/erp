        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	For Each Order EmpCod
		&linkRedirect = EmpDirVir.Trim() + 'wpMarketSucessed.aspx'
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable10.Width = 187
	Grid1.Rows = Page.Rows
	&Grid1CurrentPage = 1
	&Grid1CurrentPage.Visible = False
	&Grid1PageCount = -1
	&codigo.Visible = False
	Grid1PaginationBar.RowsPerPageSelectedValue = Grid1.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&Grid1PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	&imagemMarket.FromImage(mercadoLivre)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&GridActionGroup1.Clear()
	&GridActionGroup1.AddItem(0, 'O que Fazer')
	&GridActionGroup1.AddItem(1, 'Alterar Configurações')
	If (MrkTip = TipoMarketplace.MercadoLivre and MrkStsInt = StatusMarketplace.Pendente)
		&GridActionGroup1.AddItem(2, 'Validar Integração')
	Endif
	If (MrkStsInt = StatusMarketplace.Integrada)
		&GridActionGroup1.AddItem(3, 'Produtos')
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid2.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case Grid1PaginationBar.SelectedPage = !'Previous'
			&Grid1CurrentPage -= 1
			Grid1.PreviousPage()
		Case Grid1PaginationBar.SelectedPage = !'Next'
			&Grid1CurrentPage += 1
			Grid1.NextPage()
		Otherwise
			&PageToGo.FromString(Grid1PaginationBar.SelectedPage)
			&Grid1CurrentPage = &PageToGo
			Grid1.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Grid1PaginationBar.RowsPerPageSelectedValue
	&Grid1CurrentPage = 1
	Grid1.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoaddShopee'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoaddMagalu'

	msg('Em breve')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoaddMercadoLivre'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	addMercadoLivre_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event addMercadoLivre_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcMarketplace.Create(&EmpCod, 0, TipoMarketplace.MercadoLivre)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event addMercadoLivre_Modal.Close

	if addMercadoLivre_Modal.Result = 'S'
		For Each Order EmpCod, MrkCod
			Where EmpCod = &EmpCod
			Where MrkTip = TipoMarketplace.MercadoLivre
			Where MrkSts = Status_AtivoInativo.ATIVO
			Where MrkStsInt = StatusMarketplace.Pendente
			//gravalinkredirect
			prcRedirectMercadoLivre.Call(EmpCod, MrkCod, &linkRedirect, &IsSucesso)
			
			if &IsSucesso = true
				&Link = 'https://auth.mercadolivre.com.br/authorization?response_type=code&client_id=7665836300727694&redirect_uri=https://adm.jaspi.com.br/loginsucessed.aspx&state='+trim(MrkGuid)
				link(&Link)
			Endif
		
			Exit
		EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndEvent

Event &GridActionGroup1.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &GridActionGroup1 = 1
			Do 'Do UserAction1'
		Case &GridActionGroup1 = 2
			Do 'Do UserValidar'
		Case &GridActionGroup1 = 3
			Do 'Do Produtos'
	EndCase
	&GridActionGroup1 = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event UserAction1_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcMarketplace.Create(EmpCod, MrkCod, MrkTip)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event UserAction1_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

