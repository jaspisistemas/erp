	//gravalinkredirect
	prcRedirectMercadoLivre.Call(EmpCod, MrkCod, &linkRedirect, &IsSucesso)
	
	if &IsSucesso = true
		&Link = 'https://auth.mercadolivre.com.br/authorization?response_type=code&client_id=7665836300727694&redirect_uri=https://adm.jaspi.com.br/loginsucessed.aspx&state='+trim(MrkGuid)
		link(&Link)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



