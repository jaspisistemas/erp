        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&FilCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 20
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&EditarLotes.ColumnHeaderClass = !'WWActionColumn'
	ProGraRef.ColumnHeaderClass = !'WWColumn'
	ProNomGra.ColumnHeaderClass = !'WWColumn'
	BalQtd.ColumnHeaderClass = !'WWColumn'
	BalTotLotQtd.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	VerificaLoteInformadoBalanco.Call(EmpCod, FilCod, BalCod, ProCod, ProGraCod, &PedLotTotOk)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EditarLotes.FromImage(ActionUpdate)
	&EditarLotes.TooltipText = ""

	Do Case
		Case &PedLotTotOk = true
			&EditarLotes.ColumnClass = !'WWActionColumn WWColumnSuccess WWColumnSuccessFirstColumn'
			ProGraRef.ColumnClass = !'WWColumn WWColumnSuccess'
			ProNomGra.ColumnClass = !'WWColumn WWColumnSuccess'
			BalQtd.ColumnClass = !'WWColumn WWColumnSuccess'
			BalTotLotQtd.ColumnClass = !'WWColumn WWColumnSuccess'
		Case &PedLotTotOk  = false
			&EditarLotes.ColumnClass = !'WWActionColumn WWColumnDanger WWColumnDangerFirstColumn'
			ProGraRef.ColumnClass = !'WWColumn WWColumnDanger'
			ProNomGra.ColumnClass = !'WWColumn WWColumnDanger'
			BalQtd.ColumnClass = !'WWColumn WWColumnDanger'
			BalTotLotQtd.ColumnClass = !'WWColumn WWColumnDanger'
		Otherwise
			&EditarLotes.ColumnClass = 'WWActionColumn'
			ProGraRef.ColumnClass = 'WWColumn'
			ProNomGra.ColumnClass = 'WWColumn'
			BalQtd.ColumnClass = 'WWColumn'
			BalTotLotQtd.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarCancelar'

	wwBalanco.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharBalanco'

	VerificaLoteInformadoBalanco.Call(&EmpCod, &FilCod, &BalCod, 0, 0, &IsTodosInformados)
	
	if &IsTodosInformados = TRUE //TUDO CERTO
		//		wpFecharBalanco.Popup(&EmpCod, &FilCod, &BalCod)
		//

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	FecharBalanco_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else //AJUSTAR ERROS
		msg('É preciso informar todos os lotes aos produtos!, Produto com cadastro Requer Lote = SIM, é preciso informar o Lote.')
	Endif

EndEvent

Event FecharBalanco_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpFecharBalanco.Create(&EmpCod, &FilCod, &BalCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FecharBalanco_Modal.Close

	wwBalanco.Link()

EndEvent

Event &EditarLotes.Click

	BalancoProdutoLote.Popup(TrnMode.Update, EmpCod, FilCod, BalCod, ProCod, ProGraCod)
	Refresh

EndEvent


]]></Source>
