        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPRESUMODIARIO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PEsCod = &Context.PesCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&MovDtaCon = ServerDate()
	&MovDtaConFin = &MovDtaCon
	&IsMovCaixa = Status_SimNao.Sim
	&IsContaPagar = Status_SimNao.Sim
	&IsContaReceber = Status_SimNao.Sim
	&IsFaturamento = Status_SimNao.Sim
	&IsPedido = Status_SimNao.Sim

EndEvent

Event &IsMovCaixa.Click

	Do 'caixa'

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS077.link(&EmpCod,&FilCod,&MovDtaCon, &MovDtaConFin, &IsMovCaixa,&MovCtaBanCod,&IsContaPagar,&IsContaReceber,&IsFaturamento,&IsPedido,&IsSintetico,&IsCartaoSintetico)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'Caixa'

	If &IsMovCaixa = Status_SimNao.Sim
		&MovCtaBanCod.Enabled = True
	Else
		&MovCtaBanCod.Enabled = False
	EndIf

EndSub


]]></Source>
