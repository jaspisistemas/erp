      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWCTETERCEIROS', Status_SimNao.Sim, 2, &AutNiv)
	loadWWPContext.Call(&wwpContext)
	txtAviso.Caption = ''
	padraousuario.Call('L', 'WPADDCTETERCEIROS', 1, &wwpContext.EmpCod, &padObs, &PadDtaMod)
	&CteCfop = Substr(&padObs, 1, 5)
	&CteImpCst.FromString(Substr(&padObs, 6, 2))
	&GravarInserirNovo = Substr(&padObs, 8, 1)
	
	if Substr(&padObs, 9, 1) = 'E'
		&CteEntSai = Status_EntradaSaida.Entrada
	Else
		&CteEntSai = Status_EntradaSaida.Saida
	Endif
	
	
	if &parCteCod > 0
		&FilCod.Enabled = 0
		
		&EmpCod = &ParEmpCod
		&FilCod = &ParFilCod
		&CteCod = &parCteCod
		
		do 'loadCteTerceiros'
	Else
		&EmpCod = &wwpContext.EmpCod
		&FilCod = &wwpContext.FilCod
		&CteImpCst = ClassificacaoCst.Outros
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&OldCteChv = &CteChv
	do 'CaptionEntradaSaida'

EndEvent

Event Enter

	do 'VerificaCFOP'
	&NUmeroMensagem = ''
	&Mensagem = ''
	VerificaChaveCteTerceirosJaLancada.Call(&EmpCod, &FilCod, &CteCod, &CteChv, &IsErroLancada, &Mensagem)
	VerificaChaveNumeroSerieTerceirosJaLancada.Call(&EmpCod, &FilCod, &CteCod, &CteNum, &CteSer, &CteTomCod, &IsErroLancadaNumero, &NUmeroMensagem)
	do 'GetTomador'
	do 'GetDestinatario'
	do 'VerificaChave'
	if &IsErroLancada = false &IsErroLancadaNumero = false
		//&CteIniUfe,&CteIniCidCod
		Do CAse
			Case not &ErroCfopMensagem.IsEmpty()
				msg(&ErroCfopMensagem)
				&CteCfop.SetFocus()
				
			Case &IsErroDestino = true
				msg('Informe o Cliente/Fornecedor do CTe')
				&CteDesCod.SetFocus()
			Case &CteTomRaz.IsEmpty()
				msg('Informe a Transportadora do CTe')
				&CteTomCod.SetFocus()
			Case &IsErroTomadorCnpj = true
				msg('Transportadora informada não Corresponde à Transportadora emitente do Cte.')
				&CteTomCod.SetFocus()
			Case &CteDtaEms.IsEmpty()
				msg('Data de emissão não pode ser vazia!')
				&CteDtaEms.setfocus()				
			Case &CteDtaSai.IsEmpty()
				msg('Data Entrada/Saida não pode ser vazia!')
				&CteDtaSai.setfocus()				
			CAse &CteVlrTotPreSer.IsEmpty()
				msg('Valor do documento nao pode ser Vazio!')
				&CteVlrTotPreSer.SetFocus()
			Case len(trim(&CteChv)) <> 44
				msg('Chave do Cte, Inválida!')
				&CteChv.setfocus()
			Case &CteChv.IsEmpty()
				msg('Chave do Cte, nao pode ser vazia!')
				&CteChv.setfocus()
			Case &CteTomCod.IsEmpty()
				msg('Obrigatorio informar a transportadora!')
				&CteTomCod.SetFocus()
			Otherwise
				retornaSoNumeros.Call(&CteCfop, &CteCfop)
				&Varchar = Substr(&CteCfop, 1, 1) + '.' + Substr(&CteCfop, 2, 3)
				&CteCfop = &Varchar
				
				if &CteCod.IsEmpty()					
					&padObs = trim(&Varchar) + &CteImpCst.ToString() + &GravarInserirNovo
					if &CteEntSai = Status_EntradaSaida.Entrada
						&padObs += 'E'
					Else
						&padObs += 'S'
					Endif
				
					padraousuario.Call('G', 'WPADDCTETERCEIROS', 1, &wwpContext.EmpCod, &padObs, &PadDtaMod)
				EndIf
				
				GravaCteTerceiros.Call(&OqueFazer, &EmpCod, &CteCod, &FilCod,&CteTomCod,&CteNum,&CteSer,&CteModCod,&CteDtaEms,&CteChv,&CteCfop,&CteImpCst,&CteImpVbc,&CteImpAli,&CteImpVlr,&CteVlrRecSer,&CteVlrTotPreSer, &CteDtaSai, &CteEntSai, &CteDesCod)
				
				if &GravarInserirNovo = 'S' and &CteCod = 0
					msg('Lançamento Gravado com sucesso!')
					wpAddCTeTerceiros.Link('ADD', &EmpCod, &FilCod, 0)
				Else
					wwCteTerceiros.Link()
				Endif					
		EndCase
		
	Else
		if &Mensagem.IsEmpty()
			msg(&NUmeroMensagem)
		Else
			msg(&Mensagem)
		Endif
	Endif

