	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovo'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WpNovaPessoa.PopUp('TRA', &CteTomCod, '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CteEntSai.IsValid

	do 'CaptionEntradaSaida'

EndEvent

Event &CteDesCod.IsValid

	Do 'GetDestinatario'

EndEvent

Event &CteTomCod.IsValid

	If Not &CteTomCod.IsEmpty()
		Do 'GetTomador'
	EndIf

EndEvent

Event &CteChv.IsValid

	txtAviso.Caption = ''
	
	
	retornaSoNumeros.Call(&CteChv, &CteChv)
	
	VerificaChaveCteTerceirosJaLancada.Call(&EmpCod, &FilCod, &CteCod, &CteChv, &IsErroLancada, &Mensagem)
	
	if &IsErroLancada = false and &OldCteChv <> &CteChv
		&CteNum = val(Substr(&CteChv, 26, 9))
		&CteSer = val(substr(&CteChv, 23, 3))
		&CteModCod = substr(&CteChv, 21, 2)
	Else
		txtAviso.Caption = &Mensagem
		txtAviso.ForeColor = RGB(255,0,0)
	Endif
	
	&OldCteChv = &CteChv

EndEvent

Sub 'VerificaCFOP'

	&ErroCfopMensagem = ''
	For Each Order CfoCod
		Where CfoCod = &CteCfop
		
		
//		&ErroCfopMensagem = 'CFOP Não Localizado!'
		
		Exit
	When none
		&ErroCfopMensagem = 'CFOP Não Localizado!'
	EndFor

EndSub

Sub 'CaptionEntradaSaida'

	if &CteEntSai = Status_EntradaSaida.Entrada
		&CteDesCod.Caption = 'Remetente'
	Else
		&CteDesCod.Caption = 'Destinatário'
	Endif

EndSub

Sub 'VerificaChave'

	&IsErroTomadorCnpj = false
	&ChaveCte = RetornaSoNumeros.Udp(&CteChv)
	&CnpjChave = substr(&ChaveCte, 7, 14)
	
	&TomadorCnpj  = RetornaSoNumeros.Udp(&TomadorCnpj )
	
	if &TomadorCnpj <> &CnpjChave
		&IsErroTomadorCnpj = true
	EndIf

EndSub

Sub 'GetDestinatario'

	&IsErroDestino = false
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CteDesCod
		
		//		&CteTerUfe = PesCidUfeCod
		//		&PesCteTerCidCod = PesCidIBGE
		
		If PesTip = tipoPessoa.FISICA
			&CteDesCnpj = PesCpf
		Else
			&CteDesCnpj = PesCnpj
		EndIf
		&CteDesRaz = SubStr(PesRaz,1,35)+' '+&CteDesCnpj
		
		Exit
	When none
		&IsErroDestino = true
	EndFor

EndSub

Sub 'GetTomador'

	&CteTomRaz.SetEmpty()
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CteTomCod
		&CteTomRaz = PesRaz
		&TomadorCnpj = PesCnpj
		Exit
	EndFor

EndSub

Sub 'loadCteTerceiros'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&CteEntSai = CteEntSai
		&CteTomCod = CteTomCod 
		&CteTomRaz = CteTomRaz
		&CteDesCod = CteDesCod
		&CteDesRaz = CteDesRaz
		&CteNum = CteNum
		&CteSer = CteSer
		&CteModCod = CteModCod
		&CteDtaEms = CteDtaEms
		&CteDtaSai = CteDtaSai
		&CteChv = CteChv
		&CteCfop = CteCfop
		&CteImpCst = CteImpCst
		&CteImpVbc = CteImpVbc
		&CteImpAli = CteImpAli
		&CteImpVlr = CteImpVlr
		&CteVlrRecSer = CteVlrRecSer
		&CteVlrTotPreSer = CteVlrTotPreSer
		
		if not CteArqXml.IsEmpty()
			&CteEntSai.Enabled = 0
			&CteTomCod.Enabled = 0
			&CteTomRaz.Enabled = 0
			&CteDesCod.Enabled = 0
			&CteDesRaz.Enabled = 0
			&CteNum.Enabled = 0
			&CteSer.Enabled = 0
			&CteModCod.Enabled = 0
			&CteDtaEms.Enabled = 0
			//&CteDtaSai.Enabled = 0
			&CteChv.Enabled = 0
//			&CteCfop = CteCfop
			btnNovo.Visible = 0
			btnNovoDes.Visible = 0
		Endif
	
		Exit
	EndFor

EndSub


