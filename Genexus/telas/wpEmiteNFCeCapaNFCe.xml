Sub 'loadCliente'

	&NfeCliTipPes = TipoPessoa.FISICA
	
	if &ConsumidorNfeCliCod <> &NfeCliCod
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &NfeCliCod
			&NfeCliRaz = PesRaz
			&NfeCliTipPes = PesTip
			&NfeCliCpf = PesCpf
			&NfeCliCnpj = PesCnpj
			
			Exit
		EndFor
	Endif

EndSub

Sub 'LoadNFCe'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&NfeCliTipPes = NfeCliTipPes
		&NfeCliCnpj = NfeCliCnpj
		&NfeCliCpf = NfeCliCpf
		&NfeCliCod = NfeCliCod
		&NfeCliRaz = NfeCliRaz
		
		&NfeDtaEms = NfeDtaEms
		&NfeHorEms = NfeHorEms
		
		&NfeFin = NfeFin
		&NfeNum = NfeNum
		&NfeSer = NfeSer
	
		&NfeProTer = NfeProTer
		&ModCod = ModCod

		&LctCod = NfeLctCod
		&NfeCliEml = NfeCliEml
		
		&NfeVlrTot = NfeVlrTot
		&NfeVlrTotPro = NfeVlrTotPro
		&NfeDadAdi = NfeDadManAdi
		&autNfeDadAdi = NfeDadAutAdi
		&NfeSts = NfeSts
		&IsAutorizada = false
		if NfeSts <> Status_Nfe.Digitando and NfeProTer = Nota_ProPriaTerceira.PROPRIA
			&IsAutorizada = true
		Endif
	
		If NfeSts = Status_NFe.Digitando and NfeVlrTot > 0
			btnTransmitirNFCe.Visible = 1
		EndiF
	
		Exit
	EndFor

EndSub


