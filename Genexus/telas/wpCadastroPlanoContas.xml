      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWPLANOCONTA', Status_SimNao.Sim, 2, &AutNiv)
	 
	loadWWPContext.Call(&Context)
	&EmpCod = &parmEmpCod
	&PlanCod = &parmPlanCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PlanCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadPlanoContas'

EndEvent

Event 'Dofechar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPlanoContas.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PlanHie.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Código Hierárquico'), DVMessageType.error, &PlanHie.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PlanNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Descrição'), DVMessageType.error, &PlanNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'CheckRequiredFields'
	
	if &CheckRequiredFieldsResult = True
		PlanoCategoriaPaiHierarquico.call(&EmpCod, &PlanCod, &PlanHie, &PlanHie, &PaizaoMensagem, &PlanPaiCod, &PlanPaiHie, &IsErroHierarquia, &AntPlanCatTip)
		
		Do Case
			CAse not &ErroPlanoMensagem.IsEmpty()
				msg(&ErroPlanoMensagem)
				
			Case &IsErroHierarquia = true
				msg(&PaizaoMensagem)
				
			Otherwise
				GravaPlanoContas.Call(&EmpCod, &PlanCod, &PlanNom, &PaizaoMensagem, &PlanAnaSin, &PlanHie, &PlanCatTip,&PlanUtiTra,&PlanGrpDre, &Context.UserName)

				if &mode = TrnMode.Insert
					wpCadastroPlanoContas.Link(TrnMode.Insert, &EmpCod, 0)
				Else
					wwPlanoContas.Link()
				EndIF
			
		EndCase
	
	EndIF

EndEvent

Event &PlanHie.IsValid

	&PlanHie = &PlanHie.Replace(',','.')

	PlanoCategoriaPaiHierarquico.call(&EmpCod, &PlanCod, &PlanHie, &PlanHie, &PaizaoMensagem, &PlanPaiCod, &PlanPaiHie, &IsErroHierarquia, &AntPlanCatTip)
	If &IsErroHierarquia = true
		msg(&PaizaoMensagem)
	EndIF

	&PlanCatTip.Enabled = 1
	If not &PaizaoMensagem.IsEmpty()
		&PlanCatTip = &AntPlanCatTip
		&PlanCatTip.Enabled = 0
	EndIF

	if &PaizaoMensagem.IsEmpty() and &parmPlanCod = 0
		&PaizaoMensagem = '### --- SERÁ CRIADO UMA NOVA HIERARQUIA --- ###'
	EndIF

EndEvent

Event &PlanAnaSin.IsValid

	If &PlanAnaSin <> 'A'
		&PlanGrpDre.SetEmpty()
		&PlanGrpDre.Enabled = 0
	Else
		&PlanGrpDre.Enabled = 1
	EndIf

EndEvent

Sub 'LoadPlanoContas'

	&PlanHie.Enabled = 1
	
	For Each Order EmpCod, PlanCod
		Where EmpCod  = &EmpCod
		Where PlanCod = &PlanCod
		&PlanNom    = PlanNom
		&PlanAnaSin = PlanAnaSin
		&PlanCatTip = PlanCatTip
		&PlanHie    = PlanHie
		&PlanUtiTra = PlanUtiTra
		&PlanGrpDre = PlanGrpDre
		&PlanHie.Enabled = 0
		
		VerificaFilhoPlanoContas.Call(EmpCod, PlanCod, PlanHie, PlanCod, &IsExiste)
		
		If &IsExiste = true
			&PlanAnaSin.Enabled = 0
			&PlanCatTip.Enabled = 0
			&PlanUtiTra.Enabled = 0
		EndIf
		
		If PlanAnaSin <> 'A'
			&PlanGrpDre.SetEmpty()	
			&PlanGrpDre.Enabled = 0
		Else
			&PlanGrpDre.Enabled = 1
		EndIf	

		&PlanCatTip.Enabled = 0
		
		PlanoCategoriaPaiHierarquico.call(EmpCod, PlanCod, PlanHie, &PlanHie, &PaizaoMensagem, &PlanPaiCod, &PlanPaiHie, &IsErroHierarquia, &AntPlanCatTip)
		Exit
	When none
		&EmpCod = &Context.EmpCod
	EndFor

EndSub


]]></Source>
