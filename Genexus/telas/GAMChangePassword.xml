      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	TableError.Visible = False
	Form.Backcolor = rgb(238,238,238)
	&User = GAMRepository.GetUserToChangePassword()
	If not &User.Name.IsEmpty()
		&UserName = &User.Name
	Else
		&Errors = GAMRepository.GetLastErrors()
		Do 'DisplayMessages'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &UserPasswordNew = &UserPasswordNewConf
		&isOK = GAMRepository.UpdateUserToChangePassword(&UserPassword, &UserPasswordNew, &Errors)
		If &isOK
			If &Errors.Count > 0
				Msg("WWP_GAM_PasswordSavedSuccessfully")
				Do 'DisplayMessages'
			Else
				If GAMRepository.IsRemoteAuthentication(&IDP_State)
					//Redirect to remote authentication
					GAMRepository.RedirectToRemoteAuthentication(&IDP_State)
				Else
					&URL = GAMRepository.GetLastErrorsURL()
					If &URL.IsEmpty()
						GAMHome()
					Else
						Link(&URL)
					Endif
				Endif
			Endif
		Else
			Do 'DisplayMessages'
		Endif
	Else
		TableError.Visible = true
		Msg("WWP_GAM_PasswordAndConfirmationDontMatch")
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event BackToLogin.Click

	&isOK = GAMRepository.Logout(&Errors)
	Login('', '')

EndEvent

Sub 'DisplayMessages'

	TableError.Visible = true
	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


]]></Source>
