        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWVENDEDORCOMISSAO', Status_SimNao.Sim, 3, &AutNiv)
	LoadWWPContext.Call(&Context)
	AtualizaComissao.Call(&Context.EmpCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesCod.TooltipText = "0 - Todos Vededores"
	&iniPedDtaEms.Visible = False
	&finPedDtaEms.Visible = False
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &auxPesCod
			
	&iniPedDtaEms = serverdate()
	&Ano = &iniPedDtaEms.Year()
	&Mes = &iniPedDtaEms.Month()
	
//	&finPedDtaEms = serverdate()

EndEvent

Event 'DoAplicaComissao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_AplicaComissao.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_AplicaComissao.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_AplicaComissao.Result = !'Yes'
		Do 'Do Action AplicaComissao'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action AplicaComissao'

	&iniPedDtaEms = YMDtoD(&Ano, &Mes, 1)
	&finPedDtaEms = EoM(&iniPedDtaEms)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	BTNAplicaComissao.Visible = 0
	&ProgressId = 'wpAplComi' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	AplicaComissao.Submit('AplicaComissao',&ProgressId,  &EmpCod, &FilCod, &PesCod, &iniPedDtaEms, &finPedDtaEms)

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

//	For Each Order ProgressId
