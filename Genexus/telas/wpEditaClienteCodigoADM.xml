      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&FilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'ValidaCliente'
	If &IsErroCliente = false 
		prcAtualizaClienteADM.Call(&EmpCod, &FilCod, &PesCod, &PesEmpSecCod)
		return
	Else
		msg(&Mensagem)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovoCliente'

	wpNovaPessoa.Popup('CLI', &PesCod, &VarPesCod)
	&PesCod.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PesCod.IsValid

	do 'ValidaCliente'
	if not &Mensagem.IsEmpty()
		msg(&Mensagem)
	EndIf

EndEvent

Sub 'ValidaCliente'

	&Mensagem.SetEmpty()
	&IsErroCliente = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesEmpSecCod = &PesEmpSecCod
		
		&IsErroCliente = true
		&Mensagem = 'Código ADM já utilizado em um Cliente'
		Exit
	EndFor

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PesCodRaz = PesRaz
		
		if not PesEmpSecCod.IsEmpty() and not PesEmpSecCod.IsNull()
			&IsErroCliente = true
			&Mensagem = 'Cliente já possui Código do ADM'
		Endif
		
		Exit
	When None
		&Mensagem = 'Cliente não Localizado'
		&IsErroCliente = true
	EndFor

EndSub


]]></Source>
