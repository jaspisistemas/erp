      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	do 'GetNota'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&NfeCliSuf.TooltipText = "É preciso solicitar ao seu cliente o Nº do SUFRAMA dele!"
	&EmpCod.Visible = False
	&FilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &NfeCliSuf.IsEmpty()
		msg('Informe o Código do SUFRAMA do Cliente!')
	Else
		GravaSuframaNFe.Call(&EmpCod, &FilCod, &NfeCod, &NfeCliSuf)
		
		RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
		
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			
			&NomeArquivo = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'lotenfe'+trim(str(&NfeCod))+'.SIN'
			&NomeArquivoVirtual = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + 'lotenfe'+trim(str(&NfeCod))+'.SIN'
			&File.Source = &NomeArquivo
			If &File.Exists()
				&File.Delete()
			EndIf
			
			&XmlWriter.Open(&NomeArquivo)
			&XmlWriter.WriteStartDocument('UTF-8')
			&XmlWriter.WriteStartElement('lote')
			&XmlWriter.WriteAttribute('nro',&NfeCod)
			&XmlWriter.WriteAttribute('versao_sw','6.0')
			&XmlWriter.WriteAttribute('dtEmissao', padl( trim(str(day(NfeDtaEms),2,0)),2,'0')+ '/'+padl( trim(str(month(NfeDtaEms),2,0)),2,'0')+'/'+  str(year(NfeDtaEms),4,0))
			&XmlWriter.WriteAttribute('xmlns','http://www.portal.fucapi.br')
			&XmlWriter.WriteAttribute('xmlns:xsi','http://www.w3.org/2001/XMLSchema-instance')
			&XmlWriter.WriteAttribute('xsi:schemaLocation','http://www.portal.fucapi.br http://alvaraes.suframa.gov.br:7778/PMNRecEViewController/jsp/importardados/NFe.xsd') 
			
			&NfeCliCnpj = retornaSoNumeros.udp(NfeCliCnpj)
			&NfeTraCnpj = retornaSoNumeros.udp(NfeTraCnpj)
			&AuxNfeCliSuf = retornaSoNumeros.udp(&NfeCliSuf)
			
			&XmlWriter.WriteElement('cnpjDestinatario',&NfeCliCnpj)
			&XmlWriter.WriteElement('cnpjTransp',&NfeTraCnpj)
			&XmlWriter.WriteElement('inscSufDestinatario',&AuxNfeCliSuf)
			&XmlWriter.WriteElement('ufDestino',NfeCliCidUF)
			&XmlWriter.WriteElement('ufOrigem',FilCidUfeCod)
			&XmlWriter.WriteElement('qtdeNF',1)
			
			&XmlWriter.WriteStartElement('notasFiscais')
			&XmlWriter.WriteStartElement('notaFiscal')
			&XmlWriter.WriteAttribute('chaveAcesso',NfeChv)
			&XmlWriter.WriteAttribute('txZero','false')
			
			&XmlWriter.WriteEndElement()
			&XmlWriter.WriteEndElement()
			&XmlWriter.WriteEndElement()
			
			&XmlWriter.Close()
		
			link(&NomeArquivoVirtual)
	
		endfor		
	EndIF

EndEvent

Sub 'GetNota'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&NfeCliCod = NfeCliCod
		&NfeCliRaz = NfeCliRaz
		&NfeCliSuf = NfeCliSuf
		&NfeNum = NfeNum
		&FilCodNom = FilCodNom
		
		If not NfeCliCidUF in ('AM','AP','AC','RO','RR')
			msg('Somente estados do AM,AP,AC,RO,RR estão Habilitados ao SUFRAMA!')
		EndIf
	
		Exit
	EndFor

EndSub


]]></Source>
