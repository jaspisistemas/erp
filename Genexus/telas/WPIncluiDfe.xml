      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&MdfeEveCod.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		
		&MDFeNum = MDFeNum
		&MDFeDtaEms = MDFeDtaEms
		&FilCodNom = FilCodNom
		&MDFeVlrTot = MDFeVlrTot
		&MDFeChv = MDFeChv
		&MDFeProt = MDFeProt
		
		If MDFeChv.IsEmpty()
			msg('MDFe não possui a chave de acesso!')
		EndIF
		
		
		For Each Order EmpCod, FilCod, MDFeCod,MdfeEveCod
			Where MdfeEveCod = &MdfeEveCod
			&MdfeEveCarUf = MdfeEveCarUf
			&MdfeEveCarCid = MdfeEveCarCid
			&MdfeEveCarUf.Enabled = False
			&MdfeEveCarCid.Enabled = False
		When none
			&MdfeEveCarUf.Enabled = True
			&MdfeEveCarCid.Enabled = True
		EndFor
		Exit
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'ValidaUfCidadeCarregamento'

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwincluirDfe.Link(&EmpCod,&FilCod, &MDFeCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdicionar'

	Do Case
		Case &MdfeEveCarUf.Trim().IsEmpty()
			msg('Estado de carregamento é obrigatório!')
		Case &MdfeEveCarCid.IsEmpty()
			msg('Estado de carregamento é obrigatório!')
		Case &MdfeEveDesUf.Trim().IsEmpty()
			msg('Estado de Descarregamento é obrigatório!')
		Case &MdfeEveDesCid.IsEmpty()
			msg('Estado de Descarregamento é obrigatório!')
		Case &IsErro = true
			msg('Chave de acesso NF-e inválida!')
			
		OtherWise
			
			EventoGravaDfe.call(&EmpCod,&FilCod,&MDFeCod,&MdfeEveCod,&MdfeEveCarUf,&MdfeEveCarCid,&MdfeEveDesUf,&MdfeEveDesCid,&MDFeEveDesChv)
			Refresh keep
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &MDFeEveDesChv.IsValid

	If Not &MDFeEveDesChv.Trim().IsEmpty()
		ValidaChaveNota.Call(&MDFeEveDesChv,&IsErro)
	EndIf

EndEvent

Sub 'ValidaUfCidadeCarregamento'

	For Each Order EmpCod,FilCod,MDFeCod,MdfeEveNro,(MdfeEveDfeCod) //Pega ultima Nota Adicionada no evento que esta em digitação para comparar a uf e cidade de Carregamento pois nao podem ser difiretes para o mesmo evento.
		//se fordiferente tem ser outro evento.
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		Where MdfeEveNro = '110115'
		Where MdfeEveSts = Status_MDfe.Digitando
//		Where MdfeEveCod = &MdfeEveCod  
		&MdfeEveCarUf = MdfeEveCarUf		
		&MdfeEveCarCid = MdfeEveCarCid
		&MdfeEveCarUf.Enabled = False
		&MdfeEveCarCid.Enabled = False
		
		Exit
	EndFor

EndSub


]]></Source>
