      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&PesCod = &parmPesCod
	do 'Cliente'
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
	&Ordem = Substr(&padObs, 1, 1)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&padObs = &Ordem
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
	
	
	do 'Cliente'
	RCOOpenWindow1.LinkOpen = RELJAS074.Link(&Context.EmpCod, &Context.FilCod, &PesCod, &GrupHie, &Ordem, &Estoque, 'N', &Custo)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event &PesCod.IsValid

	do 'Cliente'

EndEvent

Sub 'Cliente'

	For Each Order EmpCod, PesCod
		Where EmpCod = &Context.EmpCod
		Where PesCod = &PesCod
		&PesRaz = PesRaz
		Exit
	When None
		If &PesCod <> 0
			&PesRaz = 'FORNECEDOR NÃO LOCALIZADO'
		Else
			&PesRaz = 'TODOS OS FORNECEDORES'
		EndIF
	EndFor

EndSub


]]></Source>
