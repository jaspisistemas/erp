      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&WwpContext)
	RetornaAutorizacao.Call('WWTRANSFPRODUTO', Status_SimNao.Sim, 2, &AutNiv)
	Progress.Visible = 0
	
//	retornaConfSistema.Call(&WwpContext.EmpCod, &WwpContext.FilCod domConfSistema.TCon197, )

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 150

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&IsMovimentarEstoque = false
	For Each Order EmpCod, TrsCod 
		Where EmpCod = &EmpCod
		Where TrsCod = &trsCod
		&TrsSts = TrsSts
		Do Case
			Case TrsSts = Status_Pedido.FECHADO
				form.Caption = 'ABRIR Transferência'
				TextBlockTitle.Caption = 'Deseja ABRIR a transferência, movimentando os Estoques de entrada/saída?'
				&IsMovimentarEstoque = true
			Case TrsSts = Status_Pedido.ABERTO
				if &OqueFazer = 'C'
					form.Caption = 'CANCELAR Transferência'
					TextBlockTitle.Caption = 'Deseja CANCELAR a transferência?'
				Else
					&IsMovimentarEstoque = true
					form.Caption = 'FECHAR Transferência'
					TextBlockTitle.Caption = 'Deseja FECHAR a transferência, movimentando os Estoques de entrada/saída?'
				Endif
			Case TrsSts = Status_Pedido.CANCELADO
				form.Caption = 'REABRIR Transferência'
				TextBlockTitle.Caption = 'Deseja REABRIR a transferência Cancelada?'
				
		EndCase
		
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&FilCOd = &Context.FilCod

EndEvent

Event scaProgressBar1.OnComplete

	Return

EndEvent

Event Enter

	If &IsMovimentarEstoque = true
		btnCancel.Visible = 0
		BtnEnter.Visible = 0
		Progress.Visible = 1
		&ProgressId = 'wpFechaTrans' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		if &TrsSts = Status_Pedido.FECHADO
			AbreTransferenciaProduto.Submit('wpFechaTrans', &ProgressId, &EmpCod, &FilCod, &Context.PesCod, &trsCod)
		Else
			FechaTransferenciaProduto.Submit('wpFechaTrans', &ProgressId, &EmpCod, &FilCod, &Context.PesCod, &trsCod)
		EndiF
	Else
		AbreCancelaTransferenciaProduto.Call(&EmpCod, &trsCod)
		return
	Endif

EndEvent


]]></Source>
