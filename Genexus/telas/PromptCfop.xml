	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'EnableDynamicFilters1'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CfoNom1.Visible = False
	&CfoDesCpl1.Visible = False
	&CfoCod1.Visible = False
	Do Case
	Case &DynamicFiltersSelector1 = !'CFONOM'
		&CfoNom1.Visible = True
	Case &DynamicFiltersSelector1 = !'CFODESCPL'
		&CfoDesCpl1.Visible = True
	Case &DynamicFiltersSelector1 = !'CFOCOD'
		&CfoCod1.Visible = True
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'EnableDynamicFilters2'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CfoNom2.Visible = False
	&CfoDesCpl2.Visible = False
	&CfoCod2.Visible = False
	Do Case
	Case &DynamicFiltersSelector2 = !'CFONOM'
		&CfoNom2.Visible = True
	Case &DynamicFiltersSelector2 = !'CFODESCPL'
		&CfoDesCpl2.Visible = True
	Case &DynamicFiltersSelector2 = !'CFOCOD'
		&CfoCod2.Visible = True
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

