Sub 'EnableDynamicFilters3'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CfoNom3.Visible = False
	&CfoDesCpl3.Visible = False
	&CfoCod3.Visible = False
	Do Case
	Case &DynamicFiltersSelector3 = !'CFONOM'
		&CfoNom3.Visible = True
	Case &DynamicFiltersSelector3 = !'CFODESCPL'
		&CfoDesCpl3.Visible = True
	Case &DynamicFiltersSelector3 = !'CFOCOD'
		&CfoCod3.Visible = True
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'ResetDynFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&DynamicFiltersEnabled2 = False
	&DynamicFiltersSelector2 = !'CFONOM'
	&CfoNom2.SetEmpty()
	Do 'EnableDynamicFilters2'

	&DynamicFiltersEnabled3 = False
	&DynamicFiltersSelector3 = !'CFONOM'
	&CfoNom3.SetEmpty()
	Do 'EnableDynamicFilters3'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

