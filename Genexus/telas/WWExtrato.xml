      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&hoje  = ServerDate()
	&DtaIni.Enabled = False
	&DtaFin.Enabled = False
	&IsMostraDetalhe = Status_SimNao.Nao
	If &httpRequest.Method = 'GET'
		PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		&ExtTip = Val(substr(&PadObs,21,1))
		&ExtTip = Iif(&ExtTip = 0,4,&ExtTip)
		&ExtFil = 1
	 
		If &ExtTip = 4
			&DtaIni = ctod(substr(&PadObs,1,10))
			&DtaFin = ctod(substr(&PadObs,11,10))
		EndIf
		
		If &DtaIni.IsEmpty()
			&DtaIni = YMDtoD(year(&hoje),Month(&hoje),1)
		EndIf
		If &DtaFin.IsEmpty()
			&DtaFin = YMDtoD(year(&hoje),Month(&hoje),day(EoM(&hoje)))
		EndIf
	EndIf
	
	Do 'CalculaData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ExtTip.Click

	Do 'CalculaData'

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS014.link(&EmpCod,&context.FilCod,&CtaBanCod,&DtaIni,&DtaFin,&ExtFil,&IsMostraDetalhe)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	
	&PadObs = dtoC(&DtaIni)+dtoc(&DtaFin)
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

EndEvent

Sub 'CalculaData'

	&DtaIni.Enabled = False
	&DtaFin.Enabled = False
	Do case
		Case &ExtTip = 1  //Mensal 
			&DtaIni = YMDtoD(year(&hoje),Month(&hoje),1)
			&DtaFin = YMDtoD(year(&hoje),Month(&hoje),day(EoM(&hoje)))
			
		Case &ExtTip = 2 // Semanal
			&DtaIni = &hoje - (DoW(&hoje) -1)
			&DtaFin = &hoje + (7 - DoW(&hoje))
		Case &ExtTip = 3 // Diário
			&DtaIni = &hoje
			&DtaFin = &hoje
			
		Case &ExtTip = 4 // Outro
			&DtaIni.Enabled = True
			&DtaFin.Enabled = true			
	EndCase

EndSub


]]></Source>
