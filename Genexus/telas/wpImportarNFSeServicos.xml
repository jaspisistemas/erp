Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Servicos.EmpCod = &EmpCod
	&WizardData.Servicos.FilCod = &FilCod
	&WizardData.Servicos.tmpNFeCod = &tmpNFeCod
	&WizardData.Servicos.tmpEmixCod = &tmpEmixCod
	&WizardData.Servicos.Mensagem = &Mensagem
	&WizardData.Servicos.MostrarPendentes = &MostrarPendentes
	&WizardData.Servicos.NfeChv = &NfeChv
	&WizardData.Servicos.ForCNPJ = &ForCNPJ
	&WizardData.Servicos.tmpEmixNom = &tmpEmixNom
