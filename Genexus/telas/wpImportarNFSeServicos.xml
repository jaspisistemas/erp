		&GridItem.tmpPedQtdVarchar = &tmpPedQtdVarchar
		&GridItem.tmpPedVlrUnt = &tmpPedVlrUnt

		&WizardData.Servicos.Grid.Add(&GridItem)
	EndFor
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

