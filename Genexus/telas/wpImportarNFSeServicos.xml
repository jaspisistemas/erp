        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&tmpNFeCod.Visible = False
	&tmpEmixCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

EndEvent

Event Grid.Load

	&tmpProRef = tmpProRef
	&tmpEntCFOP = tmpEntCFOP
	
	&tmpProQtdCmpEmb = tmpProQtdCmpEmb
	if &tmpProQtdCmpEmb < 0
		&tmpProQtdCmpEmb = &tmpProQtdCmpEmb*-1
	Endif
	&tmpProQtdCmpEmbVarchar = toformattedString(&tmpProQtdCmpEmb)
	
	&tmpPedQtdVarchar = toformattedString(tmpPedQtd)
	RetiraZerosDepoisVirgula.Call(&tmpPedQtdVarchar, &tmpPedQtdVarchar)
		
	If tmpProQtdCmpEmb <> 0 and tmpProQtdCmpEmb <> 1
		RetiraZerosDepoisVirgula.Call(&tmpProQtdCmpEmbVarchar, &tmpProQtdCmpEmbVarchar)

		if tmpProQtdCmpEmb > 0
			&tmpPedQtd = tmpProQtdCmpEmb * tmpPedQtd
			&Varchar = toformattedString(&tmpPedQtd)
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
		
			&tmpPedQtdVarchar += ' X '+ &tmpProQtdCmpEmbVarchar.Trim() + ' ('+&Varchar.Trim() + ')'
		Else
			&tmpPedQtd = tmpPedQtd / (tmpProQtdCmpEmb)		
			&Varchar = toformattedString(&tmpPedQtd)
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
		
			&tmpPedQtdVarchar += ' / '+ &tmpProQtdCmpEmbVarchar.Trim() + ' (' +&Varchar.Trim() + ')'
		Endif
	EndIf
	 
	
	&tmpProNom.TooltipText = tmpProNomERP

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Editar = !'<i class="fa fa-pen"></i>'

	

&auxMensagem = trim(tmpProNomERP)
&tmpProNom = &auxMensagem

	

&auxMensagem = trim(tmpProForCod)+'- '+trim(tmpProNom)
&tmpProForCodNom = &auxMensagem

	&tmpPedVlrUnt = tmpPedVlrUnt
	Do Case
		Case tmpProCod <> 0
			&GridBadge = format(!"<i class='fa fa-circle FontColorIconSuccess FontColorIconSmall BootstrapTooltipRight' title='%1'></i>", "Vinculado com Produto do ERP")
		Case tmpProCod = 0
			&GridBadge = format(!"<i class='fa fa-circle FontColorIconDanger FontColorIconSmall BootstrapTooltipRight' title='%1'></i>", "Pruduto ainda não cadastrado")
		Otherwise
			&GridBadge = ''
	EndCase
	&tmpNcmCodWithTags.HorizontalAlignment = !'Right'
	&tmpNcmCodWithTags = trim(tmpNcmCod.ToFormattedString())
	If tmpNcmCod <> tmpProNcmCod
		&tmpNcmCodWithTags = format(!"<i class='fa fa-circle FontColorIconWarning FontColorIconSmall TagBeforeText BootstrapTooltipTop' title='%1'></i>", "NCM Difere do cadastro vinculado.") + &tmpNcmCodWithTags
	EndIf
	If tmpNcmCod =  tmpProNcmCod
		&tmpNcmCodWithTags = format(!"<i class='fa fa-circle FontColorIconSuccess FontColorIconSmall TagBeforeText BootstrapTooltipTop' title='%1'></i>", "NCM é igual do cadastro vinculado.	") + &tmpNcmCodWithTags
	EndIf
	If tmpProNcmCod = 0 or tmpProNcmCod = 99
		&tmpNcmCodWithTags = format(!"<i class='fa fa-circle FontColorIconDanger FontColorIconSmall TagBeforeText BootstrapTooltipTop' title='%1'></i>", "NCM nao informado no vinculo do produto.	") + &tmpNcmCodWithTags
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		wpImportarNFSe(!'Servicos', !'GravarNFSe', false, &SessionGuid)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

