EndSub

Event &tmpProNom.Click

	Produtos.Popup('RETURN', TrnMode.Update, &EmpCod, tmpProCod, '')
	Refresh keep

EndEvent

Event &Editar.Click

	wpnotatemporariaNFSeProduto.popup(tmpNFeCod,tmpNfeItmCod)
	Refresh keep

EndEvent

Sub 'LoadTemporaria'

	For Each Order tmpNFeCod
		WHere tmpNFeCod = &tmpNFeCod
		
		RetornaNomeTipoLancamento.Call(&EmpCod, tmpLctCod, &LctNom)
		btnAlterarOperacao.Caption = &LctNom
		btnAlterarOperacao.TooltipText = 'Clique para trocar Tipo lançamento'
		
		if tmpPedCliCnpj.IsEmpty()
			&ForCNPJ = tmpPedCliCpf
		Else
			&ForCNPJ = tmpPedCliCnpj
		EndIF
		
		&NfeChv = tmpNfeChv
		&tmpEmixCod = tmpEmixCod
		&tmpEmixNom = tmpEmixNom
		if tmpEmixNom.Length() > 20
			&tmpEmixNom.TooltipText = tmpEmixNom
			&tmpEmixNom = gxGetMLi(tmpEmixNom, 1, 20)
		Endif
		&LctCod = tmpLctCod
		
		
		Exit
	When None
		wwNotasServico.Link()
	EndFor

EndSub


