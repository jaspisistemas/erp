      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&IsAcesso = false 
	DpFilialAcesso.Call(&ParmEmpCod, &ParmPesCod, &sdtFilialAcesso)
	for &sdtFilialAcessoitem in &sdtFilialAcesso
		if &sdtFilialAcessoitem.PesFilAce = &ParmFilCod
			&IsAcesso = true
			Exit
		Endif
	EndFor

//	LoadWWPContext.Call(&Context)
	&AutIsAdm = RetornaAutorizacaoAdministrador.Udp(&ParmEmpCod, &ParmPesCod)
	retornaAutorizacao.Call('WWNOTAS', Status_SimNao.Nao, 2, &wwNotasAutNiv)
	if &wwNotasAutNiv < 2 and &AutIsAdm = false
		retornaAutorizacao.Call('WWCTE', Status_SimNao.Nao, 2, &wwNotasAutNiv)
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event gridWid.Load

	If &wwNotasAutNiv > 1 or &AutIsAdm = true
		WCwpValidadeCertificado.Object = wpValidadeCertificado.Create(&ParmEmpCod)	
		load
		
		WCwpValidadeCertificado.Object = wcNotasPendentes.Create(&ParmEmpCod)
		load
		
		retornaAutorizacao.Call('WWREMESSA', Status_SimNao.Nao, 1, &wwRemessaAutNiv)
		if &wwRemessaAutNiv > 1
			&QtdBolSemReg = RetornaBoletosSemRegistro.udp(&ParmEmpCod)
			if &QtdBolSemReg > 0
				WCwpValidadeCertificado.Object = wcRegistraBoletos.Create(&ParmEmpCod)
				load
			EndIf
		Endif
	
		if &IsAcesso = true
			
			WCwpValidadeCertificado.Object = wcAvisoMensalidadeSistema.Create(&ParmEmpCod)
			Load
		Endif

	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


