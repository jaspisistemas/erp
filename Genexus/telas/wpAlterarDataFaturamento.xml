      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPALTERARDATAFATURAMENTO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&FilCodNom = trim(str(&Context.FilCod)) + ' - ' + trim(&Context.FilRaz)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&FilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	oqFazer.ForeColor 	= RGB(0, 140, 40)
	oqFazer1.ForeColor 	= RGB(0, 140, 40)
	oqFazer2.ForeColor 	= RGB(0, 140, 40)
	
	&PedCod.SetFocus()

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

EndEvent

Event &PedCod.IsValid

	do 'loadPedido'

EndEvent

Event Enter

	Do Case
		Case &NovPedDtaEms.IsEmpty()
			msg('Informe a Nova Data de Emissão!')
			
		Case &NovPedDtaFat.IsEmpty() and not &PedDtaFat.IsEmpty()
			msg('Informe a Nova Data de Faturamento!')
			
		Case &NovPedDtaFat < &NovPedDtaEms 
			msg('A nova Data de Faturamento não pode ser Menor que a Nova Data de Emissão!')
			
		Case &PedDtaFat.IsEmpty() and not &NovPedDtaFat.IsEmpty()
			msg('Não é possível alterar data de Faturamento de um pedido que não possuí Data de Faturamento!')
			
		Case &IsEncontrado = false
			msg('Pedido não Encontrado!')
			
		Otherwise
			If &PedDtaEms <> &NovPedDtaEms or &NovPedDtaFat <> &PedDtaFat
				AtualizaDatasPedido.Call(&EmpCod, &FilCod, &PedCod, &NovPedDtaEms, &Context.PesCod, &NovPedDtaFat, &Context.UserName)
				do 'loadPedido'
				Msg('Datas Alteradas com Sucesso!')
				&PedCod.SetFocus()
			EndIf
	EndCase

EndEvent

Sub 'loadPedido'

	&IsEncontrado = false
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedCliCodRaz 	= PedCliCodRaz
		&PedDtaEms 		= PedDtaEms
		&PedDtaFat 		= PedDtaFat
		&NovPedDtaEms 	= PedDtaEms
		&NovPedDtaFat 	= PedDtaFat
		
		&IsEncontrado = true
		Exit
	When none
		If &PedCod <> 0
			&PedCliCodRaz = 'PEDIDO NÃO LOCALIZADO'
			msg(&PedCliCodRaz)
		Else
			&PedCliCodRaz = 'INFORME CÓDIGO DO PEDIDO'
		EndIF
	EndFor

EndSub


]]></Source>
