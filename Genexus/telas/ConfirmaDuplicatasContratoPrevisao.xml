        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	
	&OcultarOutras = true
	
	//GravaDuplicatasTemporariasContratoPrevisao_Existentes.Call(&EmpCod, &FilCod, &PesCod, &SerItmCod)
	
	do 'SubTotaliza'
	&Count = 500 // pra nao interferir qnd for gerar nova dup na tmp
	Do 'GetCliente'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&OcultarCanceladas.Visible = False
	&OcultarPagas.Visible = False
	&OcultarParciais.Visible = False
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&PesCod.Visible = False
	&SerCliCod.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&RemoveDuplicata.ColumnHeaderClass = !'WWActionColumn'
	&DupSts.ColumnHeaderClass = !'WWColumn'
	&SerItmDupNro.ColumnHeaderClass = !'WWColumn'
	&SerItmDupVlr.ColumnHeaderClass = !'WWColumn'
	&CreVlrSdo.ColumnHeaderClass = !'WWColumn'
	DupTmpCreDtaVct.ColumnHeaderClass = !'WWColumn'
	&semana.ColumnHeaderClass = !'WWColumn'
	&SerItmPlanCod.ColumnHeaderClass = !'WWColumn'
	&SerItmCbrCod.ColumnHeaderClass = !'WWColumn'

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = grid.CurrentPage
	
	do 'SubTotaliza'

EndEvent

Event Grid.Load

	&DupSts = DupTmpCreSts
	&SerItmDupNro = DupTmpCreDupNro		
	&SerItmFilPgt = DupTmpCreFilPgt
	&SerItmRecPag = DupTmpCreRecPag
	&SerItmDtaEms = DupTmpCreDtaEms
	&SerItmDupVlr = DupTmpCreVlrDup
	&CreVlrSdo = DupTmpCreVlrSdo
	
	&SerItmCbrCod = DupTmpCreCbrCod
	&SerItmCbrCod.Visible = true
	if DupTmpCreRecPag = ReceberPagar.Pagar
		&SerItmCbrCod.Visible = false
	EndIf
	
	&Semana = substr(cdow(DupTmpCreDtaVct), 1, 3)
	&SerItmVlrSdo = DupTmpCreVlrSdo
	&SerItmCliCod = DupTmpCreCliCod
	
	&PesCodRaz = ''
	//RetornaInfoConfirmaDuplicatasServico.Call(DupTmpEmpCod, DupTmpFilCod, DupTmpCreCliCod, &SerItmCod, &PesCodRaz, &SerCodNom)
	
//	&SerItmVenCod = DupTmpCreVenCod
	&AuxEmpCod = DupTmpEmpCod
	&AuxPesCod = DupTmpPesCod
	&AuxFilCod = DupTmpFilCod
	&AuxCreCod = DupTmpCreCod
	&SerItmBloNro = DupTmpCreBloNro
	&SerItmPlanCod = DupTmpCrePlanCod
	
	&SerItmDupNro.Enabled = 1
	DupTmpCreDtaVct.Enabled = 1
	&SerItmDupVlr.Enabled = 1
	&SerItmCbrCod.Enabled = 1
//	&SerItmDtaEms.Enabled = 1
	&SerItmBloNro.Enabled = 1
	&SerItmPlanCod.Enabled = 1
	if DupTmpCreVlrDup = 0
		&DupSts = 'I' //evitar lançar duplicata com valor zero
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&RemoveDuplicata.FromImage(ActionFiltersClean)
	&RemoveDuplicata.TooltipText = ""

	Do Case
		Case &DupSts = 'I'
			&RemoveDuplicata.ColumnClass = !'WWActionColumn WWColumnLineThrough WWColumnLineThroughFirstColumn'
			&DupSts.ColumnClass = !'WWColumn WWColumnLineThrough'
			&SerItmDupNro.ColumnClass = !'WWColumn WWColumnLineThrough'
			&SerItmDupVlr.ColumnClass = !'WWColumn WWColumnLineThrough'
			&CreVlrSdo.ColumnClass = !'WWColumn WWColumnLineThrough'
			DupTmpCreDtaVct.ColumnClass = !'WWColumn WWColumnLineThrough'
			&semana.ColumnClass = !'WWColumn WWColumnLineThrough'
			&SerItmPlanCod.ColumnClass = !'WWColumn WWColumnLineThrough'
			&SerItmCbrCod.ColumnClass = !'WWColumn WWColumnLineThrough'
		Case &DupSts = 'P'
			&RemoveDuplicata.ColumnClass = !'WWActionColumn WWColumnSuccess WWColumnSuccessFirstColumn'
			&DupSts.ColumnClass = !'WWColumn WWColumnSuccess'
			&SerItmDupNro.ColumnClass = !'WWColumn WWColumnSuccess'
			&SerItmDupVlr.ColumnClass = !'WWColumn WWColumnSuccess'
			&CreVlrSdo.ColumnClass = !'WWColumn WWColumnSuccess'
			DupTmpCreDtaVct.ColumnClass = !'WWColumn WWColumnSuccess'
			&semana.ColumnClass = !'WWColumn WWColumnSuccess'
			&SerItmPlanCod.ColumnClass = !'WWColumn WWColumnSuccess'
			&SerItmCbrCod.ColumnClass = !'WWColumn WWColumnSuccess'
		Case &DupSts = 'C'
			&RemoveDuplicata.ColumnClass = !'WWActionColumn WWColumnDanger WWColumnDangerFirstColumn'
			&DupSts.ColumnClass = !'WWColumn WWColumnDanger'
			&SerItmDupNro.ColumnClass = !'WWColumn WWColumnDanger'
			&SerItmDupVlr.ColumnClass = !'WWColumn WWColumnDanger'
			&CreVlrSdo.ColumnClass = !'WWColumn WWColumnDanger'
			DupTmpCreDtaVct.ColumnClass = !'WWColumn WWColumnDanger'
			&semana.ColumnClass = !'WWColumn WWColumnDanger'
			&SerItmPlanCod.ColumnClass = !'WWColumn WWColumnDanger'
			&SerItmCbrCod.ColumnClass = !'WWColumn WWColumnDanger'
		Otherwise
			&RemoveDuplicata.ColumnClass = 'WWActionColumn'
			&DupSts.ColumnClass = 'WWColumn'
			&SerItmDupNro.ColumnClass = 'WWColumn'
			&SerItmDupVlr.ColumnClass = 'WWColumn'
			&CreVlrSdo.ColumnClass = 'WWColumn'
			DupTmpCreDtaVct.ColumnClass = 'WWColumn'
			&semana.ColumnClass = 'WWColumn'
			&SerItmPlanCod.ColumnClass = 'WWColumn'
			&SerItmCbrCod.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//Do 'SubTotaliza'
	
	Do case
		case &CreVlrSdo = &SerItmDupVlr and DupTmpCreSts = 'A' and DupTmpCreVlrDup <> 0 //CreVlrDup = 0 é pra entrar na segunda condição
			&RemoveDuplicata.Enabled = 1
			&RemoveDuplicata.FromImage(ico_error)
			&SerItmDupNro.Enabled = 1
			//	DupTmpCreDtaVct.Enabled = 1 - nao precisa !?
			&SerItmDupVlr.Enabled = 1
			&SerItmBloNro.Enabled = 1
			&SerItmPlanCod.Enabled = 1
			&SerItmCbrCod.Enabled = 1
			&CreVlrSdo.Enabled = 0
			
		case DupTmpCreSts = 'I' or &DupSts = 'I'
			&RemoveDuplicata.FromImage(UndeleteRow)
			&RemoveDuplicata.Enabled = 1
			&SerItmDupNro.Enabled = 0
			DupTmpCreDtaVct.Enabled = 0 //- nao precisa !?
			&SerItmDupVlr.Enabled = 0
			&SerItmBloNro.Enabled = 0
			&SerItmPlanCod.Enabled = 0
			&SerItmCbrCod.Enabled = 0
			&CreVlrSdo.Enabled = 0
			
		case &CreVlrSdo <> &SerItmDupVlr or &DupSts = 'P'
			&RemoveDuplicata.FromImage(IconVerde)
			&RemoveDuplicata.Enabled = 0
			&SerItmDupNro.Enabled = 0
			DupTmpCreDtaVct.Enabled = 0 // - nao precisa !?
			&SerItmDupVlr.Enabled = 0
			&SerItmBloNro.Enabled = 0
			&SerItmPlanCod.Enabled = 0
			&SerItmCbrCod.Enabled = 0
			&CreVlrSdo.Enabled = 0
			
		case &DupSts = 'C'
			&RemoveDuplicata.FromImage(iconVermelho)
			&RemoveDuplicata.Enabled = 0
			&SerItmDupNro.Enabled = 0
			DupTmpCreDtaVct.Enabled = 0 // - nao precisa !?
			&SerItmDupVlr.Enabled = 0
			&SerItmBloNro.Enabled = 0
			&SerItmPlanCod.Enabled = 0
			&SerItmCbrCod.Enabled = 0
			&CreVlrSdo.Enabled = 0
		
	EndCase

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

