	MonitoraContratoPrevisaoCliente.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInserirDup'

	&Count += 1
	NewTmpDuplicataContratoPrevisao.Call(&EmpCod, &FilCod, &PesCod, &SerItmCod, &Count, &SerItmRecPag )
	
	&AuxCreCod = &Count //para AtualizaDuplicatasTemporarias
	&SerItmDupNro.Enabled = 1
//	DupTmpCreDtaVct.Enabled = 1 - nao precisa !?
	&SerItmDupVlr.Enabled = 1
	&SerItmBloNro.Enabled = 1
	&SerItmPlanCod.Enabled = 1
	&DupSts = 'A'
	
	Do 'SubTotaliza'
	Refresh

