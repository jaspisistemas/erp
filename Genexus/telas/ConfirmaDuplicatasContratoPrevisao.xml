	&SerItmDupVlr = &CreVlrSdo

EndEvent

Event &SerItmBloNro.IsValid

	Do 'GravaGrid'
	do 'SubTotaliza'

EndEvent

Event &SerItmDupNro.IsValid

	Do 'GravaGrid'
	do 'SubTotaliza'

EndEvent

Event &SerItmDupVlr.IsValid

	&CreVlrSdo = &SerItmDupVlr
	Do 'GravaGrid'
	do 'SubTotaliza'

EndEvent

Event DupTmpCreDtaVct.IsValid

	Do 'GravaGrid'
	do 'SubTotaliza'

EndEvent

Event &SerItmPlanCod.IsValid

	Do 'GravaGrid'
	do 'SubTotaliza'

EndEvent

Event Enter

//	&IsErro = false
	&AuxMsg = ''
	
//	Do 'SubVerifica'
//	if &IsErro = false
		GravaDuplicatasContratoPrevisao.Call(&EmpCod, &PesCod, &FilCod, &FilCod, &SerItmCod)
		//GravaContratoPrevisao ( 'ULTVC' só usa empcod e seritmcod) - o resto não precisa
		GravaContratoPrevisao.Call('ULTVC',&EmpCod,&FilCod,&SerItmCod,'',0,0,0,0,TipoPlano.ANUAL,0,TipoLancamentoServico.CONTRATO,&Today,&Today,Status_AtivoInativo.ATIVO,0,0,ReceberPagar.Receber,0,'')
//		RetornaUltimoVencimentoDuplicata.Call(&EmpCod, &FilCod ,&SerItmCod, &SerItmUltVct)
		MonitoraContratoPrevisaoCliente.Link()
//	else
//		msg(&AuxMsg)
//	EndIf

EndEvent

Event &RemoveDuplicata.Click

	Do case
		case &DupSts = 'A'
			&DupSts = 'I'
			
			
		case &DupSts = 'I'
			&DupSts = 'A'
			
		case &DupSts = 'P'
			
		Otherwise 
			&DupSts = 'A'
	EndCase
	
	Do 'GravaGrid'
	Refresh
//	grid.Refresh()

EndEvent

Sub 'GravaGrid'

	&TotDupVlr = 0
	&Data = ServerDate()
	AtualizaDuplicatasTemporarias.Call(&AuxEmpCod, &AuxFilCod, &AuxFilCod ,&AuxCreCod, &AuxPesCod, &SerItmDupNro, DupTmpCreDtaVct, &SerItmDupVlr ,&SerItmCbrCod ,&Data ,&SerItmBloNro, &SerItmPlanCod, 0 , &DupSts)

EndSub

Sub 'SubTotaliza'

	&TotDupVlr = 0
	For each Order DupTmpEmpCod,DupTmpFilCod,DupTmpPesCod
		Where DupTmpEmpCod = &Context.EmpCod
		Where DupTmpFilCod = &Context.FilCod
		Where DupTmpPesCod = &Context.PesCod
		where DupTmpCreSts <> 'I' and DupTmpCreSts <> 'C'
		&TotDupVlr += DupTmpCreVlrSdo
	EndFor

EndSub

Sub 'GetCliente'

	&CfgVlr = RetornaConfSistema.UDP(&EmpCod, &FilCod, domConfSistema.TCon020_ClientePadraoVista)
	&VistaCreCliCod = iif(&CfgVlr = '', 0, val(&CfgVlr))
	
	For each order EmpCod, SerItmCod
		where EmpCod = &EmpCod
		where SerItmCod = &SerItmCod
		if SerCliCod = &VistaCreCliCod
			&SerCliCodRaz = SerCliNom
		else
			&SerCliCod = SerCliCod
			&SerCliCodRaz = SerCliCodRaz
		EndIf
		&SerItmAbv = SerItmAbv
		&SerItmTip = SerItmTip
		&SerItmRecPag = SerItmRecPag
		exit
	EndFor

EndSub

