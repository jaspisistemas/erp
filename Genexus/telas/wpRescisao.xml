				&sdtPagamentosFolhaContasItem.FPagDupCod = 2
				&sdtPagamentosFolhaContasItem.FPagDupCreCod = 0
				&sdtPagamentosFolhaContasItem.FPagDupFilCod = 0
				&sdtPagamentosFolhaContasItem.FPagDupVct = &guiaFPagDupVct
				
				&sdtPagamentosFolhaContasItem.FPagDupVlr = &guiaFPagDupVlr
				&sdtPagamentosFolhaContasItem.FPagDupPlanCod = &guiaPlanCod
				&sdtPagamentosFolhaContas.Add(&sdtPagamentosFolhaContasItem)
			Endif
		
			prcGravaPagamentoRescisao.Call(&EmpCod, &PesCod, &FPagCod, &PesRecCod, &FerAnoBas, &GravarPesDtaDem, &IsBloquearUsuarioSenhaAcessoSistema, &IsRemoverStatusFuncionario, &sdtItensFolha, &sdtPagamentosFolhaContas, &sdtPagamentoFolhaAdiantamentos)
			
			wwPagamentoRescisao.Link()
