      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&PESSOACONTAS = 'PC'+serverTime()
	&WebSession.Remove(&PESSOACONTAS)
	
	&CreRecPag = 'P'
	//&CreRecPag.Visible = 0
	
	&FerAnoBas = Year(serverdate())
	//&FPagMes

	txtErroFuncionario.Caption = ''
	txtErro.Caption = ''
	txtPlanoPadraoGuia.Visible =0
	txtPlanoPadrao.Visible = 0
	tbAdiantamentos.Visible = 0
	tbAdiantamentosVencendosMes.Visible= 0
	tbAdiantamentosSelecionados.Visible = 0

	if &parmFPagCod > 0
		&EmpCod = &parmEmpCod
		&FPagCod = &parmFPagCod
		do 'carregaFolhaLancada'
		&PesCod.Enabled=0
		do 'Totaliza'
	Else
		loadwwpContext.Call(&WwpContext)
		&EmpCod = &WwpContext.EmpCod
		
		do 'getOperacaoPadraoFerias'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&CreRecPag.Visible = False
	&guiaPlanCod.Visible = False
	&PlanCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAdiantamentos'

	&WebSession.Set(&PESSOACONTAS, &sdtPagamentoFolhaAdiantamentos.ToJson())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UserAdiantamentos_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event UserAdiantamentos_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpSelectionarAdiantamentos_SDT.Create(&EmpCod, &FPagCod, &PESSOACONTAS, &FerAnoBas, &FPagMes, &PesCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	retornaCodigoPlanoContas.Call(&EmpCod, &PlanoContas, &PlanCod)
	retornaCodigoPlanoContas.Call(&EmpCod, &GuiaPlanoContas, &guiaPlanCod)
	
	txtErro.ForeColor = rgb(255,0,0)
	Do CAse
		CAse &FPagDupVlr.IsEmpty() or (&FPagDupVlr-&TotalAdiantamentos < 0)
			txtErro.Caption = 'Valor Total Rescisório não pode ser zero, ou não pode ter mais adiantamentos que valor rescisório!'
			&FPagDupVlr.SetFocus()
		CAse &FPagDupVct.IsEmpty()
			txtErro.Caption = 'Data Vencimento Rescisório deve ser informado!'
			&FPagDupVct.SetFocus()
		Case &PlanCod= 0
			txtErro.Caption = 'Plano de contas inválido!'
			&PlanoContas.SetFocus()
			
		Case &IsmultaRescisoria = true and &guiaFPagDupVct.IsEmpty()
			txtErro.Caption = 'Data Vencimento Multa Rescisória deve ser informado!'
			&guiaFPagDupVct.SetFocus()
		Case &IsmultaRescisoria = true and &guiaFPagDupVlr.IsEmpty()
			txtErro.Caption = 'Valor Total Multa Rescisória não pode ser zero!'
			&guiaFPagDupVlr.SetFocus()
		Case &IsmultaRescisoria = true and &guiaPlanCod.IsEmpty()
			txtErro.Caption = 'Plano de contas da Multa Rescisória inválido!'
			&guiaPlanoContas.SetFocus()
			
		Case &FPagDupVlr < &TotalAdiantamentos
			txtErro.Caption = 'Total Valores Rescisórios não pode ser menor que o total de Adiantamentos!'
			&FPagDupVlr.SetFocus()
			
		Case (&FPagDupVlr < 0)
			txtErro.Caption = 'Total Pago não pode ser menor do que zero!'
			&FPagDupVlr.SetFocus()
		Otherwise
			
			//Rescisao
			&TotalPago = &FPagDupVlr
			
			&sdtItensFolhaItem = new()
			&sdtItensFolhaItem.FPagItemVlr = &FPagDupVlr
			&sdtItensFolhaItem.FPagGerTip = 'M'
			
			Do CAse
				CAse &IsAvisoIndenizado= true
					&sdtItensFolhaItem.FPagLcfCod = 13 //Aviso Prévio Indenizado
					&sdtItensFolhaItem.FPagItemCpl = ''
				CAse &IsAvisoIndenizado= FALSE
					&sdtItensFolhaItem.FPagLcfCod = 14 //Aviso Prévio Trabalahado
					&sdtItensFolhaItem.FPagItemCpl = ''
			EndCAse			
			&sdtItensFolhaItem.PlanCod = &PlanCod
			&sdtItensFolhaItem.LcfCreDeb = 'C'				
			&sdtItensFolha.add(&sdtItensFolhaItem)		
			
			//multa
			if (&IsmultaRescisoria = true and &guiaFPagDupVlr > 0)
				&sdtItensFolhaItem = new()
				&sdtItensFolhaItem.FPagItemVlr = &guiaFPagDupVlr
				&sdtItensFolhaItem.FPagGerTip = 'M'
				
				&TotalPago += &guiaFPagDupVlr
				
				&sdtItensFolhaItem.PlanCod = &guiaPlanCod
				&sdtItensFolhaItem.LcfCreDeb = 'C'
				&sdtItensFolhaItem.FPagLcfCod = 24 //Multa fgts rescisorio
				&sdtItensFolha.add(&sdtItensFolhaItem)
			Else
				&guiaFPagDupVlr = 0
			EndIf
			
			//Adiantamentos
			if &TotalAdiantamentos > 0
				&TotalPago -= &TotalAdiantamentos
				&sdtItensFolhaItem = new()
				&sdtItensFolhaItem.FPagItemVlr = &TotalAdiantamentos
				&sdtItensFolhaItem.FPagGerTip = 'M'
				
				&sdtItensFolhaItem.LcfCreDeb = 'D'
				&sdtItensFolhaItem.FPagLcfCod = 95 //Adiantamentos
				&sdtItensFolha.add(&sdtItensFolhaItem)
			Else
				&TotalAdiantamentos = 0
				&sdtPagamentoFolhaAdiantamentos.Clear()
			Endif
		
			//Duplicatas
			&sdtPagamentosFolhaContasItem = new()
			&sdtPagamentosFolhaContasItem.ContaDuplicata = 'D' //Duplicata
			&sdtPagamentosFolhaContasItem.FPagDupCod = 1
			&sdtPagamentosFolhaContasItem.FPagDupCreCod = 0
			&sdtPagamentosFolhaContasItem.FPagDupFilCod = 0
			&sdtPagamentosFolhaContasItem.FPagDupVct = &FPagDupVct
			
			&sdtPagamentosFolhaContasItem.FPagDupVlr = (&FPagDupVlr-&TotalAdiantamentos)
		
			&sdtPagamentosFolhaContasItem.FPagDupPlanCod = &PlanCod
			&sdtPagamentosFolhaContas.Add(&sdtPagamentosFolhaContasItem)
			
			if &IsmultaRescisoria = true //Pagar multa rescisoria
				&sdtPagamentosFolhaContasItem = new()
