Sub 'Totaliza'

	&TotalPago = &FPagDupVlr
	if &IsmultaRescisoria = true
		&TotalPago += &guiaFPagDupVlr
	EndIf
	&TotalPago -= &TotalAdiantamentos

EndSub

Sub 'getOperacaoPadraoFerias'

	if &IsAvisoIndenizado = true
		For Each Order EmpCod, LcfCod
			Where EmpCod = &EmpCod
			Where LcfCod = 13 // INdenizado
			
			RetornaPlanCodNomVir.Call(EmpCod, LcfPlanCod, &auxPlanNomFerias)			
			Exit
		EndFor
	
		&PlanoContas = retornaMesmoValor.Udp(&auxPlanNomFerias, &EmpCod)
	Else
		For Each Order EmpCod, LcfCod
			Where EmpCod = &EmpCod
			Where LcfCod = 14 // Trabalhado
			
			RetornaPlanCodNomVir.Call(EmpCod, LcfPlanCod, &auxPlanNomFerias)			
			Exit
		EndFor
	
		&PlanoContas = retornaMesmoValor.Udp(&auxPlanNomFerias, &EmpCod)
	Endif

	if &guiaPlanoContas.IsEmpty()
		For Each Order EmpCod, LcfCod
			Where EmpCod = &EmpCod
			Where LcfCod = 24 // Multa
			
			RetornaPlanCodNomVir.Call(EmpCod, LcfPlanCod, &auxPlanNomFerias)			
			Exit
		EndFor
		
		&guiaPlanoContas = retornaMesmoValor.Udp(&auxPlanNomFerias, &EmpCod)
	Endif
	
	if &PlanoContas.IsEmpty()
		if &IsAvisoIndenizado = true
			txtPlanoPadrao.Caption = 'Plano contas padrão não atribuído a operação folha "13-Aviso Prévio Indenizado"'
		Else
			txtPlanoPadrao.Caption = 'Plano contas padrão não atribuído a operação folha "14-Aviso Prévio Trabalhado"'
		Endif
	
		txtPlanoPadrao.Visible= 1
		txtPlanoPadrao.ForeColor = RGB(255,0,0)
	Endif
	if &guiaPlanoContas.IsEmpty()
		txtPlanoPadraoGuia.Caption = 'Plano contas padrão não atribuído a operação folha "15-Pagamento Férias"'
		txtPlanoPadraoGuia.Visible= 1
		txtPlanoPadraoGuia.ForeColor = RGB(255,0,0)
	Endif

EndSub

Sub 'carregaFolhaLancada'

	For Each Order EmpCod, FPagCod
		Where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		
		//		&DescricaoMensagem = trim(Str(FPagAno)) + ' | EDITANDO LANÇAMENTO'
		//		&FerAnoBas.AddItem(FPagAno, &DescricaoMensagem)
		//		&FerAnoBas.ForeColor = RGB(255,0,0)
		
		&FerAnoBas = FPagAno
		&PesCod = FPagPesCod
		&FPagMes = month(FPagLctDtaHor.ToDate())
		
		&GravarPesDtaDem = FPagDtaDem
		&IsBloquearUsuarioSenhaAcessoSistema = FPagIsBloUsu
		&IsRemoverStatusFuncionario = FPagIsRemFun
		//Itens da Folha
		For Each Order EmpCod, FPagCod, FPagLcfCod
			Do CAse
				CAse FPagLcfCod = 13 //Aviso Prévio Indenizado
					&IsAvisoIndenizado = true
					&FPagDupVlr = FPagItemVlr
				Case FPagLcfCod = 14 //Aviso Prévio Trabalhado
					&IsAvisoIndenizado = false
					&FPagDupVlr = FPagItemVlr
				Case FPagLcfCod = 24//Multa Resisao
					&IsmultaRescisoria = true
					&guiaFPagDupVlr = FPagItemVlr
			EndCase
		EndFor
		
		if FPagSts <> Status_Folha.Aberto
			btnEnter.Enabled = 0
			&IsRemoverStatusFuncionario.Enabled = 0
			&IsBloquearUsuarioSenhaAcessoSistema.enabled = 0
			&GravarPesDtaDem.Enabled =0
			&IsAvisoIndenizado.Enabled =0
			&IsmultaRescisoria.Enabled = 0
			&FPagDupVlr.Enabled = 0
			&FPagDupVct.Enabled = 0
			&PlanoContas.Enabled = 0
			&guiaFPagDupVlr.Enabled = 0
			&guiaFPagDupVct.Enabled = 0
			&guiaPlanoContas.Enabled = 0
			
			btnEnter.Enabled =0
			
		Endif
		
		//adiantamentos
		&sdtPagamentoFolhaAdiantamentos.Clear()
		&TotalAdiantamentos = 0
		For Each Order EmpCod, FPagCod, FPagAdiMovCod,FPagAdiMovItmCod
			
			&TotalAdiantamentos += FPagAdiMovVlr
			
			&sdtPagamentoFolhaAdiantamentosItem = new()
			&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovCod = FPagAdiMovCod
			&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovItmCod = FPagAdiMovItmCod
			&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovVlr = FPagAdiMovVlr
			&sdtPagamentoFolhaAdiantamentos.Add(&sdtPagamentoFolhaAdiantamentosItem)
		EndFor
		
		//Duplicata
		For Each ORder EmpCod, FPagCod, FPagDupCod
			if FPagDupCod = 1 //Rescisao
				&FPagDupVct = FPagDupVct
				&PlanoContas = RetornaPlanCodNomVir.UDP(EmpCod, FPagDupPlanCod)
			Endif
			
			if FPagDupCod = 2
				&guiaFPagDupVct = FPagDupVct //Multa
				&guiaPlanoContas = RetornaPlanCodNomVir.UDP(EmpCod, FPagDupPlanCod)
			Endif
		EndFor
		
		Exit
	EndFor

	do 'getFuncionario'
	
	tbAdiantamentos.Visible = (&AlgumAdiantamento > 0 or &sdtPagamentoFolhaAdiantamentos.Count > 0)
	tbAdiantamentosSelecionados.Visible = &TotalAdiantamentos > 0

EndSub

Sub 'getFuncionario'

	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PesRaz= PesRaz
		&PesDtaAdm = PesDtaAdm
		&PesDtaDem = PesDtaDem
		&PesDtaReg = PesDtaReg				
		&PesIsFun = PesIsFun
		&PesIsVen = PesIsVen
		&PesFunFilCod = PesFunFilCod
		
//		do case
//			case PesDtaAdm.IsEmpty() or PesDtaAdm.IsNull()
//				txtErroFuncionario.Caption = 'Funcionário sem data de admissão informada, inclua a data admissão ao cadastro do funcionário!'
//				txtErroFuncionario.ForeColor = RGB(255,0,0)
//			Case PesIsFun <> true
//				txtErroFuncionario.Caption = 'Funcionário não está marcado como funcionário no seu cadastro!'
//				txtErroFuncionario.ForeColor = RGB(255,0,0)
//		EndCAse
		
		&PesRecCod = 0
		For EAch Order EmpCod, PesCod, (PesRecCod)
//			Where PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsEmpty() or PesRecSts.IsNull()
//			where not PesRecDtaAdm.IsEmpty() and not PesRecDtaAdm.IsNull()
//			Where PesRecDtaDem.IsEmpty() or PesRecDtaDem.IsNull()
			&PesRecCod = PesRecCod
			Exit
		EndFor
		
		Exit
	EndFor
	
	if &PesCod> 0
		&AdiantamentosPendentes = RetornaAdiantamento.Udp(&EmpCod, &PesCod, &FerAnoBas, &FPagMes)
		&AlgumAdiantamento = RetornaAdiantamento.Udp(&EmpCod, &PesCod, 0, 0)
		tbAdiantamentos.Visible = (&AlgumAdiantamento > 0 or &sdtPagamentoFolhaAdiantamentos.Count > 0)
		tbAdiantamentosVencendosMes.Visible= &AdiantamentosPendentes > 0 
		txtAvisoAdiantamentos.Caption= FORMAT('ESSA PESSOA POSSUI R$ %1 EM VALES COM VENCIMENTO NO PERIODO', trim(toformattedString(&AdiantamentosPendentes)))
	Endif
	
	&IsRemoverStatusFuncionario.Visible = (&PesIsFun = true or &PesIsVen = true)

EndSub


