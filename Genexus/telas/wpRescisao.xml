Event UserAdiantamentos_Modal.Close

	if userAdiantamentos_Modal.Result = 'S'
		&PadObs = ''
		&sdtPagamentoFolhaAdiantamentos.Clear()
		&TotalAdiantamentos = 0
		
		&PadObs = &WebSession.Get(&PESSOACONTAS)
		if not &PadObs.IsEmpty()
			&sdtPagamentoFolhaAdiantamentos.FromJson(&PadObs)
			
			for &sdtPagamentoFolhaAdiantamentosItem in &sdtPagamentoFolhaAdiantamentos
				&TotalAdiantamentos += &sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovVlr
			EndFor
		Endif
		
		do 'Totaliza'
		
		tbAdiantamentosSelecionados.Visible = &TotalAdiantamentos > 0
	Endif

