      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	//RetornaAutorizacao.Call('WWNOTASINUTILIZADAS', Status_SimNao.Sim, 2, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	TableFinanceiro.Visible = false
	&tmpCancelarDuplicatas = False
	&FilCod = &AuxFilCod
	&CteSer = &AuxCteSer
	&Mensagem = 'ERROS QUE IMPOSSIBILITAM A AUTORIZACAO DO CONHECIMENTO DE TRANSPORTE, INUTILIZACAO SOLICITADA'
	If not &AuxModCod.IsEmpty()
		&ModCod = &AuxModCod
	EndIf
	
	If not &auxFilInuNroIni.IsEmpty()
		&FilInuNroFin = &auxFilInuNroIni
		&FilInuNroIni = &auxFilInuNroIni
	EndIf
	
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		For each Order EmpCod, FilCod, CteCod,CteDupCod
			TableFinanceiro.Visible = true
			&tmpCancelarDuplicatas = true
			exit
		EndFor
		
		Exit
	EndFor
	do 'Total'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	obs.ForeColor = RGB(0,0,150)
	QtdNotas.ForeColor = RGB(0,0,150)

EndEvent

Event 'DoConfirmar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Do Case
		Case &VeioDeOnde = 'WWCTE'
			WWCte.Link()
		Otherwise
			wwNotasInutilizadas.Link()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	Do 'Verifica_especial'
	
	Do Case
		Case &CteSer.IsEmpty()
			msg('Informe a Serie da Nota')
		Case &FilInuNroIni.IsEmpty()
			msg('Informe a Sequencia Inicial')
		Case &FilInuNroFin.IsEmpty()
			msg('Informe a Sequencia Final')
			
		Otherwise
			If &erro = 0
				GeraXmlInutilizacaoCte.Call(&EmpCod, &FilCod,&CteCod,&ModCod, &CteSer, &FilInuNroIni, &FilInuNroFin, &Mensagem, &Context.PesCod,&tmpCancelarDuplicatas)
			EndIF
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FilInuNroIni.IsValid

	If &FilInuNroFin < &FilInuNroIni
		&FilInuNroFin = &FilInuNroIni
	EndIF
	do 'Total'

EndEvent

Event &FilInuNroFin.IsValid

	do 'Total'

EndEvent

Sub 'Total'

	&Total = &FilInuNroFin - &FilInuNroIni
	If &FilInuNroIni <> 0
		&Total += 1
	EndIF

	QtdNotas.Caption = 'Selecionado ' + trim(Str(&Total)) + ' sequências para a Inutilização'

EndSub

Sub 'Verifica_especial'

    &erro = 0 
    &Tamanho = len(&Mensagem)
    If &tamanho < 15 or &tamanho > 255
        msg('Tamanho da justificativa tem que ficar entre 15 e 255 caracteres!')
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&Mensagem,&Posicao,1) < ' '  or (substr(&Mensagem,&Posicao,1) > 'z'  ))
                msg('Caracter especial "'+  substr(&Mensagem,&Posicao,1) + '" Não é permitido!' ) 
                &erro = 1
            Endif
        EndFor
    EndIf

	If &FilInuNroFin < &FilInuNroIni
		&erro = 1
		msg('Numeração Final da Inutilização não pode ser menor que a Inicial!')
	EndIF

EndSub


]]></Source>
