      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPCURVAABCPRODUTOS', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&FilCodNom = trim(str(&Context.FilCod )) + ' - ' + trim(&Context.FilRaz)
	&ListarEstoque = Status_SimNao.Nao
	&SomenteComEstoque = Status_SimNao.Sim
	&A_EstABC_Qtd = 70
	&B_EstABC_Qtd = 20
	&C_EstABC_Qtd = 10
	&D_EstABC_Qtd = 0
	&TipoCurva  = 'V'
	&Ordem = 'C'
	&PesRaz = 'TODOS OS FORNECEDORES'
	&LisPesRaz = 'TODOS OS FORNECEDORES'
	&iniPedDtaFat = serverdate() - 365
	&finPedDtaFat = serverdate()
	
	&IncluirPedidosSemFinanceiro = Status_SimNao.Nao
	&IncluirProdutosInativos = Status_SimNao.Nao
	&AtualizarCurvaCadastro = Status_SimNao.Nao
	&ImprimirProdutosSemVenda = Status_SimNao.Nao

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&finPedDtaFat.TooltipText = "Período Ideal para Apuração são os ultimos 12 Meses. Mas os Últimos 6 Meses já é possível utilizar como Base."

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	padraoUsuario.Call('L', 'WPCURVAABC1', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&Ordem = Substr(&PadObs,1,1)
		&TipoCurva = Substr(&PadObs,2,1)
		&QualCurva = Substr(&PadObs,3,1)
	EndIF

	If &TipoCurva.IsEmpty()
		&TipoCurva = 'V'
	EndIf

	padraoUsuario.Call('L', 'WPCURVAABC2', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&AtualizarCurvaCadastro = iif(Substr(&PadObs,1,1) = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
		&CalcularListarTipoCurva = Substr(&PadObs,2,1)
		&IncluirProdutosInativos = iif(Substr(&PadObs,3,1) = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
		&IncluirPedidosSemFinanceiro = iif(Substr(&PadObs,4,1) = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
		&ImprimirProdutosSemVenda = iif(Substr(&PadObs,5,1) = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
	EndiF

EndEvent

Event Enter

	&PadObs = &AtualizarCurvaCadastro + &CalcularListarTipoCurva + &IncluirProdutosInativos + &IncluirPedidosSemFinanceiro + &ImprimirProdutosSemVenda
	padraoUsuario.Call('G', 'WPCURVAABC2', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	if (&A_EstABC_Qtd + &B_EstABC_Qtd + &C_EstABC_Qtd) <> 100
        msg('A soma das curvas A, B, C, devem corresponder ao Total de 100%')
	Else
		&Numeric = Random()
		&CrvCod = round(&Numeric * 10000000, 0)
		
		&ProgressId = 'RecalculaListaABC' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()
		
		btnEnter.Visible = false
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()

		RecalcularListaAbc.Submit(&ProgressId, &ProgressId,&EmpCod, &FilCod, &CrvCod,&iniPedDtaFat, &finPedDtaFat, &ProPadForCod, &GrupHie, &IncluirPedidosSemFinanceiro, &AtualizarCurvaCadastro, &IncluirProdutosInativos,&CalcularListarTipoCurva, &ImprimirProdutosSemVenda, &RecListarEstoque, &RecUfeCod)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoListarCurva'

	&PadObs = &Ordem + &TipoCurva + &QualCurva
	padraoUsuario.Call('G', 'WPCURVAABC1', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	Do case
		case &LisProSts = Status_AtivoInativo.ATIVO
			&AuxProSts = Status_Produto.ATIVO
		case &LisProSts = Status_AtivoInativo.INATIVO
			&AuxProSts = Status_Produto.INATIVO
		otherwise
			&AuxProSts = nullvalue(&AuxProSts)
	EndCase
	
	RCOOpenWindow1.LinkOpen = RELJAS024a.Link(&EmpCod, &FilCod, &Ordem, &QualCurva, &LisPesCod, &TipoCurva, &SomenteComEstoque, &AuxProSts, &ListarEstoque, &LisGrupHie)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &LisPesCod.IsValid

	&AuxPesCod = &LisPesCod
	do 'Fornecedor'
	&LisPesRaz = &AuxPesRaz

EndEvent

Event &PesCod.IsValid

	&AuxPesCod = &PesCod
	do 'Fornecedor'
	&PesRaz = &AuxPesRaz

EndEvent

Event scaProgressBar1.OnComplete

	btnEnter.Visible = true
//	UserProgress.Visible = False
	RCOOpenWindow1.LinkOpen = RELJAS025.Link(&EmpCod, &FilCod, &CrvCod,&iniPedDtaFat, &finPedDtaFat, &ProPadForCod, &GrupHie, &IncluirPedidosSemFinanceiro, &AtualizarCurvaCadastro, &IncluirProdutosInativos, &A_EstABC_Qtd, &B_EstABC_Qtd, &CalcularListarTipoCurva, &ImprimirProdutosSemVenda, &RecListarEstoque, &RecUfeCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'Fornecedor'

	&AuxPesRaz = 'TODOS OS FORNECEDORES'
	
	If &AuxPesCod <> 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &AuxPesCod
			Where PesIsFor = true
			&AuxPesRaz = PesRaz
			Exit
		When none
			&AuxPesRaz = 'FORNECEDOR NÃO ENCONTRADO'
		EndFor
	EndIF

EndSub


]]></Source>
