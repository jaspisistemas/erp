      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&ObsCarregamentoMensagem.ForeColor = RGB(0,0,255)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 600
	&NfeFilCod.Visible = False
	&NfePedCod.Visible = False
	&PedFatFilCod.Visible = False
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadNFe'

EndEvent

Event Grid.Load

	&NfeDupNro.Enabled = 1
	NfeDupVct.Enabled = 1
	&NfeDupVlr.Enabled = 1
	&NfeCbrCod.Enabled = 1
	
	&NfePedTmpSts = Status_SimNao.Nao
	if not NfeDupCreSeq.IsEmpty() and Not NfeDupCreSeq.IsNull()
		RetornaStatusDuplicata.call(EmpCod, NfeDupFiLCod, NfeDupCreSeq, &NfePedTmpSts)
	EndIF
	
	&NfeDupItmCod = NfeDupItmCod
	&NfeDupCreSeq = NfeDupCreSeq
	&NfeDupFiLCod = NfeDupFiLCod
	&NfeDupNro = NfeDupNro
	&NfeDupVlr = NfeDupVlr
	&NfeCbrCod = NfeCbrCod
	
	if &NfePedTmpSts = Status_SimNao.Sim
		&NfeDupNro.Enabled = 0
		NfeDupVct.Enabled = 0
		&NfeDupVlr.Enabled = 0
		&NfeCbrCod.Enabled = 0
	Else
		&NfeDupNro.Enabled = 1
		NfeDupVct.Enabled = 1
		&NfeDupVlr.Enabled = 1
		&NfeCbrCod.Enabled = 1
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//		Load
	//	EndFor

EndEvent

Event 'DoVoltarReturn'

	Do Case
		Case &TelaOrigem = 'WWPEDIDOBALCAO' or &TelaOrigem = 'PEDIDOBALCAO'
			wwPedidoBalcao.Link()
		Case &TelaOrigem = 'WWORDEMSERVICO' or &TelaOrigem = 'ORDEMSERVICO'
			wwOrdemServico.Link()
		Otherwise
			&link = trim(&TelaOrigem) + '.aspx'
			link(&link)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharIsso'

	&link = trim(&TelaOrigem) + '.aspx'
	link(&link)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEmitirNFe'

	&EmitirConferir = 'E' //EMITIR /CONFERIR
	do 'FinalizaTransmite'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConferirNfe'

	&EmitirConferir = 'C' //EMITIR /CONFERIR
	do 'FinalizaTransmite'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoaddParcela'

	wpAdicionarDuplicata.Popup(&EmpCod, &FilCod, &NfeCod)
	Refresh
	
	RetornaTotalDuplicatasNFe.Call(&EmpCod, &FilCod, &NfeCod, &TotMovItmVlr, &CarMovItmVlr, &TotDebVlrDup, &TotCreVlrDup, &TotalMoeda )
	&Diferenca = &NfeVlrTot - &TotalMoeda

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &NfeDupNro.IsValid

	do 'AtualizaDuplicata'

EndEvent

Event &NfeDupVlr.IsValid

	do 'AtualizaDuplicata'

EndEvent

Event &NfeCbrCod.IsValid

	do 'AtualizaDuplicata'

EndEvent

Event NfeDupVct.IsValid

	do 'AtualizaDuplicata'

EndEvent

Sub 'FinalizaTransmite'

	Do 'LoadNFe'
	
	ValidaSchemaNFe.Call(&EmpCod, &FilCod, &NfeCod, &Context.FilCod,&Mensagem)
	
	grid.Refresh()
	
	if &Mensagem.IsEmpty()		
		if &EmitirConferir = 'E' //EMITIR /CONFERIR			
			GeraXmlNFeModelo55_4.Call(&EmpCod, &FilCod, &NfeCod, 'S', &Context.PesCod, 'E', &SolCod)
	
			
			wpautorizaNotaRecepcao.Link(&TelaOrigem, &EmpCod, &FilCod, &NfeCod, &SolCod)
			
		Else
			&WizardData.Capa.FilCod = &FilCod
			&WizardData.Capa.NfeCod = &NfeCod
			&WizardData.Capa.EmpCod = &EmpCod
			//&WizardData.Capa.SolCod = 0
			&WebSession.Set('wpNota_Data', &WizardData.ToJson())
			
			wpNota.Link('', 'Capa', false)
		EndIf
	
	Else
		msg(&Mensagem)
	EndIF

EndSub

Sub 'LoadNFe'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		&FilCodNom = gxGetMLi(FilCodNom, 1, 60)
		&PedFatFilCod = FilCod
		
		&NfeCliCodRaz = gxGetMLi(NfeCliCodRaz, 1, 60)
		&NfeVlrTot = NfeVlrTot
		&NfeNum = NfeNum
		
		&NfeFilCod = NfeFilCod
		&NfePedCod = NfePedCod
		
		Exit
	EndFor
	
	RetornaTotalDuplicatasNFe.Call(&EmpCod, &FilCod, &NfeCod, &TotMovItmVlr, &CarMovItmVlr, &TotDebVlrDup, &TotCreVlrDup, &TotalMoeda )
	&Diferenca = &NfeVlrTot - &TotalMoeda

EndSub

Sub 'AtualizaDuplicata'

	NovaDuplicataNFe.Call('ALT', &EmpCod, &FilCod, &NfeCod, &NfeDupItmCod, &NfeDupNro, NfeDupVct, &NfeDupVlr, &NfeCbrCod)
