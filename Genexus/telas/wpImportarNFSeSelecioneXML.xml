        <Source><![CDATA[
Event Start

	LoadwwpContext.Call(&wwpContext)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	Do 'AttributesSecurityCode'
	&tmpNFeCod.Visible = False
	&DeOndeVem.Visible = False
	&PedFilCod.Visible = False
	&PedCliCpfCnpj.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		wpImportarNFSe(!'SelecioneXML', !'Envolvidos', false, &SessionGuid)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&tmpNFeCod = &WizardData.SelecioneXML.tmpNFeCod
	&DeOndeVem = &WizardData.SelecioneXML.DeOndeVem
	&PedCod = &WizardData.SelecioneXML.PedCod
	&PedFilCod = &WizardData.SelecioneXML.PedFilCod
	&PedCliCodRaz = &WizardData.SelecioneXML.PedCliCodRaz
	&PedCliCpfCnpj = &WizardData.SelecioneXML.PedCliCpfCnpj

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.SelecioneXML.tmpNFeCod = &tmpNFeCod
	&WizardData.SelecioneXML.DeOndeVem = &DeOndeVem
	&WizardData.SelecioneXML.PedCod = &PedCod
	&WizardData.SelecioneXML.PedFilCod = &PedFilCod
	&WizardData.SelecioneXML.PedCliCodRaz = &PedCliCodRaz
	&WizardData.SelecioneXML.PedCliCpfCnpj = &PedCliCpfCnpj
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbDadosPedido.Visible = (&PedCod > 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event FileUpload1.UploadComplete

	&NomeTemporario = 'IMPXMLNFSE' + trim(str(&wwpContext.EmpCod)) + trim(Str(&wwpContext.PesCod)) + '-'
	NotaTemporariaApaga.Call(&NomeTemporario)
		
	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&NomeArquivoXml = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			&tmpNFeCod = &NomeTemporario + '1'
			
			Do 'SaveVariablesToWizardData'
	
			GravaXmlNotaTemporariaNFSe.Call(&wwpContext.EmpCod, &tmpNFeCod, &PedCod, &NomeArquivoXml, &IsFalhaArquivo)
			
			if &IsFalhaArquivo = false
				wpImportarNFSe(!'SelecioneXML', !'Envolvidos', false, &SessionGuid)
			Else
				msg('Arquivo XML não reconhecido!')
			Endif
		
		EndiF
	EndFor

//	if &FileUploadDataColl.Count > 0
//		wpNotaImportadas.Link(&NomeTemporario)
//	Endif
	
	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent


]]></Source>
