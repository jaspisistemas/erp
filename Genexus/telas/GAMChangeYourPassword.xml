      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&UserName = GAMUser.GetName()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &UserPasswordNew = &UserPasswordNewConf 
		&ChangePwdOK = GAMUser.ChangeYourPassword(&UserPassword, &UserPasswordNew, &Errors)
		If &ChangePwdOK
			commit
			&UserPassword.Enabled 		 = False
			&UserPasswordNew.Enabled 	 = False
			&UserPasswordNewConf.Enabled = False
			BtnEnter.Visible = False
			Msg("WWP_GAM_PasswordChangedSuccesfully")
		Else
			Do 'DisplayMessages'
		Endif
	Else
		Msg("WWP_GAM_NewPasswordNotMatch")
	Endif

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		Msg(Format("Error: %1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


]]></Source>
