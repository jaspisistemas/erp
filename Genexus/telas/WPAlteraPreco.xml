      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&AumentarPrecos = 'A'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GrupHie.TooltipText = "Informe um grupo de produtos, para alterar somente o grupo informado."
	&ProPadForCod.TooltipText = "Informe o fornecedor padrão do produto, para alterar somente os valores dos produtos deste fornecedor."

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	&Mensagem = 'Tem Certeza que deseja Adicionar/Subtrair o seguinte % das colunas abaixo?'
	
	If &IsColuna1 = true and &TabPrc1 <> 0
		&mensagem += Newline() + 'COLUNA 1:  '+ trim(toformattedString(&TabPrc1)) + '%'
	EndIF
	If &IsColuna2 = true and &TabPrc2 <> 0
		&mensagem += Newline() + 'COLUNA 2:  '+ trim(toformattedString(&TabPrc2)) + '%'
	EndIF
	If &IsColuna3 = true and &TabPrc3 <> 0
		&mensagem += Newline() + 'COLUNA 3:  '+ trim(toformattedString(&TabPrc3)) + '%'
	EndIF
	If &IsColuna4 = true and &TabPrc4 <> 0
		&mensagem += Newline() + 'COLUNA 4:  '+ trim(toformattedString(&TabPrc4)) + '%'
	EndIF
	If &IsColuna5 = true and &TabPrc5 <> 0
		&mensagem += Newline() + 'COLUNA 5:  '+ trim(toformattedString(&TabPrc5)) + '%'
	EndIF

	If &IsColuna1 = false and &IsColuna2 = false and &IsColuna3 = false and &IsColuna4 = false and &IsColuna5 = false  
		msg('ATENÇÃO! Marque pelo menos 1 opção para alteração!')
	Else
		DVelop_ConfirmPanel_Confirmar.ConfirmationText = &Mensagem

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIf

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	RCOOpenWindow1.LinkOpen = RELJAS066.Link(&AumentarPrecos, &EmpCod,&TabCod,&GrupHie,&MarCod,&ProPadForCod,&IsColuna1,&IsColuna2,&IsColuna3,&IsColuna4,&IsColuna5,&TabPrc1,&TabPrc2,&TabPrc3,&TabPrc4,&TabPrc5)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
