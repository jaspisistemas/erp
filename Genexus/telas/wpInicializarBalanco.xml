      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoacaoFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do case
		case &ProSts = Status_AtivoInativo.ATIVO
			&AuxProSts = Status_Produto.ATIVO
		case &ProSts = Status_AtivoInativo.INATIVO
			&AuxProSts = Status_Produto.INATIVO
		otherwise
			&AuxProSts = nullvalue(&AuxProSts)
	EndCase

	Do 'getMarca'
	if &IserroMarca = false
		&Random = Random() * 10000000000
		&ProgressId = 'addBalanco' + trim(Str(&Random))
		
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		btnEnter.Enabled = 0
		btnacaoFechar.Enabled = 0
		
		GravaTodosProdutosBalanco.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &BalCod, &MarCod, &ProSetCod, &GrupHie, &AuxProSts, &Inicializar)
	Endif

EndEvent

Event scaProgressBar1.OnComplete

	ApagaProgress.Call(&ProgressId)
	wwpActions.WCPopup_Close('')

EndEvent

Event &MarCod.IsValid

	Do 'getMarca'

EndEvent

Sub 'getMarca'

	&IserroMarca = false
	If &MarCod = 0
		&MarNom = 'Todas as marcas'
	Else
		For each Order EmpCod,MarCod
			Where EmpCod = &EmpCod
			Where MarCod = &MarCod
			&MarNom = MarNom
			Exit
		When none
			&IserroMarca = true
			&MarNom = 'Marca não encontrada'
			&MarCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
