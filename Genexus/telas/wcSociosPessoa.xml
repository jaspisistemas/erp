        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	RetornaAutorizacao.Call('WWPESSOASOCIO', Status_SimNao.Nao, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadPessoa'

EndEvent

Event Refresh

	prcUltimaAlteracaoQuadroSocial.Call(&EmpCod, &PesCod, &PesSocDta)
	&dataLimite = serverdate()
	&dataLimite = &dataLimite.AddDays(-7)
//	tbb.Visible = 0
	txtUltimaAlteracao.Caption = 'CONFERIDO: ' + trim(&PesSocDta.ToFormattedString())
//		tbb.Visible = 1
	if &PesSocDta > &dataLimite
		btnSociosConferidos.Visible = 0
	Endif

	do 'LoadPessoa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&update.ColumnHeaderClass = !'WWIconActionColumn'
	&Deletar.ColumnHeaderClass = !'WWIconActionColumn'
	PesSocSts.ColumnHeaderClass = !'WWColumn'
	PesSocCpf.ColumnHeaderClass = !'WWColumn'
	PesSocNom.ColumnHeaderClass = !'WWColumn'
	PesSocDtaInc.ColumnHeaderClass = !'WWColumn'
	PesSocDtaFin.ColumnHeaderClass = !'WWColumn'
	PesSocDta.ColumnHeaderClass = !'WWColumn'
	&CapitalSocio.ColumnHeaderClass = !'WWColumn'
	PesSocPer.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&update = !'<i class="fa fa-pen"></i>'
	
	&Deletar = !'<i class="fa fa-times"></i>'
	If (&AutNiv >= 3)
		&Deletar.Class = !'Attribute'
	Else
		&Deletar.Class = !'Invisible'
	Endif

	&update.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWIconActionColumn WWColumnLineThrough WWColumnLineThroughFirstColumn', !'WWIconActionColumn')
	&Deletar.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWIconActionColumn WWColumnLineThrough', !'WWIconActionColumn')
	PesSocSts.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PesSocCpf.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PesSocNom.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PesSocDtaInc.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PesSocDtaFin.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PesSocDta.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&CapitalSocio.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	PesSocPer.ColumnClass = iif(PesSocSts <> Status_AtivoInativo.ATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &PesSocVlrTot > 0
		&CapitalSocio = &PesSocVlrTot * (PesSocPer / 100)
	EndIf

EndEvent

Event 'DoAddSocio'

	wpAddSocio.Popup(&EmpCod, &PesCod, 0)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSociosConferidos'

	GravaNadaAlteracao.Call(&EmpCod, &WwpContext.FilCod, &PesCod, &WwpContext.UserName)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &update.Click

	wpAddSocio.Popup(EmpCod, PesCod, PesSocCod)
	Refresh

EndEvent

Event &Deletar.Click

	wpSocioRemove.Popup(EmpCod, PesCod, PesSocCod)
	Refresh

EndEvent

Sub 'LoadPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesSocVlrTot = PesSocVlrTot
		&PesSocTotPer = PesSocTotPer
		&PesDtaFun = PesDtaFun
		Exit
	EndFor

	&PesSocTotPer.ForeColor = RGB(0,0,0)
	if &PesSocTotPer <> 100
		&PesSocTotPer.ForeColor = RGB(255,0,0)
	Endif

EndSub


]]></Source>
