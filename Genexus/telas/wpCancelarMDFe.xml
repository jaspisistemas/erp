      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&xJust = 'MANIFESTO EMITIDO COM DIVERGENCIA DE INFORMACOES, CANCELAMENTO SOLICITADO'
	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		
		&MDFeNum = MDFeNum
		&MDFeDtaEms = MDFeDtaEms
		&FilCodNom = FilCodNom
		&MDFeVlrTot = MDFeVlrTot
		&MDFeChv = MDFeChv
		&MDFeProt = MDFeProt
			
		If MDFeChv.IsEmpty()
			msg('MDFe não possui a chave da MDFe.')
		EndIF
	
		Exit
	EndFor
	
	obs.ForeColor = RGB(0,0,150)
	&hojeHora = ServerNow()

EndEvent

Event 'DoConfirmar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwMDFe.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	&xJust = &xJust.Trim()
	loadWWPContext.Call(&Context)
	Do 'Verifica_especial'
	
	Do Case
		Case &MDFeChv.IsEmpty()
			msg('MDFe não possui a chave da MDFe, só pode cancelar uma MDFe se a Mesma Estiver Autorizada!')
		Case &MDFeProt.IsEmpty()
			msg('MDFe não possui número do Protocolo, Consulte a MDFe no SEFAZ!')
		Case &erro = 0
			GravaXmlCancelamentoMDFe.Call(&EmpCod, &FilCod, &MDFeCod, &xJust, &Context.PesCod,&hojeHora, &SolCod)
			wpCancelaMDFeRecepcao.Link(&EmpCod, &FilCod, &MDFeCod, &xJust, &SolCod)
			
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Verifica_especial'

    &erro = 0 
    &Tamanho = len(&xJust)
    if &tamanho < 15 or &tamanho > 255
        msg('Tamanho da justificativa tem que ficar entre 15 e 255')
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&xJust,&Posicao,1) < ' '  or (substr(&xJust,&Posicao,1) > 'z'  ))
                msg('Caracter especial '+  substr(&xJust,&Posicao,1) + 'Não é permitido' ) 
                &erro = 1
            Endif
        EndFor
    EndIf

EndSub


]]></Source>
