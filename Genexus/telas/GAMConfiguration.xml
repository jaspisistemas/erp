      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WWPContext)
	if &WWPContext.Old_Perfil <> 3
		Dashboard.Link()
	EndIf

	For &GAMAPIVersion in GAMVersion.Elements()
		Exit
	EndFor
	&isOk = GeneXusSecurity.GAM.GetDataBaseVersion(&GAMDatabaseVersion)
	&isOk = GeneXusSecurity.GAM.GetEnableTracing(&EnableTracing)
	&isOk = GeneXusSecurity.GAM.GetDefaultRepository(&DefaultRepository)
	&isOk = GeneXusSecurity.GAM.GetRegularExpressionToValidateEmail(&EmailRegularExpression)
	
	&isAdminGAM = GAMRepository.IsGAMAdministrator(&Errors)
	
	&DefaultRepository.Clear()
	If not &DefaultRepository.IsEmpty()  OR  GeneXusSecurity.GAM.isMultitenant()
		If &isAdminGAM
			&DefaultRepository.AddItem(!"", !"(none)")
		Endif
		&LoadDefaultOK = False
		&GAMRepositoryCollection = GeneXusSecurity.GAM.GetAllRepositories(&Filter, &Errors)
		If &GAMRepositoryCollection.Count > 0
			For &GAMRepositoryItem in &GAMRepositoryCollection
				If &GAMRepositoryItem.AuthenticationMasterRepositoryId.IsEmpty()
					If &GAMRepositoryItem.GUID = &DefaultRepository
						&LoadDefaultOK = True
					Endif
					&DefaultRepository.AddItem(&GAMRepositoryItem.GUID, &GAMRepositoryItem.Name)
				Endif
			Endfor
		Endif
		If not &LoadDefaultOK  AND  not &DefaultRepository.IsEmpty()
			&DefaultRepository.Clear()
			&DefaultRepository.AddItem(&DefaultRepository, &DefaultRepository)
		Endif
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &DefaultRepository.IsEmpty()  OR  GeneXusSecurity.GAM.isMultitenant())
		&DefaultRepository.Visible = False
		DefaultRepository_Cell.Class = !'Invisible'
	Else
		&DefaultRepository.Visible = True
		DefaultRepository_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&isAdminGAM)
		&EmailRegularExpression.Visible = False
		EmailRegularExpression_Cell.Class = !'Invisible'
	Else
		&EmailRegularExpression.Visible = True
		EmailRegularExpression_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	&isOk = GeneXusSecurity.GAM.SetEnableTracing(&EnableTracing)
	If &isOK
		&GAMRepository = GAMRepository.Get()
		If GAMRepository.IsGAMAdministrator(&Errors)
			&isOk = GeneXusSecurity.GAM.SetRegularExpressionToValidateEmail(&EmailRegularExpression) 
			&isOK = GeneXusSecurity.GAM.SetDefaultRepository(&DefaultRepository)
			If &isOk
				Msg(GetMessageText("GXM_sucupdated"))
			Else
				Msg(!"Default repository could not be saved")
			Endif
		Else
			Msg(GetMessageText("GXM_sucupdated"))
		Endif
	Else
		Msg(!"Tracing status could not be saved")
	Endif

EndEvent


]]></Source>
