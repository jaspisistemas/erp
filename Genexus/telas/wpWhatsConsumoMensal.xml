      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Ano = year(&Today)
	&Mes = month(&Today)
	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Group.GridInternalName = Grid.InternalName
	tbDezembro.Width = 60
	tbNovembro.Width = 60
	tbOutubro.Width = 60
	tbSetembro.Width = 60
	tbAgosto.Width = 60
	tbJulho.Width = 60
	tbJunho.Width = 60
	tbMaio.Width = 60
	tbAbril.Width = 60
	tbMarco.Width = 60
	tbFevereiro.Width = 60
	tbJaneiro.Width = 60
	
	Grid.Rows = Page.Rows
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' Whats App'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'contabiliza'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	WaSts.ColumnHeaderClass = !'WWColumn'
	
	&Grid_GroupCaption.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Grid_GroupCaption = trim(WaDtaEms.ToFormattedString())
	&Grid_GroupCaption = format('%1: %2', "Wa Dta Ems", iif(WaDtaEms.IsEmpty(), 'WWP_FilterEmpty', &Grid_GroupCaption))
	
	Do Case
		Case WaSts.ToString().Trim() = !"P"
			WaSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case WaSts.ToString().Trim() = !"F"
			WaSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case WaSts.ToString().Trim() = !"S"
			WaSts.ColumnClass = !'WWColumn WWColumnSuccess WWColumnSuccessSingleCell'
		Otherwise
			WaSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	do 'contabiliza'
	&WaAnoMes = trim(str(&Ano)) + padL(trim(str(&Mes)), 2, '0')
	txtDetalhamento.Caption = 'DETALHAMENTO: ' + &WaAnoMes.Trim()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"WAANOMES"
				&WaAnoMes.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"OQUEFILTRAR"
				&OqueFiltrar.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"WAANOMES", "", not &WaAnoMes.IsEmpty(), 0, &WaAnoMes, '')
