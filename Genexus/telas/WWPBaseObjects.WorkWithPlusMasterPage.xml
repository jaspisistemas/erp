Event OnMessage(&NotificationInfo)

	//###################################notificações#####################################\\
	if &NotificationInfo.Id.StartsWith(!"WebNotification#")
		&WWP_WebNotification.FromJson(&NotificationInfo.Message)
		if WWP_IsReceivedWebNotification.Udp(&WWP_WebNotification.WWPWebNotificationId) = false
			WWP_SetWebNotificationReceived.Call(&WWP_WebNotification.WWPWebNotificationId)
			&WWP_UserExtended.Load(WWP_GetLoggedUserId())
			If &WWP_UserExtended.WWPUserExtendedDesktopNotif
				msg(DVMessageGetDesktopNotificationMsg(&WWP_WebNotification.WWPWebNotificationTitle, &WWP_WebNotification.WWPWebNotificationText, &WWP_WebNotification.WWPWebNotificationIcon, WWPBaseObjects.Notifications.Common.WWP_VisualizeNotification.Link(&WWP_WebNotification.WWPNotificationId)))
			EndIf
		endif
	endif
	Do 'LoadNotifications'
	//####################################################################################\\

EndEvent

Sub 'LoadBookmarks'

	&BookmarksData = new()
	
	&BookmarksDataItem = new()
	&BookmarksDataItem.EventKey = !'AddBookmark'
	&BookmarksDataItem.IsDivider = False
	&BookmarksData.Add(&BookmarksDataItem)
	
	&nomePaginaaberta = &HttpRequest.ScriptName
	&nomePaginaaberta = upper(&nomePaginaaberta)
	&nomePaginaaberta = &nomePaginaaberta.Replace('.ASPX', '')
	
	//	&CurrentURL = &HttpRequest.BaseUrl + &HttpRequest.ScriptName + iif(&HttpRequest.QueryString.Trim().IsEmpty(), '', !'?' + &HttpRequest.QueryString)
	//	&GridStateCollection.FromXml(LoadManageFiltersState(!"AppBookmarks"))
	&BookmarkFound = False
	For Each Order EmpCod, PesCod, FavOrd
		Where EmpCod = &wwpContext.EmpCod
		Where PesCod = &wwpContext.PesCod
		Where FavRotAutCod = &NomePaginaaberta
		Where FavWebSmart = 'W' or FavWebSmart.IsNull() or FavWebSmart.IsEmpty()
		&BookmarkFound = True
		Exit
	EndFor

	If &BookmarkFound
		DDo_Bookmarks.Update('', !"fas fa-star " + ThemeClass:FontColorIconBookmarkTitleAdded)
		&BookmarksDataItem.Title = "WWP_Bookmark_Edit"
		&BookmarksDataItem.FontIcon = !"fas fa-star " + ThemeClass:FontColorIconBookmarkAdded
	Else
		DDo_Bookmarks.Update('', !"far fa-star " + ThemeClass:FontColorIconBookmarkTitle)
		&BookmarksDataItem.Title = "WWP_Bookmark_Add" 
		&BookmarksDataItem.FontIcon = !"far fa-star " + ThemeClass:FontColorIconBookmark
	Endif
	
	&isprimeiro = false
	For Each Order EmpCod, PesCod, FavOrd, FavRotAutNom
		Where EmpCod = &wwpContext.EmpCod
		Where PesCod = &wwpContext.PesCod
		Where FavWebSmart = 'W' or FavWebSmart.IsNull() or FavWebSmart.IsEmpty()
		
		if &isprimeiro = false
			&BookmarksDataItem = new()
			&BookmarksDataItem.IsDivider = True
			&BookmarksData.Add(&BookmarksDataItem)
		Endif
		&isprimeiro = true
	
		&BookmarksDataItem = new()
		&BookmarksDataItem.Title = FavRotAutNom
		&BookmarksDataItem.Link = FavRotAutCod + '.aspx'
		&FontIcon = GetBookmarkFontIcon(&GridStateCollectionItem.GridStateXML.Replace(&HttpRequest.BaseUrl, ""), &DVelop_Menu)
		&BookmarksDataItem.FontIcon = iif(&FontIcon = "", !"FontColorIconBookmark fas fa-link", ThemeClass:FontColorIconBookmark + !" " + &FontIcon)
		&BookmarksDataItem.IsDivider = False
		&BookmarksData.Add(&BookmarksDataItem)
		&IndexToAddItems += 1
	EndFor
	
	if &IndexToAddItems > 0
		&BookmarksDataItem = new()
		&BookmarksDataItem.IsDivider = True
		&BookmarksData.Add(&BookmarksDataItem)
		&BookmarksDataItem = new()
		&BookmarksDataItem.Title = 'Gerenciador favoritos'
		&BookmarksDataItem.FontIcon = !"fas fa-cog " + ThemeClass:FontColorIconBookmark
		&BookmarksDataItem.EventKey = !'ManageBookmarks'
		&BookmarksDataItem.IsDivider = False
		&BookmarksData.Add(&BookmarksDataItem)
	Endif

EndSub

Sub 'LoadNotifications'

	//###################################notificações#####################################\\
	&NotificationsCount = 0
	For each WWP_Notification
		Where WWPUserExtendedId = WWP_GetLoggedUserId()
		Where Not WWPNotificationIsRead
		&NotificationsCount += 1
	EndFor
	
	ddc_NotificationsWC.Update(iif(&NotificationsCount > 0,  &NotificationsCount.ToString().Trim(), ''), ddc_NotificationsWC.Icon)
