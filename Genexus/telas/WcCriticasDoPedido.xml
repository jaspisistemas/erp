	GridPedidoPaginationBar.RowsPerPageSelectedValue = GridPedido.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	GridPedidoPaginationBar.RowsPerPageSelectedValue 	= 10
	GridHistoricoPaginationBar.RowsPerPageSelectedValue = 10
	
	GridPedido.Rows		= 10
	GridHistorico.Rows	= 10

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridHistoricoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	//The variable '&GridPedidoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridHistoricoCurrentPage	= GridHistorico.CurrentPage
	&GridHistoricoPageCount		= GridHistorico.PageCount
	
	&GridPedidoCurrentPage		= GridPedido.CurrentPage
	&GridPedidoPageCount		= GridPedido.PageCount

EndEvent

