	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridHistoricoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridHistoricoPaginationBar.SelectedPage = !'Previous'
			&GridHistoricoCurrentPage -= 1
			GridHistorico.PreviousPage()
		Case GridHistoricoPaginationBar.SelectedPage = !'Next'
			&GridHistoricoCurrentPage += 1
			GridHistorico.NextPage()
		Otherwise
			&PageToGo.FromString(GridHistoricoPaginationBar.SelectedPage)
			&GridHistoricoCurrentPage = &PageToGo
			GridHistorico.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridHistoricoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridHistorico.Rows = GridHistoricoPaginationBar.RowsPerPageSelectedValue
	&GridHistoricoCurrentPage = 1
