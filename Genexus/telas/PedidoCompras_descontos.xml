      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	ValorTotalBruto.ForeColor = RGB(0,100,255)
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedVlrBrt = PedVlrBrt
		
		
		&PedVlrDscPrm = PedVlrDscPrm
		&PedPerPrm1 = PedPerPrm1
		&PedTotVlrPrm = PedTotVlrPrm
		
		&PedVlrDscSpm = PedVlrDscSpm
		&PedPerSpm1 = PedPerSpm1
		&PedTotVlrSpm = PedTotVlrSpm
		
		&PedVlrDscSrv = PedVlrDscSrv
		&PedPerSrv1 = PedPerSrv1
		&PedTotVlrSrv = PedTotVlrSrv
		
		&PedVlrDscGlb = PedVlrDscGlb
		&PedVlrLiq = PedVlrLiq
		&PedVlrFrt = PedVlrFrt
		&PedVlrOut = PedVlrOut
		
		ValorTotalBruto.Caption = trim(toformattedString(PedVlrBrt))
		//ValorTotalLiquido.Caption = trim(toformattedString(PedVlrLiq))
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 650
	wbLiq.Width = 600
	UnnamedTable5.Width = 600
	UnnamedTable4.Width = 600
	tbservi.Width = 650
	UnnamedTable3.Width = 650
	UnnamedTable2.Width = 600
	wb1.Width = 600
	tab2.Height = 45

	Do 'AttributesSecurityCode'
	&PedVlrBrt.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbservi.Visible = (&PedTotVlrSrv > 0 or &PedPerSrv1 > 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedPerPrm1.IsValid

	&PedVlrDscPrm = 0 
    if &PedTotVlrPrm <> 0 and &PedPerPrm1 <> 0 
        &PedVlrDscPrm = round((&PedTotVlrPrm * &PedPerPrm1) / 100,2)
    endif
    Do  'Total'

EndEvent

Event &PedPerSpm1.IsValid

	&PedVlrDscSpm = 0 
    if &PedTotVlrSpm <> 0 and &PedPerSpm1 <> 0 
        &PedVlrDscSpm = round((&PedTotVlrSpm * &PedPerSpm1) / 100,2)
    endif
    Do  'Total'

EndEvent

Event &PedPerSrv1.IsValid

	&PedVlrDscSrv = 0 
    if &PedTotVlrSrv <> 0 and &PedPerSrv1 <> 0 
        &PedVlrDscSrv = round((&PedTotVlrSrv * &PedPerSrv1) / 100,2)
    endif
    Do  'Total'

EndEvent

Event &PedVlrDscGlb.IsValid

	Do  'Total'

EndEvent

Event &PedVlrOut.IsValid

	Do  'Total'

EndEvent

Event Enter

	do 'GravaDescontosPedido'

EndEvent

Event 'Voltar'

 2
	return

EndEvent

Event 'ConfirmarDescontos'

 10
	do 'GravaDescontosPedido'

EndEvent

Sub 'Total'

	&PedVlrLiq = &PedVlrBrt+&PedVlrOut - (&PedVlrDscGlb  + &PedVlrDscPrm + &PedVlrDscSpm + &PedVlrDscSrv)
	//ValorTotalLiquido.Caption = trim(toformattedString(&PedVlrLiq))

EndSub

Sub 'GravaDescontosPedido'

	GravaDescontosVenda.Call(&EmpCod, &FilCod, &PedCod, &PedVlrDscGlb, &PedPerSpm1, &PedPerPrm1, &PedPerSrv1, &PedVlrOut, &PedVlrFrt, &Context.UserName)
	//GravaDescontos
	
	return

EndSub


]]></Source>
