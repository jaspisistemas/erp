      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	MsgTabela.Visible = false
	&oquefazer = 1
	&Error = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&oquefazer.TooltipText = "1 - CRIAR NOVA TABELA, o ERP irá criar uma nova tabela, com status em contrução, baseando-se na tabela de origem selecionada. 2- USAR TABELA EXISTENTE, o ERP irá pedir o nro da tabela existente e vai mostrar as opções possíveis á realizar."

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&parTabDtaIni.Visible = False
	&parmTabSts.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&oquefazer = 1)
		&NewTabCod.Visible = False
		NewTabCod_Cell.Class = !'Invisible'
	Else
		&NewTabCod.Visible = True
		NewTabCod_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&oquefazer = 2)
		&DstTabCod.Visible = False
		DstTabCod_Cell.Class = !'Invisible'
	Else
		&DstTabCod.Visible = True
		DstTabCod_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&oquefazer = 2)
		&DstFazer.Visible = False
		DstFazer_Cell.Class = !'Invisible'
	Else
		&DstFazer.Visible = True
		DstFazer_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &oquefazer.IsValid

	Do 'AttributesSecurityCode'
	&DstTabCod = ''

EndEvent

Event &DstTabCod.IsValid

	Do 'GetTabela'

EndEvent

Event Enter

&Error = 0
	Do Case
		Case &oquefazer = 1 //Criar nova Tabela
			If &NewTabCod.Trim().IsEmpty()
				msg('ATENÇÃO! Para criar uma nova tabela informe o número da nova tabela.')
				&NewTabCod.SetFocus()
				&Error = 1
			Else
				Do 'ValidaTabela'
				msg('ATENÇÃO! A nova tabela já existe informe outro número para nova tabela.')
				&NewTabCod.SetFocus()
			EndIf
		Case &oquefazer = 2 //Usar Tabela existente
			If &dstTabCod.Trim().IsEmpty()
				msg('ATENÇÃO! Para usar uma tabela existente informe o número da tabela.')
				&dstTabCod.SetFocus()
				&Error = 1
			EndIf
	EndCase
	If &Error = 0
		ClonaTabela.Call(&EmpCod,&TabCod,&DstTabCod,&NewTabCod,&oquefazer,&DstFazer)
		If &oquefazer = 1
			TabelaPreco.Call(TrnMode.Update,&EmpCod,&NewTabCod)
		EndIf
	EndIf

EndEvent

Sub 'GetTabela'

	If &DstTabCod.Trim().isEmpty()
		msg('ATENÇÃO! Nro da Tabela destino vazio, favor informar!')
	Else
		For each Order EmpCod TabCod
			Where EmpCod = &EmpCod
			Where TabCod = &DstTabCod
			Where TabSts <> StatusTabela.Inativa
			MsgTabela.Visible = true
			MsgTabela.Caption = 'Tabela '+TabCod.Trim()+' está '+StatusTabela.EnumerationDescription(TabSts)
		When none
			msg('ATENÇÃO! Tabela não esta ativa!')
		EndFor
	EndIf

EndSub

Sub 'ValidaTabela'

	For each Order EmpCod TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &NewTabCod
		&Error = 1
		Exit
	EndFor

EndSub


]]></Source>
