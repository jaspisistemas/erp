      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Status.Caption = ''
	&PesCep = &inPesCEP

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSelecionarDados'

	If not &PesLog.IsEmpty()
		&inPesLog = &PesLog
	EndIf
	
	If not &PesBai.IsEmpty()
		&inPesBai = &PesBai
	EndIF

	If (not &PesBai.IsEmpty()) and (not &PesLog.IsEmpty())
		Return
	Else
		msg('Não Localizado Valores do Logradouro e do Bairro')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PesLog.SetEmpty()
	&PesBai.SetEmpty()
	Do 'AttributesSecurityCode'
	
	Status.Caption = 'Aguarde ... localizando Logradouro ...'

	&SoNumero = RetornaSoNumeros.Udp(&PesCep)
	
	&urlString = "web_cep.php?cep="  + &SoNumero.Trim() + "&formato=xml"
	&httpClient.Host = 'cep.republicavirtual.com.br'
	&httpClient.Port = 80
	&httpClient.Secure = false
	&httpClient.Timeout = 10
	&httpClient.Execute("POST", &urlString)
 	
	If &httpClient.ErrCode = 0
		&Varchar = &httpClient.ToString()
		
		FormataRetornoCEP.Call(&Varchar, &Varchar, &PesLog, &PesBai)
		msg(&Varchar)
		Do 'AttributesSecurityCode'
		Status.Caption = ''
	Else 
		msg(&httpClient.ErrDescription)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


Sub 'AttributesSecurityCode'

EndSub

]]></Source>
