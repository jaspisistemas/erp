      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&FilCod = &wwpContext.FilCod
	do 'loadProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'loadProdutoEntrada'
	Do CAse
		Case &TrsEntPedQtd > &EstQtd
			msg('Estoque so possui: ' + trim(&EstQtd) + ' ' + &ProEmbUnd.Trim())
		Case &IsErroEntrada = false
			prcGravaTransfencia.Call(&EmpCod, &FilCod, &DestinoProCod, &DestinoProGraCod, &FilCod, &Procod, &ProGraCod, &TrsEntPedQtd)
			Return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &TrsEntProRef.IsValid

	do 'loadProdutoEntrada'

EndEvent

Sub 'loadProdutoEntrada'

	&DestinoProGraCod = 0
	&DestinoProCod = 0
	&IsErroEntrada = true
	&TrsEntProNom = 'INFORME PRODUTO DESTINO'
	
	RetornaprodutoReferencia_basico.Call(&EmpCod, &TrsEntProRef, &DestinoProCod, &DestinoProGraCod, &TrsEntProNom, &IsAchouProduto, &erroMensagem)
	
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &DestinoProCod
		Where ProGraCod = &DestinoProGraCod
		
		&TrsEntProNom = ProNomGra
		&IsErroEntrada = false
		&DestinoProCod = ProCod
		&DestinoProGraCod = ProGraCod
		Exit
	when none
		if not &TrsEntProRef.IsEmpty()
			&TrsEntProNom = UPPER('Produto Destino não Localizado')
			msg('Produto Destino não Localizado!')
			//Msg.ForeColor = RGB(180,40,0)
		EndiF
	EndFor

EndSub

Sub 'loadProduto'

	For Each ORder EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &PRoGraCod
		
		&ProEmbUnd = ProEmbUnd
		&ProNom = ProNomGra
		&MarNom = MarNom
		
		Exit
	EndFor

	For Each order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&Estqtd 	= EstQtd
		&NovEstQtd  = EstQtd
		Exit
	EndFor

EndSub


]]></Source>
