      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&TipoPlanoVarchar		= 'D'
	TbAviso.Backcolor 	= RGB(254,221,88)
	&Aviso.ForeColor	= RGB(9,13,17)
	&Aviso 				= 'ATENÇÃO! Será gerado uma duplicata para os seguintes lançamentos, da viagem: ' + Trim(Str(&parmViaCod)) + '. Por favor, selecione uma data de vencimento para as demais.'
	
	&sdtLancamentoDasViagens.FromXml(&WebSession.Get("!ItensLancamento"))
	
	&CreDtaVct = &Today.AddDays(1)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount		= Grid.PageCount
	&GridCurrentPage	= Grid.CurrentPage
	&LinhaPorPag  		= Grid.Rows

EndEvent

Event Grid.Load

	&GridPageCount 	= 1
	&GridPag 		= 0
	&LinhaPorPag  	= Grid.Rows
	
	For &sdtLancamentoDasViagensItem In &sdtLancamentoDasViagens

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&gridViaLanCod		= &sdtLancamentoDasViagensItem.ViaLanCod
		&gridViaLanDta		= &sdtLancamentoDasViagensItem.ViaLanDta
		&gridViaLanObs		= &sdtLancamentoDasViagensItem.ViaLanObs
		&gridViaLanPlanCod	= &sdtLancamentoDasViagensItem.ViaLanPlanCod
		&gridViaLanVlr		= &sdtLancamentoDasViagensItem.ViaLanVlr
		&gridViaLanFor		= &sdtLancamentoDasViagensItem.ViaLanFor
		Do 'BuscaPessoa'

		&GridPag += 1
		If &GridPag = &LinhaPorPag  
			&GridPageCount 	+= 1
			&GridPag 		= 0
		EndIf
		
		Load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult = TRUE
		prcAdicionaGravaDuplicataViagem.Call('INS', &parmEmpCod, &parmFilCod, &parmViaCod, &CreDtaVct, 0)
		Return
	EndIf

EndEvent

Sub 'CheckRequiredFields'

	//Verifica se todos os campos obrigatórios foram preenchidos
	&CheckRequiredFieldsResult = True
	If &CreDtaVct.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Data de Vencimento'), DVMessageType.error, &CreDtaVct.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

EndSub

Sub 'BuscaPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &parmEmpCod
		Where PesCod = &gridViaLanFor
		
		&gridPesCodRaz = PesCodRaz
		
		Exit
	When None
		&gridPesCodRaz = 'NÃO INFORMADO'
	EndFor

EndSub


]]></Source>
