      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&MDFeDtaEnc = serverdate()
	&MDFeHorEnc = serverTime()
	do 'SetUfCidade'
	txtObs.ForeColor = RGB(210,130,0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	FormataHora.Call(&MDFeHorEnc, &MDFeHorEnc)
	
	&IsErroCidade = false
	For Each Order EmpCod, CidCod
		Where EmpCod = &EmpCod
		Where CidCod = &CidCod
		If CidIBGE.IsEmpty() or CidIBGE.IsNull()
			msg('Cidade informada não possui codigo de IBGE cadastrado!')
			&IsErroCidade = true
		EndIF
		Exit
	When none
		&IsErroCidade = true
		msg('Cidade não Localizada')
	EndFor
	
	If &IsErroCidade = false
		GeraEncerramentoMDFe.Call(&EmpCod, &FilCod, &MDfeCod, &MDFeDtaEnc,&MDFeHorEnc ,&CidCod, &Context.PesCod, &SolCod)
		wpencerraMDfe.Link(&EmpCod, &FilCod, &MDfeCod, &SolCod)
	EndIF

EndEvent

Event &MDFeHorEnc.IsValid

	FormataHora.Call(&MDFeHorEnc, &MDFeHorEnc)

EndEvent

Sub 'SetUfCidade'

	For Each Order EmpCod, FilCod,MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDfeCod
		&UfeCod = MDFeDstUfeCod
		&CidCod = MDFeDesCidCod
		exit
	EndFor

EndSub


]]></Source>
