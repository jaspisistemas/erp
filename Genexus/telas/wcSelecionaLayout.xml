        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid_DWC.Class = !'Invisible WCD_' + upper(Grid.InternalName)
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadGridSDT'
	&LayNom.Enabled = true

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&btnSelect = !'<i class="fas fa-check"></i>'
	
	&btnEdita = !'<i class="fas fa-pen"></i>'
	
	&btnDeleta = !'<i class="fas fa-times"></i>'
	
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&PageToGo = Grid.CurrentPage
			&PageToGo += 1
			Grid.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnNovo'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	btnNovo_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event btnNovo_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcGravaLayoutConciliacao.Create(TrnMode.Insert)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event btnNovo_Modal.Close

	do 'LoadGridSDT'
	
	if 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	endif

EndEvent

Event &btnEdita.Click

	&WebSession.Set('#CONMAQ_LAYOUTCSV', &sdtLayoutConciliaCartaos.CurrentItem.ToJson())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	btnEdita_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event btnEdita_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcGravaLayoutConciliacao.Create(TrnMode.Update)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event btnEdita_Modal.Close

	do 'LoadGridSDT'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DetailWebComponent.Click

	&WebSession.Set('#CONMAQ_LAYOUTCSV', &sdtLayoutConciliaCartaos.CurrentItem.ToJson())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_DWC.Object = wcGravaLayoutConciliacao.Create(TrnMode.Display)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &LayNom.ControlValueChanged

	&sdtLayoutConciliaCartaos = RetornaLayoutPorNome(&EmpCod,&LayNom)

EndEvent

Event &btnDeleta.Click

	CrudLayout(TrnMode.Delete, &Context.EmpCod, &sdtLayoutConciliaCartaos.CurrentItem)
	do 'LoadGridSDT'

EndEvent

Event &btnSelect.Click

	&LayCod = &sdtLayoutConciliaCartaos.CurrentItem.sdtLayCod
	&LayNom = &sdtLayoutConciliaCartaos.CurrentItem.sdtLayNom
	
	return

EndEvent

Sub 'LoadGridSDT'

	&sdtLayoutConciliaCartaos = CarregaLayoutConciliacaoMaq(&Context.EmpCod)

EndSub


