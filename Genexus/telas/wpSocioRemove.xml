        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)
	RetornaAutorizacao.Call('WWPESSOASOCIO', Status_SimNao.Sim, 3, &AutNiv)
	do 'loadSocio'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	GravaSocio.Call('DEL', &EmpCod, &WwpContext.FilCod,  &PesCod, &PesSocCod, &PesSocNom, &PesSocCpf, &PesSocPer, &PesSocDtaInc, &PesSocDtaFin, &PesSocSts,&PesSocDtaNas,&PesSocAdm, &WwpContext.UserName)
	Return

EndEvent

Sub 'loadSocio'

	For each Order EmpCod, PesCod, PesSocCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod 
		Where PesSocCod = &PesSocCod
		&PesSocDtaNas = PesSocDtaNas
		&PesSocNom = PesSocNom
		&PesSocCpf = PesSocCpf
		&PesSocSts = PesSocSts
		&PesSocPer = PesSocPer
		&PesSocDtaInc = PesSocDtaInc
		&oldPesSocCpf = PesSocCpf
		
		Exit
	EndFor

EndSub


]]></Source>
