      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&FolAno = Year(&Today)
	&FolMes = Month(&Today)
	retornaAutorizacao.Call('WPSALARIOFUNCIONARIO', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAniversariantes'

	WpAniversarios.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FilCod.IsValid

	&SepararFuncionariosPorFilial.Enabled = (&FilCod = 0)

EndEvent

Event &FunCod.IsValid

	Do 'Funcionario'

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS089.Link(&EmpCod,&FilCod,&FunCod,&FucCod,&SetCod,&PesSts,&MovCtaBanCod,&TipoFolha, &Demitidos, &Ordenar, &PesSalTip, &FolAno, &FolMes, &SepararFuncionariosPorFilial, &NaoDestacarFuncoes)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

EndEvent

Sub 'funcionario'

	If &FunCod = 0
		&FunNom = 'Todos os funcionários'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &FunCod
			Where PesIsFun = True
			
			&FunNom = PesRaz
			Exit
		When none
			msg('Pessoa não encontada por não ser um funcionário ou estar inativo. Verifique!')
			&FunNom = 'Pessoa não encontada Verifique!'
			&FunCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
