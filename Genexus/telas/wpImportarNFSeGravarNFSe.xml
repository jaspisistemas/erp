      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProcessando.Visible = 0
	
	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	RetornaAutorizacao.Call('WWPEDIDOCOMPRA', Status_SimNao.Nao, 2, &WWPEDIDOCOMPRA_AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&tmpEmixCod.Visible = False
	&tmpNfeChvRef.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SalvarNotaCompra = true
	&FecharPedidoSelecionado.Enabled = 0
	&PedCod = &WizardData.SelecioneXML.PedCod
	if &WizardData.SelecioneXML.PedCod.IsEmpty()
		&SubstituirItensPedido = false
		&SubstituirItensPedido.Visible = false
		
		if &WWPEDIDOCOMPRA_AutNiv > 0
			&SalvarPedidoCompra = true
		Else
			&SalvarPedidoCompra = false
			&SalvarPedidoCompra.Enabled = 0
			
		EndiF
		
		&FecharPedidoSelecionado.Visible = 0
		&PedDtaFat.Visible = 0
		&FecharFinanceiroSelecionado.Visible = 0
	Else
		obsPedido.Caption = 'PEDIDO: ' + trim(str(&WizardData.SelecioneXML.PedCod))
		&SalvarPedidoCompra = false
		&SalvarPedidoCompra.Enabled = 0
		
		if &WWPEDIDOCOMPRA_AutNiv > 0
			&SubstituirItensPedido = false
			&SubstituirItensPedido.Visible = true
		Endif
	EndIF	
	
	&LctCod = &WizardData.Envolvidos.LctCod
	
	&DeOndeVem = &WizardData.SelecioneXML.DeOndeVem
	If &DeOndeVem.IsEmpty()
		Dashboard.Link()
	EndIF
	
//	&NomeTemporario = &DeOndeVem.Trim() + 'IMPXMLCOMPRA' + trim(str(&EmpCod)) + trim(Str(&wwpContext.PesCod)) + '-'

	&tmpNFeCod = &WizardData.SelecioneXML.tmpNFeCod
	
	do 'LoadTemporaria'

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	wpImportarNFSe(!'GravarNFSe', !'Servicos', true, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&PedDtaFat = &WizardData.GravarNFSe.PedDtaFat
	&SalvarPedidoCompra = &WizardData.GravarNFSe.SalvarPedidoCompra
	&FecharPedidoSelecionado = &WizardData.GravarNFSe.FecharPedidoSelecionado
	&FecharFinanceiroSelecionado = &WizardData.GravarNFSe.FecharFinanceiroSelecionado
	&SubstituirItensPedido = &WizardData.GravarNFSe.SubstituirItensPedido
	&SalvarNotaCompra = &WizardData.GravarNFSe.SalvarNotaCompra
	&tmpEmixCod = &WizardData.GravarNFSe.tmpEmixCod
	&tmpNfeChvRef = &WizardData.GravarNFSe.tmpNfeChvRef
	&NfeChv = &WizardData.GravarNFSe.NfeChv
	&tmpEmixNom = &WizardData.GravarNFSe.tmpEmixNom

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.GravarNFSe.PedDtaFat = &PedDtaFat
	&WizardData.GravarNFSe.SalvarPedidoCompra = &SalvarPedidoCompra
	&WizardData.GravarNFSe.FecharPedidoSelecionado = &FecharPedidoSelecionado
	&WizardData.GravarNFSe.FecharFinanceiroSelecionado = &FecharFinanceiroSelecionado
	&WizardData.GravarNFSe.SubstituirItensPedido = &SubstituirItensPedido
	&WizardData.GravarNFSe.SalvarNotaCompra = &SalvarNotaCompra
	&WizardData.GravarNFSe.tmpEmixCod = &tmpEmixCod
	&WizardData.GravarNFSe.tmpNfeChvRef = &tmpNfeChvRef
	&WizardData.GravarNFSe.NfeChv = &NfeChv
	&WizardData.GravarNFSe.tmpEmixNom = &tmpEmixNom
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'FinishWizard'

	if &FecharPedidoSelecionado = true and &PedCod > 0 and &PedDtaFat.IsEmpty()
		msg('Favor informar a data de Faturamento do Pedido!')
	Else
		
		&AuxFecharFinanceiroSelecionado = &FecharFinanceiroSelecionado
		tbConfirmar.Visible = 0
		tbProcessando.Visible = 1
		
		&ProgressId = trim(&tmpNFeCod) + 'IMPORTANOTA'
		apagaProgress.Call(&ProgressId)
		scaProgressBar.ProcessId = &ProgressId
		scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar.Start()
		
		if &SalvarPedidoCompra = true 
			if (&PedVenCod = 0 or &PedVenCod.IsEmpty()) // se não informou o vendedor na tela, ou não é uma devolução de venda 
				&PedVenCod = &wwpContext.PesCod //pega o logado
			Endif
			
			&PedCod = UltimoCodigoEmpresa.Udp(domParCod.PEDIDO, &EmpCod, &FilCod)
		Endif	
		
		if &FecharFinanceiroSelecionado = true		
			padraoUsuario.Call('G', 'HAVERSERLECIONADO_FCHDV', &wwpContext.PesCod, &wwpContext.EmpCod, '', &PadDtaMod)
		Endif	
		
		prcProcessoImportacaoNFSe.Submit(&ProgressId, &ProgressId, &tmpNFeCod, &EmpCod, &FiLCod, &PedVenCod, &LctCod, &tmpNfeFatFilCod, &DevPedCodOciRef, &PedCod, &PedDtaFat, &SalvarPedidoCompra, &FecharPedidoSelecionado, &SalvarNotaCompra, &SalvarOrdemCostura, &SubstituirItensPedido, &wwpContext.PesCod, &wwpContext.UserName)
		
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar.OnComplete

	if &AuxFecharFinanceiroSelecionado = true		
		wpFechaFinanceiroCompras.Call(&WizardData.SelecioneXML.DeOndeVem, &EmpCod, &FilCod, &PedCod)
	Else
		do 'Sair'
	Endif

EndEvent

Sub 'Sair'

	do case
		case &WizardData.SelecioneXML.DeOndeVem = 'WWPEDIDOCOMPRA'
			wwPedidoCompra.Link()
		Case &WizardData.SelecioneXML.DeOndeVem = 'WWNOTAS'
			wwNotas.Link()
		Case &WizardData.SelecioneXML.DeOndeVem = 'WWNOTASSERVICO'
			wwNotasServico.Link()
		Case &WizardData.SelecioneXML.DeOndeVem = 'WWORDEMCOSTURA'
			WWORDEMCOSTURA.Link()
		Case &WizardData.SelecioneXML.DeOndeVem = 'WWDEVOLUCAOVENDA' 
			wwdevolucaoVenda.Link()
		Case &WizardData.SelecioneXML.DeOndeVem = 'WWDEVOLUCAOCOMPRA' 
			wwdevolucaoCompra.Link()
		Case &WizardData.SelecioneXML.DeOndeVem = 'WWPEDIDOVENDA'
			wwPedidoVenda.Link()
		otherwise
			wwPedidoCompra.Link()
	EndCase

EndSub

Sub 'LoadTemporaria'

	For Each Order tmpNFeCod
		WHere tmpNFeCod = &tmpNFeCod
		&FilCod = tmpFilCod
		&tmpNfeFatFilCod = tmpNfeFatFilCod
		&NfeChv = tmpNfeChv
		&tmpEmixCod = tmpEmixCod
		&tmpNfeChvRef= tmpNfeChvRef
		&tmpEmixNom = trim(str(tmpEmixCod))+' - '+trim(tmpEmixNom)
		

		VerificaNotaJahLancadaNFSe.Call(&EmpCod, tmpNfeFatFilCod, tmpNfeProTer, tmpEmixCod, tmpNfeNum, &auxNfeCod)
		
		Exit
	When None
		wwNotasServico.Link()
	EndFor

EndSub


]]></Source>
