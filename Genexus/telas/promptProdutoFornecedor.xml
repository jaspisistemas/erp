      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&ProForCod = &PesCod
	RetornaAutorizacao.Call('WPFORNECEDORPRODUTO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	&ProSts = nullvalue(&ProSts)
	DDO_Grid.GridInternalName = Grid.InternalName

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	ProRef.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

//	&GridCurrentPage = Grid.CurrentPage
//	&GridRecordCount = Grid.RecordCount
//	&GridPageCount = grid.PageCount
	
	do 'LoadNomes'

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&selecionar = !'<i class="fas fa-check"></i>'
	
	ProRef.ColumnClass = iif(ProSts <> Status_AtivoInativo.Ativo, !'WWColumn WWColumnDanger WWColumnDangerSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	do 'voltar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"PROFORCOD"
				&ProForCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PRONOM"
				&ProNom.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PROSTS"
				&ProSts.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PROFORPROCOD"
				&ProForProCod.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndSub

Sub 'SaveGridState'

	If 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"PROFORCOD", "", not &ProForCod.IsEmpty(), 0, &ProForCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"PRONOM", "", not &ProNom.IsEmpty(), 0, &ProNom, '')
	WWP_GridStateAddFilterValue(&GridState, !"PROSTS", "", not &ProSts.IsEmpty(), 0, &ProSts, '')
	WWP_GridStateAddFilterValue(&GridState, !"PROFORPROCOD", "", not &ProForProCod.IsEmpty(), 0, &ProForProCod, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endif

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"ProdutoFornecedor"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &selecionar.Click

	&WebSession.set('wpeditacodigoprocod', trim(str(ProCod)))
	&WebSession.set('wpeditacodigoproref', ProRef.Trim())
	&WebSession.set('wpeditacodigopronom', ProNom.Trim())
	&WebSession.set('wpeditacodigoprojalancado', ProForProCod.Trim())
	do 'voltar'

EndEvent

Sub 'voltar'

	wwpActions.WCPopup_Close('')

EndSub

Sub 'LoadNomes'

	If &PesCod <> 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &Context.EmpCod
			Where PesCod = &PesCod
			&PesRaz = PesCodRaz
			Exit
		EndFor
	EndIF

EndSub


]]></Source>
