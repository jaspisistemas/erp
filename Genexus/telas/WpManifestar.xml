Event Start

	RetornaExisteSolicitacaoPendente.call(&EmpCod, &FilCod, &ManCod, 0, TipoSolicitacao.Manifestar_DFe, &IsPendente, &AuxSoLCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&ManNsu.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Sucesso.Visible = False
	pro.Visible = False
	TableMsg.Visible = False
	
	if &IsPendente = true
		Falha.Visible = 0
		TableMsg.Visible = 1
		txtMsg.Caption = 'JÁ EXISTE EM STATUS PENDENTE UMA SOLICITAÇÃO DE MANIFESTAÇÃO DA NFE'
	Endif

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&Evento = 210240)
		&xJust.Visible = False
		xJust_Cell.Class = !'Invisible'
	Else
		&xJust.Visible = True
		xJust_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	GeraXmlSincroManifestIndividual.Call(&EmpCod,&FilCod,'S',&ManCod,&ManCha,&SolCod)

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		txtMsg.ForeColor = RGB(210,130,0)
		txtMsg.Caption = ProgressLogXml.Trim()
		Exit
	EndFor

	Falha.Visible = True
	TableMsg.Visible = true

EndEvent

Event Enter

	pro.Visible = True
	Falha.Visible = False
	Do 'Grava'
	
	
//	&Random = random()* 10
//	&ProgressId = 'EventDFe' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
//	&ProgressId = &ProgressId.trim()
//	scaProgressBar1.ProcessId = &ProgressId
//	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
//	scaProgressBar1.Start()
	
//	EventoDFe.Submit('EventoDFe', &ProgressId, &EmpCod, &FilCod, &FilCod, &SolCod)
//	txtMsg.Caption = ''
	return

EndEvent

Event &Evento.Click

	Do 'AttributesSecurityCode'

EndEvent

Event &Evento.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Sub 'Grava'

	For Each Order EmpCod, ManCod
		Where EmpCod = &EmpCod
		Where ManCod = &ManCod
		Where ManSts <> Status_DFe.Excluido
		
		if ManEveSol <> &Evento or (ManSts <> Status_DFe.Ciencia  and ManEveSol = 210210)
			GeraXmlManifestacao.Call(&EmpCod,&FilCod,'S',&ManCha,&ManNsu,&Evento,&xJust,&ManCod,&SolCod)
		EndIf
	
	EndFor

EndSub


