      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPMETAVENDEDOR', Status_SimNao.Sim, 1, &AutNiv)
	
	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	if not &ParPesCod.IsEmpty()
		&PesCod = &ParPesCod
		&PesMetAno = &ParPesMetAno
		do 'LoadVEndedorMeta'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PesCod.IsValid

	do 'LoadVEndedorMeta'

EndEvent

Event Enter

	do case
		Case &PesMetAno.IsEmpty()
			msg('Informe Ano Base para a Meta!')
			&PesMetAno.SetFocus()
		Case &PesCod.IsEmpty() or &PesIsVen = false
			msg('Informe Vendedor Válido!')
			&PesCod.SetFocus()
		Otherwise
			&PesMetVlrDemais = 0
			&JanPesMetVlr = 0
			if &PesMetVlr > 0
				&PesMetVlrDemais = round((&PesMetVlr / 12),0)
				&JanPesMetVlr = &PesMetVlr - (&PesMetVlrDemais * 11)
			Endif			
			GravaMEtaVendedor.Call(&EmpCod, &PesCod, &PesMetAno, &JanPesMetVlr,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais,&PesMetVlrDemais)
			msg('Metas Atualizadas!')
			&PesMetVlr = 0
			&PesCod.SetFocus()
			
	EndCase

EndEvent

Sub 'LoadVendedorMeta'

	&PesIsVen = false
	&PesMetVlr = 0
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesIsVen = PesIsVen	
		&PesRaz = PesRaz
		
		For Each Order EmpCod, PesCod, PesMetAno
			Where PesMetAno = &PesMetAno
			&PesMetVlr += PesMetVlr
		EndFor
		Exit
	EndFor

EndSub


]]></Source>
