      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&CodigoUsuario = trim(str(&Context.EmpCod)) + trim(str(&Context.FilCod)) + trim(Str(&Context.PesCod))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtEtiquetaLotes.Rows = Page.Rows
	GridsdtEtiquetaLotesPaginationBar.RowsPerPageSelectedValue = GridsdtEtiquetaLotes.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &IsClear = true
		padraoUsuario.Call('G', &CodigoUsuario, &Context.PesCod, &Context.EmpCod, '', &PadDtaMod)
	EndIf

	if 1=2
		abreEtiquetaLote.Link()
	Endif

EndEvent

Event Refresh

	padraoUsuario.Call('L', &CodigoUsuario, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&sdtEtiquetaLote.FromJson(&PadObs)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtEtiquetaLotesCurrentPage = GridsdtEtiquetaLotes.CurrentPage
	&GridsdtEtiquetaLotesPageCount = GridsdtEtiquetaLotes.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtEtiquetaLotes.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Remove.FromImage(ActionDelete)
	&Remove.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtEtiquetaLotesPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtEtiquetaLotesPaginationBar.SelectedPage = !'Previous'
			GridsdtEtiquetaLotes.PreviousPage()
		Case GridsdtEtiquetaLotesPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtEtiquetaLotes.CurrentPage
			&PageToGo += 1
			GridsdtEtiquetaLotes.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtEtiquetaLotesPaginationBar.SelectedPage)
			GridsdtEtiquetaLotes.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtEtiquetaLotesPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtEtiquetaLotes.Rows = GridsdtEtiquetaLotesPaginationBar.RowsPerPageSelectedValue
	GridsdtEtiquetaLotes.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	if &sdtEtiquetaLote.Count > 0
		//		&Random = (Random() * 10000000)
		//		&ArquivoFisico  =  'EtiqPro' + trim(&EtqCod) + trim(str(&Random)) + '.pdf'
		
		&PadObs = &sdtEtiquetaLote.ToJson()
		padraoUsuario.Call('G', &CodigoUsuario, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		
		Do Case
			Case &TipoEtiqueta = 'P' //PICOLES
				EmbPage1.Source = Reljas047a.Link(&Context.EmpCod, &Context.FilCod, &Context.PesCod, &CodigoUsuario)
			Case &TipoEtiqueta = 'S' //SORVETES
				EmbPage1.Source = Reljas047b.Link(&Context.EmpCod, &Context.FilCod, &Context.PesCod, &CodigoUsuario)
		EndCAse
	
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLimpar'

	padraoUsuario.Call('G', &CodigoUsuario, &Context.PesCod, &Context.EmpCod, '', &PadDtaMod)
	&sdtEtiquetaLote.Clear()
	&ProRef.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	do 'validaProduto'

EndEvent

Event 'f4'

 4
	PromptProdutoGradeRef.Popup(&EmpCod, &ProCod, &ProGraCod, &ProRef)
	&ProRef.SetFocus()

EndEvent

Event Enter

	do 'validaProduto'
	if &IsExiste = true
		
		&sdtEtiquetaLoteItem = new()
		&sdtEtiquetaLoteItem.ProRef = &ProRef
		&sdtEtiquetaLoteItem.ProNom = &ProNom
		&sdtEtiquetaLoteItem.PedDtaFat = &PedDtaFat
		&sdtEtiquetaLoteItem.Lote = &Lote
		&sdtEtiquetaLoteItem.Quantidade = &QuantidadeRedonda
		
		&sdtEtiquetaLote.Add(&sdtEtiquetaLoteItem)
		
		&PadObs = &sdtEtiquetaLote.ToJson()
		padraoUsuario.Call('G', &CodigoUsuario, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		
		&ProRef.SetFocus()
	EndiF

EndEvent

Event &Remove.Click

	For &sdtEtiquetaLoteItem in &sdtEtiquetaLote
		if &sdtEtiquetaLoteItem.ProRef = &sdtEtiquetaLote.CurrentItem.ProRef and &sdtEtiquetaLoteItem.Quantidade = &sdtEtiquetaLote.CurrentItem.Quantidade
			&Index = &sdtEtiquetaLote.IndexOf(&sdtEtiquetaLoteItem)
			&sdtEtiquetaLote.Remove(&index)
		EndIF
	EndFor
	
	&PadObs = &sdtEtiquetaLote.ToJson()
	padraoUsuario.Call('G', &CodigoUsuario, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	&ProRef.SetFocus()

EndEvent

Sub 'validaProduto'

//	&ProBar = ''
	&IsExiste = false
//	&ProQtdEmb.SetEmpty()
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
//		&ProNom = ProNom
//		&ProBar = ProBar
		&IsExiste = true	
//		&NovoProCod = trim(&ProRef)
//		&NovoProNom = trim(&ProNom)
//		&ProQtdEmb = ProQtdEmb
		Exit
	When None
		If &ProCod <> 0
			&ProNom = 'PRODUTO NÃO LOCALIZADO!'
			msg(&ProNom)
		Else
			&ProNom = '<-- INFORME O PRODUTO'
		EndIF
	EndFor

EndSub


