      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProCodNom = ProRef.Trim() + ProNom.Trim()
		&ProIMC = ProIMC
		Exit
	EndFor
	&ProVlrVda = round((&ProVlrCus * ( 1 + (&ProIMC/100))), 2)

EndEvent

Event &ProIMC.IsValid

	&ProVlrVda = round((&ProVlrCus * ( 1 + (&ProIMC/100))), 2)

EndEvent

Event Enter

	GravaAcrescimoVenda.call(&EmpCod, &ProCod, &ProIMC)
	Return

EndEvent


]]></Source>
