        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 100
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount
	&GridCurrentPage = grid.CurrentPage

EndEvent

Event Grid.Load

	&ProGraNom.ForeColor  = RGB(0,0,0)
	&EstLoc.ForeColor 	  = RGB(0,0,0)
	&VarCharIMC.ForeColor = RGB(0,0,0)
	EstUltEnt.ForeColor   = RGB(0,0,0)
	EstUltSai.ForeColor   = RGB(0,0,0)
	EstUltFab.ForeColor   = RGB(0,0,0)
	EstMin_Formatado.ForeColor   = RGB(0,0,0)
	EstABC_Qtd.ForeColor   = RGB(0,0,0)
	EstABC_Ren.ForeColor   = RGB(0,0,0)
	EstPrd_Formatado.ForeColor   = RGB(0,0,0)
	EstQtd_Formatado.ForeColor   = RGB(0,0,0)
	EstSdo_Formatado.ForeColor   = RGB(0,0,0)
	EstSug_Formatado.ForeColor   = RGB(0,0,0)
	&TabPrc1.ForeColor   = RGB(0,0,0)
	
	&ProGraNom.FontBold   = false
	&EstLoc.FontBold      = false
	&VarCharIMC.FontBold  = false
	EstUltEnt.FontBold    = false
	EstUltSai.FontBold    = false
	EstUltFab.FontBold    = false
	EstMin_Formatado.FontBold    = false
	EstABC_Qtd.FontBold    = false
	EstABC_Ren.FontBold    = false
	EstPrd_Formatado.FontBold    = false
	EstQtd_Formatado.FontBold    = false
	EstSdo_Formatado.FontBold    = false
	EstSug_Formatado.FontBold    = false
	&TabPrc1.FontBold    = false
	
	&R = 0
	&G = 150
	&B = 50
	if ProGraCod = &ProGraCod
		&ProGraNom.ForeColor  = RGB(&R,&G,&B)
		&EstLoc.ForeColor     = RGB(&R,&G,&B)
		&VarCharIMC.ForeColor = RGB(&R,&G,&B)
		EstUltEnt.ForeColor = RGB(&R,&G,&B)
		EstUltSai.ForeColor = RGB(&R,&G,&B)
		EstUltFab.ForeColor = RGB(&R,&G,&B)
		EstMin_Formatado.ForeColor = RGB(&R,&G,&B)
		EstABC_Qtd.ForeColor = RGB(&R,&G,&B)
		EstABC_Ren.ForeColor = RGB(&R,&G,&B)
		EstPrd_Formatado.ForeColor = RGB(&R,&G,&B)
		EstQtd_Formatado.ForeColor = RGB(&R,&G,&B)
		EstSdo_Formatado.ForeColor = RGB(&R,&G,&B)
		EstSug_Formatado.ForeColor = RGB(&R,&G,&B)
		&TabPrc1.ForeColor = RGB(&R,&G,&B)
		
		&ProGraNom.FontBold   = true
		&EstLoc.FontBold      = true
		&VarCharIMC.FontBold  = true
		EstUltEnt.FontBold    = true
		EstUltSai.FontBold    = true
		EstUltFab.FontBold    = true
		EstMin_Formatado.FontBold    = true
		EstABC_Qtd.FontBold    = true
		EstABC_Ren.FontBold    = true
		EstPrd_Formatado.FontBold    = true
		EstQtd_Formatado.FontBold    = true
		EstSdo_Formatado.FontBold    = true
		EstSug_Formatado.FontBold    = true
		&TabPrc1.FontBold    = true
	EndIF
	
	if EstSdo_Formatado < 0
		EstSdo_Formatado.ForeColor = RGB(200,0,0)
	EndiF
	
	if EstQtd_Formatado < 0
		EstQtd_Formatado.ForeColor = RGB(200,0,0)
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	if ProGraCod = 1
	&ProGraNom = 'VARIACOES'
Else
	&ProGraNom = ProGraNom
EndIF
	
	If Not EstLoc.IsEmpty()
	&EstLoc = EstLoc
Else
	&EstLoc = 'SEM_LOCACAO'
EndIF

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &AuxTabPrc1 <> 0 
        &CalcProIMC = 100 - ((ProVlrCus /&auxTabPrc1) * 100)
    EndIf

	&VarCharIMC = trim(toformattedString(&ProIMC)) + ' / ' + trim(ToformattedString(&CalcProIMC))

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
