      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	For Each Order EmpCod 
		Where EmpCod = &EmpCod
		Where PlanCod = &OriPlanCod
		&PlanCodNom = PlanCodNom
		If PlanCatTip = 'C'
			&CreRecPag = 'R'
		Else
			&CreRecPag = 'P'
		Endif

		Exit
	When none
		Return
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	asdasd.Height = 100
	&CreRecPag.Visible = False
	&ValorOrigem.Visible = False
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RetornaCodigoPlanoContas.Call(&EmpCod, &PlanCodDestino, &DestPlanCod)
	
	if &DestPlanCod.IsEmpty()
		Msg('Selecione Plano de Contas.')
	Else
		prcTransferePlanoContas.Call(&EmpCod, &OriPlanCod, &DestPlanCod)
		Return
	Endif

EndEvent


]]></Source>
