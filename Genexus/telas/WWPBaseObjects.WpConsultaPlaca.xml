        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPCONSULTAPLACA', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext(&Context)
	&EmpCod 	= &Context.EmpCod
	&FilCod 	= &Context.FilCod
	&PedCliCod 	= 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable4.Width = 300
	WCWcConsultaPlacaPedido.Object = WcConsultaPlacaPedido.Create(&Context.EmpCod, &Context.FilCod, &PedVeiPla, &PedSts, &PedCliCod)
	WCWcConsultaPlacaProprietario.Object = WcConsultaPlacaProprietario.Create(&Context.EmpCod, &AuxVeiCod, &IsMostrarAntigos, &PedCliCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirRelatorio'

	Do 'BuscaVeiculo'
	
	If &AuxVeiCod > 0 or &PedCliCod <> 0
		&NomeArquivo = 'RELATORIOPLACACLIENTE' + Trim(Str(Random()))
		RCOOpenWindow1.LinkOpen = RELJAS160.Link(&Context.EmpCod, &Context.FilCod, &PedVeiPla, &IsMostrarAntigos, &PedSts, &PedCliCod)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		Msg('É necessário informar uma placa, ou cliente, registrado(a) no sistema.')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedVeiPla.IsValid

	Do 'BuscaVeiculo'
	WCWcConsultaPlacaPedido.Object 			= WcConsultaPlacaPedido.Create(&Context.EmpCod, &Context.FilCod, &PedVeiPla, &PedSts, &PedCliCod)
	WCWcConsultaPlacaProprietario.Object 	= WcConsultaPlacaProprietario.Create(&Context.EmpCod, &AuxVeiCod, &IsMostrarAntigos, &PedCliCod)

EndEvent

Event &PedCliCod.IsValid

	WCWcConsultaPlacaProprietario.Object 	= WcConsultaPlacaProprietario.Create(&Context.EmpCod, &AuxVeiCod, &IsMostrarAntigos, &PedCliCod)
	WCWcConsultaPlacaPedido.Object 			= WcConsultaPlacaPedido.Create(&Context.EmpCod, &Context.FilCod, &PedVeiPla, &PedSts, &PedCliCod)

EndEvent

Event &IsMostrarAntigos.Click

	WCWcConsultaPlacaProprietario.Object = WcConsultaPlacaProprietario.Create(&Context.EmpCod, &AuxVeiCod, &IsMostrarAntigos, &PedCliCod)

EndEvent

Event &PedSts.ControlValueChanged

	WCWcConsultaPlacaPedido.Object 			= WcConsultaPlacaPedido.Create(&Context.EmpCod, &Context.FilCod, &PedVeiPla, &PedSts, &PedCliCod)

EndEvent

Sub 'BuscaVeiculo'

	For Each Order EmpCod, VeiCod
		Where EmpCod = &Context.EmpCod
		Where VeiPla = &PedVeiPla
		
		&AuxVeiCod = VeiCod
		
		Exit
	When None
		&AuxVeiCod = 0
	EndFor

EndSub


]]></Source>
