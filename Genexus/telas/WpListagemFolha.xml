      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPLISTAGEMFOLHA', Status_SimNao.Sim, 3, &AutNiv)
	&FPagAno = year(&Today)
	&FPagMes = Month(&Today)
	&SetNom = 'TODOS OS SETORES.'
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesFunFilCod = &Context.FilCod
	&PesCod = &Context.PesCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAniversariantes'

	WpAniversarios.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &SetCod.IsValid

	Do 'Setor'

EndEvent

Event 'Prompt'

	4	
	PromptSetor.Popup(&EmpCod,&SetCod)

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS026.link(&EmpCod,&context.FilCod,&FPagAno,&FPagMes,&PesFunFilCod,&SetCod,&Tipo,&PesSts,&Ordem)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'Setor'

	If &SetCod = 0
		&SetNom = 'TODOS OS SETORES.'
	Else
		For each Order EmpCod,SetCod
			Where EmpCod = &EmpCod
			Where SetCod = &SetCod
			&SetNom = SetNom
			Exit
		When none
			&SetNom = 'SETORE NÃO ENCONTRADO.'
			&SetCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
