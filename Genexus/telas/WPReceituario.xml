      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'Cliente'
	&WizardStep.Title = 'Cliente'
	&WizardStep.Description = 'Cliente'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'PRODUTOS'
	&WizardStep.Title = 'Produtos'
	&WizardStep.Description = 'Produtos'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Fim'
	&WizardStep.Title = 'Completado'
	&WizardStep.Description = 'Completado'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'Cliente'
		&WebSession.Remove(&Pgmname + !'_Data')
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsArrowWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWReceituario.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'Cliente'
			WizardStepWC.Object = WPReceituarioCliente.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'PRODUTOS'
			WizardStepWC.Object = WPReceituarioPRODUTOS.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Fim'
			WizardStepWC.Object = WPReceituarioFim.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
