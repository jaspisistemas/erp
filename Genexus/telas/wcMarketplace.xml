      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[parm(in:&EmpCod, in:&MrkCod, in:&parMrkTip);


prompt(promptVendedor, &EmpCod, &MrkPadVenCod);

prompt(promptCliente, &EmpCod, &MrkPadCliCod);

prompt(promptTipoLancamento, &EmpCod, &MrkPadLctCod);

prompt(promptTransportadora, &EmpCod, &MrkPadTraCod);
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
