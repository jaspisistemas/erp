      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&MrkTip = &parMrkTip
	&MrkTip.Enabled = 0
	if &MrkCod > 0
		do 'loadMarketplace'
	Endif

	&MrkPadGrvCli.Enabled = false
	&MrkPadGrvCli = false //POR HORA INDISPONIVEL

	do case
		case &MrkTip = TipoMarketplace.MercadoLivre
		&imagemMarketplace.FromImage(mercadoLivre)
	EndCAse

	//combo filiais
	For Each ORder EmpCod, FilCod
		Where EmpCod = &EmpCod
		&MrkPadFilCod.AddItem(FilCod, FilCodNom)
		&MrkPadNfeFilCod.AddItem(FilCod, FilCodNom)
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&MrkCod.Visible = False
	&MrkTip.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'getVendedor'
	do 'getCliente'
	do 'getTipoLancamento'
	do 'getTransportadora'
	
	Do Case
		CAse &IsErroVendedor = true 
			&MrkPadVenCod.SetFocus()
		Case &IsErroCliente = true
			&MrkPadCliCod.SetFocus()
		case &IsErroTipoLancamento = true
			&MrkPadLctCod.SetFocus()
		otherwise
			if &MrkNom.IsEmpty()
				msg('Informe o nome do Marketplace')
			Else
				prcGravarMarketplace.Call(&EmpCod, &MrkCod, &MrkTip, &MrkNom, &MrkPadFilCod, &MrkPadNfeFilCod, &MrkPadVenCod, &MrkPadCliCod, &MrkPadGrvCli, &MrkPadLctCod, &MrkPadTraCod)
				
				wwpActions.WCPopup_Close('S')
			Endif
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwpActions.WCPopup_Close('N')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &MrkPadVenCod.IsValid

	do 'getVendedor'

EndEvent

Event &MrkPadCliCod.IsValid

	do 'getCliente'

EndEvent

Event &MrkPadLctCod.IsValid

	do 'getTipoLancamento'

EndEvent

Event &MrkPadTraCod.IsValid

	do 'getTransportadora'

EndEvent

Sub 'getCliente'

	&IsErroCliente = false
	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &MrkPadCliCod
		
		&MrkPadCliRaz = PesRaz
		Do CAse
			CAse PesIsCli = false and PesIsFor = false 
				&IsErroCliente = true
				msg('Pessoa informado não é um cliente!')
		EndCase
		
		
		Exit
	When None
		&IsErroCliente = true
		msg('Cliente padrão não informado!')
	EndFor

EndSub

Sub 'getTipoLancamento'

	&IsErroTipoLancamento = false
	For Each ORder EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &MrkPadLctCod
		
		&MrkPadLctNom = LctNom
		If LctTip <> TipoLancamento.SaidaMercadoria
			&IsErroTipoLancamento = true
			msg('Tipo lançamento não utilizavel para venda de mercadorias!')
		Endif		
		
		Exit
	When None
		&IsErroTipoLancamento = true
		msg('Tipo lancamento não informado!')
	EndFor

EndSub

Sub 'getVendedor'

	&IsErroVendedor = false
	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &MrkPadVenCod
		
		&MrkPadVenRaz = PesRaz
		Do CAse
			CAse PesIsVen = false 
				&IsErroVendedor = true
				msg('Pessoa informado não é um vendedor!')
			Case (not PesDtaDem.IsEmpty() and not PesDtaDem.IsNull())
				&IsErroVendedor = true
				msg('Vendedor informado com status de demitido!')
		EndCase
		
		
		Exit
	When None
		&IsErroVendedor = true
		msg('Vendedor não informado!')
	EndFor

EndSub

Sub 'getTransportadora'

	&IsErrotranspor = false
	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &MrkPadTraCod
		
		&MrkPadTraRaz = PesRaz
		Do CAse
			CAse PesIsTra = false or PesSts = status_AtivoInativo.INATIVO
				&IsErrotranspor = true
				msg('Pessoa informado não é uma Transportadora ou esta inativada!')
		EndCase
		
		
		Exit
	When None
		&IsErrotranspor = true
		msg('Transportadora não informada!')
	EndFor

EndSub

Sub 'loadMarketplace'

	For Each ORder EmpCod, MrkCod
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		
		&MrkStsInt = MrkStsInt
		&MrkSts  = MrkSts
		&MrkTip = MrkTip
		&MrkPadFilCod = MrkPadFilCod
		&MrkPadNfeFilCod = MrkPadNfeFilCod
		&MrkPadVenCod = MrkPadVenCod
		&MrkPadCliCod = MrkPadCliCod
		&MrkPadTraCod = MrkPadTraCod
		
		&MrkNom = MrkNom
		&MrkSellID = MrkSellID
		&MrkTok = MrkTok
		&MrkDtaVctTok = MrkDtaVctTok
		
		&MrkPadGrvCli = MrkPadGrvCli
		&MrkPadLctCod = MrkPadLctCod
		
		Exit
	EndFor

	do 'getVendedor'
	do 'getCliente'
	do 'getTipoLancamento'
	do 'getTransportadora'

EndSub


]]></Source>
