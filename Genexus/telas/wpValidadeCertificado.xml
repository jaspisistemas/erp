      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&HojeData = serverdate()
	&FilVctCer = &HojeData + 30
	&AvisoVencimentoMensagem.SetEmpty()
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilVctCer <= &FilVctCer
		Where not FilVctCer.IsEmpty() and not FilVctCer.IsNull()
		
		&QtdDias = &HojeData - FilVctCer
		If FilCpj.Trim().Length() > 14
			&TIPO = 'E-CNPJ '
		Else
			&TIPO = 'E-CPF '
		EndIf
		&TIPO += EmpA1A3
		
		if &QtdDias < 0
			&QtdDias = &QtdDias * -1
		EndIF
		
		
		if not &AvisoVencimentoMensagem.IsEmpty()
			&AvisoVencimentoMensagem += NewLine()
		EndIF
		
		&AvisoVencimentoMensagem += 'CERTIFICADO DIGITAL TIPO: '+&TIPO.Trim()+' DA FILIAL:' + trim(str(FilCod)) + ' - ' + trim(substr(FilRaz, 1, 10)) 
		&AvisoVencimentoMensagem += NewLine()
		
		Do Case
			CAse FilVctCer = &HojeData
				&AvisoVencimentoMensagem += '# VENCE HOJE: ' + trim(toFormattedString(&HojeData)) + ' #'
			Case FilVctCer < &HojeData
				&AvisoVencimentoMensagem += '# VENCIDO À MAIS DE ' +trim(toformattedString(&QtdDias)) + ' DIAS #'
			Otherwise
				if &QtdDias > 1
					&AvisoVencimentoMensagem += '# VENCE EM ' +trim(toformattedString(&QtdDias)) + ' DIAS #'
				Else
					&AvisoVencimentoMensagem += '# VENCE EM ' +trim(toformattedString(&QtdDias)) + ' DIA #'
				Endif
		EndCase
		&AvisoVencimentoMensagem += NewLine()
		&AvisoVencimentoMensagem += 'PROVIDÊNCIE SUA RENOVAÇÃO ENTRANDO EM CONTATO CONOSCO (44) 9-9753-8680!'
	EndFor
	
	txtAlerta.Caption = &AvisoVencimentoMensagem.Trim()
	txtAlerta.ForeColor = RGB(178,0,0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Visible = (&AvisoVencimentoMensagem <> '')
	If not(&AvisoVencimentoMensagem <> '')
		DVPanel_TableContent_Cell.Class = !'Invisible'
	Else
		DVPanel_TableContent_Cell.Class = !'col-xs-12'
	EndIf
	TableAttributes.Visible = (&AvisoVencimentoMensagem <> '')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
