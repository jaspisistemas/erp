      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	&AcePesCod = &Context.PesCod
	RetornaAutorizacao.Call('WPCURVAABC', Status_SimNao.Sim, 1, &AutNiv)
	&CurvaA = 70
	&CurvaB = 20
	&CurvaC = 10
	&PedDtaEms = YMDtoD(year(&Today),Month(&Today),1)
	&PedDtaEms_go = &Today
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	If &Context.PesIsVen = true
		&AutNiv = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
		&PedVenCod.Enabled = &AutNiv
		If &AutNiv < 1
			&PedVenCod = &Context.PesCod
		Else
			&PedVenCod = val(SubStr(&PadObs,9,8))
		EndIF
	Else
		&PedVenCod = val(SubStr(&PadObs,9,8))
	EndIF
	&FilCod = val(SubStr(&PadObs,1,8))
	&PedDtaEms = iif(ctod(SubStr(&PadObs,17,10)) <> &datavazia,ctod(SubStr(&PadObs,17,10)),&Today)
	&PedDtaEms_go = iif(ctod(SubStr(&PadObs,27,10)) <> &datavazia,ctod(SubStr(&PadObs,27,10)),&Today)
	&UfeCod = SubStr(&PadObs,37,2)
	&CidCod = val(SubStr(&PadObs,39,8))
	&Tipo   = SubStr(&PadObs,47,1)
	&Status = iif(SubStr(&PadObs,48,1) = '1',true,False)
	&IsGravar = iif(SubStr(&PadObs,49,1) = '1',true,False)
	
	If &Tipo.IsEmpty()
		&Tipo = 'C'
	EndIf
	Do 'Vendedor'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsGravar.TooltipText = 'Vai zerar a curva dos clientes tudo para "C" e atualizar conforme faturamento.'
	&Status.TooltipText = "Marque para listar os clientes inativos também."
	&Tipo.TooltipText = "Determina qual o tipo de relatório que deseja listar."

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&FilCod = &Context.FilCod

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&Tipo = 'C')
		&CurvaPor.Visible = False
		CurvaPor_Cell.Class = !'Invisible'
	Else
		&CurvaPor.Visible = True
		CurvaPor_Cell.Class = !'CellPaddingLeft45'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Tipo.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event Enter

	If (&CurvaA + &CurvaB + &CurvaC) <> 100
        msg('ATENÇÃO! A soma das curvas A - B - C , deve ser igual a 100%!')
    else
        &Curva_A = 0                    // EXEMPLO SE EU ESCOLHI    70% - 20% - 10% 
        &Curva_B = &CurvaA             // ENTAO EU DEFINO ONDE COMEÇA CADA CURVA
        &Curva_C = &CurvaA + &CurvaB  // CURVAA = 0..70    CURVAB = 70..90    - CURVAC = 90..100
		RCOOpenWindow1.LinkOpen = RELJAS070.link(&EmpCod,&FilCod,&PedVenCod,&PedDtaEms,&PedDtaEms_go,&UfeCod,&CidCod,&Tipo,&Status,&IsGravar,&Curva_A,&Curva_B,&Curva_C,&CurvaPor)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		&PadObs = PadL(trim(str(&FilCod)),8,'0') + PadL(trim(str(&PedVenCod)),8,'0') +dtoc(&PedDtaEms)+dtoc(&PedDtaEms_go)+&UfeCod+PadL(trim(str(&CidCod)),8,'0')+&Tipo+iif(&Status = true,'1','0')+iif(&IsGravar = true,'1','0')  
		PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	EndIf

EndEvent

Event &PedVenCod.IsValid

	Do 'Vendedor'

EndEvent

Sub 'Vendedor'

	If &PedVenCod = 0
		&PedVenRaz = 'TODOS OS VENDEDORES'
	Else		
		For each Order EmpCod PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PedVenCod
			If PesIsVen = True
				&PedVenRaz = PesRaz
			Else
				msg('ATENÇÃO! Essa pessoa não é um vendedor. Verifique!')
				&PedVenCod.SetFocus()
			EndIf
			exit
		When none
			msg('ATENÇÃO! Vendedor não encontrado.')
			&PedVenRaz = 'ATENÇÃO! VENDEDOR NÃO ENCONTRADO.'
			&PedVenCod.SetFocus()			
		EndFor
	EndIf

EndSub


]]></Source>
