      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[Event Start
	
	LoadWWPContext.Call(&Context)

	if &Context.TipoPerfil <> 3
		return
	endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows

	If &HTTPRequest.Method = HttpMethod.Get
		Do 'LoadSavedFilters'
	EndIf
	&LanMaqStatus = nullvalue(&LanMaqStatus)
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' Lancamento Maquininha'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do Case
		Case &ManageFiltersExecutionStep = 1
			&ManageFiltersExecutionStep = 2
		Case &ManageFiltersExecutionStep = 2
			&ManageFiltersExecutionStep = 0
			Do 'LoadSavedFilters'
	EndCase
	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Update = !'<i class="fa fa-pen"></i>'
		&Update.Link = LancamentoMaquininha.Link(TrnMode.Update, EmpCod, BanCarCod, LanMaqCod)
	&Delete = !'<i class="fa fa-times"></i>'
		&Delete.Link = LancamentoMaquininha.Link(TrnMode.Delete, EmpCod, BanCarCod, LanMaqCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ddo_ManageFilters.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case ddo_ManageFilters.ActiveEventKey = !'<#Clean#>'
			Do 'CleanFilters'
			Grid.FirstPage()
		Case ddo_ManageFilters.ActiveEventKey = !'<#Save#>'
			Do 'SaveGridState'
			SaveFilterAs.Popup(!'WWLancamentoMaquininhaFilters', &PgmName + !"GridState")
			&ManageFiltersExecutionStep = 2
			Refresh
		Case ddo_ManageFilters.ActiveEventKey = !'<#Manage#>'
			ManageFilters.Popup(!'WWLancamentoMaquininhaFilters')
			&ManageFiltersExecutionStep = 2
			Refresh
		Otherwise
			&ManageFiltersXml = GetFilterByName(!'WWLancamentoMaquininhaFilters', ddo_ManageFilters.ActiveEventKey)
			If &ManageFiltersXml.IsEmpty()
				msg('WWP_FilterNotExist')
			Else
				Do 'CleanFilters'
				SaveGridState.Call(&PgmName + !"GridState",  &ManageFiltersXml)
				&GridState.FromXml(&ManageFiltersXml)
				&OrderedBy = &GridState.OrderedBy
				&OrderedDsc = &GridState.OrderedDsc
				Do 'SetDDOSortedStatus' 
				Do 'LoadRegFiltersState'
				Grid.FirstPage()
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

		LancamentoMaquininha.Call(TrnMode.Insert, nullvalue(EmpCod), nullvalue(BanCarCod), nullvalue(LanMaqCod))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadSavedFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ManageFiltersData = WWP_ManageFiltersLoadSavedFilters(!'WWLancamentoMaquininhaFilters', '', '', False)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CleanFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&LanMaqStatus.SetEmpty()
	&LanMaqDtaPgto.SetEmpty()
	&LanMaqDtaPgto_To.SetEmpty()
	&LanMaqDtaVenda.SetEmpty()
	&LanMaqDtaVenda_To.SetEmpty()
	&LanMaqBandeiraOperator = 0
	&LanMaqBandeira.SetEmpty()
	&LanMaqNroAutOperator = 0
	&LanMaqNroAut.SetEmpty()
	&LanMaqNSUOperator = 0
	&LanMaqNSU.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'
	Do 'LoadRegFiltersState'
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadRegFiltersState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"LANMAQSTATUS"
				&LanMaqStatus.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"LANMAQDTAPGTO"
				&LanMaqDtaPgto.FromString(&GridStateFilterValue.Value)
				&LanMaqDtaPgto_To.FromString(&GridStateFilterValue.ValueTo)
			Case &GridStateFilterValue.Name = !"LANMAQDTAVENDA"
				&LanMaqDtaVenda.FromString(&GridStateFilterValue.Value)
				&LanMaqDtaVenda_To.FromString(&GridStateFilterValue.ValueTo)
			Case &GridStateFilterValue.Name = !"LANMAQBANDEIRA"
				&LanMaqBandeira.FromString(&GridStateFilterValue.Value)
				&LanMaqBandeiraOperator = &GridStateFilterValue.Operator
			Case &GridStateFilterValue.Name = !"LANMAQNROAUT"
				&LanMaqNroAut.FromString(&GridStateFilterValue.Value)
				&LanMaqNroAutOperator = &GridStateFilterValue.Operator
			Case &GridStateFilterValue.Name = !"LANMAQNSU"
				&LanMaqNSU.FromString(&GridStateFilterValue.Value)
				&LanMaqNSUOperator = &GridStateFilterValue.Operator
		EndCase
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"LANMAQSTATUS", "", not &LanMaqStatus.IsEmpty(), 0, &LanMaqStatus.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"LANMAQDTAPGTO", "", not (&LanMaqDtaPgto.IsEmpty() AND &LanMaqDtaPgto_To.IsEmpty()), 0, &LanMaqDtaPgto.ToString().Trim(), &LanMaqDtaPgto_To.ToString().Trim())
	WWP_GridStateAddFilterValue(&GridState, !"LANMAQDTAVENDA", "", not (&LanMaqDtaVenda.IsEmpty() AND &LanMaqDtaVenda_To.IsEmpty()), 0, &LanMaqDtaVenda.ToString().Trim(), &LanMaqDtaVenda_To.ToString().Trim())
	WWP_GridStateAddFilterValue(&GridState, !"LANMAQBANDEIRA", "", not &LanMaqBandeira.IsEmpty(), &LanMaqBandeiraOperator, &LanMaqBandeira, '')
	WWP_GridStateAddFilterValue(&GridState, !"LANMAQNROAUT", "", not &LanMaqNroAut.IsEmpty(), &LanMaqNroAutOperator, &LanMaqNroAut, '')
	WWP_GridStateAddFilterValue(&GridState, !"LANMAQNSU", "", not &LanMaqNSU.IsEmpty(), &LanMaqNSUOperator, &LanMaqNSU, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"LancamentoMaquininha"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub
