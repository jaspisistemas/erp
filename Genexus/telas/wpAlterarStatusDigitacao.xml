      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	do 'loadPedido'
	txtMsg.ForeColor = RGB(0, 100, 255)
	
	RetornaAutorizacao.Call('WWFRETEREGRAS', Status_SimNao.Nao, 1, &FreteAutNiv)
//	retornaAutorizacaoAdministrador.Call(&Context.EmpCod, &Context.PesCod, &AutIsAdm)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&TestaMensagem <>  '' or &Testa1Mensagem <> '' or &Mensagem <> '')
		DVPanel_ValidacaoPedido_Cell.Class = !'Invisible'
	Else
		DVPanel_ValidacaoPedido_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	if (&TestaMensagem.IsEmpty() and &Mensagem.IsEmpty() and &Testa1Mensagem.IsEmpty()) or (&FreteAutNiv >= 3)
		do 'loadPedido'
		GravaStatusDigitado.Call(&EmpCod, &FilCod, &PedCod, false, &Context.PesCod)
		do 'EnviaNotificacao'
		
		Return
	Else
		msg(&AvisoValidaFreteMensagem)
	EndIF

EndEvent

Sub 'loadPedido'

	retornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon088_QuantidadeReferencia, &TCon088_QuantidadeReferencia)
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedCliCod = PedCliCod
		&PedCliRaz = PedCliRaz
		
		ValidaRegrasFrete.Call(EmpCod, PedTipSaiFrt, PedDtaEms, PedVlrLiq, TabCod, TabPrmCod, PedCliCod, PedPerFrt, PedFrtFix, 'S', &TestaMensagem) 
		ValidaRegrasFrete.Call(EmpCod, PedTipFrt, PedDtaEms, PedVlrLiq, TabCod, TabPrmCod, PedCliCod, PedPerFrt, PedFrtFix, 'R', &Testa1Mensagem) 
		
		&QtdExigida = val(&TCon088_QuantidadeReferencia)
		validaReferenciaComercial.Call(EmpCod, PedCliCod, &QtdExigida, &Mensagem)
		
		
		&AvisoValidaFreteMensagem = &TestaMensagem.Trim() + newLine() + trim(&Testa1Mensagem) + newLine() + trim(&Mensagem)
		&AvisoValidaFreteMensagem = &AvisoValidaFreteMensagem.Trim()
		txtAlerta.Caption = &AvisoValidaFreteMensagem
		
		If PedStsDigBlk <> true
			Return
		EndIF
		
		Exit
	EndFor

EndSub

Sub 'EnviaNotificacao'

	For Each Order EmpCod, AutGrpCod											//## Busca o código do Perfil com as determinadas Autorizações ##\\
		Where EmpCod = &EmpCod													//## código da empresa ##\\
		Where AutCod IN ('LIBERACREDITOPEDIDOANALISADO', 'LIBERACREDITOPEDIDO')	//## Autorizações ##\\
		Where AutNiv > 0														//## Autorizado ##\\
		
		&CollGrpCod.Add(AutGrpCod)	//## Adiciona à Collection o(os) Código(os) do perfil ##\\
		
	EndFor

	For Each Order EmpCod, AutGrpCod, PesCod	//## Busca o Código do(os) Usuários/Pessoas com o(os) determinado(os) perfil ##\\
		Where EmpCod = &EmpCod					//## Código da Empresa ##\\
		Where AutGrpCod in &CollGrpCod			//## Código(os) do perfil ##\\
		
		&CollPesExtCod.Add(PesExtCod)			//## Adiciona os Códigos Externos GAM na Collection (&CollPesExtCod) ##\\
		
		For &PesExtCod in &CollPesExtCod
			
			//## Atribuí os valores da Collection (&CollPesExtCod) na variavel &PesExtCod ##\\
			
		EndFor
	
		&X = 1
		Do While &X <= &CollPesExtCod.Count //## Vai enviar as notificações para os determinados perfis definidos na Collection (&CollPesExtCod) ##\\
			do 'BuscaUsuariosGAM'			//## Busca o GAMGUID referente ao Código Externo GAM ##\\
			&X +=1 
			Exit
		enddO
	EndFor

EndSub

Sub 'BuscaUsuariosGAM'

	&Filter.ExternalId = trim(str(&PesExtCod)) //## Define o filtro que será usado no GetUser ##\\
	
	For &User in GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors) //## Procura o GAMGUID do usuário e envia a notificação para o mesmo ##\\
		&IDUsuario = &User.GUID //## Define IDUsuario como o código do GAMGUID ##\\
		
		&NotificationLink = WWPedidoVenda.Link()	//## Define o Link da Notificação, ao clicar nela ##\\
		WWP_SendNotification(!'StatusDigitacaoOk', !"StatusDigitacao", '', "fas fa-exclamation FontColorIconWarning", "Digitação OK!", Format("%1 concluiu a digitação de um pedido. Solicita a análise financeira/liberação do crédito! %2 %3",WWP_GetUserFullName(WWP_GetLoggedUserId()), "Confira em: VENDAS TELEVENDAS!"), Format("%1 concluiu a digitação de um pedido. Solicita a análise financeira/liberação do crédito! %2 %3",WWP_GetUserFullName(WWP_GetLoggedUserId()), "Confira em: VENDAS TELEVENDAS!"), &NotificationLink, '', '', True, &IDUsuario)

		Exit
	EndFor

EndSub


