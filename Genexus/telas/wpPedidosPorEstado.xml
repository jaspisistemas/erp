      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPPEDIDOSPORESTADO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	
	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	&FilCodNom = trim(str(&Context.FilCod)) + ' - ' + trim(&Context.FilRaz)

	&finPedDtaFat = serverdate()
	&iniPedDtaFat = &finPedDtaFat
	
	&LctAtuSal = Status_EntradaSaida.Saida
	//&SomenteComInconsistencia = Status_SimNao.Nao
	//&SeparaPedidoVendedor = false
	
	&PedVenRaz = 'TODOS OS VENDEDORES'
	&LctNom = 'TODAS AS OPERAÇÕES'
	&PedCliRaz = 'TODOS OS CLIENTES'
	&PedCliCidNom = 'TODAS AS CIDADES'
	&LctGerFin = Status_SimNao.Sim
	&PedSts = Status_Pedido.FECHADO

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&FilCod.Visible = False
	&EmpCod.Visible = False
	&TabDtaIni.Visible = False
	&TabSts.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod

EndEvent

Event &LctCod.IsValid

	do 'Operacao'

EndEvent

Event &PedCliCod.IsValid

	do 'Cliente'

EndEvent

Event &PedVenCod.IsValid

	do 'Vendedor'

EndEvent

Event &PedCliCidCod.IsValid

	do 'CidadeCliente'

EndEvent

Event &RatCod.IsValid

	do 'RamoAtividade'

EndEvent

Event Enter

do 'Vendedor'
	do 'Operacao'
	do 'Cliente'
	do 'CidadeCliente'
	do 'RamoAtividade'
	Do Case
		Case &IsErroVendedor = true
			&PedVenCod.SetFocus()
			
		Case &IsOperacao = true
			&LctCod.SetFocus()
			
		Case &IsCliente = true
			&PedCliCod.SetFocus()
			
		Case &IsCidadeCliente = true
			&PedCliCidCod.SetFocus()
			
		case &IsErroRamo = true
			&RatCod.SetFocus()
			
		Case &finPedDtaFat < &iniPedDtaFat or &finPedDtaFat.IsEmpty()
			msg('Data Final não pode ser menor que Inicial e nem Vazia!')
			&iniPedDtaFat.SetFocus()
		Otherwise
			&Random = trim(Str((Random() * 1000)))
			RCOOpenWindow1.LinkOpen = RELJAS059.Link(&EmpCod, &FilCod, &PedVenCod, &PedVenAreCod, &PedCliCod, &PedCliCidCod, &PedCliCidAreCod, &PedCliCidUfeCod, &RatCod, &PedSts, &iniPedDtaFat, &finPedDtaFat, &LctCod, &LctGerFin, &TabCod, &Agrupar, &LctAtuSal, &AnaliticoSintetico)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent

Sub 'RamoAtividade'

	&IsErroRamo = false
	&RatNom = 'TODOS OS RAMOS'
	If &RatCod <> 0
		For Each Order EmpCod, RatCod
			Where EmpCod = &EmpCod
			Where RatCod = &RatCod
			&RatNom = RatNom
			Exit
		When none
			&RatNom = 'RAMO NÃO ENCONTRADO'
			msg(&RatNom)
			&IsErroRamo = true
			&RatCod.SetFocus()
		EndFor
	EndIF

EndSub

Sub 'CidadeCliente'

	&IsCidadeCliente = false
	&PedCliCidNom = 'TODAS AS CIDADES'
	If &PedCliCidCod <> 0
		For Each order EmpCod, CidCod
			Where EmpCod = &EmpCod
			Where CidCod = &PedCliCidCod
			&PedCliCidNom = CidNom
			Exit
		When none
			
			&PedCliCidNom = 'CIDADE NÃO ENCONTRADA'
			msg(&PedCliCidNom)
			&IsCidadeCliente = true
			&PedCliCidCod.SetFocus()
		EndFor
		
	EndIF

EndSub

Sub 'Cliente'

	&IsCliente = false
	&PedCliRaz = 'TODOS OS CLIENTES'
	If &PedCliCod <> 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			where PesCod = &PedCliCod
			Where PesIsCli = true
			&PedCliRaz = PesRaz
			Exit
		When none
			&PedCliRaz = 'CLIENTE NÃO ENCONTRADO'
			msg(&PedCliRaz)
			&IsCliente = true
			&PedCliCod.SetFocus()
		EndFor
	EndIF

EndSub

Sub 'Operacao'

	&IsOperacao = false
	&LctNom = 'TODAS AS OPERAÇÕES'
	If &LctCod <> 0
		For Each Order EmpCod, LctCod
			Where EmpCod = &EmpCod
			Where LctCod = &LctCod
			&LctNom = LctNom
			Exit
		When None
			&LctNom = 'TODAS AS OPERAÇÕES'
			msg(&LctNom)
			&IsOperacao = true
		EndFor
	EndIF

EndSub

Sub 'Vendedor'

	&IsErroVendedor = false
	&PedVenRaz = 'TODOS OS VENDEDORES'
	If &PedVenCod <> 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			where PesCod = &PedVenCod
			Where PesIsVen = true
			&PedVenRaz = PesRaz
			Exit
		When none
			&PedVenRaz = 'VENDEDOR NÃO ENCONTRADO'
			msg(&PedVenRaz)
			&IsErroVendedor = true
		EndFor
	EndIF

EndSub


]]></Source>
