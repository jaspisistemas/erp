      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&AptAtiCod.Visible = False
	&AptCod.Visible = False
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadLancamentoStart'

EndEvent

Event Enter

	do 'ValidaFuncionario'
	do 'EtapaProduto'
	FormataHORA.Call(&AptHorIni, &AptHorIni)
	FormataHORA.Call(&AptHorFin, &AptHorFin)
	retornaDiferencaEntreHoras.Call(&AptHorIni, &AptHorFin, &HoraTotal, &Segundos)
	
	do case
		case &Segundos.IsEmpty()
			msg('Período Inválido!')
			&AptHorIni.SetFocus()
		Case &AptDtaLct.IsEmpty()
			msg('Data Lançamento Inválida!')
			&AptDtaLct.SetFocus()
		Case &PesRaz.IsEmpty()
			msg('Funcionario inválido!')
			&AptFunCod.SetFocus()
		Case &AptProNom.IsEmpty()
			msg('Molde não Localizado!')
		Otherwise
			GravaApontamentoMolde.Call(&EmpCod, &AptCod, &AptDtaLct, &AptAtiCod, &AptFunCod, &AptHorIni, &AptHorFin, &AptMolCod, &AptObs, &AptQtd)
			
			if &inAptCod = 0
				msg('Apontamento salvo com sucesso!')
				&AptObs.SetEmpty()
				&AptQtd.SetEmpty()
				&AptMolCod.SetEmpty()
				&AptDtaLct.SetFocus()
			Else
				Return
			EndIf
	EndCase

EndEvent

Event &AptHorIni.IsValid

	FormataHORA.Call(&AptHorIni, &AptHorIni)
	retornaDiferencaEntreHoras.Call(&AptHorIni, &AptHorFin, &HoraTotal, &Segundos)
	&AptHorFin.SetFocus()

EndEvent

Event &AptHorFin.IsValid

	FormataHORA.Call(&AptHorFin, &AptHorFin)
	retornaDiferencaEntreHoras.Call(&AptHorIni, &AptHorFin, &HoraTotal, &Segundos)
	&AptMolCod.SetFocus()

EndEvent

Event &AptFunCod.IsValid

	do 'ValidaFuncionario'

EndEvent

Event &AptMolCod.IsValid

	do 'EtapaProduto'
	if &inAptCod.IsEmpty()
		do 'loadLancamento'
	endif
	
	&AptQtd.SetFocus()

EndEvent

Sub 'loadLancamentoStart'

	&AptCod.SetEmpty()
	For Each Order EmpCod,AptDtaLct,AptCod
		Where EmpCod = &inEmpCod
		where AptDtaLct = &inAptDtaLct
		where AptCodVin = &inAptCod
		
		&AptCod = AptCod
		&AptDtaLct = AptDtaLct
		
		&AptAtiCod = AptAtiCod
		&AptFunCod = AptFunCod
		&AptHorIni = AptHorIni
		&AptHorFin = AptHorFin
	
		&AptMolCod = AptMolCod
		&AptQtd = AptMolQtd

		&AptCod = AptCod
		&AptObs = AptObs
		
		&AptDtaLct.Enabled = 0
		
		do 'ValidaFuncionario'
		do 'EtapaProduto'
		Exit
	EndFor

EndSub

Sub 'EtapaProduto'

	&AptProNom.SetEmpty()
//	&CTrCod.SetEmpty()
//	&GrupCtrQtd.SetEmpty()
	For Each Order EmpCod, GrupCod, GrupCTrOrd
		Where EmpCod = &EmpCod
		Where MolCod = &AptMolCod
//		&CTrCod = GrupCTrCod
		&AptProNom = MolNom
//		&GrupCtrQtd = GrupCTrQtd
		Exit
	When none
		msg('Molde não Localizado!')
	EndFor

EndSub

Sub 'ValidaFuncionario'

	&PesRaz.SetEmpty()
	For Each order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &AptFunCod
		Where PesIsFun = true
		&PesRaz = PesRaz
		Exit
	When none
		msg('Pessoa não localizada')
	EndFor

EndSub

Sub 'loadLancamento'

	&AptCod.SetEmpty()
	For Each Order EmpCod,AptDtaLct,AptAtiCod,AptFunCod,AptHorIni,AptHorFin,AptMolCod,AptEtpCod, AptCod
		where EmpCod = &EmpCod
		where AptDtaLct = &AptDtaLct
		where AptAtiCod = &AptAtiCod
		where AptFunCod = &AptFunCod
		where AptHorIni = &AptHorIni
		where AptHorFin = &AptHorFin
		where AptMolCod = &AptMolCod
		&AptCod = AptCod
		&AptQtd = AptMolQtd
		&AptObs = AptObs
		Exit
	When none
		if not &GrupCtrQtd.IsEmpty() and &AptQtd.IsEmpty()
			&AptQtd = &GrupCtrQtd
		EndiF

	EndFor

EndSub


]]></Source>
