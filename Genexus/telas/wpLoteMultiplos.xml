      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &parPedItmCod < 0
		Return
	Endif

	do 'loadPedidoProduto'

EndEvent

Sub 'loadPedidoProduto'

	For Each order EmpCod, FilCod, PedCod, (PedItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedItmCod = &parPedItmCod when Not &parPedItmCod.IsEmpty()
		
		TextBlockTitle.Caption = 'PROD: ' + trim(ProGraRef) + ' - ' + trim(ProNomGra)
		&PedItmCod = PedItmCod
		
		Exit
	When none
		Return
	EndFor
	
	PedidoProdutoLote.Link(TrnMode.Update, &EmpCod, &FilCod, &PedCod, &PedItmCod)

EndSub


]]></Source>
