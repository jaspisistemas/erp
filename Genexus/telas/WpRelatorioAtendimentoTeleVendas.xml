      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPRELATORIOATENDIMENTOTELEVENDAS', Status_SimNao.Sim, 1, &AutNiv)
	
	&TrocarTelevendas = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
	&AuxPedVenCod.Enabled = &TrocarTelevendas
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	
	If &TrocarTelevendas = 0
		&AuxPedVenCod = &Context.PesCod
	EndIf
	
	&dias = -30 							//## Atribui valor ##\\
	&PesSacDtaAte = servernow()				//## Atribui a data e a hora do momento ##\\
	&PesSacDtaDe = &Today.AddDays(&dias)	//## Calcula a data e a hora ##\\
	
	TbDadosCliente.Visible = 0
	&CheckRequiredFieldsResult = True		//## Define o resultado dos campos obrigatórios como True ##\\
	
	&IsImprimirLigacoes = True				//## Imprimir conteúdo das conversas ##\\
	
	Do 'Vendedor'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAjuda'

	innewWindow.Target = 'https://ajuda.jaspi.com.br/index.aspx?f1258114-5c0a-4b1f-bd83-2ad673668522'
	inNewWindow.Name = '_blank'
	innewWindow.OpenWindow()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FiltrarCliente.Click

	If TbDadosCliente.Visible = 0	//## Se o campo para informar os dados do Cliente estiver invisivel ##\\
		TbDadosCliente.Visible = 1	//## Deixa o campo visível ##\\
	Else							//## Se o campo para informar os dados do Cliente estiver visível ##\\
		TbDadosCliente.Visible = 0	//## Deixa o campo invisivel ##\\
		&PesCod = 0					//## Atribui valor 0 ##\\
	EndIf

EndEvent

Event Enter

	If &FiltrarCliente = True and &PesCod.IsEmpty()		//## Se a opção de filtrar por cliente estiver marcada e nenhum cliente for informado ##\\
		Msg(DVMessageGetBasicNotificationMsg('', 'É obrigatório informar o Cliente!', DVMessageType.error, &PesCod.InternalName, DVMessageBoolean.True, ''))	//## Emite está mensagem ##\\
		&CheckRequiredFieldsResult = False				//## Define o resultado dos campos obrigatórios como False ##\\
	Else												//## Se foi informado o cliente, ok e segue a vida ##\\
		&CheckRequiredFieldsResult = True				//## Define o resultado dos campos obrigatórios como True ##\\
	EndIf
	
	If &CheckRequiredFieldsResult = True				//## Se tudo estiver informado, imprime o relatório com base nos filtros atribuídos ##\\
		RCOOpenWindow1.LinkOpen = RELJAS154.Link(&EmpCod, &FilCod, &PesCod, &AuxPedVenCod, &PesSacDtaDe, &PesSacDtaAte, &IsImprimirLigacoes)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIf

EndEvent

Event &AuxPedVenCod.IsValid

	Do 'Vendedor'

EndEvent

Sub 'Vendedor'

	If &AuxPedVenCod = 0									//## Se não houver vendedor selecionado ##\\
		&AuxPesRaz = 'TODOS OS VENDEDORES'
		&PesCodRaz = '0 - TODOS OS VENDEDORES'

	Else													//## Senão busca, pelo código, o nome do mesmo ##\\
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &AuxPedVenCod
//			Where PesIsVen = True //jdf nao é mais agora, mas ja foi
			
			&AuxPesRaz = PesRaz
			&PesCodRaz = PesCodRaz
			
		When None											//## Caso não exista vendedor emite a mensagem ##\\
			
			Msg('Vendedor não encontado ou pessoa não é vendedor!')
			&AuxPesRaz = 'VENDEDOR NÃO ENCONTRADO'
			&AuxPedVenCod.SetFocus()
			
		EndFor
	EndIf

EndSub


]]></Source>
