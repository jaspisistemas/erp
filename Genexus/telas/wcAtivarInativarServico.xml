      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod
	do 'getTipoServicos'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Page.Rows
	Grid1_TitlesCategories.GridInternalName = Grid1.InternalName
	&Grid1CurrentPage = 1
	&Grid1CurrentPage.Visible = False
	&Grid1PageCount = -1
	Grid1PaginationBar.RowsPerPageSelectedValue = Grid1.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&Grid1CurrentPage = Grid1.CurrentPage
	&Grid1PageCount = Grid1.PageCount

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&Grid1PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	TipSerEmpIsUse.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserUpdate = !'<i class="fas fa-pencil-alt"></i>'
	&UserUpdate.Link = wpEditarTaxas.Link(TipSerCod, TipSerItmCod)
	&UserInativar = !'<i class="fas fa-times"></i>'

	Do Case
		Case TipSerEmpIsUse.ToString().Trim() = !"true"
			TipSerEmpIsUse.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case TipSerEmpIsUse.ToString().Trim() = !"false"
			TipSerEmpIsUse.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			TipSerEmpIsUse.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case Grid1PaginationBar.SelectedPage = !'Previous'
			&Grid1CurrentPage -= 1
			Grid1.PreviousPage()
		Case Grid1PaginationBar.SelectedPage = !'Next'
			&Grid1CurrentPage += 1
			Grid1.NextPage()
		Otherwise
			&PageToGo.FromString(Grid1PaginationBar.SelectedPage)
			&Grid1CurrentPage = &PageToGo
			Grid1.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Grid1PaginationBar.RowsPerPageSelectedValue
	&Grid1CurrentPage = 1
	Grid1.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction2'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWTiposServicos.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpEditarTaxas.Call(&TipSerCod, 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &UserInativar.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_UserInativar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_UserInativar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_UserInativar.Result = !'Yes'
		Do 'Do UserInativar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do UserInativar'

	prcInativarTipoServico.Call(TipSerCod, TipSerItmCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'getTipoServicos'

	For Each Order TipSerCod
		Where TipSerCod = &TipSerCod
		&TipSerNom = TipSerNom
		Exit
	When none
		Dashboard.Link()
	EndFor

	For EAch Order TipSerCod
		Where TipSerCod = &TipSerCod
		Where TipSerEmpCod = &EmpCod
		
		Exit
	When None
		wpEditarTaxas.Link(&TipSerCod, 0)
	EndFor

EndSub


]]></Source>
