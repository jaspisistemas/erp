      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CollectionIsEmpty.Visible = False
	GridGridStateCollections.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	loadWWPContext.Call(&WwpContext)
	If &HTTPRequest.Method = HttpMethod.Get
		
//		&GridStateCollection.FromXml(LoadManageFiltersState(&UserKey))
		do 'getFavoritos'
	EndIf

EndEvent

Event GridGridStateCollections.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&MoveUp = !'<i class="fas fa-arrow-up"></i>'
	
	&MoveDown = !'<i class="fas fa-arrow-down"></i>'
	
	&UDelete = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	If &UserKey.ToLower() = !"appbookmarks"
		GridStateCollection__Title.Title = "Favorito"
		Form.Caption = "Gerenciador de Favoritos"
	Else
		GridStateCollection__GridStateXML.Visible = false
		GridStateCollection__Title.Class = ThemeClass:AttributeRealWidth
	EndIf

EndEvent

Event Enter

	&IsOK = True
	For &GridStateCollectionItem in &GridStateCollection
		If &GridStateCollectionItem.Title.IsEmpty()
			msg('Favorito não pode ter Titulo vazio!')
			&IsOK = False
			Exit
		EndIf
	EndFor

	If &IsOK = true
		
		For Each Order EmpCod, PesCod, FavOrd, FavRotAutNom
			Where EmpCod = &wwpContext.EmpCod
			Where PesCod = &wwpContext.PesCod
			Where FavWebSmart = 'W' or FavWebSmart.IsNull() or FavWebSmart.IsEmpty()
			
			GravaFavorito.Call('DEL', &WwpContext.EmpCod, &WwpContext.PesCod, FavRotAutCod, FavRotAutNom, 0, &mensagem)
		EndFor
	
		&Orderm = 0
		For &GridStateCollectionItem in &GridStateCollection
			&Ordem += 1
			GravaFavorito.Call('ADD', &WwpContext.EmpCod, &WwpContext.PesCod, &GridStateCollectionItem.GridStateXML, Substr(&GridStateCollectionItem.Title, 1, 40), &Ordem, &mensagem)
			NovoLateralGx15.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &wwpContext.Old_Perfil)
			GlobalEvents.Master_RefreshHeader()
		EndFor
	
		Return
	EndIf

EndEvent

Event &MoveUp.Click

	&i = &GridStateCollection.IndexOf(&GridStateCollection.CurrentItem)
	If &i > 1
		&GridStateCollectionItem = &GridStateCollection.Item(&i)
		&GridStateCollection.Remove(&i)
		&GridStateCollection.Add(&GridStateCollectionItem, &i - 1)
	EndIf

EndEvent

Event &MoveDown.Click

	&i = &GridStateCollection.IndexOf(&GridStateCollection.CurrentItem)
	If &i < &GridStateCollection.Count
		&GridStateCollectionItem = &GridStateCollection.Item(&i)
		&GridStateCollection.Remove(&i)
		&GridStateCollection.Add(&GridStateCollectionItem, &i + 1)
	EndIf

EndEvent

Event &UDelete.Click

	&i = &GridStateCollection.IndexOf(&GridStateCollection.CurrentItem)
	&GridStateCollection.Remove(&i)
  	if &GridStateCollection.Count = 0
		&CollectionIsEmpty = true
	endif

EndEvent

Sub 'GetFavoritos'

	For Each Order EmpCod, PesCod, FavOrd, FavRotAutNom
		Where EmpCod = &wwpContext.EmpCod
		Where PesCod = &wwpContext.PesCod
		Where FavWebSmart = 'W' or FavWebSmart.IsNull() or FavWebSmart.IsEmpty()
	
		&GridStateCollectionItem = new()
		&GridStateCollectionItem.Title = FavRotAutNom
		&GridStateCollectionItem.GridStateXML = FavRotAutCod
		&GridStateCollection.Add(&GridStateCollectionItem)
	EndFor

EndSub


]]></Source>
