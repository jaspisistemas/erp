gamentosFolhaContas" fieldSpecifier="item(0).FPagCtaMovItmCod" titleExp="Mov.Itm" class="AttributeRealWidth" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;ColumnClass&lt;/Name&gt;&lt;Value&gt;WWColumn&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ColReadOnly&lt;/Name&gt;&lt;Value&gt;True&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ColVisible&lt;/Name&gt;&lt;Value&gt;False&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></simplegrid></cell></row><row><cell><action controlName="BtnAddContaPagamento" onClickEvent="'DoAddContaPagamento'" caption="[Adicionar Conta Pagamento]" class="btn-block" /></cell></row><row><cell cellClass="CellMarginTop"><table controlName="UnnamedTable3" class="" tableType="Responsive" responsiveSizes="[]"><row><cell><table controlName="TableMergedUnnamedTable4" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><table controlName="UnnamedTable4" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;TotalLancamento" labelCaption="Total a Pagar" readonly="True" class="ReadonlyAttribute" /></cell></row></table></cell><cell><table controlName="UnnamedTable5" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;TotalPagamento" labelCaption="Total Pagamentos" readonly="True" class="ReadonlyAttribute" /></cell></row></table></cell><cell><table controlName="UnnamedTable6" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;Diferenca" labelCaption="Diferença" readonly="True" class="ReadonlyAttribute" /></cell></row></table></cell></row></table></cell></row></table></cell></row></table></cell></row></table></group></cell></row></table></cell></row><row><cell cellClass="CellMarginTop"><table controlName="TableMergedBtnEnter" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><action controlName="BtnEnter" onClickEvent="Enter" caption="GX_BtnEnter" class="Button" /></cell><cell cellClass="DataContentCell"><action controlName="BtnCancelar" onClickEvent="'DoCancelar'" caption="Cancelar" class="btn-block" /></cell></row></table></cell></row></table></cell></row></table></cell></row><row><cell><html controlName="Html_BottomAuxiliarControls" formId="2" /></cell></row></table></layout></detail></Form><Form id="2" type="html"><BODY><gxAttribute AttID="&amp;EmpCod" /><gxAttribute AttID="&amp;OqueFazer" /></BODY></Form></GxMultiForm>]]></Source>
