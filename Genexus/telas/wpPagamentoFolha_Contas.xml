      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&FPagCod = &parFPagCod
	
	loadwwPContext.Call(&wwpContext)
	DpContaBancariaNomeFilial_EmpCod.Call(&wwpContext.EmpCod, &wwpContext.PesCod, 0, &sdtContaBancaria)
	&FPagCtaBanCod.Clear()
	sdtPagamentosFolhaContas__FPagCtaBanCod.Clear()
	For &sdtContaBancariaItem in &sdtContaBancaria
		&FPagCtaBanCod.AddItem(&sdtContaBancariaItem.CtabanCod, &sdtContaBancariaItem.CtaBanCodNom )
		sdtPagamentosFolhaContas__FPagCtaBanCod.AddItem(&sdtContaBancariaItem.CtabanCod, &sdtContaBancariaItem.CtaBanCodNom )
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 320
	UnnamedTable6.Width = 110
	UnnamedTable5.Width = 110
	UnnamedTable4.Width = 110
	&EmpCod.Visible = False
	&OqueFazer.Visible = False
	GridsdtPagamentosFolhaContass.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'loadLancamento'

EndEvent

Event GridsdtPagamentosFolhaContass.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserDeletaPagamento = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	sdtPagamentosFolhaContas__FPagCtaBanCod.Clear()
	For &sdtContaBancariaItem in &sdtContaBancaria
		sdtPagamentosFolhaContas__FPagCtaBanCod.AddItem(&sdtContaBancariaItem.CtabanCod, &sdtContaBancariaItem.CtaBanCodNom )
	EndFor

EndEvent

Event Enter

	&IsErroContas = false
	if &IsPagamentoMultiplo = false
		&TotalPagamento = &TotalLancamento
		&Diferenca = 0
		&sdtPagamentosFolhaContas.Clear()
		&sdtPagamentosFolhaContasItem = new()
		&sdtPagamentosFolhaContasItem.FPagCtaTip = &FPagCtaTip
		&sdtPagamentosFolhaContasItem.FPagCtaBanCod = &FPagCtaBanCod
		&sdtPagamentosFolhaContasItem.FPagCtaVlr = &TotalLancamento
		&sdtPagamentosFolhaContasItem.FPagCtaNroDoc = &FPagCtaNroDoc
		&sdtPagamentosFolhaContas.Add(&sdtPagamentosFolhaContasItem)
		
		Do CAse
			Case &FPagCtaNroDoc.IsEmpty() and &FPagCtaTip = TipoFolha.ChequePropio
				&FPagCtaNroDoc.SetFocus()
				Msg('Pagamento do tipo Cheque deve informar o número do documento/cheque')
				&IsErroContas = true
		EndCAse
	Else
		For &sdtPagamentosFolhaContasItem in &sdtPagamentosFolhaContas
			Do CAse
				CAse &sdtPagamentosFolhaContasItem.FPagCtaVlr <= 0
					msg('Informado pagamento Múltiplo e possui contas sem valor informado!')
					&IsErroContas = true
					Exit
				Case &sdtPagamentosFolhaContasItem.FPagCtaNroDoc.IsEmpty() and &sdtPagamentosFolhaContasItem.FPagCtaTip = TipoFolha.ChequePropio
					Msg('Você deve informar o Número do Documento do CHEQUE.')
					&IsErroContas = true
					Exit
			EndCAse
		EndFor
	Endif
	
	do 'validaItensFolha'
	prcValidaPAgamentoAdiantamentos.Call(&EmpCod, &FPagCod, &sdtPagamentoFolhaAdiantamentos,&IsErroAdiantamentos, &MensagemAdiantamentos)
	
	&IsGravoutudo = false
	Do CAse
		CAse &TotalLancamento < 0
			Msg('Atenção Total dos lançamentos não pode ser negativo.')
			
		Case &IsErroItensFolha = true or &IsErroContas = true
			//parou o processo
			
		case &IsErroAdiantamentos= true
			msg(&MensagemAdiantamentos)
			
		case &sdtItensFolha.Count = 0
			msg('ATENÇÃO! Necessário ter no mínimo um item para efetuar o lançamento!')
			
		CAse &TotalLancamento <> &TotalPagamento
			msg('Total de Lançamentos a Pagar diferente do total de Pagamentos informados!')
			
		CAse &FPagPesCod.IsEmpty()
			msg('Favor informar pessoa a receber a diária!')
			
		CAse &IsPagamentoMultiplo = true and &sdtPagamentosFolhaContas.Count = 1
			msg('Selecionado opção pagamento múltiplo e não informado mais de uma conta, favor alterar para pagamento Único!')
			
		CAse &FPagSts = Status_Folha.Aberto
		
			prcGravaPagamentoFolha.Call(&EmpCod, &FPagCod, TipoPagamentoFolha.PagamentoDiarias, &FPagPesCod, &FPagAno, &FPagMes, false, &FPagCod)
			prcGravaPagamentoFolhaItem.call(&EmpCod, &FPagCod, &sdtItensFolha, &sdtPagamentosFolhaContas, &sdtPagamentoFolhaAdiantamentos)
			return
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoPagamentoMultiplo'

	&FPagCtaNroDoc = &FPagCtaNroDoc.Trim()
	&IsPagamentoMultiplo = true
	
	&sdtPagamentosFolhaContas.Clear()
	
	&sdtPagamentosFolhaContasItem = new()
	&sdtPagamentosFolhaContasItem.FPagCtaBanCod = &FPagCtaBanCod
	&sdtPagamentosFolhaContasItem.FPagCtaNroDoc = &FPagCtaNroDoc.Trim()
	&sdtPagamentosFolhaContasItem.FPagCtaTip = &FPagCtaTip
	&sdtPagamentosFolhaContas.Add(&sdtPagamentosFolhaContasItem)
	&sdtPagamentosFolhaContasItem = new()
	&sdtPagamentosFolhaContasItem.FPagCtaBanCod = &FPagCtaBanCod
	&sdtPagamentosFolhaContasItem.FPagCtaNroDoc = &FPagCtaNroDoc.Trim()
	&sdtPagamentosFolhaContasItem.FPagCtaTip = &FPagCtaTip
	&sdtPagamentosFolhaContas.Add(&sdtPagamentosFolhaContasItem)
	
	do 'tipopagamento'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoPagamentoUnico'

	&IsPagamentoMultiplo = false
	
	for &sdtPagamentosFolhaContasItem in &sdtPagamentosFolhaContas
		&FPagCtaBanCod = &sdtPagamentosFolhaContasItem.FPagCtaBanCod
		&FPagCtaNroDoc = &sdtPagamentosFolhaContasItem.FPagCtaNroDoc.Trim()
		&FPagCtaTip = &sdtPagamentosFolhaContasItem.FPagCtaTip
		Exit
	EndFor
	&sdtPagamentosFolhaContas.Clear()
	
	do 'tipopagamento'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAddContaPagamento'

	&sdtPagamentosFolhaContasItem = new()
	&sdtPagamentosFolhaContasItem.FPagCtaBanCod = &FPagCtaBanCod
	&sdtPagamentosFolhaContasItem.FPagCtaNroDoc = &FPagCtaNroDoc
	&sdtPagamentosFolhaContasItem.FPagCtaTip = &FPagCtaTip
	&sdtPagamentosFolhaContas.Add(&sdtPagamentosFolhaContasItem)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event sdtPagamentosFolhaContas__FPagCtaVlr.IsValid

	do 'totalizaPagamentos'

EndEvent

Event &UserDeletaPagamento.Click

	for &sdtPagamentosFolhaContasItem in &sdtPagamentosFolhaContas
		if &sdtPagamentosFolhaContasItem.FPagCtaCod = &sdtPagamentosFolhaContas.CurrentItem.FPagCtaCod
			&Index = &sdtPagamentosFolhaContas.IndexOf(&sdtPagamentosFolhaContas.CurrentItem)
			&sdtPagamentosFolhaContas.Remove(&Index)
			Exit
		Endif
	EndFor
	do 'totalizaPagamentos'

EndEvent

Sub 'totalizaPagamentos'

	&TotalPagamento  = 0
	For &sdtPagamentosFolhaContasItem in &sdtPagamentosFolhaContas
		//JDF a gambiarra abaixo tem que deixar pois nao somava certo fazendo a funcao abaixo
		//&TotalPagamento += &sdtPagamentosFolhaContasItem.FPagCtaVlr
		&Varchar = str(&sdtPagamentosFolhaContasItem.FPagCtaVlr,18,2)
		&moeda.FromString(&Varchar)
		&TotalPagamento += &moeda
		
	EndFor
	
	&Diferenca = &TotalLancamento - &TotalPagamento

EndSub

Sub 'tipopagamento'

	if &IsPagamentoMultiplo = true
		tbPagamentoMultiplo.Visible= 1
		btnPagamentoMultiplo.Visible = 0
		tbUnico.Visible = 0
		btnPagamentoUnico.Visible = 1
	Else
		tbUnico.Visible = 1
		btnPagamentoMultiplo.Visible = 1
		btnPagamentoUnico.Visible = 0
		tbPagamentoMultiplo.Visible= 0
	Endif

EndSub

Sub 'loadLancamento'

	For Each ORder EmpCod, FPagCod
		Where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		
		&FPagSts = FPagSts
		
		&FPagPesCod = FPagPesCod
		do 'getFuncionario'
		
		&FPagAno = FPagAno
		&FPagMes = FPagMes 
		
		Exit			
	EndFor
	
	do 'carregaAdiantamentos'
	do 'carregaSDT'
	do 'carregaSDTpagamentos'
	do 'tipopagamento'
	&Diferenca= &TotalLancamento - &TotalPagamento

EndSub

Sub 'carregaSDTpagamentos'

	&TotalPagamento = 0
	For Each ORder EmpCod, FPagCod, FPagCtaCod
		Where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		
		&sdtPagamentosFolhaContasItem = new()
		&sdtPagamentosFolhaContasItem.FPagCtaCod = FPagCtaCod
		&sdtPagamentosFolhaContasItem.FPagCtaBanCod = FPagCtaBanCod
		&sdtPagamentosFolhaContasItem.FPagCtaMovCod = FPagCtaMovCod
		&sdtPagamentosFolhaContasItem.FPagCtaMovItmCod = FPagCtaMovItmCod
		&sdtPagamentosFolhaContasItem.FPagCtaNroDoc = FPagCtaNroDoc
		&sdtPagamentosFolhaContasItem.FPagCtaTip = FPagCtaTip
		&sdtPagamentosFolhaContasItem.FPagCtaVlr = FPagCtaVlr
		&TotalPagamento += FPagCtaVlr
		&sdtPagamentosFolhaContas.Add(&sdtPagamentosFolhaContasItem)
	EndFor
	
	&IsPagamentoMultiplo = &sdtPagamentosFolhaContas.Count > 1
	
	if &sdtPagamentosFolhaContas.Count = 1
		for &sdtPagamentosFolhaContasItem in &sdtPagamentosFolhaContas
			&FPagCtaBanCod = &sdtPagamentosFolhaContasItem.FPagCtaBanCod
			&FPagCtaNroDoc = &sdtPagamentosFolhaContasItem.FPagCtaNroDoc
			&FPagCtaTip = &sdtPagamentosFolhaContasItem.FPagCtaTip
		EndFor	
		&TotalPagamento = &TotalLancamento
	Endif

EndSub

Sub 'carregaAdiantamentos'

	&sdtPagamentoFolhaAdiantamentos.Clear()
	&TotalAdiantamentos = 0
	For Each Order EmpCod, FPagCod, FPagAdiMovCod,FPagAdiMovItmCod
		where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		
		&TotalAdiantamentos += FPagAdiMovVlr
		
		&sdtPagamentoFolhaAdiantamentosItem = new()
		&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovCod = FPagAdiMovCod
		&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovItmCod = FPagAdiMovItmCod
		&sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovVlr = FPagAdiMovVlr
		&sdtPagamentoFolhaAdiantamentos.Add(&sdtPagamentoFolhaAdiantamentosItem)
	EndFor

EndSub

Sub 'carregaSDT'

	&TotalLancamento = 0
	&sdtItensFolha.Clear()
	
	For Each Order EmpCod, FPagCod, FPagLcfCod
		Where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		
		&sdtItensFolhaItem = new()
		&sdtItensFolhaItem.FPagLcfCod = FPagLcfCod
		&sdtItensFolhaItem.FPagGerTip = FPagGerTip
		&sdtItensFolhaItem.FPagItemCpl = FPagItemCpl
		&sdtItensFolhaItem.FPagItemVlr = FPagItemVlr
		
		&FPagLcfCod = FPagLcfCod
		&PlanCod = 0
		do 'getOperacoesFolha'
		
		&sdtItensFolhaitem.PlanCod = &PlanCod
		if &LcfCreDeb = 'C'
			&sdtItensFolhaItem.PlanNom = 'Crédito ('+&PlanNom.Trim() + ')'
		Else
			&sdtItensFolhaItem.PlanNom = 'Débito'
		Endif
		
		&sdtItensFolhaItem.LcfNom = &LcfNom
		if not FPagItemCpl.IsEmpty()
			&sdtItensFolhaItem.LcfNom += '(' + FPagItemCpl.Trim() + ')'
		Endif	
		&sdtItensFolhaItem.LcfCreDeb = &LcfCreDeb		
		&sdtItensFolha.Add(&sdtItensFolhaItem)
		
		//Credito ou Debito
		if &LcfCreDeb = 'C'
			&TotalLancamento += FPagItemVlr
		Else
			&TotalLancamento -= FPagItemVlr
		Endif
	EndFor

EndSub

Sub 'getOperacoesFolha'

	For Each ORder EmpCod, LcfCod
		Where EmpCod = &EmpCod
		Where LcfCod = &FPagLcfCod
		
		&LcfNom = LcfNom
		&LcfCreDeb = LcfCreDeb
		
		Do CAse
//			CAse (LcfPlanCod.IsEmpty() or LcfPlanCod.IsNull()) and LcfCreDeb = 'C'
//				prcRetornaPrimeiroPlanoContasOperacoesFolha.Call(&EmpCod, &PlanCod, &PlanNom)
			Case LcfCreDeb = 'C'
				&PlanCod = LcfPlanCod
				do 'getPlanoContas'
			Otherwise
				&PlanCod = 0
				&PlanNom = ''
		EndCAse	
		
		do 'getSdtItens'
		
		Exit
	EndFor

EndSub

Sub 'getPlanoContas'

	For Each ORder EmpCod, PlanCod
		Where EmpCod = &EmpCod
		Where PlanCod = &PlanCod
		&PlanNom = PlanHie.Trim() + ' - ' + PlanNom.Trim()
		Exit
	When none
		&PlanNom = 'NÃO DEFINIDO'
	EndFor

EndSub

Sub 'getSdtItens'

	For &sdtItensFolhaItem in &sdtItensFolha
		if &sdtItensFolhaItem.FPagLcfCod = &FPagLcfCod
			&FPagItemCpl = &sdtItensFolhaItem.FPagItemCpl
			&FPagItemVlr = &sdtItensFolhaItem.FPagItemVlr
			Exit
		EndIf
	EndFor

EndSub

Sub 'getFuncionario'

	&IsErroPessoa= false
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &FPagPesCod
	
		&FPagPesRaz = PesRaz	
	
		Exit
	When none
		&IsErroPessoa= true
		if &FPagPesCod <> 0			
			msg('Esta pessoa não foi localizada!')
		EndIf
	EndFor

EndSub

Sub 'validaItensFolha'

	&IsErroItensFolha = false
	For &sdtItensFolhaItem in &sdtItensFolha
		Do CAse
			CAse &sdtItensFolhaItem.PlanCod.IsEmpty() and &sdtItensFolhaItem.LcfCreDeb = 'C'
				Msg('Existe um erro na operação: '+&sdtItensFolhaItem.FPagLcfCod.ToString() +', as operações do tipo Crédito precisam conter plano de contas!')
				&IsErroItensFolha = true
				exit
			Case &sdtItensFolhaItem.FPagItemVlr <= 0
				Msg('Existe um erro na operação: '+&sdtItensFolhaItem.FPagLcfCod.ToString() +', Valor informado não pode ser menor ou igual a zero!')
				&IsErroItensFolha = true
				exit
		EndCAse
	
	EndFor

EndSub


