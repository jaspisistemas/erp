      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	Do 'AttributesSecurityCode'
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount	 = Grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar = !'<i class="fas fa-times"></i>'
	If (&OpeSts = Status_Ciot.Digitando)
		&Deletar.Class = !'Attribute'
	Else
		&Deletar.Class = !'Invisible'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult AND not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WPOperacaoTransporte(!'Pgto', !'Obter', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		
		Do 'SaveVariablesToWizardData'
		prcNovoEFrete_Login.Call(&Token, &ProtocoloServico, &StatusLogin)
		If &StatusLogin = 200
			Do 'GravarProprietario'
		Else
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &StatusLogin.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
		EndIf
		If &StatusLogin = 200
			prcNovoEFrete_Logout.Call(&Token, &StatusLogOut)
		Endif
		
	EndIf

EndEvent

Event 'WizardPrevious'

	if  1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	WPOperacaoTransporte(!'Pgto', !'Impostos', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		WPOperacaoTransporte(!'Pgto', !'Impostos', false)
	EndIf

EndEvent

Event &Deletar.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Deletar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_Deletar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Deletar.Result = !'Yes'
		Do 'Do Deletar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAddPgto'

	&QuitacaoQtd = 0
	For Each Line In Grid
		If OpePgtCat = PefServiceCategoriaPagamento.Quitacao
			&QuitacaoQtd	+= 1
			Exit
		EndIf
	EndFor
	
	If 	&QuitacaoQtd >= 1
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'A operação não pode conter mais de um pagamento com a categoria de "QUITAÇÃO".', DVMessageType.error, "", DVMessageBoolean.True,""))
		&OpePgtCat.SetFocus()
	Else
		Do 'CheckRequiredFields'
		Do case
			Case &CheckRequiredFieldsResult = True
				GravaOperacaoTransportePagamento.call('ADD',&EmpCod,&FilCod,&OpeCod,0,&OpePgtBan,&OpePgtConTip,&OpePgtAge,&OpePgtCon,&OpePgtVal, &OpeDtaLib, &OpePgtCat)
				Refresh keep
		EndCase
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (&OpeSts = Status_Ciot.Digitando)
		BtnWizardNext.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

