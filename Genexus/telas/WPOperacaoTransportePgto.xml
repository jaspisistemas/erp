		&IsAvisado = True
	EndIf

EndEvent

Sub 'GravarProprietario'

	prcNovoEFrete_Proprietario.Call(&OpeConCod, &Token, &StatusRet)
	
	If &StatusRet = 200
		&IsProprietario = True
		For Each Order (OpeVeiCod), EmpCod, FilCod, OpeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where OpeCod = &OpeCod
			
			&OpeVeiPla = OpeVeiPla
			Do 'VerificaRNTRC'
			
			If &IsProprietario = False
				Exit
			EndIf
		EndFor
		
		If &IsProprietario = True
			Do 'GravarVeiculos'
		Else
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", 'Operação incompleta por ERRO no Proprietário do Veículo: ' +Trim(&OpeVeiPla) , DVMessageType.error, "", DVMessageBoolean.True,""))
		EndIf
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", 'Operação incompleta por ERRO no Contratado/Transportador.', DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf

EndSub

Sub 'VerificaRNTRC'

	For Each Order EmpCod, VeiCod
		Where EmpCod = &EmpCod
		Where VeiPla = &OpeVeiPla
		
		If VeiProCod <> &OpeConCod
			prcNovoEFrete_Proprietario.Call(VeiProCod, &Token, &StatusRet)
			
			If &StatusRet = 0
				&IsProprietario = False
			EndIf
		EndIf
		Exit
	EndFor

EndSub

Sub 'GravarVeiculos'

	&IsVeiculosOk = True
	For Each Order EmpCod, FilCod, OpeCod, OpeVeiCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where OpeCod = &OpeCod
		
		&AuxVeiPla 	 = OpeVeiPla
		Do 'GetVeiculo'
		
		prcNovoEFrete_Veiculos.Call(&Token, &AuxVeiCod, &StatusRet)
		If &StatusRet = 0
			&IsVeiculosOk = False
		EndIf
		
	EndFor
	
	If &IsVeiculosOk = True
		Do 'GravarMotorista'
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", 'Operação incompleta por ERRO no(os) veículo(os).', DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf

EndSub

Sub 'GravarMotorista'

	prcNovoEFrete_Motorista.Call(&Token, &OpeMotCod, &StatusRet)
	If &StatusRet = 200
		prcNovoEFrete_PEF.Call(&Token, &OpeCod, &StatusRet, &Status)
		If &StatusRet = 200
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", 'Operação cadastrada com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))	
			WPOperacaoTransporte(!'Pgto', !'Obter', false)
		EndIf
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", 'Operação incompleta por ERRO no motorista.', DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf

EndSub

Sub 'GetVeiculo'

	For Each Order EmpCod, VeiCod
		Where EmpCod = &EmpCod
		Where VeiPla = &AuxVeiPla
		
		&AuxVeiCod	 = VeiCod
		
		Exit
	EndFor

EndSub

Sub 'GetOperacao'

	For each order EmpCod, FilCod, OpeCod
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&OpeSts					= OpeSts
		TextCIOTStatus.Caption	= 'CIOT: ' + Trim(OpeNroCiot) + ' ' + UPPER(OpeSts.EnumerationDescription())
		&OpeConCod				= OpeConCod
		&OpeMotCod				= OpeMotCod
		&OpeEmiGra				= OpeEmiGra
		
		Exit
	EndFor

EndSub

Sub 'GetContas'

	&CtabanCod.Clear()
	&CtabanCod.AddItem(0, '(SELECIONAR)')
	For Each Order EmpCod, CtabanCod
		Where EmpCod 	= &EmpCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO 
		Where CtaBanTip = TipoConta.BANCO
		
		&CtabanCod.AddItem(CtabanCod, CtaBanNom)
		
	EndFor

EndSub

Sub 'VerificaConta'

	For Each Order EmpCod, CtabanCod
		Where EmpCod 	= &EmpCod
		Where CtabanCod	= &CtabanCod
		
		&OpePgtBan 		= CtaBanBanCod
		&OpePgtAge		= CtaBanAgeCod
		If CtaBanCrtDig.IsEmpty()
			&OpePgtCon	= CtaBanCrt
		Else
			&OpePgtCon	= CtaBanCrt + '-' + CtaBanCrtDig
		EndIf
		Exit
	When None
		&OpePgtBan.SetEmpty()
		&OpePgtAge.SetEmpty()
		&OpePgtCon.SetEmpty()
	EndFor

EndSub


