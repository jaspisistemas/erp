      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWPESSOAOBSERVACAO', Status_SimNao.Sim, 2, &AutNiv)
	
	loadWWPContext.Call(&Context)
	
	Do Case
		Case &DeOndeVem = 'WWFUNCIONARIO'
			TextBlockTitle.Caption = 'Observações do Funcionário'
			&PesCodRaz.Caption = 'Funcionário'
			
		Case &DeOndeVem = 'WWVENDEDOR'
			TextBlockTitle.Caption = 'Observações do Vendedor'
			&PesCodRaz.Caption = 'Vendedor'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesFunObsCod.Visible = False
	&PesCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadObservacao'

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PesFunObs.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Observação'), DVMessageType.error, &PesFunObs.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = True
		GravaObservacaoPessoa.Call(&EmpCod, &PesCod, &PesFunObsCod, &PesFunObsUsuCod, &PesFunObs)
		wwPessoaObservacao.Link(&DeOndeVem, &EmpCod, &PesCod)
	EndIF

EndEvent

Sub 'loadObservacao'

	&PesFunObsDtaHor = ServerNow()
	&PesFunObsUsuCod = &Context.PesCod
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&PesCodRaz = PesCodRaz
		
		For Each Order EmpCod, PesCod, PesFunObsCod
			Where PesFunObsCod = &PesFunObsCod
			&PesFunObs = PesFunObs
			&PesFunObsDtaHor = PesFunObsDtaHor
			&PesFunObsUsuCod = PesFunObsUsuCod
			Exit
		EndFor
	
		Exit
	When none
		
		
	EndFor

EndSub


]]></Source>
