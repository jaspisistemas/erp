      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	//AVISA DUPLICATA DISPONIVEL
	AvisoDuplicataJASPI.Visible = 0
	AvisoDuplicataJASPI1.Visible = 0 
	retornaAutorizacao.Call('WWDUPLICATAPAGAR', Status_SimNao.Nao, 1, &AutNiv)
	RetornaAutorizacaoAdministrador.Call(&EmpCod, &wwpContext.PesCod, &AutIsAdm)
//	if UPPER(&wwpContext.UserName) = 'SUPORTE.JASPI'
	if &AutNiv > 0 or &AutIsAdm = true or UPPER(&wwpContext.UserName) = 'SUPORTE.JASPI'
		prcAvisoDuplicataJaspi.Call(&EmpCod, &Mensagem, &nivel)
		AvisoDuplicataJASPI.Caption = &Mensagem	
		If &nivel > 0
			//link duplicatas Jaspi
			PadraoUsuario.Call('L', '#VENCIMENTODUPLICATAJASPI#', 1, &EmpCod, &PadObs, &PadDtaMod)
			if not &PadObs.IsEmpty()
				&dupCreDtavct = CtoD(Substr(&PadObs,1,10))
				&Cryptografado = Substr(&PadObs,11,37)
				
				CodigoExternoDuplicata.Call(&Cryptografado, 0, 0, 0, 0, &dupCreDtavct, &Cryptografado)
				&Varchar = 'http://app.jaspi.com.br/areacliente.aspx?' + &Cryptografado.Trim()
				AvisoDuplicataJASPI1.LinkTarget = '_blank'
				AvisoDuplicataJASPI1.Link = &Varchar.Trim()
				AvisoDuplicataJASPI1.Visible = 1
			Endif
		
			Do CAse
				Case &nivel = 3
					AvisoDuplicataJASPI.ForeColor = RGB(170,0,0)
					AvisoDuplicataJASPI.Visible = 1
				Case &nivel = 2
					AvisoDuplicataJASPI.ForeColor = RGB(4,140,28)
					AvisoDuplicataJASPI.Visible = 1				
			EndCase
		
		Endif
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&nivel > 0)
		DVPanel_TableContent_Cell.Class = !'Invisible'
	Else
		DVPanel_TableContent_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
