        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPRESULTADOANUAL', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&MostrarVazio = Status_SimNao.Sim
	&Ano = year(&Today)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtAnalises_Empowerer.GridInternalName = GridSdtAnalises.InternalName
	GridSdtAnalises.Rows = 500
	&GridSdtAnalisesCurrentPage = 1
	&GridSdtAnalisesCurrentPage.Visible = False
	&GridSdtAnalisesPageCount = -1
	GridSdtAnalisesPaginationBar.RowsPerPageSelectedValue = GridSdtAnalises.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridSdtAnalisesPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtAnalises.Load

	For &SdtAnaliseItem in &SdtAnalise
		
		&gridPlanHie = &SdtAnaliseItem.PlanHie
		&PlanCodNom = &SdtAnaliseItem.PlanNom
		&Tipo = &SdtAnaliseItem.PlanCatTip
		Do case
			Case &Tipo = 'C'
				&Tipo = 'CRÉDITO'
			Case &Tipo = 'D'
				&Tipo = 'DÉBITO'
			Otherwise
				&Tipo = ''
		Endcase
	
		&Mes01 = iif(&SdtAnaliseItem.Janeiro <> 0, &SdtAnaliseItem.Janeiro.ToFormattedString(), '')
		&Mes02 = iif(&SdtAnaliseItem.Favereiro <> 0, &SdtAnaliseItem.Favereiro.ToFormattedString(), '')
		&Mes03 = iif(&SdtAnaliseItem.Marco <> 0, &SdtAnaliseItem.Marco.ToFormattedString(), '')
		&Mes04 = iif(&SdtAnaliseItem.Abril <> 0, &SdtAnaliseItem.Abril.ToFormattedString(), '')
		&Mes05 = iif(&SdtAnaliseItem.Maio <> 0, &SdtAnaliseItem.Maio.ToFormattedString(), '')
		&Mes06 = iif(&SdtAnaliseItem.Junho <> 0, &SdtAnaliseItem.Junho.ToFormattedString(), '')
		&Mes07 = iif(&SdtAnaliseItem.Julho <> 0, &SdtAnaliseItem.Julho.ToFormattedString(), '')
		&Mes08 = iif(&SdtAnaliseItem.Agosto <> 0, &SdtAnaliseItem.Agosto.ToFormattedString(), '')
		&Mes09 = iif(&SdtAnaliseItem.Setembro <> 0, &SdtAnaliseItem.Setembro.ToFormattedString(), '')
		&Mes10 = iif(&SdtAnaliseItem.Outubro <> 0, &SdtAnaliseItem.Outubro.ToFormattedString(), '')
		&Mes11 = iif(&SdtAnaliseItem.Novembro <> 0, &SdtAnaliseItem.Novembro.ToFormattedString(), '')
		&Mes12 = iif(&SdtAnaliseItem.Dezembro <> 0, &SdtAnaliseItem.Dezembro.ToFormattedString(), '')
		&Total = iif(&SdtAnaliseItem.TotalAno <> 0, &SdtAnaliseItem.TotalAno.ToFormattedString(), '')
		
		Do cAse
			CAse &SdtAnaliseItem.PlanCodNom = 'TOTAL CRÉDITO'
				&R = 0
				&G = 0 
				&B = 255
				&IsBold = 0
				
			CAse &SdtAnaliseItem.PlanCodNom = 'TOTAL DÉBITO'
				&R = 255
				&G = 0 
				&B = 0
				&IsBold = 0
				
			Case &SdtAnaliseItem.PlanCodNom = 'SALDO DO MÊS'
				&R = 0
				&G = 0 
				&B = 0
				&IsBold = 1
			Otherwise
				&R = 0
				&G = 0 
				&B = 0
				&IsBold = 0
		EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&gridPlanHie.ForeColor = RGB(&R,&G,&B)
		&PlanCodNom.ForeColor = RGB(&R,&G,&B)
		&Tipo.ForeColor = RGB(&R,&G,&B)
		&Mes01.ForeColor = RGB(&R,&G,&B)
		&Mes02.ForeColor = RGB(&R,&G,&B)
		&Mes03.ForeColor = RGB(&R,&G,&B)
		&Mes04.ForeColor = RGB(&R,&G,&B)
		&Mes05.ForeColor = RGB(&R,&G,&B)
		&Mes06.ForeColor = RGB(&R,&G,&B)
		&Mes07.ForeColor = RGB(&R,&G,&B)
		&Mes08.ForeColor = RGB(&R,&G,&B)
		&Mes09.ForeColor = RGB(&R,&G,&B)
		&Mes10.ForeColor = RGB(&R,&G,&B)
		&Mes11.ForeColor = RGB(&R,&G,&B)
		&Mes12.ForeColor = RGB(&R,&G,&B)
		&Total.ForeColor = RGB(&R,&G,&B)
		
		&gridPlanHie.FontBold = &IsBold
		&PlanCodNom.FontBold = &IsBold
		&Tipo.FontBold = &IsBold
		&Mes01.FontBold = &IsBold
		&Mes02.FontBold = &IsBold
		&Mes03.FontBold = &IsBold
		&Mes04.FontBold = &IsBold
		&Mes05.FontBold = &IsBold
		&Mes06.FontBold = &IsBold
		&Mes07.FontBold = &IsBold
		&Mes08.FontBold = &IsBold
		&Mes09.FontBold = &IsBold
		&Mes10.FontBold = &IsBold
		&Mes11.FontBold = &IsBold
		&Mes12.FontBold = &IsBold
		&Total.FontBold = 1
		
		Load
	EndFor

EndEvent

Event GridSdtAnalisesPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSdtAnalisesPaginationBar.SelectedPage = !'Previous'
			&GridSdtAnalisesCurrentPage -= 1
			GridSdtAnalises.PreviousPage()
		Case GridSdtAnalisesPaginationBar.SelectedPage = !'Next'
			&GridSdtAnalisesCurrentPage += 1
			GridSdtAnalises.NextPage()
		Otherwise
			&PageToGo.FromString(GridSdtAnalisesPaginationBar.SelectedPage)
			&GridSdtAnalisesCurrentPage = &PageToGo
			GridSdtAnalises.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtAnalisesPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtAnalises.Rows = GridSdtAnalisesPaginationBar.RowsPerPageSelectedValue
	&GridSdtAnalisesCurrentPage = 1
	GridSdtAnalises.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLancamentos'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWTotaisFinanceiro.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpImprimeTotalFinanceiro.PopUp()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAtualizar'

	Do 	'CarregarDados'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CarregarDados'

	CarregarAnaliseAnualManual.Call(&EmpCod,&FilCod,&Ano,&PlanHie,&MostrarVazio,&SdtAnalise)
	GridSdtAnalises.Refresh()

EndSub


]]></Source>
