      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		&Repository.Load(&Id)
		If &Repository.Success()
			&GUID 						= &Repository.GUID					 	
			&Name 						= &Repository.Name 						
			&NameSpace 					= &Repository.NameSpace 				
			&Description  				= &Repository.Description 				
			&GenerateSessionStatistics	= &Repository.GenerateSessionStatistics		
			&GUID.Enabled 						= False
			&Name.Enabled 						= False
			&NameSpace.Enabled 					= False
			&Description.Enabled 				= False
			&AdministratorUserName.Enabled 		= False
			&AdministratorUserPassword.Enabled 	= False
			&GenerateSessionStatistics.Enabled 	= False
			&ConnectionUserName.Enabled 		= False
			&ConnectionUserPassword.Enabled 	= False
			TblUsersSettings.Visible 			= False
			&UpdateConnectionFile.Visible		= False
			BtnEnter.Caption = "WWP_GAM_Delete"
		Else
			&Errors = &Repository.GetErrors()
			Do 'DisplayErrors'
		EndIf	
	EndIf	
	If &Mode = TrnMode.Insert
		&GenerateSessionStatistics		= GAMGenerateSessionStatistics.Minimum
		&CreateGAMApplication			= True
		&UpdateConnectionFile			= True
		
		//Load Repository List
		&Repositories = GeneXusSecurity.GAM.GetAllRepositories(&RepositoryFilter, &Errors)
		If &Errors.Count = 0
			For &Repo in &Repositories
				&CopyFromRepositoryId.AddItem(0,"WWP_GAM_NoCopying")
				&CopyFromRepositoryId.AddItem(&Repo.Id, &Repo.Id.ToString() + !" - " + &Repo.Name.Trim())
			EndFor
		Else
			Do 'DisplayErrors'
		EndIf
		&CopyFromRepositoryId			= 2
		&CopyRoles						= True
		&AdministratorRoleId 			= 2
		&CopySecurityPolicies			= True
		&CopyApplication				= True
		&CopyFromApplicationId			= 2
		&CopyApplicationRolePermissions	= True	
	Else
		GXUITabsPanel_Tabs.HideTab(2)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&UpdateConnectionFile.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&CopyApplicationRolePermissions Or &CopyRoles Or Not &CopyApplication)
		&AdministratorRoleId.Visible = False
		AdministratorRoleId_Cell.Class = !'Invisible'
	Else
		&AdministratorRoleId.Visible = True
		AdministratorRoleId_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&CopyApplicationRolePermissions Or &CopyRoles Or Not &CopyApplication)
		&CopyFromApplicationId.Visible = False
		CopyFromApplicationId_Cell.Class = !'Invisible'
	Else
		&CopyFromApplicationId.Visible = True
		CopyFromApplicationId_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&Mode = TrnMode.Delete)
		&GUID.Visible = False
		GUID_Cell.Class = !'Invisible'
	Else
		&GUID.Visible = True
		GUID_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&Mode <> TrnMode.Insert And &UseCurrentRepositorAsMasterAuthentication)
		&UseCurrentRepositorAsMasterAuthentication.Visible = False
		UseCurrentRepositorAsMasterAuthentication_Cell.Class = !'Invisible'
	Else
		&UseCurrentRepositorAsMasterAuthentication.Visible = True
		UseCurrentRepositorAsMasterAuthentication_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (Not &UseCurrentRepositorAsMasterAuthentication)
		&Namespace.Visible = False
		Namespace_Cell.Class = !'Invisible'
	Else
		&Namespace.Visible = True
		Namespace_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	&Repository.Load(&Id)
	&isOK = True
	If &Mode = TrnMode.Insert
		// Validate passwords
		If &AdministratorUserPassword.Trim() <> &ConfAdministratorUserPassword.Trim()
			Msg("WWP_GAM_AdminPasswordConfNotMatch")
			&isOK = False
		EndIf
		If &ConnectionUserPassword.Trim() <> &ConfConnectionUserPassword.Trim()
			Msg("WWP_GAM_ConnectionPasswordConfNotMatch")
			&isOK = False
		EndIf
	EndIf
	If &isOK
		Do Case
			Case &Mode = TrnMode.Insert
				&GUID = GUID.NewGuid().ToString()
				&RepositoryCreate.GUID					 	= &GUID 
				&RepositoryCreate.Name 						= &Name 
				&RepositoryCreate.NameSpace 				= &NameSpace 
				&RepositoryCreate.Description 				= &Description 
				&RepositoryCreate.AdministratorUserName 	= &AdministratorUserName 
				&RepositoryCreate.AdministratorUserPassword = &AdministratorUserPassword 
				&RepositoryCreate.AllowOauthAccess 			= &AllowOauthAccess
				&RepositoryCreate.ConnectionUserName 		= &ConnectionUserName 
				&RepositoryCreate.ConnectionUserPassword 	= &ConnectionUserPassword 
				&RepositoryCreate.GenerateSessionStatistics	= &GenerateSessionStatistics
				&RepositoryCreate.GiveAnonymousSession 		= True 
				&RepositoryCreate.AllowOauthAccess			= True
					
				If &UseCurrentRepositorAsMasterAuthentication
					&GAMRepository = GAMRepository.Get()
					&RepositoryCreate.AuthenticationMasterRepositoryId	= &GAMRepository.Id
					&RepositoryCreate.AuthenticationMasterAuthTypeName	= &AuthenticationMasterAuthTypeName
				Endif
				
				&RepositoryCreate.CreateGAMApplication		= &CreateGAMApplication
				
				If not &CopyFromRepositoryId.IsEmpty()
					&RepositoryCreate.CopyFromRepositoryId 			= &CopyFromRepositoryId
					If &CopyRoles
						&RepositoryCreate.CopyRoles					= &CopyRoles
						&RepositoryCreate.AdministratorRoleId		= &AdministratorRoleId
					EndIf
					&RepositoryCreate.CopySecurityPolicies			= &CopySecurityPolicies
				Endif
				
				If &CopyApplication and not &CopyFromApplicationId.IsEmpty()  
					&RepositoryCreate.CopyApplication 				= &CopyApplication
					&RepositoryCreate.CopyFromApplicationId			= &CopyFromApplicationId
					&RepositoryCreate.CopyApplicationRolePermissions= &CopyApplicationRolePermissions
				Endif
				&isOK = GeneXusSecurity.GAM.CreateRepository(&RepositoryCreate, &UpdateConnectionFile, &Errors)
				If &isOK
					Commit
					If &isGAMAdminAccessRepository
						//Enable the gamadmin user to access the new repository
						&RepositoryNew = GAMRepository.GetByGUID(&GUID, &Errors)
						&GAMUser = GAMUser.Get()
						&isOK = GeneXusSecurity.GAM.RepositoryUserEnable(&RepositoryNew.Id, &GAMUser, &AdministratorRoleId, &Errors)
						If &isOK
							Commit
						Endif
					Endif
				Endif
			
			Case &Mode = TrnMode.Delete
				&isOK = GeneXusSecurity.GAM.DeleteRepository(&Repository.GUID, &Errors)
				If &isOK
					Commit
				Endif
		EndCase
	EndIf
	If &isOK
		Return
	Else
		Do 'DisplayErrors'
	Endif

EndEvent

Event &UseCurrentRepositorAsMasterAuthentication.Click

	&GAMRepository = GAMRepository.Get()
	&NameSpace = &GAMRepository.NameSpace
	If &UseCurrentRepositorAsMasterAuthentication
		&NameSpace.Visible						= False
		&AdministratorUserName.Caption			= "WWP_GAM_AdministratorUserNameUserExistCurrentTenant"
		&AdministratorUserPassword.SetEmpty()
		&AdministratorUserPassword.Visible		= False
		&ConfAdministratorUserPassword.SetEmpty()
		&ConfAdministratorUserPassword.Visible	= False
	Else
		&NameSpace.Visible						= True
		&AdministratorUserName.Caption			= "WWP_GAM_AdministratorUserName"
		&AdministratorUserPassword.Visible		= True
		&ConfAdministratorUserPassword.Visible	= True
	Endif
	Do 'AttributesSecurityCode'

EndEvent

Event &CopyApplicationRolePermissions.Click

	If &CopyApplicationRolePermissions
		&CopyRoles					 = True
		&CopyApplication 			 = True
	EndIf
	Do 'AttributesSecurityCode'

EndEvent

Event &CopyRoles.Click

	If Not &CopyRoles	
		&CopyApplicationRolePermissions = False
		&CopyApplication 				= False
	EndIf
	Do 'AttributesSecurityCode'

EndEvent

Event &CopyApplication.Click

	If Not &CopyApplication			
		&CopyApplicationRolePermissions = False
		&CopyRoles 						= False
	EndIf
	Do 'AttributesSecurityCode'

EndEvent

Sub 'DisplayErrors'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


