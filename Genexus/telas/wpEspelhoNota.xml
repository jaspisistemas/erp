      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&PesCod = &Context.PesCod

//	&Istem_MATRICIAL = RetornaTemImpressora.Udp(&Context.EmpCod, domTipoImpressora.MATRICIAL)
	
	&OqueFazer1.Clear()
	&OqueFazer1.AddItem('1', 'PEDIDO/ESPELHO NOTA - SEM LOGOMARCA')
//	&OqueFazer1.AddItem('1A', 'PEDIDO/ESPELHO NOTA - COM LOGOMARCA')
//	&OqueFazer1.AddItem('9', 'PEDIDO/ESPELHO NOTA - MODELO A5')
	&OqueFazer1.AddItem('2', 'ESPELHO NOTA - NF-E MODELO 55')
	
//	If &Istem_MATRICIAL = true
//		&OqueFazer1.AddItem('3A', 'PEDIDO/ESPELHO NOTA - DIRETA MATRICIAL')
//		&EmpImpCod1.Clear()
//		For Each Order EmpCod, EmpImpCod
//			Where EmpCod = &Context.EmpCod
//			where EmpImpTip = domTipoImpressora.MATRICIAL	
//			&Mensagem = EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
//			&EmpImpCod1.AddItem(EmpImpCod,&Mensagem)
//		EndFor
//	Endif

	padraoUsuario.Call('L', 'WPESPELHONOTA', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&OqueFazer1 = trim(Substr(&PadObs,1,5))
		&Ordem1 = Substr(&PadObs, 6,1)
		&DestacarImpostos1 = iif(Substr(&PadObs, 7,1) = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
		&EmpImpCod1 = val(Substr(&PadObs, 8,8))
		&QtdVias1 = val(Substr(&PadObs, 17,8))
	EndIF
	
	padraoUsuario.Call('L', 'WPESPELHONOTA_3', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&FecharAutomaticamente = iif(&PadObs = '0', false, true)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	loadWWPContext.Call(&Context)
	
	&PadObs = padR(trim(&OqueFazer1),5, ' ') + &Ordem1 + trim(&DestacarImpostos1.ToString()) + &EmpImpCod1.ToFormattedString() + &QtdVias1.ToFormattedString()
	padraoUsuario.Submit('', 'G', 'WPESPELHONOTA', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	&OqueFazer = &OqueFazer1
	&Ordem = &Ordem1
	&DestacarImpostos = &DestacarImpostos1
	&EmpImpCod = &EmpImpCod1
	&QtdVias = &QtdVias1
	do 'chamaimpressao'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&OqueFazer1 = '1' or &OqueFazer1 = '1A')
		&DestacarImpostos1.Visible = False
		DestacarImpostos1_Cell.Class = !'Invisible'
	Else
		&DestacarImpostos1.Visible = True
		DestacarImpostos1_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	
	tbus.Visible = (1=2)
	tb1IMpressoras.Visible = (&OqueFazer1 = '3A')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	msg(scaProgressBar1.ProcessId +  !" execution finished.")
	return

EndEvent

Sub 'ChamaImpressao'

	&Varchar = ServerTime()
	If &DestacarImpostos = Status_SimNao.Sim
		&IsIMposto = true
	Else
		&IsIMposto = false
	EndIF
	&PesCod = &Context.PesCod
	
	Do Case
		Case &OqueFazer = '1' //IMPRESSAO CLIENTE SEM LOGO
			&NomeArquivo = 'PedidoVenda' + trim(str(&NfeCod))
			RCOOpenWindow1.LinkOpen = RELJAS126.Link(&EmpCod, &FilCod, &NfeCod, &PesCod, &NomeArquivo, &Ordem, &Varchar, &IsIMposto)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '1A' //IMPRESSAO CLIENTE COM LOGO
			&NomeArquivo = 'PedidoVenda' + trim(str(&NfeCod))
			//			RCOOpenWindow1.LinkOpen = RELJAS078.Link(&EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, &Varchar, &IsIMposto)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '2' //IMPRESSAO SEPARACAO
			
			&NfeArqXml = RetornaXmlNota.udp(&EmpCod, &FilCod, &NfeCod)
			if &NfeArqXml.IsEmpty()
				GeraXmlNFeModelo55_4.Call(&EmpCod, &FilCod, &NfeCod, 'N', &Context.PesCod, 'E', &SolCod)
			EndIF
			
			GeraPdfDanfe.Call(&EmpCod, &FilCod, &NfeCod, &UrlPDF, &UrlFisico)
			
			RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '9' //Pedido para Cliente - Folha A5
			&NomeArquivo = 'PedidoCliente' + trim(str(&NfeCod))
			//			RCOOpenWindow1.LinkOpen = RELJAS081.Link(&DeOndeVem, &EmpCod, &FilCod, &PedCod, &PesCod, &NomeArquivo, &Ordem, &Varchar, 'A5')
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueFazer = '3A' // Pedido Matricial
			//			For &Count = 1 to &QtdVias
			//				prcGravaImpressao.Call(&EmpCod, &EmpImpCod, 'RELJAS124', &FilCod, &PedCod, &Context.PesCod)
			//			EndFor
			//		
			//			&IsReturn = true
	EndCase

	
	if &FecharAutomaticamente  = true
		
		if &IsReturn = true 
			return
		Else
			&Random = Random() * 10000000000
			&ProgressId = 'wpImpPedido' + trim(Str(&Random))
			
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			EsperaSegundos.Submit('', &ProgressId)
		EndIf
	Endif

EndSub


]]></Source>
