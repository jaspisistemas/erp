      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&UltimaCompra   = Status_SimNao.sim	
	&UfCidade       = Status_SimNao.sim
	&SeparaVendedor = Status_SimNao.sim
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	
	retornaAutorizacao.Call('WPVENDASPORVENDEDORES', Status_SimNao.Sim, 1, &AutNiv)
	retornaAutorizacao.Call('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1, &AutNivTel)
	If &AutNivTel = 0 and &Context.PesIsVen = true
		&PedVenCod = &Context.PesCod
		&PedVenCod.Enabled = False
	Else
		&PedVenCod = 0
		&PedVenCod.Enabled= True
	EndIf
	&PedDtaFat = &Today -30
	&PedDtaFat_to = &Today
	&LctAtuEst = Status_EntradaSaida.Saida
	&PedSts = 'F'
	&LctGerFin.SetEmpty()
	&PesSts = 'A'

	Do 'Vendedor'
	Do 'Lancamento'
	Do 'RamoAtividade'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&LctAtuEst.TooltipText = "Atualiza Estoque"
	&PedDtaFat_to.TooltipText = "Caso o status seja igual aberto o filtro será pela data de emissão!"

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoExcel'

	RetornaSoNumeros.Call(ServerTime(),&VarChar)
	if &Context.EmpCod.IsEmpty() or &Context.FilCod.IsEmpty()
		LoadWWPContext.Call(&Context)
	EndIf
	RetornaConfiguracoesPastas.Call(&Context.EmpCod,&Context.FilCod,&sdtConfiguracoesPasta)
	&UrlFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis + 'WPVendasPorVendedores' + &VarChar + '.xlsx'
	&UrlVirtual = &sdtConfiguracoesPasta.PastaDiretorioTempVir + 'WPVendasPorVendedores' + &VarChar + '.xlsx'
	RELJAS112_002.Call(&UrlFisico,&ExcelFilename,&EmpCod, &FilCod,&PedVenCod,&PesCodRaz,&PedSts,&PedDtaFat,&PedDtaFat_to,&LctAtuEst,&LctCod,&LctCodNom,&LctGerFin,&RatCod,&RatCodNom,&PesSts,&GrupHie,&ProTip,&UltimaCompra,&UfCidade,&OrdemCompra,&SeparaVendedor)
	Link(&UrlVirtual)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&lctCod = 0)
		&LctGerFin.Visible = False
		LctGerFin_Cell.Class = !'Invisible'
	Else
		&LctGerFin.Visible = True
		LctGerFin_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&UltimaCompra = Status_SimNao.Sim)
		&OrdemCompra.Visible = False
		OrdemCompra_Cell.Class = !'Invisible'
	Else
		&OrdemCompra.Visible = True
		OrdemCompra_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &LctCod.IsValid

	Do 'Lancamento'

EndEvent

Event &UltimaCompra.Click

	Do 'AttributesSecurityCode'

EndEvent

Event &RatCod.IsValid

	Do 'RamoAtividade'

EndEvent

Event &PedVenCod.IsValid

	Do 'Vendedor'

EndEvent

Event Enter

	RCOOpenWindow1.LinkOpen = RELJAS112.Link(&EmpCod, &FilCod,&PedVenCod,&PesCodRaz,&PedSts,&PedDtaFat,&PedDtaFat_to,&LctAtuEst,&LctCod,&LctCodNom,&LctGerFin,&RatCod,&RatCodNom,&PesSts,&GrupHie,&ProTip,&UltimaCompra,&UfCidade,&OrdemCompra,&SeparaVendedor)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'Lancamento'

	If &LctCod = 0
		&LctNom = 'TODOS OS TIPO DE LANÇAMENTO'
		&LctCodNom = '0 - TODOS OS TIPO DE LANÇAMENTO'
	Else
		For each Order EmpCod,LctCod
			Where EmpCod = &EmpCod
			Where LctCod = &LctCod
			&LctNom = LctNom
			&LctCodNom = LctCodNom
			Exit
		When none
			msg('Tipo de Lançamento não encontrado!')
			&LctNom = 'Tipo de Lançamento não encontrado!'
			&LctCod.SetFocus()
		EndFor
	EndIf

EndSub

Sub 'RamoAtividade'

	If &RatCod = 0
		&RatNom = 'TODOS OS RAMOS ATIVIDADE'
		&RatCodNom = '0 - TODOS OS RAMOS ATIVIDADE'
	Else
		For each Order EmpCod,RatCod
			Where EmpCod = &EmpCod
			Where RatCod = &RatCod
			&RatNom = RatNom
			&RatCodNom = RatCodNom
			Exit
		When none
			msg('Ramo atividade não encontrado')
			&RatNom = 'Ramo atividade não encontrado'
			&RatCod.SetFocus()
		EndFor
	EndIf

EndSub

Sub 'Vendedor'

	If &PedVenCod = 0
		&PedVenRaz = 'TODOS OS VENDEDORES'
		&PesCodRaz = '0 - TODOS OS VENDEDORES'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PedVenCod
			Where PesIsVen = True
			&PedVenRaz = PesRaz
			&PesCodRaz = PesCodRaz
			Exit
		When none
			msg('Vendedor não encontado ou pessoa não é vendedor!')
			&PedVenRaz = 'VENDEDOR NÃO ENCONTRADO'
			&PedVenCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
