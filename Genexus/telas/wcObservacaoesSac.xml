        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Ligacao_Empowerer.GridInternalName = Ligacao.InternalName
	Ligacao.Rows = 5
	&LigacaoCurrentPage = 1
	&LigacaoCurrentPage.Visible = False
	&LigacaoPageCount = -1
	LigacaoPaginationBar.RowsPerPageSelectedValue = Ligacao.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Ligacao.Rows = &QtdLinhas
	
	PesSacDlg.Visible = 0

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&LigacaoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&LigacaoCurrentPage = Ligacao.CurrentPage
	&LigacaoRecordCount = Ligacao.RecordCount
	&LigacaoPageCount = Ligacao.PageCount
	PesSacDlg.Visible = 0

EndEvent

Event Ligacao.Load

	PesSacDlg.Visible = 0
	&PesSacVenCodNom = gxGetMLi(PesSacVenCodNom, 1, 30)
	retornaNomePessoa.Call(EmpCod, PesSacFunCod, &PesRaz)
	&PesSacVenCodNom.Tooltiptext = 'Gravada por: ' + trim(str(PesSacFunCod)) + ' - ' + trim(&PesRaz)
//	if PesSacDlg.Length() > 200
//		&PesSacDlg = gxGetMLi(PesSacDlg, 1, 200) + '...'
//	Else
		&PesSacDlg = PesSacDlg.Trim()
//	endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event LigacaoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case LigacaoPaginationBar.SelectedPage = !'Previous'
			&LigacaoCurrentPage -= 1
			Ligacao.PreviousPage()
		Case LigacaoPaginationBar.SelectedPage = !'Next'
			&LigacaoCurrentPage += 1
			Ligacao.NextPage()
		Otherwise
			&PageToGo.FromString(LigacaoPaginationBar.SelectedPage)
			&LigacaoCurrentPage = &PageToGo
			Ligacao.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event LigacaoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Ligacao.Rows = LigacaoPaginationBar.RowsPerPageSelectedValue
	&LigacaoCurrentPage = 1
	Ligacao.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event PesSacDta.Click

	&webSession.Set('WPVEROBS', &PesSacDlg.Trim())
	wpVerObs.Popup()
	//&PesSacDlg.Enabled = 1

EndEvent


