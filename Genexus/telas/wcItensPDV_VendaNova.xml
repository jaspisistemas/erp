Sub 'carregaInfo'

	&Qtd = 0
	
	For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&Qtd += 1
		
		&ProNom = ProNomGra
		&PedItmCod = PedItmCod
		
	
		////		&gridPedItmCod = PedItmCod
		////		&gridPedQtd =  PedQtd
		////		If PedItmDsc >= 100
		////			&gridProNom = substr(ProNomGra, 1, 30)+' -BRINDE-'
		////		Else
		////			&gridProNom = substr(ProNomGra, 1, 40)
		////		EndIf
		////		
