//		if PedItmPrm <> domPedItmPrm.NORMAL
//			&gridPedVlrItm.ForeColor = RGB(230,45,45)
//		Else
//			&gridPedVlrItm.ForeColor = RGB(0,0,0)
//		EndIF
		
		////	&EliminarItem.FromImage(ActionDelete)
		////	&EliminarItem.TooltipText = "Deletar Item"
		do 'PreencheCampos'
		
		
		if &Qtd >= 5
			Exit
		EndIF
	EndFor

EndSub

Sub 'PreencheCampos'

	do Case
		Case &Qtd = 1
			txtProduto1.Caption = &ProNom
			txtItem1.Caption = trim(str(&PedItmCod))
			txtValorTotal1.Caption = format('R$ %1', trim(toFormattedString(&PedVlrItm)))
			
		Case &Qtd = 2
			txtProduto2.Caption = &ProNom
			txtItem2.Caption = trim(str(&PedItmCod))
			txtValorTotal2.Caption = format('R$ %1', trim(toFormattedString(&PedVlrItm)))
			
		Case &Qtd = 3
			txtProduto3.Caption = &ProNom
			txtItem3.Caption = trim(str(&PedItmCod))
			txtValorTotal3.Caption = format('R$ %1', trim(toFormattedString(&PedVlrItm)))
			
		Case &Qtd = 4
			txtProduto4.Caption = &ProNom
			txtItem4.Caption = trim(str(&PedItmCod))
			txtValorTotal4.Caption = format('R$ %1', trim(toFormattedString(&PedVlrItm)))
			
		Case &Qtd = 5
			txtProduto5.Caption = &ProNom
			txtItem5.Caption = trim(str(&PedItmCod))
			txtValorTotal5.Caption = format('R$ %1', trim(toFormattedString(&PedVlrItm)))
	EndCase

EndSub

Sub 'limpacampos'

	txtProduto1.Caption = ''
	txtProduto2.Caption = ''
	txtProduto3.Caption = ''
	txtProduto4.Caption = ''

EndSub


