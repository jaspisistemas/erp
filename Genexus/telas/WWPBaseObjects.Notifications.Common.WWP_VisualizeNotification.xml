      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 700

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each WWPBaseObjects.Notifications.Common.WWP_Notification
		Where WWPNotificationId = &WWPNotificationId
		
		//Security Code
		If WWPUserExtendedId <> WWP_GetLoggedUserId()
			NotAuthorized(&pgmname)
		Endif
		
		WWPBaseObjects.Notifications.Common.WWP_ChangeNotificationStatus.SetNotificationReadById(WWPNotificationId)
		If Not WWPNotificationLink.IsEmpty()
			If Not WWPNotificationMetadata.IsEmpty()
				&WWPNotificationMetadataSDT.FromJson(WWPNotificationMetadata)
				&WebSession.Set(&WWPNotificationMetadataSDT.SessionKey, &WWPNotificationMetadataSDT.SessionValue)
			EndIf
			Link(WWPNotificationLink)
		EndIf
	EndFor

EndEvent

Event 'DoMarkAsRead'

	WWPBaseObjects.Notifications.Common.WWP_ChangeNotificationStatus.SetNotificationReadUnreadById(&WWPNotificationId)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Load

	If WWPNotificationIsRead
		MarkAsRead.Caption = !'<i class="fas fa-envelope DiscussionsSendIcon"></i>'
		MarkAsRead.TooltipText = "Mark as unread"
	Else
		MarkAsRead.Caption = !'<i class="fas fa-envelope-open DiscussionsSendIcon"></i>'
		MarkAsRead.TooltipText = "Mark as read"
	EndIf

EndEvent


]]></Source>
