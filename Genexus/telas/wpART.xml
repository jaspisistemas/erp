      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&PesArtCod = &parPesArtCod
	
	&sdtart.FromJson(&WebSession.Get(&PESSOAART))
	For &sdtartItem in &sdtart
		If &sdtartItem.PesArtCod = &PesArtCod	
			&PesArtNro = &sdtartItem.PesartNro
			&PesArtUfe = &sdtartItem.PesArtUfe
//			&PesArtSeqIni = &sdtartItem.PesArtSeqIni
//			&PesArtSeqFin = &sdtartItem.PesArtSeqFin
			Exit
		Endif
		
		&UltPesArtCod = &sdtartItem.PesArtCod
	EndFor
	&WebSession.Remove(&PESSOAART)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesArtCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do case
		Case &PesArtNro.IsEmpty()
			msg('Nro da ART obrigatório!')
			&PesArtNro.SetFocus()
		Case &PesArtUfe.IsEmpty()
			msg('UF ART Obrigatório!')
			&PesArtUfe.SetFocus()
		Otherwise
			
			if &PesArtCod > 0
				For &sdtartItem in &sdtart
					If &sdtartItem.PesArtCod = &PesArtCod
						&sdtartItem.PesArtNro = &PesArtNro
						&sdtartItem.PesArtUfe = &PesArtUfe
						&sdtartItem.PesArtSeqIni = &PesArtSeqIni
						&sdtartItem.PesArtSeqFin = &PesArtSeqFin
						&sdtartItem.PesArtSts = Status_SimNao.Sim
						Exit
					Endif
				EndFor
			Else
				&PesArtCod = &UltPesArtCod+1
				&sdtartItem = new()
				&sdtartItem.PesArtCod = &PesArtCod
				&sdtartItem.PesArtNro = &PesArtNro
				&sdtartItem.PesArtUfe = &PesArtUfe
				&sdtartItem.PesArtSeqIni = &PesArtSeqIni
				&sdtartItem.PesArtSeqFin = &PesArtSeqFin
				&sdtartItem.PesArtSts = Status_SimNao.Sim
				&sdtart.Add(&sdtartItem)
			Endif
		
						
			&WebSession.Set(&PESSOAART, &sdtart.ToJson())
			return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
