      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&GAMApplication.Load(&ApplicationId)
	&ApplicationMenu = &GAMApplication.GetMenu(&Id, &Errors)	
	if &Mode <> GAMAPiMode.Insert		
		&Name 		= &ApplicationMenu.Name
		&Dsc		= &ApplicationMenu.Description
		&GUID		= &ApplicationMenu.GUID
		&GUID.Enabled		= False
	endif
	If &Mode = GAMAPiMode.Display
		BtnEnter.Visible 	= False
	Endif
	If &Mode = GAMAPiMode.Display or &Mode = GAMAPiMode.Delete
		&Name.Enabled 		= False
		&Dsc.Enabled		= False				
		BtnEnter.Caption = "Delete"
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&GAMApplication.Load(&ApplicationId)
	If not &Name.IsEmpty()
		Do Case
			Case &Mode = GAMAPiMode.Insert
				&ApplicationMenu.GUID			= &GUID
				&ApplicationMenu.Name			= &Name
				&ApplicationMenu.Description 	= &Dsc
				&isOK = &GAMApplication.AddMenu(&ApplicationMenu, &Errors)		
			Case &Mode = GAMAPiMode.Update
				&ApplicationMenu = &GAMApplication.GetMenu(&Id, &Errors)
				&ApplicationMenu.GUID			= &GUID
				&ApplicationMenu.Name			= &Name
				&ApplicationMenu.Description 	= &Dsc
				&isOK = &GAMApplication.UpdateMenu(&ApplicationMenu, &Errors)		
			Case &Mode = GAMAPiMode.Delete
				&ApplicationMenu = &GAMApplication.GetMenu(&Id, &Errors)
				&isOK = &GAMApplication.DeleteMenu(&ApplicationMenu, &Errors)
		EndCase
	Else
		&isOK = False
		&Error = new()
		&Error.Code 	= GAMErrorMessages.ApplicationMenuOptionNameNull
		&Error.Message	= GAMErrorMessages.EnumerationDescription(&Error.Code)
		&Errors.Add(&Error)		
	Endif
	If &isOK
		Commit
		return
	Else
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor
	Endif

EndEvent


]]></Source>
