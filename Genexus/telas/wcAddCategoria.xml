	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event categoriaMultilojas_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcCategoriasMarkt.Create(&EmpCod, &GrupCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event categoriaMultilojas_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event tableSelecionado.Click

	&QtdLevels = &SelecionadossdtAux.currentItem.level
	do 'selecionaAnterior'

EndEvent

Event gridlayout.Click

	&BuscarVarchar = &sdtMLCategorias.CurrentItem.id
	
	&Selecionadossdtitem = new()
	&Selecionadossdtitem.id = &sdtMLCategorias.CurrentItem.id
	&Selecionadossdtitem.level  = &QtdLevels
	&Selecionadossdtitem.name = &sdtMLCategorias.CurrentItem.name
	&Selecionadossdt.Add(&Selecionadossdtitem)
	
	&SelecionadossdtAux.Clear()
	&SelecionadossdtAux = &Selecionadossdt
	freeStyleGrid2.Refresh()
	
	&QtdLevels += 1

	do 'getcategoriaItem'
	if &sdtcategoriasMLItemAux.children_categories.Count > 0		
		
		&sdtMLCategorias.Clear()
		for &sdtcategoriasMLItemAuxItem in &sdtcategoriasMLItemAux.children_categories
			&sdtMLCategoriasItem = new()
			&sdtMLCategoriasItem.id = &sdtcategoriasMLItemAuxItem.id
			&sdtMLCategoriasItem.name = &sdtcategoriasMLItemAuxItem.name
			&sdtMLCategoriasItem.level = &QtdLevels
			&sdtMLCategorias.Add(&sdtMLCategoriasItem)
		Endfor
	
		FreeStyleGrid1.Refresh()
	Else
		tbFreeStyleGrid1.Visible = 0
		&GrupMrkCatSku = &BuscarVarchar
		&GrupMrkCatSkuNome = &sdtMLCategorias.CurrentItem.name
		do 'Sucesso'
	Endif

EndEvent

Sub 'selecionaAnterior'

	For &CollLongVarcharItem in &CollLongVarchar
		if &CollLongVarcharItem.level > &QtdLevels
			&index = &CollLongVarchar.IndexOf(&CollLongVarcharItem)
			&CollLongVarchar.Remove(&index)			
		Endif
		
		if &CollLongVarcharItem.level = &QtdLevels
			if &QtdLevels = 1
				&sdtMLCategorias.FromJson(&CollLongVarcharItem.LongVarchar)
			Else
				&sdtcategoriasMLItemAux.FromJson(&CollLongVarcharItem.LongVarchar)
				&sdtMLCategorias.Clear()
				for &sdtcategoriasMLItemAuxItem in &sdtcategoriasMLItemAux.children_categories
					&sdtMLCategoriasItem = new()
					&sdtMLCategoriasItem.id = &sdtcategoriasMLItemAuxItem.id
					&sdtMLCategoriasItem.name = &sdtcategoriasMLItemAuxItem.name
					&sdtMLCategorias.Add(&sdtMLCategoriasItem)
				Endfor
			Endif
		EndIf
	EndFor
	
	&SelecionadossdtAux.Clear()
	For &Selecionadossdtitem in &Selecionadossdt
		if &Selecionadossdtitem.level < &QtdLevels
			&SelecionadossdtAuxItem = new()
			&SelecionadossdtAuxItem.id = &Selecionadossdtitem.id
			&SelecionadossdtAuxItem.name = &Selecionadossdtitem.name
			&SelecionadossdtAuxItem.level = &Selecionadossdtitem.level
			&SelecionadossdtAux.Add(&SelecionadossdtAuxItem)
		Endif
	EndFor
	&Selecionadossdt = &SelecionadossdtAux
	
	tbFreeStyleGrid1.Visible = 1
	freeStyleGrid1.Refresh()
	freeStyleGrid2.Refresh()
	Sucesso.Visible = 0

EndSub

Sub 'Sucesso'

	Sucesso.Visible = 1
	&Mensagem = ''
	for &Selecionadossdtitem in &Selecionadossdt
		if not &Mensagem.IsEmpty()
			&Mensagem += ' > '
		Endif
		&Mensagem += &Selecionadossdtitem.name
	EndFor
	Hierarquiacompleta.Caption = &Mensagem
	txtGrupoSelecionado.Caption = &GrupMrkCatSkuNome

EndSub

Sub 'buscarcategorias'

	&BuscarVarchar = ''
	do 'getcategoria'
	if &sdtMLCategorias.Count > 0
		btnUserAction1.Visible = 0
		sucesso.Visible = 0
		tbFreeStyleGrid1.Visible = 1
		FreeStyleGrid2.Visible = 1
	Endif

EndSub

Sub 'getcategoria'

	&sdtMLCategorias.Clear()
	prcCategoriasML.Call(&EmpCod, &BuscarVarchar, &LongVarchar)
	&sdtMLCategorias.FromJson(&LongVarchar)
	&sdtMLCategoriasItem = new()
	&sdtMLCategoriasItem.level = &QtdLevels
	&sdtMLCategoriasItem.LongVarchar = &LongVarchar
	&CollLongVarchar.Add(&sdtMLCategoriasItem)

EndSub

Sub 'getcategoriaItem'

	prcCategoriasML.Call(&EmpCod, &BuscarVarchar, &LongVarchar)
	&sdtcategoriasMLItemAux.FromJson(&LongVarchar)
	&sdtMLCategoriasItem = new()
	&sdtMLCategoriasItem.level = &QtdLevels
	&sdtMLCategoriasItem.LongVarchar = &LongVarchar
	&CollLongVarchar.Add(&sdtMLCategoriasItem)

EndSub


