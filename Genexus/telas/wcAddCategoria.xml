Event Start

	loadWWPContext.Call(&wwpContext)
	&QtdLevels = 1 
	&CollLongVarchar.Clear()
	&Selecionadossdt.Clear()
	
	For Each Order EmpCod, GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &GrupCod
		txtNomeGrupo.Caption = 'Grupo Sistema: ' + trim(GrupNomCmp)
		Exit
	endFor
	
	&imagemMarketplace.FromImage(mercadoLivre)
	&BuscarVarchar = '' 
	Sucesso.Visible = 0
	
	do 'buscarcategorias'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	combos.Width = 440
	gridlayout.Width = 410
	FreeStyleGrid1.Rows = 10
	sdtMLCategorias__id.Visible = False
	sdtMLCategorias__picture.Visible = False
	sdtMLCategorias__permalink.Visible = False
	sdtMLCategorias__level.Visible = False
