      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	PadraoUsuarioHora.Call('L', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	&IsTrazerComPreco = iif(Substr(&PadObs,1,1) = '0', false, true)
	&SeleiconarCarregar = iif(Substr(&PadObs,2,1) = '0', false, true)
	
	txtMsg.Caption = ''
	&CotCOmItmCod = &parCotCOmItmCod
	do 'loadItem'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	CotComProForVlrFin.ForeColor = rgb(0,0,0)
	If CotComProForCod = &MenorCotComProForCod
		CotComProForVlrFin.ForeColor = rgb(2, 115, 253)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionSelecione.FromImage(DDOMultiselSelOption)
	&ActionSelecione.TooltipText = ""
	
	&UserObs = !'<i class="fas fa-comment"></i>'
	If (not CotComProForObs.IsEmpty() and not CotComProForObs.IsNull())
		&UserObs.Class = !'Attribute'
	Else
		&UserObs.Class = !'Invisible'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&UserObs.TooltipText = CotComProForObs
	if CotComProForCod <> CotComProSelForCod
		&ActionSelecione.FromImage(DDOMultiselOption)
	Endif

EndEvent

Event 'DoUserNenhum'

	prcSetaFornecedorPadrao.Call(&EmpCod, &CotComCod, &CotComItmCod, 0)
	txtMsg.Caption = format('Produto: %1, confirmado fornecedor: %2' , trim(&CotComProNom), 'Nenhum selecionado')
	txtMsg.ForeColor = rgb(255, 0, 0)
	if &SeleiconarCarregar = true
		&AuxCotComItmCod = &CotComItmCod
		do 'getProximoRegistro'
	Endif
	grid1.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserSair'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAnterior'

	&AuxCotComItmCod = &CotComItmCod
	do 'getRegistroAnterior'
	grid1.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserProximo'

	&AuxCotComItmCod = &CotComItmCod
	do 'getProximoRegistro'
	grid1.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &SeleiconarCarregar.Click

	do 'GravarPadrao'

EndEvent

Event &IsTrazerComPreco.Click

	do 'GravarPadrao'

EndEvent

Event &ActionSelecione.Click

	prcSetaFornecedorPadrao.Call(EmpCod, CotComCod, CotComItmCod, CotComProForCod)
	txtMsg.Caption = format('Produto: %1, confirmado fornecedor: %2 - %3' , trim(&CotComProNom), trim(str(CotComProForCod)), trim(CotComProForRaz))
	txtMsg.ForeColor = rgb(0, 92, 255)
	if &SeleiconarCarregar = true
		&AuxCotComItmCod = &CotComItmCod
		do 'getProximoRegistro'
	Endif
	grid1.Refresh()

EndEvent

Sub 'GravarPadrao'

	&PadObs = iif(&IsTrazerComPreco = false, '0', '1')
	&PadObs += iif(&SeleiconarCarregar = false, '0', '1')
	PadraoUsuarioHora.Call('G', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')

EndSub

Sub 'loadItem'

	For Each Order EmpCod, CotComCod, CotComItmCod
		where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod = &CotComItmCod
		
		&CotComProRef = CotComProRef
		&CotComProNom = CotComProNom
		&MenorCotComProForCod = CotComProMenForCod
		
		Exit
	EndFor

EndSub

Sub 'getProximoRegistro'

	&IsTem = false
	For Each Order EmpCod, CotComCod, CotComItmCod
		where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod > &AuxCotComItmCod
	
		if &IsTrazerComPreco = true
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				where CotComProForSts = StatusProdutoCotado.COTADO
				&IsTem = true
				Exit
			When None
				&IsTem = false
			EndFor
			
			if &IsTem = true				
				&CotCOmItmCod = CotComItmCod
				&CotComProRef = CotComProRef
				&CotComProNom = CotComProNom
				&MenorCotComProForCod = CotComProMenForCod
				Exit
			Endif
		Else
			&CotCOmItmCod = CotComItmCod
			&CotComProRef = CotComProRef
			&CotComProNom = CotComProNom
			&MenorCotComProForCod = CotComProMenForCod
			Exit
		Endif
	
	EndFor

EndSub

Sub 'getRegistroAnterior'

	&IsTem = false
	For Each Order EmpCod, CotComCod, (CotComItmCod)
		where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod < &CotComItmCod
		
		if &IsTrazerComPreco = true
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				where CotComProForSts = StatusProdutoCotado.COTADO
				&IsTem = true
				Exit
			When None
				&IsTem = false
			EndFor
			
			if &IsTem = true				
				&CotCOmItmCod = CotComItmCod
				&CotComProRef = CotComProRef
				&CotComProNom = CotComProNom
				&MenorCotComProForCod = CotComProMenForCod
				Exit
			Endif		
		Else			
			&CotCOmItmCod = CotComItmCod
			&CotComProRef = CotComProRef
			&CotComProNom = CotComProNom
			&MenorCotComProForCod = CotComProMenForCod
			Exit
		Endif
	EndFor

EndSub


