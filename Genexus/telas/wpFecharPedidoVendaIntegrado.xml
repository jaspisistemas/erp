      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProcessando.Visible = 0
	
	RetornaAutorizacao.Call('VENDAFECHAESTOQUE', Status_SimNao.Sim, 1, &AutNiv)	
	TextBlockTitle.Caption = 'Fecha financeiro pedido de venda Nº: ' + trim(Str(&PedCod))
	
	loadWWPContext.Call(&Context)
	&PesCod = &Context.PesCod
	do 'carregaFilial'
	Aviso.ForeColor = RGB(0,0,150)
	&PedDtaFat = serverdate()	
	do 'LoadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PedDtaFat.TooltipText = "Data chegada do pedido, Quando entrou no Estoque."

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&FinAutNiv = RetornaAutorizacao.UDP('VENDAFECHAFINANCEIRO', Status_SimNao.Nao, 1)
	
	If &FinAutNiv = 0
		&DefinirFinanceiro.Clear()
		&DefinirFinanceiro.AddItem('N', 'NÃO AUTORIZADO FECHAR FINANCEIRO')
		
		&DefinirFinanceiro = 'N'
		&DefinirFinanceiro.Enabled = 0
	EndIF

EndEvent

Event 'DoCancelaFechamento'

	do 'volta'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	&PedVlrAgr.Enabled = 0
	&NovPedVlrLiq.Enabled = 0
	&PedObsFin.Enabled = 0
	&PedObsEst.Enabled = 0
	&PedCliObs.Enabled = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &PedObsFin.IsEmpty())
		&PedObsFin.Visible = False
		PedObsFin_Cell.Class = !'Invisible'
	Else
		&PedObsFin.Visible = True
		PedObsFin_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (not &PedCliObs.IsEmpty())
		&PedCliObs.Visible = False
		PedCliObs_Cell.Class = !'Invisible'
	Else
		&PedCliObs.Visible = True
		PedCliObs_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (&PedVlrAgr <> 0)
		&NovPedVlrLiq.Visible = False
		NovPedVlrLiq_Cell.Class = !'Invisible'
	Else
		&NovPedVlrLiq.Visible = True
		NovPedVlrLiq_Cell.Class = !'col-xs-12 DscTop'
	EndIf
	If Not (&PedVlrAgr <> 0)
		&PedVlrAgr.Visible = False
		PedVlrAgr_Cell.Class = !'Invisible'
	Else
		&PedVlrAgr.Visible = True
		PedVlrAgr_Cell.Class = !'col-xs-12 DscTop'
	EndIf
	If &PedVlrAgr.Visible = False
		UnnamedTable6.Visible = False
	EndIf
	If &NovPedVlrLiq.Visible = False
		UnnamedTable7.Visible = False
	EndIf
	
	tbvaloragrupado.Visible = (&PedVlrAgr <> 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	do 'LoadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For Each Order EmpCod, FilCod, PedCod
		where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod  = &PedCod
		
		If PedSts <> Status_Pedido.ABERTO and PedSts <> Status_Pedido.SEPARANDO
			do 'volta'
		EndiF
	
		&PedDtaEms = PedDtaEms
		&PedSts = PedSts
		Exit
	EndFOr
	
	Do case
		Case &PedDtaFat < &PedDtaEms
			msg('Data de Faturamento não informada ou inferior a data do pedido!')
		Otherwise
			&DefinirFinanceiro.Enabled = 0
			&PedDtaFat.Enabled = 0
			
			&AuxDefinirFinanceiro = &DefinirFinanceiro
			tbConfirmar.Visible = 0
			tbProcessando.Visible = 1
			
			&ProgressId = trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&PedCod)) + 'FECHA'
			apagaProgress.Call(&ProgressId)
			scaProgressBar.ProcessId = &ProgressId
			scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar.Start()
		
			AtualizaEstoqueGerencialVenda_submit.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &PedCod, &PedDtaFat, &Context.PesCod,  Status_Pedido.FECHADO, false)	
	EndCAse

EndEvent

Event ScaProgressBar.OnComplete

	if &AuxDefinirFinanceiro = 'S'
		If &DeOndeVem = 'WWPEDIDOVENDAAGR'
			wpPedido_FechaFinanceiroAgr.Link(upper(&DeOndeVem), &EmpCod, &FilCod, &PedCod, 0, false)
		Else			
			wpPedido_FechaFinanceiro.Link(upper(&DeOndeVem), &EmpCod, &FilCod, &PedCod, 0, false)
		EndIf		
	Else
		do 'volta'
	EndIF

EndEvent

Sub 'carregaFilial'

	//FILIAL COMBO
	&CreFilPgt.Clear()
	DpFilialAcesso.Call(&Context.EmpCod, &Context.PesCod, &sdtFilialAcesso)
	for &sdtFilialAcessoItem in &sdtFilialAcesso
		&CreFilPgt.AddItem(&sdtFilialAcessoItem.PesFilAce, &sdtFilialAcessoItem.PesFilAceNom)
	EndFor

EndSub

Sub 'volta'

	&Link = &DeOndeVem.trim() + '.aspx'
	Link(&Link)

EndSub

Sub 'LoadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedCliCodRaz = PedCliCodRaz
		
		if LctTip = TipoLancamento.DevolucaoCompra
			&PedCliCodRaz.Caption = 'Fornecedor'
		Endif
		
		&LctCodNom = LctCodNom
		&PedVlrBrt = PedVlrBrt
		&PedVlrLiq = PedVlrLiq
		&CreFilPgt = PedFatFilCod
		&FilCodNom = FilCodNom
		&PedDtaEms = PedDtaEms
		&PedVlrAgr = PedVlrAgr
		&NovPedVlrLiq = PedVlrFin
		
		&PedObsFin = PedObsFin
		If PedObsFin.IsEmpty()
			&PedObsFin.Visible = 0
		EndIF
		
		&PedCliObs = PedCliObs
		If PedCliObs.IsEmpty()
			&PedCliObs.Visible = 0
		EndIF
		
		&PedObsEst = PedObsEst
		If PedObsEst.IsEmpty()
			&PedObsEst.Visible = 0
		EndIF
		
		&PedObsGer = PedObsGer
		If PedObsGer.IsEmpty()
			&PedObsGer.Visible = 0
		EndIF
		
		&PedCodOciRef = 0
		if PedStsGer = Pedido_gerado.OrdemCarregamento
			&PedCodOciRef = PedCodOciRef
		EndIF
		
		Aviso.Caption = ''
		If LctAtuEst = Status_EntradaSaida.Nenhum
			Aviso.Caption = 'ATENÇÃO. Pedido não atualiza Estoque. SOMENTE SERÁ ALTERADO O STATUS PARA FECHADO SEM MOVIMENTAR ESTOQUE.'
		EndIF
		
		If PedStsFin <> Status_Financeiro.ABERTO
			&DefinirFinanceiro.Clear()
			&DefinirFinanceiro.AddItem('N', 'NÃO. FINANCEIRO JÁ DEFINIDO')
			
			&DefinirFinanceiro = 'N'
			&DefinirFinanceiro.Enabled = 0
		EndIF
		
		If LctGerFin = Status_SimNao.Nao
			&DefinirFinanceiro.Clear()
			&DefinirFinanceiro.AddItem('N', 'PEDIDO NÃO GERA FINANCEIRO')
			
			&DefinirFinanceiro = 'N'
			&DefinirFinanceiro.Enabled = 0
		EndIF
		
		If PedSts <> Status_Pedido.ABERTO and PedSts <> Status_Pedido.SEPARANDO
			do 'volta'
		EndiF
		
		Exit
	When None
		return
	EndFor

EndSub


]]></Source>
