      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &PedCod <> 0
		TextBlockTitle.Caption = 'REFERENCIAS/ANEXOS PEDIDO: ' + trim(Str(&PedCod))
	Else
		TextBlockTitle.Caption = 'REFERENCIAS/ANEXOS CLIENTE: ' + trim(Str(&PesCod))
	EndIf

	loadWWPContext.Call(&Context)
	
	&IsCompra = false
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		if LctTip = TipoLancamento.EntradaMercadoria or LctTip = TipoLancamento.orcamentoCompra
			&IsCompra = true
		EndIF
		Exit
	EndFor

	if &IsCompra = false
		retornaAutorizacao.Call('WPREFERENCIASCOMERCIAIS', Status_SimNao.Nao, 1, &AutNiv)
		if &AutNiv < 1
			GXUITabsPanel_abaAnexRef.HideTab(1) //REFERENCIAS
		EndIF
	EndIF

	retornaAutorizacao.Call('WPUPLOADARQUIVOS', Status_SimNao.Nao, 1, &AutNiv)
	if &AutNiv < 1
		GXUITabsPanel_abaAnexRef.HideTab(2) //ANEXOS CLIENTE
	EndIF
	
	If &PedCod.IsEmpty()
		GXUITabsPanel_abaAnexRef.HideTab(3)	//ANEXOS PEDIDO
		GXUITabsPanel_abaAnexRef.HideTab(4) //COTACAO
	Else		
		retornaAutorizacao.Call('WWCOTACAOFRETE', Status_SimNao.Nao, 3, &AutNiv)
		retornaAutorizacao.Call('COTACOESFRETE', Status_SimNao.Nao, 3, &doisAutNiv)
		if &AutNiv < &doisAutNiv
			&AutNiv = &doisAutNiv
		EndIF
		
		If &AutNiv < 1
			GXUITabsPanel_abaAnexRef.HideTab(4) //COTACAO
		EndiF
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 600
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesCodRaz = PesCodRaz
		&PesSts = PesSts
		&PesIsCli = PesIsCli
		&PesIsFor = PesIsFor
		&PesIsTra = PesIsTra
		&PesIsFun = PesIsFun
		&PesIsVen = PesIsVen
		Exit
	EndFor
	
	if &IsCompra =false
		WCwpReferencias.Object = wpReferencias.Create(&EmpCod, &PesCod)
	Else
		WCwpReferencias.Object = wcRefPedido.Create(&EmpCod, &FilCod, &PedCod)
	EndIF

	wcAnex.Object = wpUploadArquivos.Create(&EmpCod, &PesCod)
	WCwpAnexosPedido.Object = wpAnexosPedido.Create(&EmpCod, &FilCod, &PedCod)
	WCwcCotacoesFrete.Object = wcCotacoesFrete.Create(&EmpCod, &FilCod, &PedCod)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarReturn'

	Return

EndEvent

Event gxUITabsPanel_abaAnexRef.TabChanged

	do 'AtivaPage'

EndEvent

Event 'DoMonitoraClientes'

	wwCliente.Link()

EndEvent

Sub 'AtivaPage'

	&numeric = gxUITabsPanel_abaAnexRef.ActivePage
	
	Do CAse
		Case &numeric = 1
			if &IsCompra =false
				WCwpReferencias.Object = wpReferencias.Create(&EmpCod, &PesCod)
			Else
				WCwpReferencias.Object = wcRefPedido.Create(&EmpCod, &FilCod, &PedCod)
			EndIF
			
		Case &numeric = 2
			wcAnex.Object = wpUploadArquivos.Create(&EmpCod, &PesCod)
		Case &numeric = 3
			WCwpAnexosPedido.Object = wpAnexosPedido.Create(&EmpCod, &FilCod, &PedCod)
		Case &numeric = 4
			WCwcCotacoesFrete.Object = wcCotacoesFrete.Create(&EmpCod, &FilCod, &PedCod)
	EndCase

EndSub


]]></Source>
