      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	do 'loadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&mensagemErro.SetEmpty()
	&FicCod.SetEmpty()
	&Mensagem.SetEmpty()
	
	Do Case
		Case &TipoPedido = 'D'
			&PedStsGer = Pedido_Gerado.Delivery
			
		Case &TipoPedido = 'M'
			&PedStsGer = Pedido_Gerado.PDV
			if not &FicBar.IsEmpty()
				localizaPedidoFicha.Call(&EmpCod, &FilCod, &FicBar, &FicCod, &AuxPedCod, &Mensagem, &IsLimite)
			EndiF
			
		Case &TipoPedido = 'B'
			&PedStsGer = Pedido_Gerado.PDV
			&FicCod = 0
	EndCase

	Do CAse
		CAse (not &AuxPedCod.IsEmpty()) and (&AuxPedCod <> &PedCod) and (not &FicBar.IsEmpty())
			&mensagemErro = 'Ficha já utilizada em outro pedido: ' + trim(Str(&AuxPedCod))
			&FicBar.SetFocus()
			msg(&mensagemErro)
			
		Case not &Mensagem.IsEmpty()
			msg(&Mensagem)
			&FicBar.SetFocus()	
			
		Case &TipoPedido = 'M' and &FicBar.IsEmpty()
			msg('Ao selecionar Tipo Pedido Ficha/Mesa, é necessário informar numero da Ficha/Mesa')
			&FicBar.SetFocus()	
			
		otherwise
			
			AlteraCapaPedidoStatusGeracao.Call(&EmpCod, &FilCod, &PedCod, &FicCod, &PedStsGer)
			Return
	EndCase

EndEvent

Sub 'loadPedido'

	For Each order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		do Case
			Case PedStsGer = Pedido_Gerado.Delivery
				&TipoPedidoAtual = 'D'
			Case PedStsGer = Pedido_Gerado.PDV and PedFicCod > 0
				&TipoPedidoAtual = 'M'
				&PedFicCod = PedFicCod
			Case PedStsGer = Pedido_Gerado.PDV
				&TipoPedidoAtual = 'B'
				&PedFicCod =PedFicCod 
			Otherwise
				Return
		EndCAse		
		Exit
	EndFor

	if &PedFicCod > 0
		For Each Order EmpCod, FicCod
			Where EmpCod = &EmpCod
			where FicCod = &PedFicCod
			
			&TipoPedido = FicBar
			&FicBar = FicBar
			
			Exit
		EndFor
	Endif

EndSub


]]></Source>
