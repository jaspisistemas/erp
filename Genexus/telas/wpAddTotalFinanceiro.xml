      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
//	&PlanCod = &parPlanCod
	&FinAno = &parFinAno
	&FinMes = &parFinMes
	&CreRecPag = ReceberPagar.Pagar
	
	if not &parPlanCod.IsEmpty()
		
		do 'LoadPlano'
	Else
		&FinAno = year(serverDate())
		&FinMes = Month(serverDate())
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RetornaCodigoPlanoContas.Call(&EmpCod, &PlanCod, &NewPlanCod)
	if &NewPlanCod.IsEmpty()
		msg('Plano Contas Inválido!')
		&PlanCod.SetFocus()
	Else
		prcGravaTotalFinanceiro.call('ADD', &EmpCod, &NewPlanCod, &FinAno, &FinMes, &FinVlr)
		
		&FinVlr.SetEmpty()
		&PlanCod.SetFocus()
	EndIF

EndEvent

Event &PlanCod.IsValid

	do 'LoadPlano'

EndEvent

Sub 'LoadPlano'

		RetornaCodigoPlanoContas.Call(&EmpCod, &PlanCod, &NewPlanCod)

	For Each Order EmpCod, PlanCod, FinAno, FinMes
		Where EmpCod = &EmpCod
		Where PlanCod = &NewPlanCod
		Where FinAno = &FinAno
		Where FinMes = &FinMes
	
		&FinVlr = FinVlr
		Exit
	EndFor
	
	&FinVlr.SetFocus()

EndSub


]]></Source>
