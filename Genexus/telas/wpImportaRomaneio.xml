	endfor
	
	Grids.Refresh()

EndSub

Sub 'carregaTipoLancamento'

	&NfeLctCod.Clear()
	DpTipoLancamentoNota.Call(&EmpCod, &NfeFin, &NfeEntSai, &SdtTipoLancamento)
	For &SdtTipoLancamentoItem in &SdtTipoLancamento
		&NfeLctCod.AddItem(&SdtTipoLancamentoItem.LctCod, &SdtTipoLancamentoItem.LctCodNom)
	EndFor

