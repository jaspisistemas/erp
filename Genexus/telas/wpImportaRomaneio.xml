Sub 'UserMessage'

	if not &UserMessage.title.IsEmpty() or not &UserMessage.message.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg(&UserMessage.title,&UserMessage.message,&UserMessage.type,'',true,'',''))
	endif

EndSub

Sub 'adicionaRegistroVazio'

	&sdtLeituraRomaneioTxt = new()
	&sdtLeituraRomaneioTxt.origem = 'MANUAL'
	&sdtLeituraRomaneioTxts.Add(&sdtLeituraRomaneioTxt)

EndSub

Sub 'ajustaMinimoLinhasVazias'

	&qtdLinhasVazias = 0
	for &sdtLeituraRomaneioTxt in &sdtLeituraRomaneioTxts
		if &sdtLeituraRomaneioTxt.Codigo.IsEmpty()
			&qtdLinhasVazias += 1
		endif
	endfor
	
	for &i = &qtdLinhasVazias to 1
		do 'adicionaRegistroVazio'
	endfor

EndSub


