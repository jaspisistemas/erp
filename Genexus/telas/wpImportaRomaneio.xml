Event FileUpload1.UploadComplete

	for &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source = &FileUploadData.File
			&path = &File.GetAbsoluteName() /// Pega o local temporario
			&extensao = trim(&FileUploadData.Extension.ToLower())
			&arqNom = trim(&FileUploadData.FullName)
			&File.Close()
			
			prcLeRomaneio(&path,&arqNom,&extensao,&colunaPrimeiraLinha,&colunaCodigo,&colunaPesoLiquido,&sdtLeituraRomaneioTxts,&UserMessage)
		EndiF
	EndFor

	do 'UserMessage'
	
	if &sdtLeituraRomaneioTxts.Count > 0
		do 'iniciaProcesso'
	else
		tb_dadosLidos.Visible = false
		tb_upload.Visible = true
