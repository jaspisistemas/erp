Event &NfeCliCod.IsValid

	if not &NfeCliCod.isEmpty()
		if &NfeCliCod <> &OldNfeCliCod
			for each Pessoa order EmpCod, PesCod
				where EmpCod = &EmpCod
				where PesCod = &NfeCliCod
				
				if PesSts = Status_AtivoInativo.INATIVO
					msg('Atenção! Cliente com Status INATIVO!')
				endif
				
				if PesRazNf.IsEmpty() or PesRazNf.IsNull()
					&NfeCliRaz = PesRaz
				else
					&NfeCliRaz = PesRazNf
				endif
				
				exit
			when none
				&NfeCliCod.SetFocus()
			endfor
		Endif
		
		&OldNfeCliCod = &NfeCliCod
	endif

EndEvent

Event &varNfeProCod.IsValid

	if not &varNfeProCod.isEmpty()
		RetornaProdutoReferencia(&EmpCod, &varNfeProCod, &NfeProCod, &NfeProGraCod, &NfeProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &erroMensagem )
		
		if not &erroMensagem.IsEmpty()
			Msg(DVMessageGetBasicNotificationMsg(&erroMensagem,'',DVMessageType.error,'',true,'',''))
		endif
	endif

EndEvent

