Sub 'iniciaProcesso'

	tb_dadosLidos.Visible = true
	tb_upload.Visible = false
	btnImportar.Visible = true
	btnReiniciarProcesso.visible = true
	
	&NfeCliCod.SetFocus()
	
	do 'ajustaMinimoLinhasVazias'

EndSub

