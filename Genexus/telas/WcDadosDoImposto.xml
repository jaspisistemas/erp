      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable19.Width = 175
	UnnamedTable18.Width = 175
	UnnamedTable17.Width = 175
	UnnamedTable16.Width = 175
	UnnamedTable15.Width = 175

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PedItmAcr.Enabled 		= 1	
	&PedItmDsc.Enabled 		= 1	 
	&PedItmIcm.Enabled 		= 1	 	
	&PedItmIcmSt.Enabled	= 1	 
	&PedItmIcmStPob.Enabled = 1	
	&PedItmIpi.Enabled 		= 1
	
	&OldPedItmAcr		= &PedItmAcr
	&OldPedItmDsc		= &PedItmDsc
	&OldPedItmIcm		= &PedItmIcm
	&OldPedItmIcmSt		= &PedItmIcmSt
	&OldPedItmIcmStPob	= &PedItmIcmStPob
	&OldPedItmIpi		= &PedItmIpi
	
	RetornaTotalLiquidoBruto.Call(&EmpCod, &FilCod, &PedCod, &PedVlrBrt, &PedVlrLiq)
	
	&TotEstQtd = &EstQtd + &AuxEstQtd
	Do Case
		Case &TotEstQtd > &ProQtdMin
			&EstQtd.ForeColor 		= RGB(0,100,0)
			&AuxEstQtd.ForeColor 	= RGB(0,100,0)
			Do Case
				Case &EstQtd < &ProQtdMin and &EstQtd > 0
					&EstQtd.ForeColor	= RGB(218,165,32)
				Case &EstQtd < &ProQtdMin and &EstQtd <= 0
					&EstQtd.ForeColor 	= RGB(178,34,34)
				Case &AuxEstQtd = 0
					&AuxEstQtd.ForeColor = RGB(0,0,0)
			EndCase
			
		Case &TotEstQtd = &ProQtdMin
			&EstQtd.ForeColor 		= RGB(218,165,32)
			&AuxEstQtd.ForeColor 	= RGB(218,165,32)
			
			Do Case 
				Case &EstQtd <= 0 
					&EstQtd.ForeColor = RGB(178,34,34)
					
				Case &AuxEstQtd <= 0
					&AuxEstQtd.ForeColor = RGB(178,34,34)
			EndCase
			
		Case &TotEstQtd < &ProQtdMin
			&EstQtd.ForeColor 		= RGB(178,34,34)
			&AuxEstQtd.ForeColor 	= RGB(178,34,34)
			Do Case 
				Case &AuxEstQtd > 0 
					&AuxEstQtd.ForeColor 	= RGB(218,165,32)		
			EndCase
	EndCase

EndEvent

Event 'DoValor'

	wpValorImp.Popup(&PedVlrItm, &PedItmDsc, &PedItmAcr, &PedItmIpi, &PedItmIcmSt, &PedItmIcm, &PedItmIcmStPob)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDescAlt'

	&PedItmAcr	 		= &OldPedItmAcr
	&PedItmDsc			= &OldPedItmDsc
	&PedItmIcm			= &OldPedItmIcm
	&PedItmIcmSt		= &OldPedItmIcmSt
	&PedItmIcmStPob		= &OldPedItmIcmStPob
	&PedItmIpi			= &OldPedItmIpi
	
	prcAtualizaValoresComImpostos.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &PedItmAcr, &PedItmDsc, &PedItmIpi, &PedItmIcmSt, &PedItmIcmStPob, &PedItmIcm, &Context.UserName)
	RetornaTotalLiquidoBruto.Call(&EmpCod, &FilCod, &PedCod, &PedVlrBrt, &PedVlrLiq)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

