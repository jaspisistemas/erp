      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName

	JSDynamicFilters.Caption = ''
	&EmbEsp1 = nullvalue(&EmbEsp1)
	&DynamicFiltersSelector1 = !'EMBNOM'
	Do 'EnableDynamicFilters1'
	&EmbEsp2 = nullvalue(&EmbEsp2)
	&DynamicFiltersSelector2 = !'EMBNOM'
	Do 'EnableDynamicFilters2'
	&EmbEsp3 = nullvalue(&EmbEsp3)
	&DynamicFiltersSelector3 = !'EMBNOM'
	Do 'EnableDynamicFilters3'
	
	AddDynamicFilters1.JSEvent('onclick', format(!"WWPDynFilterShow_AL('%1', 2, 0)", TableDynamicFilters.InternalName))
	RemoveDynamicFilters1.JSEvent('onclick', format(!"WWPDynFilterHideLast_AL('%1', 3, 0)", TableDynamicFilters.InternalName))
	AddDynamicFilters2.JSEvent('onclick', format(!"WWPDynFilterShow_AL('%1', 3, 0)", TableDynamicFilters.InternalName))
	RemoveDynamicFilters2.JSEvent('onclick', format(!"WWPDynFilterHideLast_AL('%1', 3, 0)", TableDynamicFilters.InternalName))
	RemoveDynamicFilters3.JSEvent('onclick', format(!"WWPDynFilterHideLast_AL('%1', 3, 0)", TableDynamicFilters.InternalName))
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = 'Consulta de Cadastro de Embalagens'
	Do 'LoadDynFiltersState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaLinhaTam.Call(&linhaNumeric, &TamanhoNumeric)
	TableMain.Height = &TamanhoNumeric
	Grid.Rows = &linhaNumeric
	
	&EmbNom1.SetFocus()

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Select = !'<i class="fas fa-check"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&InOutEmbCod = EmbCod
	&InOutEmbCodNom = EmbCodNom
	Return

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'AddDynamicFilters1'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&DynamicFiltersEnabled2 = True
	AddDynamicFilters1.Visible = False
	RemoveDynamicFilters1.Visible = True

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'RemoveDynamicFilters1'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&DynamicFiltersRemoving = True
	&DynamicFiltersIgnoreFirst = True
	Do 'SaveDynFiltersState'
	Do 'ResetDynFilters'
	Do 'LoadDynFiltersState'
	&DynamicFiltersRemoving = False
	&DynamicFiltersIgnoreFirst = False
	Grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DynamicFiltersSelector1.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'EnableDynamicFilters1'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'AddDynamicFilters2'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&DynamicFiltersEnabled3 = True
	AddDynamicFilters2.Visible = False
