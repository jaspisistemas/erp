		Do Case
			Case &DynamicFiltersSelector1 = !'EMBNOM' AND not &EmbNom1.IsEmpty()
				&GridStateDynamicFilter.Value = &EmbNom1.ToString()
			Case &DynamicFiltersSelector1 = !'EMBCOD' AND not &EmbCod1.IsEmpty()
				&GridStateDynamicFilter.Value = &EmbCod1.ToString()
			Case &DynamicFiltersSelector1 = !'EMBUND' AND not &EmbUnd1.IsEmpty()
