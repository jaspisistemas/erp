				&GridStateDynamicFilter.Value = &EmbEsp3.ToString()
		EndCase
		If &DynamicFiltersRemoving OR not &GridStateDynamicFilter.Value.IsEmpty()
			&GridState.DynamicFilters.Add(&GridStateDynamicFilter)
		EndIf
	EndIf

