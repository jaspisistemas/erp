        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	inicializaFiliais.Call(&Context.EmpCod, &AuxPesCod)
	do 'LoadPessoa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 500
	GridEmpresa.Rows = 0
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridEmpresa.Load

	RetornaPEssoaEmpresaAcesso.Call(PesAceEmpCod, PesAcePesCod, &PesRaz, &EmpRaz)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&OldPesFilAceNiv = PesFilAceNiv
	&OldPesFilIsPad = PesFilIsPad
	if PesCod = &Context.PesCod and &Context.FilCod = PesFilAce		
		PesFilIsPad.Enabled = 0
		PesFilAceNiv.Enabled = 0
	Else		
		PesFilIsPad.Enabled = 1
		PesFilAceNiv.Enabled = 1
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	prcAdicionarAutorizacaoAcesso.Call(&auxEmpCod, &AuxPesCod, &PesAceGuid, &Mensagem)
	&PesAceGuid.SetEmpty()
	if not &Mensagem.IsEmpty()
		msg(&Mensagem)
	Endif

	do 'LoadPessoa'
	GridEmpresa.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGerarCodigo'

	prcCriaCodigoGuidAcessoExterno.Call(&auxEmpCod, &AuxPesCod)
	do 'LoadPessoa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event PesFilAceNiv.Click

	if &OldPesFilAceNiv <> PesFilAceNiv
		&IsFilialPadrao = PesFilIsPad
		if PesFilAceNiv < 2
			&IsFilialPadrao = false
		Endif
	
		GravaFilialacesso.Call(EmpCod, PesCod, PesFilAce, PesFilAceNiv, &IsFilialPadrao)
		Refresh
	Endif

EndEvent

Event PesFilIsPad.IsValid

	if &OldPesFilIsPad <> PesFilIsPad
		&PesFilAceNiv = PesFilAceNiv
		if PesFilIsPad = true
			&PesFilAceNiv = 2
		Endif
	
		GravaFilialacesso.Call(EmpCod, PesCod, PesFilAce, &PesFilAceNiv, PesFilIsPad)
		Refresh
	Endif

EndEvent

Event limpar_campo.Click

	prcLimpaCodigoAcesso.Call(&auxEmpCod, &AuxPesCod)
	do 'LoadPessoa'

EndEvent

Sub 'LoadPessoa'

	btnGerarCodigo.Visible = 0
	txtMensagem.Visible = 0
	tbCampo.Visible = 1
	
	for Each Order EmpCod, PesCod
		Where EmpCod = &auxEmpCod
		Where PesCod = &AuxPesCod
		
		&newPesAceGuid = PesAceGuid
		
		if PesAceGuid.IsEmpty() or PesAceGuid.IsNull()
			btnGerarCodigo.Visible = 1
			txtMensagem.Visible = 1
			
			tbCampo.Visible = 0
		Endif
	
		Exit
	EndFor

EndSub


