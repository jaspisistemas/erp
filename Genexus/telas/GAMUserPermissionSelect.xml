//	Endif
//	If &CurrentPage = 1
//		TBFirst.Class 		= ThemeClass:SelectedPagingText
//		TBPrev.Class 		= ThemeClass:SelectedPagingText
//		TBFirst. Enabled 	= False
//		TBPrev.Enabled		= False
//	Endif
//	GridWW.Refresh()
//Endevent
//
//Event 'Next'
//	if &CurrentPage = 1
//		TBFirst.Class 		= ThemeClass:PagingText
