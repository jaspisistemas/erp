      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&UserNick = &GAMUser.GetName()	
	&PesExtCod = Val(&GAMUser.GetExternalId())
	&TipoPerfil = RetTipNick.Udp(&GAMUser.GetExternalId()) // 1 Usuario 2 Contador
	Welcome.Caption = 'Bem Vindo: ' + trim(&UserNick)
	If upper(&UserNick) <> 'SUPORTE.JASPI' and &TipoPerfil <> 3
		Dashboard.Link()
	EndIF		

	For Each Order EmpCod
		&EmpCod = EmpCod
		do 'ValidaSuporte'
		if &IsOkAcesso = true	
			&EmpCodNom = EmpCodNom
			Exit
		Endif
	EndFor
	&EmpCodSug = &EmpCodNom

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	SubMain.Width = 500

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For Each Order EmpCod
		Where EmpCodNom = &EmpCodSug
		Where FilCod = &FilCod
		
		&EmpCod = EmpCod
		do 'ValidaSuporte'
		if &IsOkAcesso = true
			ProcLoadInicio.Call(EmpCod, FilCod, &IsLicenciado, &IsOkAcesso)
			
			If &URL.IsEmpty()
				Dashboard.Call()
			Else
				Link(&URL)
			Endif
		Else
			msg( 'SUPORTE. Não autorizado a entrar nessa empresa!')
		Endif	
		
		Exit
	When None
		msg('Putz, Selecione a empresa!')
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'ValidaSuporte'

	&IsOkAcesso = true
	If upper(&UserNick) <> 'SUPORTE.JASPI'
		For each order SupCod
			Where SupExtID = &PesExtCod
			
			For each order SupCod, SupEmpCod
				Where SupEmpCod = &EmpCod
				if SupEmpAce <> true
					&IsOkAcesso = false						
				Endif
			EndFor
		EndFor
	Endif

EndSub


]]></Source>
