      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	if &DiariasFolhas = 'D'
		wwpActions.WCPopup_UpdateTitle('Pagamento de "Diárias"')
	Else
		wwpActions.WCPopup_UpdateTitle('Pagamento de "Folhas"')
	Endif

	retornaAutorizacao.Call('WPPAGAMENTOFOLHA', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	&Ano = Year(&Today)
	&Mes = Month(&Today)-1
	Do 'Funcionario'
	&MovDtaCon = &Today
	
	PadraoUsuarioHora.Call('L','WPPAGAMENTODIARIA',&PesCod,&EmpCod,&AgruparPorTipo, &PadDtaMod, &PAdDtaHorMod, 'P')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	PadraoUsuarioHora.Call('G','WPPAGAMENTODIARIA',&PesCod,&EmpCod,&AgruparPorTipo, &PadDtaMod, &PAdDtaHorMod, 'P')

	if &AgruparPorTipo = 'T'
		RCOOpenWindow1.LinkOpen = RELJAS072_PagamentoFolha2.link(&EmpCod,&FilCod,&Ano,&Mes,&FunCod,&movDtaCon,'',&FolPgtCtaBanCod, &TipoFolha,&DiariasFolhas)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		RCOOpenWindow1.LinkOpen = RELJAS072_PagamentoFolha.link(&EmpCod,&FilCod,&Ano,&Mes,&FunCod,&movDtaCon,'',&FolPgtCtaBanCod, &TipoFolha,&DiariasFolhas)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndIF

EndEvent

Event &FunCod.IsValid

	Do 'Funcionario'

EndEvent

Sub 'funcionario'

	If &FunCod = 0
		&FunNom = 'Todos os funcionários'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &FunCod
			Where PesIsFun = True
			Where PesSts = Status_AtivoInativo.ATIVO
			&FunNom = PesRaz
			Exit
		When none
			msg('Pessoa não encontada por não ser um funcionário ou estar inativo. Verifique!')
			&FunNom = 'Pessoa não encontada Verifique!'
			&FunCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
