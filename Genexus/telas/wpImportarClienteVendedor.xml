	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPaginationBar.SelectedPage = !'Previous'
			GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.PreviousPage()
		Case GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.CurrentPage
			&PageToGo += 1
			GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPaginationBar.SelectedPage)
			GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.Rows = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPaginationBar.RowsPerPageSelectedValue
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPaginationBar.SelectedPage = !'Previous'
			GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.PreviousPage()
		Case GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.CurrentPage
			&PageToGo += 1
			GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPaginationBar.SelectedPage)
			GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.Rows = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPaginationBar.RowsPerPageSelectedValue
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	Do Case
		Case &SdtImportaClienteVendedor.SdtImportaClienteVendedorSucess.Count <= 0
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Não há dados importados com sucesso.', DVMessageType.regular, "", DVMessageBoolean.True, ""))
		OtherWise

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_BtnConfirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

EndEvent

Event DVelop_ConfirmPanel_BtnConfirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Ask If DVelop_ConfirmPanel_BtnConfirmar.Result = !'Yes'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If DVelop_ConfirmPanel_BtnConfirmar.Result = !'Yes'
		tbFileUpload.Visible	= 0
		tbScanProgressImporta.Visible	= 0
		tbButtons.Visible	= 0
		tbScaProgressSalva.Visible	= 1
		
		&Random = Random() * 10000000000
		&ProgressId = 'GravaVinculoVendedor' + trim(Str(&Random))
		
		ScanProgressSalva.ProcessId = &ProgressId
		ScanProgressSalva.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		ScanProgressSalva.Start()
		SubstituiVendedorClientes_Importacao.Submit(&ProgressId, &ProgressId, &EmpCOd, &SdtImportaClienteVendedor, &Context.PesCod)
	EndIf

EndEvent

Event ScanProgressSalva.OnComplete

	msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'Vinculo de cliente e vendedores alterado.', DVMessageType.success, "", DVMessageBoolean.True, ""))
	apagaProgress.Call(&ProgressId)
	
	wpAlteraVendedorCliente.Link()

EndEvent

Event FileUpload.UploadComplete

	Do Case
		Case &PrimeiraLinha.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O campo "Primeira Linha" é de preenchimento obrigatório.', DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&PrimeiraLinha.SetFocus()
			
		Case &ColCliente.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O campo "Coluna CLIENTE" é de preenchimento obrigatório.', DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&ColCliente.SetFocus()
			
		Case &ColVenExt.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O campo "Coluna VENDE. EXTER." é de preenchimento obrigatório.', DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&ColVenExt.SetFocus()
			
		Case &ColVenInt.IsEmpty()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O campo "Coluna VENDE. INTER." é de preenchimento obrigatório.', DVMessageType.regular, "", DVMessageBoolean.True, ""))
			&ColVenInt.SetFocus()
			
		OtherWise
			
			For &FileUploadData In &UploadedFiles
				If Not &FileUploadData.File.IsEmpty()
					&LongVarChar.SetEmpty()
					tbScanProgressImporta.Visible	= 1
					&File.Source	= &FileUploadData.File
					&PathURL	= &File.GetAbsoluteName()
					&File.Close()
					
					&Random = Random() * 10000000000
					&ProgressId = 'NvVinculoVendedor' + trim(Str(&Random))
					
					ScanProgressImporta.ProcessId = &ProgressId
					ScanProgressImporta.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
					ScanProgressImporta.Start()
					
					prcImportarClienteVendedor.Submit(&ProgressId, &ProgressId, &EmpCOd, &PathURL, &PrimeiraLinha, &ColCliente, &ColVenExt, &ColVenInt, &Context.PesCod)
				EndIf
			EndFor
		
	EndCase

	FileUpload.Clear()
	&UploadedFiles.Clear()

EndEvent

Event ScanProgressImporta.OnComplete

	&SdtImportaClienteVendedor.SdtImportaClienteVendedorErro.Clear()
	&SdtImportaClienteVendedor.SdtImportaClienteVendedorSucess.Clear()

	PadraoUsuario.Call('L', &ProgressId, &Context.PesCod, &EmpCOd, &LongVarChar, ServerDate())	
	&SdtImportaClienteVendedor.FromJson(&LongVarChar)
	
	tbImportaErro.Visible	= IIf(&SdtImportaClienteVendedor.SdtImportaClienteVendedorErro.Count > 0, 1, 0)
	tbImportaSucesso.Visible	= IIf(&SdtImportaClienteVendedor.SdtImportaClienteVendedorSucess.Count > 0, 1, 0)
	
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.Refresh()
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.Refresh()
	
	apagaProgress.Call(&ProgressId)
	tbButtons.Visible	= IIf(&SdtImportaClienteVendedor.SdtImportaClienteVendedorSucess.Count > 0, 1, 0)
	tbScanProgressImporta.Visible	= 0

EndEvent


]]></Source>
