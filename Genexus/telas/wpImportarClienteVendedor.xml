        <Source><![CDATA[
Event Start

	LoadWWpContext.Call(&Context)
	&EmpCod	= &Context.EmpCod
	
	tbImportaSucesso.Visible	= 0
	tbImportaErro.Visible	= 0
	tbButtons.Visible	= 0
	tbScanProgressImporta.Visible	= 0
	tbScaProgressSalva.Visible	= 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable3.Height = 5
	UnnamedTable5.Height = 5
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.Rows = Page.Rows
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.Rows = Page.Rows
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPaginationBar.RowsPerPageSelectedValue = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.Rows
	GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPaginationBar.RowsPerPageSelectedValue = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosCurrentPage = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.CurrentPage
	&GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErrosPageCount = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.PageCount
	&GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssCurrentPage = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.CurrentPage
	&GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesssPageCount = GridSdtImportaClienteVendedor_SdtImportaClienteVendedorSucesss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSdtImportaClienteVendedor_SdtImportaClienteVendedorErros.Load

