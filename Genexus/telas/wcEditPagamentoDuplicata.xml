      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&AuxCreRecPag = 'P'
	&CreRecPag = 'D' //Debito
	&SdtPagamentoDuplicata.FromXml(&Websession.Get(&ChaveSession))
	
	loadWWPContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod
	do 'carregaCombo'
	
	//######################### Configurações de parâmetro para vale#########
	RetornaConfSistema.Call(&EmpCod, &WwpContext.FilCod, domConfSistema.TCon014_PlanoAdiantamento, &CfgVlr)
	&ValePlanHie = trim(&cfgVlr)
	
	For each Order EmpCod,PlanHie,PlanCod
		Where EmpCod = &EmpCod
		Where PlanHie = &ValePlanHie
		&ValePlanCod = PlanCod    // Retorna Código do Planbo de Contas Origem
		Exit
	EndFor

	&IsAchou = false
	For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
		if &SdtPagamentoDuplicataItem.EmpCod = &ediEmPCod and &SdtPagamentoDuplicataItem.FilCod = &ediFiLCod and &SdtPagamentoDuplicataItem.CreCod = &ediCreCod
			
			&CreDtaEms = &SdtPagamentoDuplicataItem.CreDtaEms
			&CreDtaVct = &SdtPagamentoDuplicataItem.CreDtaVct
			&CreDupNro = &SdtPagamentoDuplicataItem.CreDupNro
			&CreVlrSdo = &SdtPagamentoDuplicataItem.CreVlrSdo
			
			&CrePlanCodNomVir = &SdtPagamentoDuplicataItem.CrePlanCodNomVir
			
			
			&FuncionarioPesCod = &SdtPagamentoDuplicataItem.MovFunCod
			
			If &SdtPagamentoDuplicataItem.CrePlanCod = &ValePlanCod and &ValePlanCod > 0
				tbFuncionario.Visible = true
			Else
				tbFuncionario.Visible = false
			EndIf
			
			&IsAchou = true
			Exit
		Endif
	EndFor

	&PlanCod = RetornaCodigoPadraoPlano.Udp(&CrePlanCodNomVir, &EmpCod)

	if &IsAchou = false
		do 'sair'	
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserSair'

	do 'sair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	retornaCodigoPlanoContas.Call(&EmpCod, &PlanCod, &CrePLancod)
	
	If &CrePLancod = &ValePlanCod and &ValePlanCod > 0 and &FuncionarioPesCod.IsEmpty()
		msg('Informe Funcionário para o Vale!')		
	Else		
		RetornaNomePessoa.Call(&EmpCod, &FuncionarioPesCod, &PesRaz)
		For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
			if &SdtPagamentoDuplicataItem.EmpCod = &ediEmPCod and &SdtPagamentoDuplicataItem.FilCod = &ediFiLCod and &SdtPagamentoDuplicataItem.CreCod = &ediCreCod
								
				&SdtPagamentoDuplicataItem.CrePlanCodNomVir = &PlanCod
				&SdtPagamentoDuplicataItem.CrePlanCod = &CrePLancod
				
				&SdtPagamentoDuplicataItem.MovFunCod = &FuncionarioPesCod
				&SdtPagamentoDuplicataItem.MovFunNom = trim(str(&FuncionarioPesCod)) + ' - ' + &PesRaz.Trim()
				
			EndIf
		EndFor
		
		&WebSession.Set(&ChaveSession,&SdtPagamentoDuplicata.Toxml())
		padraoUsuario.Call('G', 'SEL_WWDuplicataPagar', &WwpContext.PesCod, &WwpContext.EmpCod, &SdtPagamentoDuplicata.ToJson(), &PadDtaMod)
		
		do 'sair'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PlanCod.IsValid

	retornaCodigoPlanoContas.Call(&EmpCod, &PlanCod, &CrePLancod)
	
	If &CrePLancod = &ValePlanCod and &ValePlanCod > 0
		tbFuncionario.Visible = true
	Else
		tbFuncionario.Visible = false
	EndIf

EndEvent

Sub 'sair'

	wwpActions.WCPopup_Close('')

EndSub

Sub 'carregaCombo'

	DpFuncionario.Call(&SdtPessoa)
	&FuncionarioPesCod.Clear()
	&FuncionarioPesCod.AddItem(0, 'Selecione o Funcionário')
	for &SdtPessoaItem in &SdtPessoa
		&mensagem = trim(str(&SdtPessoaItem.PesCod)) + ' - ' + trim(&SdtPessoaItem.PesRaz)
		&FuncionarioPesCod.AddItem(&SdtPessoaItem.PesCod, &mensagem)
	EndFor

EndSub


]]></Source>
