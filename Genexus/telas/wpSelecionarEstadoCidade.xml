        <Source><![CDATA[
Event Start

	txtUF.ForeColor = RGB(255,0,0)
	LoadwwpContext.Call(&WwpContext)
		
	padraoUsuario.Call('L', '#CONFIGUFS_OFF#', &PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
