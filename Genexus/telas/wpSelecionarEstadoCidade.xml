	&PadObs.SetEmpty()
	padraoUsuario.Call('L', '#CONFIGCIDADES_OFF#', &PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	&sdtCidade.FromJson(&PadObs)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtCidades.Rows = Page.Rows
	GridsdtUFs.Rows = Page.Rows
	GridsdtCidadesPaginationBar.RowsPerPageSelectedValue = GridsdtCidades.Rows
	GridsdtUFsPaginationBar.RowsPerPageSelectedValue = GridsdtUFs.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtCidadesCurrentPage = GridsdtCidades.CurrentPage
	&GridsdtCidadesPageCount = GridsdtCidades.PageCount
	&GridsdtUFsCurrentPage = GridsdtUFs.CurrentPage
	&GridsdtUFsPageCount = GridsdtUFs.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtCidades.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&RemoverCidade = !'<i class="fa fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtUFs.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtCidadesPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtCidadesPaginationBar.SelectedPage = !'Previous'
			GridsdtCidades.PreviousPage()
		Case GridsdtCidadesPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtCidades.CurrentPage
			&PageToGo += 1
			GridsdtCidades.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtCidadesPaginationBar.SelectedPage)
			GridsdtCidades.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtCidadesPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtCidades.Rows = GridsdtCidadesPaginationBar.RowsPerPageSelectedValue
	GridsdtCidades.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtUFsPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtUFsPaginationBar.SelectedPage = !'Previous'
