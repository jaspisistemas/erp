	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&AuxsdtCidade = &sdtCidade
	&IsJaAdicionado = false
	
	For &AuxCidadeItem in &AuxsdtCidade
		If &AuxCidadeItem.CidCod = &CidCod
			&IsJaAdicionado = true
			Exit
		Endif
	EndFor

	if &IsJaAdicionado = false
		For Each Order EmpCod, CidCod
			Where EmpCod = &EmpCod
			Where CidCod = &CidCod
			&AuxCidadeItem = new()
			&AuxCidadeItem.CidCod = &CidCod
			&AuxCidadeItem.CidNom = &CidNom
			&AuxCidadeItem.CidSel = true
			&AuxsdtCidade.Add(&AuxCidadeItem)
			Exit
		EndFor
	Endif
	
	&PadObs = &AuxsdtCidade.ToJson()
	padraoUsuario.Call('G', '#CONFIGCIDADES_OFF#', &PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	&sdtCidade.FromJson(&PadObs)
	SetDeviceAtualizaS.Call(&EmpCod, &PesCod)
	
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdicionarTodasCidades'

	prcGravarTodasCidades.Call(&wwpContext.EmpCod, &PesCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event sdtUF__UfeSel.Click

	&PadObs.SetEmpty()
	&PadObs = &sdtUF.ToJson()
	padraoUsuario.Call('G', '#CONFIGUFS_OFF#', &PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	SetDeviceAtualizaS.Call(&EmpCod, &PesCod)

EndEvent

Event &RemoverCidade.Click

	&AuxsdtCidade = &sdtCidade
	
	For &AuxCidadeItem in &AuxsdtCidade
		If &AuxCidadeItem.CidCod = &SdtCidade.CurrentItem.CidCod
			&Index = &AuxsdtCidade.IndexOf(&AuxCidadeItem)
			&AuxsdtCidade.Remove(&Index)
			Exit
		Endif
	EndFor
	
	&PadObs = &AuxsdtCidade.ToJson()
	padraoUsuario.Call('G', '#CONFIGCIDADES_OFF#', &PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	&sdtCidade.FromJson(&PadObs)
	
	SetDeviceAtualizaS.Call(&EmpCod, &PesCod)
	Refresh

EndEvent

