Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		OportunidadeHospedagem(!'DadosHospedagem', !'Concluido', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		Do 'SaveVariablesToWizardData'
	EndIf

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&OptDom = &WizardData.DadosHospedagem.OptDom
	&OptVctDom = &WizardData.DadosHospedagem.OptVctDom
	&OptSerCod = &WizardData.DadosHospedagem.OptSerCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.DadosHospedagem.OptDom = &OptDom
	&WizardData.DadosHospedagem.OptVctDom = &OptVctDom
	&WizardData.DadosHospedagem.OptSerCod = &OptSerCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	GravaOportunidade.call(&WizardData)
	
	OportunidadeHospedagem(!'DadosHospedagem', !'Concluido', false)

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &OptDom.trim().isEmpty())
		&OptVctDom.Visible = False
		OptVctDom_Cell.Class = !'Invisible'
	Else
		&OptVctDom.Visible = True
		OptVctDom_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &OptDom.IsValid

	do 'AttributesSecurityCode'

EndEvent


