      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProcessando.Visible = 0
	
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	obsPedido.Caption = ''
	&PedVenCod = 0
	&tmpNfeChvRef = ''	
	
	RetornaAutorizacao.Call('WWPEDIDOCOMPRA', Status_SimNao.Nao, 2, &WWPEDIDOCOMPRA_AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	tbVen.Width = 600
	&tmpEmixCod.Visible = False
	&tmpNfeChvRef.Visible = False
	&PedVenCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SalvarNotaCompra = true
	&FecharPedidoSelecionado.Enabled = 0
	&PedCod = &WizardData.SelecionarXML.PedCod
	if &WizardData.SelecionarXML.PedCod.IsEmpty()
		&SubstituirItensPedido = false
		&SubstituirItensPedido.Visible = false
		
		if &WWPEDIDOCOMPRA_AutNiv > 0
			&SalvarPedidoCompra = true
		Else
			&SalvarPedidoCompra = false
			&SalvarPedidoCompra.Enabled = 0
			
		EndiF
		
		&FecharPedidoSelecionado.Visible = 0
		&PedDtaFat.Visible = 0
		&FecharFinanceiroSelecionado.Visible = 0
	Else
		obsPedido.Caption = 'PEDIDO: ' + trim(str(&WizardData.SelecionarXML.PedCod))
		&SalvarPedidoCompra = false
		&SalvarPedidoCompra.Enabled = 0
		
		if &WWPEDIDOCOMPRA_AutNiv > 0
			&SubstituirItensPedido = false
			&SubstituirItensPedido.Visible = true
		Endif
	EndIF
	
	if &WizardData.SelecionarXML.DeOndeVem <> 'WWORDEMCOSTURA'
		&SalvarOrdemCostura = false
		&SalvarOrdemCostura.Visible = 0
	Else
		&SalvarOrdemCostura = true
		&SalvarOrdemCostura.Visible = 1
	EndIF		
	
	&LctCod = &WizardData.Envolvidos.LctCod
	
	&DeOndeVem = &WizardData.SelecionarXML.DeOndeVem
	If &DeOndeVem.IsEmpty()
		Dashboard.Link()
	EndIF
	TableDevolucao.Visible = &DeOndeVem='WWDEVOLUCAOVENDA'
	
	&NomeTemporario = &DeOndeVem.Trim() + 'IMPXMLCOMPRA' + trim(str(&EmpCod)) + trim(Str(&Context.PesCod)) + '-'
	&tmpNFeCod = &NomeTemporario + '1'
	
	do 'LoadTemporaria'
	If not  &tmpNfeChvRef.IsEmpty()
		Do 'BuscaPedidoVenda'
	EndIf

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	ImportarXmlCompra(!'GravaNf', !'Totais', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&tmpEmixCod = &WizardData.GravaNf.tmpEmixCod
	&tmpNfeChvRef = &WizardData.GravaNf.tmpNfeChvRef
	&PedDtaFat = &WizardData.GravaNf.PedDtaFat
	&SalvarPedidoCompra = &WizardData.GravaNf.SalvarPedidoCompra
	&FecharPedidoSelecionado = &WizardData.GravaNf.FecharPedidoSelecionado
	&FecharFinanceiroSelecionado = &WizardData.GravaNf.FecharFinanceiroSelecionado
	&SubstituirItensPedido = &WizardData.GravaNf.SubstituirItensPedido
	&SalvarNotaCompra = &WizardData.GravaNf.SalvarNotaCompra
	&SalvarOrdemCostura = &WizardData.GravaNf.SalvarOrdemCostura
	&VinculosMensagem = &WizardData.GravaNf.VinculosMensagem
	&AvisoPedidoMensagem = &WizardData.GravaNf.AvisoPedidoMensagem
	&PagamentoMensagem = &WizardData.GravaNf.PagamentoMensagem
	&CreditoMensagem = &WizardData.GravaNf.CreditoMensagem
	&PedVenRaz = &WizardData.GravaNf.PedVenRaz
	&PedVenCod = &WizardData.GravaNf.PedVenCod
	&PedVenCodVar = &WizardData.GravaNf.PedVenCodVar
	&PesRazVar = &WizardData.GravaNf.PesRazVar
	&PedCliCodVar = &WizardData.GravaNf.PedCliCodVar
	&DevPedCodOciRef = &WizardData.GravaNf.DevPedCodOciRef
	&NfeChv = &WizardData.GravaNf.NfeChv
	&tmpEmixNom = &WizardData.GravaNf.tmpEmixNom

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.GravaNf.tmpEmixCod = &tmpEmixCod
	&WizardData.GravaNf.tmpNfeChvRef = &tmpNfeChvRef
	&WizardData.GravaNf.PedDtaFat = &PedDtaFat
	&WizardData.GravaNf.SalvarPedidoCompra = &SalvarPedidoCompra
	&WizardData.GravaNf.FecharPedidoSelecionado = &FecharPedidoSelecionado
	&WizardData.GravaNf.FecharFinanceiroSelecionado = &FecharFinanceiroSelecionado
	&WizardData.GravaNf.SubstituirItensPedido = &SubstituirItensPedido
	&WizardData.GravaNf.SalvarNotaCompra = &SalvarNotaCompra
	&WizardData.GravaNf.SalvarOrdemCostura = &SalvarOrdemCostura
	&WizardData.GravaNf.VinculosMensagem = &VinculosMensagem
	&WizardData.GravaNf.AvisoPedidoMensagem = &AvisoPedidoMensagem
	&WizardData.GravaNf.PagamentoMensagem = &PagamentoMensagem
	&WizardData.GravaNf.CreditoMensagem = &CreditoMensagem
	&WizardData.GravaNf.PedVenRaz = &PedVenRaz
	&WizardData.GravaNf.PedVenCod = &PedVenCod
	&WizardData.GravaNf.PedVenCodVar = &PedVenCodVar
	&WizardData.GravaNf.PesRazVar = &PesRazVar
	&WizardData.GravaNf.PedCliCodVar = &PedCliCodVar
	&WizardData.GravaNf.DevPedCodOciRef = &DevPedCodOciRef
	&WizardData.GravaNf.NfeChv = &NfeChv
	&WizardData.GravaNf.tmpEmixNom = &tmpEmixNom
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'FinishWizard'

	if &FecharPedidoSelecionado = true and &PedCod > 0 and &PedDtaFat.IsEmpty()
		msg('Favor informar a data de Faturamento do Pedido!')
	Else
		
		&AuxFecharFinanceiroSelecionado = &FecharFinanceiroSelecionado
		tbConfirmar.Visible = 0
		tbProcessando.Visible = 1
		
		&ProgressId = trim(&tmpNFeCod) + 'IMPORTANOTA'
		apagaProgress.Call(&ProgressId)
		scaProgressBar.ProcessId = &ProgressId
		scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar.Start()
		
		if &SalvarPedidoCompra = true 
			if (&PedVenCod = 0 or &PedVenCod.IsEmpty()) // se não informou o vendedor na tela, ou não é uma devolução de venda 
