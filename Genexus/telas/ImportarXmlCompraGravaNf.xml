Sub 'LoadVendedor'

	&PesCodRazSugg = ''
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedVenCod
		
		//&IsErroVendedor = false
		
		&PesCodRazSugg = PesCodRazSugg		
		&PedVenCodVar = trim(str(&PedVenCod))		
		&PesDtaDem = RetornaDataRecrutamento.udp(EmpCod, PesCod,'D')
		
		Do CAse				
			CAse  PesIsVen <> true
				&IsErroVendedor = true
				&mensagem = 'Vendedor é obrigatório.'
				do 'MensagemErro'
				
			CAse not &PesDtaDem.IsEmpty()
				&IsErroVendedor = true
				&mensagem = 'ATENÇÃO! Vendedor está demitido. Verifique!'
				do 'MensagemErro'
				
			Otherwise
				&IsErroVendedor = false
		EndCase
		
	When none
		&IsErroVendedor = true
		&mensagem = 'Vendedor é obrigatório.'
		do 'MensagemErro'
	EndFor
	
	&PedVenRaz = &PesCodRazSugg

EndSub

Sub 'LoadCliente'

	&IsErroCliente = false
	&PedCliObs = ''
	&PesCodRazSugg = ''
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		&PesCodRazSugg = PesCodRazSugg
		&PedCliCodVar = trim(str(&PedCliCod))
		
		&PedCliObs = trim(PesObs) + ' ' + trim(PesObsMas)
		&PedCliObs = &PedCliObs.Trim()
		
		Do Case
			Case PesSts <> Status_AtivoInativo.ATIVO and &Mode = TrnMode.insert //VERIFICAR REGRA
				&mensagem = 'Cliente com Cadastro inativado!'
				do 'mensagemErro'
			Case PesIsCli <> true and PesIsFor <> true
				&mensagem = 'Cliente é obrigatório!'
				do 'mensagemErro'
		EndCase		

		&PedCliCidCod = PesCidCod
		&PedCliTpcCod = TpcCod
		
		Exit
	When none
		&IsErroCliente = true
		&mensagem = 'Cliente é obrigatório!'
		do 'mensagemErro'
	EndFor
	
	&PesRazVar = &PesCodRazSugg
//	txtPedCliObs.Caption = &PedCliObs
	
	if  &IsErroCliente <> true			
		&PagamentoMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &PedCliCod, 'P')
		&CreditoMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &PedCliCod, 'C')
		&AvisoPedidoMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &PedCliCod, 'A')
		&VinculosMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &PedCliCod, 'V')
		&TotalMensagem = trim(&PagamentoMensagem) + trim(&CreditoMensagem) + trim(&AvisoPedidoMensagem) + trim(&VinculosMensagem)
	Endif

EndSub

Sub 'mensagemErro'

	Msg(&mensagem)

EndSub

Sub 'LocalizaPedidoDevolucao'

	If not  &DevPedCodOciRef.IsEmpty()
		&IsAchouPedidoDevolucao = false
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &DevPedCodOciRef
			
			&PedCliCodRaz = PedCliCodRaz_Nov
			&PedVenCodRaz = PedVenCodRaz
			
			&PedVlrBrt = PedVlrBrt
			&PedVlrLiq = PedVlrLiq
			
			&IsAchouPedidoDevolucao = true
			
			&PedCliObs = PedCliObs
					
			if LctAtuEst = Status_EntradaSaida.Saida
				&LctAtuEst = Status_EntradaSaida.Entrada
			Else
				&LctAtuEst = Status_EntradaSaida.Nenhum
			Endif
		
//			txtPedCliObs.Caption = &PedCliObs
			
			&PagamentoMensagem = RetornaObsClienteFORMULA.udp(EmpCod, FilCod, PedCod, PedCliCod, 'P')
			&CreditoMensagem = RetornaObsClienteFORMULA.udp(EmpCod, FilCod, PedCod, PedCliCod, 'C')
			&AvisoPedidoMensagem = RetornaObsClienteFORMULA.udp(EmpCod, FilCod, PedCod, PedCliCod, 'A')
			&VinculosMensagem = RetornaObsClienteFORMULA.udp(EmpCod, FilCod, PedCod, PedCliCod, 'V')
			&TotalMensagem = trim(&PagamentoMensagem) + trim(&CreditoMensagem) + trim(&AvisoPedidoMensagem) + trim(&VinculosMensagem)
			
			&PedFatFilCod = PedFatFilCod 
			
			If LctTip <> TipoLancamento.SaidaMercadoria and LctTip <> TipoLancamento.AmostraGratis
				&mensagem = 'Tipo Lançamento do Pedido à Devolver não é um Pedido de Saída!'
				do 'mensagemErro'
				&IsAchouPedidoDevolucao = false	
			Endif
			
			&PedVenCodVar = trim(str(PedVenCod))
			&PedVenCod = val(&PedVenCodVar)
			do 'LoadVendedor'
			
			&PedCliCodVar = trim(str(PedCliCod))
			&PedCliCod = val(&PedCliCodVar)
			do 'LoadCliente'
			
			Exit
		When none
			if not &DevPedCodOciRef.IsEmpty()
				&mensagem = 'Pedido não Localizado'
				do 'mensagemErro'
			Endif
			
		Endfor
	Endif

EndSub

Sub 'VisibleIvisible'

	tbMensagensFinanceiras.Visible = (&TotalMensagem <> '')	
	credito.Visible = (&CreditoMensagem <> '')
	pagamento.Visible = (&PagamentoMensagem <> '')
	aviso.Visible = (&AvisoPedidoMensagem <> '')
	Vinculos.Visible = (&VinculosMensagem <> '')

EndSub

Sub 'Sair'

	do case
		case &WizardData.SelecionarXML.DeOndeVem = 'WWPEDIDOCOMPRA'
			wwPedidoCompra.Link()
		Case &WizardData.SelecionarXML.DeOndeVem = 'WWNOTAS'
			wwNotas.Link()
		Case &WizardData.SelecionarXML.DeOndeVem = 'WWORDEMCOSTURA'
			WWORDEMCOSTURA.Link()
		Case &WizardData.SelecionarXML.DeOndeVem = 'WWDEVOLUCAOVENDA' 
			wwdevolucaoVenda.Link()
		Case &WizardData.SelecionarXML.DeOndeVem = 'WWDEVOLUCAOCOMPRA' 
			wwdevolucaoCompra.Link()
		Case &WizardData.SelecionarXML.DeOndeVem = 'WWPEDIDOVENDA'
			wwPedidoVenda.Link()
		otherwise
			wwPedidoCompra.Link()
	EndCase

EndSub

Sub 'loadTemporaria'

	For Each Order tmpNFeCod
		WHere tmpNFeCod = &tmpNFeCod
		&FilCod = tmpFilCod
		&tmpNfeFatFilCod = tmpNfeFatFilCod
		&NfeChv = tmpNfeChv
		&tmpEmixCod = tmpEmixCod
		&tmpNfeChvRef= tmpNfeChvRef
		&tmpEmixNom = trim(str(tmpEmixCod))+' - '+trim(tmpEmixNom)
		
		Exit
	EndFor

EndSub

Sub 'BuscaPedidoVenda'

	For each Order EmpCod,NfeProTer,NfeChv,NfeSts,NfeCod
		Where EmpCod = &EmpCod
		Where NfeProTer = 'P'
		Where NfeSts = Status_NFe.Autorizada
		Where NfeChv = &tmpNfeChvRef
		&devPedCodOciRef = NfePedCod 
		exit
	EndFor

EndSub


