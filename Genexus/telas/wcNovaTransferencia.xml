      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWTRANSFPRODUTO', Status_SimNao.Sim, 2, &AutNiv)
	loadwwpContext.Call(&WwpContext)
	do 'loadTransferencia'
	do 'TipoTransferencia'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrsEntTipLct.Visible = False
	&TrsEntNfeCod.Visible = False
	&TrsEntPedCod.Visible = False
	&TrsSaiTipLct.Visible = False
	&TrsSaiNfeCod.Visible = False
	&TrsSaiPedCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&FilCod = &TrsEntFiLCod
	do 'loadFilial'
	&TrsEntFilRaz = &FilRaz
	&IsErroFilialEntrada = &IsErro
	
	&FilCod = &TrsSaiFilCod
	do 'loadFilial'
	&TrsSaiFilRaz = &FilRaz
	&IsErroFilialSaida = &IsErro
	
	Do CAse
		Case &TrsDtaEms > serverdate()
			msg('Datas Futuras não permitido aqui!')
			&TrsDtaEms.SetFocus()
			
		CAse &IsErroFilialEntrada = true
			&TrsEntFiLCod.SetFocus()
			msg(&TrsEntFilRaz)
			
		Case &IsErroFilialSaida = true
			&TrsSaiFilCod.SetFocus()
			msg(&TrsSaiFilRaz)
			
		Otherwise
			prcGravaCapaTransferencia.Call(&OqueFazer, &EmpCod, &TrsCod, &TrsDtaEms, &TrsSaiFilCod, &TrsEntFiLCod, &TrsTip, &outTrsCod)
			wwpactions.WCPopup_Close(trim(Str(&outTrsCod)))
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserCancelar'

	wwpactions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &TrsSaiFilCod.IsValid

	&FilCod = &TrsSaiFilCod
	do 'loadFilial'
	&TrsSaiFilRaz = &FilRaz
	&IsErroFilialSaida = &IsErro

EndEvent

Event &TrsEntFiLCod.IsValid

	&FilCod = &TrsEntFiLCod
	do 'loadFilial'
	&TrsEntFilRaz = &FilRaz
	&IsErroFilialEntrada = &IsErro

EndEvent

Event &TrsTip.IsValid

	do 'TipoTransferencia'

EndEvent

Sub 'TipoTransferencia'

	Do CAse
		Case &TrsTip = 'I'
			txtInterna.Caption = 'Movimentação de estoque interna sem geração de nota fiscal.'
			txtInterna.ForeColor = RGB(255,0,0)
		Case &TrsTip = 'D' //REMESSA
			txtInterna.Caption = 'Emissão NOTA DE REMESSA para filial destino!'
			txtInterna.ForeColor = RGB(0,255,0)
		Case &TrsTip = 'R' //RETORNO
			txtInterna.Caption = 'Emissão NOTA DE RETORNO para filial destino!'
			txtInterna.ForeColor = RGB(0,0,255)
	EndCase

EndSub

Sub 'loadFilial'

	&IsErro = false
	&FilRaz.SetEmpty()
	For each ORder EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilRaz  = FilRaz
		Exit
	When none
		&FilRaz = 'FILIAL NÃO LOCALIZADA'
		&IsErro = true
	EndFor

EndSub

Sub 'loadTransferencia'

	For Each ORder EmpCod, TrsCod
		Where EmpCod = &EmpCod
		Where TrsCod = &TrsCod
		
		&TrsDtaEms = TrsDtaEms
		&TrsSaiFilCod = TrsSaiFilCod
		&TrsSaiFilRaz = TrsSaiFilRaz
		//TrsSaiPedCod
		//TrsSaiNfeCod
		&TrsSaiTipLct = TrsSaiTipLct
		&TrsSts = TrsSts
		&TrsEntFiLCod = TrsEntFiLCod
		&TrsEntFilRaz = TrsEntFilRaz
		//TrsEntPedCod
		//TrsEntNfeCod
		&TrsEntTipLct = TrsEntTipLct
		&TrsTip = TrsTip
		
		Exit
	When none
		&TrsDtaEms = serverdate()
		&TrsSaiFilCod = &WwpContext.FilCod
		&TrsEntFiLCod = &WwpContext.FilCod
		
		&FilCod = &TrsEntFiLCod
		do 'loadFilial'
		&TrsEntFilRaz = &FilRaz
		&IsErroFilialEntrada = &IsErro
		
		&FilCod = &TrsSaiFilCod
		do 'loadFilial'
		&TrsSaiFilRaz = &FilRaz
		&IsErroFilialSaida = &IsErro
	Endfor

EndSub


]]></Source>
