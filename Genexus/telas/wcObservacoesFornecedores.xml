Sub 'montacombo'

	&Fornecedor.Clear()
	&CountFornecedores = 1
	&Mensagem = '0 - TODOS OS FORNECEDORES'
	&Fornecedor.AddItem(0, &Mensagem)
	for Each Order EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		
		if CotComForSts = StatusCotacaoFornecedor.FINALIZADA
			&Mensagem = 'Forn'+trim(str(&CountFornecedores)) + ' - ' + trim(str(CotComForCod)) + ' - ' + trim(CotComForRaz)
			&Fornecedor.AddItem(CotComForCod, &Mensagem)
		Endif
	
		&CountFornecedores += 1
	
	EndFor

EndSub


