        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 920
	TableMain.Height = 420
	
	&EmpCod.Visible = False
	&PesCod.Visible = False

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Form.Caption = 'SÓCIOS DA EMPRESA'
	Do 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'loadPessoa'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For each Order EmpCod,PesCod,PesSocCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the data
	
	&Update = !'<i class="fa fa-pen"></i>'
	
	&Delete = !'<i class="fa fa-times"></i>'
	If (1=2)
		&Delete.Class = !'Attribute'
	Else
		&Delete.Class = !'Invisible'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&PesSocCod = PesSocCod
		&PesSocCpf = PesSocCpf
		&PesSocDtaNas = PesSocDtaNas
		&PesSocNom = PesSocNom
		&PesSocSts = PesSocSts
		&PesSocAdm = PesSocAdm
		load
	EndFor

EndEvent

Event &Update.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpSocio.PopUp('UPD', &EmpCod, &PesCod, &PesSocCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Delete.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpSocio.PopUp('DEL', &EmpCod, &PesCod, &PesSocCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAnexos'

	wpreferenciascomerciais.Popup(&EmpCod, &WWPContext.FilCod, &PesCod, 0)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpSocio.PopUp('INS', &EmpCod, &PesCod, 0)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'loadPessoa'

	For each order EmpCod,PesCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		&PesCodRaz = substr(PesCodRaz,1,50)
		&PesFan = substr(PesFan,1,50)
		&PesCnpj = PesCnpj
		exit
	EndFor

EndSub


