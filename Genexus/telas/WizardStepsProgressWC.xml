      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SelectedStepNumber = 1
	For &WizardStep in &WizardSteps
		If &WizardStep.Code = &CurrentStep
			WizardStepTitle.Caption = &WizardStep.Title
			If &WizardStep.Description <> ''
				WizardStepDescription.Caption = &WizardStep.Description
			Else
				WizardStepDescriptionCell.Visible = False
			Endif
			Exit
		Else
			&SelectedStepNumber += 1
		Endif
	Endfor
	&StepNumber = 1

EndEvent

Event GridWizardSteps.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do Case
		Case &StepNumber < &SelectedStepNumber
			UnnamedTableFSGridWizardSteps.Class = !'Flex CompletedStep'
		Case &StepNumber = &SelectedStepNumber
			UnnamedTableFSGridWizardSteps.Class = !'Flex CurrentStep'
		Otherwise
			UnnamedTableFSGridWizardSteps.Class = !'Flex RemainingStep'
	EndCase
	&StepNumber += 1

EndEvent


]]></Source>
