      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	scaProgressBar1.Visible = 0
	
	LoadWWPContext.Call(&wwpContext)
	do 'loadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	Return

EndEvent

Event Enter

	&NomeArquivo = 'OutrasSaidas' + trim(str(&PedCod))
	RCOOpenWindow1.LinkOpen = RELJAS016O.Link(&wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &wwpContext.PesCod, &NomeArquivo, &Ordem, &Varchar)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	
	&ProgressId = 'wpOutrasEntradas' + trim(Str(&wwpContext.EmpCod)) + trim(Str(&wwpContext.FilCod)) + trim(Str(&wwpContext.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	EsperaSegundos.Submit('', &ProgressId)

EndEvent

Sub 'loadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
	
		&FilCodNom = FilCodNom
		&PedDtaEms = PedDtaEms
		Exit
	EndFor

EndSub


]]></Source>
