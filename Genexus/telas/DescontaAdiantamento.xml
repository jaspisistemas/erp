      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	Do 'GetMovimento'
	&PesCod = &Context.PesCod
	
	RetornaAutorizacao.Call('ADIANTAMENTO_DESCONTARMANUAL', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesCod.Visible = False
	&MovCtaBanCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&IsAutorizado = false
	&Mensagem.SetEmpty()

	AtualizaAdiantamento.call(&EmpCod,&MovCod,&MovItmCod)
	return

EndEvent

Sub 'GetMovimento'

	For each Order EmpCod,MovCod,MovItmCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		Where MovItmCod = &MovItmCod
		
		&MovDta = MovDta
		&MovDtaCon = MovDtaCon
		&MovVlr = MovVlr
		&MovDoc = MovDoc		
		&MovCtaBanCod = MovCtaBanCod
		&MovCtaBanNom = str(MovCtaBanCod) +' - '+trim(MovCtaBanNom)
		&MovTip = MovTip
		&MovFunCod = MovFunCod
		&MovFunAno = MovFunAno
		&MovFunMes = MovFunMes
		&MovItmVlr = MovItmVlr
		
	EndFor

EndSub


]]></Source>
