      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&TipoPlanoVarchar	= 'D'
	TbAviso.Backcolor 	= RGB(254,221,88)
	&Aviso.ForeColor	= RGB(9,13,17)
	&Aviso 				= 'ATENÇÃO! Será gerado uma duplicata para os seguintes lançamentos, da viagem: ' + Trim(Str(&parmViaCod)) + '. Por favor, selecione uma data de vencimento para as demais.'	
	&CreDtaVct			= &Today.AddDays(1)
	&AuxViaDtaChe		= &Today
	
	Do 'LoadViagem'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount		= Grid.PageCount
	&GridCurrentPage	= Grid.CurrentPage
	&GridRows  			= Grid.Rows

EndEvent

Event Grid.Load

	&QtdDespesas	= 0
	&GridPageCount 	= 1
	&GridLinhaPag 	= 0
	&GridRows	  	= Grid.Rows
	
	For Each Order EmpCod, FilCod, ViaCod, ViaLanCod
		Where EmpCod		= &parmEmpCod				//Empresa
		Where FilCod		= &parmFilCod				//Filial
		Where ViaCod		= &parmViaCod				//Viagem
		Where ViaLanSts		= Status_AtivoInativo.ATIVO	//Ativo
		Where ViaLanTip		<> 'A' AND ViaLanTip <> 'DE'//Todas as DESPESAS	
				
		&gridViaLanFor		= ViaLanFor
		&gridViaLanPlanCod	= ViaLanPlanCod
		&gridViaLanCod		= ViaLanCod
		&gridViaLanDta		= ViaLanDta
		&gridViaLanObs		= ViaLanObs
		&gridViaLanVlr		= ViaLanVlr
		
		Do 'BuscaPessoa'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&GridLinhaPag += 1
		If &GridLinhaPag = &GridRows  
			&GridPageCount 	+= 1
			&GridLinhaPag	= 0
		EndIf
		
		&QtdDespesas += 1
		Load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do 'CheckRequiredFields' //Verifica se não há erros
	If &CheckRequiredFieldsResult = True	//se não houver erros	
		
		If &QtdDespesas >= 1
			prcAdicionaGravaDuplicataViagem.Call('INS', &parmEmpCod, &parmFilCod, &parmViaCod, &CreDtaVct, 0)
		EndIf
		prcAtualizaStatusViagem.Call(&parmEmpCod, &parmFilCod, &parmViaCod, 'F', &AuxViaVeiFinKM, &AuxViaDtaChe)
		
		WWPActions.WCPopup_Close('Ok')
		
	EndIf

EndEvent

Sub 'LoadViagem'

	For Each Order EmpCod, FilCod, ViaCod
		Where EmpCod = &parmEmpCod
		Where FilCod = &parmFilCod
		Where ViaCod = &parmViaCod
		
		&ViaVeiIniKM = ViaVeiIniKM
		&VeiPla		 = VeiPla
		
		Exit
	EndFor

EndSub

Sub 'CheckRequiredFields'

	&CheckRequiredFieldsResult = True
	
	If &QtdDespesas >= 1 And &CreDtaVct.IsEmpty()
		msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "A data de Vencimento das Duplicatas é obrigatória." ,DVMessageType.regular, "", DVMessageBoolean.True,""))		
		&CheckRequiredFieldsResult = False
		&CreDtaVct.SetFocus()
	EndIf
	
	If &AuxViaDtaChe.IsEmpty()
		msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "A data de Chegada é obrigatória." ,DVMessageType.regular, "", DVMessageBoolean.True,""))		
		&CheckRequiredFieldsResult = False
		&AuxViaDtaChe.SetFocus()
	EndIf
	
	If &AuxViaVeiFinKM.IsEmpty()
		msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "A quilometragem final do Veículo é obrigatória." ,DVMessageType.regular, "", DVMessageBoolean.True,""))		
		&CheckRequiredFieldsResult = False
		&AuxViaVeiFinKM.SetFocus()
	EndIf

	If &AuxViaVeiFinKM <= &ViaVeiIniKM
		msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "A quilometragem final do Veículo não pode ser menor que a inicial." ,DVMessageType.regular, "", DVMessageBoolean.True,""))		
		&CheckRequiredFieldsResult = False
		&AuxViaVeiFinKM.SetFocus()
	EndIf

EndSub

Sub 'BuscaPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &parmEmpCod
		Where PesCod = &gridViaLanFor
		
		&gridPesCodRaz = PesCodRaz
		
		Exit
	When None
		&gridPesCodRaz = 'NÃO INFORMADO'
	EndFor

EndSub


]]></Source>
