      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	
	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		
		&CrePLancod = CrePlanCod
		&CrePlanHie = CrePlanHie
		Exit
	EndFor

	&CrePlanCodNomVir = &CrePlanHie
	
	tbFuncionario.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Height = 200
	&EmpCod.Visible = False
	&CreRecPag.Visible = False
	&AuxPlanCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	retornaCodigoPlanoContas.Call(&EmpCod, &CrePlanCodNomVir, &CrePLancod)
	RetornaPlanCodNomVir.Call(&EmpCod, &CrePLancod, &PlanNom)

	if &CrePLancod.IsEmpty()
		msg('Plano de Contas inválido!')
	Else
		prcAlterarDadosLancamentoDuplicata.Call(&EmpCod, &FilCod, &CreCod, &CrePLancod)
		
		Return
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CrePlanCodNomVir.IsValid

	retornaCodigoPlanoContas.Call(&EmpCod, &CrePlanCodNomVir, &CrePLancod)

EndEvent


]]></Source>
