Sub 'loadPedidoAberto'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
//		if &FilImg146_50.IsEmpty() //IMAGEM FILIAL
//			if FilImg_LogRel.IsEmpty()
//				&FilImg146_50.FromImage(FilialSemImagem)
//			Else		
//				&FilImg146_50 = FilImg_LogRel
//			EndIF		
//		EndIF
		
		&PedVlrLmt = PedVlrLmt
		&TabCod = TabCod
		&TabPrmCod = TabPrmCod
		&TabColCod = TabColCod
		&PedDtaEms = PedDtaEms
		&PedHorEms = PedHorEms
		&Mensagem = 'CLIENTE: ' + trim(PedCliCodRaz)
		Cliente.Caption = Substr(&Mensagem, 1, 32)
		
		If PedCliTip = TipoPessoa.JURIDICA
			&Mensagem = 'CNPJ: ' + trim(PedCliCnpj) 
		Else
			&Mensagem = 'CPF: ' + trim(PedCliCpf)
		EndIF
		
		Cpf.Caption = &Mensagem
		Exit
	When none		
		pdv_m.Link()
	EndFor

EndSub

