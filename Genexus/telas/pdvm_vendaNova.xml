	&Mensagemerro = ''
	&TotalProdutoMoeda = 0
	
	If not &CodigoProduto.IsEmpty()
        //pega a posicao do * para ver se possui quantidade
        &posicao = &CodigoProduto.IndexOf('*', 1)
        &posicaoFinalQtd = &posicao - 1
		
		//NOVO CODIGO DE BARRAS
        If &posicao <> 0
            &posicao += 1 
            &NovoProBar = substr(&CodigoProduto, &posicao, 18)       
        Else
            &NovoProBar = Substr(&CodigoProduto,1, 18)		
        EndIF
		
        Do CAse
			CAse &posicaoFinalQtd > 0 //QUANTIDADE INFORMADA MANUAL
	            &PedQtd = val(substr(&CodigoProduto, 1, &posicaoFinalQtd))
	            If &PedQtd <= 0
	                &PedQtd = 1
	            EndIf		
				
			Case &NovoProBar.Substring(1,1) = '2' and &NovoProBar.Length() = 13 //QTD BALANCA
				&TotalProdutoMoeda = val(substr(&NovoProBar,8,5)) 
				&TotalProdutoMoeda = &TotalProdutoMoeda / 100
				&PedQtd = 1
				
				&NovoProBar = Substr(&NovoProBar, 2, 6)
				
			Otherwise //QTD AUTOMATICA
	            &PedQtd = 1
        EndCase		
		
		//PRODUTO
		&IsAchouProduto = false
		&ProNom = ''
		&ProCod = 0
		&ProGraCod = 1
		
		RetornaProdutoReferencia.Call(&EmpCod, &NovoProBar, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &MensagemErro)
		do 'AttributesSecurityCode'
		
		if not &Mensagemerro.IsEmpty()
			&Mensagemerro = &Mensagemerro.ToUpper()
			do 'SonErro'
			&CodigoProduto.SetFocus()
			
		Else //SE DEU ERRO JA PARA SENAO PEGA PRECO, ...
			RetornaImagemPrincipal180.Call(&EmpCod, &ProCod, TipoImagemProduto.IMAGEM_VENDA, &ProImg180, &IsSemImagem)
			
			if &ProReqVlr = true and &ProReqQtd = false				
				&auxPedVlrUnt.SetFocus()
			Else
				//if &Multiplicador = 1 //DEVOLVER VAI ABRIR UM POUPOP
				do 'GetPreco'
				//Else
				//do 'GetPrecoPedido'
				//EndIF
				
				If &PedVlrItm > 0
					if &TotalProdutoMoeda > 0
						&PedQtd = ROUND(&TotalProdutoMoeda / &PedVlrUnt, 3)
						&PedVlrItm = &TotalProdutoMoeda
					EndIF
					
					If &ProReqQtd = true
						&auxPedQtd = &PedQtd
						&auxPedVlrUnt = &PedVlrUnt
						&auxPedQtd.SetFocus()
					Else
						//						If &Multiplicador = 1 //DEVOLVER VAI ABRIR UM POUPOP
						do 'GravaItemPDV'
						//						Else
						//							do 'GravaItemPDVdevolucao'
						//						EndIF
					EndIF
				Else
					&Mensagemerro = 'PRODUTO NÃO LOCALIZADO NO PED.!'
					
					do 'SonErro'
					&CodigoProduto.SetFocus()
				Endif
			EndIF
		EndIF	
	EndIF
	
	&CodigoProduto.SetEmpty()
	
//	If &ProReqQtd = false and &ProReqVlr = false
//		&CodigoProduto.SetFocus()
//	EndIF
//

EndSub

Sub 'GravaItemPDV'

	&PedQtdCan = 0
	&PedItmDsc = 0
	&PedItmCod = 0
	Do 'TestaLimiteCreditoFicha'
	If &IsLimiteErro = False
		GravaItemPedidoVenda_PDV.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &ProCod, &ProGraCod, &PedQtd, &PedQtdCan, &PedVlrUnt, &PedVlrTab, &PedItmDsc, '',&PedVenCod, &PedCodOciRefItm, &MensagemInserida, &MensagemAlterado, &Context.UserName)
		
		if &PedItmCod = 1
			pdv_AtualizaEmissao.Call(&EmpCod, &FilCod, &PedCod)
		EndIF
		
		do 'ItensTotal'
	Else
		&Mensagemerro = 'LIMITE DE CRÉDITO EXCEDIDO, DIRIJA-SE AO CAIXA PARA FAZER O ACERTO!'
		do 'SonErro'
	EndIf
	&CodigoProduto.SetFocus()

EndSub

Sub 'ITensTotal'

	wcTot.Refresh()
	WCwcItensPDV_VendaNova.Refresh()

EndSub

Sub 'TestaLimiteCreditoFicha'

	if &PedVlrLmt > 0
		&IsLimiteErro = False
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			If PedVlrLmt > 0 
				If (PedVlrLiq+&PedVlrItm) >=  PedVlrLmt
					&IsLimiteErro = True
				EndIf
			EndIf
			Exit
		EndFor
	Endif

EndSub

Sub 'getPreco'

	&PedVlrUnt = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
	&PedVlrTab = &PedVlrUnt 
	
	&PedItmPrm = RetornaPrecoUnitarioTipo.Udp(&EmpCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedItmDsc)

	Promocao.Caption = iif(&PedItmPrm = domPedItmPrm.NORMAL, '', 'PROMOÇÃO')

	&PedVlrItm = &PedVlrUnt * &PedQtd

EndSub

Sub 'SonErro'

	&ProImg325.FromImage(imgErro)
	
	if &TCon089_ExecutarSonsErro <> 'N'
		&IsErroUmaVEz = true // quando fechar ver se é true se for executar um som sem som.
		if &TCon089_ExecutarSonsErro = 'S'
			EmbPage1.Source = 'sons/erroalto.wav'
		Else
			EmbPage1.Source = 'sons/erro.wav'
		endif
	EndIf

	do 'AttributesSecurityCode'

EndSub


