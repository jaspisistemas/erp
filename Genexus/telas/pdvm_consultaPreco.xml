        <Source><![CDATA[
Event Start

	cnsPrm.ForeColor = RGB(230,45,45)
	&ProImg180.FromImage(Produto_Sem_Imagem)
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tab2.Height = 50
	tab1.Height = 50

	Do 'AttributesSecurityCode'
	&TabCod.Visible = False
	&FilCod.Visible = False
	&TabColCod.Visible = False
	&ProGraCod.Visible = False
	&TabPrmCod.Visible = False
	&auxPedVlrUnt.Visible = False
	&PedDtaEms.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		If FilBalTabCod.IsEmpty() or FilBalTabCod.IsNull()
			&TabCod = FilTabCod
			&TabPrmCod = FilTabPrmCod
			&TabColCod = FilTabColCod
		Else
			&TabCod = FilBalTabCod
			&TabPrmCod = FilBalTabPrmCod
			&TabColCod = FilBalTabColCod
		Endif
	
		Exit
	EndFor

	&ProGraCod = 1	
	&PedDtaEms = serverdate()

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&PrmPedVlrUnt > 0)
		&PrmPedVlrUnt.Visible = False
		PrmPedVlrUnt_Cell.Class = !'Invisible'
	Else
		&PrmPedVlrUnt.Visible = True
		PrmPedVlrUnt_Cell.Class = !'CellPaddingLeft10'
	EndIf
	
	tab1.Visible = (&PrmPedVlrUnt = 0)
	tab2.Visible = (&PrmPedVlrUnt > 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CodigoProduto.SetFocus()

EndEvent

Event Enter

	Return

EndEvent

Event &CodigoProduto.IsValid

	&PedVlrUnt = 0
	&PrmPedVlrUnt = 0
	&ProImg180.FromImage(Produto_Sem_Imagem)
	&IsAchouProduto = false
	&ProCodNom = ''
	&ProGraCod = 1
	&PedVlrUnt.SetEmpty()
	
	&NovoProBar = &CodigoProduto
	
	RetornaProdutoReferencia.Call(&EmpCod, &NovoProBar, &ProCod, &ProGraCod, &ProCodNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &MensagemErro)

	if &IsAchouProduto = true
		For Each Order EmpCod, ProCod, ProImgPri
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			Where ProImgPri = true
			&ProImg180 = ProImg180
			Exit
		When none
			&ProImg180.FromImage(Produto_Sem_Imagem)
		EndFor
		Do 'Estoque'
		
		Do 'GetPreco'
	EndIF
	&CodigoProduto.SetFocus()

EndEvent

Sub 'getPreco'

	&PedVlrUnt = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, '', &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
	&auxPedVlrUnt = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
	if &auxPedVlrUnt < &PedVlrUnt
		&PrmPedVlrUnt = &auxPedVlrUnt
		cnsPrm.Caption = 'Produto na Promoção de R$ ' + trim(toformattedString(&PedVlrUnt)) + ' por R$ ' + trim(toformattedString(&auxPedVlrUnt))
	EndIF
	Do 'AttributesSecurityCode'

EndSub

Sub 'Estoque'

	For Each Order EmpCod, FilCod, ProCod,ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		&EstQtd = EstQtd
		&EstSdo = EstSdo
		exit
	EndFor

EndSub


]]></Source>
