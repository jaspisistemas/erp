        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPedidoProduto.Rows = Page.Rows
	&GridPedidoProdutoCurrentPage = 1
	&GridPedidoProdutoCurrentPage.Visible = False
	&GridPedidoProdutoPageCount = -1
	GridPedidoProdutoPaginationBar.RowsPerPageSelectedValue = GridPedidoProduto.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPedidoProdutoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPedidoProdutoCurrentPage	= GridPedidoProduto.CurrentPage
	&GridPedidoProdutoPageCount		= GridPedidoProduto.PageCount

EndEvent

Event GridPedidoProduto.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&QuantidadeFormatada6 	= PedQtd
&PedQtdVarchar 			= trim(toformattedString(&QuantidadeFormatada6)) 
RetiraZerosDepoisVirgula.Call(&PedQtdVarchar, &PedQtdVarchar)
	&PedVlrUntVarchar = trim(toformattedString(PedVlrUnt)) 
RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntVarchar, &PedVlrUntVarchar)
	&PedItmDscVarchar = trim(toformattedString(PedItmDsc)) 
RetiraZerosDepoisVirgula.Call(&PedItmDscVarchar, &PedItmDscVarchar)
	&PedVlrUntDscVarchar = trim(toformattedString(PedVlrUntComDsc)) 
RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntDscVarchar, &PedVlrUntDscVarchar)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPedidoProdutoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPedidoProdutoPaginationBar.SelectedPage = !'Previous'
			&GridPedidoProdutoCurrentPage -= 1
			GridPedidoProduto.PreviousPage()
		Case GridPedidoProdutoPaginationBar.SelectedPage = !'Next'
			&GridPedidoProdutoCurrentPage += 1
			GridPedidoProduto.NextPage()
		Otherwise
			&PageToGo.FromString(GridPedidoProdutoPaginationBar.SelectedPage)
			&GridPedidoProdutoCurrentPage = &PageToGo
			GridPedidoProduto.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPedidoProdutoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPedidoProduto.Rows = GridPedidoProdutoPaginationBar.RowsPerPageSelectedValue
	&GridPedidoProdutoCurrentPage = 1
	GridPedidoProduto.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


