      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &Pedcod
		&PedCliCodRaz = PedCliCodRaz
		
		if PedStsFut = VendaFutura.BloqueiaVendaFutura
			&Mensagem = 'PEDIDO COM ENTREGA FUTURA'
			&PedStsFut = VendaFutura.NaoBloqueado
		Else
			&PedStsFut = VendaFutura.BloqueiaVendaFutura
			&Mensagem = 'PEDIDO VENDA'
		Endif
	
		Exit
	Endfor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PedStsFut.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	AtualizaVendaFutura.Call(&EmpCod, &FilCod, &Pedcod, &PedStsFut)
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
