        <Source><![CDATA[
Event Start

	&RemoverVinculoCaixa = true
	&RemoverVinculoDuplicata = true
	txtAlerta.Caption = ''
	RetornaAutorizacao.Call('WWDUPLICATAS_DESVINCULAPAGAMENTO', Status_SimNao.Nao, 1, &Autniv)
	&RemoverVinculoCaixa.Enabled = &Autniv

	do 'duplicata'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRemoverPagamentoDuplicata'

	if &RemoverVinculoCaixa = false
		DeletarPagamento.Call(&EmpCod,&FilCod,&CreCod,&CrePagCod)
		Refresh
	Else
		
		//VerificaCaixaAberto
		
		if &IsCaixaFechadoEmissao = false and &IsCaixaFechado = false
			//Autorizado excluir
			&webSession.set('DuplicataPagamento',&sdtDeleteMovimentoItem.ToXml())
			DeletaMovimentoComDependenciasDuplicata.Call(&EmpCod,&MovCod,&CreMovItmCod,&IsTransferencia,&IsFolhaPgto,&IsDuplicata)
		Endif
	Endif

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'duplicata'

	For Each Order EmpCod, FilCod, CreCod, CrePagCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		Where CrePagCod = &CrePagCod
		
		&MovCod = CreMovCod
		&CreMovItmCod = CreMovItmCod
				
		Exit
	EndFor
		
		
	
	For Each Order EmpCod, MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		
		PrcValidaCaixaAberto.Call(EmpCod, MovCtaBanCod, MovDtaCon, &IsCaixaFechado, &Mensagem)
		PrcValidaCaixaAberto.Call(EmpCod, MovCtaBanCod, MovDta, &IsCaixaFechadoEmissao, &MensagemEmissao)
		
		
		Do Case
			Case MovSts = Status_Caixa.Cancelado
				txtAlerta.Caption = 'Movimento Cancelado já'
				txtalerta.ForeColor = RGB(255,0,0)
				btnRemoverPagamentoDuplicata.Visible = 0
				&IsCaixaFechado = TRUE
				
			Case &IsCaixaFechado = true
				txtAlerta.Caption = &Mensagem
				txtalerta.ForeColor = RGB(255,0,0)
				btnRemoverPagamentoDuplicata.Visible = 0
				
			CAse &IsCaixaFechadoEmissao = true
				txtAlerta.Caption = &MensagemEmissao
				txtalerta.ForeColor = RGB(255,0,0)
				btnRemoverPagamentoDuplicata.Visible = 0
				&IsCaixaFechado = TRUE
				
			Case not MovFecCod.IsNull() and not MovFecCod.IsEmpty()
				txtAlerta.Caption = 'Movimento já fechado pelo PDV'
				txtalerta.ForeColor = RGB(255,0,0)
				btnRemoverPagamentoDuplicata.Visible = 0
				&IsCaixaFechado = TRUE
				
			case MovTip = TipoMovimento.DescontoDuplicataCheque
				txtAlerta.Caption = 'Não é possível excluir movimentos de duplicatas e/ou cheques descontados.'
				txtalerta.ForeColor = RGB(255,0,0)
				btnRemoverPagamentoDuplicata.Visible = 0
				&IsCaixaFechado = TRUE
		EndCase
		
		For Each Order EmpCod, MovCod, MovItmCod
			Where MovItmCod = &CreMovItmCod
			&sdtDeleteMovimentoItemItem = new()
			&sdtDeleteMovimentoItemItem.MovItmCod    = MovItmCod
			&sdtDeleteMovimentoItemItem.MovItmVlr    = MovItmVlr
			&sdtDeleteMovimentoItemItem.PlanCod       = PlanCod
			&sdtDeleteMovimentoItemItem.MovItmCpl    = MovItmCpl
			&sdtDeleteMovimentoItemItem.MovCreFilCod = MovCreFilCod
			&sdtDeleteMovimentoItemItem.MovCreCod    = MovCreCod		
			&sdtDeleteMovimentoItemItem.MovCrePagCod = MovCrePagCod
			&sdtDeleteMovimentoItemItem.MovTrnOriCod = MovTrnOriCod
			&sdtDeleteMovimentoItemItem.MovTrnOriCodItm = MovTrnOriCodItm
			&sdtDeleteMovimentoItemItem.MovFunAno    = MovFunAno
			&sdtDeleteMovimentoItemItem.MovFunMes    = MovFunMes
			&sdtDeleteMovimentoItemItem.MovFunCod    = MovFunCod
		 
			Do Case
				Case MovTrnOriCod.IsEmpty() and MovTrnOriCodItm.IsEmpty() and PlanUtiTra = true
					&IsTransferencia = True
				Case not MovTrnOriCod.IsEmpty() and not MovTrnOriCodItm.IsEmpty()
					&IsTransferencia = True
				Case not MovCreCod.IsEmpty() and not MovCreFilCod.IsEmpty()
					&IsDuplicata = True
				Case (not MovFunAno.IsEmpty()) and (not MovFunMes.IsEmpty()) and (not MovFunCod.IsEmpty())
					&IsFolhaPgto = True
			Endcase	
			
			&sdtDeleteMovimentoItem.Add(&sdtDeleteMovimentoItemItem)
		EndFor
	
		Exit
	EndFor

EndSub


]]></Source>
