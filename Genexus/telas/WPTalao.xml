        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWTALAO', Status_SimNao.Sim, 3, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	Do Case
		Case &TalFolQtd <= 0
			msg('Informe a Quantidade de Folhas de Cheques do Talão!')
			&TalFolQtd.SetFocus()
		Case &TalFolIni <= 0
			msg('Sequência inicial tem que ser maior que 0')
			&TalFolIni.SetFocus()
		Otherwise
			DVelop_ConfirmPanel_Confirmar.ConfirmationText = 'Confirma o lançamento do Talão com os cheques números ' + trim(str(&TalfolIni)) + ' até ' + trim(Str(&TalFolfin))+' ?'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Confirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

EndEvent

Event DVelop_ConfirmPanel_Confirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Confirmar.Result = !'Yes'
		Do 'Do Action Confirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Confirmar'

	ValidaCheques.Call(&EmpCod,&TalCtabanCod,&TalFolIni,&TalFolfin,&Mensagem,&IsErro)
	IF &IsErro = false
		GravaTalaoCheques.Call(&EmpCod,&TalCtabanCod,&TalFolIni,&TalFolfin,&TalFolQtd,&TalDTaEnt,&TalObs,&TalCtaBanCrt,&TalCtaBanBanCod,&TalCtaBanAge)
		Return
	Else
		msg(&Mensagem)
		&TalFolQtd.SetFocus()
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &TalCtabanCod.IsValid

	Do 'BancoConta'

EndEvent

Event &TalFolQtd.IsValid

	&TalFolfin = (&TalFolIni + &TalFolQtd - 1)

EndEvent

Sub 'BancoConta'

	For each Order EmpCod,CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &TalCtabanCod
		&TalCtaBanCrt = CtaBanCrt 
		&TalCtaBanBanCod = CtaBanBanCod
		&TalCtaBanAge = CtaBanAgeCod
		Exit
	EndFor

EndSub


]]></Source>
