      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid_DWC.Class = !'Invisible WCD_' + upper(Grid.InternalName)
	
	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	DDO_Grid.GridInternalName = Grid.InternalName

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	ProGraRef.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetornaAutorizacao.Call('WWPRODUTO', Status_SimNao.Nao, 1, &AutNivProduto)
	RetornaTelaProduto.call(&Context.EmpCod, &LinkMensagem)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&AlterarItem = !'<i class="fa fa-pen"></i>'
	
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'
	
	&EliminarItem = !'<i class="fa fa-times"></i>'
	
	&PedVlrUntVarchar = trim(toformattedString(PedVlrUnt)) 
	RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntVarchar, &PedVlrUntVarchar)
	&PedVlrUntDscVarchar = trim(toformattedString(PedVlrUntDsc)) 
	RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntDscVarchar, &PedVlrUntDscVarchar)
	ProGraRef.ColumnClass = iif(ProSts = Status_Produto.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	PedProNom.LinkTarget = '_blank'
	if &AutNivProduto > 1
		if &LinkMensagem = 'WWPRODUTO'
			PedProNom.Link = Produtos.Link('', TrnMode.Update, EmpCod, ProCod, '')
		Else
			PedProNom.Link = impProduto.Link(TrnMode.Update, EmpCod, ProCod)
		EndiF
		
	Else
		PedProNom.Link = VerProduto.Link('DashBoard', EmpCod, ProCod)
		PedProNom.LinkTarget = '_blank'
	EndiF
	
	&AuxPedQtdEmb = PedQtdEmb
	&AuxPedQtd = PedQtd
	&PedProEmbQtd = PedProEmbQtd
	Do Case
		Case PedProEmbQtd <> 1 and PedProEmbQtd > 0
			&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			
			&PedQtd = &Varchar
			
			&Varchar = trim(toformattedString(&PedProEmbQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' X ' + trim(&Varchar) 
			
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' (' + trim(&Varchar) + ')'
			
		Case PedProEmbQtd < 0
			&PedProEmbQtd = &PedProEmbQtd *-1
			&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd = trim(&Varchar)
			
			&Varchar = trim(toformattedString(&PedProEmbQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' / ' + trim(&Varchar) 
			
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' (' + trim(&Varchar) + ')'
			
		Otherwise
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd = trim(&Varchar)
	EndCase

EndEvent

Event &EliminarItem.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod_Selected = EmpCod
	&FilCod_Selected = FilCod
	&PedCod_Selected = PedCod
	DVelop_ConfirmPanel_EliminarItem.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_EliminarItem.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_EliminarItem.Result = !'Yes'
		Do 'Do EliminarItem'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DetailWebComponent.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_DWC.Object = wbDetalheImpostoProduto.Create(EmpCod, FilCod, PedCod, PedItmCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do EliminarItem'

	DeletaItemPedidoCompra.Call(EmpCod, FilCod, PedCod, PedItmCod)
	
    grid.Refresh()
	Msg('Produto eliminado com sucesso!')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	If 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"EMPCOD"
				&EmpCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"FILCOD"
				&FilCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PEDCOD"
				&PedCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"PROGRANOM"
				&ProGraNom.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
