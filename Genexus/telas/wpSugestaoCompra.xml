      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPSUGESTAOCOMPRA', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	&FilCodNom = trim(str(&Context.FilCod)) + ' - ' + trim(&Context.FilRaz)

	

	&ArredondarQuantidades 	= Status_SimNao.Nao
	&ImprimirConcorrentes 	= Status_SimNao.Nao
	&ImprimirTodosProdutos 	= Status_SimNao.Nao
	&ImprimirSomentePadrao 	= Status_SimNao.Nao

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAjuda'

	innewWindow.Target = 'https://ajuda.jaspi.com.br/index.aspx?fa1d623d-694f-4921-92dd-9361d60456f9'
	inNewWindow.Name = '_blank'
	innewWindow.OpenWindow()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'Cliente'

EndEvent

Event &PesCod.IsValid

	do 'Cliente'

EndEvent

Event Enter

	do 'Cliente'
	RCOOpenWindow1.LinkOpen = RELJAS012.Link(&Context.EmpCod, &Context.FilCod, &PesCod, &GrupHie, &Ordem, &ArredondarQuantidades, &ImprimirTodosProdutos, &ImprimirConcorrentes, &ImprimirSomentePadrao, &ImprimirSemFonecedor)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'Cliente'

	For Each Order EmpCod, PesCod
		Where EmpCod = &Context.EmpCod
		Where PesCod = &PesCod
		&PesRaz = PesRaz
		Exit
	When None
		If &PesCod <> 0
			&PesRaz = 'FORNECEDOR NÃO LOCALIZADO'
		Else
			&PesRaz = 'TODOS OS FORNECEDORES'
		EndIF
	EndFor

EndSub


]]></Source>
