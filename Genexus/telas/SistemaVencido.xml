Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbmsgg.Visible = (&nivel > 0)
	If not(&IsADM = true)
		DVPanel_tbAdm_Cell.Class = !'Invisible'
	Else
		DVPanel_tbAdm_Cell.Class = !'col-xs-12 CellMarginTop'
	EndIf
	If not(&IsVisivelResultado = true)
		DVPanel_UnnamedTable4_Cell.Class = !'Invisible'
	Else
		DVPanel_UnnamedTable4_Cell.Class = !'col-xs-12 CellMarginTop'
	EndIf
	UnnamedTable5.Visible = (1=2)
	If not(&nivel > 0)
		DVPanel_TableContent12_Cell.Class = !'Invisible'
	Else
		DVPanel_TableContent12_Cell.Class = !'col-xs-12 CellMarginTop'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	LoadwWPContext.Call(&context)
	If &context.PesCod = 0 or &context.EmpCod = 0 or &context.FilCod = 0
		Login.Link('','')
	EndIF

EndEvent

Sub 'GravaLIcenca'

	&IsVisivelResultado = true
	
	if not &MsgChv.IsEmpty()
		gravaLicenca.Call(&EmpCod, &MsgChv)
		
		VerificaLicenca.Call(&EmpCod, &MsgChv, &EmpCodSec, '', &IsOk)	
		if &IsOk = true
			Login.Link('','')
		EndIF
	EndIF

EndSub


