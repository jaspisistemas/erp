        <Source><![CDATA[
Event Start

	LoadwWPContext.Call(&context)
	If &context.PesCod = 0 or &context.EmpCod = 0 or &context.FilCod = 0
		Login.Link('','')
	EndIF 
	
	&UserNick = &GAMUser.GetName()
	
	If &context.Old_Perfil <> 3 //USUARIOS SISTEMAS		
		RetornaAutorizacaoAdministrador.Call(&Context.EmpCod, &Context.PesCod, &IsADM)
		btnEntrarSuporte.Visible = 0
	Else
		&IsADM = true
		btnEntrarSuporte.Visible = 1
	EndIF
	
	&IsVisivelResultado = false
	
	&QtdDias = 999
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		txtDadosEmpresa.Caption = 'Autorizar: ' + trim(EmpRaz) + ' CNPJ:' + trim(EmpCpfCnpj)
		getVencimento.Call(&EmpCod, EmpCodSec, &jaspi, &VencimentoData, &EmpCodSec, &QtdDias)
		Exit
	EndFor
	if &QtdDias <= 15
		Login.Link('','')
	EndIF
	
	//AVISA DUPLICATA DISPONIVEL
	AvisoDuplicataJASPI.Visible = 0
	AvisoDuplicataJASPI1.Visible = 0 
	
	prcAvisoDuplicataJaspi.Call(&EmpCod, &Mensagem, &nivel)
	&Mensagem = 'SISTEMA VENCIDO!, Efetue a quitação dos débitos para poder continuar a utilizar o sistema!'
	AvisoDuplicataJASPI.Caption = &Mensagem	
	If &nivel > 0
		//link duplicatas Jaspi
		PadraoUsuario.Call('L', '#VENCIMENTODUPLICATAJASPI#', 1, &EmpCod, &PadObs, &PadDtaMod)
		if not &PadObs.IsEmpty()
			&dupCreDtavct = CtoD(Substr(&PadObs,1,10))
			&Cryptografado = Substr(&PadObs,11,37)
			
			CodigoExternoDuplicata.Call(&Cryptografado, 0, 0, 0, 0, &dupCreDtavct, &Cryptografado)
			&Varchar = 'http://app.jaspi.com.br/areacliente.aspx?' + &Cryptografado.Trim()
			AvisoDuplicataJASPI1.LinkTarget = '_blank'
			AvisoDuplicataJASPI1.Link = &Varchar.Trim()
			AvisoDuplicataJASPI1.Visible = 1
		Endif
		
		AvisoDuplicataJASPI.ForeColor = RGB(170,0,0)
		AvisoDuplicataJASPI.Visible = 1
		
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable2.Height = 55
	UnnamedTable1.Height = 15

	Do 'AttributesSecurityCode'
	&IsADM.Visible = False
	&EmpCod.Visible = False
	&PadObs.Visible = False
	&Nivel.Visible = False
	&IsVisivelResultado.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGravarChave'

	&MsgChv = &ChaveLiberacao
	do 'GravaLIcenca'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEntrarSuporte'

	LoadwWPContext.Call(&context)
	if &Context.Old_Perfil = 3 //SUPORTE JASPI
		VerificaLicenca.Call(&EmpCod, &MsgChv, &EmpCodSec, 'SUPORTE.JASPI', &IsOk)
		Dashboard.Link()
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&IsVisivelResultado = false
//	&ppJASPI_LicencaSistemasdtLicenca.MsgRet = ''
	Do 'AttributesSecurityCode'
//	For Each Order EmpCod
//		Where EmpCod = &EmpCod
//		&EmpCodSec = EmpCodSec
//		
//		HostWebServiceJaspiADM.Call(&EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
//		&Location = GetLocation('ppJASPI_LicencaSistema') //objeto externo onde foi importado o WSDL no GX XEV1 
//		&Location.Host = &EmpWebHost //servidor 
//		&Location.Port = &EmpWebPor //porta  
//		&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
//		&Location.Secure = false //false 
//		&Location.CancelOnError = 2 //tratar exceção do WS 	
//		
//		&ppJASPI_LicencaIn.CliCodSync = EmpCodSec.Trim()
//		&ppJASPI_LicencaIn.CliVer = EmpVer.Trim()
//		&ppJASPI_LicencaIn.His1 = ''
//		&ppJASPI_LicencaIn.His2 = ''
//		&ppJASPI_LicencaIn.His3 = ''
//		
//		&ppJASPI_LicencaSistemasdtLicenca = &ppJASPI_LicencaSistema.Execute(&ppJASPI_LicencaIn)
//		
//		If GetSOAPErr()= 0 
//			Exit
//		Else
//			retorno.Caption = GetSOAPErrMsg()
//			&IsVisivelResultado = true
//		EndIf		
//		
//		Exit
//	EndFor
	getLicenca.Call(&EmpCod, &MensagemRetornoLicenca)
	&IsVisivelResultado = true
	retorno.Caption = &MensagemRetornoLicenca
	
	If &MensagemRetornoLicenca.IsEmpty()		
		For Each Order EmpCod
			Where EmpCod = &EmpCod
			VerificaLicenca.Call(EmpCod, EmpChv, EmpCodSec, '', &IsOk)	
			if &IsOk = true
				Login.Link('','')
			EndIF
		EndFor
	EndIF

	Do 'AttributesSecurityCode'

