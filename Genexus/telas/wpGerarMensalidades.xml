        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWMENSALIDADES', Status_SimNao.Sim, 3, &AutNiv)
	loadwwpContext.Call(&wwpcontext)
	padraousuarioHora.Call('L', '#WPGERARMENSALIDADES#', &wwpcontext.PesCod, &wwpcontext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'T')
	&SdtServicosSelecionados.FromJson(&PadObs)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtServicosSelecionadoss.Rows = 5
	GridsdtServicosSelecionadossPaginationBar.RowsPerPageSelectedValue = GridsdtServicosSelecionadoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtServicosSelecionadossCurrentPage = GridsdtServicosSelecionadoss.CurrentPage
	&GridsdtServicosSelecionadossPageCount = GridsdtServicosSelecionadoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtServicosSelecionadoss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtServicosSelecionadossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtServicosSelecionadossPaginationBar.SelectedPage = !'Previous'
			GridsdtServicosSelecionadoss.PreviousPage()
		Case GridsdtServicosSelecionadossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtServicosSelecionadoss.CurrentPage
			&PageToGo += 1
			GridsdtServicosSelecionadoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtServicosSelecionadossPaginationBar.SelectedPage)
			GridsdtServicosSelecionadoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtServicosSelecionadossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtServicosSelecionadoss.Rows = GridsdtServicosSelecionadossPaginationBar.RowsPerPageSelectedValue
	GridsdtServicosSelecionadoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&GUID = GUID.NewGuid()
	&ProgressId = &GUID.ToString()
	scaProgressBar.ProcessId = &ProgressId
	scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar.Start()
	
	prcGeraLancamentoServicoPedidos.Submit(&ProGressId, &ProGressId, &wwpcontext.EmpCod, &wwpcontext.PesCod, &wwpcontext.UserName, &sdtServicosSelecionados)
	padraousuarioHora.Call('X', '#WPGERARMENSALIDADES#', &wwpcontext.PesCod, &wwpcontext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'T')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

