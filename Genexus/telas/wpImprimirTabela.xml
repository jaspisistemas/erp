      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	
	if not &parmTabCod.IsEmpty()
		&TabCod = &parmTabCod
	EndIF
	&Coluna1 = true
	&Coluna2 = true
	&Coluna3 = true
	&Coluna4 = true
	&Coluna5 = true
	&ProSts = Status_AtivoInativo.ATIVO
	padraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PAdObs, &PadDtaMod)
	if not &PAdObs.IsEmpty()
		&ListarDatas = substr(&PAdObs, 1,1)
		&SepararGrupos = substr(&PAdObs, 2,1)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Coluna1.Caption = 'IMPRIME COL. 01'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&PAdObs = &ListarDatas + &SepararGrupos
	padraoUsuario.Call( 'G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PAdObs, &PadDtaMod)
	
	&Random = random() * 100000
	Do case
		case &ProSts = Status_AtivoInativo.ATIVO
			&AuxProSts = Status_Produto.ATIVO
		case &ProSts = Status_AtivoInativo.INATIVO
			&AuxProSts = Status_Produto.INATIVO
		otherwise
			&AuxProSts = nullvalue(&AuxProSts)
	EndCase
	
	RCOOpenWindow1.LinkOpen = RELJAS034a.Link(&Random, &EmpCod, &FilCod, &TabCod, &GrupHie, &AuxProSts, &ListarDatas, &Coluna1,&Coluna2,&Coluna3,&Coluna4,&Coluna5, &SepararGrupos)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


]]></Source>
