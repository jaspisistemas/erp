      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable2.Height = 30

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	//Procura a duplicata
	&IsSemDuplicata = False
	For Each ORder EmpCod, FilCod, CreCod
		Where EmpCod 		= &parmEmpCod		//Empresa
		Where FilCod 		= &parmFilCod		//Filial
		Where CreViaCod 	= &parmCreViaCod	//Viagem
		Where CreVlrDup		= &parmViaLanVlr	//Valor da Duplicata
		
		If CreSts = Status_Duplicata.CANCELADA //Se já estiver sido cancelada
			
			If not CreCheCod.IsEmpty() and not CreCheCod.IsNull() //E houver cheque
				ChequeTerceiros_AlteraStatus.Call(EmpCod, CreCheCod, MotivoCheque.CANCELADO) //Altera o Status do Cheque
			Endif
			
			return
			
		EndIF
		
		&CreCod = CreCod //Código da Duplicata
		
		If CreFrpPgtoTip = TipoDuplicata.CHEQUEP or CreFrpPgtoTip = TipoDuplicata.CHEQUET //Se houver cheque próprio ou de terceiros
			TxtCancelar.Caption = 'ATENÇÃO! Esta duplicata é do tipo CHEQUE, Nro.:' + trim(CreDupNro) + ' CLI/FOR.:' + trim(CreCliRaz)+', se cancelar essa duplicata, o cheque será excluido!'
		Else
			TxtCancelar.Caption = 'Deseja cancelar a duplicata Nro.:' + trim(CreDupNro) + ' CLI/FOR.:' + trim(CreCliRaz)+ ' ?'
		EndIf
		Exit
	When None
		
		TxtCancelar.Caption = 'Deseja realmente cancelar o lançamento?' //Se não houver duplicata
		&IsSemDuplicata = True
		
	EndFor

EndEvent

Event 'DoFechar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &IsSemDuplicata = False //Se houver duplicata
		CancelarDuplicata.call(&parmEmpCod, &parmFilCod, &CreCod, &Mensagem) //Tenta cancelar duplicata
		If &Mensagem.IsEmpty() //Se conseguiu cancelar a duplicata
			//Cancela o Lançamento
			prcMovimentaLancamentosViagem.Call('DLT', &parmEmpCod, &parmFilCod, &parmCreViaCod, '', Status_SimNao.Sim, &parmViaLanVlr, '', &Today, '', '', 0, 0, '', 0, 0, 0, 0, &parmCreViaLanCod, 0, 0, 0)
			WWPActions.WCPopup_Close('Ok')
		Else
			//Senão emite o erro
			Msg(&Mensagem)
		EndIF
	Else
		//Apenas cancela o Lançamento
		prcMovimentaLancamentosViagem.Call('DLT', &parmEmpCod, &parmFilCod, &parmCreViaCod, '', Status_SimNao.Sim, &parmViaLanVlr, '', &Today, '', '', 0, 0, '', 0, 0, 0, 0, &parmViaLanCod, 0, 0, 0)
		WWPActions.WCPopup_Close('Ok')
	EndIf

EndEvent


]]></Source>
