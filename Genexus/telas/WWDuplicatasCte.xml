      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TotalMoeda.Visible = False
	GridDuplicata_Empowerer.GridInternalName = GridDuplicata.InternalName
	GridDuplicata.Rows = Page.Rows
	&GridDuplicataCurrentPage = 1
	&GridDuplicataCurrentPage.Visible = False
	&GridDuplicataPageCount = -1
	GridDuplicataPaginationBar.RowsPerPageSelectedValue = GridDuplicata.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'carregadados'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridDuplicataPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&gridCteTmpSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = GridDuplicata.PageCount	
	RetornaTotalDuplicatasCTe.Call(&EmpCod, &FilCod, &CteCod, &DinCreVlrDup, &CarCreVlrDup, &CarDebVlrDup, &DupCreVlrDup, &TotalMoeda )
	&Diferenca = &CteVlrRecSer - &TotalMoeda

EndEvent

Event GridDuplicata.Load

	&GridCteDupCod = CteDupCod
	&gridCteDupNro = CteDupNro
	&gridCteDupDtaVct = CteDupDtaVct
	&gridCteDupVlr  = CteDupVlr
	
	&gridCteTmpSts = Status_SimNao.Nao
	if not CteDupCreSeq.IsEmpty() and Not CteDupCreSeq.IsNull()
		RetornaStatusDuplicata.call(EmpCod, CteDupFilCod, CteDupCreSeq, &gridCteTmpSts)
	EndIF
	
	&gridCteDupCod = CteDupCod
	&gridCteDupCreSeq = CteDupCreSeq
	&gridCteDupFiLCod = CteDupFilCod
	
	
	&gridCteDupNro = CteDupNro
	&gridCteDupVlr = CteDupVlr
	&gridCteDupCbrCod = CteDupCbrCod
	&GridCteDupDtaVct = CteDupDtaVct

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DeleteDuplicata.FromImage(ActionDelete)
	&DeleteDuplicata.TooltipText = "Deletar Duplicata"

	Do Case
		Case &GridCteTmpSts = Status_SimNao.sim
			&gridCteTmpSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case &GridCteTmpSts = Status_SimNao.Nao
			&gridCteTmpSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			&gridCteTmpSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridDuplicataPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridDuplicataPaginationBar.SelectedPage = !'Previous'
			&GridDuplicataCurrentPage -= 1
			GridDuplicata.PreviousPage()
		Case GridDuplicataPaginationBar.SelectedPage = !'Next'
			&GridDuplicataCurrentPage += 1
			GridDuplicata.NextPage()
		Otherwise
			&PageToGo.FromString(GridDuplicataPaginationBar.SelectedPage)
			&GridDuplicataCurrentPage = &PageToGo
			GridDuplicata.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridDuplicataPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridDuplicata.Rows = GridDuplicataPaginationBar.RowsPerPageSelectedValue
	&GridDuplicataCurrentPage = 1
	GridDuplicata.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWCTe.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsertDuplicata'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpAdicionarDuplicataCte.PopUp(&EmpCod, &FilCod, &CteCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Refresh

EndEvent

Event &DeleteDuplicata.Click

	If &gridCteTmpSts = Status_SimNao.Nao
		DeletaCteDuplicata.call(EmpCod,FilCod,CteCod,CteDupCod)
		Gridduplicata.Refresh()
		
		RetornaTotalDuplicatasCTe.Call(&EmpCod, &FilCod, &CteCod, &DinCreVlrDup, &CarCreVlrDup, &CarDebVlrDup, &DupCreVlrDup, &TotalMoeda )
		&Diferenca = &CteVlrRecSer - &TotalMoeda
	Else
		msg('Duplicatas já possui pagamentos, não é possível Eliminar/Alterar por aqui!')
	EndIF

EndEvent

Sub 'carregadados'

	For Each Order EmpCod,FilCod,CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CteVlrRecSer = CteVlrRecSer
		&CteNum = CteNum
		If not CteRemCpf.Trim().IsEmpty()
			&CteRemCnpj = CteRemCpf
		Else
			&CteRemCnpj = CteRemCnpj
		EndIf
		&CteRemRaz = SubStr(CteRemRaz,1,35)+' '+&CteRemCnpj 
		&CteDtaEms = CteDtaEms
	Endfor

EndSub


]]></Source>
