Sub 'UpdateReqIaDtaHorOperatorValues'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	ReqIaDtaHor_Cell.Class = !'Invisible'
	ReqIaDtaHor_To_Cell.Class = !'Invisible'
	ReqIaDtaHor_RangeMiddleText_1.Class = !'Invisible'
	Do Case
		Case &ReqIaDtaHorOperator = 0
			&ReqIaDtaHor = &Today
		Case &ReqIaDtaHorOperator = 1
			&ReqIaDtaHor = &Today
			&ReqIaDtaHor_To = &Today + 1
		Case &ReqIaDtaHorOperator = 2
			&ReqIaDtaHor = &Today.AddDays(1)
		Case &ReqIaDtaHorOperator = 3
			ReqIaDtaHor_Cell.Class = !''
			ReqIaDtaHor_To_Cell.Class = !''
			ReqIaDtaHor_RangeMiddleText_1.Class = !''
	EndCase

