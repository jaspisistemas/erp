      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Form.Caption = ' Requisicao IA'

	Do 'PrepareTransaction'
	Do 'UpdateReqIaDtaHorOperatorValues'
	Do 'LoadGridState'
	&OrderedBy.Clear()
	&OrderedBy.AddItem(1, 'Id')
	&OrderedBy.AddItem(2, 'Tokens (menor > maior)')
	&OrderedBy.AddItem(3, 'Tokens (maior > menor)')
	If &OrderedBy < 1
		&OrderedBy = 1
	EndIf
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&isLimitarConteudo = true

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod
	if &Context.TipoPerfil <> 3
		Dashboard()
	endif

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Delete = !'<i class="fa fa-times"></i>'
	&Delete.Link = RequisicaoIA.Link(TrnMode.Delete, EmpCod, ReqIaCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&classe = 'xGridLimitContent'
	
	&classes = ReqIaPost.Class
	utilAlteraClasse(&isLimitarConteudo,&classe,&classes)
	ReqIaPost.Class = &classes
	
	&classes = ReqIaRec.Class
	utilAlteraClasse(&isLimitarConteudo,&classe,&classes)
	ReqIaRec.Class = &classes

EndEvent

Event 'DoCleanFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CleanFilters'
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ReqIaDtaHorOperator.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ReqIaDtaHor.SetEmpty()
	&ReqIaDtaHor_To.SetEmpty()
	Do 'UpdateReqIaDtaHorOperatorValues'
	Grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CleanFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.SetEmpty()
	&ReqIaCod.SetEmpty()
	&ReqIaId.SetEmpty()
	&ReqIaTokTotOperator = 0
	&ReqIaTokTot.SetEmpty()
	&ReqIaMod.SetEmpty()
	&ReqIaPost.SetEmpty()
	&ReqIaRec.SetEmpty()
	&ReqIaDtaHorOperator = 0
	&ReqIaDtaHor.SetEmpty()
	&ReqIaDtaHor_To.SetEmpty()
	Do 'UpdateReqIaDtaHorOperatorValues'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	Do 'LoadRegFiltersState'
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadRegFiltersState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"EMPCOD"
				&EmpCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"REQIACOD"
				&ReqIaCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"REQIAID"
				&ReqIaId.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"REQIATOKTOT"
				&ReqIaTokTot.FromString(&GridStateFilterValue.Value)
				&ReqIaTokTotOperator = &GridStateFilterValue.Operator
			Case &GridStateFilterValue.Name = !"REQIAMOD"
				&ReqIaMod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"REQIAPOST"
				&ReqIaPost.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"REQIAREC"
				&ReqIaRec.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"REQIADTAHOR"
				&ReqIaDtaHor.FromString(&GridStateFilterValue.Value)
				&ReqIaDtaHorOperator = &GridStateFilterValue.Operator
				&ReqIaDtaHor_To.FromString(&GridStateFilterValue.ValueTo)
				Do 'UpdateReqIaDtaHorOperatorValues'
		EndCase
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"EMPCOD", "", not &EmpCod.IsEmpty(), 0, &EmpCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"REQIACOD", "", not &ReqIaCod.IsEmpty(), 0, &ReqIaCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"REQIAID", "", not &ReqIaId.IsEmpty(), 0, &ReqIaId, '')
	WWP_GridStateAddFilterValue(&GridState, !"REQIATOKTOT", "", not &ReqIaTokTot.IsEmpty(), &ReqIaTokTotOperator, &ReqIaTokTot.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"REQIAMOD", "", not &ReqIaMod.IsEmpty(), 0, &ReqIaMod, '')
