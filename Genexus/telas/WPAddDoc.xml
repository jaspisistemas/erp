      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[Parm(in:&EmpCod,in:&FilCod,in:&CteCod,in:&CteDocTip,in:&CteDocCod,in:&Round);
]]></Source>
