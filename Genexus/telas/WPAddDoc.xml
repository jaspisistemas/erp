/Name&gt;&lt;Value&gt;False&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;IconPosition&lt;/Name&gt;&lt;Value&gt;Right&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;AutoScroll&lt;/Name&gt;&lt;Value&gt;False&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><table controlName="InfoOutras" class="" tableType="Responsive" responsiveSizes="[]" containerSlotName="InfoOutras"><row><cell cellClass="DataContentCell"><data attribute="&amp;CteDocTipOri" labelCaption="Tipo" class="AttributeRealWidth" /></cell><cell cellControlName="CteDocDes_Cell"><data attribute="&amp;CteDocDes" labelCaption="Descrição" class="AttributeRealWidth" /></cell></row><row><cell cellClass="RequiredDataContentCell"><data attribute="&amp;OtrCteDocNro" labelCaption="Número" class="AttributeRealWidth" /></cell><cell cellClass="RequiredDataContentCell"><data attribute="&amp;OtrCteDocDta" labelCaption=" Data de Emissão " class="AttributeRealWidthDate" /></cell></row><row><cell cellClass="RequiredDataContentCell"><data attribute="&amp;OtrCteDocVlrTotPro" labelCaption="Valor " class="AttributeRealWidth" /></cell><cell><data attribute="&amp;OtrCteDocDtaPre" labelCaption="Previsão de entrega " class="AttributeRealWidthDate" /></cell></row></table></ucw></cell></row></table></cell></row><row><cell cellClass="CellMarginTop"><action controlName="BtnInfor" onClickEvent="'DoInfor'" caption="Informações" class="BtnSecurity" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;Adiciona Informações&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></cell></row></table></cell></row><row><cell><actiongroup controlName="ActionGroup_Actions" /></cell></row></table></cell></row></table><actionGroups><actionGroup controlName="ActionGroup_Actions" class="TrnActionGroup"><item><action controlName="BtnEnter" onClickEvent="Enter" caption="GX_BtnEnter" class="Button" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name