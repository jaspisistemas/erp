      </Part>
      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do Case
		Case &CteDocTip = TipoDocumentoCte.NF
			TableNfe.Visible = False
			TableNf.Visible = True			
			TableOutros.visible = false
		Case &CteDocTip = TipoDocumentoCte.Nfe
			TableNfe.Visible = True
			TableNf.Visible = False
			TableOutros.visible = false
		Case &CteDocTip = TipoDocumentoCte.Otros
			TableNfe.Visible = False
			TableNf.Visible = False
			TableOutros.visible = true
	EndCase
	If &CteDocCod <> 0 
		Do 'CarregaUpdate'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CteDocTotPso.TooltipText = "Soma de peso bruto automático"
	&CteDocVlrNtf.TooltipText = "Soma valor da carga  automático"

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	Return 
//	Sessao

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInfor'

	Do 'CheckRequiredFields'
	Do Case
		Case &CheckRequiredFieldsResult = False
			msg('ATENÇÃO! Não foi possível adicionar Documento. Verifique!')
		Case &IsErro = true
			msg('ATENÇÃO! Não foi possível adicionar esta chave de nota pois a mesma não é válida. Verifique!')
		OtherWise
			If &CteDocTip = TipoDocumentoCte.Otros
				&CteDocDta = &OtrCteDocDta
				&CteDocNro = &OtrCteDocNro
				&CteDocVlrTotPro = &OtrCteDocVlrTotPro
				If not &OtrCteDocDtaPre.IsEmpty()
					&CteDocDtaPre = &OtrCteDocDtaPre
				EndIf
			EndIf
			GravaCteDoc.call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteDocNroRom,&CteDocNroPed,&CteDocMod,&CteDocSer,&CteDocNro,&CteDocTipOri,&CteDocDes,&CteDocDta,&CteDocVbc,&CteDocVlrIcm,&CteDocVstIcm,&CteDocVst,&CteDocVlrTotPro,&CteDocVlrTotNtf,&CteDocCfoPre,&CteDocPes,&CteDocChvNfe,&CteDocVlrNtf,&CteDocTotPso,&CteDocPinSuf,&CteDocDtaPre,&CteDocNcmPre)
			WPAddPin.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip)
			If &CteDocCod <> 0 
				Do 'CarregaUpdate'
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If (&CteDocTipOri = DocumentoOriginario.Outros and &CteDocTip = TipoDocumentoCte.Otros) AND &CteDocDes.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Descrição'), DVMessageType.error, &CteDocDes.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If &CteDocTipOri = DocumentoOriginario.Outros and &CteDocTip = TipoDocumentoCte.Otros
		CteDocDes_Cell.Class = !'col-xs-12 col-sm-6 RequiredRequiredDataContentCell'
	Else
		CteDocDes_Cell.Class = !'col-xs-12 col-sm-6 RequiredDataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&SdtCte.FromXml(&webSession.get('CTE'))
	If &sdtCte.Tela = 'WPAddPin'
		&SdtEmpCod = &sdtCte.EmpCod
		&SdtFilCod = &sdtCte.FilCod
		&SdtCteCod = &sdtCte.CteCod
		&SdtCteDocCod = &sdtCte.CteDocCod 
		&SdtCteDocTip = &sdtCte.CteDocTip
		Do Case
			Case &SdtCteDocTip = 1
				TableNfe.Visible = False
				TableNf.Visible = True			
				TableOutros.visible = false
			Case &SdtCteDocTip = 2
				TableNfe.Visible = True
				TableNf.Visible = False
				TableOutros.visible = false
			Case &SdtCteDocTip = 3
				TableNfe.Visible = False
				TableNf.Visible = False
				TableOutros.visible = true
		EndCase
	
		Do 'CarregaUpdateReturn'
	EndIf

EndEvent

Event &CteDocTipOri.IsValid

	Do 'AttributesSecurityCode'
	If &CteDocTipOri = DocumentoOriginario.NFCe
		&CteDocDes.Caption = 'Chave NFC-e'
	Else
		&CteDocDes.Caption = 'Descrição'
	EndIf

EndEvent

Event Enter

	If &CteDocTip = TipoDocumentoCte.NFe
		ValidaChaveNota.Call(&CteDocChvNfe,&IsErro)
		&CteModCod = SubStr(trim(&CteDocChvNfe),21,2) // TEM QUE SER MODELO 55
		If &CteModCod <> '55'
			msg('CHAVE INVÁLIDA! Só é permitido adicionar documento Modelo 55 NF-e.')
			&IsErro = true
		EndIf
	EndIf

	Do 'CheckRequiredFields'
	Do Case
		Case &CheckRequiredFieldsResult = False
			msg('ATENÇÃO! Não foi possível adicionar Documento. Verifique!')
		Case &IsErro = true
			msg('ATENÇÃO! Não foi possível adicionar esta chave de nota pois a mesma não é válida. Verifique!')
		OtherWise
			If &CteDocTip = TipoDocumentoCte.Otros
				&CteDocDta = &OtrCteDocDta
				&CteDocNro = &OtrCteDocNro
				&CteDocVlrTotPro = &OtrCteDocVlrTotPro
				If not &OtrCteDocDtaPre.IsEmpty()
					&CteDocDtaPre = &OtrCteDocDtaPre
				EndIf
			EndIf
			GravaCteDoc.call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteDocNroRom,&CteDocNroPed,&CteDocMod,&CteDocSer,&CteDocNro,&CteDocTipOri,&CteDocDes,&CteDocDta,&CteDocVbc,&CteDocVlrIcm,&CteDocVstIcm,&CteDocVst,&CteDocVlrTotPro,&CteDocVlrTotNtf,&CteDocCfoPre,&CteDocPes,&CteDocChvNfe,&CteDocVlrNtf,&CteDocTotPso,&CteDocPinSuf,&CteDocDtaPre,&CteDocNcmPre)
			&CteDocNroRom = ''
			&CteDocNroPed = ''
			&CteDocSer = ''
			&CteDocNro = ''
			&CteDocDes = ''
			&CteDocDta.SetEmpty()
			&CteDocVbc = 0
			&CteDocVlrIcm = 0
			&CteDocVstIcm = 0
			&CteDocVst = 0
			&CteDocVlrTotPro = 0
			&CteDocVlrTotNtf = 0
			&CteDocCfoPre = 0
			&CteDocPes = 0
			&CteDocChvNfe = ''
			&CteDocVlrNtf = 0
			&CteDocTotPso = 0
			&CteDocPinSuf = 0
			&CteDocDtaPre.SetEmpty()
			If &CteDocTip = TipoDocumentoCte.NFe
				&CteDocChvNfe.SetFocus()
			EndIf
	EndCase

EndEvent

Event &CteDocChvNfe.IsValid

	ValidaChaveNota.Call(&CteDocChvNfe,&IsErro)
	&CteModCod = SubStr(trim(&CteDocChvNfe),21,2) // TEM QUE SER MODELO 57
	If &CteModCod <> '55'
		msg('CHAVE INVÁLIDA! Só é permitido adicionar documento Modelo 55 NF-e.')
		&IsErro = true
	EndIf

EndEvent

Event &CteDocDes.IsValid

	If &CteDocTipOri = DocumentoOriginario.NFCe
		ValidaChaveNota.Call(&CteDocDes,&IsErro)
		&CteModCod = SubStr(trim(&CteDocChvNfe),21,2) // TEM QUE SER MODELO 57
		If &CteModCod <> '65'
			msg('CHAVE INVÁLIDA! Só é permitido adicionar documento Modelo 55 NFC-e.')
			&IsErro = true
		EndIf
	EndIf

EndEvent

Sub 'CarregaUpdate'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteDocTip
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		Where CteDocTip = &CteDocTip
		
		&CteDocCfoPre = CteDocCfoPre
		&CteDocNroRom = CteDocNroRom
		&CteDocNroPed = CteDocNroPed
		&CteDocMod = CteDocMod
		&CteDocSer = CteDocSer
		&CteDocNro = CteDocNro
		&CteDocPinSuf = CteDocPinSuf
		&CteDocPes = CteDocPes
		&CteDocDta = CteDocDta
		&CteDocVbc = CteDocVbc
		&CteDocVlrIcm = CteDocVlrIcm
		&CteDocVstIcm = CteDocVstIcm
		&CteDocVst = CteDocVst
		&CteDocVlrTotPro = CteDocVlrTotPro
		&CteDocNcmPre = CteDocNcmPre
		//NFE
		If CteDocTip = TipoDocumentoCte.Nfe
			&CteDocVlrNtf = CteDocVlrTotNtf
			&CteDocDtaPre = CteDocDtaPre 
		Else
			&CteDocVlrTotNtf = CteDocVlrTotNtf
			&OtrCteDocDtaPre = CteDocDtaPre
		EndIf
		
		
		&CteDocTotPso = CteDocTotPso 
		&CteDocChvNfe = CteDocChvNfe
		

		// OUTROS
		&CteDocTipOri = CteDocTipOri
		&CteDocDes    = CteDocDes
		&OtrCteDocDta = CteDocDta
		&OtrCteDocNro = CteDocNro
		&OtrCteDocVlrTotPro = CteDocVlrTotPro
		
		exit
	EndFor

EndSub

Sub 'CarregaUpdateReturn'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteDocTip
		Where EmpCod = &SdtEmpCod
		Where FilCod = &SdtFilCod
		Where CteCod = &SdtCteCod
		Where CteDocCod = &SdtCteDocCod
		Where CteDocTip = &SdtCteDocTip
		&CteDocNroRom = CteDocNroRom
		&CteDocNroPed = CteDocNroPed
		&CteDocMod = CteDocMod
		&CteDocSer = CteDocSer
		&CteDocNro = CteDocNro
		&OtrCteDocNro = CteDocNro
		&CteDocTipOri = CteDocTipOri
		&CteDocDes = CteDocDes
		&CteDocNcmPre = CteDocNcmPre
		&CteDocDta = CteDocDta
		&OtrCteDocDta = CteDocDta
		&CteDocVbc = CteDocVbc
		&CteDocVlrIcm = CteDocVlrIcm
		&CteDocVstIcm = CteDocVstIcm
		&CteDocVst = CteDocVst
		&CteDocVlrTotPro = CteDocVlrTotPro
		&CteDocVlrTotNtf = CteDocVlrTotNtf
		&OtrCteDocVlrTotPro = CteDocVlrTotPro
		&CteDocCfoPre = CteDocCfoPre
		&CteDocPes = CteDocPes
		&CteDocVlrTotPro = CteDocPes
		&CteDocChvNfe = CteDocChvNfe
		&CteDocPinSuf = CteDocPinSuf
		exit
	EndFor

EndSub


]]></Source>
