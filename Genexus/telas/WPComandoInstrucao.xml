      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Height = 100

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&CreVlrSdo.Visible = False
	&CreRecPag.Visible = False
	&CreFilPgt.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CampoData = &Today+1
	do 'LoadDuplicata'

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbComplemento.Visible = (&CreCmdIns = 9)
	tbCampoTexto.Visible = (&CreCmdIns = 5  or &CreCmdIns = 9 or &CreCmdIns = 2)
	tbData.Visible = (&CreCmdIns = 4)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CreCmdIns.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event Enter

	InstrucaoBoletoApiECommerce.call(&EmpCod,&FilCod,&CreCod,&CreCmdIns,&CreCmdCpl,&CampoData,&CampoTexto,&MsgErro,&MsgSucesso)
	
	If not &MsgErro.Trim().IsEmpty()
		msg( &MsgErro )
	EndIf
	
	If not &MsgSucesso.Trim().IsEmpty()
		msg(&MsgSucesso)
	EndIf

EndEvent

Sub 'LoadDuplicata'

	For each Order EmpCod,FilCod,CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		&CreRecPag = CreRecPag
		&CreFilPgt = CreFilPgt
		&CreBloNro = CreBloNro
		&CreCbrCod = CreCbrCod
		&CreCliCod = CreCliCod
		&CreCliRaz = CreCliRaz
		&CreDtaEms = CreDtaEms
		&CreDtaVct = CreDtaVct
		&CreDupNro = CreDupNro
		&CreVlrDup = CreVlrDup
		&CreVlrSdo = CreVlrSdo
		exit
	EndFor

EndSub


]]></Source>
