EndEvent

Sub 'Do AutorizarCCe'

	if NfeCCeStsLib = true or ( &TCon142_LiberarAutorizacaoCCe <> 'S')
		geraXmlAutorizacaoCCe.Call('', EmpCod, FilCod, NfeCod, NfeCCeCod)
	Else
		msg('Carta de Correção ainda não Liberada para emissão')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Do Email'

	if NfeCCeSts = Status_NFe.Autorizada
		wpEnviaCce.Popup(EmpCod, FilCod, NfeCod, NfeCCeCod)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

