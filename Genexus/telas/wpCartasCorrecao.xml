      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon142_LiberarAutorizacaoCCe, &TCon142_LiberarAutorizacaoCCe)
	if &TCon142_LiberarAutorizacaoCCe <> 'S'
		&ActionSelecione.Visible = 0
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadDadosNota'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = grid.currentPage
	&GridRecordCount = grid.RecordCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&AlterarCarta = !'<i class="fa fa-pen"></i>'
	
	&ActionSelecione.FromImage(DDOMultiselSelOption)
	&ActionSelecione.TooltipText = ""
	
	&comboOptions.Clear()
	&comboOptions.AddItem(0, 'WWP_ActionGroupCaption')
	If (NfeCCeSts = Status_NFe.Digitando)
		&comboOptions.AddItem(1, 'Autorizar CCe')
	Endif
	If (NfeCCeSts = Status_Nfe.Autorizada)
		&comboOptions.AddItem(2, 'Enviar E-mail')
	Endif
	If (NfeCCeSts = Status_Nfe.Autorizada)
		&comboOptions.AddItem(3, 'Imprimir CCe')
	Endif
	If &comboOptions.Count = 1
		&comboOptions.Class = !'Invisible'
	Else
		&comboOptions.Class = !'Attribute'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If NfeCCeSts <> Status_NFe.Digitando
		&AlterarCarta = !'<i class="fa fa-search"></i>'
		
		If NfeCCeSts = Status_NFe.Autorizada
			NfeCCeSts.ForeColor = RGB(0,160,40)			
		Else
			NfeCCeSts.ForeColor = RGB(160,40,0)
		EndiF
	Else
		NfeCCeSts.ForeColor = RGB(0,0,0)
		&AlterarCarta = !'<i class="fas fa-pen"></i>'
	EndIf
	
	if NfeCCeStsLib = true
		&ActionSelecione.FromImage(DDOMultiselSelOption)
	Else
		&ActionSelecione.FromImage(DDOMultiSelOption)
	EndIf

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AlterarCarta.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	AlterarCarta_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event AlterarCarta_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpAddCCe.Create(EmpCod, FilCod, NfeCod, NfeCCeCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event AlterarCarta_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &comboOptions.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &comboOptions = 1
			Do 'Do AutorizarCCe'
		Case &comboOptions = 2
			Do 'Do Email'
		Case &comboOptions = 3
			Do 'Do ImprimirDOc'
	EndCase
	&comboOptions = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtnInserir'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	BtnInserir_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

