Sub 'getLoad'

	For each order EmpCod,FilCod,CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CteSts = CteSts
		
		If CteSts = Status_Nfe.Digitando
			BtnEnter.Visible = True
		Else
			BtnEnter.Visible = False
		EndIf
	
		&CteObsGer = trim(CteObsGer)
		&CtePla = CtePlc
		&CtePlaTra = CtePlcTra
		&CteNroCon = CteNroCon
		&CteDocTra = CteDocTra
		&CteCiotNro = CteCiotNro
		
		&CteCpfMot = CteCpfMot
		&CteNomMot = CteNomMot
		If not FilAtmUsu.Trim().IsEmpty()
			TableAverbacao.Visible = true
		Else
			TableAverbacao.Visible = False
		EndiF

		&CteAveCodLim = CteAveCodLim
		&CteAveRam = CteAveRam
		&CteVlrAva = CteVlrAva
		&CteVlrAce = CteVlrAce
		&CteVlrCon = CteVlrCon
		
		&CtePosDocAnt = CtePosDocAnt
		If CtePosDocAnt = Status_SimNao.Nao
			GXUITabsPanel_Avancado.HideTab(3)
		EndIf

		&CtePosVei = CtePosVei
		If CtePosVei = Status_SimNao.Nao
			GXUITabsPanel_Avancado.HideTab(2)
		EndIf
		exit
	EndFor

EndSub

Sub 'VeiculoTab'

	If &CtePosVei = Status_SimNao.Sim
		GXUITabsPanel_Avancado.ShowTab(2)
		GXUITabsPanel_Avancado.SelectTab(2)
	Else
		GXUITabsPanel_Avancado.SelectTab(1)
		GXUITabsPanel_Avancado.HideTab(2)
	EndIf

EndSub

Sub 'DocAntTab'

	If &CtePosDocAnt = Status_SimNao.Sim
		GXUITabsPanel_Avancado.ShowTab(3)
		GXUITabsPanel_Avancado.SelectTab(3)
	Else
		GXUITabsPanel_Avancado.SelectTab(1)
		GXUITabsPanel_Avancado.HideTab(3)	
	EndIf

EndSub


