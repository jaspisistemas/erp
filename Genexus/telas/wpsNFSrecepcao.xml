      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtMsg.Caption = ''
	loadwwpContext.Call(&wwpContext)
	pro.Visible = 1
	funcaoAutorizada.Visible = 0
	Sucesso.Visible = 0
	Falha.Visible = 0

	

	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod		
		Where NfsCod = &NfsCod
		
		&NfsPedFiLCod = NfsPedFilCod
		&NfsPedCod = NfsPedCod
		
		if &DeOndevem <> 'FECHAMENTOBALCAO'
			btnBtn1a.Visible = 0
		Endif
	
		if NfsSts = Status_NFe.Digitando
			&Random = random()* 1000000000
			&ProgressId = 'autoNFe' + trim(Str(&wwpContext.EmpCod)) + trim(Str(&wwpContext.FilCod)) + trim(Str(&wwpContext.PesCod)) + trim(str(&Random))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()
			
			RecepcaoNFe.Submit('RecepcaoNFe', &ProgressId, &EmpCod, &wwpContext.FilCod, &NfsCod, &SolCod)
		Else
			wwNotasservico.Link()
		EndIF
		
		Exit
		
	When none
		wwNotasservico.Link()
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoReimprimir'

 8

	do 'imprimenota'
	
	RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn1'

	do CAse
		CAse &DeOndevem = 'WWPEDIDOBALCAO' or &DeOndevem = 'FECHAMENTOBALCAO'
			wwpedidoBalcao.Link()
		Case &DeOndevem = 'FECHAMENTOBALCAO'
			wpPedidoPedido_Fechado.Link('WWPEDIDOBALCAO', &EmpCod, &NfsPedFiLCod, &NfsPedCod)
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn1a'

	wpPedidoPedido_Fechado.Link('WWPEDIDOBALCAO', &EmpCod, &NfsPedFiLCod, &NfsPedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtn2'

	wwNotasServico.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	pro.Visible = 0
	
	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		txtMsg.ForeColor = RGB(210,130,0)
		txtMsg.Caption = ProgressLogXml.Trim()
		
		do 'imprimenota'
		
		if not &UrlPDF.IsEmpty()			
			&Window.Url = Link(&UrlPDF)
			&Window.Height = 500	
			&Window.Width = 900
			&Window.Open()
		Endif
	
		Exit
	EndFor

EndEvent

Sub 'imprimenota'

	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NfsCod
		
		If not NfsArqXml.IsEmpty() and NfsSts = Status_NFe.Autorizada
			
			funcaoAutorizada.Visible = 1
			Sucesso.Visible = 1
			
			//GravarStatusIMpressao.Submit('GravarStatusIMpressao', EmpCod, FilCod, NfsCod, 0)
			txtMsg.ForeColor = RGB(0,210,25)
			
			GeraPdfDanfeNFSe.Call(EmpCod, NfsCod, &UrlPDF, &UrlFisico)
			
//			btnNovaNFSe.SetFocus()
		Else
			Falha.Visible = 1
//			btnNovaNFSe.SetFocus()
		EndIF
		
		Exit
	EndFor

EndSub


]]></Source>
