      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 3
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		//&PedSts = PedSts
		&PedStsCod = PedNovStsPaiCod
		&PedStsFinCod = PedNovStsFinCod
		&PedStsFinPaiCod = PedNovStsFinPaiCod
		Exit
	EndFor

	For Each Order EmpCod, StsOrd
		Where EmpCod = &EmpCod
//		Where StsPed = &PedSts
		Where StsCod = &PedStsCod or StsPaiCod = &PedStsCod
		Where StsEst = true or StsWs = Status_WsUsu.WebService
		&StsCod.AddItem(StsCod, StsNom)
	EndFor
	
	For Each Order EmpCod, StsOrd
		Where EmpCod = &EmpCod
//		Where StsPed = &PedSts
		Where StsCod = &PedStsFinPaiCod or StsPaiCod = &PedStsFinPaiCod
		Where StsCrd = true or StsWs = Status_WsUsu.WebService
		&StsFinCod.AddItem(StsCod, StsNom)
	EndFor
	
	&StsFinCod = &PedStsFinCod
	&StsCod = &PedStsCod

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = grid.PageCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	GravaStatusPedido.Call(&EmpCod, &FilCod, &PedCod, &StsCod, &HisStsObs, &StsFinCod, &Context.PesCod)
	Return

EndEvent


]]></Source>
