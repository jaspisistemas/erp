      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&ZerarSaldo.Visible = 0
	loadwwpContext.Call(&wwpContext)
	Padraousuario.Call('L', '#ZERASALDOFUTURO#'+trim(str(&Pedcod)), &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	&ZerarSaldo = iif(&PadObs = '1', true, false)
	
	&AuxPedQtd.Enabled = 1
	do 'loadOrdemCarregamento'
	
	RetornaValorSaldo.Call(&EmpCod, &FilCod, &PedCod, &PedCodOciRef, &CreVlrSdo, &Mensagem)
	txtqtdSal.Caption = trim(&Mensagem)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbsaldo.Width = 450
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&AuxPedQtd.Enabled = 1
	
	For each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCodOciRef
		&PedItmCod = PedItmCod
		&PedQtd    = PedQtd
		&PedVlrItm = PedVlrItm
		&ProCod    = ProCod
		&ProNom    = ProNom
		&PedVlrUnt = PedVlrUnt
		&PedVlrUntDsc = PedVlrUntDsc
		&PedVlrUntComDsc = PedVlrUntComDsc
		&PedVlrBrt = PedVlrBrt
		&PedVlrCus = PedVlrCus
		&PedVlrLiq = PedVlrLiq
		&PedQtdEmb = PedQtdEmb
		&PedItmDsc = PedItmDsc
		&PedVlrTab = PedVlrTab
		&GridPedItmPagQtdTot = PedItmPagQtdTot - RetornaQtdCredito.Udp(EmpCod,FilCod,ProCod,PedCod)
		&PedQtdDsp = PedQtd - RetornaQtdRetirada.Udp(EmpCod,FilCod,ProCod,PedCod)
		
		
		do 'qtdAdicionada'
				
		load
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	loadwwpContext.Call(&wwpContext)
	For Each Line in grid
	
			If &AuxPedQtd > &PedQtdDsp
				&AuxPedQtd = &PedQtdDsp  //leva somente a quantidade deisponível.
			Endif
			
			if &AuxPedQtd > &GridPedItmPagQtdTot
				&SelPedItmPagQtdTot = &GridPedItmPagQtdTot
				//ex:  Paguei 2 qtd tenho 4 qtde disponível para selecionar, porem meu total selecionado(&AuxPedQtd) é 3 qtde então vou usar 2 qtde(&GridPedItmPagQtdTot) de crédito pago, 
				//para nao gerar o financeiro dessas 2 porem vou gerar fin de 1 qtde na orderm de carregamento
			Else
				&SelPedItmPagQtdTot = &AuxPedQtd //seleciona a qtde paga igual a quantidade selecionada, para abater como crédito
				//ex:  Paguei 4 qtd  tenho 4 qtde disponível para selecionar, porem meu total selecionado(&AuxPedQtd) é 2 qtde então vou usar 2 qtde de crédito pago, para nao gerar o financeiro na ordem de carregamento
			EndIf
			//Leva somente o total do crédito menor ou igual a quantidade disponível e selecionado.
			
			Do 'RetornaCodigoItem'
			GravaItemPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &ProCod, 1,&AuxPedQtd, 0,&SelPedItmPagQtdTot, &PedVlrUnt, &PedVlrTab, &PedItmDsc, '', 0, 0, '', '', &wwpContext.UserName)
	EndFor
	
	&PadObs = iif(&ZerarSaldo = true, '1', '0')
	Padraousuario.Call('G', '#ZERASALDOFUTURO#'+trim(str(&Pedcod)), &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	
	return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AuxPedQtd.IsValid

	If &AuxPedQtd > &PedQtdDsp
		&AuxPedQtd = &PedQtdDsp
	Endif

	if &AuxPedQtd > &GridPedItmPagQtdTot
		&SelPedItmPagQtdTot = &GridPedItmPagQtdTot
	Else
		&SelPedItmPagQtdTot = &AuxPedQtd
	EndIf

EndEvent

Sub 'RetornaCodigoItem'

	For each Order EmpCod,FilCod,PedCod,ProCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where ProCod = &ProCod
		&PedItmCod = PedItmCod
		Exit
	When none
		&PedItmCod = 0
	EndFor

EndSub

Sub 'loadOrdemCarregamento'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedCodOciRef = PedCodOciRef
		Exit
	Endfor

EndSub

Sub 'qtdAdicionada'

	&auxPedQtd = 0
	For each Order EmpCod,FilCod,PedCod,ProCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where ProCod = &ProCod
		&auxPedQtd = PedQtd
		exit
	EndFor

EndSub


]]></Source>
