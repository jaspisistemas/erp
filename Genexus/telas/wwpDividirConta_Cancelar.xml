      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	do 'CarregaSDT_DIVIDIR'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridRecebimentos.Rows = 0
	Grid.Rows = 15
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

EndEvent

Event GridRecebimentos.Load

	for &SdtDividirContaDuplicatasItem in &SdtDividirContaDuplicatas
		For Each ORder EmpCod, FilCod, PedCod, PedTmpDupCod
			Where EmpCod = &SdtDividirContaDuplicatasItem.EmpCod
			Where FilCod = &SdtDividirContaDuplicatasItem.FIlCOd
			Where PedTmpCreCod = &SdtDividirContaDuplicatasItem.CreCod

			&grid2CreDupNro = PedTmpDupNro
			&grid2CreVlrDup = PedTmpDupVlr
			&grid2CreDtaVct = PedTmpDupVct
			&grid2CreCod = PedTmpCreCod
			&grid2PlanCod = PedTmpPlanCod
			&grid2IsPaga = PedTmpSts
			&grid2CreCbrCod = PedTmpDupCbrCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			load
		EndFor
	EndFor

EndEvent

Event Grid.Load

	For each ORder EmpCod, FilCod, PedCod, PedItmCod, PedProPagItm
		Where EmpCod = &EmpCod
		Where FilCod = &FIlCOd
		Where PedCod = &PedCod
		Where PedProPagItm = &PedProPagItm
		Where PedProPagVlr > 0
		
		//PRODUTOS
		&ProGraRef = '--'
		&ProGraNom = 'PRODUTO NAO LOCALIZADO'
		&PedVlrItm = PedProPagVlr		
		&ProGraRef = ProGraRef
		&ProGraNom = PedProNom

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	for &SdtDividirContaDuplicatasItem in &SdtDividirContaDuplicatas
		CancelaStatusFinanceiroPedido_Dividir.Call(&SdtDividirContaDuplicatasItem.EmpCod, &SdtDividirContaDuplicatasItem.FilCod, &SdtDividirContaDuplicatasItem.CreCod)
	EndFor
	prcGravaReceberContaDelete.Call(&EmpCod, &FIlCOd, &PedCod, &PedProPagItm)
	ApagaTemporariaPedidoDuplicata.Call(&EmpCod, &FilCod, &PedCod, &Context.PesCod, &PedFrpPgtoTip)
	prcDividirConta.Call(&EmpCod, &FIlCOd, &PedCod, 0, true, 0)
	
	Return

EndEvent

Sub 'CarregaSDT_DIVIDIR'

	For each ORder EmpCod, FilCod, PedCod, PedItmCod, PedProPagItm
		Where EmpCod = &EmpCod
		Where FilCod = &FIlCOd
		Where PedCod = &PedCod
		Where PedProPagItm = &PedProPagItm
		Where not PedProPagAdi.IsEmpty() and not PedProPagAdi.IsNull()
		&SdtDividirContaDuplicatas.FromXml(PedProPagAdi)
	EndFor

EndSub


