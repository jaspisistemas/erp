	&FilPesCod = &Context.PesCod
	&Status = 'A'
	&StsDup.SetEmpty()
	&IsPerdido = true
	retornaAutorizacao.Call('WWCONSULTADEBITOS', Status_SimNao.Sim, 1, &AutNiv)
	//RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon077_ExibeStatusDebitoCliente, &TCon077_ExibeStatusDebitoCliente)
	If &Context.PesIsVen = true
		retornaAutorizacao.Call('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1, &AutNivTel)
		If &AutNivTel = 0
			&PesCod = &Context.PesCod
			&PesCod.Enabled = 0
			Do 'Vendedor'
		Else
			&PesCod.Enabled = 1
		EndIf
	EndIF
	&CreRecPag = ReceberPagar.Receber
	If &CreDtaEmsFin.IsEmpty()
		//&CreDtaEmsIni = &Today - (day(&Today)+1)
		&CreDtaEmsFin = &Today
	EndIf

	If &CreDtaVctIni.IsEmpty() or &CreDtaVctFin.IsEmpty()
		&CreDtaVctIni = YMDtoD(2000,1,1)
		&CreDtaVctFin = &Today
	EndIf
	do 'montaFilialFaturamento'
	//RETORNA FORMAS PAGAMENTOS
	RetornaFormasPagamento.Call(&Context.EmpCod, 'R', '', &Context.PesCod, &Context.TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	&CreFrpPgtoCod.Clear()
	&CreFrpPgtoCod.AddItem(0, 'TODAS - EXCETO CARTÕES')
	For &sdtFormasPagamentoItem in &sdtFormasPagamento	
		&DescricaoVarchar = &sdtFormasPagamentoItem.FrpPgtoCodExib + ' - ' + &sdtFormasPagamentoItem.FrpPgtoNom
		&CreFrpPgtoCod.AddItem(&sdtFormasPagamentoItem.FrpPgtoCod, &DescricaoVarchar)
	EndFor
	//RETORNA FORMAS PAGAMENTOS
	
//	If &TCon077_ExibeStatusDebitoCliente = 'S'
//		&Status.Enabled = TRUE
//	Else
//		&Status.Enabled = False
//	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsMostrarObs.TooltipText = "marcando esta opção, sera mostrado as observações da duplicata "
	&IsJuros.TooltipText = "Somar valor de juros no saldo da duplicata, com simulação de pgto na data de emisão do relatório."
	&IsPromessa.TooltipText = "Marcando esta opção o relatorio vai filtrar pela data de promessa e não por data de vencimento."
	&IsSintetico.TooltipText = "Marque esta opção para o relatório sair no modo sintético (Resumido)"
	&AreCod.TooltipText = "Área do Vendedor"
	&UfeCod.TooltipText = "Estado do Cliente"
	&CidCod.TooltipText = "Cidade do Cliente"

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'Cliente'
	Do 'Vendedor'
	Do 'Area'
	Do 'Cidade'
	Do 'Estado'

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&IsSintetico = False)
		&IsMostrarObs.Visible = False
		IsMostrarObs_Cell.Class = !'Invisible'
	Else
		&IsMostrarObs.Visible = True
		IsMostrarObs_Cell.Class = !'col-xs-12 col-sm-6 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'AttributesSecurityCode'

EndEvent

Event &CreCliCod.IsValid

	Do 'Cliente'

EndEvent

Event &PesCod.IsValid

	Do 'Vendedor'

EndEvent

Event &AreCod.IsValid

	Do 'Area'

EndEvent

Event &CidCod.IsValid

	Do 'Cidade'

EndEvent

Event &UfeCod.IsValid

	Do 'Estado'

EndEvent

Event &IsSintetico.Click

	Do 'AttributesSecurityCode'
	&IsMostrarObs = false

EndEvent

Event Enter

	Do 'Obrigatorio'
	Do 'AttributesSecurityCode'
	If &CheckRequiredFieldsResult = True
		If &Status = 'A'
			RCOOpenWindow1.LinkOpen = RELJAS021.Link(&EmpCod,&FilCod,&AreCod,&CidCod,&UfeCod,&CreCliCod,&CreDtaEmsFin,&CreDtaEmsIni,&CreDtaVctFin,&CreDtaVctIni,&CreDupPrt,&CreRecPag,&IsSintetico,&PesCod,&CreCbrCod,&CreCliClaTip,&IsPromessa,&IsJuros,&IsMostrarObs,&Ordem,&CreFrpPgtoCod,&Status, &IsPerdido,&IsPedido,&IsDetalhaPedido, &StsDup,&CreFilPgt)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Else
			RCOOpenWindow1.LinkOpen = RELJAS021P.Link(&EmpCod,&FilCod,&AreCod,&CidCod,&UfeCod,&CreCliCod,&CreDtaEmsFin,&CreDtaEmsIni,&CreDtaVctFin,&CreDtaVctIni,&CreDupPrt,&CreRecPag,&IsSintetico,&PesCod,&CreCbrCod,&CreCliClaTip,&IsPromessa,&IsJuros,&IsMostrarObs,&Ordem,&CreFrpPgtoCod,&Status, &IsPerdido,&IsPedido,&IsDetalhaPedido, &StsDup,&CreFilPgt)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Endif
	EndIf

EndEvent

Sub 'Obrigatorio'

		&CheckRequiredFieldsResult = True
	If &FilCod.IsEmpty()
		Msg('Filial é obrigatório.')
		&CheckRequiredFieldsResult = False
	EndIf
	If &CreDtaEmsFin.IsEmpty()
		Msg('Emissão Final é obrigatório.')
		&CheckRequiredFieldsResult = False
	EndIf
	If &CreDtaVctFin.IsEmpty()
		Msg('Vcto Final é obrigatório.')
		&CheckRequiredFieldsResult = False
	EndIf

EndSub

Sub 'Cliente'

	If &CreCliCod <> 0         
		For Each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &CreCliCod
			&CreCliRaz = substr(PesRaz,1,30)	
			Exit
		When none
			msg('ATENÇÃO! Cliente não encontrado ou pessoa não é cliente. Verifique!')
			&CreCliRaz = 'Cliente não encontrado.'
			&CreCliCod.SetFocus()
		EndFor
	Else
		&CreCliRaz = 'Todos os clientes'
	EndIf

EndSub

Sub 'Vendedor'

	If not &PesCod.IsEmpty()
		For Each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			Where PesIsVen = True
			
			&PesRaz = PesRaz
			Exit
		When none
			msg('ATENÇÃO! Vendedor não encontrado ou pessoa não é vendedor. Verifique!')
			&PesRaz = 'Vendedor não encontrado.'
			&PesCod.SetFocus()
		EndFor
	Else
		&PesRaz = 'Todos os Vendedores'
	EndIf

EndSub

Sub 'Area'

	If not &AreCod.IsEmpty()
		For Each Order EmpCod,AreCod
			Where EmpCod = &EmpCod
			Where AreCod = &AreCod
			&AreNom = AreNom
			Exit
		When none
			msg('ATENÇÃO! Área não encontrado, Verifique!')
			&AreNom = 'Área não encontrado.'
			&AreCod.SetFocus()
		EndFor
	Else
		&AreNom = 'Todas as Áreas'
	EndIf

EndSub

Sub 'Cidade'

	If not &CidCod.IsEmpty()
		For Each Order EmpCod,CidCod
			Where EmpCod = &EmpCod
			Where CidCod = &CidCod
			&CidNom = CidNom
			Exit
		When none
			msg('ATENÇÃO! Cidade não encontrado, Verifique!')
			&CidNom = 'Cidade não encontrado.'
			&CidCod.SetFocus()
		EndFor
	Else
		&CidNom = 'Todas as Cidades'
	EndIf

EndSub

Sub 'Estado'

	If not &UfeCod.IsEmpty()
		For Each Order EmpCod,UfeCod
			Where EmpCod = &EmpCod
			Where UfeCod = &UfeCod
			&UfeNom = UfeNom
			Exit
		When none
			msg('ATENÇÃO! Estado não encontrado, Verifique!')
			&UfeNom = 'Estado não encontrado.'
			&UfeCod.SetFocus()
		EndFor
	Else
		&UfeNom = 'Todos os Estados'
	EndIf

EndSub

Sub 'montaFilialFaturamento'

	&CreFilPgt.Clear()
	&CreFilPgt.AddItem(0, '0 - TODAS FILIAIS')
	tbFilialFaturamento.Visible = 0
	
	For &Filials in &Context.Filials
		&CreFilPgt.AddItem(&Filials.FilCodVin, gxGetMLi(&Filials.FilRazVin, 1, 25))
	EndFor
	
	if &Context.Filials.Count > 1
		tbFilialFaturamento.Visible = 1
	Endif

EndSub


