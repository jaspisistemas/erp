Sub 'loadCotacao'

	For Each ORder EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComForCod = &CotComForCod
		
		txtFornecedor.Caption = 'Fornecedor: ' + trim(CotComForRaz)
		&CotComForTipFrt = CotComForTipFrt
		&CotComForFrtVlr = CotComForFrtVlr
		&CotComForPrzEnt = CotComForPrzEnt
		
		&CotComForObs = CotComForObs
		&CotComForObs.Visible = not CotComForObs.IsEmpty() and not CotComForObs.IsNull()
		FormataParcelaMax.Call(CotComForPrzPgtParc, 0, &CotComForPrzPgtParc)
		
		Exit	
	EndFor

EndSub


