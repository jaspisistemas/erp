      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('VENDAFECHAESTOQUE', Status_SimNao.Sim, 1, &AutNiv)
	
	TextBlockTitle.Caption = 'Fecha estoque pedido de venda'
	
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&SdtPedido.FromXml(&websession.Get('SETWWPedidoVenda')) 
	PadraoUsuario.Call('L', '#PROSSEGUIRFECHAMENTO#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	if &PadObs = '1'
		&ProsseguirFechamento = true
	Else
		&ProsseguirFechamento = false
	Endif

	&PedDtaFat = serverdate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PedDtaFat.TooltipText = "Data saída do pedido, Quando saiu do  Estoque."
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelaFechamento'

	do 'volta'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &ProsseguirFechamento = true
		&PadObs = '1'
	Else
		&PadObs = '0'
	Endif

	PadraoUsuario.Call('G', '#PROSSEGUIRFECHAMENTO#', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	&StatusInvalido = 0  
	&DataInvalido = 0
	For &SdtPedidoItem in &SdtPedido
		For Each Order EmpCod, FilCod, PedCod   // valida as datas e status dos pedidos  
			where EmpCod = &SdtPedidoItem.EmPCod
			Where FilCod = &SdtPedidoItem.FiLCod
			Where PedCod  = &SdtPedidoItem.PedCod
			
			Do Case
				Case PedSts <> Status_Pedido.ABERTO and PedSts <> Status_Pedido.SEPARANDO
					&StatusInvalido = 1
				Case &PedDtaFat < PedDtaEms
					&DataInvalido = 1
			EndCase

			&PedDtaEms = PedDtaEms
			&PedSts = PedSts
		EndFOr
	EndFOr
	
	//#### se nenhum pedido ficou inválido vai funcionar.
	Do case
		Case &DataInvalido = 1
			msg('Data de Faturamento não informada ou inferior a data de emissão do pedido, verifique os pedidos selecionados!')
		Case &StatusInvalido = 1
			msg('Status de pedido diferente de ABERTO ou SEPARANDO, verifique os pedidos selecionados!')
		Otherwise
			
			For &SdtPedidoItem in &SdtPedido
				AtualizaEstoqueGerencialVenda.Call(&SdtPedidoItem.EmPCod, &SdtPedidoItem.FiLCod, &SdtPedidoItem.PedCod, &PedDtaFat, &Context.PesCod,  Status_Pedido.FECHADO)
				
//				//ATUALIZAPEDIDOVINCULADO
//				if not &PedCodOciRef.IsEmpty()
//					AtualizaVendaFutura.Call(&EmpCod, &FilCod, &PedCodOciRef, VendaFutura.BloqueiaVendaFutura)
//				Endif
				
			EndFor
			
			Do 'volta'
	EndCase

EndEvent

Sub 'volta'

	&Link = &DeOndeVem.trim() + '.aspx'
	Link(&Link)

EndSub


]]></Source>
