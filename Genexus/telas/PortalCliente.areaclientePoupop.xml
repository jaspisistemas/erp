        <Source><![CDATA[
Event Start

	Embeddedpage.Height = 700
	embeddedpage.Width = 700
		
	if &BoletoRecibo = 'B'
		if &CreCod <> 0
			PortalCliente.getDadosClienteDuplicata.Call(&EmpCod, &FilCod, &CreCod, &AuxDiretorioFisico)	
			&AuxDiretorioFisico = &AuxDiretorioFisico.Replace('http://', 'https://')
			Embeddedpage.Source = &AuxDiretorioFisico
		Else
			&random = retornaSoNumeros.Udp(serverTime())
			Embeddedpage.Source = RELJAS045.Link(&EmpCod, &FilCod, &Random)
		Endif
	Else
		&random = retornaSoNumeros.Udp(serverTime())
		&DeOndeVem = 'DUPLICATA'
		Embeddedpage.Source = RELJAS020.Link(&random, &DeOndeVem)
	Endif

