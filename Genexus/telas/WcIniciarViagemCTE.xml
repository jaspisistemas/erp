      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCTE.Rows = Page.Rows
	&GridCTECurrentPage = 1
	&GridCTECurrentPage.Visible = False
	&GridCTEPageCount = -1
	GridCTEPaginationBar.RowsPerPageSelectedValue = GridCTE.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext(&Context)
	&AuxEmpCod 		= &Context.EmpCod
	&AuxFilCod 		= &Context.FilCod
	
	&AteCteDtaEms	= &Today
	&IniCteDtaEms	= &Today - 30

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridCTEPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	CteSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCTECurrentPage	= GridCTE.CurrentPage
	&GridCTEPageCount	= GridCTE.PageCount

EndEvent

Event GridCTE.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Selecionar = !'<i class="fas fa-plus"></i>'

	&CteTerCidNom = Trim(CteTerCidNom)+' - '+CteTerUfe
	Do Case
		Case CteSts = Status_NFe.Digitando
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case CteSts = Status_NFe.Autorizada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case CteSts = Status_Nfe.Cancelada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case CteSts = Status_NFe.Denegada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfoLight WWColumnTagInfoLightSingleCell'
		Case CteSts = Status_NFe.Inutilizada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			CteSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridCTEPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridCTEPaginationBar.SelectedPage = !'Previous'
			&GridCTECurrentPage -= 1
			GridCTE.PreviousPage()
		Case GridCTEPaginationBar.SelectedPage = !'Next'
			&GridCTECurrentPage += 1
			GridCTE.NextPage()
		Otherwise
			&PageToGo.FromString(GridCTEPaginationBar.SelectedPage)
			&GridCTECurrentPage = &PageToGo
			GridCTE.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridCTEPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridCTE.Rows = GridCTEPaginationBar.RowsPerPageSelectedValue
	&GridCTECurrentPage = 1
	GridCTE.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Selecionar.Click

	&AuxCteChv = CteChv
	&AuxPesCpf = CteCpfMot
	&CteNomMot = CteNomMot

	&DataVazia.SetEmpty()
	Do 'VerificaCTE'
	Do 'CarregaVeiculo'
	Do 'GetMotorista'
	
	Do Case
		Case &IsExisteCTe = True
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "Este CT-e já está vinculado a viagem: " + Trim(Str(&AuxViaCod)),DVMessageType.information, "", DVMessageBoolean.True,""))
			
		Case &IsAchouMotorista = FALSE
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "Motorista do CT-e não encontrado ou não cadastrado: " + Trim(&CteNomMot) ,DVMessageType.error, "", DVMessageBoolean.True,""))
			
		OtherWise			
			
			prcMovimentaViagem.Call('INS', EmpCod, FilCod, &NewViaCod, '', &Today, &DataVazia, 0, 0, 0, 'P', CteVlrRecSer, &AuxPesCod, &AuxVeiCod, CteIniUfe, CteIniCidCod, CteTerUfe, CteTerCidCod, &ViaPlaCar1, '', '', 0,0, &Mensagem)
			prcVinculaViagemCteCarga.Call(EmpCod, FilCod, CteCod, &NewViaCod)

			If Not &Mensagem.IsEmpty()
				&AuxMensagem = SubStr(&Mensagem, 1, 3)
				If &AuxMensagem = '200'
					prcValorComissaoViagem.Call(EmpCod, FilCod, 0, &NewViaCod, 0, 0)
					msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", Trim(&Mensagem), DVMessageType.success, "", DVMessageBoolean.True,""))
					WpAdicionaViagens.Link('wpviagens', 'UPD', &NewViaCod)
				Else
					msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", Trim(&Mensagem), DVMessageType.regular, "", DVMessageBoolean.True,""))
				EndIf
			EndIf
		
	EndCase

EndEvent

Sub 'CarregaVeiculo'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &AuxEmpCod
		Where FilCod = &AuxFilCod
		Where CteChv = &AuxCteChv
		
		&AuxCteCod 	= CteCod
		&ViaPlaCar1	= CtePlc
		&AuxVeiPla	= CtePlcTra
		Do 'GetVeiculo'

		Exit
	EndFor

EndSub

Sub 'GetMotorista'

	&IsAchouMotorista = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &AuxEmpCod
		Where PesCpf = &AuxPesCpf
		
		&AuxPesCod 	 = PesCod
		&IsAchouMotorista = true
		Exit		
	EndFor

EndSub

Sub 'GetVeiculo'

	For Each Order EmpCod, VeiCod
		Where EmpCod = &AuxEmpCod
		Where VeiPla = &AuxVeiPla
		
		&AuxVeiCod = VeiCod
		
		Exit
	EndFor

EndSub

Sub 'VerificaCTE'

	For Each Order EmpCod, FilCod, ViaCod, ViaCarCod
		Where EmpCod 		= &AuxEmpCod
		Where FilCod 		= &AuxFilCod
		Where ViaCarCteChv	= &AuxCteChv
		Where ViaCarSts		<> 'C'
		
		&AuxViaCod			= ViaCod
		&IsExisteCTe		= True
		
		Exit
	When None
		
		&AuxViaCod			= 0
		&IsExisteCTe		= False
		
	EndFor

EndSub


]]></Source>
