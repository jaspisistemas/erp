        <Source><![CDATA[
Event Start

	&IsRemoveTudo = false
	
	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	Grid.Rows = 10
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadGrupo'

EndEvent

Event Refresh

	&TotOcsEtpQtd.SetEmpty()
	&TotValueOcsEtpQtd.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&Alterar.ColumnHeaderClass = !'WWActionColumn'
	&remove.ColumnHeaderClass = !'WWActionColumn'
	OcsEtpItm.ColumnHeaderClass = !'WWColumn'
	OcsEtpGrupCod.ColumnHeaderClass = !'WWColumn'
	OcsEtpGrupNom.ColumnHeaderClass = !'WWColumn'
	OcsEtpQtd.ColumnHeaderClass = !'WWColumn'
	&OcsQtd.ColumnHeaderClass = !'WWColumn'
	&AptQtd.ColumnHeaderClass = !'WWColumn'
	&AlterarOrdem.ColumnHeaderClass = !'WWIconActionColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'CalculateTotalizersa'
	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount

EndEvent

Event Grid.Load

	&AptQtd = prcRetornaQuantosApontamentos.Udp(EmpCod, OcsCod, OcsItm, OcsEtpItm)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Alterar.FromImage(ActionUpdate)
	&Alterar.TooltipText = ""
	
	&remove.FromImage(ActionDelete)
	&remove.TooltipText = ""
	If (&AptQtd =  0)
		&remove.Class = !'ActionBaseColorAttribute'
	Else
		&remove.Class = !'Invisible'
	Endif
	&AlterarOrdem = !'<i class="fas fa-sync"></i>'

	&OcsQtd = OcsQtd
	&AptQtd = prcRetornaQuantosApontamentos.Udp(EmpCod, OcsCod, OcsItm, OcsEtpItm)
	&Alterar.ColumnClass = iif(OcsEtpQtd <= 0, !'WWActionColumn WWColumnDanger WWColumnDangerFirstColumn', !'WWActionColumn')
	&remove.ColumnClass = iif(OcsEtpQtd <= 0, !'WWActionColumn WWColumnDanger', !'WWActionColumn')
	OcsEtpItm.ColumnClass = iif(OcsEtpQtd <= 0, !'WWColumn WWColumnDanger', !'WWColumn')
	OcsEtpGrupCod.ColumnClass = iif(OcsEtpQtd <= 0, !'WWColumn WWColumnDanger', !'WWColumn')
	OcsEtpGrupNom.ColumnClass = iif(OcsEtpQtd <= 0, !'WWColumn WWColumnDanger', !'WWColumn')
	OcsEtpQtd.ColumnClass = iif(OcsEtpQtd <= 0, !'WWColumn WWColumnDanger', !'WWColumn')
	&OcsQtd.ColumnClass = iif(OcsEtpQtd <= 0, !'WWColumn WWColumnDanger', !'WWColumn')
	&AptQtd.ColumnClass = iif(OcsEtpQtd <= 0, !'WWColumn WWColumnDanger', !'WWColumn')
	&AlterarOrdem.ColumnClass = iif(OcsEtpQtd <= 0, !'WWIconActionColumn WWColumnDanger', !'WWIconActionColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSim'

//	Do case
//		otherwise
			&IsRemoveTudo = false
			Do 'AttributesSecurityCode'
			GravaEtapaProdutoOrdem.Call('DEL', &EmpCod, &ocsCod, &OcsItm, 0, 0, 0)
			refresh
			&CTrCod = 0
			&CTrCod.SetFocus()
//	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNaoRemove'

	&IsRemoveTudo = false
	Do 'AttributesSecurityCode'
	&CTrCod = 0
	&CTrCod.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&IsRemoveTudo <> true)
		DVPanel_TableAttributes_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributes_Cell.Class = !'col-xs-12'
	EndIf
	If not(&IsRemoveTudo = true)
		DVPanel_RemoveTudo_Cell.Class = !'Invisible'
	Else
		DVPanel_RemoveTudo_Cell.Class = !'col-xs-12'
	EndIf
	UnnamedTable1.Visible = (&IsCopiarEtapas <> true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event 'DoImprimir'

	RCOOpenWindow1.LinkOpen = RELJAS100.Link(&EmpCod, &FilCod, &GrupCod)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event &Alterar.Click

	wpEditaEtapaOrdem.Popup(EmpCod, OcsCod, OcsItm, OcsEtpItm)
	Refresh

EndEvent

Event &CTrCod.IsValid

	do 'ValidaEtapa'

EndEvent

Event Enter

	do 'ValidaEtapa'
	Do Case
		case &CTrNom.IsEmpty()
			msg('Etapa não localizada!')
		otherwise
			
			GravaEtapaProdutoOrdem.Call('ADD', &EmpCod, &OcsCod, &OcsItm, &CTrCod, 0, &GrupCTrQtd)
			refresh
			&CTrCod = 0
			&GrupCTrQtd.SetEmpty()
			&CTrCod.SetFocus()
	Endcase

EndEvent

Event &remove.Click

	if &AptQtd = 0
		wpRemoveEtapaOrdem.Popup(EmpCod, OcsCod, OcsItm, OcsEtpItm)
		Refresh
	Else
		msg('Etapa não Pode ser eliminada, possui lançamentos!')
	Endif

EndEvent

Event &AlterarOrdem.Click

	NovaOrdemEtapaCostura.Popup(EmpCod, OcsCod, OcsItm, OcsEtpItm)
	Refresh

EndEvent

Sub 'LoadGrupo'

	For each ORder EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &OcsItm
		&GrupHie = OcsProNroCor
		&GrupNom = OcsProGraNom
		Exit
	EndFor

EndSub

Sub 'ValidaEtapa'

	&CTrNom.SetEmpty()
	RetornaNomeEtapa.call(&EmpCod, &CTrCod, &CTrNom)

EndSub

Sub 'CalculateTotalizersa'

	For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &OcsItm
		
		&TotOcsEtpQtd += OcsEtpQtd 
		
	EndFor
	&TotValueOcsEtpQtd = &TotOcsEtpQtd.ToFormattedString()

EndSub


