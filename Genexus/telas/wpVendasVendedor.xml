      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPVENDASVENDEDOR', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&WwpContext)
	&EmpCod = &WwpContext.EmpCod
	&FilCod = &WwpContext.FilCod
	
	&TrocarTelevendas = RetornaAutorizacao.UDP('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1)
	&PedVenCod.Visible = &TrocarTelevendas
	&AnoBase = Year(serverDate())
	
	if &TrocarTelevendas < 1 or &PedVenCod.IsEmpty()
		&PedVenCod = &WwpContext.PesCod
		do 'ValidaVendedor'
		
		&SelPedVenCod = &PedVenCod
		&selPedVenRaz = &PedVenRaz
		&SelAnoBase = &AnoBase
		&SelMesBase = &MesBase
		
		prcVendasVendedor.Call(&EmpCod, &FilCod, &PedVenCod, &PesVenIntExt, &RegistradoTodos, false, &AnoBase, &MesBase, &sdtPedidosVendedor, &sdtPedidosTotal)
		prcRetornaMetaVendedor.call(&EmpCod, &PedVenCod, &PesVenIntExt, &RegistradoTodos, &AnoBase, &MetaAnualMoeda, &MetaMensalMoeda, &MetaDia)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&FilCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 35
	GridMetas_Empowerer.GridInternalName = GridMetas.InternalName
	GridMetas.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	If &SelMesBase.IsEmpty()
		&Mes.Visible = 1
		&dia.Visible = 0
		&Semana.Visible = 0
	Else
		&Mes.Visible = 0
		&dia.Visible = 1
		&Semana.Visible = 1
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&RealizadoMoeda.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	for &sdtPedidosVendedorItem in &sdtPedidosVendedor
		&Mes = &sdtPedidosVendedorItem.Mes
		&dia = &sdtPedidosVendedorItem.Dia
		&Semana = &sdtPedidosVendedorItem.Semana

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&Vendido = &sdtPedidosVendedorItem.VendidoMoeda
		&Faturado = &sdtPedidosVendedorItem.FaturadoMoeda
		
		&Vendido.ColumnClass = 'WWColumn'
		&Semana.ForeColor = RGB(0,0,0)
		&dia.ForeColor = RGB(0,0,0)
		&Vendido.ForeColor = RGB(0,0,0)
		&Faturado.ForeColor = RGB(0,0,0)
		If &Semana = 'SÁB' or &Semana = 'DOM' or &sdtPedidosVendedorItem.feriado = true
			&Semana.ForeColor = RGB(255,0,0)
			&dia.ForeColor = RGB(255,0,0)
			&Vendido.ForeColor = RGB(255,0,0)
			&Faturado.ForeColor = RGB(255,0,0)
		Endif
		
		If  &Vendido < &MetaDia or &Vendido.IsEmpty()
			&Vendido.ColumnClass = 'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Else //&Vendido >= &MetaDia
			&Vendido.ColumnClass = 'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Endif
	
		load
	EndFor

EndEvent

Event GridMetas.Load

	if &selMesBase.IsEmpty()
		&TituloMeta = 'Anual'
		&OrcadoMoeda = &MetaAnualMoeda
		&RealizadoMoeda = &TotalVendido
	Else
		&TituloMeta = 'Mensal'
		&OrcadoMoeda = &MetaMensalMoeda
		&RealizadoMoeda = &TotalVendido
	Endif

	do 'Pinta'
	Load
	
	if &selMesBase.IsEmpty()
		&TituloMeta = 'Mensal'
		&OrcadoMoeda = &MetaMensalMoeda
		if &TotalVendido > 0
			&RealizadoMoeda = &TotalVendido/12
		Else
			&RealizadoMoeda = 0
		Endif
		
		do 'Pinta'
		LOad
	Endif
	
	&TituloMeta = 'Diária'
	&OrcadoMoeda = &MetaDia
	Do Case 
		Case &selMesBase.IsEmpty() and &TotalVendido > 0
			&RealizadoMoeda = &TotalVendido/365
		Case &TotalVendido > 0  and &selMesBase <> 0
			&Data = YMDtoD(&selAnoBase, &selMesBase, 1)
			&UltimaData = eoM(&data)
			&Numeric = val(substr(toformattedString(&UltimaDAta),1,2))
			&RealizadoMoeda = &TotalVendido / &Numeric
		Otherwise
			&RealizadoMoeda  = 0
	Endcase

	do 'Pinta'
	Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	Do Case
		Case &RealizadoMoeda > &OrcadoMoeda
			&RealizadoMoeda.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case &RealizadoMoeda < &OrcadoMoeda and &RealizadoMoeda > 0
			&RealizadoMoeda.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			&RealizadoMoeda.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

