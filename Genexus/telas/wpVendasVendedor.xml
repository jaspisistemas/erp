EndEvent

Event Enter

	&TotalVendido.SetEmpty()
	&TotalFaturado.SetEmpty()
	do 'ValidaVendedor'
	if &PesIsVen = false and &PedVenCod <> 0
		msg('Pessoa informada não é um vendedor!')
	Else
		
		&SelPedVenCod = &PedVenCod
		&selPedVenRaz = &PedVenRaz
		&SelAnoBase = &AnoBase
		&SelMesBase = &MesBase
		
		prcVendasVendedor.Call(&EmpCod, &FilCod, &PedVenCod, &PesVenIntExt, &RegistradoTodos, false, &AnoBase, &MesBase, &sdtPedidosVendedor, &sdtPedidosTotal)
		prcRetornaMetaVendedor.call(&EmpCod, &PedVenCod, &PesVenIntExt, &RegistradoTodos, &AnoBase, &MetaAnualMoeda, &MetaMensalMoeda, &MetaDia)		
		
		For &sdtPedidosTotalItem in &sdtPedidosTotal
			Do Case
				Case &sdtPedidosTotalItem.Descricao = 'VENDIDO'
					&TotalVendido = &sdtPedidosTotalItem.FaturadoMoeda
				Case &sdtPedidosTotalItem.Descricao = 'FATURADO'
					&TotalFaturado  = &sdtPedidosTotalItem.FaturadoMoeda
			EndCase
		EndFor
	
		refresh
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	do 'ValidaVendedor'
	if &PesIsVen = false and &PedVenCod <> 0
		msg('Pessoa informada não é um vendedor!')
	Else
		
		&SelPedVenCod = &PedVenCod
		&selPedVenRaz = &PedVenRaz
		&SelAnoBase = &AnoBase
		&SelMesBase = &MesBase
		
		RCOOpenWindow1.LinkOpen = RELJAS123.Link(&EmpCod, &FilCod, &PedVenCod, &PesVenIntExt, &RegistradoTodos, &SelAnoBase, &SelMesBase)
