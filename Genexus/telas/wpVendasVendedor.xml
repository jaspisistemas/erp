Sub 'Pinta'

	Do Case
		Case &RealizadoMoeda > &OrcadoMoeda
			&RealizadoMoeda.ColumnClass = 'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case &RealizadoMoeda < &OrcadoMoeda and &RealizadoMoeda > 0
			&RealizadoMoeda.ColumnClass = 'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			&RealizadoMoeda.ColumnClass = 'WWColumn'
	EndCase

EndSub

Sub 'ValidaVendedor'

	&PedVenRaz.SetEmpty()
	&PesVenIntExt.Enabled = 1
	
	&RegistradoTodos.Enabled = 1
	&PesIsVen = false
	for Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		where PesCod = &PedVenCod
		
		if &TrocarTelevendas > 0
			&PedVenRaz = PesRaz
		Else
			&PedVenRaz = PesCodRaz
		EndIf
	
		&PesVenIntExt = PesVenIntExt
		&PesIsVen = PesIsVen
		
		&PesVenIntExt.Enabled = 0
		&RegistradoTodos.Enabled = 0
		Exit
	When none
		if &PedVenCod.IsEmpty()
			&PedVenRaz = 'TODOS OS VENDEDORES'
		Else
			&PedVenRaz = 'VENDEDOR NÃO LOCALIZADO'
		Endif
	EndFor

EndSub


