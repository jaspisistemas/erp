      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	do 'CarregaPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItens_Empowerer.GridInternalName = GridItens.InternalName
	GridItens.Rows = 0
	&GridItensCurrentPage = 1
	&GridItensCurrentPage.Visible = False
	&GridItensPageCount = -1
	GridItensPaginationBar.RowsPerPageSelectedValue = GridItens.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	loadWWPContext.Call(&Context)
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon017_DescMax, &Varchar)
	&TCon017_DescMax = val(&Varchar) //Tabela Normal

	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon131_DescMaxTabPromocao, &Varchar)
	&TCon131_DescMaxTabPromocao = val(&Varchar) //Tabela Normal
	
	
	if &Context.TipoPerfil <> 3																			//## Se o perfil do usuário for diferente de ADM ##\\
		RetornaAutorizacaoDescontoMaximo.Call(&EmpCod, &Context.PesCod, &IsAutorizadoDescontoMaximo)	//## Verifica se ele está autorizado a dar o desconto máximo ##\\
	Else
		&IsAutorizadoDescontoMaximo = true																//## Se o perfil for ADM, ele estará autorizado a dar o desconto máximo ##\\
	Endif

	&PedItmDsc.Enabled = &AutorizadoDesconto															//## Desconto só será habilitado se o usuário poder adicionar desconto ##\\
	
	&Mensagem = ''
	TxtMensagem.Caption = ''
	TbItens.Visible = 0

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridItensPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridItens.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'RecarregaDesc'	//## Rotina para carregar os itens ##\\

EndEvent

Event GridItensPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridItensPaginationBar.SelectedPage = !'Previous'
			&GridItensCurrentPage -= 1
			GridItens.PreviousPage()
		Case GridItensPaginationBar.SelectedPage = !'Next'
			&GridItensCurrentPage += 1
			GridItens.NextPage()
		Otherwise
			&PageToGo.FromString(GridItensPaginationBar.SelectedPage)
			&GridItensCurrentPage = &PageToGo
			GridItens.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridItensPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItens.Rows = GridItensPaginationBar.RowsPerPageSelectedValue
	&GridItensCurrentPage = 1
	GridItens.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	prcAlteraDescontoPedidoProduto.Call(&EmpCod, &FilCod, &PedCod, &PedItmDsc, &Context, &IsTensComErro, &TotalMensagem)	//## Procedimento para atualizar a tabela PedidoProduto ##\\
	if &IsTensComErro = false
		Return
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedItmDsc.IsValid

	&IsFocoPercentual = true
	
	IF &PedItmCod.IsEmpty()	//## Se não houver dados no GridItens ele carrega novos dados ##\\
		GridItens.Load()
	Else
		Refresh				//## Senão ele atualiza o GridItens ##\\
	EndIf

EndEvent

Sub 'RecarregaDesc'

	For Each Order EmpCod, FilCod, PedCod, PedItmCod	//## Faz uma pesquisa na Tabela PedidoProduto ##\\
		Where EmpCod = &EmpCod							//## Código da Empresa passada por parâmetro ##\\
		Where FilCod = &FilCod							//## Código da Filial passada por parâmetro ##\\
		Where PedCod = &PedCod							//## Código do pedido passado por parâmetro ##\\
		
		&PedItmCod = PedItmCod							//## Define o Código do Item ##\\
		&PedVlrUnt = PedVlrUnt							//## Define o Valor Unitário do Item ##\\
		&PedVlrTab = PedVlrTab							//## Define o Valor do Item referente a sua tabela de preço ##\\
				
		&ProCod = ProCod								//## Código do Produto (Item) ##\\
		&PedProNom = ProNom			//## Nome do Produto (Item) ##\\
		&ProDesMax = ProDesMax		//## Desconto máximo do PRODUTO (Item) ##\\
		&GrupDscMax = GrupDscMax	//## Desconto máximo do GRUPO do Produto ##\\
		&ProGraCod = ProGraCod					//## Código da Grade do Produto ##\\
		&ProGraRef = ProGraRef					//## Código de Barras do Produto ##\\
		
		&QuantidadeFormatada6 = PedQtd									//## Quantidade de Itens ##\\
		&PedQtdVarchar = trim(toformattedString(&QuantidadeFormatada6))	//## Quantidade de Itens em VarChar ##\\
		RetiraZerosDepoisVirgula.Call(&PedQtdVarchar, &PedQtdVarchar)	//## Quantidade de Itens em VarChar e sem os zeros após a vírgula ##\\
		
		&PedVlrUntVarchar = trim(toformattedString(PedVlrUnt))							//## Valor Unitário do Item em VarChar ##\\
		RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntVarchar, &PedVlrUntVarchar)	//## Valor Unitário do Item em VarChar e sem os zeros após a vírgula ##\\
		
		&PedItmDscVarchar = trim(toformattedString(PedItmDsc))					//## Desconto atual do Item em VarChar ##\\
		RetiraZerosDepoisVirgula.Call(&PedItmDscVarchar, &PedItmDscVarchar)		//## Desconto atual do Item em VarChar e sem os zeros após a vírgula ##\\
		
		&PedVlrUntDscVarchar = trim(toformattedString(PedVlrUntComDsc))						//## Valor Unitário do Item, com desconto, atual em VarChar ##\\
		RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntDscVarchar, &PedVlrUntDscVarchar)	//## Valor Unitário do Item, com desconto, atual em VarChar e sem os zeros após a vírgula ##\\
		
		RetornaTotalAutorizado.Call(&EmpCod, &FilCod, &PedCod, &ProCod, &ProGraCod, &PedLibAutPedQtd, &PedLIbAutPedVlr, &PedLibAutPedDesc)	//## Verifica as autorizações do pedido ##\\
		
		
		If &IsAutorizadoDescontoMaximo <> true	//## Se o usuário não estiver autorizado à dar o desconto máximo ##\\
			
			&TotalDescontos = 0
			IF (&PedVlrUnt <> &PedVlrTab) AND (&PedVlrUnt > 0) AND (&PedVlrTab > 0)
				&TotalDescontos = (100 - ((&PedVlrUnt / &PedVlrTab) * 100))
			EndIF
			
			//if &PedItmDsc > 0
			&TotalDescontos += &PedItmDsc
			//EndIF
			if &PedItmDsc < 0
				&TotalDescontos = 0
			Endif
		
			&PedItmPrm = PedItmPrm
			if PedItmPrm = domPedItmPrm.NORMAL and &TotalDescontos > 0
				&PedItmPrm = domPedItmPrm.DESCONTO
			Endif		
			
			&PedVlrItm = round((PedVlrUntDsc*PedQtd)/(1+PedItmDsc/100),2)	//## Calcula o novo valor total com base no novo desconto ##\\
			
			VerificaDescontoMaximoPedidoItem.Call(EmpCod, FilCod, PedCod, &Context, PedItmCod, &PedItmPrm, &PedVlrItm, &TotalDescontos, PedVlrUnt, &TCon017_DescMax, &TCon131_DescMaxTabPromocao, &PesDscMax, &ProDesMax, &GrupDscMax, &PedLibAutPedQtd, &PedLibAutPedVlr, &PedLibAutPedDesc, ProRef, ProNom, &Mensagem, &IsErro)
			&ErroDescontoMaximo = iif(&IsErro = true, 1, 0)
		EndIf
		
		if &ErroDescontoMaximo = 1															//## Se houver um erro de desconto ##\\
			if &PedItmDsc > 0 and &AutorizadoDesconto <> 0 and &IsFocoPercentual = true

				&PedItmDsc.SetFocus()														//## Define o foco do cursor na Edite de desconto ##\\\
				&PedVlrItm = PedVlrItm														//## Atribui o atual valor total do Item ##\\
				&PedItmDscVarchar = trim(toformattedString(PedItmDsc))						//## Atribui o desconto atual do Item em VarChar, novamente ##\\
								
				RetiraZerosDepoisVirgula.Call(&PedItmDscVarchar, &PedItmDscVarchar)			//## Desconto atual do Item em VarChar e sem os zeros após a vírgula ##\\
				
				Tbitens.Visible = 1
				TxtMensagem.Visible = 1
				TxtMensagem.Caption = trim(&Mensagem)										//## Mostra a mensagem de ERRO ##\\		
			EndiF
			Load
		Else																				//## Se não houver erro de desconto ##\\
			If &PedItmDsc > 0																//## Se a nova porcentagem de desconto for maior que zero ##\\
				&PedVlrItm = round((PedVlrUntDsc*PedQtd)/(1+&PedItmDsc/100),2)				//## Calcula o novo valor Total do Item com o desconto informado ##\\
				&PedItmDscVarchar = trim(toformattedString(&PedItmDsc)) 					//## Novo valor de Desconto em VarChar ##\\
				
				RetiraZerosDepoisVirgula.Call(&PedItmDscVarchar, &PedItmDscVarchar)			//## Novo valor de Desconto em VarChar e sem os zeros após a vírgula ##\\
				
				Tbitens.Visible = 0
				TxtMensagem.Visible = 1
				TxtMensagem.Caption = 'O desconto de ' + trim(&PedItmDscVarchar) +'% foi aplicado à itens.' //## Confirma o sucesso da operação ##\\
			EndIf
		EndiF
		
	EndFor

EndSub

Sub 'CarregaPedido'

	For Each Order EmpCod, FilCod, PedCod	//## Faz uma busca na Tabela Pedido para carregar as informações do Pedido ##\\
		Where EmpCod = &EmpCod				//## Código da Empresa passada por parâmetro ##\\
		Where FilCod = &FilCod				//## Código da Filial passada por parâmetro ##\\
		Where PedCod = &PedCod				//## Código do Pedido passado por parâmetro ##\\
		
		&PesDscMax = PedCliDscMax			//## Desconto máximo do CLIENTE ##\\
		
		Exit
	EndFor

EndSub


]]></Source>
