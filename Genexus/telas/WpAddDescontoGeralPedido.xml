      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[PARM(IN:&EmpCod, In:&FilCod, In:&PedCod, In:&AutorizadoDesconto, out:&PedItmDsc);
]]></Source>
