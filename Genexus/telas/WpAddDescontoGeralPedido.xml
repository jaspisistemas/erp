up_AGBtns" class="TrnActionGroup"><item><action controlName="BtnCancel" onClickEvent="Cancel" caption="GX_BtnCancel" class="BtnDefault" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;title&lt;/Name&gt;&lt;Value&gt;GX_BtnCancel&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;" /></item><item><action controlName="BtnConfirmar" onClickEvent="'DoConfirmar'" caption="Confirmar" /></item></actionGroup></actionGroups></layout></detail></Form><Form id="2" type="html"><BODY><gxAttribute AttID="&amp;GridItensCurrentPage" /><gxWWP.GridEmpowerer ControlName="GridItens_Empowerer" /></BODY></Form></GxMultiForm>]]></Source>
