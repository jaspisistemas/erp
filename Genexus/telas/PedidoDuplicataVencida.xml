      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 600
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		TextBlockTitle.Caption = trim(PesCodRaz)
		Exit
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EnviarEmail.FromImage(ActionEmail)
	&EnviarEmail.TooltipText = ""
	If ((CreCbrImp = TipoImpressao.ImprimirBoleto and CreBloNro <> ''))
		&EnviarEmail.Class = !'ActionAttribute'
	Else
		&EnviarEmail.Class = !'Invisible'
	Endif
	&Imprimir.FromImage(ActionPrinter)
	&Imprimir.TooltipText = ""
	If ((CreCbrImp = TipoImpressao.ImprimirBoleto and CreBloNro <> ''))
		&Imprimir.Class = !'ActionAttribute'
	Else
		&Imprimir.Class = !'Invisible'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	CreDupNro.Link = verDuplicata.Link('Dashboard', EmpCod, FilCod, CreCod)
	CreDupNro.LinkTarget = '_blank'
	
	CrePedCod.Link = VerPedido.Link('', EmpCod, FilCod, CrePedCod)
	CrePedCod.LinkTarget = '_blank'
	
	If CreDtaVct < &CreDtaVct
		CreDtaVct.ForeColor = RGB(160,40,0)
		&QtdDiasVcto = &CreDtaVct - CreDtaVct
		&QtdDiasVcto.ForeColor = RGB(160,40,0)
	Else
		CreDtaVct.ForeColor = RGB(0,0,0)
		&QtdDiasVcto = &CreDtaVct - CreDtaVct
		&QtdDiasVcto.ForeColor = RGB(0,0,0)
	EndIF
	
	&CreVenNom = trim(str(CreVenCod)) + ' - ' + substr(CreVenNom,1,10)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &EnviarEmail.Click

	If CreSts <> Status_Duplicata.CANCELADA
		&sdtBoleto.Clear()
		&sdtBoletoItem = new()
		&sdtBoletoItem.CreEmpCod = EmpCod
		&sdtBoletoItem.CreFilCod = FilCod
		&sdtBoletoItem.CreCod = CreCod
		&sdtBoleto.Add(&sdtBoletoItem)
		
		GerarBoleto.call(&sdtBoleto, true, &IsErro, &newSdtBoleto)
		
		if &IsErro = false
			&WebSession.Set('wpEnviaBoleto', &sdtBoleto.Toxml())
			wpEnviaBoleto.Popup()
		EndIF
	EndIF

EndEvent

Event &Imprimir.Click

	If CreSts <> Status_Duplicata.CANCELADA
		&sdtBoleto.Clear()
		&sdtBoletoItem.CreCod = CreCod
		&sdtBoletoItem.CreFilCod = FilCod
		&sdtBoletoItem.CreEmpCod = EmpCod
		&sdtBoleto.Add(&sdtBoletoItem)
		
		GerarBoleto.call(&sdtBoleto, true, &IsErro, &newSdtBoleto)
		
		if &IsErro = false
			RCOOpenWindow1.LinkOpen = RELJAS045.Link(EmpCod, FilCod, '')
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		EndIf
	EndIf

EndEvent


]]></Source>
