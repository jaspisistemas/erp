      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&SdtPedido.FromXml(&websession.Get('SETWWPedidoVenda_CancelamentoGrupo'))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbJustificativa.Height = 60
	&IsPodePodeExcluir.Visible = False
	&PodeAlterarAutNiv.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For &SdtPedidoItem in &SdtPedido
		For Each Order EmpCod, FilCod, PedCod   // valida as datas e status dos pedidos  
			where EmpCod = &SdtPedidoItem.EmPCod
			Where FilCod = &SdtPedidoItem.FiLCod
			Where PedCod  = &SdtPedidoItem.PedCod
			
			If &Mensagem.IsEmpty()
				msg('Informe um porque do Cancelamento dos pedidos por favor!')
				&Mensagem.SetFocus()
			Else
				&Mensagem2 = 'Cancelamento realizado com rotina em Grupo com motivo: '+trim(&Mensagem)
				&PedStsCod = RetornaCodigoStatusPedido.Udp(&EmpCod, 'CANCELADO')
				GravaStatusPedido.Call(EmpCod, FilCod, PedCod, &PedStsCod, &Mensagem2, 0, &Context.PesCod)
				AtualizaEstoqueGerencialVenda.Call(EmpCod, FilCod, PedCod, PedDtaFat, &Context.PesCod, Status_Pedido.CANCELADO)				
			Endif
		EndFor
	EndFor

	return

EndEvent


]]></Source>
