      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadwwPContext.Call(&Context)
	&PesCod = &Context.PesCod
	
	Do 'LoadNfe'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&NfeLctNatOpe.Visible = False
	&LctDesFun.Visible = False
	&LctTip.Visible = False
	&NfeCliCidUF.Visible = False
	&NfeCliGruImpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &ModCod = '55' and &NfeCliCod <> 0 and &IgnoraTabelaImposto = Status_SimNao.Sim	
		Do 'ValidaTabelaimposto'
	Else
		&IsAchou = true
	EndIf
		
	Do Case
		Case &IsAchou = true 
			prcClonarNfe.Call(&EmpCod, &FilCod, &NfeCod, &FilCodFat, &auxNfeFin,&auxNfeEntSai,&auxNfeLctCod, Nota_ProPriaTerceira.PROPRIA, &IgnoraTabelaImposto,&NewNfeCod)
			
			if &ModCod = '65'
				&WizardData65.CapaNFCe.FilCod = &FilCodFat
				&WizardData65.CapaNFCe.NfeCod = &NewNfeCod
				&WizardData65.CapaNFCe.EmpCod = &EmpCod
				&WizardData65.CapaNFCe.SolCod = 0
				&WebSession.Set('wpEmiteNFCe_Data', &WizardData65.ToJson())
				
				wpemitenfce.Link('', 'CapaNFCe', false)
			Else
				&WizardData.Capa.FilCod = &FilCodFat
				&WizardData.Capa.NfeCod = &NewNfeCod
				&WizardData.Capa.EmpCod = &EmpCod
				&WebSession.Set('wpNota_Data', &WizardData.ToJson())
				
				wpNota.Link('', 'Capa', false)
			EndIF
		otherWise
			Msg('Tabela de imposto não encontrada para este tipo de lançamento!')
	EndCase

EndEvent

Event &auxNfeLctCod.IsValid

	Do 'loadNatureza'

EndEvent

Event &auxNfeFin.IsValid

	Do 'MontaCombo'

EndEvent

Event &auxNfeEntSai.IsValid

	Do 'MontaCombo'

EndEvent

Sub 'ValidaTabelaimposto'

	&IsAchou = 0
	
	For Each Order EmpCod,FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCodFat
		
		if FilBasImp = 0
			&FilBasImp = FilCod
		Else
			&FilBasImp = FilBasImp
		EndIF	
	EndFor

	RetornaRegimeTributarioFilial.Call(&EmpCod, &FilBasImp, &FilRegTrib, &CImpOriUfeCod)
	
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NfeCliCod
		&NfeCliGruImpCod = PesGruImpCod
		exit
	EndFor

	//Esta localizando se tem alguma tabela de imposto cadastrada, precisava verificar se todos os CImpCatCod possuem cadastro.
	For Each Order EmpCod,CImpTbFilCod,CImpLctCod,CImpOriUfeCod,CImpDstUfeCod,CImpGruImpCod,CImpCatCod,(CImpDtaIni)
		Where EmpCod = &EmpCod
		Where CImpTbFilCod = &FilBasImp
		Where CImpLctCod = &auxNfeLctCod
		Where CImpOriUfeCod = &CImpOriUfeCod
		Where CImpDstUfeCod = &NfeCliCidUF
		Where CImpGruImpCod = &NfeCliGruImpCod
		//Where CImpCatCod = &CImpCatCod
		Where CImpDtaIni <= ServerDate()
		&IsAchou = 1 
		Exit
	EndFor

EndSub

Sub 'MontaCombo'

	&auxNfeLctCod.Clear()
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where (LctTip = TipoLancamento.DevolucaoCompra or LctTip = TipoLancamento.DevolucaoVenda) When &auxNfeFin = NotaFinalidade.EmissaoDevolucao 
		Where (LctTip <> TipoLancamento.DevolucaoCompra and LctTip <> TipoLancamento.DevolucaoVenda) When &auxNfeFin <> NotaFinalidade.EmissaoDevolucao
		Where (LctTip = TipoLancamento.OrcamentoCompra or LctTip = TipoLancamento.DevolucaoVenda or LctTip = TipoLancamento.EntradaMercadoria or LctTip = TipoLancamento.MovimentacaoValores) When &auxNfeEntSai = Status_EntradaSaida.Entrada
		Where (LctTip = TipoLancamento.OrcamentoVenda or LctTip = TipoLancamento.DevolucaoCompra or LctTip = TipoLancamento.SaidaMercadoria or LctTip = TipoLancamento.MovimentacaoValores) When &auxNfeEntSai = Status_EntradaSaida.Saida
		&auxNfeLctCod.AddItem(LctCod,LctCodNom)
	EndFor

EndSub

Sub 'loadNatureza'

	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &auxNfeLctCod
		&NfeLctNatOpe = LctNatOpe
		&LctDesFun = LctDesFun
		&LctTip  = LctTip 
		Exit
	EndFor

EndSub

Sub 'LoadNfe'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		&FilCodNom = FilCodNom
		&NfeNum = NfeNum
		&NfeCliCod = NfeCliCod
		&NfeCliRaz = NfeCliRaz
		
		&ModCod = ModCod
		&NfeChv = NfeChv
		&NfeFin = NfeFin		
		&FilCodFat = &FilCod
		&NfeEntSai = NfeEntSai
		&NfeLctCod = NfeLctCod	
		&NfeCliCidUF = NfeCliCidUF
		&NfeDtaEms = NfeDtaEms
		If ModCod = '55'
			TextBlockTitle.Caption = 'Clonar NFe: ' + trim(str(NfeNum))
		Else
			TextBlockTitle.Caption = 'Clonar NFCe: ' + trim(str(NfeNum))
		EndIf
		Exit
		
	When none
		return
	EndFor

	&auxNfeFin = &NfeFin		
	&FilCodFat = &FilCod
	&auxNfeEntSai = &NfeEntSai
	
	Do 'MontaCombo'
	&auxNfeLctCod = &NfeLctCod
	Do 'loadNatureza'

EndSub


]]></Source>
