        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 20
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&EditarLotes.ColumnHeaderClass = !'WWActionColumn'
	ProGraRef.ColumnHeaderClass = !'WWColumn'
	ProNomGra.ColumnHeaderClass = !'WWColumn'
	PrdItmQtd.ColumnHeaderClass = !'WWColumn'
	PrdLotTot.ColumnHeaderClass = !'WWColumn'
	&IsErroProduto.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridRecordCount = Grid.RecordCount
	&GridPageCount = grid.PageCount

EndEvent

Event Grid.Load

	VerificaLoteinformadoEntradaProducaoItem.Call(EmpCod, FilCod, PrdCod, PrdItmCod, &IsTodosInformadosAux)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EditarLotes.FromImage(ActionUpdate)
	&EditarLotes.TooltipText = ""

	Do Case
		Case PrdItmQtd <> PrdLotTot or &IsTodosInformadosAux = false
			&EditarLotes.ColumnClass = !'WWActionColumn WWColumnDanger WWColumnDangerFirstColumn'
			ProGraRef.ColumnClass = !'WWColumn WWColumnDanger'
			ProNomGra.ColumnClass = !'WWColumn WWColumnDanger'
			PrdItmQtd.ColumnClass = !'WWColumn WWColumnDanger'
			PrdLotTot.ColumnClass = !'WWColumn WWColumnDanger'
			&IsErroProduto.ColumnClass = !'WWColumn WWColumnDanger'
		Case PrdItmQtd = PrdLotTot
			&EditarLotes.ColumnClass = !'WWActionColumn WWColumnSuccess WWColumnSuccessFirstColumn'
			ProGraRef.ColumnClass = !'WWColumn WWColumnSuccess'
			ProNomGra.ColumnClass = !'WWColumn WWColumnSuccess'
			PrdItmQtd.ColumnClass = !'WWColumn WWColumnSuccess'
			PrdLotTot.ColumnClass = !'WWColumn WWColumnSuccess'
			&IsErroProduto.ColumnClass = !'WWColumn WWColumnSuccess'
		Otherwise
			&EditarLotes.ColumnClass = 'WWActionColumn'
			ProGraRef.ColumnClass = 'WWColumn'
			ProNomGra.ColumnClass = 'WWColumn'
			PrdItmQtd.ColumnClass = 'WWColumn'
			PrdLotTot.ColumnClass = 'WWColumn'
			&IsErroProduto.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarCancelar'

	Do CAse
		Case &DeOndeVem = 'WWENTRADAPRODUCAO'
			WWEntradaProducao.Link()
	
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	VerificaLoteInformadoEntradaProducao.Call(&EmpCod, &FilCod, &PrdCod, &IsTodosInformados, &Mensagem)
	if &IsTodosInformados = false
		msg(&Mensagem)
	Else
		FechaEntradaProducao.Popup(EmpCod, FilCod, PrdCod)
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &EditarLotes.Click

	wpLoteMultiplosEntradaProducao.Popup(EmpCod, FilCod, PrdCod, PrdItmCod)
	Refresh

EndEvent


