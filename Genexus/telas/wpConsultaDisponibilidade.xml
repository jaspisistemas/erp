      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&ListarTudo = true
	&ProCod = &inProCod
	&ProGraCod = &inProGraCod
	do 'loadProduto'
	
	&PedDtaPrv = &inPedDtaPrv
	if &PedDtaPrv.IsEmpty()
		&PedDtaPrv = serverdate()
	Endif

	&PedDtaDsp = &inPedDtaRetCon

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 493
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	if PedCliCodRaz_Nov.Length() > 30
		&PedCliRaz = substr(PedCliCodRaz_Nov, 1, 30) + '...'
	Else
		&PedCliRaz = PedCliCodRaz_Nov 
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd,  &erroMensagem)

EndEvent

Sub 'loadProduto'

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		For Each Order EmpCod, ProCod, ProGraCod
			Where ProGraCod = &ProGraCod
			
			&ProRef = ProGraRef
			&ProNom = ProNomGra
			
		EndFor			
		Exit
	EndFor

EndSub


]]></Source>
