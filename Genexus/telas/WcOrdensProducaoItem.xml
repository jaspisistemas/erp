      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'GetProduto'
	&Numeric	= 0

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	OrdTip.ColumnHeaderClass = !'WWColumn hidden-xs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount		= Grid.PageCount
	&GridCurrentPage	= Grid.CurrentPage

EndEvent

Event Grid.Load

	&Numeric   += 1
	&OrdCod		= OrdCod
	Do 'CaptionText'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	Do Case
		Case OrdTip = TipoOrdem.ExedenteProducao
			OrdTip.ColumnClass = !'WWColumn hidden-xs WWColumnInfo WWColumnInfoSingleCell'
		Case OrdTip = TipoOrdem.CancelamentoProducao
			OrdTip.ColumnClass = !'WWColumn hidden-xs WWColumnDanger WWColumnDangerSingleCell'
		Case OrdTip = TipoOrdem.OrdemProducao and OrdSts = Status_Producao.EmProducao
			OrdTip.ColumnClass = !'WWColumn hidden-xs WWColumnSuccess WWColumnSuccessSingleCell'
		Otherwise
			OrdTip.ColumnClass = 'WWColumn hidden-xs'
	EndCase
	Do Case
		Case OrdSts = Status_Producao.EmProducao
			OrdSts.ColumnClass = !'WWColumn WWColumnSuccess WWColumnSuccessSingleCell'
		Case OrdSts = Status_Producao.Produzido
			OrdSts.ColumnClass = !'WWColumn WWColumnBold WWColumnBoldSingleCell'
		Otherwise
			OrdSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GrupHie = OrdGrupHie
	&ProSetCod = OrdSetCod
	do 'GetSetorGrupo'
	OrdCod.Link = ViewLancamentoOrdemProducao.Link(EmpCod, FilCod, OrdCod, '')
	
	&GridOrdProQtd	= RetiraZerosDepoisVirgula.Udp(Trim(ToFormattedString(OrdProQtd)))

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'GetSetorGrupo'

	&GrupNomCmp = &GrupHie.Trim()
	For Each Order EmpCod, GrupHie
		Where EmpCod = &EmpCod
		Where GrupHie = &GrupHie
		&GrupNomCmp = GrupCodNom
		Exit
	EndFor

	&SetCodNom  = trim(str(&ProSetCod))
	For Each Order EmpCod, SetCod
		Where EmpCod = &EmpCod
		Where SetCod = &ProSetCod
		&SetCodNom = SetCodNom
		Exit
	EndFor

EndSub

Sub 'GetProduto'

	For Each Order EmpCod, ProCod
		Where EmpCod	= &EmpCod
		Where ProCod	= &ProCod
		
		&ProNom			= ProRef + ' ' + ProNom
		Do 'CaptionText'
		
		Exit
	EndFor

EndSub

Sub 'CaptionText'

	&IsAchou	= False
	If Not &OrdCod.IsEmpty()
		For &AuxOrdCod In &CollOrdCod
			If &AuxOrdCod = &OrdCod
				&IsAchou	= True
				Exit
			EndIf
		EndFor
		If &IsAchou	= False
			&CollOrdCod.Add(&OrdCod)
		EndIf
	EndIf
	
	TextProduto.Caption	= 'Produto: ' + &ProNom + ' localizado em ' + Trim(Str(&CollOrdCod.Count)) + IIf(&CollOrdCod.Count = 1, ' ordem.', ' ordens.')

EndSub


]]></Source>
