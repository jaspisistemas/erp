      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	TextBlockTitle.Caption = 'PRODUTO: ' + trim(str(ProCod))
	
	For each Order EmpCod, ProCod
		Form.Caption = ProNom.ToString()
		Exit
	When none
		Form.Caption = "Registro não encontrado"
	Endfor
	
	RetornaMaisCodigosCompleto.Call(EmpCod, ProCod, 1, &OutrosCodigosMensagem)
	RetornaAutorizacao.Call('WPFORNECEDORPRODUTO', Status_SimNao.Nao, 1, &WPFORNECEDORPRODUTO)
	if &WPFORNECEDORPRODUTO > 0
		wcFornec.Object = wcFornecedoresProduto.Create(ProCod)
	EndIF

	wcVenda.Object = wcPrecoVenda.Create(ProCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&WPFORNECEDORPRODUTO > 0)
		DVPanel_tbFornecedores_Cell.Class = !'Invisible'
	Else
		DVPanel_tbFornecedores_Cell.Class = !'col-xs-12'
	EndIf
	tbCus1.Visible = (&WPFORNECEDORPRODUTO > 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoModificar'

	RetornaAutorizacao.Call('WWPRODUTO', Status_SimNao.Nao, 1, &AutNivProduto)
	RetornaTelaProduto.call(EmpCod, &LinkMensagem)
	if &AutNivProduto > 1
		if &LinkMensagem = 'WWPRODUTO'
			Produtos.Link('', TrnMode.Update, EmpCod, ProCod, '')
		Else
			impProduto.Link(TrnMode.Update, EmpCod, ProCod)
		EndiF
	Else
		msg('Não Autorizado à Editar Produto!')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImagens'

	wwImagemProduto.Popup(ProCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
