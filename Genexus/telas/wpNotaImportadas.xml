      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	&tmpStsNF.FromString(&WebSession.Get('FilWPIMP'))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 100
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount
	&GridCurrentPage = grid.CurrentPage

EndEvent

Event Grid.Load

	&ProPriaTerceiro = tmpNfeProTer

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&addEmitente.FromImage(iconAmarelo)
	&addEmitente.TooltipText = ""
	
	&AddDestinatario.FromImage(iconAmarelo)
	&AddDestinatario.TooltipText = ""
	
	&AddProduto.FromImage(iconAmarelo)
	&AddProduto.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&addEmitente.Link = ''
	&AddDestinatario.Link = ''
	&addEmitente.LinkTarget = '_blank'
	&AddDestinatario.LinkTarget = '_blank'
	if tmpEmixCod.IsEmpty() and tmpModCod = '55'
		&addEmitente.FromImage(IconVermelho)
		&addEmitente.TooltipText = "Adicionar Emitente"
	Else
		&addEmitente.Link = verCliente.Link('DashBoard', tmpEmpCod, tmpEmixCod)
		&addEmitente.FromImage(iconVerde)
		&addEmitente.TooltipText = "Emitente Cadastrado"
	EndIF

	if tmpDestxCod.IsEmpty() and tmpModCod = '55'
		&AddDestinatario.FromImage(IconVermelho)
		&AddDestinatario.TooltipText = "Adicionar Destinatário"
	Else
		&AddDestinatario.FromImage(iconVerde)
		&AddDestinatario.Link = verCliente.Link('DashBoard', tmpEmpCod, tmpDestxCod)
		&AddDestinatario.TooltipText = "Destinatário Cadastrado"
	EndIF

	retornaProdutoNaoVinculado.Call(tmpNFeCod, &IsSemVinculo)
	if &IsSemVinculo = true
		&AddProduto.FromImage(IconVermelho)
		&AddProduto.TooltipText = "Produtos Sem Vínculos."
	Else
		&AddProduto.FromImage(iconVerde)
		&AddProduto.TooltipText = "Produtos Vinculados."
	EndIF

	tmpNfeNum.ForeColor = RGB(0,0,0)
	tmpNfeSer.ForeColor = RGB(0,0,0)
	tmpModCod.ForeColor = RGB(0,0,0)
	tmpNfeNum.Tooltiptext = ''
	If tmpStsNF = 'S'
		tmpNfeNum.Tooltiptext = 'NFe Já Lançada!'
		tmpNfeNum.ForeColor = RGB(255,0,0)
		tmpNfeSer.ForeColor = RGB(255,0,0)
		tmpModCod.ForeColor = RGB(255,0,0)
	EndiF

	&IsGravarNotas.Enabled = 1
	If tmpEmixCod.IsEmpty() or (tmpDestxCod.IsEmpty() and tmpModCod <> '65') or &IsSemVinculo = true or tmpStsNF = 'S'
		&IsGravarNotas = false
		&IsGravarNotas.Enabled = 0
	EndIF

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	wpimportaxmlnfe.Link(&DeOndeVEm, &PedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSelecionar'

	For Each line in grid
		&IsGravarNotas = true
		If tmpEmixCod.IsEmpty() or (tmpDestxCod.IsEmpty() and tmpModCod <> '65') or &IsSemVinculo = true or tmpStsNF = 'S'
			&IsGravarNotas = false
		EndIF
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For Each Line in Grid
		If &IsGravarNotas = true
			//GRAVA NOTA FISCAL
			NotaTemporaria_NotaFiscal.Call(tmpNFeCod, &Context.EmpCod, &Context.FilCod, 0, 0)
		EndiF
	EndFor

	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &tmpStsNF.IsValid

	&WebSession.Set('FilWPIMP', &tmpStsNF.tostring())
//	Refresh

EndEvent

Event &tmpStsNF.Click

	&WebSession.Set('FilWPIMP', &tmpStsNF.tostring())
//	Refresh

EndEvent

Event &addEmitente.Click

	&sdtPessoa.Clear()
	&webSession.Remove('NOVAPESSOA')
	
	NotaTemporariaCarregaPessoa.call(tmpNFeCod, 'EMIT', &sdtPessoa)

	wpNovaPessoa.Popup('FOR', 0, '')

	wpnotaIMportadas.Link(&tmpNfeCod)

EndEvent

Event &AddDestinatario.Click

	&sdtPessoa.Clear()
	&webSession.Remove('NOVAPESSOA')
	NotaTemporariaCarregaPessoa.call(tmpNFeCod, 'DEST', &sdtPessoa)

	wpNovaPessoa.Popup('CLI', 0, '')

	wpnotaIMportadas.Link(&tmpNfeCod)

EndEvent

Event &AddProduto.Click

	wpNotaImportadasProdutos.Link(tmpNFeCod)

EndEvent


]]></Source>
