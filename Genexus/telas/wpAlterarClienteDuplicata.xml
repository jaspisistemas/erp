      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	RetornaAutorizacao.Call('WWDUPLICATAS_ALTERARCLIENTE', Status_SimNao.Sim, 1, &AutNiv)
	txtMensagem.Caption = ''
	txtMensagem.ForeColor = rgb(150,0,0)
	do 'loadpedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbespaco.Height = 20
	tbespaco1.Height = 100

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'loadCliente'
	if &IsErroCliente = false
		GravaNovoClienteDuplicataPedido.Call(&EmpCod, &FilCod, &PedCod, &PedCliCod, &wwpContext.PesCod)
		Return
	Else
		txtMensagem.Caption = 'FAVOR INFORMAR UM CLIENTE/FORNECEDOR VÁLIDO!'
		txtMensagem.ForeColor = rgb(150,0,0)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PesCodRazSugg.IsValid

	RetornaCodigoPEssoaSugestNome.Call(&EmpCod, &PesCodRazSugg, &PedCliCod)
	do 'loadCliente'

EndEvent

Sub 'loadpedido'

	For Each ORder EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedCliCodRaz = PedCliCodRaz
		
		&PedCliCod = PedCliCod
		do 'loadCliente'
		Exit
	When none
		Return
	EndFor

EndSub

Sub 'LoadCliente'

	&IsErroCliente = false
	&AuxPesCodRazSugg = ''
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		
		&AuxPesCodRazSugg = PesCodRazSugg
		
		Exit
	When none
		&IsErroCliente = true
	EndFor
	
	&PesCodRazSugg = &AuxPesCodRazSugg

EndSub


]]></Source>
