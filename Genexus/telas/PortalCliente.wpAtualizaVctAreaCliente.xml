      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&CreCod.Visible = False
	&FilCod.Visible = False
	&CreBloNro.Visible = False
	&CreCbrCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'loadDuplicata'

EndEvent

Event Enter

	&IsErro = false
	AtualizaVctAreaCliente.Call(&EmpCod,&FilCod,&CreCod,&NovCreDtaVct,&IsErro,&Mensagem)
	if &IsErro = false and &Mensagem.IsEmpty()
		return
	else
		msg(&Mensagem)
	EndIF

EndEvent

Sub 'loadDuplicata'

	For each order EmpCod,FilCod,CreCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where CreCod = &CreCod
		&CreDtaVct = CreDtaVct
		&numeric = DoW(&Today)
		
		Do case
			case &numeric = 1 //domingo
				&NovCreDtaVct = &Today.AddDays(1) //domingo + 1 = segunda
			case &numeric = 7 //sabado
				&NovCreDtaVct = &Today.AddDays(2) //sabado + 2 = segunda
			case &numeric = 6 //sexta
				&NovCreDtaVct = &Today.AddDays(3) //sexta + 3 = segunda
			case &numeric > 1 and &numeric < 7 //segunda a sexta
				&NovCreDtaVct = &Today.AddDays(1)
		EndCase
	
		&CreVlrSdo = CreVlrSdo
		&CreBloNro = CreBloNro
		&CreDupNro = CreDupNro
		&CreCbrCod = CreCbrCod
		exit
	when none
		msg('Não é possível atualizar este boleto. Entre em contato com o suporte JASPI.')
		btnEnter.Enabled = false
	EndFor

EndSub


]]></Source>
