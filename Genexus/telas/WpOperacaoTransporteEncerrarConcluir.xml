      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	GridPagamentos.Rows = Page.Rows
	&GridPagamentosCurrentPage = 1
	&GridPagamentosCurrentPage.Visible = False
	&GridPagamentosPageCount = -1
	GridPagamentosPaginationBar.RowsPerPageSelectedValue = GridPagamentos.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPagamentosPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&CancelarPagamento.ColumnHeaderClass = !'WWIconActionColumn'
	&GridLancamentosOpeDtaLib.ColumnHeaderClass = !'WWColumn'
	&GridLancamentosOpePgtVal.ColumnHeaderClass = !'WWColumn'
	&GridLancamentosOpePgtBan.ColumnHeaderClass = !'WWColumn'
	&GridLancamentosOpePgtAge.ColumnHeaderClass = !'WWColumn'
	&GridLancamentosOpePgtCon.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPagamentosPageCount	= GridPagamentos.PageCount
	&GridPagamentosCurrentPage	= GridPagamentos.CurrentPage
	&GridPagamentosRows			= GridPagamentos.Rows

EndEvent

Event GridPagamentos.Load

	&GridPagamentosPageCount	= 1
	&Item						= 0
	&GridPagamentosRows			= GridPagamentos.Rows
	For Each Order EmpCod, FilCod, OpeCod, OpePgtCod
		Where EmpCod	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&GridLancamentosEmpCod		= EmpCod
		&GridLancamentosFilCod		= FilCod
		&GridLancamentosOpeCod		= OpeCod
		&GridLancamentosOpeDtaLib	= OpeDtaLib
		&GridLancamentosOpePgtAge	= OpePgtAge
		&GridLancamentosOpePgtCod	= OpePgtCod
		&GridLancamentosOpePgtCon	= OpePgtCon
		&GridLancamentosOpePgtSts	= OpePgtSts
		&GridLancamentosOpePgtVal	= OpePgtVal

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&CancelarPagamento = !'<i class="fas fa-times"></i>'
	If (&GridLancamentosOpePgtSts = Status_AtivoInativo.ATIVO)
		&CancelarPagamento.Class = !'Attribute'
	Else
		&CancelarPagamento.Class = !'Invisible'
	Endif

	&CancelarPagamento.ColumnClass = iif(&GridLancamentosOpePgtSts = Status_AtivoInativo.INATIVO, !'WWIconActionColumn WWColumnLineThrough WWColumnLineThroughFirstColumn', !'WWIconActionColumn')
	&GridLancamentosOpeDtaLib.ColumnClass = iif(&GridLancamentosOpePgtSts = Status_AtivoInativo.INATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&GridLancamentosOpePgtVal.ColumnClass = iif(&GridLancamentosOpePgtSts = Status_AtivoInativo.INATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&GridLancamentosOpePgtBan.ColumnClass = iif(&GridLancamentosOpePgtSts = Status_AtivoInativo.INATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&GridLancamentosOpePgtAge.ColumnClass = iif(&GridLancamentosOpePgtSts = Status_AtivoInativo.INATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')
	&GridLancamentosOpePgtCon.ColumnClass = iif(&GridLancamentosOpePgtSts = Status_AtivoInativo.INATIVO, !'WWColumn WWColumnLineThrough', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&Item += 1
		If &Item	=	&GridPagamentosRows
			&GridPagamentosPageCount 	+= 1
			&Item 						= 0
		EndIf

		Load
	EndFor

EndEvent

Event GridPagamentosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPagamentosPaginationBar.SelectedPage = !'Previous'
			&GridPagamentosCurrentPage -= 1
			GridPagamentos.PreviousPage()
		Case GridPagamentosPaginationBar.SelectedPage = !'Next'
			&GridPagamentosCurrentPage += 1
			GridPagamentos.NextPage()
		Otherwise
			&PageToGo.FromString(GridPagamentosPaginationBar.SelectedPage)
			&GridPagamentosCurrentPage = &PageToGo
			GridPagamentos.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPagamentosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPagamentos.Rows = GridPagamentosPaginationBar.RowsPerPageSelectedValue
	&GridPagamentosCurrentPage = 1
	GridPagamentos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WpOperacaoTransporteEncerrar(!'Concluir', !'Completo', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		If Not &HasValidationErrors			
			Do Case
				Case &OpePso <= 0 
					Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O peso bruto da cargua deve ser maior que 0', DVMessageType.regular, "", DVMessageBoolean.True,""))
					&OpePso.SetFocus()
				Case &OpeTerEnc = False
					Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Você deve estar ciente do encerramento.', DVMessageType.regular, "", DVMessageBoolean.True,""))
					&OpeTerEnc.SetFocus()
				OtherWise
					Do 'SaveVariablesToWizardData'
					prcNovoEFrete_Login.Call(&Token, &ProtocoloServico, &StatusLogin)
					If &StatusLogin = 200
						prcNovoEFrete_EncerrarCIOT.Call(&WebSessionKey, &Token, &StatusRet)	
						If &StatusRet = 200
							Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", 'Operação encerrada com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))
							WpOperacaoTransporteEncerrar(!'Concluir', !'Completo', false)
						EndIf
					Else
						Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &StatusLogin.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
					EndIf
					If not &Token.Trim().IsEmpty()
						prcNovoEFrete_Logout.Call(&Token, &StatusLogOut)
					Endif
			EndCase
		EndIf
	EndIf

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	WpOperacaoTransporteEncerrar(!'Concluir', !'Encerrar', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CancelarPagamento.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	CancelarPagamento_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event CancelarPagamento_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = WcOperacaoTransporteCancelarPagamento.Create(&GridLancamentosEmpCod, &GridLancamentosFilCod, &GridLancamentosOpeCod, &GridLancamentosOpePgtCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event CancelarPagamento_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&OpeTerEnc = &WizardData.Concluir.OpeTerEnc
	&DescritivoImpOut = &WizardData.Concluir.DescritivoImpOut
	&OpeImpOut = &WizardData.Concluir.OpeImpOut
	&OpeImpIssqn = &WizardData.Concluir.OpeImpIssqn
	&OpeImpSest = &WizardData.Concluir.OpeImpSest
	&OpeImpInss = &WizardData.Concluir.OpeImpInss
	&OpeImpIRRF = &WizardData.Concluir.OpeImpIRRF
	&OpeTotSeg = &WizardData.Concluir.OpeTotSeg
	&OpeTotPed = &WizardData.Concluir.OpeTotPed
	&OpeTotCom = &WizardData.Concluir.OpeTotCom
	&OpePso = &WizardData.Concluir.OpePso
	&OpeNroCiot = &WizardData.Concluir.OpeNroCiot
	&EmpCod = &WizardData.Concluir.EmpCod
	&FilCod = &WizardData.Concluir.FilCod
	&OpeCod = &WizardData.Concluir.OpeCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&EmpCod 	= &WizardData.Encerrar.EmpCod
		&FilCod 	= &WizardData.Encerrar.FilCod
		&OpeCod 	= &WizardData.Encerrar.OpeCod
		&OpeNroCiot = &WizardData.Encerrar.OpeNroCiot
		
		Do 'LoadOperacao'
	EndIf

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.Concluir.OpeTerEnc = &OpeTerEnc
	&WizardData.Concluir.DescritivoImpOut = &DescritivoImpOut
	&WizardData.Concluir.OpeImpOut = &OpeImpOut
	&WizardData.Concluir.OpeImpIssqn = &OpeImpIssqn
	&WizardData.Concluir.OpeImpSest = &OpeImpSest
	&WizardData.Concluir.OpeImpInss = &OpeImpInss
	&WizardData.Concluir.OpeImpIRRF = &OpeImpIRRF
	&WizardData.Concluir.OpeTotSeg = &OpeTotSeg
	&WizardData.Concluir.OpeTotPed = &OpeTotPed
	&WizardData.Concluir.OpeTotCom = &OpeTotCom
	&WizardData.Concluir.OpePso = &OpePso
	&WizardData.Concluir.OpeNroCiot = &OpeNroCiot
	&WizardData.Concluir.EmpCod = &EmpCod
	&WizardData.Concluir.FilCod = &FilCod
	&WizardData.Concluir.OpeCod = &OpeCod
	&WizardData.Concluir.GridPagamentos.Clear()
	For Each Line in GridPagamentos
		&GridPagamentosItem = new()
		&GridPagamentosItem.GridLancamentosFilCod = &GridLancamentosFilCod
		&GridPagamentosItem.GridLancamentosOpeCod = &GridLancamentosOpeCod
		&GridPagamentosItem.GridLancamentosEmpCod = &GridLancamentosEmpCod
		&GridPagamentosItem.GridLancamentosOpePgtSts = &GridLancamentosOpePgtSts
		&GridPagamentosItem.GridLancamentosOpePgtCod = &GridLancamentosOpePgtCod
		&GridPagamentosItem.GridLancamentosOpeDtaLib = &GridLancamentosOpeDtaLib
		&GridPagamentosItem.GridLancamentosOpePgtVal = &GridLancamentosOpePgtVal
		&GridPagamentosItem.GridLancamentosOpePgtBan = &GridLancamentosOpePgtBan
		&GridPagamentosItem.GridLancamentosOpePgtAge = &GridLancamentosOpePgtAge
		&GridPagamentosItem.GridLancamentosOpePgtCon = &GridLancamentosOpePgtCon

		&WizardData.Concluir.GridPagamentos.Add(&GridPagamentosItem)
	EndFor
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadOperacao'

	For Each Order EmpCod, FilCod, OpeCod
		Where EmpCod	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&OpePso 		= OpePso
		
		For Each Order EmpCod, FilCod, OpeCod, OpeViaCod, OpeValCod
			Where OpeViaCod	 	= 1
			Where OpeValCod		= 1
			
			&OpeTotCom			= OpeTotCom
			&OpeTotPed			= OpeTotPed
			&OpeTotSeg			= OpeTotSeg
			
			Exit
		EndFor
		
		For Each Order EmpCod, FilCod, OpeCod, OpeImpCod
			Where OpeImpCod = 1
			
			&OpeImpIRRF		= OpeImpIRRF
			&OpeImpInss		= OpeImpInss
			&OpeImpSest		= OpeImpSest
			&OpeImpIssqn	= OpeImpIssqn
			&OpeImpOut		= OpeImpOut
			
			Exit
		EndFor
		
		Exit
	EndFor

EndSub


]]></Source>
