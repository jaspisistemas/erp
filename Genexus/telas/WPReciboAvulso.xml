      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPRECIBOAVULSO', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&RcbFilCod = &Context.FilCod
	&RcbDta = ServerDate()
	
	PadraoUsuario.Call('L','WPRECIBOAVULSO',&PesCod,&EmpCod,&PadObs,&PadDtaMod)
	&TipoImpressao = &PadObs

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRecibos'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWRecibo.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&sdtRecibo.Clear()
	&WebSession.Remove('ReciboImp')
		Do 'GravaRecibo'
	&ServerTime = ServerTime()
	&sdtReciboItem = new()
	&sdtReciboItem.EmpCod = &EmpCod
	&sdtReciboitem.RcbCod = &RcbCod
	&sdtRecibo.Add(&sdtReciboItem)
	&WebSession.Set('ReciboImp',&sdtRecibo.ToXml()) //Só usa no A4
	PadraoUsuario.Call('G','WPRECIBOAVULSO',&PesCod,&EmpCod,&TipoImpressao,&PadDtaMod) //Grava padrão usuario
	Do case
		case &TipoImpressao = 'A4'
			&Window.Url = RELJAS020.Link(&ServerTime,'AVULSO') 
			&Window.Height = 800
			&Window.Width = 800
			&Window.Open()
			
		case &TipoImpressao = 'T'
			&Window.Url = RELJAS114C.Link(&EmpCod,&RcbCod)
			&Window.Height = 800
			&Window.Width = 800
			&Window.Open()
			
		otherwise //(Padrão)
			GravaSessaoWpTipoImpressao.Call('RECIBO_AVULSO',&EmpCod,0,&RcbCod,0,0,&ServerTime,'','')
			wpTipoImpressao.Popup()
			Refresh
	EndCase

EndEvent

Event &RcbDstCod.IsValid

	Do 'Pessoa'

EndEvent

Sub 'GravaRecibo'

	UltimoCodigoEmpresa.Call(domParCod.RECIBO, &EmpCod, 0, &RcbCod)
	GravaReciboAvulso.Call(&EmpCod,&RcbCod,&RcbDoc,&RcbDstCod,&RcbDstNom,&RcbDta,&RcbFilCod,&RcbObs,&RcbTip,&RcbVlr)

EndSub

Sub 'Pessoa'

	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &RcbDstCod
		If &RcbDstNom.IsEmpty()
			&RcbDstNom = PesRaz
		Endif
		Exit
	EndFor

EndSub


]]></Source>
