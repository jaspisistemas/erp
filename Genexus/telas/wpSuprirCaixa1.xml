      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	
	if &MovCreDeb = 'C' //SUPRIMENTO
		Form.Caption = 'Suprimento de Caixa'
	Else //SANGRIA
		Form.Caption = 'Sangria de Caixa'
	EndiF
	do 'Plano'
//	tbUser.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	espacojus.Height = 100

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&MovDta = serverdate()
	&MovDtaCon = &MovDta
	&MovTip = TipoMovimento.Manual
	
	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = true
		&SdtMovimentoItem.Clear()
		
		&SdtMovimentoItemItem = new()
		&SdtMovimentoItemItem.MovItmCod = &AuxMovItmCod
		&SdtMovimentoItemItem.MovItmCpl = &MovItmCpl
		&SdtMovimentoItemItem.MovItmVlr = &MovItmVlr
		&SdtMovimentoItemItem.PlanCod    = &PlanCod
		&SdtMovimentoItemItem.PlanCodNom = &PlanCodNom
		&SdtMovimentoItem.Add(&SdtMovimentoItemItem)
		
		GravaMovimento.Call(&Context.EmpCod, TrnMode.Insert, &MovCod, &MovDta,&MovDtaCon,&MovCtaBanCod,&MovCreDeb,&MovDoc,&SdtMovimentoItem,&MovTip,'',&Erro)
		
		
		&random = random() * 9
		&printMovCod = &MovCod
		
		RCOOpenWindw1.LinkOpen = RELJAS073.Link(&random, &Context.EmpCod, &printMovCod, &Context.PesCod)
		RCOOpenWindw1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		msg('Lançamento efetuado com sucesso!')
		do 'limpaCampos'
		//		&ProgressId = 'Suprim' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		//		&ProgressId = &ProgressId.trim()
		//		scaProgressBar1.ProcessId = &ProgressId
		//		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		//		scaProgressBar1.Start()
		//		
		//		EsperaSegundos.Submit('', &ProgressId)
	EndIF

EndEvent

Sub 'CheckRequiredFields'

	&CheckRequiredFieldsResult = True
	If &MovItmVlr.IsEmpty()
		Msg('Valor do Laçamento obrigatório!')
		&CheckRequiredFieldsResult = False
	EndIf
	If &PlanCod.IsEmpty()
		Msg('Plano de Contas Obrigatório!')
		&CheckRequiredFieldsResult = False
	EndIf
	If &MovItmCpl.IsEmpty()
		Msg('Complemento é obrigatório!')
		&CheckRequiredFieldsResult = False
	EndIf

EndSub

Sub 'limpaCampos'

	&MovCod = 0
	&MovItmVlr = 0
	&MovDoc.SetEmpty()
	&MovItmCpl.SetEmpty()
	&MovItmVlr.SetFocus()

EndSub

Sub 'Plano'

	&PlanCod.Clear()
	For each Order EmpCod,PlanAnaSin,PlanCatTip,PlanUtiTra,PlanHie 
		Where EmpCod = &EmpCod
		Where PlanAnaSin = 'A'
		Where PlanUtiTra = false
		Where PlanCatTip = &MovCreDeb
		&PlanCod.AddItem(PlanCod,PlanCodNom)
	EndFor

EndSub


]]></Source>
