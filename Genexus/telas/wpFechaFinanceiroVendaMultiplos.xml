      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	&Link = &DeOndeVem.Trim() + '.aspx'
	&SdtPedido.FromXml(&websession.Get('FECHAMENTOMULTIPLO'))
	If UPPER(&DeOndeVem) = 'WWDEVOLUCAOVENDA'
		RetornaAutorizacao.Call('DEVOLUCAOFECHAFINANCEIRO', Status_SimNao.Sim, 1, &AutNiv)
	Else		
		RetornaAutorizacao.Call('VENDAFECHAFINANCEIRO', Status_SimNao.Sim, 1, &AutNiv)
	EndIF
	
	&CrePagDta = serverdate()
	&CtabanCod = &Context.CtaBanCod
	RetornaCreditoCliente.Call(&EmpCod, &PedCliCod, ReceberPagar.Pagar, &CreditoMensagem, &ValorCredito)
	
	If &CreditoMensagem.IsEmpty()
		&CreditoMensagem.Visible = 0
	EndIF
	
	//RETORNA FORMAS PAGAMENTOS
	RetornaFormasPagamento.Call(&Context.EmpCod, 'R', 'S', &Context.PesCod, &Context.TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	&PedFrpPgtoCod.Clear()
	For &sdtFormasPagamentoItem in &sdtFormasPagamento	
		if &sdtFormasPagamentoItem.FrpPgtoTip = TipoDuplicata.DUPLICATA
			&DescricaoVarchar = &sdtFormasPagamentoItem.FrpPgtoCodExib + ' - ' + &sdtFormasPagamentoItem.FrpPgtoNom
			&PedFrpPgtoCod.AddItem(&sdtFormasPagamentoItem.FrpPgtoCod, &DescricaoVarchar)
		Endif
	EndFor
	//RETORNA FORMAS PAGAMENTOS
	do 'getConfigFormaPagamento'
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &CfgVlr)
	For Each Order EmpCod, PlanCod
		Where EmpCod = &EmpCod
		Where PlanHie = &CfgVlr
		&PlanCod = PlanCod
		Exit
	EndFor
	
	For &SdtPedidoItem in &SdtPedido
		For Each Order EmpCod, FilCod, PedCod
			where EmpCod = &SdtPedidoItem.EmPCod
			Where FilCod = &SdtPedidoItem.FiLCod
			Where PedCod  = &SdtPedidoItem.PedCod
			&LctTip = LctTip
			&CreCbrCod = FilCbrCod
			&PedPraCod = PedPraCod
			If not PedDtaFat.IsEmpty()
				If &CreDtaEms < PedDtaFat
					&CreDtaEms = PedDtaFat
				EndIf
			Else
				&CreDtaEms = serverdate()
			EndIf
			&LctCodNom = LctCodNom
			&PedVlrBrt += PedVlrBrt
			&PedVlrLiq += PedVlrLiq
			&PedPraNom = trim(str(PedPraCod)) + ' - ' + trim(PedPraNom)
			&PedPraParNom = '000'
			&PraMedBlo = PedPraMedBlo
			Do 'parcelas'
			Exit
		EndFor
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&PedCod.Visible = False
	&FilCodNom.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelarFechamento'

	link(&Link)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &CreditoMensagem.IsEmpty())
		&CreditoMensagem.Visible = False
		CreditoMensagem_Cell.Class = !'Invisible'
	Else
		&CreditoMensagem.Visible = True
		CreditoMensagem_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Link = &DeOndeVem.Trim() + '.aspx'

EndEvent

Event &PedFrpPgtoCod.IsValid

	Do 'getConfigFormaPagamento'

EndEvent

Event &PedPraParNom.IsValid

	do 'parcelas'

EndEvent

Event Enter

	RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon045_ModeloDuplicata, &OpcaoFechamento)
	
	For &SdtPedidoItem in &SdtPedido
		For Each Order EmpCod, FilCod, PedCod
			where EmpCod = &SdtPedidoItem.EmPCod
			Where FilCod = &SdtPedidoItem.FiLCod
			Where PedCod  = &SdtPedidoItem.PedCod
			
			If PedStsFin <> Status_Financeiro.ABERTO
				msg('Pedido '+ trim(str(PedCod))+' já encontra-se fechado no financeiro, nada será feito por aqui!')
			Else			
				Do 'AttributesSecurityCode'				
				Do 'parcelas'	
				
				iF &CreDtaEms < &PedDtaEms
					msg('Data de fechamento do pedido não pode ser menor que a data de emissão do pedido!')
					
				eLSE
					If &PedPraParNom.IsEmpty()
						&PedPraParNom = '000'
					EndIF
					
					atualizaFormasPagamentoPedido.call(EmpCod, FilCod, PedCod, &PedPraParNom, &Context.UserName)
					ApagaTemporariaPedidoVenda.Call(EmpCod, FilCod, PedCod, &PedTmpFrpPgtoTip)
					
					&TotalDuplicatas = PedVlrFin
				
					&sdtPgto = new()							
					&sdtPgto.FrpPgtoCod = &PedFrpPgtoCod
					
					&sdtPgto.PedDtaFat = &CrePagDta
					&sdtPgto.PedTmpCreCliCod = 0
					&sdtPgto.FunPesCod = 0							
					&sdtPgto.creVlrDup = &TotalDuplicatas
					&sdtPgto.PlanCod = &CrePlanCod
					&sdtPgto.IsPago = false
					&sdtPgto.CreCbrCod = &CreCbrCod
					&sdtPgto.OpcaoFechamento = &OpcaoFechamento
					MontaDuplicatasPedidoVenda01_JDF.Call('ADD', EmpCod, FilCod, PedCod, &sdtPgto)
					
					GravaDuplicatasAReceber1.Call(EmpCod, FilCod, PedCod)						
					CriticasPedido.Submit('Critica', EmpCod, FilCod, PedCod, TipoCriticaPedido.FechadoFinanceiro, &Context.PesCod)
					
				EndIf
			EndIF
			
		EndFor
	EndFor

	&Link = &DeOndeVem.Trim() + '.aspx'
	link(&Link)

EndEvent

Event &CreDtaEms.IsValid

	Do 'parcelas'

EndEvent

Sub 'getConfigFormaPagamento'

	&sdtFormaPagamentoContas.Clear()
	&sdtFormaPagamentoLocalCobranca.Clear()
	&sdtFormaPagamentoBandeira.Clear()
	
	getConfigFormaPagamentoReceber.call(&EmpCod, &FilCod, &Context.PesCod, &PedFrpPgtoCod, &PedFrpPgtoTip, &FrpPgtoDest, &sdtFormaPagamentoContas, &sdtFormaPagamentoLocalCobranca, &sdtFormaPagamentoBandeira)
	
	&CreCbrCod.Clear()
	For &sdtFormaPagamentoLocalCobrancaItem in &sdtFormaPagamentoLocalCobranca
		&CreCbrCod.AddItem(&sdtFormaPagamentoLocalCobrancaItem.CbrCod, &sdtFormaPagamentoLocalCobrancaItem.CbrCodNom)
	EndFor

EndSub

Sub 'parcelas'

	FormataParcela.Call(&PedPraParNom, &PedPraParNom)
	RetornaPrazoMedio.Call(&PedPraParNom, &infPraMedBlo)
	RetornaVencimentosParcela.Call(&EmpCod, &PedCliCidCod, &PedPraParNom,ReceberPagar.Receber, &CreDtaEms, &sdtVencimentos, &Mensagem)

EndSub


]]></Source>
