      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Carrega.FromString(&WebSession.Get('CARREGA'))
	&WebSession.Remove('CARREGA')
	
	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	
	&PedTraRedCod = &inPedTraRedCod
	
	if &Carrega = 'S'
		do 'carregaPedidosEntregas'
		&SdtPedidos = &AuxSdtPedidos
	Else
		padraoUsuario.Call('L', 'CARREGASDTPEDIDOS', &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
		&AuxSdtPedidos.Fromxml(&PadObs)
		&SdtPedidos = &AuxSdtPedidos
		do 'SomaTotais'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	txtSpaco.Width = 50
	Grid.Rows = 0
	GridsdtPedidoss.Rows = Page.Rows
	GridsdtPedidossPaginationBar.RowsPerPageSelectedValue = GridsdtPedidoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	GridsdtPedidoss.Rows = Page.Rows10

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtPedidossCurrentPage = GridsdtPedidoss.CurrentPage
	&GridsdtPedidossPageCount = GridsdtPedidoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&AcaoBaixar.FromImage(ActionCobranca)
	&AcaoBaixar.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if not &DuplicataMoeda.IsEmpty()
		&PedFrpPgtoTip = TipoDuplicata.DUPLICATA
		&TotalReceberMoeda = &DuplicataMoeda
		load
	Endif
	if not &DinheiroMoeda.IsEmpty()
		&PedFrpPgtoTip = TipoDuplicata.DINHEIRO
		&TotalReceberMoeda = &DinheiroMoeda
		load
	Endif
	if not &CartaoMoeda.IsEmpty()
		&PedFrpPgtoTip = TipoDuplicata.CARTAOC
		&TotalReceberMoeda = &CartaoMoeda
		load
	Endif
	if not &ChequeMoeda.IsEmpty()
		&PedFrpPgtoTip = TipoDuplicata.CHEQUEP
		&TotalReceberMoeda = &ChequeMoeda
		load
	EndIF

EndEvent

Event GridsdtPedidoss.Load

	&DadosDoEntregador = &SdtPedidos.CurrentItem.PedTraRedCodRaz
	if &SdtPedidos.CurrentItem.Localizado <> 'S'
		&Seleciona.FromImage(DDOMultiselOption)
	Else
		&Seleciona.FromImage(DDOMultiselSelOption)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Previous'
			GridsdtPedidoss.PreviousPage()
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtPedidoss.CurrentPage
			&PageToGo += 1
			GridsdtPedidoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtPedidossPaginationBar.SelectedPage)
			GridsdtPedidoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = GridsdtPedidossPaginationBar.RowsPerPageSelectedValue
	GridsdtPedidoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

	wwMonitoraDelivery.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirListagem'

	&Random = serverTime()
	
	if &AuxSdtPedidos.Count > 0
		padraoUsuario.Call('G', 'CARREGASDTPEDIDOS', &wwpContext.PesCod, &wwpContext.EmpCod, &AuxSdtPedidos.ToXml(), &PadDtaMod)
		padraoUsuario.Call('G', 'IMPRIMIRCARREGASDTPEDIDOS', &wwpContext.PesCod, &wwpContext.EmpCod, &AuxSdtPedidos.ToXml(), &PadDtaMod)
		
		RCOOpenWindow1.LinkOpen = RELJAS130.Link(&Random, &AuxPedFrpPgtoTip)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		msg('Nada para ser Impresso!')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'carregaPedidosEntregas'
	&SdtPedidos = &AuxSdtPedidos
	grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Seleciona.Click

	For &AuxSdtPedidosItem in &AuxSdtPedidos
		if &AuxSdtPedidosItem.PedCod = &SdtPedidos.CurrentItem.PedCod // sdtPedidos__PedCod
			if &SdtPedidos.CurrentItem.Localizado = 'S' //sdtPedidos__Localizado = 'S'
				&AuxSdtPedidosItem.Localizado = 'N'
			Else
				&AuxSdtPedidosItem.Localizado = 'S'
			EndIf
			Exit
		Endif
	EndFor
	&SdtPedidos = &AuxSdtPedidos
	padraoUsuario.Call('G', 'CARREGASDTPEDIDOS', &wwpContext.PesCod, &wwpContext.EmpCod, &AuxSdtPedidos.ToXml(), &PadDtaMod)
	do 'SomaTotais'
	grid.Refresh()

EndEvent

Event &AcaoBaixar.Click

	padraoUsuario.Call('G', 'CARREGASDTPEDIDOS', &wwpContext.PesCod, &wwpContext.EmpCod, &AuxSdtPedidos.ToXml(), &PadDtaMod)
	wpConfirmaAcertoPedidos.Popup(&PedFrpPgtoTip)
	wpacertoEntregador.Link(&PedTraRedCod)

EndEvent

Sub 'carregaPedidosEntregas'

	prcRetornaSdtPedidos.Call(&EmpCod, &FilCod, &PedTraRedCod, &AuxSdtPedidos)
	padraoUsuario.Call('G', 'CARREGASDTPEDIDOS', &wwpContext.PesCod, &wwpContext.EmpCod, &AuxSdtPedidos.ToXml(), &PadDtaMod)
	do 'SomaTotais'

EndSub

Sub 'SomaTotais'

	&DinheiroMoeda.SetEmpty()
	&CartaoMoeda.SetEmpty()
	&ChequeMoeda.SetEmpty()
	&DuplicataMoeda.SetEmpty()
		
	For &AuxSdtPedidosItem in &AuxSdtPedidos
		if &AuxSdtPedidosItem.Localizado = 'S'
			Do CAse
				Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.DINHEIRO
					&DinheiroMoeda += &AuxSdtPedidosItem.PedVlrLiq
				Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CARTAOC or &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CARTAOD
					&CartaoMoeda += &AuxSdtPedidosItem.PedVlrLiq
				Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CHEQUEP or &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CHEQUET
					&ChequeMoeda += &AuxSdtPedidosItem.PedVlrLiq
				Otherwise //Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.DUPLICATA
					&DuplicataMoeda += &AuxSdtPedidosItem.PedVlrLiq
			EndCase
		EndIf
	EndFor

EndSub


