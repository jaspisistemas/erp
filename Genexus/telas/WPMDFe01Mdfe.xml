Sub 'LoadMDFe'

	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDfeCod
		
		&MDFeDtaEms = MDFeDtaEms
		&MDFeHorEms = MDFeHorEms
		&MDFeDtaSai = MDFeDtaSai
		&MDFeHorSai = MDFeHorSai
		&MDFeNum    = MDFeNum
		&MDFeSer    = MDFeSer
		&MDFeSts    = MDFeSts 
		&MDFeTipEmt = MDFeTipEmt
		&MDFeModCod = MDFeModCod
		&MDFeTipMod = MDFeTipMod
		&MDFeOriUfeCod = MDFeOriUfeCod
		do 'GetCidadeCarregamento'
		&Estado = 1
		Do 'CarregaCidades'
		
		&MDFeDstUfeCod = MDFeDstUfeCod
		&auxMDFeDesCidCod = MDFeDesCidCod
		&Estado = 2
		Do 'CarregaCidades'
		
		&MDFeChv    = MDFeChv
		&MDFeProt   = MDFeProt
		&MDFeAdc    = MDFeAdc		
		&MDfeUnd    = MDfeUnd
		&MDFeVlrTot = MDFeVlrTot
		&MDfePsoBrt = MDFePsoBrt
		&MDFeTotNF  = MDFeTotNF
		&MDFeDtaEnc = MDFeDtaEnc
		&MDFeHorEnc = MDFeHorEnc
		&MDFeEncUfeCod = MDFeEncUfeCod
		
		
		&MDFeTipTra = MDFeTipTra
		&MDFeLotCarCep = MDFeLotCarCep
		&MDFeLotDesCep = MDFeLotDesCep
		Exit		
	EndFor

EndSub

Sub 'GetCidadeCarregamento'

	For Each Order EmpCod, FilCod, MDFeCod,MDFeCarCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDfeCod
		Where MDFeCarCod = 1
		&AuxMDFeCarCidCod = MDFeCarCidCod
		Exit
	EndFor

EndSub

Sub 'CarregaCidades'

	Do Case
		Case &Estado = 1
			&MDFeCarCidCod.Clear()
			&UfeCod = &MDFeOriUfeCod
		Case &Estado = 2
			&MDFeDesCidCod.Clear()
			&UfeCod = &MDFeDstUfeCod
		
	EndCase
	
	For each Order EmpCod, UfeCod
		Where EmpCod = &EmpCod
		Where UfeCod = &UfeCod
		Do Case
			Case &Estado = 1
				
				&MDFeCarCidCod.AddItem(CidCod,CidNom)
			Case &Estado = 2
				
				&MDFeDesCidCod.AddItem(CidCod,CidNom)
		EndCase
	EndFor

	Do Case
		Case &Estado = 1
			&MDFeCarCidCod = &AuxMDFeCarCidCod
		Case &Estado = 2
			&MDFeDesCidCod = &auxMDFeDesCidCod
	EndCase

EndSub


