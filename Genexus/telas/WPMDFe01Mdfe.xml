      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&SolCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &MDFeTipEmt = MDFe_TipoEmitente.NaoPrestador
		&PadObs = '1'
	Else
		&PadObs = '2'
	EndIf

	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult AND not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		WPMDFe01(!'Mdfe', !'Documentos', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WPMDFe01(!'Mdfe', !'BemVindo', true)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	If 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&MDFeCod = &WizardData.Mdfe.MDFeCod
	&MDFeNum = &WizardData.Mdfe.MDFeNum
	&MDFeSer = &WizardData.Mdfe.MDFeSer
	&MDFeProt = &WizardData.Mdfe.MDFeProt
	&MDFeModCod = &WizardData.Mdfe.MDFeModCod
	&MDFeChv = &WizardData.Mdfe.MDFeChv
	&MDFeSts = &WizardData.Mdfe.MDFeSts
	&SolCod = &WizardData.Mdfe.SolCod
	&MDFeDtaEnc = &WizardData.Mdfe.MDFeDtaEnc
	&MDFeHorEnc = &WizardData.Mdfe.MDFeHorEnc
	&MDFeEncUfeCod = &WizardData.Mdfe.MDFeEncUfeCod
	&MDFeAdc = &WizardData.Mdfe.MDFeAdc
	&MDFeLotDesCep = &WizardData.Mdfe.MDFeLotDesCep
	&MDFeDesCidCod = &WizardData.Mdfe.MDFeDesCidCod
	&MDFeDstUfeCod = &WizardData.Mdfe.MDFeDstUfeCod
	&MDFeLotCarCep = &WizardData.Mdfe.MDFeLotCarCep
	&MDFeCarCidCod = &WizardData.Mdfe.MDFeCarCidCod
	&MDFeOriUfeCod = &WizardData.Mdfe.MDFeOriUfeCod
	&MDFeTipEmt = &WizardData.Mdfe.MDFeTipEmt
	&MDFeTipMod = &WizardData.Mdfe.MDFeTipMod
	&MDFeTipTra = &WizardData.Mdfe.MDFeTipTra
	&EmpCod = &WizardData.Mdfe.EmpCod
	&PesCod = &WizardData.Mdfe.PesCod
	&MDFeHorSai = &WizardData.Mdfe.MDFeHorSai
	&MDFeDtaSai = &WizardData.Mdfe.MDFeDtaSai
	&MDFeHorEms = &WizardData.Mdfe.MDFeHorEms
	&MDFeDtaEms = &WizardData.Mdfe.MDFeDtaEms
	&FilCod = &WizardData.Mdfe.FilCod

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		LoadWWPContext.Call(&Context)
		
		&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
		&EmpCod = &Context.EmpCod
		&PesCod = &Context.PesCod
		
		//## CARREGANDO FILAIL NO COMBOBOX DESTA FORMA POIS VIA DINAMIC COMBO COMEÇOU DAR PAU
		&sdtFilialAcesso = DpFilialAcesso.udp(&EmpCod,&PesCod)		
		For  &sdtFilialAcessoItem in &sdtFilialAcesso			
			&FilCod.AddItem(&sdtFilialAcessoItem.PesFilAce,&sdtFilialAcessoItem.PesFilAceNom)
		EndFor
		
		&EmpCod = &WizardData.Mdfe.EmpCod
		&FilCod = &WizardData.Mdfe.FilCod
		&MDFeCod = &WizardData.Mdfe.MdfeCod
		
		If &MDFeCod <> 0
			Do 'LoadMDFe'
		Else
			
			&EmpCod = &Context.EmpCod
			&PesCod = &Context.PesCod
			//&FilTime = &Context.FilTime
			RetornaConfSistema.Call(&EmpCod, &Context.FilCod, domConfSistema.TCon002_FilialFaturamento, &CfgVlr)
			&FilCod = val(&CfgVlr)
			If &FilCod.IsEmpty()
				&FilCod = &Context.FilCod
			EndIF
			&MDFeDtaEms =  serverdate()
			&MDFeHorEms = servertime() //iif(&FilTime <> 0,serverTime()-&FilTime,serverTime())
			&MDFeDtaSai = serverdate()
			&MDFeHorSai = serverTime()
			&MdfeSer    = RetornaSerieNF.Udp(domParCod.MDFESER, &EmpCod, &FilCod)
			&MDFeSts    = Status_MDFe.Digitando
			&MDFeTipEmt = MDFe_TipoEmitente.NaoPrestador
			&MDFeModCod = '58'
			&MDFeTipMod = TipoModalidade.Rodoviario
			&MdfeNum = 0
			PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
			
			If not &PadObs.IsEmpty()
				&MDFeTipEmt = iif(Substr(&PadObs,1,1) = '1',MDFe_TipoEmitente.NaoPrestador,MDFe_TipoEmitente.Prestador)
			EndIF
			
			For Each Order EmpCod, FilCod
				Where EmpCod = &Context.EmpCod
				Where FilCod = &Context.FilCod
				
				&MDFeOriUfeCod = FilCidUfeCod
				&auxMDFeCarCidCod = FilCidCod
				&MDFeLotCarCep = FilCep
				&Estado = 1
				Do 'CarregaCidades'
				
