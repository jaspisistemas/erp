      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&HojeDataHora = serverdate()
	
	&PesSacPrxLig = &HojeDataHora
	&Hora = '18:00:00'
	&Dias = 7
	
	if &PedStsEnv = Status_Rastreamento.Entregue
		form.Caption = 'Confirmação de Entrega'
		RetornaAutorizacao.Call('CONFIRMARENTREGA', Status_SimNao.Sim, 1, &AutNiv)
	Else
		form.Caption = 'Cancelamento de Entrega'
		RetornaAutorizacao.Call('CANCELARENTREGA', Status_SimNao.Sim,  1, &AutNiv)
	EndIF
	
	do 'loadRastreio'
	&PedDtaDsp = serverdate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableAttributes.Height = 250

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&PedStsEnv = Status_Rastreamento.Entregue)
		DVPanel_TableAttributes_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributes_Cell.Class = !'col-xs-12'
	EndIf
	tbconf.Visible = (&PedStsEnv <>  Status_Rastreamento.Entregue)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Dias.IsValid

	&PesSacPrxLig = &HojeDataHora.AddDays(&Dias)

EndEvent

Event &Hora.IsValid

	FormataHORA.Call(&Hora, &Hora)
	if &Hora = '00:00:00'
		&Hora = '18:00:00'
	EndiF

EndEvent

Event Enter

	If &PedStsEnv = Status_Rastreamento.Entregue
		
		&PrxPesSacPrxLig = &PesSacPrxLig 
		&Hor = val(Substr(&Hora, 1, 2))
		&min = val(Substr(&Hora, 4, 2))
		&Seg = val(Substr(&Hora, 7, 2))
		&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddHours(&Hor)
		&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddMinutes(&min)
		&PrxPesSacPrxLig = &PrxPesSacPrxLig.AddSeconds(&Seg)
		
		RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.TCon043_DiasMaxPrxLig, &CfgVlr)
		&valor =  val(&CfgVlr)
		&MaximaData = Serverdate() + &valor
		&HojeDataHora = serverdate()
		Do Case
			Case &PesSacDlg.IsEmpty()
				msg('Escreva o conteúdo da conversa para poder agendar uma próxima ligação!')
				&PesSacDlg.Setfocus()
				
			Case &PedDtaDsp < &PedDtaEms
				msg('Data da entrega não pode ser inferior a data da postagem!')
				&PedDtaDsp.SetFocus()
				
			Case &PrxPesSacPrxLig > &MaximaData
				&Mensagem = 'Não é Permitido o Agendamento para uma data superior à ' + trim(str(&valor)) + ' dias! [CONF197]'
				msg(&Mensagem)
				&PesSacDlg.Setfocus()
				
			Case &HojeDataHora > &PrxPesSacPrxLig 
				msg('Não é possível agendar uma data inferior à Hoje!')
				&PesSacDlg.Setfocus()
				
			Otherwise				
				GravaLigacaoTelevendas.Submit('', &EmpCod, &PedCliCod, &PedVenCod, &PesIsVen, Status_InternoExterno.INTERNO, &PesSacDlg, &PrxPesSacPrxLig, 'I', &Context.PesCod)
				
				Rastreamento_Finaliza.Call(&EmpCod, &FilCod, &PedCod, &PedStsEnv, &PedEnvCod, &PedDtaDsp, &Context.UserName)
				Return
				
		EndCase
	Else //CANCELA ENTREGA
		Rastreamento_Finaliza.Call(&EmpCod, &FilCod, &PedCod, &PedStsEnv, &PedEnvCod, &PedDtaDsp, &Context.UserName)
		Return
	EndiF

EndEvent

Sub 'loadRastreio'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedDtaEms = PedDtaEms
		&PedCliCod = PedCliCod
		&PedCliRaz = PedCliRaz
		&PedDtaDsp = PedDtaDsp
		&PedEnvCod = PedEnvCod
		&PedVenCod = PedVenCod
		&PesIsVen = PedVenIs
		
		Exit
	EndFor

EndSub


]]></Source>
