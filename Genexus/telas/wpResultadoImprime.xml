	return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if &Mes.IsEmpty()
		&DtaIni = YMDtoD(&Ano, 1, 1)
		
		&Data = YMDtoD(&Ano, 12, 1)
		&DtaFin = EoM(&Data)
	Else
		&DtaIni = YMDtoD(&Ano, &Mes, 1)
		&DtaFin = EoM(&DtaIni)
	Endif

	RCOOpenWindow1.LinkOpen = RELJAS015.link(&WwpContext.EmpCod,0,&PlanHie,&DtaIni,&DtaFin,'',false)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent


