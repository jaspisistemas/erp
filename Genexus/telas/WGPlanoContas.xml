Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&ano = year(&Today)
	&mes = month(&Today)
	&IniMovDtaCon = yMDtoD(&ano,&mes,1) 
	&FinMovDtaCon = eom(&Today)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableContent.Width = 1350
	TableGraf.Width = 420
	TableGraf.Height = 250
	Ttop.Width = 420

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPrincipal.Load

	For each Order EmpCod,PlanCatTip,PlanCod
		Where EmpCod = &EmpCod
		Where PlanAnaSin = 'S'
		&auxPlanHie = PlanHie
		&PlanCodNom = PlanCodNom
		&ColPlanCod = RetornaCollPlanoContas.udp(EmpCod,PlanHie)
		Do "SetQueryViewerParametersExample"
		Do "SetObjectNameExample"
		Load		
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAtualizar'

	Do "SetQueryViewerParametersExample"
		Do "SetObjectNameExample"

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

