	// Collection parameter
	&Parameter = New()
	&Parameter.Name = "PlanCod"
	&Parameter.Value = &ColPlanCod.ToJson()		// Or &Parameter.Value = &CollectionVariable.ToJson()
	&Parameters.Add(&Parameter)

EndSub

