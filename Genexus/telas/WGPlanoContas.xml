	// Change query or dataprovider in runtime
	QueryViewer1.ObjectName = "QPlanosContas"			// Or QueryViewer1.ObjectName = &CharacterVariable

EndSub

Sub "SetQueryViewerParametersExample"

	// Set query or dataprovider parameters in runtime

	&Parameters = New()
	// Numeric parameter
	&Parameter = New()
	&Parameter.Name = "EmpCod"
	&Parameter.Value = &EmpCod.ToString().Trim() 				// Or &Parameter.Value = &NumericVariable.ToString().Trim()
	&Parameters.Add(&Parameter)
	
	// Character parameter
	&Parameter = New()
	&Parameter.Name = "IniMovDtaCon"
	&Parameter.Value = &IniMovDtaCon.ToString()			// Or &Parameter.Value = &CharacterVariable
	&Parameters.Add(&Parameter)
	
	// Boolean parameter
	&Parameter = New()
	&Parameter.Name = "FinMovDtaCon"
	&Parameter.Value = &FinMovDtaCon.ToString()			// Or &Parameter.Value = &BooleanVariable.ToString()
	&Parameters.Add(&Parameter)
	
