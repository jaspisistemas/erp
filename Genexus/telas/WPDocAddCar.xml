      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If &ParCteInfUndCarTip <> 0 
		Do 'GetLacres'
	EndIf

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&DelLacre.JSEvent( "onclick", "confirm ( 'Tem certeza que deseja excluir este Lacre?')")
	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndCarTip
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		Where CteInfUndCarTip = &ParCteInfUndCarTip

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DelLacre.FromImage(ActionDelete)
	&DelLacre.TooltipText = "Deletar Lacre"
	
	&UUpdate.FromImage(ActionUpdate)
	&UUpdate.TooltipText = "Editar Lacre"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUInsertCarga'

	WPDocCarAddLac.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndCarTip,&CteUniCarLac)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DelLacre.Click

	DeletaCteDocCargaLacre.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteInfUndCarTip,&CteInfUndCarTip,&CteUniCarLac)
	Refresh

EndEvent

Event &UUpdate.Click

	WPDocCarAddLac.Call(&EmpCod,&FilCod,&CteCod,&CteDocCod,&CteDocTip,&CteInfUndCarTip,&CteUniCarLac)
	Refresh

EndEvent

Sub 'GetLacres'

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndCarTip,CteUniCarLac
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		Where CteInfUndCarTip = &ParCteInfUndCarTip
		&CteUniCarLac = CteUniCarLac		
	EndFor

EndSub


]]></Source>
