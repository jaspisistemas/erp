Sub 'MensalidadeSistema'

	//AVISA DUPLICATA DISPONIVEL
	retornaAutorizacao.Call('WWDUPLICATAPAGAR', Status_SimNao.Nao, 1, &AutNiv)
	
	if &AutNiv > 1 or &AutIsAdm = true or &Old_Perfil = 3  or &Old_Perfil = 2
		
		&Mensagem.SetEmpty()
		PadraoUsuario.Call('L', '#VENCIMENTODUPLICATAJASPI#', 1, &EmpCod, &PadObs, &PadDtaMod)  //Grava no GetVencimentoWbsJapsi e 	appwbsjaspiduplicatas_out
		
		&VencimentoData.FromString(Substr(&PadObs,1,10))
		&AuxVencimentoData = &VencimentoData.AddDays(-10)
		
		&Nivel = 0
		if (&AuxVencimentoData < &HojeData ) and not &VencimentoData.IsEmpty() //5 DIAS antes de vencer
				
			&NotificationIconClass = 'fas fa-barcode jaspiWWIconDangerColumn'
			&SDTNotificationsDataItem = new()
			&SDTNotificationsDataItem.NotificationTitle = 'Mensalidade disponível para pagamento!'
			&SDTNotificationsDataItem.NotificationDatetime = &VencimentoData
			&SDTNotificationsDataItem.NotificacaoTipo = 'Mensalidade'
			&SDTNotificationsDataItem.NotificationIconClass = &NotificationIconClass
			&SDTNotificationsData.Add(&SDTNotificationsDataItem)
		Endif
	Endif

EndSub

