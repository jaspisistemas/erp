      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&IsAcesso = false
	DpFilialAcesso.Call(&EmpCod, &PesCod, &sdtFilialAcesso)
	for &sdtFilialAcessoitem in &sdtFilialAcesso
		if &sdtFilialAcessoitem.PesFilAce = &FilCod
			&IsAcesso = true
			Exit
		Endif
	EndFor
	
	&AutIsAdm = RetornaAutorizacaoAdministrador.Udp(&EmpCod, &PesCod)
	retornaAutorizacao.Call('WWNOTAS', Status_SimNao.Nao, 2, &wwNotasAutNiv)
	if &wwNotasAutNiv < 2 and &AutIsAdm = false
		retornaAutorizacao.Call('WWCTE', Status_SimNao.Nao, 2, &wwNotasAutNiv)
		if &wwNotasAutNiv < 2 and &AutIsAdm = false			
			retornaAutorizacao.Call('WWNOTASSERVICO', Status_SimNao.Nao, 1, &wwNotasAutNiv)	
		Endif
	EndiF

	For Each ORder EmpCod
		Where EmpCod = &EmpCod
		tabbAndroid.Visible = EmpIsAppErp
		Exit
	EndFor

	
	retornaAutorizacao.Call('WWPRODUTO', Status_SimNao.Nao, 1, &WWPRODUTOAutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable5.Height = 9
	UnnamedTable3.Height = 9
	UnnamedTable10.Height = 5
	UnnamedTable8.Width = 2
	UnnamedTable11.Width = 2
	UnnamedTable6.Height = 5
	UnnamedTable15.Height = 13
	UnnamedTable12.Height = 13
	GridNotifications.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Compilacao.Call(false, &Compilacao, &IsExecutaUpdate, &DisEmpVer, &DisEmpCmp)
	SubInfo.Caption	= 'Versão Atual - ' + trim(str(&DisEmpCmp))
	
	Do 'VerificaVersoes'

EndEvent

Event GridNotifications.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&btnNotificationIcon = !'<i class=""></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&btnNotificationIcon.Class = ''
	&btnNotificationIcon = Format(!'<i class="%1"></i>', &SDTNotificationsData.CurrentItem.NotificationIconClass)

	&TipoNotificacao = &SDTNotificationsData.CurrentItem.NotificacaoTipo
	&btnNotificationIcon.LinkTarget = ''
	Do Case
		Case upper(&TipoNotificacao) = 'REMESSA'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
			&btnNotificationIcon.TooltipText = 'Clique Aqui para Registrar os boletos'
		Case upper(&TipoNotificacao) = 'CTE' 
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
			&btnNotificationIcon.TooltipText = 'Monitorar CTe'
		Case upper(&TipoNotificacao) = 'NFCE'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
			&btnNotificationIcon.TooltipText = 'Monitorar NFCe'
		Case upper(&TipoNotificacao) = 'NFE'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
			&btnNotificationIcon.TooltipText = 'Monitorar NFe'
		Case upper(&TipoNotificacao) = 'CERTIFICADO'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
			&btnNotificationIcon.TooltipText = ''		
		Case upper(&TipoNotificacao) = 'CERTCONTA'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
			&btnNotificationIcon.TooltipText = ''			
		Case upper(&TipoNotificacao) = 'MENSALIDADE'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
			&btnNotificationIcon.TooltipText = 'Imprimir Mensalidade Sistema'
		Case upper(&TipoNotificacao) = 'NCM'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
			&btnNotificationIcon.TooltipText = 'Visualizar NCMS'	
		Case upper(&TipoNotificacao) = 'RECEITUARIO'
			&TipoNotificacao.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
			&btnNotificationIcon.TooltipText = 'Existe NF-e com receituário pendente'
		Otherwise
			&TipoNotificacao.ColumnClass = !'WWColumn'
			&btnNotificationIcon.TooltipText = ''
	EndCase
	
	
	&gridData = &SDTNotificationsData.CurrentItem.NotificationDatetime

EndEvent

Event ddc_Info.OnLoadComponent

	If 1 = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

