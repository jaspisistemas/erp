EndEvent

Event Refresh

	&SDTNotificationsData.Clear()
	&HojeData = serverdate()
	
	IF &wwNotasAutNiv > 1 OR &AutIsAdm = TRUE
		do 'VencimentoCertificado'
		do 'NotasPendentes'
	eNDIF
	
	do 'BoletosPendentes'
	do 'MensalidadeSistema'
	if &WWPRODUTOAutNiv > 1
		do 'ProdutosNCM'
	Endif
	do 'VencimentoCertificadoContasBancarias'
	NotificationsSubtitle.Caption = ''//Format("WWP_Notifications_NewNotifications", &SDTNotificationsData.Count.ToString().Trim())

EndEvent

Event Table_Versao.Click

	BtnVersao_Modal.Confirm()

EndEvent

Event TabbAndroid.Click

	BtnAndroid_Modal.Confirm()

EndEvent

Event Table_Manuais.Click

	InNewWindow1.Target = !"https://ajuda.jaspi.com.br/"
	InNewWindow1.OpenWindow()

EndEvent

Event &btnNotificationIcon.Click

	Do Case
		Case upper(&TipoNotificacao) = 'NFSE'
			wwNotasServico.Link()
			
		Case upper(&TipoNotificacao) = 'NFE' or upper(&TipoNotificacao) = 'RECEITUARIO'
			wwnotas.Link()
			
		Case upper(&TipoNotificacao) = 'NFCE'
			wwnotasNFCe.Link()
			
		Case upper(&TipoNotificacao) = 'CTE'
			wwCTe.Link()
			
		Case upper(&TipoNotificacao) = 'CERTIFICADO'
			wwfilial.Link()
			
		CAse upper(&TipoNotificacao) = 'CERTCONTA'
			wwContas.Link()
			
		Case upper(&TipoNotificacao) = 'REMESSA'
			wpBoletosRegistrar.Popup(&EmpCod)
			Refresh
		Case Upper(&TipoNotificacao) = 'MENSALIDADE'
			
			//link duplicatas Jaspi
			PadraoUsuarioHora.Call('L', '#VENCIMENTODUPLICATAJASPI#', 1, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
			if not &PadObs.IsEmpty()
				&dupCreDtavct = CtoD(Substr(&PadObs,1,10))
				&Cryptografado = Substr(&PadObs,11,37)
				
				
				
				CodigoExternoDuplicata.Call(&Cryptografado, 0, 0, 0, 0, &dupCreDtavct, &Cryptografado)				
				
				&Mensagem = 'https://app.jaspi.com.br/portalcliente.areacliente.aspx?' + &Cryptografado.Trim()
				link(&Mensagem)
			Endif
			
		Case upper(&TipoNotificacao) = 'NCM'
			wpCorrigeNCM.Link()
			
	EndCase

EndEvent

Sub 'VencimentoCertificadoContasBancarias'

	&CtaVctCer = &HojeData
	&CtaVctCer = &CtaVctCer.AddDays(30)
	
	For Each //Order EmpCod, CtabanCod
		Where EmpCod = &EmpCod
		where CtaBanSts = Status_AtivoInativo.ATIVO
		Where CtaBanPixApi = 'P' //API PRODUCAO
		Where (not CtaVctCer.IsEmpty() and not CtaVctCer.IsNull()) and CtaVctCer <= &CtaVctCer
			
			if CtaVctCer > &HojeData
				&NotificationIconClass = "fas fa-award jaspiWWIconWarningColumn"
				&SDTNotificationsDataItem = new()
				&SDTNotificationsDataItem.NotificationTitle = format('Certificado digital API BANCO: %1', CtaBanNom.Trim() + ' ESTÁ PARA VENCER EM MENOS DE 30 dias !')
				&SDTNotificationsDataItem.NotificationDatetime = CtaVctCer
				&SDTNotificationsDataItem.NotificacaoTipo = 'CERTCONTA'
				&SDTNotificationsDataItem.NotificationIconClass = &NotificationIconClass
				&SDTNotificationsData.Add(&SDTNotificationsDataItem)
			Else
				&NotificationIconClass = "fas fa-award jaspiWWIconWarningColumn"
