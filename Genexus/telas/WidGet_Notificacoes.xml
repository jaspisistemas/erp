				&SDTNotificationsDataItem.NotificacaoTipo = 'CERTCONTA'
				&SDTNotificationsDataItem.NotificationIconClass = &NotificationIconClass
				&SDTNotificationsData.Add(&SDTNotificationsDataItem)
			Endif
		
	EndFor

EndSub

