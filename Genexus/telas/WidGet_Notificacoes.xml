Sub 'VencimentoCertificado'

	//Vencimento Certificado
	&FilVctCer = &HojeData + 30
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilVctCer <= &FilVctCer
		Where not FilVctCer.IsEmpty() and not FilVctCer.IsNull()
		
		&QtdDias = &HojeData - FilVctCer
		If FilCpj.Trim().Length() > 14
			&TIPO = 'E-CNPJ '
		Else
			&TIPO = 'E-CPF '
		EndIf
		
		if &QtdDias < 0
			&QtdDias = &QtdDias * -1
		EndIF
		&AvisoVencimentoMensagem = ''	
		
		&AvisoVencimentoMensagem += &TIPO.Trim() + ' FILIAL:' + trim(str(FilCod))		
		Do Case
			CAse FilVctCer = &HojeData
				&AvisoVencimentoMensagem += ' # VENCE HOJE: ' + trim(toFormattedString(&HojeData)) + ' #'
				&NotificationIconClass = "fas fa-award jaspiWWIconWarningColumn"
			Case FilVctCer < &HojeData
				&AvisoVencimentoMensagem += ' # VENCIDO À MAIS DE ' +trim(toformattedString(&QtdDias)) + ' DIAS #'
				&NotificationIconClass = "fas fa-award jaspiWWIconWarningColumn"
			Otherwise
				if &QtdDias > 1
					&NotificationIconClass = "fas fa-award jaspiWWIconWarningColumn"
					&AvisoVencimentoMensagem += ' # VENCE: ' +trim(toformattedString(&QtdDias)) + ' DIAS #'
				Else
					&NotificationIconClass = "fas fa-award jaspiWWIconWarningColumn"
					&AvisoVencimentoMensagem += ' # VENCE: ' +trim(toformattedString(&QtdDias)) + ' DIA #'
				Endif
		EndCase
	
		&DateTime = FilVctCer
		
		&SDTNotificationsDataItem = new()
		&SDTNotificationsDataItem.NotificationTitle = &AvisoVencimentoMensagem
		&SDTNotificationsDataItem.NotificationDatetime = &DateTime
		&SDTNotificationsDataItem.NotificacaoTipo = 'Certificado'
		&SDTNotificationsDataItem.NotificationIconClass = &NotificationIconClass
		&SDTNotificationsData.Add(&SDTNotificationsDataItem)
	EndFor

EndSub


