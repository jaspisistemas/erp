      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&isContato = 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 420
	eer.Width = 600
	eer.Height = 420
	UnnamedTable2.Width = 600
	UnnamedTable1.Width = 600

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = true
		&isContato = 0
		
		&ppJASPI_NovoClientesdtFuturoCliente = new()
		&ppJASPI_NovoClientesdtFuturoCliente.FutCliCnpj = &FilCpj
		&ppJASPI_NovoClientesdtFuturoCliente.FutCliCidNom = &CidNom
		&ppJASPI_NovoClientesdtFuturoCliente.FutCliRaz = &FilRaz
		&ppJASPI_NovoClientesdtFuturoCliente.FutCliCon = &FilCon
		&ppJASPI_NovoClientesdtFuturoCliente.FutCliEml = &PesEml
		&ppJASPI_NovoClientesdtFuturoCliente.FutCliFon = &FilFonNum
		
		Do Case 
			Case &Quantidade = 1 //de 01 a 03
				&Observacao = 'Qtd.Funcionarios: de 01 a 03'
			Case &Quantidade = 4//de 04 a 06
				&Observacao = 'Qtd.Funcionarios: de 04 a 06'
			Case &Quantidade = 7//de 07 a 10
				&Observacao = 'Qtd.Funcionarios: de 07 a 10'
			Case &Quantidade = 11//de 11 a 50
				&Observacao = 'Qtd.Funcionarios: de 11 a 50'
			Case &Quantidade = 51//Mais que 50
				&Observacao = 'Qtd.Funcionarios: Mais que 50'
		EndCase
		
		&Observacao += ' Cidade:' + trim(&CidNom) + '; Obs:' + trim(&PesObs)
		
		&ppJASPI_NovoClientesdtFuturoCliente.FutCliObs = &Observacao
		
		
		
		HostWebServiceJaspiADM.Call(0, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
		&Location = GetLocation('ppJASPI_NovoCliente') //objeto externo onde foi importado o WSDL no GX XEV1 
		&Location.Host = &EmpWebHost //servidor 
		&Location.Port = &EmpWebPor //porta  
		&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
		&Location.Secure = false //false 
		&Location.CancelOnError = 2 //tratar exceção do WS 	
		
		&ppJASPI_NovoCliente.Execute(&ppJASPI_NovoClientesdtFuturoCliente)
		
		If GetSOAPErr()= 0 
			If &ppJASPI_NovoClientesdtFuturoCliente.StsErro = 1
				&isContato = 0
				Do 'AttributesSecurityCode'
			Else
				
				msg(&ppJASPI_NovoClientesdtFuturoCliente.StsMensagem)
			EndiF
		Else 
			&Msg = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
			&Msg += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
			Msg(&Msg) 
		EndIf
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	FormataFONE.Call(&FilFonNum, &FilFonNum)
	ValidaCpfCnpj.Call(&FilCpj, &erro, 'N')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &FilCon.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nome'), DVMessageType.error, &FilCon.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &FilFonNum.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Telefone'), DVMessageType.error, &FilFonNum.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PesEml.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Email'), DVMessageType.error, &PesEml.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &Quantidade.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Quantidade de funcionários'), DVMessageType.error, &Quantidade.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &FilRaz.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nome Empresa'), DVMessageType.error, &FilRaz.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &FilCpj.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','CNPJ'), DVMessageType.error, &FilCpj.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CidNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Cidade-Estado'), DVMessageType.error, &CidNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &erro = 1
		msg('CNPJ empresa inválido')
		&CheckRequiredFieldsResult = false
	EndIF

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableAttributes.Visible = (&isContato = 1)
	eer.Visible = (&isContato = 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &FilFonNum.IsValid

	FormataFONE.Call(&FilFonNum, &FilFonNum)

EndEvent

Event &FilCpj.IsValid

	ValidaCpfCnpj.Call(&FilCpj, &erro, 'N')

EndEvent


]]></Source>
