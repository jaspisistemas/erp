      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	loadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	RetornaTabelaFilial.Call(&EmpCod, &Context.FilCod, &TabNum)

EndEvent

Event Refresh

	RetornaColunas_Nome.Call(&EmpCod, &TabNum, &SdtColunasTabela)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	
	TabPrc2.Visible = &SdtColunasTabela.Tem2
	TabPrc3.Visible = &SdtColunasTabela.Tem3
	TabPrc4.Visible = &SdtColunasTabela.Tem4
	TabPrc5.Visible = &SdtColunasTabela.Tem5
	TabPrc6.Visible = &SdtColunasTabela.Tem6
	TabPrc7.Visible = &SdtColunasTabela.Tem7
	TabPrc8.Visible = &SdtColunasTabela.Tem8
	TabPrc9.Visible = &SdtColunasTabela.Tem9
	
	TabPrc1.Title = &SdtColunasTabela.TabColNom1
	TabPrc2.Title = &SdtColunasTabela.TabColNom2
	TabPrc3.Title = &SdtColunasTabela.TabColNom3
	TabPrc4.Title = &SdtColunasTabela.TabColNom4
	TabPrc5.Title = &SdtColunasTabela.TabColNom5
	TabPrc6.Title = &SdtColunasTabela.TabColNom6
	TabPrc7.Title = &SdtColunasTabela.TabColNom7
	TabPrc8.Title = &SdtColunasTabela.TabColNom8
	TabPrc9.Title = &SdtColunasTabela.TabColNom9

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&VolumeEmbalagem = 'EMB:' + trim(toformattedString(ProQtdEmb)) + ' / VOL:' + trim(toformattedString(ProQtdVol))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
