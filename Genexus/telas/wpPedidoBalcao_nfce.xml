        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	enddde.Visible = 0
	&tmpPedQtdFat.Enabled = 1
	&PesTip = TipoPessoa.FISICA	
	do 'loadTemporaria'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable4.Height = 40
	&PesTip.Visible = False
	&EmpCod.Visible = False
	&FilCod.Visible = False
	Grid.Rows = 100

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PesCnpj.SetFocus()
	do 'VerificaNotaLancada'
	do 'impressaoDireta'

EndEvent

Event Grid.Load

	&tmpPedQtdFat = tmpPedQtdFat

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&VisualizaImposto = !'<i class="fa fa-search"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&tmpNcmCod = tmpNcmCod
	if &tmpNcmCod.IsEmpty()
		&tmpNcmCod = 99
	Endif

EndEvent

Event 'DoImprimirTicket'

 8
	if &OqueFazer1.Count > 0
	 	&PadOBs = &OqueFazer1
		padraoUsuario.Call('G', 'WPEMITENFCE_IMPRESSAODIRETA', &Context.PesCod, &Context.EmpCod, &PadOBs, &PAdDtaMod)
		&EmpImpCod1 = val(Substr(&OqueFazer1, 6, 8))
	 	do CAse
			Case Substr(&OqueFazer1, 1, 2) = '3B' // PEDIDO CUPOM DELIVERY
				prcGravaImpressao.Call(&EmpCod, &EmpImpCod1, 'RELJAS124_B', &FilCod, &PedCod, &Context.PesCod, '', 0, &FiDtaIni)
				
			Otherwise
				wpConfirmaImpressaoPedido.Popup(&EmpCod, &FilCod, &PedCod)
		EndCase
	Else
		wpConfirmaImpressaoPedido.Popup(&EmpCod, &FilCod, &PedCod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoNovaVenda'

 2
 do CAse
	 Case &DeOndeVem = 'PDV_M'
		GravaCapaPedidoPDV.Call(&Context.EmpCod, &Context.FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
		Pdvm_venda.Link(&AuxPedCod)
	Case &DeOndeVem = 'WWPEDIDOBALCAO' or &DeOndeVem = 'PEDIDOBALCAO'
		GravaCapaPedidoPDV.Call(&Context.EmpCod, &Context.FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
		wwpVendas_3.Link('WWPEDIDOBALCAO', &EmpCod, &FilCod, &AuxPedCod, 0)
		
	Case &DeOndeVem = 'WWORDEMSERVICO' or &DeOndeVem = 'ORDEMSERVICO'
		GravaCapaPedidoPDV.Call(&EmpCod, &FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
		wwpVendas_3.Link('WWORDEMSERVICO', &EmpCod, &FilCod, &AuxPedCod, 0)
		
	Case &DeOndeVem = 'WWOFICINAMECANICA' or &DeOndeVem = 'OFICINAMEC'
		GravaCapaPedidoPDV.Call(&EmpCod, &FilCod, 0, 0, &Context.PesCod, Pedido_Gerado.PDV, 0, &AuxPedCod)
		wwpVendas_3.Link('WWOFICINAMECANICA', &EmpCod, &FilCod, &AuxPedCod, 0)
		
	Case &DeOndeVem = 'WWMONITORADELIVERY'
		wwMonitoraDelivery.Link()
	
	Case &DeOndeVem = 'WWLOCACAOPRODUTOS'
		wwpvendasCliente.Call('WWLOCACAOPRODUTOS', &EmpCod, &FilCod, 0)
		
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &tmpNcmCod.Click

	wpAjustaNCMProduto.Popup(&EmpCod, tmpProCod)
	Refresh

EndEvent

Event 'PromptCliente'

	4
	PromptCliente.Popup(&EmpCod, &PesCod)
	&PesCod.SetFocus()

EndEvent

Event &PesCod.IsValid

	If &OldPesCod <> &PesCod
		do 'loadPessoa'
	EndIf
	&OldPesCod = &PesCod

EndEvent

Event &tmpPedQtdFat.IsValid

	do 'AtualizaItemTabelaTemporaria'
	do 'loadTemporaria'

EndEvent

Event &FatFilCod.Isvalid

	Do 'AtualizaNotaTemporaria'

EndEvent

Event &tmpNfeVlrFrt.IsValid

	Do 'AtualizaNotaTemporaria'

EndEvent

Event &tmpTotOut.IsValid

	Do 'AtualizaNotaTemporaria'

EndEvent

Event &tmpNfeVlrDsc.IsValid

	Do 'AtualizaNotaTemporaria'

EndEvent

Event Enter

	do 'confirmaEmissaoNFCe'

EndEvent

Event 'EnterF11'

 11
	do 'confirmaEmissaoNFCe'

EndEvent

Event &VisualizaImposto.Click

	&FilBasImp = RetornaFilialBaseImposto.Udp(&EmpCod, &FatFilCod)
	
	do 'Pedido'
	
	CadastroTabelaImposto.Popup(&FilBasImp, &LctBasImpCod, &PedCliCidUfeCod, &PedCliGruImpCod, tmpProCatCod)

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)

EndEvent

Event &PesCnpj.IsValid

	do 'validacpfcnpj'
	Do Case
		Case (&CnpjStatus = 1 and &PesTip = TipoPessoa.FISICA) 
			msg('CPF Informado é inválido!')
			&PesCnpj.SetFocus()
		Case (&CnpjStatus = 1 and &PesTip = TipoPessoa.JurIDICA)
			msg('CNPJ Informado é inválido!')
			&PesCnpj.SetFocus()
	endcase

EndEvent

Sub 'loadPessoa'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesTip = PesTip
		if PesTip = TipoPessoa.JURIDICA
			&PesCnpj = PesCnpj
		Else
			&PesCnpj = PesCpf
		Endif
	
		&PesCpf = PesCpf
		&PesRaz = PesRaz
		exit
	EndFor

EndSub

Sub 'impressaoDireta'

	padraoUsuario.Call('L', 'WPEMITENFCE_IMPRESSAODIRETA', &Context.PesCod, &Context.EmpCod, &PadOBs, &PAdDtaMod)
	
	&Istem_CUPOM1 = RetornaTemImpressora.Udp(&Context.EmpCod, domTipoImpressora.CUPOM1, domTipoImpressora.CUPOM2)
	tbPedidoImpressaoDireta.Visible = 0
	&OqueFazer1.clear()
	
	if &Istem_CUPOM1 = true
		&ModeloPedido = 'IMPRESSÃO NFCE - TICKET'
		For Each Order EmpCod, EmpImpPC, EmpImpNom
			Where EmpCod = &Context.EmpCod
			where EmpImpTip = domTipoImpressora.CUPOM1 or EmpImpTip = domTipoImpressora.CUPOM2
			
			&Mensagem = &ModeloPedido + '|' + EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
			&CodigoImpressora = '3B   ' + PadL(str(EmpImpCod), 8, ' ')
			&OqueFazer1.AddItem(&CodigoImpressora, &Mensagem)
		EndFor
		tbPedidoImpressaoDireta.Visible = 1

		&OqueFazer1 = trim(Substr(&PadOBs, 1, 15))
	Endif
	&Mensagem.SetEmpty()

EndSub

Sub 'validacpfcnpj'

	ValidaCpfCnpj.Call(&PesCnpj, &CnpjStatus, 'N')
	do 'GravaCliente'

EndSub

Sub 'AtualizaItemTabelaTemporaria'

	AtualizaPedQtdFat.Call(&tmpNFeCod, tmpNfeItmCod, &tmpPedQtdFat)

EndSub

Sub 'loadTemporaria'

	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNFeCod

		&OldPesCod = 0
		&PesCod = 0
		
		&tmpNfeVlrFrt = tmpNfeVlrFrt
		&tmpNfeVlrDsc = tmpNfeVlrDsc
		&tmpNfePerDsc = tmpNfePerDsc
		&PedVlrLiq = tmpTotNFe
		&NfeVlrTot = tmpTotNFe
		&NfeVlrTotPro = tmpTotNFe
		&FatFilCod = tmpNfeFatFilCod
		&PesRaz = tmpPedCliNom
		
		If tmpPedCliTip = TipoPessoa.JURIDICA
			&PesCnpj = tmpPedCliCnpj
			&PesTip = tmpPedCliTip
		Else
			&PesCnpj = tmpPedCliCpf
			&PesTip = tmpPedCliTip
		EndIf
			
		&tmpTotOut = tmpTotOut
		Exit
	EndFor

EndSub

Sub 'AtualizaNotaTemporaria'

	AtualizaCapaNotaTemporariaVendaImpacta.Call(&tmpNFeCod, &EmpCod, &FilCod, &FatFilCod, &PedCod, &tmpNfeVlrFrt, &tmpTotOut, true, &tmpNfeVlrDsc, &tmpNfePerDsc, &TipoDesconto,'9',false)
	refresh

EndSub

Sub 'GravaCliente'

	If &PesCnpj.Length() > 14
		&PesTip = TipoPessoa.JURIDICA
		&PesCpf = '' 
	Else
		&PesTip = TipoPessoa.FISICA
		&PesCpf = &PesCnpj
	EndIf

	GravaClienteTemporariaModelo65.Call(&tmpNFeCod, &PesTip, &PesCnpj, &PesCpf, &PesRaz)

EndSub

Sub 'confirmaEmissaoNFCe'

	do 'validacpfcnpj'
	
	Do CAse
		Case (&CnpjStatus = 1 and &PesTip = TipoPessoa.FISICA) 
			msg('CPF Informado é inválido!')
			&PesCnpj.SetFocus()
		Case (&CnpjStatus = 1 and &PesTip = TipoPessoa.JurIDICA)
			msg('CNPJ Informado é inválido!')
			&PesCnpj.SetFocus()
		Otherwise
			&EmitirConferir = 'E'
			
			validacoesNFCe.Call(&tmpNFeCod, &EmpCod, &FilCod, &PedCod, &ErroMensagem)
			
			if &ErroMensagem.IsEmpty()
				GravaNotaFiscalModelo65.Call(&DeOndeVem, &EmpCod, &FilCod, &PedCod, &tmpNFeCod, &EmitirConferir, &Context.PesCod, &PesEml)
			Else
				msg(&ErroMensagem)
			EndIf
	EndCase

EndSub

Sub 'Pedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&LctBasImpCod = LctBasImpCod
		&PedCliCidUfeCod = PedCliCidUfeCod
		&PedCliGruImpCod = PedCliGruImpCod
		Exit
	EndFor

EndSub

Sub 'VerificaNotaLancada'

	For Each Order EmpCod, NfeFilCod, NfePedCod, NfeSts
		Where EmpCod = &EmpCod
		Where NfeFilCod = &FilCod
		Where NfePedCod = &PedCod
		Where NfeSts in (Status_NFe.Autorizada, Status_NFe.Digitando)
		txtNotaJaLancada.Caption = 'ATENÇÃO. Esse pedido já possui uma nota Fiscal! Número: ' + trim(str(NfeNum)) + ' Filial :' + trim(str(FilCod))
		Exit
	EndFor

EndSub


