      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&tmpEmixCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&ApagarItensPedidoAtual = true
	&AdicionarItensPedidoAtual = true
	&tmpNFeCod = &WizardData.SelecionarArquivo.tmpNFeCod
	do 'loadTemporaria'

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'WizardPrevious'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'SaveVariablesToWizardData'
	wpImportarCompraXLSX(!'GravarPedido', !'Produtos', true, &SessionGuid)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&tmpEmixCod = &WizardData.GravarPedido.tmpEmixCod
	&ApagarItensPedidoAtual = &WizardData.GravarPedido.ApagarItensPedidoAtual
	&AdicionarItensPedidoAtual = &WizardData.GravarPedido.AdicionarItensPedidoAtual
	&tmpEmixNom = &WizardData.GravarPedido.tmpEmixNom

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.GravarPedido.tmpEmixCod = &tmpEmixCod
	&WizardData.GravarPedido.ApagarItensPedidoAtual = &ApagarItensPedidoAtual
	&WizardData.GravarPedido.AdicionarItensPedidoAtual = &AdicionarItensPedidoAtual
	&WizardData.GravarPedido.tmpEmixNom = &tmpEmixNom
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'FinishWizard'

	if &ApagarItensPedidoAtual = true
		DeletaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, 0)
	Endif

	if &AdicionarItensPedidoAtual = true
		prcGravaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &tmpNFeCod, &wwpContext.UserName)
	Endif

	if &WizardData.SelecionarArquivo.DeOndeVem = 'WPPEDIDOCOMPRAITEM'
		SaveGridState.Call("wcItensCompra2GridState",  '')
		wpPedidoCompraItem.Link(&FilCod, &PedCod, 0)
	Else
		wwPedidoCompra.Link()
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'loadTemporaria'

	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNFeCod
		&PedCod = tmpPedCod
		&EmpCod = tmpEmpCod
		&FilCod = tmpFilCod
		&tmpEmixNom = tmpEmixNom
	When None
		Do 'SaveVariablesToWizardData'
		wpImportarCompraXLSX(!'Produtos', !'SelecionarArquivo', false, &SessionGuid)
	EndFor

EndSub


