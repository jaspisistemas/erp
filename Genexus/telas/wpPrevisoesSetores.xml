        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPPREVISOESSETORES', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 300

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	for &SdtSetorItem in &SdtSetor
		if (&SdtSetorItem.QtdAbr > 0 or &SdtSetorItem.QtdPrd > 0 ) and &SdtSetorItem.SetPrdMax > 0
			&SetCod = &SdtSetorItem.SetCod
			&SetNom = &SdtSetorItem.SetNom
			&SetPrdMax = &SdtSetorItem.SetPrdMax
			
			//pRODUZINDO
			&DiasProduzindo = 0
			&Produzindo = &SdtSetorItem.QtdPrdMtr
			if &SetPrdMax > 0 and &Produzindo > 0
				&DiasProduzindo = round(&Produzindo / &SetPrdMax,2)
				If &DiasProduzindo <= 0
					&DiasProduzindo = 1
				EndIF
			EndIF	
			&PrevisaoProducao = &SdtSetorItem.DataPrd			
			if &PrevisaoProducao.IsEmpty() or &PrevisaoProducao < &Hoje
				&PrevisaoProducao = &Hoje
			EndIF
			RetornaSomaDiasUteis.Call(&PrevisaoProducao, 0, &PrevisaoProducao)
			
			&DiasFila = 0
			//AGUARDANDO PRODUCAO
			&AguardandoProducao = &SdtSetorItem.QtdAbrMtr
			if &SetPrdMax > 0 and &AguardandoProducao > 0
				&DiasFila = round(&AguardandoProducao / &SetPrdMax,2)
				If &DiasFila <= 0
					&DiasFila = 1
				EndIF
			EndiF
			RetornaSomaDiasUteis.Call(&PrevisaoProducao, &DiasFila, &PrevisaoTotal)
			
			//TOTAL PRODUCAO 
			&ProducaoTotal = &AguardandoProducao + &Produzindo
			&DiasTotal = &DiasProduzindo + &DiasFila
			//&PrevisaoTotal = &PrevisaoProducao + &DiasTotal

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			Load
		EndIF
	EndFor

EndEvent

Event 'DoAttualizar'

	CalculaprevisaoSetores.Call(&Context.EmpCod, &Context.FilCod, &PedDtaPrv, &SdtSetor)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&Hoje = serverdate()
	
	if &PedDtaPrv.IsEmpty()
		&PedDtaPrv = &Hoje
	Endif

	
	LoadWWPContext.Call(&Context)
	
	CalculaprevisaoSetores.Call(&Context.EmpCod, &Context.FilCod, &PedDtaPrv, &SdtSetor)

EndEvent


]]></Source>
