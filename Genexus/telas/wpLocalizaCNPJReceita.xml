      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Mensagem = ''
	TbScaProgressBar.Visible = 0	//## Barra de progresso inivisivel ##\\
	TbPesInsEst.Visible = 0
	
	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	do 'VerificaEmpresaFilial' //## Verifica se a Filial tem os requisitos para fazer a consulta por XML, SEFAZ ##\\
	
	
	&PesCnpj = &ParmPesCnpj
	&PesRaz = &parmPesRaz
	&PesFan = &parmPesFan
	&PesInsEst = &parmPesInsEst
	&PesCep = &parmPesCep
	&PesLog = &parmPesLog
	&PEsCpl = &parmPesCpl
	&PesBai = &parmPesBai
	&PesCidCod = &parmPesCidCod
	&PesNro = &ParmPesNro
	if &PesCidCod <> 0
		do 'cidade'
	Endif

	if not &ParmPesCnpj.IsEmpty()
		&PesCnpj.Enabled = 0
		If &FilAmbEms = '1' and &FilVctCer >= &Today //se tem certificado valido e esta em produção
//			If &PesCnpj.Length() > 14
				&PesCnpj.Caption = 'CNPJ'
				TbMensagem.Class = 'TableCardProgressAdminBaseColor'
				Textmensagem.Caption = 'ATENÇÃO! INFORME O ESTADO PARA CONSEGUIR CONSULTAR A INCRIÇÃO ESTADUAL DO CNPJ!'
//			else
//				&PesCnpj.Caption = 'CPF'
//				TbMensagem.Class = 'TableCardProgressAdminBaseColor'
//				Textmensagem.Caption = 'ATENÇÃO! INFORME O ESTADO PARA CONSEGUIR CONSULTAR O CAD-PRO DO CPF!'
//			EndIf
		Else
//			If &PesCnpj.Length() > 14
				&PesCnpj.Caption = 'CNPJ'
				TbMensagem.Class = 'TableCardProgressAdminBaseColor'
				Textmensagem.Caption = 'ATENÇÃO! ESSA CONSULTA NÃO RETORNA INCRIÇÃO ESTADUAL DO CNPJ POIS ESTÁ SEM CERTIFICADO DIGITAL!'
//			else
//				&PesCnpj.Caption = 'CPF'
//				TbMensagem.Class = 'TableCardProgressAdminBaseColor'
//				Textmensagem.Caption = 'ATENÇÃO! ESTA CONSULTA NÃO FUNCIONA SEM CERTIFICADO DIGITAL!'
//			EndIf
		EndIf			
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TbMensagem.Height = 40

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If &UfeCod <> ''
		&auxUfeCod = &UfeCod
	EndIf

EndEvent

Event 'DoSelecionar'

	&parmPesRaz = Trim(&PesRaz)
	&parmPesFan = trim(&PesFan)
	&parmPesInsEst = Trim(&PesInsEst)
	&parmPesCep = Trim(&PesCep)
	&parmPesLog = trim(&PesLog)
	&parmPesCpl = trim(&PEsCpl)
	&parmPesBai = trim(&PesBai)
	&ParmPesNro = trim(&PesNro)
	
	if &ParmPesCnpj.IsEmpty() 
		&ParmPesCnpj = &PesCnpj
	Endif
	
	return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnPesquisar'

	If &IsError = false
		Do Case
			Case &FilAmbEms = '1' and &FilVctCer >= &Today and not &auxUfeCod.IsEmpty() //## Caso o ambiente for 'Produção' e o certificado não esteja vencido, então ele utiliza XML SEFAZ, senão utiliza do Web Service Convencional ##\\
				prcGeraXMLConsultaContribuite.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &PesCnpj, &auxUfeCod, &SdtConfiguracoesPasta) //## Gera o XML de envio para fazer a consulta ##\\
				
				//			&Mensagem = 'Realizando consulta via Web Service SEFAZ.'						//## Emite a Mensagem ##\\
				TbMensagem.Class = 'TableCardProgressAdminWarning'
				Textmensagem.Caption = 'REALIZANDO CONSULTA VIA WEB SERVICE SEFAZ.'
				
				TbScaProgressBar.Visible = 1													//## Barra de progresso visivel ##\\
				
				&Random = Random() * 10000000000												//## Gera um número aleatório para o ID do Progresso ##\\
				&ProgressId = 'ConsultaCadContribuite' + trim(Str(&Random))						//## Define o ID progresso como 'ConsultaCadContribuite' + Número aleatório
				
				scaProgressBar1.ProcessId = &ProgressId
				scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)			//## Cria o Progresso na tabela ##\\
				scaProgressBar1.Start()															//## Inicia a barra de progresso ##\\
				
				prcProgressoConsultaCadContribuinte.Submit('', &ProgressId, &PesCnpj, &SdtConfiguracoesPasta)
				
				BTNbtnPesquisar.Visible = 0
				
			Otherwise //## Caso a filial não tenha os requisitos mínimos para a consulta por SEFAZ, então utiliza do Web Service convencional ##\\
				if not &PesCnpj.IsEmpty() //## Se o CNPJ não for vazio, atribui os valores e emite a mensagem de Sucesso ##\\
					ValidaCpfCnpj.Call(&PesCnpj, &Numeric, 'N') 
					
					ConsultaRFB.call(&EmpCod, &PesCnpj,&AuxPesRaz,&AuxPesFan,&AuxPesCep,&AuxPesLog,&AuxPesNro,&AuxPesBai,&AuxPesCidUfeCod,&AuxPesCidCod,&AuxPesEml, &AuxPesFonNum,&HttpClient)
					If &httpClient.ErrCode = 0
						Do 'Preencher'
						TbMensagem.Class = 'TableCardProgressAdminSuccess'
						Textmensagem.Caption = 'CONSULTA REALIZADA COM SUCESSO, POR WEBSERVICE!'
					Else
						TbMensagem.Class = 'TableCardProgressAdminDanger'
						Textmensagem.Caption = &httpClient.ErrDescription+ ', POR WEBSERVICE!'
					EndIf
					
				EndiF
		EndCase
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PesCnpj.IsValid

	&IsError = False
	If &PesCnpj.Length() > 14
		&PesCnpj.Caption = 'CNPJ'
	else
		&PesCnpj.Caption = 'CPF'
	EndIf
	
	ValidaCpfCnpj.Call(&PesCnpj,&ErroCpf,'N')
	Do Case
		Case &ErroCpf = 1 and &PesCnpj.Length() <= 14
			&IsError = true
			TbMensagem.Class = 'TableCardProgressAdminDanger'
			Textmensagem.Caption = 'ATENÇÃO! CPF INVÁLIDO.'
		Case &ErroCpf = 1 and &PesCnpj.Length() > 14
			&IsError = true
			TbMensagem.Class = 'TableCardProgressAdminDanger'
			Textmensagem.Caption = 'ATENÇÃO! CNPJ INVÁLIDO.'
	EndCase

EndEvent

Event scaProgressBar1.OnComplete

	TbScaProgressBar.Visible = 0
	
	//## Procura e lê um Xml existente ##\\
	prcLerXMLConsultaContribuinte.Call(&EmpCod,&PesCnpj, &SdtConfiguracoesPasta, &Mensagem, &AuxPesRaz,&AuxPesFan,&AuxPesCep,&AuxPesLog,&AuxPesNro,&AuxPesBai, &AuxPesCidCod, &auxPesCidNom, &IsAchou, &StatusConsulta, &auxPEsCpl, &auxPesInsEst)
	
	If &isAchou = True //## Se achou o XML, Verifica o Status do mesmo ##\\
		do case 
			Case &StatusConsulta = '111' or &StatusConsulta = '112' //## Caso o XML conter o status de 'Sucesso', atribui os valores e emite a mensagem de Sucesso. ##\\
				
				Do 'Preencher'
				
				TbMensagem.Class = 'TableCardProgressAdminSuccess'
				Textmensagem.Caption = trim(&Mensagem) + ' ATRAVÉS DA SEFAZ.' //## Emite a Mensagem ##\\				
				TbPesInsEst.Visible = 1 //## Mostra a IE ##\\
				
			OtherWise //## Caso o XML conter um Status de Rejeição, ele cancela a busca da SEFAZ e faz a busca pelo Web Service convencional ##\\
				TbMensagem.Class = 'TableCardProgressAdminDanger'
				Textmensagem.Caption = trim(&Mensagem) + ' ATRAVÉS DA SEFAZ.'
				
				if not &PesCnpj.IsEmpty() //## Se o CNPJ não for vazio, atribui os valores e emite a mensagem de Sucesso ##\\
					ValidaCpfCnpj.Call(&PesCnpj, &Numeric, 'N') 
					
					ConsultaRFB.call(&EmpCod, &PesCnpj,&AuxPesRaz,&AuxPesFan,&AuxPesCep,&AuxPesLog,&AuxPesNro,&AuxPesBai,&AuxPesCidUfeCod,&AuxPesCidCod,&AuxPesEml, &AuxPesFonNum,&httpClient)
					If &httpClient.ErrCode = 0
						Do 'Preencher'
						TbMensagem.Class = 'TableCardProgressAdminSuccess'
						Textmensagem.Caption = 'CONSULTA REALIZADA COM SUCESSO, POR WEBSERVICE!'
					Else
						TbMensagem.Class = 'TableCardProgressAdminDanger'
						Textmensagem.Caption = &httpClient.ErrDescription+ ', POR WEBSERVICE!'
					EndIf
					
				EndiF
				
				
		EndCase	
		
	Else //## Se ele não achou o XML com as informações, faz então uma busca pelo Web Service convencional e emite a mensagem ##\\
		
		if not &PesCnpj.IsEmpty() //## Se o CNPJ não for vazio, atribui os valores e emite a mensagem de Sucesso ##\\
			ValidaCpfCnpj.Call(&PesCnpj, &Numeric, 'N') 
			
			ConsultaRFB.call(&EmpCod, &PesCnpj,&AuxPesRaz,&AuxPesFan,&AuxPesCep,&AuxPesLog,&AuxPesNro,&AuxPesBai,&AuxPesCidUfeCod,&AuxPesCidCod,&AuxPesEml, &AuxPesFonNum,&httpClient)
			If &httpClient.ErrCode = 0
				Do 'Preencher'
				TbMensagem.Class = 'TableCardProgressAdminSuccess'
				Textmensagem.Caption = 'CONSULTA REALIZADA COM SUCESSO, POR WEBSERVICE!'
			Else
				TbMensagem.Class = 'TableCardProgressAdminDanger'
				Textmensagem.Caption = &httpClient.ErrDescription+ ', POR WEBSERVICE!'
			EndIf
		EndiF		
	EndIf

EndEvent

Sub 'Preencher'

	if not &AuxPesRaz.IsEmpty()
		&PesRaz = &AuxPesRaz
	EndiF
	if not &AuxPesFan.IsEmpty()
		&PesFan = &AuxPesFan
	Else
		&PesFan = &parmPesFan
	EndiF
	if not &AuxPesCep.IsEmpty()
		&PesCep = &AuxPesCep
	EndiF
	if not &AuxPesLog.IsEmpty()
		&PesLog = &AuxPesLog
	EndiF
	if not &AuxPesNro.IsEmpty()
		&PesNro = &AuxPesNro
	EndiF
	if not &AuxPesBai.IsEmpty()
		&PesBai = &AuxPesBai
	EndiF
	if not &auxPEsCpl.IsEmpty()
		&PesCpl = &auxPEsCpl
	EndiF
	if not &auxPesInsEst.IsEmpty()
		&PesInsEst = &auxPesInsEst
	EndiF

	if not &AuxPesCidCod.IsEmpty()
		&PesCidCod = &AuxPesCidCod
		if &PesCidCod <> 0
			do 'Cidade'
		EndIf
	EndiF
	
	if &PesEml.IsEmpty()
		&PesEml = &AuxPesEml
	EndIF
	if &PesFonNum.IsEmpty()
		&PesFonNum = &AuxPesFonNum
	EndIF

EndSub

Sub 'VerificaEmpresaFilial'

	For Each Order EmpCod, FilCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &wwpContext.FilCod
		
		&FilAmbEms = FilAmbEms 
		&FilVctCer = FilVctCer
		
		Exit
	EndFor

EndSub

Sub 'Cidade'

	For each Order EmpCod,CidCod
		Where EmpCod = &EmpCod
		Where CidCod = &PesCidCod
		&PesCidNom = CidNom
		&PesCidUfeCod = UfeCod
		&PesCidPaiNom = PaiNom
		&parmCidCodNomUfe = CidCodNomUfe
		Exit
	EndFor

EndSub


