t;Dados&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;Collapsible&lt;/Name&gt;&lt;Value&gt;True&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;Collapsed&lt;/Name&gt;&lt;Value&gt;False&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ShowCollapseIcon&lt;/Name&gt;&lt;Value&gt;False&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;IconPosition&lt;/Name&gt;&lt;Value&gt;Right&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;AutoScroll&lt;/Name&gt;&lt;Value&gt;False&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><table controlName="UnnamedTable3" class="" tableType="Responsive" responsiveSizes="[]" containerSlotName="UnnamedTable3"><row><cell><table controlName="TableMergedTbPesRaz" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><table controlName="TbPesRaz" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PesRaz" labelCaption="Razão Social" readonly="True" class="Attribute10_Bold" /></cell></row></table></cell><cell><table controlName="TbPesFan" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PesFan" labelCaption="Nome Fantasia" readonly="True" class="Attribute10_Bold" /></cell></row></table></cell></row></table></cell></row><row><cell><table controlName="TableMergedTbPesCep" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><table controlName="TbPesCep" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PesCep" labelCaption="CEP" readonly="True" class="Attribute10_Bold" /></cell></row></table></cell><cell><table controlName="TbPesLog" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PesLog" labelCaption="Logradouro" readonly="True" class="Attribute10_Bold" /></cell></row></table></cell><cell><table controlName="TbPesNro" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PesNro" labelCaption="Número" readonly="True" class="Attribute10_Bold" /></cell></row></table></cell><cell><table controlName="TbPesBai" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PesBai" labelCaption="Bairro" readonly="True" class="Attribute10_Bold" /></cell></row></table></cell><cell><table controlName="tbPesCpl" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PEsCpl" labelCaption="Complemento" readonly="True" class="Attribute10_Bold" /></cell></row></table></cell></row></table></cell></row><row><cell><table controlName="TableMergedTbPesCidNom" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&