        <Source><![CDATA[<GxMultiForm rootId="1" version="html:15.0.0;layout:17.11.0"><Form id="1" type="layout"><detail><layout><table controlName="LayoutMainTable" tableType="Responsive" responsiveSizes="[]"><row><cell><table controlName="TableMain" class="TableMain"><row><cell><errorviewer controlName="ErrorViewer" class="ErrorViewer" /></cell></row><row><cell><tab controlName="GXUITabsPanel_ttasd" class=""><item itemControlName="ConsultaPublica" caption="Consulta de Dados"><table controlName="UnnamedTable1" class="" tableType="Responsive" responsiveSizes="[]"><row><cell><table controlName="UnnamedTable2" class=""><row><cell><table controlName="TableMergedUnnamedTable4" class="TableMerged" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;cellPadding&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;cellSpacing&lt;/Name&gt;&lt;Value&gt;0&lt;/Value&gt;&lt;/Property&gt;&lt;/Properties&gt;"><row><cell cellClass="MergeDataCell"><table controlName="UnnamedTable4" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;PesCnpj" labelCaption="CNPJ" class="AttributeRealWidth" /></cell></row></table></cell><cell><table controlName="UnnamedTable5" class="" tableType="Responsive" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;label&quot;:100}]]}]"><row><cell cellClass="DscTop"><data attribute="&amp;auxUfeCod" labelCaption="UF " class="AttributeRealWidth" PATTERN_ELEMENT_CUSTOM_PROPERTIES="&lt;Properties&gt;&lt;Property&gt;&lt;Name&gt;ControlType&lt;/Name&gt;&lt;Value&gt;Dynamic Combo Box&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ControlItemValues&lt;/Name&gt;&lt;Value&gt;UfeCod&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt;Name&gt;ControlItemDescription&lt;/Name&gt;&lt;Value&gt;UfeCod&lt;/Value&gt;&lt;/Property&gt;&lt;Property&gt;&lt