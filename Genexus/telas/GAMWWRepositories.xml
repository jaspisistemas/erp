      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WWPContext)
	if &WWPContext.Old_Perfil <> 3
		Dashboard.Link()
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows

	If &HTTPRequest.Method = HttpMethod.Get
		Do 'LoadSavedFilters'
	EndIf
	Form.Caption = 'WWP_GAM_Repositories'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	TextBlockTitle.Caption = Form.Caption

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do Case
		Case &ManageFiltersExecutionStep = 1
			&ManageFiltersExecutionStep = 2
		Case &ManageFiltersExecutionStep = 2
			&ManageFiltersExecutionStep = 0
			Do 'LoadSavedFilters'
	EndCase
	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	//&GridPageCount has to be loaded manually

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&GridPageSize = Grid.Rows
  	If not &Search.IsEmpty()
		&Filter.Name = !"%" + &Search
	Endif
	&RepositoryCollection = &GAM.GetAllRepositories(&Filter, &Errors)
	If &RepositoryCollection.Count = 0
		&GridPageCount = 0
	Else
		&GridPageCount = (&RepositoryCollection.Count/&GridPageSize) + iif(Mod(&RepositoryCollection.Count, &GridPageSize) > 0, 1, 0)
	EndIf
	&GridRecordCount = &RepositoryCollection.Count
	If &Errors.Count > 0
		Do 'DisplayErrors'
	Else
		For &Repository in &RepositoryCollection
			&Id	  = &Repository.Id
			&Name = &Repository.Name

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the data
	
	//Sample conditions to be added manually:
	//Where <Attribute> like &Search when not &Search.IsEmpty()
	
	&Display = !'<i class="fa fa-search"></i>'
	&Display.Link = GAMRepositoryConfiguration.Link(&Id)
	&Update = !'<i class="fa fa-pen"></i>'
	&Update.Link = GAMRepositoryConfiguration.Link(&Id)
	&Delete = !'<i class="fa fa-times"></i>'
	&Delete.Link = GAMRepositoryEntry.Link(GAMAPiMode.Delete, &Id)
	&Id.Link = GAMRepositoryConfiguration.Link(&Id)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

			Grid.Load()
		EndFor
	EndIf

EndEvent

Event ddo_ManageFilters.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case ddo_ManageFilters.ActiveEventKey = !'<#Clean#>'
			Do 'CleanFilters'
			Grid.FirstPage()
		Case ddo_ManageFilters.ActiveEventKey = !'<#Save#>'
			Do 'SaveGridState'
			SaveFilterAs.Popup(!'GAMWWRepositoriesFilters', &PgmName + !"GridState")
			&ManageFiltersExecutionStep = 2
			Refresh
		Case ddo_ManageFilters.ActiveEventKey = !'<#Manage#>'
			ManageFilters.Popup(!'GAMWWRepositoriesFilters')
			&ManageFiltersExecutionStep = 2
			Refresh
		Otherwise
			&ManageFiltersXml = GetFilterByName(!'GAMWWRepositoriesFilters', ddo_ManageFilters.ActiveEventKey)
			If &ManageFiltersXml.IsEmpty()
				msg('WWP_FilterNotExist')
			Else
				Do 'CleanFilters'
				SaveGridState.Call(&PgmName + !"GridState",  &ManageFiltersXml)
				&GridState.FromXml(&ManageFiltersXml)
				Do 'LoadRegFiltersState'
				Grid.FirstPage()
			EndIf
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GAMRepositoryEntry.Call(GAMAPiMode.Insert, 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadSavedFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ManageFiltersData = WWP_ManageFiltersLoadSavedFilters(!'GAMWWRepositoriesFilters', '', '', False)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CleanFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Search.SetEmpty()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	
	Do 'LoadRegFiltersState'
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadRegFiltersState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"SEARCH"
				&Search.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"SEARCH", "", not &Search.IsEmpty(), 0, &Search, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'DisplayErrors'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


]]></Source>
