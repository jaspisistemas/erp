      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&IsOk = false
	
	HostWebServiceJaspiADM.Call(0, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	
	&Location = GetLocation('ppJASPI_Empresa') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost //servidor 
	&Location.Port = &EmpWebPor //porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	&Location.Secure = false //false 
	&Location.CancelOnError = 2 //tratar exceção do WS 	
	
	&ppJASPI_EmpresasdtEmpresa = &ppJASPI_Empresa.Execute(&EmpCodSec, false)
	
	If GetSOAPErr()= 0 
		If &ppJASPI_EmpresasdtEmpresa.StsErro = 1
			&IsOk = true
			&EmpRaz = &ppJASPI_EmpresasdtEmpresa.CliRaz
			&FilCpj = &ppJASPI_EmpresasdtEmpresa.CliCnpj
		Else
			NovaEmpresa(!'NovoUsuario', !'CodigoAcesso', true)
		EndIF
	Else 
		&Msg = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&Msg += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&Msg) 
	EndIf

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult AND not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		Do 'FinishWizard'
		&WebSession.Remove(&WebSessionKey)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&IsFiscal = &WizardData.NovoUsuario.IsFiscal
	&FilVctCer = &WizardData.NovoUsuario.FilVctCer
	&FilCtaEml = &WizardData.NovoUsuario.FilCtaEml
	&FilIdQrCode = &WizardData.NovoUsuario.FilIdQrCode
	&FilSenQrCode = &WizardData.NovoUsuario.FilSenQrCode
	&PesEml = &WizardData.NovoUsuario.PesEml
	&UsuarioAcesso = &WizardData.NovoUsuario.UsuarioAcesso
	&GAMPasswordDB = &WizardData.NovoUsuario.GAMPasswordDB
	&ConfirmaPass = &WizardData.NovoUsuario.ConfirmaPass
	&EmpCodSec = &WizardData.NovoUsuario.EmpCodSec
	&EmpRaz = &WizardData.NovoUsuario.EmpRaz
	&FilCpj = &WizardData.NovoUsuario.FilCpj
	&PesRaz = &WizardData.NovoUsuario.PesRaz
	&PesCpf = &WizardData.NovoUsuario.PesCpf
	&PesFonNum = &WizardData.NovoUsuario.PesFonNum

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCodSec = &WizardData.CodigoAcesso.EmpCodSec
	&EmpRaz = &WizardData.CodigoAcesso.EmpRaz
	&FilCpj = &WizardData.CodigoAcesso.FilCpj

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.NovoUsuario.IsFiscal = &IsFiscal
	&WizardData.NovoUsuario.FilVctCer = &FilVctCer
	&WizardData.NovoUsuario.FilCtaEml = &FilCtaEml
	&WizardData.NovoUsuario.FilIdQrCode = &FilIdQrCode
	&WizardData.NovoUsuario.FilSenQrCode = &FilSenQrCode
	&WizardData.NovoUsuario.PesEml = &PesEml
	&WizardData.NovoUsuario.UsuarioAcesso = &UsuarioAcesso
	&WizardData.NovoUsuario.GAMPasswordDB = &GAMPasswordDB
	&WizardData.NovoUsuario.ConfirmaPass = &ConfirmaPass
	&WizardData.NovoUsuario.EmpCodSec = &EmpCodSec
	&WizardData.NovoUsuario.EmpRaz = &EmpRaz
	&WizardData.NovoUsuario.FilCpj = &FilCpj
	&WizardData.NovoUsuario.PesRaz = &PesRaz
	&WizardData.NovoUsuario.PesCpf = &PesCpf
	&WizardData.NovoUsuario.PesFonNum = &PesFonNum
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'FinishWizard'

	HostWebServiceJaspiADM.Call(0, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	&Location = GetLocation('ppJASPI_Empresa') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost //servidor 
	&Location.Port = &EmpWebPor //porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	&Location.Secure = false //false 
	&Location.CancelOnError = 2 //tratar exceção do WS 	
	
	&ppJASPI_EmpresasdtEmpresa = &ppJASPI_Empresa.Execute(&EmpCodSec, false)
	
	If GetSOAPErr()= 0 
		If &ppJASPI_EmpresasdtEmpresa.StsErro <> 1
			NovaEmpresa(!'NovoUsuario', !'CodigoAcesso', true)
		EndIF
	Else 
		&Msg = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&Msg += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&Msg) 
	EndIf	
		
	//CRIA USUARIO GAM ##########	
	&User.AuthenticationTypeName = !"local"
	&Repository		=  GAMRepository.Get()
	&User.NameSpace	= &Repository.NameSpace
	
	&User.SecurityPolicyId = 1
	
	&User.Password = &GAMPasswordDB
	&User.FirstName = &PesRaz
	&User.Name = &UsuarioAcesso
	&User.EMail = &PesEml
	
	&User.IsBlocked = false
	&User.IsActive = true
	&User.CannotChangePassword = true
	&User.MustChangePassword = false
	
	&PasswordIsOK = true
	If &GAMPasswordDB <> &ConfirmaPass
		&PasswordIsOK = False
		Msg("A Senha e a Confirmação da Senha não Conferem.")
	Endif
	
	If &PasswordIsOK = true
		&PesExtCod = geraPesExtCod.Udp()
		
		&User.ExternalId = trim(str(&PesExtCod))
		
		&User.Password = &GAMPasswordDB
		&User.Save()

		If &User.Success()
			HostWebServiceJaspiADM.Call(0, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
			&Location = GetLocation('ppJASPI_Empresa') //objeto externo onde foi importado o WSDL no GX XEV1 
			&Location.Host = &EmpWebHost //servidor 
			&Location.Port = &EmpWebPor //porta  
			&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
			&Location.Secure = false //false 
			&Location.CancelOnError = 2 //tratar exceção do WS 	
			
			&ppJASPI_EmpresasdtEmpresa = &ppJASPI_Empresa.Execute(&EmpCodSec, true)
			
			If GetSOAPErr()= 0 
				verificaIsExisteEmpresa.Call(&ppJASPI_EmpresasdtEmpresa.CliEmpCod, &isExisteEmpresa)
				If &ppJASPI_EmpresasdtEmpresa.StsErro = 1 
					if &isExisteEmpresa = false
						Commit
						
						prcNovaEmpresa.Call(&PesExtCod, &ppJASPI_EmpresasdtEmpresa, &WizardData)
						CompletandoCadastro.Link(&ppJASPI_EmpresasdtEmpresa.CliEmpCod, &EmpCodSec)
					Else
						msg('Atenção!, Código Empresa já Cadastrado, contate o suporte JASPI!')	
					EndIF
				Else
					msg(&ppJASPI_EmpresasdtEmpresa.StsMensagem)
				EndIF
			Else 
				&Msg = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
				&Msg += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
				Msg(&Msg) 
			EndIf
		Else
			&Errors = &User.GetErrors()
			For &Error in &Errors
				Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
			EndFor
		EndIF		
	Endif
	//CRIA USUARIO GAM ##########

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PesRaz.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nome'), DVMessageType.error, &PesRaz.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PesCpf.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','CPF'), DVMessageType.error, &PesCpf.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &PesEml.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','E-mail'), DVMessageType.error, &PesEml.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &UsuarioAcesso.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Usuário'), DVMessageType.error, &UsuarioAcesso.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &GAMPasswordDB.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Senha'), DVMessageType.error, &GAMPasswordDB.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &ConfirmaPass.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Confirma Senha'), DVMessageType.error, &ConfirmaPass.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableFiscal.Visible = (&IsFiscal = Status_SimNao.Sim)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &IsFiscal.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event &PesCpf.IsValid

	validaCpfCnpj.Call(&PesCpf, &Erro, 'N')

EndEvent

Event &PesFonNum.IsValid

	FormataFonE.Call(&PesFonNum, &PesFonNum)

EndEvent


]]></Source>
