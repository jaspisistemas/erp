      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod

	padraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&OqueListar = Substr(&PadObs, 1, 1)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&OqueListar = 'B')
		&Ordem.Visible = False
		Ordem_Cell.Class = !'Invisible'
	Else
		&Ordem.Visible = True
		Ordem_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &OqueListar.IsValid

	Do 'AttributesSecurityCode'

EndEvent

Event Enter

	&PadObs = &OqueListar
	padraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		
	Do Case
		Case &OqueListar = 'A' //Historico Cliente
			RCOOpenWindow1.LinkOpen = RELJAS050.Link(&EmpCod, &FilCod,&PedCliCod)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueListar = 'B' //Produtos Cliente
			RCOOpenWindow1.LinkOpen = RELJAS033.Link(&EmpCod, &FilCod, &PedCliCod, &PedDtaFat, serverdate(), 'S', &Ordem)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		Case &OqueListar = 'C' //Cadastro Cliente
			RCOOpenWindow1.LinkOpen = RELJAS005.Link(&EmpCod, &PedCliCod)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCAse

EndEvent


]]></Source>
