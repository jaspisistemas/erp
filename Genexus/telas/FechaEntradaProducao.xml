Event Start

	LoadWWPContext.Call(&Context)
	&AutNiv = RetornaAutorizacao.UDP('FECHARENTRADAPRODUCAO', Status_SimNao.Nao, 1)
	if &AutNiv < 1
		Return
	EndIF

	do 'LoadCapa'
	
//	RetornaEmpresaModulo.Call(&Context.EmpCod, ModuloSistema.CREAMVILLE, &CREAMVILLE)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order EmpCod, FilCod, PrdCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PrdCod = &PrdCod
		&PrdEntPedCod = PrdEntPedCod
		exit
	EndFor

	
	&Varchar = ServerTime()
	&NomeArquivo = 'PedidoCompra' + trim(str(&PrdEntPedCod))
	RCOOpenWindow1.LinkOpen = RELJAS016.Link(&Context.EmpCod, &Context.FilCod, &PrdEntPedCod, &PrdCod, &Context.PesCod, &NomeArquivo, &Ordem, &Varchar)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	
	return

EndEvent

Event Enter

	do 'ValidaOperacao'
	do case
		case not &Mensagem.IsEmpty()
			msg(&Mensagem)
			
		Otherwise
			btnEnter.Visible = 0
			
			
			&ProgressId = 'FECHEENTRADAPRODUCAO' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
			&ProgressId = &ProgressId.trim()
			scaProgressBar1.ProcessId = &ProgressId
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
			scaProgressBar1.Start()			
			
			prcFechaEntradaproducao.Submit('FECHEENTRADAPRODUCAO',&ProgressId,&EmpCod, &FilCod, &PrdCod, &Context.PesCod, &PrdEntPedCod)
					

			PadraoUsuario.Call('L', 'wpImprimirEntrada', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
			If not &PadObs.IsEmpty()
				&Ordem = Substr(&PadObs, 6, 1)
			Else
				&Ordem = 'A'
			EndIF
						
			do 'AddSdt'	
	EndCase

EndEvent

Sub 'AddSdt'

	&CodigoUsuario = trim(str(&Context.EmpCod)) + trim(str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &Context.EmpCod
		Where FilCod = &Context.FilCod
		Where PedCod = &PrdEntPedCod
		
		&sdtEtiquetaLoteItem = new()
		&sdtEtiquetaLoteItem.ProRef = ProRef
		&sdtEtiquetaLoteItem.ProNom = ProNom
		&sdtEtiquetaLoteItem.PedDtaFat = PedDtaFat
		&sdtEtiquetaLoteItem.Lote = trim(str(&PrdCod))
		&sdtEtiquetaLoteItem.Quantidade = PedQtd
		
		&sdtEtiquetaLote.Add(&sdtEtiquetaLoteItem)
		
	EndFor
	&PadObs = &sdtEtiquetaLote.ToJson()
	padraoUsuario.Call('G', &CodigoUsuario, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)

EndSub

Sub 'LoadCapa'

	For Each Order EmpCod, FilCod, PrdCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod 
		Where PrdCod =&PrdCod
		&FilCodNom = FilCodNom
		&PrdDtaEnt = PrdDtaEnt
		Exit
	ENdFor
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon035_TipoLancamentoEntradaProducao, &CfgVlr)
	&LctCod = val(&CfgVlr)
	
	do 'ValidaOperacao'

EndSub

Sub 'ValidaOperacao'

	//Tem que dar Saida na Producao e Entrada do Estoque
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &LctCod
		
//		If LctAtuPro <> Status_EntradaSaida.Saida
//			&Mensagem = 'Parâmetro da Operação Entrada da Produção Inválido! É preciso informar uma Operação que Atualize o Estoque SAÍDA da Produção! [CONF272]'
//			Exit
//		EndiF
		
		If LctAtuEst <> Status_EntradaSaida.Entrada
			&Mensagem = 'Parâmetro da Operação Entrada da Produção Inválido! É preciso informar uma Operação que Atualize o Estoque ENTRADA da Empresa!'
			Exit
		EndIF
		
		Exit
	When none
		&Mensagem = 'Parâmetro da Operação Entrada da Produção não Configurado!'
	EndFor

EndSub


