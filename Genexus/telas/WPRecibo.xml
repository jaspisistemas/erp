      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWSALDO', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	Do 'Recibo'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&sdtReciboItem.EmpCod = &EmpCod
	&sdtReciboitem.RcbMovCod = &MovCod
	&sdtRecibo.Add(&sdtReciboItem)
	&WebSession.Set('ReciboImp',&sdtRecibo.ToXml())
	&ServerTime = ServerTime()
	&Window.Url =  RELJAS020.Link(&ServerTime,'MOVIMENTO') 
	&Window.Width= 800
	&Window.Height = 800
	&Window.Open()

EndEvent

Sub 'Recibo'

	For each Order EmpCod,RcbMovCod
		Where EmpCod = &EmpCod
		Where RcbMovCod = &MovCod
		&RcbTip    = RcbTip
		&RcbFilCod = RcbFilCod
		&RcbDstCod = RcbDstCod
		&RcbDstNom = RcbDstNom
		&RcbDoc    = RcbDoc
		&RcbDta    = RcbDta
		&RcbVlr    = RcbVlr
		
	EndFor

EndSub


]]></Source>
