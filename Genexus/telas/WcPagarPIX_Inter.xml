      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWpContext.Call(&wwpContext)	
	&txid	= &PIXResponse.txid.Trim()
	&SegundosMaximo	= &PIXResponse.calendario.expiracao
	&pixCopiaCola	= &PIXResponse.pixCopiaECola
	&valorOriginal	= &PIXResponse.valor.original
	&solicitacaoPagador	= &PIXResponse.solicitacaoPagador	
	
	Chronometer.TickInterval	= 1
	&SegundosAtual				= 0
	&ProgressoNumeric			= 0
	&IsPago						= False
	&IsEnviarWhats				= False
	TableWhats.Visible			= IIf(&IsEnviarWhats = True, 1, 0)
	
	&TipoCodigoBarras 			= TipoCodigoBarras.QRCODE
	RetornaConfiguracoesPastas.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtConfiguracoesPasta)
	&Arquivo = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras)  + &txid + '.png'
	
	&File.Source = &Arquivo
	If not &File.Exists()	
		ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, &txid.Trim(), &pixCopiaCola)
	EndIF
	 
	If &File.Exists()
		&LongVarChar	= &sdtConfiguracoesPasta.PastaDiretorioTempVir + trim(&TipoCodigoBarras)  + &txid.Trim() + '.png'
		&ImageQr.FromURL(&LongVarChar.Trim()) //LoadBitmap(&Arquivo.Trim())
		Chronometer.Start()
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirQR'

	&ArquivoVarChar			= 'Impressao_QrCode' + &txid.Trim()
	RCOOpenWindow.LinkOpen 	= RELJAS166.Link(&ArquivoVarChar, &wwpContext.EmpCod, &wwpContext.FilCod, &valorOriginal, &solicitacaoPagador, &LongVarChar)
	RCOOpenWindow.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelarOperacao'

 2
	
	&SegundosAtual	= &SegundosMaximo - 1
	&IsPago			= False

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEnviarPixWhats'

	Do Case 
		Case &Telefone.IsEmpty()
			&Telefone.SetFocus()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Informe um número para o envio do Copia e Cola.' ,DVMessageType.regular, "", DVMessageBoolean.True,""))
			
		OtherWise
			&Moeda	= Val(&valorOriginal)
			prcFilaEnvioWhats_EnviaCopiaCola.Call(&wwpContext.EmpCod, &wwpContext.FilCod, 0, &pixCopiaCola.Trim(), &Moeda, &Telefone, '')
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Pix enviado!", 'O pix Copia e Cola foi enviado para o número: ' + &Telefone.Trim() ,DVMessageType.information, "", DVMessageBoolean.True,""))
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Telefone.IsValid

	&Telefone	= FormataFONE.Udp(&Telefone)

EndEvent

Event &IsEnviarWhats.ControlValueChanged

	TableWhats.Visible	= IIf(&IsEnviarWhats = True, 1, 0)

EndEvent

Event Chronometer.Tick

	If &SegundosAtual < &SegundosMaximo And &IsPago	= False
		&Buscar			   += 1
		&SegundosAtual 	   += 1
		&ProgressoNumeric	= (&SegundosAtual*100)/&SegundosMaximo
		
		&AuxNumeric			= &SegundosMaximo - &SegundosAtual
		
		prcAtualizaProgressIndicator.Call(&ProgressoNumeric, &AuxNumeric)
		If &Buscar	= 5
			&Buscar = 0					
			prcRetornoRecebimentoADMERP_PixPago.Call(&txid, &IsPago)
			If &IsPago	= True
				&SegundosAtual	= &SegundosMaximo - 1
			EndIf
		EndIf
	Else			
		TableButtons.Visible	= 0
		Chronometer.Stop()
		
		If &IsPago = False
			&ImageQr.FromImage(PixErro)
			WWpActions.WCPopup_Close('')
		Else			
			&ProgressoNumeric	= 100
			&AuxNumeric			= 0
			prcAtualizaProgressIndicator.Call(&ProgressoNumeric, &AuxNumeric)
			TextTitulo.Caption	= 'Pagamento realizado e confirmado com <br>sucesso!'
			&ImageQr.FromImage(GifPixPago)
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'O pagamento foi realizado com sucesso!' ,DVMessageType.success, "", DVMessageBoolean.True,""))
			WWpActions.WCPopup_Close('P')
		EndIf
	EndIf

EndEvent


]]></Source>
