      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Aviso.Caption = 'Atenção exite um MDF-e com a mesma placa de veículo ('+Trim(&MDFeVeiPla)+') ainda não encerrado.'
	Aviso.ForeColor = RGB(255,0,0)
	
	LoadWWPContext.Call(&Context)
	&oldMDFeDtaEnc = serverdate()
	&oldMDFeHorEnc = serverTime()
	do 'SetUfCidade'
	do 'SetUfCidadeNovo'
	txtObs.ForeColor = RGB(210,130,0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))

EndEvent

Event 'DoAutorizar'

	GeraXmlMdfe.Call(&EmpCod, &FilCod, &MDFeCod, &Context.PesCod, &SolCod)
	&WizardData.Mdfe.EmpCod = &EmpCod
	&WizardData.Mdfe.FilCod = &FilCod
	&WizardData.Mdfe.MdfeCod = &MdfeCod
	&WizardData.Mdfe.SolCod = &SolCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())
	WPMDFe01(!'Modal', !'Transmitir', false)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	FormataHora.Call(&oldMDFeHorEnc, &oldMDFeHorEnc)
	
	&IsErroCidade = false
	For Each Order EmpCod, CidCod
		Where EmpCod = &EmpCod
		Where CidCod = &oldCidCod
		If CidIBGE.IsEmpty() or CidIBGE.IsNull()
			msg('Cidade informada não possui codigo de IBGE cadastrado!')
			&IsErroCidade = true
		EndIF
		Exit
	When none
		&IsErroCidade = true
		msg('Cidade não Localizada')
	EndFor
	
	If &IsErroCidade = false
		GeraEncerramentoMDFe.Call(&EmpCod, &oldFilCod, &oldMDfeCod, &oldMDFeDtaEnc,&oldMDFeHorEnc ,&oldCidCod, &Context.PesCod, &SolCod)
		wpencerraMDfe.Link(&EmpCod, &oldFilCod, &oldMDfeCod, &SolCod)
	EndIF
	
	GeraXmlMdfe.Call(&EmpCod, &FilCod, &MDFeCod, &Context.PesCod, &SolCod)
	&WizardData.Mdfe.EmpCod = &EmpCod
	&WizardData.Mdfe.FilCod = &FilCod
	&WizardData.Mdfe.MdfeCod = &MdfeCod
	&WizardData.Mdfe.SolCod = &SolCod
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())
	WPMDFe01(!'Modal', !'Transmitir', false)

EndEvent

Event &oldMDFeHorEnc.IsValid

	FormataHora.Call(&oldMDFeHorEnc, &oldMDFeHorEnc)

EndEvent

Sub 'SetUfCidade'

	For Each Order EmpCod, FilCod,MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &oldFilCod
		Where MDFeCod = &oldMDfeCod

		&oldCidCod = MDFeDesCidCod
		exit
	EndFor

EndSub

Sub 'SetUfCidadeNovo'

	For Each Order EmpCod, FilCod,MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDfeCod
		&MDFeDtaEms = MDFeDtaEms
		&UfeCod = MDFeOriUfeCod
		&CidCod = MDFeCarCidCod
		exit
	EndFor

EndSub


]]></Source>
