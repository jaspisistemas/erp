      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	padraoUsuario.Call('L', 'WWPRODUTORECEITAEX', &Context.PesCod, &Context.EmpCod, &ProRef, &PadDtaMod)
	if not &ProRef.IsEmpty()
		RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &RecProCod, &ProGraCod, &ProNom, &IsAchou, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)
	Endif
	
	retornaAutorizacao.Call('WWTABELAPRECO', Status_SimNao.Nao, 2, &TabelaPrecoAutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&RecProCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PrecosProduto.Title = 'Add R$'
	&ProdutosAfetados.Title = 'Afetados'

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	ProRef.ColumnHeaderClass = !'WWColumn'
	ProTipCus.ColumnHeaderClass = !'WWColumn hidden-xs'
	ProTipDef.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = grid.PageCount

EndEvent

Event Grid.Load

	&Alterar.Link = wpProdutoReceita.Link('WWPRODUTORECEITAEX', EmpCod, ProCod)
	RetornaProdutosAfetadosCusto.call(EmpCod, ProCod, 1, &IsProdutosAfetados)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Alterar = !'<i class="fas fa-pen"></i>'
	
	&ProdutosAfetados = !'<i class="fas fa-cubes"></i>'
	If (&TabelaPrecoAutNiv > 0 and &IsProdutosAfetados = true)
		&ProdutosAfetados.Class = !'Attribute'
	Else
		&ProdutosAfetados.Class = !'Invisible'
	Endif
	&PrecosProduto = !'<i class="fa fa-plus"></i>'
	If (&TabelaPrecoAutNiv > 0)
		&PrecosProduto.Class = !'Attribute'
	Else
		&PrecosProduto.Class = !'Invisible'
	Endif
	&ImprimirReceita = !'<i class="far fa-file-pdf"></i>'

	ProRef.ColumnClass = iif(ProSts = Status_Produto.Inativo, !'WWColumn WWColumnDanger WWColumnDangerSingleCell', !'WWColumn')
	ProTipCus.ColumnClass = iif(ProTipCus = TipoCusto.Receita, !'WWColumn hidden-xs WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell', !'WWColumn hidden-xs')
	Do Case
		Case ProTipDef = Definicao.FABRICADO
			ProTipDef.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case ProTipDef = Definicao.SEMIACABADO
			ProTipDef.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case ProTipDef = Definicao.SUBPRODUTO
			ProTipDef.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Otherwise
			ProTipDef.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	ProNom.Link = VerProduto.Link('WWPRODUTORECEITAEX', EmpCod, ProCod)
	
	//ESTA DANDO ERRO UND MEDIDA< GENEXUS ESTA CONFUNDINDO COM RecProEmbUn -JDF
	RetornaProdutoEmbalagem.Call(EmpCod, ProCod, &ProEmbCod, &ProEmbNom, &ProEmbUnd, &ProEmbQtd)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFiltrar'

		RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &RecProCod, &ProGraCod, &ProNom, &IsAchou, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)
	
	&ProRef.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	do 'LocalizaReceita'

EndEvent

Event &ImprimirReceita.Click

	imprimeReceita.Popup(ProCod)

EndEvent

Event &ProdutosAfetados.Click

	wpProdutosAfetadosAumentoCusto.Popup(EmpCod, 0, 0, 0, ProCod, 1)

EndEvent

Event &PrecosProduto.Click

	wpProdutosPrecosNovo.Popup(EmpCod, &Context.FilCod, 0, 0, ProCod, ProVlrCusRec)

EndEvent

Sub 'LocalizaReceita'

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &RecProCod, &ProGraCod, &ProNom, &IsAchou, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)
	padraoUsuario.Call('G', 'WWPRODUTORECEITAEX', &Context.PesCod, &Context.EmpCod, &ProRef, &PadDtaMod)
	
	Refresh
	&ProRef.SetFocus()

EndSub


]]></Source>
