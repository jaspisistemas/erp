        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Width = 400
	TableMain.Height = 100

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Data = ServerDate()
	Do 'loadConfig'

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &Data.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Data:'), DVMessageType.error, &Data.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Show Messages'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: ShowMessages
	For &Message in &Messages
		msg(&Message.Description)
	endfor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = True
		if &Data >= ServerDate()
			return
		else
			msg('Atenção! Não é permitido utilizar datas passadas.')
		EndIf
	else
		Do 'Show Messages'
	EndIf

EndEvent

Sub 'loadConfig'

	Do case
		case &Config = 'A' //Inserir SerItmDtaFim - ServicoCliente
			TextBlockTitle.Caption = 'Inserir Data Final'
			&Data.Caption = 'Data Final:'
			&Data.Enabled = true
			
		case &Config = 'B'
			msg('Parametro de configuração incorreto. Contate o suporte JASPI!')
			
	EndCase

EndSub


]]></Source>
