      <Part type="9b0a32a3-de6d-4be1-a4dd-1b85d3741534">
        <Source><![CDATA[parm(in:&EmpCod, in:&CtaBanCod);
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
      </Part>
      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbDadosNovoCaixa.Visible = 0
	loadWWPContext.Call(&Context)
	&CtaFecSts = FechaAbre.FecharNOVO
	PadraoUsuario.Call('L', '#PADRAORESUMOCAIXA#', &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
	if not &padObs.IsEmpty()
		&Impressao = &padObs
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&UltFecCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'getsaldo'
	
	padraoUsuarioHora.Call('L', 'WPFECHACAIXAPDV', &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod, &PadDtaHorMod, 'P')
	&CtabanCodCofre = val(&padObs)
	
	For Each Order EmpCod, CtabanCod, (FecCod)
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		Where FecSts = FechaAbre.FecharNOVO
		&RetFecCod = FecCod
		&FecHor    = FecHor
		&CtaFecSts = FecSts
		Exit
	EndFor

	For Each Order EmpCod, CtabanCod, (FecCod)
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		Where FecCod > &RetFecCod
				
		&UltCtaFecSts = FecSts
		&UltFecHor = FecHor
		&UltFecCod = FecCod
		Exit
	EndFor
	
	&IsTemAlgumLancamento = false
	For Each Order EmpCod, MovCtaBanCod
		Where EmpCod = &EmpCod
		Where MovCtaBanCod = &CtaBanCod
		Where MovFecCod = 0 or MovFecCod.IsNull()
		&IsTemAlgumLancamento = true
	EndFor

	&FecSts = 'S' //FechaAbre.FecharNOVO
	&auxFecHor = serverNow()
	
	tbDadosNovoCaixa.Visible = &FecSts = 'S' and &CtabanCodCofre.Count > 0 //FEchaAbre.FECHARNOVO

EndEvent

Event &FecSts.IsValid

	tbDadosNovoCaixa.Visible = &FecSts = 'S' and &CtabanCodCofre.Count > 0//FEchaAbre.FECHARNOVO

EndEvent

Event Enter

	&auxFecHor = serverNow()
	&AuxFecSts.FromString(&FecSts)
	
	Do Case
		case &IsTemAlgumLancamento <> true and &AuxFecSts = FEchaAbre.FecharNOVO
			msg('Caixa já FECHADO!, Não há lançamentos efetuados depois do Último Fechamento!')
			
		case &UltCtaFecSts = &AuxFecSts and &AuxFecSts = FEchaAbre.AbERTURA
			msg('Caixa já esta aberto!, não é possível ABRIR Fechamentos Anteriores ao Último Fechamento!')
			
		CAse &AuxFecSts = FechaAbre.FecharNOVO
			btnEnter.Enabled = 0
			&padObs = &Impressao
			PadraoUsuario.Call('G', '#PADRAORESUMOCAIXA#', &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
			
			padraoUsuarioHora.Call('G', 'WPFECHACAIXAPDV', &Context.PesCod, &Context.EmpCod, trim(str(&CtabanCodCofre)), &PadDtaMod, &PadDtaHorMod, 'P')
			
			&ValorMOeda = &SdoAtu
			if &SdoAtu <> &MovVlr //FAZ A TRANSFERENCIA
				if &SdoAtu > &MovVlr
					&ValorMOeda = &SdoAtu - &MovVlr
					do 'GetContaNome'
					
					&MovDoc = 'SAN_'+ trim(Substr(&CtaBanNom,1,15))
					&MovItmCpl = 'FECHAMENTO DE CAIXA - RETIRADA DE VALOR'
					Transferencia.Call(&Context.EmpCod, &Context.FilCod, &CtabanCod,&CtabanCodCofre,&MovDoc,&ValorMOeda,Serverdate(),&MovDoc,&MovItmCpl,'',&Error)
				Else
					&ValorMOeda = &MovVlr - &SdoAtu
					do 'GetContaNome'
					
					&MovDoc = 'SAN_'+ trim(Substr(&CtaBanNom,1,15))
					&MovItmCpl = 'FECHAMENTO DE CAIXA - ADICAO DE VALOR'
					Transferencia.Call(&Context.EmpCod, &Context.FilCod, &CtabanCodCofre, &CtabanCod ,&MovDoc,&ValorMOeda,Serverdate(),&MovDoc,&MovItmCpl,'',&Error)
				Endif
			EndIf
			
			do 'GetContaNome'
			prcGravaFechamento.Call(&EmpCod, &CtaBanCod, &auxFecHor, &AuxFecSts, &Context.PesCod, &SdoAtu, 'N', &FecCod)
			
			&random = str(random() * 9)
			if &impressao = 'A'
				RELJAS083_2.link(&random,&EmpCod,&Context.FilCod,&CtabanCod,&FecCod,&PesRaz,&today)
			Else
				RELJAS083_3.link(&random,&EmpCod,&Context.FilCod,&CtabanCod,&FecCod,&PesRaz,&today)
			Endif
			
		CAse &AuxFecSts = FechaAbre.AbERTURA
			btnEnter.Enabled = 0
			PrcGravaAberturaCaixa.Call(&EmpCod, &CtaBanCod, &auxFecHor, &AuxFecSts, &Context.PesCod,&RetFecCod)	
			PrcGravaAberturaCaixaAtualizaFechamento.Call(&EmpCod, &CtaBanCod, &RetFecCod)
			
			Return
	EndCase

EndEvent

Sub 'GetContaNome'

	&CtaBanNom.SetEmpty()
	For Each order EmpCod, CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		
		&CtaBanNom = CtaBanNom
		
		For Each Order EmpCod, CtabanCod, (SdoDta)
			&SdoAtu = SdoAtu
			exit
		EndFor
		Exit
	EndFor

EndSub

Sub 'ValidaPermissao'

	&IsAutorizado = False
	if &Context.PesCod > 0
		For each Order EmpCod,CtabanCod
			Where EmpCod = &Context.EmpCod
			Where CtabanCod = &auxCtaBanCod
			Where CtaFunCod = &Context.PesCod
			Where CtaFunIsRec <> Status_SimNao.Nao
			&IsAutorizado = True
			exit
		EndFor
	Else
		&IsAutorizado = True
	Endif

EndSub

Sub 'getsaldo'

	&CtabanCodCofre.Clear()
	&CtabanCod.Clear()
	
	
	
	//carrega contas cofres
	For Each Order EmpCod, CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod <> &CtaBanCod
		Where CtaBanTip = TipoConta.BANCO
		
		do 'ValidaPermissao'
		if &IsAutorizado = true
			if &CtabanCodCofre.Count.IsEmpty()
				&CtabanCodCofre.AddItem(0, 'Selecione conta "COFRE"')
			Endif
		
			&CtabanCodCofre.AddItem(CtabanCod,CtaBanCodNom)
		Endif

	when none
		&CtabanCodCofre.Clear()
	EndFor

	For Each Order EmpCod, CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		&CtabanCod.AddItem(CtabanCod,CtaBanCodNom)
		
		For Each Order EmpCod, CtabanCod, (SdoDta)
			&SdoAtu = SdoAtu
			exit
		EndFor
		Exit
	EndFor
	
	if &SdoAtu > 0
		&MovVlr = &SdoAtu
	Else
		&MovVlr  = 0
	Endif

EndSub


]]></Source>
