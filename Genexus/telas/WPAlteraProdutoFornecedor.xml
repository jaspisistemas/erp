      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do 'ValidaFornecedor'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGravar'

	&Mensagem = 'Tem Certeza que deseja alterar o seguinte % das colunas abaixo?'
	
	If &IsDesconto = true
		&mensagem += Newline() + 'DESCONTO: '+ trim(toformattedString(&ProForDsc)) + '%'
	EndIF
	If &IsAcrescimo = true
		&mensagem += Newline() + 'ACRÉSCIMO: '+ trim(toformattedString(&ProForAcr)) + '%'
	EndIF
	If &IsST = true
		&mensagem += Newline() + 'ICMS/S.T.: '+ trim(toformattedString(&ProForIcmSt)) + '%'
	EndIF
	If &IsIpi = true
		&mensagem += Newline() + 'IPI '+ trim(toformattedString(&ProForIpi)) + '%'
	EndIF
	If &IsNEwDesconto = true
		&mensagem += Newline() + 'Rateio. DESC.: '+ trim(toformattedString(&ProForRatDsc)) + '%'
	EndIF
	If &IsNewAcrescimo = true
		&mensagem += Newline() + 'Rateio. ACR.: '+ trim(toformattedString(&ProForRatAcr)) + '%'
	EndIF
	If &IsCusto = true and &ProForVlrCus <> 0
		&mensagem += Newline() + 'CUSTO '+ trim(toformattedString(&ProForVlrCus)) + '%'
	EndIF

	If &IsDesconto = false and &IsAcrescimo = false and &IsNewDesconto = false and &IsNewAcrescimo = false and &IsST = false and &IsIpi = false and &IsCusto = false  
		msg('ATENÇÃO! Marque pelo menos 1 opção para alteração!')
	Else
		DVelop_ConfirmPanel_Gravar.ConfirmationText = &Mensagem

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Gravar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIf

EndEvent

Event DVelop_ConfirmPanel_Gravar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Gravar.Result = !'Yes'
		Do 'Do Action Gravar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Gravar'

		RCOOpenWindow1.LinkOpen = RELJAS067.Link(&EmpCod,&ProForCod,&GrupHie,&ProCod,&Isdesconto,&Isacrescimo, &IsNewDesconto, &IsNewAcrescimo, &IsST,&IsIpi,&Iscusto,&ProForDsc,&ProForAcr,&ProForRatDsc, &ProForRatAcr, &ProForIcmSt,&ProForIpi,&ProForVlrCus)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	Do 'GetProduto'

EndEvent

Sub 'ValidaFornecedor'

	For each order EmpCod PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &ProForCod
		&ProForRaz = PesRaz
		Exit
	EndFor

EndSub

Sub 'GetProduto'

	&IsAchouProduto = false
	RetornaProdutoReferenciaCapa.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ErroMensagem)

EndSub


]]></Source>
