      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid_DWC.Class = !'Invisible WCD_' + upper(Grid.InternalName)
	
	Grid.Rows = 50
	Form.Caption = 'Manage my Subscriptions'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each WWPBaseObjects.WWP_UserExtended
		Where WWPUserExtendedId = WWP_GetLoggedUserId()
		&Sms = WWPUserExtendedSMSNotif
		&Mail = WWPUserExtendedEmaiNotif
		&Desktop = WWPUserExtendedDesktopNotif
		&SD = WWPUserExtendedMobileNotif
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	//&GridPageCount has to be loaded manually

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&GridRecordCount = 0
	&WWPSubscriptionRoleIdCollection = WWPBaseObjects.WWP_GetLoggedUserRoles()
	For Each WWPBaseObjects.WWP_Entity

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the data
	
	//Sample conditions to be added manually:
	//Where <Attribute> = &NotifShowOnlySubscribedEvents when not &NotifShowOnlySubscribedEvents.IsEmpty()
	
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&WWPEntityName = WWPEntityName
		&WWPEntityId = WWPEntityId
		&EntityHasItemsToShow = False
		If (Not &NotifShowOnlySubscribedEvents) AND WWP_HasSubscriptionsToDisplay(&WWPEntityName, WWPBaseObjects.Notifications.WWP_NotificationAppliesTo.AnyRecord)
			&EntityHasItemsToShow = True
		Else
			For Each WWPBaseObjects.Subscriptions.WWP_Subscription
			Where WWPNotificationDefinitionAllowUserSubscription
			Where (WWPUserExtendedId = WWP_GetLoggedUserId() And WWPSubscriptionSubscribed = True) Or WWPSubscriptionRoleId In &WWPSubscriptionRoleIdCollection
				&EntityHasItemsToShow = True
				If Not WWPSubscriptionRoleId.IsEmpty()
					WWPBaseObjects.Subscriptions.WWP_CheckUserIsNotUnsubscribed(WWPNotificationDefinitionId, 0, &EntityHasItemsToShow)
				EndIf
	
				If &EntityHasItemsToShow
					Exit
				EndIf
			EndFor
		EndIf
		If &EntityHasItemsToShow
			&GridRecordCount += 1
			Load
		EndIf
		
	EndFor
	&GridPageCount = &GridRecordCount/Grid.Rows + iif(Mod(&GridRecordCount, Grid.Rows) > 0, 1, 0)

EndEvent

Event &DetailWebComponent.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_DWC.Object = WWP_SubscriptionsSettingsWC.Create(&WWPEntityId, &NotifShowOnlySubscribedEvents)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"NOTIFSHOWONLYSUBSCRIBEDEVENTS"
				&NotifShowOnlySubscribedEvents.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"FILTERFULLTEXT"
				&FilterFullText.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"NOTIFSHOWONLYSUBSCRIBEDEVENTS", "", not &NotifShowOnlySubscribedEvents.IsEmpty(), 0, &NotifShowOnlySubscribedEvents.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"FILTERFULLTEXT", "", not &FilterFullText.IsEmpty(), 0, &FilterFullText, '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &Mail.Click

	&WWPUserExtended.Load(WWP_GetLoggedUserId())
	&WWPUserExtended.WWPUserExtendedEmaiNotif = &Mail
	&WWPUserExtended.Save()
	If &WWPUserExtended.Success()
		Commit
	EndIf

EndEvent

Event &Sms.Click

	&WWPUserExtended.Load(WWP_GetLoggedUserId())
	&WWPUserExtended.WWPUserExtendedSMSNotif = &SMS
	&WWPUserExtended.Save()
	If &WWPUserExtended.Success()
		Commit
	EndIf

EndEvent

Event &SD.Click

	&WWPUserExtended.Load(WWP_GetLoggedUserId())
	&WWPUserExtended.WWPUserExtendedMobileNotif = &SD
	&WWPUserExtended.Save()
	If &WWPUserExtended.Success()
		Commit
	EndIf

EndEvent

Event &Desktop.Click

	&WWPUserExtended.Load(WWP_GetLoggedUserId())
	&WWPUserExtended.WWPUserExtendedDesktopNotif = &Desktop
	&WWPUserExtended.Save()
	If &WWPUserExtended.Success()
		Commit
	EndIf

EndEvent

Event &NotifShowOnlySubscribedEvents.Click

	Grid_DWC.Refresh()

EndEvent


]]></Source>
