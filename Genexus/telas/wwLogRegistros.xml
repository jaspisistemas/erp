        <Source><![CDATA[
Event Start

	LoadwwpContext.Call(&Context)
	&LogErpEmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&LogErpEmpCod.Visible = False
	&ActionGroup1Data = new()
	
	&ActionGroup1DataItem = new()
	&ActionGroup1DataItem.Title = 'Inicializar Banco'
	&ActionGroup1DataItem.EventKey = !'Inicializar'
	&ActionGroup1DataItem.IsDivider = False
	&ActionGroup1Data.Add(&ActionGroup1DataItem)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	wcItems.Object = wwItensDoLog.Create(&Context.EmpCod, &LogErpTabCod, &LogTrnCod, &LogErpDtaHorMod, &LogErpDtaHorMod_To, &LogErpUsuGuid, &LogErpRegKey)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ddo_ActionGroup1.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case ddo_ActionGroup1.ActiveEventKey = !'Inicializar'
			Do 'Do Inicializar'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Inicializar_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wcGravarTabelasAtributos.Create()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Inicializar_Modal.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Inicializar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Inicializar_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	prcGetDadosBanco.Call(&EmpBDerp, &EmpBDAudit)
	if not &EmpBDAudit.IsEmpty() and &EmpBdErp <> &EmpBdAudit
		&SQLSentence = 'USE ' + trim(&EmpBDAudit)
		SQL [!&SqlSentence!]
	Endif
//	
//	&GridPageCount = grid.PageCount
//	&GridCurrentPage = Grid.CurrentPage
//	


//	&LogErpEmpCod = &Context.EmpCod

EndEvent


