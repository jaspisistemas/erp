      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPLISTAGEMCLIENTES', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	padraousuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&DATAVAZIA.SetEmpty()
	If not &PadObs.IsEmpty()
		&Ordenar = Substr(&PadObs, 1,1)
		&Papel = Substr(&PadObs, 3,1)
	EndIF
	
	do 'Cidade'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Papel.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event &PesEntCidCod.IsValid

do 'Cidade'

EndEvent

Event Enter

	&PadObs = &Ordenar
	&PadObs += &Papel
	padraousuario.Submit('', 'G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	
	RCOOpenWindow1.LinkOpen = RELJAS115.Link(&EmpCod, &PesSts,  &PesDtaCad, &PesEntCidCod, &PesEntUfeCod,  &RatCod, &Ordenar, &PesReg)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Sub 'Cidade'

	If &PesEntCidCod = 0
		&PesEntCidNom = 'TODAS AS CIDADES'
	Else
		For Each Order EmpCod, CidCod
			Where EmpCod = &EmpCod
			Where CidCod = &PesEntCidCod
			&PesEntCidNom = CidNom
			Exit
		When None
			&PesEntCidNom = 'CIDADE NÃO ENCONTRADA'
			msg(&PesEntCidNom)
		EndFOr
	EndiF

EndSub


]]></Source>
