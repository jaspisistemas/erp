        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	Do 'GETproduto'
	&DisplayPedDtaVct.Enabled = true
	&PedDtaVct = &DisplayPedDtaVct

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TabIsAntAcr.Visible = False
	&TabAltCod.Visible = False
	&ProCod.Visible = False
	&ProGraCod.Visible = False
	&PedDtaVct.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&TabPrcPrecificado = &TabPrc1
	retornaUnitarioLiquidoAntecipado.call(&TabPerAcr, &TabPerAnt, &TabDtaVct, &DataVazia,&PedDtaVct,&TabPrcPrecificado)

EndEvent

Event &DisplayPedDtaVct.ISValid

	&HojeData = Serverdate()
	&MaximoData = &HojeData.AddDays(365)
	Do Case
		Case &DisplayPedDtaVct < &HojeData
			msg('Informado uma data inferior a Hoje!, não é permitido!')
			&DisplayPedDtaVct.setfocus()
			
		Case &DisplayPedDtaVct > &HojeData.AddDays(365)
			msg('Data máxima para precificação é de 365 dias futuros: ' + trim(toformattedString(&MaximoData)))
			&DisplayPedDtaVct.setfocus()
			
		Otherwise
			if &PedDtaVct <> &DisplayPedDtaVct
				&PedDtaVct = &DisplayPedDtaVct
			EndIf 
			&TabPrcPrecificado = &TabPrc1
			retornaUnitarioLiquidoAntecipado.call(&TabPerAcr, &TabPerAnt, &TabDtaVct, &DataVazia,&PedDtaVct,&TabPrcPrecificado)
	EndCase

EndEvent

Event &TabPerAcr.IsValid

	&HojeData = Serverdate()
	&MaximoData = &HojeData.AddDays(365)
	Do Case
		Case &DisplayPedDtaVct < &HojeData
			msg('Informado uma data inferior a Hoje!, não é permitido!')
			
		Case &DisplayPedDtaVct > &HojeData.AddDays(365)
			msg('Data máxima para precificação é de 365 dias futuros: ' + trim(toformattedString(&MaximoData)))
			
		Otherwise
			if &PedDtaVct <> &DisplayPedDtaVct
				&PedDtaVct = &DisplayPedDtaVct
			EndIf 
			&TabPrcPrecificado = &TabPrc1
			retornaUnitarioLiquidoAntecipado.call(&TabPerAcr, &TabPerAnt, &TabDtaVct, &DataVazia,&PedDtaVct,&TabPrcPrecificado)
	EndCase

EndEvent

Event &TabPerAcr.ControlValueChanged

	&HojeData = Serverdate()
	&MaximoData = &HojeData.AddDays(365)
	Do Case
		Case &DisplayPedDtaVct < &HojeData
			msg('Informado uma data inferior a Hoje!, não é permitido!')
			
		Case &DisplayPedDtaVct > &HojeData.AddDays(365)
			msg('Data máxima para precificação é de 365 dias futuros: ' + trim(toformattedString(&MaximoData)))
			
		Otherwise
			if &PedDtaVct <> &DisplayPedDtaVct
				&PedDtaVct = &DisplayPedDtaVct
			EndIf 
			&TabPrcPrecificado = &TabPrc1
			retornaUnitarioLiquidoAntecipado.call(&TabPerAcr, &TabPerAnt, &TabDtaVct, &DataVazia,&PedDtaVct,&TabPrcPrecificado)
	EndCase

EndEvent

Sub 'GetProduto'

	For each Order EmpCod, TabCod,ProCod,ProGraCod,TabAltCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where TabAltCod = &TabAltCod
	
		&TabPrc1 = TabPrc1 
		&TabPerAcr = TabPerAcr
		&TabPerAnt = TabPerAnt
		&TabIsAntAcr = TabIsAntAcr  
		&gridProGraRef = ProGraRef
		&gridProNomGra = ProNomGra
//		&DisplayPedDtaVct
//		&PedDtaVct
	EndFor

EndSub


]]></Source>
