      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&ProCod = &InOutProCod
	&TlvCod = &InOutTlvCod
//	&InfCod = &InOutInfCod
	Do 'GetProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	DgnInfSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Selecionar = !'<i class="fa fa-check"></i>'
	If (DgnInfSts = Status_AtivoInativo.ATIVO)
		&Selecionar.Class = !'Attribute'
	Else
		&Selecionar.Class = !'Invisible'
	Endif

	&AuxTlvNom = Trim(str(TlvCod))+' -'+Trim(TlvNom)
	&auxInfNom =Trim(str(InfCod))+' -'+Trim(InfNom)
	Do Case
		Case DgnInfSts = Status_AtivoInativo.ATIVO
			DgnInfSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case DgnInfSts = Status_AtivoInativo.INATIVO
			DgnInfSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			DgnInfSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Selecionar.Click

	&InOutInfCod = InfCod
	return

EndEvent

Sub 'GetProduto'

	For each Order EmpCod,ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProCodNom = ProCodNom 
		Exit
	EndFor

EndSub

//Event Grid.OnLineActivate
//
//	&InOutInfCod = InfCod
//	return
//
//EndEvent
]]></Source>
