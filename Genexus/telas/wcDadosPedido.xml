      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	for Each ORder EmpCod, MrkCod, MrkPedSku
		Where EmpCod = &EmpCod
		WHere MrkCod = &MrkCod
		where MrkPedSku = &MrkPedSku
		
		txtNickName.Caption = format('Nick Name: %1', trim(MrkPedNick))
		txtNome.Caption = format('Nome Comprador: %1', trim(MrkPedCliNom))
		
		&MrkShipSku = MrkPedShipSku
		
		Exit
	EndFor

	//Dados Entrega
	For Each ORder EmpCod, MrkCod, MrkShipSku
		Where EmpCod = &EmpCod
		WHere MrkCod = &MrkCod
		Where MrkShipSku = &MrkShipSku
		
		txtLog.Caption = format('Logradouro: %1, %2', trim(MrkShipLog), MrkShipNro)
		txtCep.Caption = format('CEP: %1', trim(MrkShipCep))
		txtCidade.Caption = format('Cidade: %1-%2', trim(MrkShipCid), trim(MrkShipUF))
//		txtref.Caption = format('Referencia: %1', trim(MrkPedNick))
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	&MrkItmCod = MrkPedProItmCod
	do 'getProduto'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&Grid1CurrentPage = Grid1.CurrentPage
	&Grid1PageCount = Grid1.PageCount

EndEvent

Sub 'getProduto'

	For Each Order EmpCod, MrkCod, MrkProCod
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		Where MrkItmCod = &MrkItmCod
		&imagemProduto.FromURL(MrkUrlImgPri)
		&MrkProNom = MrkProNom 
	EndFor

EndSub


]]></Source>
