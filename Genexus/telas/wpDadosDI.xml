	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtDIsPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtDIsPaginationBar.SelectedPage = !'Previous'
			GridsdtDIs.PreviousPage()
		Case GridsdtDIsPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtDIs.CurrentPage
			&PageToGo += 1
			GridsdtDIs.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtDIsPaginationBar.SelectedPage)
			GridsdtDIs.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtDIsPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtDIs.Rows = GridsdtDIsPaginationBar.RowsPerPageSelectedValue
