        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	if not &tmpNFeCod.IsEmpty()
		Do 'loadTemporaria'
	Else
		do 'LoadNFE'
	EndIF
	
	if &sdtDI.tpViaTransp.IsEmpty()
		&sdtDI.tpViaTransp = '1'
	EndIF
	&adis = new()
	
	if &sdtDI.adis.Count = 0
		&sdtDI.adis.Add(&adis)
		&sdtDI.adis.Add(&adis)
		&sdtDI.adis.Add(&adis)
	EndIF
	&sdtDI.adis.Add(&adis)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	GridsdtDIs.Rows = Page.Rows
	GridsdtDIsPaginationBar.RowsPerPageSelectedValue = GridsdtDIs.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtDIsCurrentPage = GridsdtDIs.CurrentPage
	&GridsdtDIsPageCount = GridsdtDIs.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

