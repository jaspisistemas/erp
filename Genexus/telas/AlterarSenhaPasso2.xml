      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&userName = Decrypt64(&AuxUsuario, 'E1D89B0D44CD35AFC9CF69E7E556A97B')

	Form.Backcolor = rgb(238,238,238)
	LayoutMainTable.Class = ThemeClass:MainContainer
	TableError.Visible = false

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 270

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &UserPasswordNew = &UserPasswordNewConf	//## Se a senha nova informada pelo usuário é igual à confirmação da senha
		&User 			= GAMRepository.GetUserByLogin(&UserAuthTypeName, &UserName, &Errors)	//## Busca o usuário
		&UserNick 		= &User.GetName()	//## Nome do usuário
	
		If &Errors.Count = 0	//## Verifica se não há erros armazenados
			&ChangePwdOK = &User.ChangePasswordByKey(&KeyToChangePassword, &UserPasswordNew, &Errors)	//## Tenta alterar a senha do usuário
			If &ChangePwdOK	//## Se a alteração for bem sucedida
				Commit	//## Efetua o commit das alterações
				&AdditionalParameter.RememberUserType	= &UserRememberMe
				&AdditionalParameter.IDPState			= &IDP_State
				&LoginOK = GAMRepository.Login(&UserName, &UserPasswordNew, &AdditionalParameter, &Errors )	//## Tenta realizar o login do usuário com o novo login e senha
				
				&UserPasswordNew.Enabled 		= 	0
				&UserPasswordNewConf.Enabled 	= 	0
				
				If &LoginOK	//## Verifica se o login foi bem sucedido
					If 	GAMRepository.IsRemoteAuthentication(&IDP_State)	//## Verifica se é uma autenticação remota
						GAMRepository.RedirectToRemoteAuthentication(&IDP_State)	//## Redireciona para a autenticação remota
					Else
						If 	Upper(&UserNick) = 	'SUPORTE.JASPI'	//## Se o perfil tiver 'SUPORTE.JASPI' define com o código de suporte
							&TipoPerfil 	= 	3
						Else
							&TipoPerfil 	= 	RetTipNick.Udp(&User.GetExternalId()) // 1 Usuario 2 Contador
						Endif
						
						Do Case 
							Case 	&TipoPerfil = 	3	//## Se o perfil for de suporte
								&QtdEmpCod 	= 	RetQtdEmp.udp()	//## Verifica se há mais de uma empresa cadastrada
								If 	&QtdEmpCod 	> 	1
									WWAdmin.Link()	//## Redireciona para a página de administração
								Else
									prcLogaPrimeiraEmpresa.call(&IsOkLicenca,&IsOkAcesso) //## Logar na primeira empresa
									If 	&IsOkLicenca = true and &IsOkAcesso = True	//## Se bem sucedido
										Do 'Home'	//## Redireciona para a página inicial
									EndIF
								EndIF
								
							Case 	&TipoPerfil = 2	//## Se o perfil for de contador
								WWContador.Link(&User.GetExternalId())	//## Redireciona para a página do contador
								
							Case 	&TipoPerfil = 1	//## Se o perfil for de usuário
								&URL 		= GAMRepository.GetLastErrorsURL()	
								
								If 	Not &User.GetExternalId().IsEmpty()	//## Se não for anônimo
									ProcLoadInicio.Call(0,0, &IsOkLicenca, &IsOkAcesso)	//## Carregar a página inicial do usuário
								EndIF
								if 	&IsOkLicenca = true and &IsOkAcesso = True
									Do 'Home'	//## Redireciona para a rotina
								EndIF
						EndCase
					Endif
				Else
					Do 'DisplayMessages'
				EndIf
			Else
				Do 'DisplayMessages'
			Endif
		Else
			Do 'DisplayMessages'
		Endif
	Else
		TableError.Visible = True
		Msg("WWP_GAM_NewPasswordNotMatch")
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltarLogin'

	If GAMRepository.IsRemoteAuthentication(&IDP_State)
		GAMRemoteLogin(&IDP_State)
	Else
		Login('', '')
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Home'

	If &URL.IsEmpty()	//## Verifica se não há erros armazenados
		LoadWWPContext.Call(&Context)	//## Carregar o contexto da aplicação
		RetQtdFilialAcesso.Call(&Context.EmpCod, &Context.PesCod, 2, &QuantidadeFilial)	//## Busca a quantidade de filiais que o usuário tem acesso
		
		If &QuantidadeFilial > 1 and upper(&UserNick) <> 'SUPORTE.JASPI'	//## Se a quantidade for maior que 1 e o perfil do usuário não for de suporte
			wwSelecionaFilial.Link()	//## Redireciona para a página de seleção de filial
		Else
			Dashboard.Link()	//## Redireciona para a página inicial
		Endif
	Else
		LoadWWPContext.Call(&Context)	//## Carregar o contexto da aplicação
		RetQtdFilialAcesso.Call(&Context.EmpCod, &Context.PesCod, 2, &QuantidadeFilial)	//## Busca a quantidade de filiais que o usuário tem acesso
					
		If 	&QuantidadeFilial > 1 And upper(&UserNick) <> 'SUPORTE.JASPI'	//## Se a quantidade for maior que 1 e o perfil do usuário não for de suporte
			wwSelecionaFilial.Link()	//## Redireciona para a página de seleção de filial
		Else
			Link(&URL)	//## Redireciona para a URL de ERRO armazenada
		EndIf
	Endif

EndSub

Sub 'DisplayMessages'

	TableError.Visible = True
	For &Error in &Errors
		Msg(Format(!"%1", &Error.Message))
	EndFor

EndSub


]]></Source>
