      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SomenteComfaltas = true
//	LoadWWPContext.Call(&Context)
//	&EmpCod = &Context.EmpCod
//	&FilCod = &Context.FilCod
//	padraoUsuario.Call('L', &PedidosSelecionados, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
//	&SdtPedidos.FromJson(&PadObs)
//	
//	&numeric = &SdtPedidos.Count
//	PedidosSelecionados.Caption = trim(str(&numeric)) + ' - Pedidos Marcados'
	
	Form.Caption = 'FALTAS DOS PEDIDO'	

//	CarregaSdtFaltas.call(&Context.EmpCod, &Context.FilCod, &SdtPedidos, &sdtPedidoProduto, &TotalFaltas, &IsDiferente)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 700
	&EmpCod.Visible = False
	&FilCod.Visible = False
	GridsdtPedidoProdutos.Rows = Page.Rows
	GridsdtPedidoProdutosPaginationBar.RowsPerPageSelectedValue = GridsdtPedidoProdutos.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	padraoUsuario.Call('L', &PedidosSelecionados, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	&SdtPedidos.FromJson(&PadObs)
	
	&numeric = &SdtPedidos.Count
	PedidosSelecionados.Caption = trim(str(&numeric)) + ' - Pedidos Marcados'
	
	CarregaSdtFaltas.call(&Context.EmpCod, &Context.FilCod, &SdtPedidos, &sdtPedidoProduto, &TotalFaltas, &IsDiferente, &SomenteComfaltas)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtPedidoProdutosCurrentPage = GridsdtPedidoProdutos.CurrentPage
	&GridsdtPedidoProdutosPageCount = GridsdtPedidoProdutos.PageCount
	&PedQtdCan.ColumnHeaderClass = !'WWColumn'
	&EstQtd.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoProdutos.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&PedQtdCan.ColumnClass = iif(&sdtPedidoProduto.currentItem.PedQtdCan <= &sdtPedidoProduto.currentItem.EstQtd, !'WWColumn WWColumnSuccess WWColumnSuccessSingleCell', !'WWColumn')
	&EstQtd.ColumnClass = iif(&sdtPedidoProduto.currentItem.EstQtd <= 0, !'WWColumn WWColumnDanger WWColumnDangerSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If &sdtPedidoProduto.CurrentItem.EstLoc.IsEmpty()
		&EstLoc = 'SEM_LOCACAO'
	Else
		&EstLoc = &sdtPedidoProduto.CurrentItem.EstLoc
	EndiF

	&EstQtd.Link = wpConsultaEstoque.Link(&sdtPedidoProduto.CurrentItem.ProEstProCod)
	&EstQtd.LinkTarget = '_blank'
	
	if &IsDiferente = false
		&PedCliCodRaz = &sdtPedidoProduto.currentItem.PedCliCodRaz
		&PedCod = &sdtPedidoProduto.currentItem.PedCod
	Else
		&PedCod = 0
		&PedCliCodRaz = 'VARIOS CLIENTES'
	Endif

	&EstQtd = &sdtPedidoProduto.currentItem.EstQtd
	&Pedqtd = &sdtPedidoProduto.currentItem.PedQtd
	
	&PedqtdCan = &sdtPedidoProduto.currentItem.PedQtdCan

EndEvent

Event GridsdtPedidoProdutosPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtPedidoProdutosPaginationBar.SelectedPage = !'Previous'
			GridsdtPedidoProdutos.PreviousPage()
		Case GridsdtPedidoProdutosPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtPedidoProdutos.CurrentPage
			&PageToGo += 1
			GridsdtPedidoProdutos.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtPedidoProdutosPaginationBar.SelectedPage)
			GridsdtPedidoProdutos.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoProdutosPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoProdutos.Rows = GridsdtPedidoProdutosPaginationBar.RowsPerPageSelectedValue
	GridsdtPedidoProdutos.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRetornar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimirFaltas'

	&WebSession.Set('ITENS_FALTAS', &sdtPedidoProduto.ToXml())
	RCOOpenWindow1.LinkOpen = RELJAS037_V.Link(&EmpCod, &FilCod, &SomenteComfaltas)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGerarPedido'

	if &PedCod = 0
		msg('Não é Possível Gerar Pedido, Mais de um cliente foi selecionado!')
	Else
		&WebSession.Set('ITENS_FALTAS', &sdtPedidoProduto.ToXml())
		wpGerarPedidoFaltas.Link(&DeOndeVem, &Context.EmpCod, &Context.FilCod, &PedCod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &EstLoc.Click

	LocacaoProduto.Popup(true, &sdtPedidoProduto.CurrentItem.ProCod)
	Refresh

EndEvent

Event PedidosSelecionados.Click

	wpPedidoSelecionado.Popup(&PedidosSelecionados)

EndEvent


