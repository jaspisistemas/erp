      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&MovDtaCon = &Today
	&IsConferido = False
	&IsConferido.Enabled = true
	LoadWWPContext.Call(&Context)
	Do 'LoadConta'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = 1
	&GridCurrentPage.Visible = true
	&GridPageCount = 1

EndEvent

Event Refresh

	&GridPageCount = grid.PageCount
	&GridCurrentPage = Grid.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&gridMovVlr = MovVlr

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConferir'

	Do 'Verificaselecionados'
	If &sdtMovimento.Count >= 1
		DVelop_ConfirmPanel_Conferir.ConfirmationText = 'Deseja conferir os lançamentos com a data '+ dtoC(&MovDtaCon)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_Conferir.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		Msg('Nenhum Movimento Selecionado')
	EndIf

EndEvent

Event DVelop_ConfirmPanel_Conferir.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_Conferir.Result = !'Yes'
		Do 'Do Action Conferir'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMarcar'

	If &IsConferido = false
		BtnMarcar.Caption = 'Desmarcar'
		BtnMarcar.Tooltiptext = 'Desmarcar'
		&IsConferido = True
	Else
		BtnMarcar.Caption = 'Marcar'
		BtnMarcar.Tooltiptext = 'Marcar'
		&IsConferido = False
	EndIf
	
	If &IsConferido = False
		For Each Line
			&IsConferido = False
		EndFor
	Else
		For Each Line
			&IsConferido = True
		EndFor
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action Conferir'

	AtualizaConferencia.Call(&sdtMovimento,&MovDtaCon)
	Grid.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &MovDtaCon.IsValid

	&result = &Today - &MovDtaCon
	If ((&result > 30) or (&result < -30))
		msg('Atenção Data Diferente do dia atual Verifique!')
	EndIf

EndEvent

Sub 'LoadConta'

	For each Order EmpCod,CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &parMovCtaBanCod
		&MovCtaBanCod.AddItem(CtabanCod,CtaBanCodNom)
		Exit
	EndFor
	
	&MovCtaBanCod = &parMovCtaBanCod

EndSub

Sub 'Verificaselecionados'

	&sdtMovimento.Clear()
	For each line
		If &IsConferido = True
			&sdtMovimentoItem = new()
			&sdtMovimentoItem.EmpCod = EmpCod
			&sdtMovimentoItem.MovCod = MovCod
			&sdtMovimentoItem.MovCtaBanCod = MovCtaBanCod
			&sdtMovimento.Add(&sdtMovimentoItem)
		EndIf
	EndFor

EndSub


]]></Source>
