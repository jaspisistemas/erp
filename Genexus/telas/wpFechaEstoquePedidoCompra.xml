      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProcessando.Visible = 0
	
	do Case
		CAse &DeOndeVem = 'WWDEVOLUCAOVENDA'
			RetornaAutorizacao.Call('DEVOLUCAOFECHAESTOQUE', Status_SimNao.Sim, 1, &AutNiv)
			textBlockTitle.Caption = 'Fecha estoque devolução venda Nº: ' + trim(Str(&PedCod))
			textBlockPedCliCodRaz.Caption = 'Cliente:'
		Otherwise
			RetornaAutorizacao.Call('COMPRAFECHAESTOQUE', Status_SimNao.Sim, 1, &AutNiv)
			textBlockTitle.Caption = 'Fecha estoque pedido de compra Nº: ' + trim(Str(&PedCod))
	EndCase
	
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PedDtaFat.TooltipText = "Data chegada do pedido, Quando entrou no Estoque."

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, FilCod, PedCod
		where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod  = &PedCod
		
		&PedCliObs = PedCliObs
		If PedCliObs.IsEmpty()
			&PedCliObs.Visible = 0
		EndIF
	
		&PedObsEst = PedObsEst
		If PedObsEst.IsEmpty()
			&PedObsEst.Visible = 0
		EndIF
		&PedDtaEms = PedDtaEms
		&PedObsGer = PedObsGer
		If PedObsGer.IsEmpty()
			&PedObsGer.Visible = 0
		EndIF
		
		//&FilCodNom = FilCodNom
		&PedCliCodRaz = PedCliCodRaz
		&LctCodNom = LctCodNom
		&PedVlrBrt = PedVlrBrt
		&PedVlrLiq = PedVlrLiq
		
		If PedStsFin <> Status_Financeiro.ABERTO
			&DefinirFinanceiro.Clear()
			&DefinirFinanceiro.AddItem('N', 'NÃO. FINANCEIRO JÁ DEFINIDO')
			
			&DefinirFinanceiro = 'N'
			&DefinirFinanceiro.Enabled = 0
		EndIF
	
		If LctGerFin = Status_SimNao.Nao
			&DefinirFinanceiro.Clear()
			&DefinirFinanceiro.AddItem('N', 'PEDIDO NÃO GERA FINANCEIRO')
			
			&DefinirFinanceiro = 'N'
			&DefinirFinanceiro.Enabled = 0
		EndIF
		&LctTip = LctTip
		If LctTip = TipoLancamento.DevolucaoVenda
			Form.Caption = 'Fechar Estoque Pedido de Devolução de Venda'
		EndIF
		
		If (PedSts <> Status_Pedido.ABERTO and PedSts <> Status_Pedido.SEPARANDO) or PedStsPrc = AtualizandoEstoquePedido.Abrindo or PedStsPrc = AtualizandoEstoquePedido.Fechando
			do 'voltar'
		EndiF
		
		Exit
	When None
		return
	EndFor
	
	if &DeOndeVem = 'WWDEVOLUCAOVENDA'
		&FinAutNiv = RetornaAutorizacao.UDP('DEVOLUCAOFECHAFINANCEIRO', Status_SimNao.Nao, 1)
	Else
		&FinAutNiv = RetornaAutorizacao.UDP('COMPRAFECHAFINANCEIRO', Status_SimNao.Nao, 1)
	EndIF

	If &FinAutNiv = 0
		&DefinirFinanceiro.Clear()
		&DefinirFinanceiro.AddItem('N', 'NÃO AUTORIZADO FECHAR FINANCEIRO')
		
		&DefinirFinanceiro = 'N'
		&DefinirFinanceiro.Enabled = 0
	EndIF

	&PedDtaFat = serverdate()
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod,&Context.EmpCod, &PadObs, &PadDtaMod)
    &OqueFazer = iif(SUBSTR(&PadObs,1,5) <> '',trim(SUBSTR(&PadObs,1,5)), '1')

EndEvent

Event 'DoCancelaFechamento'

	do 'voltar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &PedCliObs.IsEmpty())
		&PedCliObs.Visible = False
		PedCliObs_Cell.Class = !'Invisible'
	Else
		&PedCliObs.Visible = True
		PedCliObs_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&AuxOqueFazer = &OqueFazer
	//ATUALIZANDO TOTAIS PEDIDO, TOMA UM TEMPO DE PROCESSAMENTO, ANALISAR MOTIVO - JDF
	//AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')

	For Each Order EmpCod, FilCod, PedCod
		where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod  = &PedCod
		
		if PedCliTip = TipoPessoa.JURIDICA
			&PedCliCpfCnpj = PedCliCnpj
		else
			&PedCliCpfCnpj = PedCliCpf
		Endif
	
		If PedSts <> Status_Pedido.ABERTO and PedSts <> Status_Pedido.SEPARANDO
			do 'voltar'
		EndiF
		&PedCliBlqNfe = PedCliBlqNfe
		&PedDtaEms = PedDtaEms
		&PedSts = PedSts
		Exit
	EndFOr
	
	Do case
		Case &PedDtaFat < &PedDtaEms
			msg('Data de Faturamento não informada ou inferior a data do pedido!')
		Otherwise
			
		    if &PedSts <> Status_Pedido.FECHADO
				&PadObs = PadL(trim(&AuxOqueFazer),5, ' ')
				PadraoUsuario.Call('G', &Pgmname, &Context.PesCod,&Context.EmpCod, &PadObs, &PadDtaMod)
			    
				Do Case
					Case &AuxOqueFazer = '1' //SOMENTE FECHAR
						tbConfirmar.Visible = 0
						tbProcessando.Visible = 1
						
						&PedDtaFat.Enabled = 0
						&DefinirFinanceiro.Enabled = 0
						
						&ProgressId = trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&PedCod)) + 'FECHAR'
						apagaProgress.Call(&ProgressId)
						scaProgressBar.ProcessId = &ProgressId
						scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
						scaProgressBar.Start()
						
						if &DeOndeVem = 'WWDEVOLUCAOVENDA' 
							AtualizaEstoqueGerencialDevolucao_submit.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &PedCod, &PedDtaFat, Status_Pedido.FECHADO, &Context.PesCod)
						Else
							AtualizaEstoqueGerencialCompra_submit.Submit(&ProgressId, &ProgressId, 0,0, &EmpCod, &FilCod, &PedCod, &PedDtaFat, &Context.PesCod, Status_Pedido.FECHADO, false)
							//							AtualizaEstoqueGerencialCompra.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &Context.PesCod, Status_Pedido.FECHADO, false)
						EndIF
						
					Case &AuxOqueFazer = '2' //LANÇAR NOTA FISCAL TERCEIROS
						&tmpNFeCod = trim(str(&EmpCod)) + trim(Str(&FilCod)) + trim(str(&PedCod)) + trim(str(&Context.PesCod))
						GravaNotaTemporariaCompra.Call(&tmpNFeCod, &EmpCod, &FilCod, &PedCod, &PedDtaFat)
						wpNotaTemporaria.Link(&DeOndeVem, &EmpCod, &FilCod, &PedCod, &PedDtaFat, &DefinirFinanceiro, &tmpNFeCod)
						
					Case &AuxOqueFazer = '3' //LANÇAR NOTA FISCAL COM O XML
						&WebSession.Remove('ImportarXmlCompra_Data')
						
						&WizardData.SelecionarXML.DeOndeVem = 'WWPEDIDOCOMPRA'
						if &LctTip = TipoLancamento.DevolucaoVenda
							&WizardData.SelecionarXML.DeOndeVem = 'WWDEVOLUCAOVENDA'
						Endif
						
						&WizardData.SelecionarXML.PedCod = &PedCod
						&WizardData.SelecionarXML.PedFilCod = &FilCod
						&WizardData.SelecionarXML.PedCliCodRaz = &PedCliCodRaz
						&WizardData.SelecionarXML.PedCliCpfCnpj = &PedCliCpfCnpj
						
						&WizardData.GravaNf.PedDtaFat = &PedDtaFat
						
						&WizardData.GravaNf.FecharPedidoSelecionado = true
						if &DefinirFinanceiro = 'S'
							&WizardData.GravaNf.FecharFinanceiroSelecionado = true
						Else
							&WizardData.GravaNf.FecharFinanceiroSelecionado = false
						EndIF
						
						&WebSession.Set('ImportarXmlCompra_Data', &WizardData.ToJson())
						
						IMportarXmlCompra.Link('SelecionarXML','SelecionarXML', false)
						
					Case &AuxOqueFazer = '4' //LANÇAR NFE PROPRIA
						If &PedCliBlqNfe = Status_simNao.Sim
							Msg('Atenção! Cliente com emissão fiscal bloqueado no cadastro, procure saber o motivo antes de desbloquear!')
						Else
							GravaNotaTemporariaVenda.Call(&EmpCod, &FilCod, &PedCod, '55')
							wpSelecionaProdutosNFe.Link(&DeOndeVem, &EmpCod, &FilCod, &PedCod)
						EndIf
				EndCase
			else 
				do 'voltar'
		    Endif
	EndcAse

EndEvent

Event ScaProgressBar.OnComplete

	Do CAse
		Case &AuxOqueFazer = '1' //SOMENTE FECHAR	
			
			if &DefinirFinanceiro = 'S' //DEFINIR FINANCEIRO
				
				padraoUsuario.Call('G', 'HAVERSERLECIONADO_FCHDV', &Context.PesCod, &Context.EmpCod, '', &PadDtaMod)
//				if &DeOndeVem = 'WWDEVOLUCAOVENDA'
					wpFechaFinanceiroCompras.Call(&DeOndeVem, &EmpCod, &FilCod, &PedCod)
//				Else
//					wpFechaFinanceiroCompras.Call('WWPEDIDOCOMPRA', &EmpCod, &FilCod, &PedCod)
//				Endif
			Else
				do 'voltar'
			Endif
	EndCase

EndEvent

Sub 'voltar'

	&link = &DeOndeVem.Trim() + '.aspx'
	link(&Link)

EndSub


]]></Source>
