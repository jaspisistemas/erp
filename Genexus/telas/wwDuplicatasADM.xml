	&Location.CancelOnError = 2 //tratar exceção do WS 
	&ppJASPI_DuplicatasERP_outADMsdtDuplicatas = &ppJASPI_DuplicatasERP_outADM.Execute()
	
	If GetSOAPErr()= 0 
		For Each order EmpCod, CbrCod
			Where EmpCod = &EmpCod
			Where CbrCod = &CreCbrcod
			&JurCod = CbrJurCod
			Exit
		EndFor		
		
		GravaDuplicatasADM_in.call(&EmpCod, &FilCod, -2, &CreVenCod, &CreCbrcod, &JurCod, &PlanCod, &ppJASPI_DuplicatasERP_outADMsdtDuplicatas)
		
		refresh
	Else 
		&mensagem = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&mensagem += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&mensagem) 
	EndIf
	
