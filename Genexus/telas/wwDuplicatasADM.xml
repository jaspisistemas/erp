Event Start

	retornaAutorizacao.Call('WWDUPLICATASADM', Status_SimNao.Sim, 1, &AutNiv)
	
	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	&PEsCod = &wwpContext.PesCod
	
	RetornaConfSistema.Call(&wwpContext.EmpCod, &wwpContext.FilCod, domConfSistema.TCon044_PlanoRecCliente, &TCon044_PlanoRecCliente)
	
	
	padraoUsuario.Call('L', '#OPCAOPADRAODUPLICATASADM#', &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PaddtaMod)
	if &PadObs.IsEmpty()
		&PlanCod = val(&TCon044_PlanoRecCliente)
	Else
		&CreCbrcod = val(substr(&PadObs, 1, 8))
		&PlanCod = val(substr(&PadObs, 9, 8))
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&FilCod.Visible = False
	&PesCod.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&ActionMarcar.ColumnHeaderClass = !'WWActionColumn'
	DupTmpCreCod.ColumnHeaderClass = !'WWColumn'
	DupTmpCreFilPgt.ColumnHeaderClass = !'WWColumn'
	&PesCodRaz.ColumnHeaderClass = !'WWColumn'
	DupTmpCreDupNro.ColumnHeaderClass = !'WWColumn'
	DupTmpCreDtaVct.ColumnHeaderClass = !'WWColumn'
	DupTmpCreVlrDup.ColumnHeaderClass = !'WWColumn'
	DupTmpCreVenCod.ColumnHeaderClass = !'WWColumn'
	&CbrCodNom.ColumnHeaderClass = !'WWColumn'
	&PlanNom.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = grid.CurrentPage
	
	&sdtDuplicatas.FromJson(&WebSession.Get('WWDUPLICATASADM_SELECIONADAS'))

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ActionMarcar.FromImage(DDOMultiselOption)
	&ActionMarcar.TooltipText = ""
	If (DupTmpCreCliCod > 0)
		&ActionMarcar.Class = !'AttributeImage20_NoBoard'
	Else
		&ActionMarcar.Class = !'Invisible'
	Endif

	If DupTmpCreCliCod <> 0
	RetornaNomePessoa.Call(&EmpCod, DupTmpCreCliCod, &PesRaz)
	&PesCodRaz = trim(str(DupTmpCreCliCod)) + ' - ' + Substr(&PesRaz,1,40)
Else
	&PesCodRaz = DupTmpCreCodSecEmp
EndIf

	&ActionMarcar.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWActionColumn WWColumnDanger WWColumnDangerFirstColumn', !'WWActionColumn')
	DupTmpCreCod.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	DupTmpCreFilPgt.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	&PesCodRaz.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	DupTmpCreDupNro.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	DupTmpCreDtaVct.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	DupTmpCreVlrDup.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	DupTmpCreVenCod.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	&CbrCodNom.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')
	&PlanNom.ColumnClass = iif(DupTmpCreCliCod = 0, !'WWColumn WWColumnDanger', !'WWColumn')

