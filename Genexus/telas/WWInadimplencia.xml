      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&IsIgnoredPrevious = True
	
	&FinCreDtaVct = EOM(serverdate())
	&IniCreDtaVct = &FinCreDtaVct.AddMonths(-6)
	
	
	UserProgress.Visible = false
	Do 'LocalCob'
	retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IsIgnoredPrevious.TooltipText = "Marcando esta opção, será ignorado a inadimplência anterior a data Inicial do período, trazendo informação somente do período selecionado."

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &IniCreDtaVct.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Período'), DVMessageType.error, &IniCreDtaVct.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &FinCreDtaVct.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Até'), DVMessageType.error, &FinCreDtaVct.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	acao.Visible = true
	UserProgress.Visible = False
	msg('Completado com sucesso! ')
//	&window.Autoresize = 1
	
	Link(&AuxNomeArquivo)

EndEvent

Event &CreCbrCod.IsValid

	Do 'LocalCob'

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult = true
		
		&ProgressId = 'Inadimplencia' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()

		acao.Visible = false
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		UserProgress.Visible = 1
		&NomeArquivo = &sdtConfiguracoesPasta.PastaDiretorioTempFis+&ProgressId.Trim()
		&NomeArquivo = &NomeArquivo.Trim()
		&file.Source = &NomeArquivo+'.pdf'
		If &file.Exists()
			&file.Delete()
		EndIf
	
		&AuxNomeArquivo = trim(&sdtConfiguracoesPasta.PastaDiretorioTempVir)+&ProgressId.Trim()+'.pdf'
		RELJAS058.Submit('RELJAS058', &ProgressId, &EmpCod,&FilCod,&CreRecPag,&IniCreDtaVct,&FinCreDtaVct,&CreCbrCod,&NomeArquivo,&IsIgnoredPrevious)
		
	EndIf

EndEvent

Sub 'LocalCob'

	If &CreCbrCod = 0
		&CreCbrNom = 'TODOS OS LOCAIS DE COBRANÇA'
	Else		
		For each Order EmpCod,CbrCod,CbrSts
			Where EmpCod = &EmpCod
			Where CbrCod = &CreCbrCod
			Where CbrSts = Status_AtivoInativo.ATIVO
			&CreCbrNom =  CbrNom
			Exit
		When none
			msg('Local de cobrança não encontrado ou inativo. Verifique!')
			&CreCbrNom = 'NÃO ENCONTRADO OU INATIVO'
			&CreCbrCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
