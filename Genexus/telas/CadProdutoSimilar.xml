      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do 'ProdutoNome'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&SimCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &Context.EmpCod

EndEvent

Event &SimProRefVin.IsValid

	Do 'ProdutoSimilar'

EndEvent

Event Enter

	GravaProdutoSimilar.Call(&EmpCod,&SimCod,&SimProCod,&SimProCodVin)
	Return

EndEvent

Sub 'ProdutoNome'

	For each Order EmpCod,ProRef
		Where EmpCod = &EmpCod
		Where ProRef = &SimProRef
		&SimProCod = ProCod
		&SimProNom = ProNom
		Exit
	EndFor
	
	For each Order EmpCod,SimCod,SimProCod,SimProCodVin
		Where EmpCod = &EmpCod
		Where SimCod = &SimCod
		&SimProCodVin = SimProCodVin
		&SimProNomVin = SimProNomVin
	EndFor

EndSub

Sub 'ProdutoSimilar'

	For each Order EmpCod,ProRef
		Where EmpCod = &EmpCod
		Where ProRef = &SimProRefVin
		&SimProCodVin = ProCod
		&SimProNomVin = ProNom
		Exit
	when none
		&SimProRefVin.SetFocus()
		msg('Produto Não Encontrado!')
		&SimProNomVin = 'Produto Não Encontrado!'
	EndFor

EndSub


]]></Source>
