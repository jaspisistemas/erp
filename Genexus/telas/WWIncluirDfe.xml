      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	MdfeEveSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar.FromImage(ActionDelete)
	&Deletar.TooltipText = ""
	
	&Alterar.FromImage(ActionUpdate)
	&Alterar.TooltipText = ""
	
	&Action.Clear()
	&Action.AddItem(0, 'WWP_ActionGroupCaption')
	&Action.AddItem(1, 'Autorizar Evento')

	Do Case
		Case MdfeEveSts = Status_MDFe.Digitando
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case MdfeEveSts = Status_MDFe.Cancelado
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case MdfeEveSts = Status_MDFe.Autorizado
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case MdfeEveSts = Status_MDFe.Encerrado
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfoLight WWColumnTagInfoLightSingleCell'
		Otherwise
			MdfeEveSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	WWmdFe.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Action.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &Action = 1
			Do 'Do Autorizar'
	EndCase
	&Action = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Autorizar'

	loadWWPContext.Call(&Context)
	GravaXmlInclusaoDfeMDFe.Call(EmpCod,FilCod, MDFeCod,MdfeEveCod ,&Context.PesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	WPIncluiDfe.Popup(&EmpCod, &FilCod, &MDFeCod,0)
	Refresh keep

EndEvent

Event &Alterar.Click

	WPIncluiDfe.Link(EmpCod, FilCod, MDFeCod,MdfeEveCod)
	Refresh keep

EndEvent

Event &Deletar.Click

	EventoDeletaDfe.call(EmpCod, FilCod, MDFeCod,MdfeEveCod)
	Refresh keep

EndEvent


]]></Source>
