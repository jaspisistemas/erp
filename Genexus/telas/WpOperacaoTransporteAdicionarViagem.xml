      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'Viagem'
	&WizardStep.Title = 'Viagem'
	&WizardStep.Description = 'Viagem'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'DocFiscais'
	&WizardStep.Title = 'Docs Fiscais'
	&WizardStep.Description = 'Docs Fiscais'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Pagamentos'
	&WizardStep.Title = 'Pagamentos'
	&WizardStep.Description = 'Pagamentos'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Completo'
	&WizardStep.Title = 'Completo'
	&WizardStep.Description = 'Completo'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'Viagem'
		&WebSession.Remove(&Pgmname + !'_Data')
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsArrowWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRetorno'

	WwOperacaoTransporte.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'Viagem'
			WizardStepWC.Object = WpOperacaoTransporteAdicionarViagemViagem.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'DocFiscais'
			WizardStepWC.Object = WpOperacaoTransporteAdicionarViagemDocFiscais.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Pagamentos'
			WizardStepWC.Object = WpOperacaoTransporteAdicionarViagemPagamentos.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
		Case &CurrentStepAux = !'Completo'
			WizardStepWC.Object = WpOperacaoTransporteAdicionarViagemCompleto.Create(&Pgmname + !'_Data', &PreviousStep, &GoingBack)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: AssignWizardStepDescription
	WizardStepDescription.Caption = ""
	&StepNumber = 1
	for &WizardStep in &WizardSteps
		if &WizardStep.Code = &CurrentStepAux
			if not &WizardStep.Description.IsEmpty()
				WizardStepDescription.Caption = Format("Step %1/%2 :: %3",&StepNumber.ToString().Trim(),&WizardSteps.Count.ToString().Trim(),&WizardStep.Description)
			endif
		else
			&StepNumber += 1
		endif
	endfor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

//oi
