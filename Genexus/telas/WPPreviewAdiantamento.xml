      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&sdtDeleteMovimentoItem.FromXml(&webSession.Get('DuplicataPagamento'))
	//	&XMLwRITER.Open('PAGAMENTOS.XML')
	//	&XMLwRITER.WriteRawText(&sdtDeleteMovimentoItem.ToXml())
	//	&XMLwRITER.Close()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'CarregaAdiantamento'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&EmpCod    = &SdtPagamentoDuplicataItem.EmpCod
		&auxFilCod = &SdtPagamentoDuplicataItem.FilCod
		&CreCliCod = &SdtPagamentoDuplicataItem.CreCliCod
		&CreCliCodRaz = &SdtPagamentoDuplicataItem.CreCliCodRaz
		&CreCod    = &SdtPagamentoDuplicataItem.CreCod
		&CreDtaEms = &SdtPagamentoDuplicataItem.CreDtaEms
		&CreDtaVct = &SdtPagamentoDuplicataItem.CreDtaVct
		&CreDupNro = &SdtPagamentoDuplicataItem.CreDupNro
		&CrePagDta = &SdtPagamentoDuplicataItem.CrePagDta
		&CrePagTip = &SdtPagamentoDuplicataItem.CrePagTip
		&CrePagVlr = &SdtPagamentoDuplicataItem.CrePagVlr
		&CrePedCod = &SdtPagamentoDuplicataItem.CrePedCod
		&CreRecPag = &SdtPagamentoDuplicataItem.CreRecPag
		&CreVenCod = &SdtPagamentoDuplicataItem.CreVenCod
		&CrePagCod = &SdtPagamentoDuplicataItem.CrePagCod
		Load
	EndFor

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CarregaAdiantamento'

	&SdtPagamentoDuplicata.Clear()
	For &sdtDeleteMovimentoItemItem in &sdtDeleteMovimentoItem
		For each Order EmpCod,FilCod,CreCod,CrePagCod
			Where EmpCod = &auxEmpCod
			Where CreCod = &sdtDeleteMovimentoItemItem.MovCreCod
			Where FilCod = &sdtDeleteMovimentoItemItem.MovCreFilCod
			Where CrePagCod = &sdtDeleteMovimentoItemItem.MovCrePagCod
			
			
			&SdtPagamentoDuplicataItem = new()
			&SdtPagamentoDuplicataItem.EmpCod  = EmpCod
			&SdtPagamentoDuplicataItem.FilCod = FilCod
			
			&auxFilCod = FilCod
			&SdtPagamentoDuplicataItem.CreCod = CreCod
			&SdtPagamentoDuplicataItem.CreCliCod = CreCliCod
			&SdtPagamentoDuplicataItem.CreCliCodRaz = CreCliCodRaz
			
			&SdtPagamentoDuplicataItem.CreDtaEms = CreDtaEms
			&SdtPagamentoDuplicataItem.CreDtaVct = CreDtaVct
			&SdtPagamentoDuplicataItem.CreDupNro = CreDupNro
			&SdtPagamentoDuplicataItem.CrePagDta = CrePagDta
			&SdtPagamentoDuplicataItem.CrePagTip = CrePagTip
			&SdtPagamentoDuplicataItem.CrePagVlr = CrePagVlr
			&SdtPagamentoDuplicataItem.CrePedCod = CrePedCod
			&SdtPagamentoDuplicataItem.CreRecPag = CreRecPag
			&SdtPagamentoDuplicataItem.CreVenCod = CreVenCod
			&SdtPagamentoDuplicataItem.CrePagCod = CrePagCod
			&SdtPagamentoDuplicata.Add(&SdtPagamentoDuplicataItem)
			&CreAdtCreCod = CreCod
			do 'BuscaDuplicataCredito'	

		EndFor	
	EndFor

EndSub

Sub 'BuscaDuplicataCredito'

	For each Order EmpCod,FilCod,CreCod
		Where EmpCod = &auxEmpCod
		Where FilCod = &auxFilCod
		Where CreAdtCreCod = &CreAdtCreCod
		
		&SdtPagamentoDuplicataItem = new()
		&SdtPagamentoDuplicataItem.EmpCod  = EmpCod
		&SdtPagamentoDuplicataItem.FilCod = FilCod
		
		&SdtPagamentoDuplicataItem.CreCod = CreCod
		&SdtPagamentoDuplicataItem.CreCliCod = CreCliCod
		&SdtPagamentoDuplicataItem.CreCliCodRaz = CreCliCodRaz
		&SdtPagamentoDuplicataItem.CreDtaEms = CreDtaEms
		&SdtPagamentoDuplicataItem.CreDtaVct = CreDtaVct
		&SdtPagamentoDuplicataItem.CreDupNro = CreDupNro
		&SdtPagamentoDuplicataItem.CrePedCod = CrePedCod
		&SdtPagamentoDuplicataItem.CreRecPag = CreRecPag
		&SdtPagamentoDuplicataItem.CreVenCod = CreVenCod
		&CrePagVlr = 0
		// SE A DUPLICATA DO TIPO CREDITO FOI UTILIZADA, OU SEJA, SE OUVE PAGAMENTO NÃO PODE DELETAR PELO MOVIMENTO TEM QUE ABRI OS PEDIDOS OU DUPLICATAS ONDE FORAM UTILIZADOS OS CRÉDITO PRIMEIRO.
		For each Order  EmpCod,FilCod,CreCod,CrePagCod
			Where CrePagSts <>  Status_Caixa.Cancelado
			&CrePagVlr += CrePagVlr
			&CrePagDta = CrePagDta
		EndFor
	
		&SdtPagamentoDuplicataItem.CrePagVlr = &CrePagVlr
		If &CrePagVlr > 0
			&SdtPagamentoDuplicataItem.IsDeletaAdiantamento = False //NAO PODE DELETAR POIS OUVE PGTO
		Else
			&SdtPagamentoDuplicataItem.IsDeletaAdiantamento = True //SEM PAGTO PODE DELETAR
		EndIf
		&SdtPagamentoDuplicata.Add(&SdtPagamentoDuplicataItem)
	EndFor

EndSub


