      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbComoSolucionar.Visible= 0
	&SolCod = &parSolCod
	btnImprimir.Visible = 0
	com.ForeColor  = RGB(0,160,40)
	&ProgressLogXml = ''
	txtMsg.Caption = ''
	txtMsg.ForeColor = RGB(210,130,0)
	
	loadWWPContext.Call(&Context)
	
	
	if &DeOndeVem = 'WWMANIFESTACAO' or &DeOndeVem = 'WWMANIFESTACAO1'
		tbBotaoSefazNF.Visible = 0
		tbBotaoSefazMani.Visible = 1
		do 'TableManifestacao'
	Else
		tbBotaoSefazNF.Visible = 1
		tbBotaoSefazMani.Visible = 0
		Do 'TableNota'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Random = Random() * 1000000000
	&ProgressId = 'CnsNFeS' + trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
	&ProgressId = &ProgressId.trim()
	
	If &HttpRequest.Method = HttpMethod.Get
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		RecepcaoNFe.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &NfeCod, &SolCod)
	EndiF
	
	Do 'AttributesSecurityCode'

EndEvent

Event 'DoMonitoraManifestacao'

	if &DeOndeVem = 'WWMANIFESTACAO'
		wwmanifestacao.Link()
	Else
		return
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraNotas'

	Do Case
		Case &DeOndeVem = 'WWNOTAS'
			wwNotas.Link()
		Case &DeOndeVem = 'WWMANIFESTACAO'
			WWManifestacao.Link()
		case &DeOndeVem = 'MONITORANOTASSUPORTE'
			MonitoraNotasSuporte.Link()
		OtherWise
			wwNotasNFCe.Link()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		if NfeArqXml.IsEmpty()
			If ModCod = '65'
				GeraXmlNFeModelo65_4.Call(EmpCod, FilCod, NfeCod, 'N', &Context.PesCod, 'E', &SolCod)
			Else
				GeraXmlNFeModelo55_4.Call(EmpCod, FilCod, NfeCod, 'N', &Context.PesCod, 'E', &SolCod)
			EndIF
		EndIF
		
		GeraPdfDanfe.Call(EmpCod, FilCod, NfeCod, &UrlPDF, &UrlFisico)
		
		RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&ProgressLogXml = '')
		DVPanel_TableAttributes_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributes_Cell.Class = !'col-xs-12'
	EndIf
	If not(&ProgressLogXml <> '')
		DVPanel_PanelRetorno_Cell.Class = !'Invisible'
	Else
		DVPanel_PanelRetorno_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	Do 'AttributesSecurityCode'

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		&ProgressLogXml = ProgressLogXml
		txtMsg.Caption = &ProgressLogXml
		
		prcTrataRetorno.Call('NFE', ProgressLogXml,&erroMensagem)
		Do CAse
			Case not &erroMensagem.IsEmpty()
				tbComoSolucionar.Visible= 1
				txtComoSolucionar.Caption= &erroMensagem
							
			Otherwise
				do 'imprimenota'
		EndCase
		
		Exit
	EndFor
	
	apagaProgress.Submit('', &ProgressId)
	Do 'AttributesSecurityCode'

EndEvent

Sub 'imprimenota'

	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
						
		If not NfeArqXml.IsEmpty() and NfeSts = Status_NFe.Autorizada
			btnImprimir.Visible = 1
		EndIF
		
		Exit
	EndFor

EndSub

Sub 'TableNota'

	For each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		TextBlockTitle.Caption = 'Fazendo a Consulta da Nota no SEFAZ, NF: ' + trim(str(NfeNum))
		Exit
	EndFor

EndSub

Sub 'TableManifestacao'

	For Each Order EmpCod, ManFilCod, ManCod
		Where EmpCod = &EmpCod
		Where ManFilCod = &FilCod
		Where ManCod = &NfeCod
		TextBlockTitle.Caption = 'Fazendo a Consulta da Nota no SEFAZ'
		Exit
	EndFor

EndSub


]]></Source>
