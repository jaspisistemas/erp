        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPIMPORTACBO', Status_SimNao.Sim, 1, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FileUpload1.UploadComplete

	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&selectedURL = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			&ResultadoAbertura = DFrOpen(&selectedURL, 400,'','','ISO-8859-1')  //Tenta abrir o arquivo								
			If &ResultadoAbertura = 0
				Do while &ResultadoNext  = 0 
					&ResultadoLeitura    = DFRGTxt(&CampoUnico,300)
					If &ResultadoLeitura = 0
						
						&CboCod = trim(SubStr(&CampoUnico,1,6))
						&CboNom = trim(SubStr(&CampoUnico,7,100))
						GravaCbo.Call(&Context.EmpCod,&CboCod,&CboNom)
					EndIf
					&ResultadoNext =  DFRNext()                            
				EndDo					
				&resultadoNext = DFRClose()
				MSG('Importação Concluída!')
			Else
				msg('Não Foi Possível Abrir o Arquivo!')
			EndIF
		Else
			msg('Arquivo Inválido!')
		EndIf
	EndFor

EndEvent


]]></Source>
