Event UploadImage.UploadComplete

	// Itera sobre cada arquivo enviado na coleção &UploadedFiles
For &FileUploadData In &UploadedFiles

    // Verifica se o arquivo não está vazio
    If Not &FileUploadData.File.IsEmpty()

        // Define o arquivo atual como fonte para a variável &File
        &File.Source = &FileUploadData.File

        // Obtém a extensão do arquivo (em letras minúsculas para facilitar a comparação)
        &ExtensionVarChar = &FileUploadData.Extension.ToLower()

        // Verifica se a extensão do arquivo é permitida
        If &ExtensionVarChar In ('jpeg', 'jpg', 'png')

            // Verifica se o arquivo existe no sistema de arquivos
            If &File.Exists()

                // Gera um número aleatório para compor o nome único do arquivo
                &Random = Random() * 100000

                // Cria um nome único para o arquivo final, concatenando:
                // - Código da empresa (&EmpCod)
                // - Código da pessoa (&PesCod)
                // - Número aleatório (&Random)
                // - Sufixo "_RUBRICA"
                // - Extensão do arquivo (&ExtensionVarChar)
                &nomeImagemFinal = trim(str(&EmpCod)) + trim(str(&PesCod)) + '_' + trim(str(&Random)) + '_RUBRICA.' + &ExtensionVarChar

                // Define o diretório temporário como fonte para a variável &Directory
                &Directory.Source = &DiretorioTemp

                // Verifica se o diretório temporário existe; se não, cria o diretório
                If Not &Directory.Exists()
                    &Directory.Create()
                EndIf

                // Define o caminho completo do arquivo temporário
                &NovaTempImagem = &DiretorioTemp + &nomeImagemFinal

                // Define o arquivo temporário como fonte para a variável &ImagemFile
                &ImagemFile.Source = &NovaTempImagem

                // Verifica se o arquivo temporário já existe; se existir, exclui o arquivo
                If &ImagemFile.Exists()
                    &ImagemFile.Delete()
                EndIf

                // Fecha o arquivo temporário após a verificação
                &ImagemFile.Close()

                // Copia o arquivo original para o diretório temporário com o novo nome único
                &File.Copy(&NovaTempImagem)

                // Define o nome virtual do arquivo (caminho virtual + nome único do arquivo)
                &NomeVirtual = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + &nomeImagemFinal

                // Processa a rubrica a partir do URL virtual do arquivo
                &PesRub.FromURL(&NomeVirtual)
				If not &PesRub.IsEmpty()
					GravaImagemUsuario.call(&EmpCod, &PesCod,&PesRub)
				EndIf
            Else
                // Se o arquivo não for encontrado, exibe uma mensagem de erro com o caminho absoluto
                Msg(Format("Arquivo não encontrado: %1", &File.GetAbsoluteName()))
            EndIf

        Else
            // Se a extensão do arquivo não for permitida, exibe uma mensagem de erro
            Msg(Format("Extensão de arquivo não permitida: %1", &ExtensionVarChar))
        EndIf

        // Fecha o arquivo após o processamento
        &File.Close()

    Else
        // Se o arquivo estiver vazio ou for inválido, exibe uma mensagem de erro
        Msg("Arquivo vazio ou inválido.")
    EndIf

EndFor

// Limpa as variáveis após o processamento
&UploadedFiles.Clear()
UploadImage.Clear()

EndEvent

Event &IsPodeAlterarSenha.Click

	If &IsPodeAlterarSenha = true
		&IsTrocarSenha = false
	EndIf

EndEvent

Event &IsTrocarSenha.Click

	If &IsTrocarSenha = true
		&IsPodeAlterarSenha = false
	EndIf

EndEvent

Event Enter

	if &IsPodeAdicionar = true
		do 'CheckRequiredFields'
		if &CheckRequiredFieldsResult
			If &mode <> TrnMode.Insert
				&User.Load(&UserId)		
			EndIF
			
			&PasswordIsOK = True
			Do Case
				Case &Mode = TrnMode.Insert or &Mode = TrnMode.Update
					&User.Password = &UserPassword
					&User.FirstName = &UserFirstName
					&User.Name = &UserName
					&User.EMail = &UserEmail
					&User.SecurityPolicyId = &UserSecurityPolicyId
					&User.IsBlocked = &IsBloqueado
					&User.IsActive = &IsAtivo
					&User.CannotChangePassword = &IsPodeAlterarSenha
					&User.MustChangePassword = &IsTrocarSenha
				 
					If &Mode = TrnMode.Insert
						If &UserPassword <> &PasswordConf
							&PasswordIsOK = False
							Msg("A Senha e a Confirmação da Senha não Conferem.")
						Endif
					Endif
					
					If &PasswordIsOK = true
						If &Mode = TrnMode.Insert
							&PesExtCod = geraPesExtCod.Udp()
							GravaPesExtCod.Call(&EmpCod, &PesCod, &PesExtCod)
							
							&User.ExternalId = trim(str(&PesExtCod))
						EndIf
						
						GravaAcesso.Call(&EmpCod, &PesCod,&IsAcessoExterno)
						&User.Password = &UserPassword
						&User.Save()
						
						
						If not &UserEmail.IsEmpty()
							gravaEmailPessoa.Call(&EmpCod, &PesCod, &UserEmail)
						EndiF
					Endif
					
					If not &PesRub.IsEmpty()
						GravaImagemUsuario.call(&EmpCod, &PesCod,&PesRub)
					EndIf
				
					
					
				Case &Mode = TrnMode.Delete
					//				&User.Password = &UserPassword
					//				&User.FirstName = &UserFirstName
					//				&User.Name = &UserName
					//				&User.EMail = &UserEmail
					//				
					//				&User.IsBlocked = &IsBloqueado
					//				&User.IsActive = &IsAtivo
					//				&User.CannotChangePassword = &IsPodeAlterarSenha
					//				&User.MustChangePassword = &IsTrocarSenha
					//				
					//				&User.Password = &UserPassword
					//				
					GravaPesExtCod.Call(&EmpCod, &PesCod, 0)
					//				&User.IsActive = false
					//				&User.IsDeleted = TRUE
					//&User.ExternalId = ''
					&User.Delete()
			EndCase
			
			If &PasswordIsOK = true
				If &User.Success()
					Commit
					return
				Else
					msg('Erro')
					&Errors = &User.GetErrors()
					For &Error in &Errors
						Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
					EndFor
				Endif
			Endif
		endif
	Else
		msg('Limite de usuários atingido, não é possível habilitar novos usuários!')
	Endif

EndEvent

Sub 'AtualizaTotaisUsuarios'

	&IsPodeAdicionar = false
	&QtdMaximo = 0
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		&QtdMaximo = EmpQtdUsu
		Exit
	EndFor

	if &QtdMaximo > 0
		tbRestricaoUsuarios.Visible = 1
		&QtdAtivos = 0
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where not PesExtCod.IsEmpty() and not PesExtCod.IsNull()
			&AuxPesExtCod = PesExtCod
			&verificaIsAtivo = false
			do 'getUsuariosGAMverifica'
			if &verificaIsAtivo = true and &PesCod = PesCod
				&IsPodeAdicionar = true
			Endif
		
		EndFor
		
		txtQtdUtilizada.Caption = Format('ATIVOS: %1 MÁX.: %2', padl(trim(toformattedString(&QtdAtivos)),2,'0'), padl(trim(toformattedString(&QtdMaximo)),2,'0'))
		Do CAse
			CAse &QtdAtivos = &QtdMaximo
				txtQtdUtilizada.ForeColor = RGB(255,100,50)
			CAse &QtdAtivos > &QtdMaximo
				txtQtdUtilizada.ForeColor = RGB(255,0,0)
			Otherwise
				&IsPodeAdicionar = true
				txtQtdUtilizada.ForeColor = RGB(0,150,255)
		EndCAse
			
	Else
		tbRestricaoUsuarios.Visible = 0
		&IsPodeAdicionar = true
	Endif

EndSub

Sub 'getUsuariosGAMverifica'

	&verificaFilter.AuthenticationTypeName	= ''
	&verificaFilter.ReturnAnonymousUser 	= false
	&verificaFilter.ExternalId = trim(str(&AuxPesExtCod))
	
	For &verificaUser in GAMRepository.GetUsersOrderBy(&verificaFilter, GAMUserListOrder.None, &verificaErrors)		
		If &verificaUser.IsActive = true and &verificaUser.IsBlocked <> true
			&QtdAtivos += 1
			&verificaIsAtivo = true
		Endif
		
		Exit
	EndFor

EndSub

Sub 'getDadosUsuario'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		If not PesRub.IsEmpty()
			&PesRub = PesRub
		Else
			&PesRub.FromImage(FilialSemImagem) 
		EndIf

		
		&UserFirstName = trim(PesRaz)
		&IsAcessoExterno = PesExtAcs
		if &Mode = TrnMode.Insert
			For Each Order EmpCod, PesCod, PesEmlCod
				&UserEmail = PesEml
				
				Exit
			EndFor
		EndIF
	
		Exit
	EndFor

EndSub


