      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WWPContext)
	if &WWPContext.Old_Perfil <> 3
		Dashboard.Link()
	EndIf

	&ConnectionName = &pConnectionName
	&ConnectionName.SetFocus()
	&ConnectionName.Enabled 	= False
	&UserName.Enabled			= False
	TblConnKeys.Visible			= False
	If &Mode = TrnMode.Insert
		&ConnectionName.Enabled 	= True
		&UserName.Enabled	  		= True
	Else
		&GAMRepositoryConnection.Load(&ConnectionName)
		&UserName	  	= &GAMRepositoryConnection.UserName
		&UserPassword	= &GAMRepositoryConnection.UserPassword
		&EncryptionKey	= &GAMRepositoryConnection.Key
	Endif
	If &Mode = TrnMode.Update
		&UserName.Enabled	  	= True
	Endif
	If &Mode = TrnMode.Delete
		BtnEnter.Caption 		= ActionTexts.Delete
	Endif
	If &Mode = !"KEY"
		Form.Caption				= Format("WWP_GAM_ConnectionKeyList", &ConnectionName.ToUpper())
		TblMainData.Visible			= False
		TblConnKeys.Visible			= True
		&ConnectionFileXML.Visible	= False
		&FileConnectionKey.Visible	= False
	Else
		Form.Caption = "WWP_GAM_Connections"
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&FileConnectionKey.Visible = False
	&pConnectionName.Visible = False
	GridWWSysConns.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridWWSysConns.Load

	&isOk = GeneXusSecurity.GAM.GetConnectionKey(&CurrentConnectionKey)
	&hasCurrentKey = False
	For &GAMSystemConnection in &GAMRepositoryConnection.GetKeys(&Errors)
		&ConnectionKey		= &GAMSystemConnection.Key
		If &GAMSystemConnection.Key.Trim() = &CurrentConnectionKey.Trim()
			&hasCurrentKey 	= True
			&isCurrentKey	= "WWP_GAM_Current"
		Else
			&isCurrentKey	= ""
		Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&ConnectionFile = !'<i class="fa fa-file"></i>'
	
	&DeleteConnection = !'<i class="fa fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		GridWWSysConns.Load()
	EndFor
	If &hasCurrentKey
		BtnUseCurrentKey.Visible = False
	Endif

EndEvent

Event 'DoUACancel'

	GAMWWConnections()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUseAutomaticKey'

	&GXGUID = GUID.NewGuid()
	&NewConnectionKey = &GXGUID.ToString().Trim()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUseCurrentKey'

	&isOk = GeneXusSecurity.GAM.GetConnectionKey(&CurrentConnectionKey)
	&NewConnectionKey = &CurrentConnectionKey.Trim()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSaveKey'

	If GeneXusSecurity.GAM.AddConnectionToFileKey(&NewConnectionKey, &ConnectionName, &Errors)
		GAMConnectionEntry(!"KEY", &pConnectionName)
	Else
		Do 'DisplayMessages'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGenKey'

	&EncryptionKey = GetEncryptionKey()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckSecurityForActions'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not (&Mode = TrnMode.Insert Or &Mode = TrnMode.Update)
		BtnEnter.Visible = False
	Endif
	 
	If not (&Mode = TrnMode.Insert Or &Mode = TrnMode.Update)
		BtnGenKey.Visible = False
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&Mode = TrnMode.Insert Or &Mode = TrnMode.Update)
		&UserPassword.Visible = False
		UserPassword_Cell.Class = !'Invisible'
	Else
		&UserPassword.Visible = True
		UserPassword_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&Mode = TrnMode.Insert Or &Mode = TrnMode.Update)
		&EncryptionKey.Visible = False
		EncryptionKey_Cell.Class = !'Invisible'
		TextBlockEncryptionKey_Cell.Class = !'Invisible'
	Else
		&EncryptionKey.Visible = True
		EncryptionKey_Cell.Class = !'MergeDataCell'
		TextBlockEncryptionKey_Cell.Class = !'col-sm-3 MergeLabelCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	&GAMRepositoryConnection.Load(&ConnectionName)	
	Do Case
	Case &Mode = TrnMode.Insert or &Mode = TrnMode.Update
		&GAMRepositoryConnection.UserName 			= &UserName
		&GAMRepositoryConnection.UserPassword		= &UserPassword
		&GAMRepositoryConnection.Key				= &EncryptionKey
		&GAMRepositoryConnection.Save()
		If &GAMRepositoryConnection.Success()
			Commit
			Return
		Else
			&Errors = &GAMRepositoryConnection.GetErrors()
			Do 'DisplayMessages'
		Endif
	
	Case &Mode = TrnMode.Delete
		&GAMRepositoryConnection.Delete()
		If &GAMRepositoryConnection.Success()
			Commit
			GAMWWConnections()
		Else
			&Errors = &GAMRepositoryConnection.GetErrors()
			Do 'DisplayMessages'
		Endif

	EndCase

EndEvent

Event 'WWConnKeys'

	GAMConnectionEntry(!"KEY", &pConnectionName)

EndEvent

Event &DeleteConnection.Click

	If GeneXusSecurity.GAM.DeleteConnectionFromFileKey(&ConnectionKey, &ConnectionName, &Errors)
		GAMConnectionEntry(!"KEY", &pConnectionName)
	Else
		Do 'DisplayMessages'
	Endif

EndEvent

Event &ConnectionFile.Click

	If &FileConnectionKey = &ConnectionKey
		&FileConnectionKey.SetEmpty()
		&ConnectionFileXML.Visible = False
	Else
		&FileConnectionKey	= &ConnectionKey
		&ConnectionFileXML.Visible = True
		&ConnectionFileXML.SetEmpty()
		GeneXusSecurity.GAM.GetConnectionXMLfromFileKey(&ConnectionName, &ConnectionKey, &FileXML, &Errors)
		If &Errors.Count = 0
			&ConnectionFileXML 	= &FileXML
		Else
			Do 'DisplayMessages'
		Endif
	Endif

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		If &Error.Code <> GAMErrorMessages.SessionExpired
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		Endif
	EndFor

EndSub


]]></Source>
