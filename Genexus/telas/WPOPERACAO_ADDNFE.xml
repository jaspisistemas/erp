      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &OpeNfeCod <> 0
		Do 'GetNota'
	Else
		&OpeNfeUndMed 		= PefServiceUnidadeDeMedidaDaMercadoria.Kg
		&OpeNfeTipCal 		= PefServiceViagemTipoDeCalculo.SemQuebra
		&OpeNfeQtdMerEmb 	= 0
		&OpeNfeTolPerTip 	= PefServiceTipoToleranciaDePerdaDeMercadoria.Nenhum
		&OpeNfeTolPerVlr 	= 0
		&OpeNfeDta			= &Today
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&OpeNfeCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	If 1 = 2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &OpeNfeNcm.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','NCM predominante de NF-e'), DVMessageType.error, &OpeNfeNcm.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OpeNfeNro.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nro. NF-e'), DVMessageType.error, &OpeNfeNro.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OpeNfeSer.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Série'), DVMessageType.error, &OpeNfeSer.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &OpeNfeVlrTot.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Valor  NF-e'), DVMessageType.error, &OpeNfeVlrTot.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Else
		&CheckRequiredFieldsResult = True
		If &OpeNfeNcm.IsEmpty()
			Msg('NCM predominante da NF-e é obrigatório.')
			&CheckRequiredFieldsResult = False
		EndIf
		If &OpeNfeNro.IsEmpty()
			Msg('Nro. da NF-e é obrigatório.')
			&CheckRequiredFieldsResult = False
		EndIf
		If &OpeNfeSer.IsEmpty()
			Msg('Série da NF-e é obrigatória.')
			&CheckRequiredFieldsResult = False
		EndIf
		If &OpeNfeVlrTot.IsEmpty()
			Msg('Valor NF-e é obrigatório.')
			&CheckRequiredFieldsResult = False
		EndIf
	
		If &OpeNfeTipCal <> PefServiceViagemTipoDeCalculo.SemQuebra And (&OpeNfeVlrUni.IsEmpty() or &OpeNfeVlrUni = 0)
			Msg('O valor por Unidade, quando a quebra, é obrigatório.')
			&CheckRequiredFieldsResult = False
		EndIf
	EndIf

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	10
	do 'CheckRequiredFields'
	Do case
		Case &CheckRequiredFieldsResult = False
			msg("Dados obrigatório, Verifique!")
		Case not &OpeNfeChv.Trim().IsEmpty() and &IsErro = True
			Msg("Chave da NF-e inválida, Verifique!")
		OtherWise
			Ope_Nfe.Call('ADD', &EmpCod, &FilCod,&OpeCod,&OpeNfeCod,&OpeNfeChv,&OpeNfeNcm,&OpeNfeNro,&OpeNfeSer,&OpeNfeVlrTot,&OpeNfeVlrUni,&OpeNfeUndMed,&OpeNfeTipCal,
			&OpeNfeQtdMerEmb,&OpeNfeTolPerTip,&OpeNfeTolPerVlr,&OpeNfeDta)
			WWPActions.WCPopup_Close('')
	EndCase

EndEvent

Event &OpeNfeChv.IsValid

	If not &OpeNfeChv.Trim().IsEmpty()
		ValidaChaveNota.Call(&OpeNfeChv,&IsErro)
		
		If &IsErro = false
			&OpeNfeNro = Val(SubStr(&OpeNfeChv,26,9))
	        &OpeNfeSer = substr(&OpeNfeChv,23,3)
		Endif
	EndIf

EndEvent

Event &OpeNfeNcm.ControlValueChanged

	Do 'GetNCM'

EndEvent

Sub 'GetNota'

	for each Order EmpCod, FilCod, OpeCod,OpeNfeCod
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		Where OpeNfeCod = &OpeNfeCod
		
		&OpeNfeChv 			= OpeNfeChv
		&OpeNfeNro 			= OpeNfeNro
        &OpeNfeSer 			= OpeNfeSer
		&OpeNfeDta			= OpeNfeDta
		&OpeNfeVlrTot		= OpeNfeVlrTot	
		&OpeNfeVlrUni 		= OpeNfeVlrUni		
		&OpeNfeNcm 			= OpeNfeNcm
		Do 'GetNCM'
		&OpeNfeUndMed 		= OpeNfeUndMed
		&OpeNfeTipCal 		= OpeNfeTipCal
		&OpeNfeQtdMerEmb 	= OpeNfeQtdMerEmb
		&OpeNfeTolPerTip 	= OpeNfeTolPerTip
		&OpeNfeTolPerVlr 	= OpeNfeTolPerVlr
		Exit
	EndFor

EndSub

Sub 'GetNCM'

	For Each Order NcmCod, NcmDes
		Where NcmCod 	= &OpeNfeNcm
		
		&AuxNcmDes 		= NcmDes
		
		Exit
	When None
		&AuxNcmDes		= 'Código NCM não cadastrado.'
		
	EndFor

EndSub


]]></Source>
