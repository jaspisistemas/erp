Event &addEmitente.Click

	&EmpCod = EmpCod
	&CteCod = CteCod
	&tipo = 'REM'
	
	&sdtPessoa.Clear()
	&webSession.Remove('NOVAPESSOA')
	
	Do 'CarregaPessoaCte' 
	wpNovaPessoa.Popup('CLI', 0, '')
	wpCteIMportados.Link('')

EndEvent

Event &addDestinatario.Click

	&EmpCod = EmpCod
	&CteCod = CteCod
	&tipo = 'DES'
	
	&sdtPessoa.Clear()
	&webSession.Remove('NOVAPESSOA')
	
	Do 'CarregaPessoaCte' 
	wpNovaPessoa.Popup('CLI', 0, '')
	wpCteIMportados.Link('')

EndEvent

Sub 'CarregaPessoaCte'

	For each Order EmpCod,CteCod
		Where EmpCod = &EmpCod
		Where CteCod = &CteCod
		
		Do Case
			Case &tipo = 'REM'
				&sdtPessoa.Clear()
				&sdtPessoaItem.PesRaz = CteRemRaz
				If not CteRemCnpj.IsEmpty()
					&sdtPessoaItem.PesCnpj = CteRemCnpj
					&sdtPessoaItem.PesTip = tipoPessoa.JURIDICA
				Else
					&sdtPessoaItem.PesCpf = CteRemCpf
					&sdtPessoaItem.PesTip = tipoPessoa.FISICA
				EndIf
				
				&sdtPessoaItem.PesBai = CteRemBai
				&sdtPessoaItem.PesCep = CteRemCep
				&sdtPessoaItem.PesCidCod = CteRemCidCod
				&sdtPessoaItem.PesFonNum = CteRemFon
				&sdtPessoaItem.PesinsEst = CteRemIns
				&sdtPessoaItem.PesLog = CteRemLog
				&sdtPessoaItem.Pesnro = CteRemNro
				&sdtPessoa.Add(&sdtPessoaItem)
			Case &tipo = 'DES'
				&sdtPessoa.Clear()
				&sdtPessoaItem.PesRaz = CteDesRaz
				If not CteDesCnpj.IsEmpty()
					&sdtPessoaItem.PesCnpj = CteDesCnpj
					&sdtPessoaItem.PesTip = tipoPessoa.JURIDICA
				Else
					&sdtPessoaItem.PesCpf = CteDesCpf
					&sdtPessoaItem.PesTip = tipoPessoa.FISICA
				EndIf
				
				&sdtPessoaItem.PesBai = CteDesBai
				&sdtPessoaItem.PesCep = CteDesCep
				&sdtPessoaItem.PesCidCod = CteDesCidCod
				&sdtPessoaItem.PesFonNum = CteDesFon
				&sdtPessoaItem.PesinsEst = CteDesIns
				&sdtPessoaItem.PesLog = CteDesLog
				&sdtPessoaItem.Pesnro = CteDesNro
				&sdtPessoa.Add(&sdtPessoaItem)
		EndCase
	
		Exit
	EndFor
	&webSession.Set('NOVAPESSOA', &sdtPessoa.ToXml())

EndSub

