        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridRecordCount = grid.RecordCount
	&GridCurrentPage = grid.CurrentPage

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&addEmitente.FromImage(iconAmarelo)
	&addEmitente.TooltipText = ""
	
	&AddDestinatario.FromImage(iconAmarelo)
	&AddDestinatario.TooltipText = ""
	
	&AddExpedidor.FromImage(iconAmarelo)
	&AddExpedidor.TooltipText = ""
	
	&AddRecebedor.FromImage(iconAmarelo)
	&AddRecebedor.TooltipText = ""
	
	&AddTomador.FromImage(iconAmarelo)
	&AddTomador.TooltipText = ""

	Do Case
		Case CteSts = Status_NFe.Digitando
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case CteSts = Status_NFe.Autorizada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case CteSts = Status_NFe.Cancelada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case CteSts = Status_NFe.Denegada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfoLight WWColumnTagInfoLightSingleCell'
		Case CteSts = Status_NFe.Inutilizada
			CteSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Otherwise
			CteSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If CteRemCod.IsEmpty() and CteModCod = '57'
		&addEmitente.FromImage(IconVermelho)
		&addEmitente.TooltipText = "Adicionar Remetente"
	Else
		&addEmitente.Link = verCliente.Link('DashBoard', EmpCod, CteRemCod)
		&addEmitente.FromImage(iconVerde)
		&addEmitente.TooltipText = "Remetente Cadastrado"
	EndIF
	
	If CteDesCod.IsEmpty() and CteModCod = '57'
		&addDestinatario.FromImage(IconVermelho)
		&addDestinatario.TooltipText = "Adicionar Destinatário"
	Else
		&addDestinatario.Link = verCliente.Link('DashBoard', EmpCod, CteDesCod)
		&addDestinatario.FromImage(iconVerde)
		&addDestinatario.TooltipText = "Remetente Cadastrado"
	EndIF

	If CteTomCod.IsEmpty() and CteModCod = '57'
		&addTomador.FromImage(IconVermelho)
		&addTomador.TooltipText = "Adicionar Tomador"
	Else
		&addTomador.Link = verCliente.Link('DashBoard', EmpCod, CteTomCod)
		&addTomador.FromImage(iconVerde)
		&addTomador.TooltipText = "Tomador Cadastrado"
	EndIF

	If CteRecCod.IsEmpty() and CteRecRaz.Trim().IsEmpty() and CteModCod = '57'
		&addRecebedor.FromImage(IconVermelho)
		&addRecebedor.TooltipText = "Adicionar Recebedor"
	Else
		&addRecebedor.Link = verCliente.Link('DashBoard', EmpCod, CteRecCod)
		&addRecebedor.FromImage(iconVerde)
		&addRecebedor.TooltipText = "Recebedor Cadastrado"
	EndIF

	If CteExpCod.IsEmpty() and CteExpRaz.Trim().IsEmpty() and CteModCod = '57'
		&addExpedidor.FromImage(IconVermelho)
		&addExpedidor.TooltipText = "Adicionar Expedidor"
	Else
		&addExpedidor.Link = verCliente.Link('DashBoard', EmpCod, CteExpCod)
		&addExpedidor.FromImage(iconVerde)
		&addExpedidor.TooltipText = "Expedidor Cadastrado"
	EndIF

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	wpimportaxmlcte.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSelecionar'

	For Each line in grid
		&IsGravarNotas = true
		If CteRemCod.IsEmpty() or (CteDesCod.IsEmpty() and CteModCod <> '57') or CteTomCod.IsEmpty()
			&IsGravarNotas = false
		EndIF
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	For Each Line in Grid
		If &IsGravarNotas = true
			//GRAVA NOTA 
			GravaCteImportado.call(EmpCod,FilCod,CteCod)
		EndiF
	EndFor

