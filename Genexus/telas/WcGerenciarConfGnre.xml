        <Source><![CDATA[Parm(In:&Mode, In:&parmEmpCod, In:&parmFilCod, In:&parmGnreConUfeCod, In:&parmGnreConRecCod, In:&parmCodigo, In:&parmDescricaoAntigo, In:&Tipo);
