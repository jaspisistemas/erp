      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do Case 
		Case &Mode = 'DLT'
			TbAlterar.Visible 		= 0
			Do 'HabilitaCampos'
			
		OtherWise
			tbTxtExcluir.Visible 	= 0
			Do 'HabilitaCampos'
	EndCase

EndEvent

Event 'DoConfirmar'

	Do Case 
		Case &Mode = 'DLT'
			prcGerenciarConfGnre.Call('DLT', &Tipo, &parmEmpCOD, &parmFilCod, &parmGnreConUfeCod, &parmGnreConRecCod, &parmCodigo, '')
		OtherWise
			prcGerenciarConfGnre.Call('UPD', &Tipo, &parmEmpCOD, &parmFilCod, &parmGnreConUfeCod, &parmGnreConRecCod, &parmCodigo, &Descricao)
	EndCase

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'HabilitaCampos'

	Do Case 
		Case &Tipo = 'REC'
			TbItensLocais.Visible 	= 0
			&Descricao.Caption 		= 'Descrição da Receita:'
		Case &Tipo = 'DET'
			&parmCodigo.Caption 			= 'Código do Detalhamento:'
			&parmDescricaoAntigo.Caption 	= 'Atual descrição do Detalhamento:'
			&Descricao.Caption 				= 'Descrição do Detalhamento:'
		Case &Tipo = 'PRO'
			&parmCodigo.Caption 			= 'Código do Produto:'
			&parmDescricaoAntigo.Caption	= 'Atual descrição do Produto:'
			&Descricao.Caption 				= 'Descrição do Produto:'
		Case &Tipo = 'DOC'
			&parmCodigo.Caption				= 'Código do Doc. Origem:'
			&parmDescricaoAntigo.Caption	= 'Atual descrição do Doc. Origem:'
			&Descricao.Caption 				= 'Descrição do Doc. Origem:'
	EndCase

EndSub


]]></Source>
