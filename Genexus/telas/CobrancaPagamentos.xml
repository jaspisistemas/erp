      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPagmento_Empowerer.GridInternalName = GridPagmento.InternalName
	GridPagmento.Rows = 5
	&GridPagmentoCurrentPage = 1
	&GridPagmentoCurrentPage.Visible = False
	&GridPagmentoPageCount = -1
	GridPagmentoPaginationBar.RowsPerPageSelectedValue = GridPagmento.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&GridPagmentoCurrentPage = GridPagmento.CurrentPage
	&GridPagmentoPageCount = GridPagmento.PageCount
	&GridPagmentoRecordCount = GridPagmento.RecordCount

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPagmentoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPagmento.Load

		&CrePagDta = CrePagDta
		&CrePagVlr = CrePagVlr
		&CrePagVlrDsc = CrePagVlrDsc
		&CrePagVlrJur = CrePagVlrJur
		
		&CreMovPlanNom = CreMovPlanNom

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPagmentoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPagmentoPaginationBar.SelectedPage = !'Previous'
			&GridPagmentoCurrentPage -= 1
			GridPagmento.PreviousPage()
		Case GridPagmentoPaginationBar.SelectedPage = !'Next'
			&GridPagmentoCurrentPage += 1
			GridPagmento.NextPage()
		Otherwise
			&PageToGo.FromString(GridPagmentoPaginationBar.SelectedPage)
			&GridPagmentoCurrentPage = &PageToGo
			GridPagmento.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPagmentoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridPagmento.Rows = GridPagmentoPaginationBar.RowsPerPageSelectedValue
	&GridPagmentoCurrentPage = 1
	GridPagmento.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
