      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	com.ForeColor  = RGB(0,160,40)
	com1.ForeColor = RGB(0,160,40)
	&ProgressLogXml = ''
	txtMsg.Caption = ''
	txtMsg.ForeColor = RGB(210,130,0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&Context)

	&ProgressId = 'autoriMDFe' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
	&ProgressId = &ProgressId.trim()
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
		
	RecepcaoNFe.Submit('RecepcaoNFe', &ProgressId, &EmpCod, &FilCod, &MDFeCod, &SolCod)
	EmbPage1.Visible = 0
	BTnBtn2.Visible = 0
	BTnBtn3.Visible = 0
	btnAjuda.Link = 'https://ajuda.jaspi.com.br/index.aspx?cedf9ab0-794d-4981-b397-2525bba5b9a6'
	btnAjuda.LinkTarget = '_blank'

EndEvent

Event 'DoBtn2'

	EmbPage1.Source = ''
	
		wwMDFE.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'Dobtn3'

	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		
		&RandomVarchar = retornaSoNumeros.Udp(serverTime())
		&Documento =  'TICKET' + &RandomVarchar.Trim()
		RCOOpenWindow1.LinkOpen =  RELJAS013_toScreen.Link(EmpCod, FilCod, MDFeCod, &Documento)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&ProgressLogXml = '')
		DVPanel_TableAttributes_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributes_Cell.Class = !'col-xs-12'
	EndIf
	If not(&ProgressLogXml <> '')
		DVPanel_Retorno_Cell.Class = !'Invisible'
	Else
		DVPanel_Retorno_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId

	
		BTnBtn2.Visible = 1
		
		&ProgressLogXml = ProgressLogXml
		txtMsg.Caption = &ProgressLogXml
		do 'imprimenota'
		Exit
	EndFor
	
	Do 'AttributesSecurityCode'

EndEvent

Sub 'imprimenota'

	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		
		If not MDFeArqXml.IsEmpty() and MDFeSts = Status_MDFe.Autorizado
			BTnBtn3.Visible = 1
			&Window.Url = RELJAS013_ToScreen.Link(EmpCod, FilCod, MDFeCod, &URLFisico)
			&Window.Height = 800
			&Window.Width = 800
			&Window.Open()
		EndIF
		
		Exit
	EndFor

EndSub


]]></Source>
