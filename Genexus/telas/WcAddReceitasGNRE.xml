	Do Case 
		Case &Tipo = 'REC'
			&Codigo.Caption 	= 'Código da Receita:'
			&Descricao.Caption 	= 'Descrição da Receita:'
		Case &Tipo = 'PRO'
			&Codigo.Caption		= 'Código do Produto:'
			&Descricao.Caption	= 'Descrição do Produto:'
		Case &Tipo = 'DET'
			&Codigo.Caption		= 'Código do Detalhamento:'
			&Descricao.Caption	= 'Descrição do Detalhamento:'
		Case &Tipo = 'DOC'
			&Codigo.Caption	 	= 'Código do Doc. Origem:'
			&Descricao.Caption	= 'Descrição do Doc.Origem:'
	EndCase

EndEvent

