      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPANEXOSPEDIDO', Status_SimNao.Sim, 2, &AutNiv)
	
	retornaAutorizacao.Call('WWTIPOSANEXOS', Status_SimNao.Nao, 2, &AutorizadoTiposAnexos)

	txtTipos.LinkTarget = '_blank'
	txtTipos.Link = wwtiposAnexos.Link()
	
	loadWWPContext.Call(&Context)
	&PedAnxTipCod.Clear()
	&PedAnxTipCod.AddItem(0, 'INFORME TIPO DOCUMENTO')
	For Each Order EmpCod, TpaOrd, TpaNom
		Where EmpCod = &Context.EmpCod
		Where TpaPed = true
		&PedAnxTipCod.AddItem(TpaCod, TpaNom)
	When none
		retornaCodigoTipoDocumento.call(&Context.EmpCod, &TpaCod)
		&PedAnxTipCod.AddItem(&TpaCod, 'OUTROS TIPOS')
	EndFor	
	
	
	&AddPedAnxCod = &PedAnxCod
	For Each Order EmpCod, FilCod, PedCod, PedAnxCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedAnxCod = &PedAnxCod
		&PedAnxTipCod = PedAnxTipCod
		&PedAnxDsc = PedAnxDsc
		
		&PedAnxMod = PedAnxMod
		Exit
	When none
		&PedAnxTipCod.SetEmpty()
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGravar'

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = true
		If &PedAnxArq.IsEmpty() and &AddPedAnxCod = 0
			Msg('Arquivo é obrigatório.')
			&CheckRequiredFieldsResult = False
		Else
			
			GravaAnexoPedido.Call('ADD', &EmpCod, &FilCod, &pedCod, &AddPedAnxCod, &PedAnxTipCod, &PedAnxDsc, &PedAnxArq)
			msg('Anexo Salvo com sucesso!')
			&PedAnxDsc.SetEmpty()
			&PedAnxArq.SetEmpty()
			&PedAnxDsc.SetFocus()
			&AddPedAnxCod.SetEmpty()
		EndIF
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &PedAnxTipCod.IsEmpty()
		Msg('Tipo Anexo é obrigatório.')
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If &PedAnxTipCod.IsEmpty() or &PedAnxTipCod = 0
		Msg('Tipo Anexo é obrigatório.')
		&CheckRequiredFieldsResult = False
	EndIf

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbTiposAnexo.Visible = (&AutorizadoTiposAnexos > 2)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


