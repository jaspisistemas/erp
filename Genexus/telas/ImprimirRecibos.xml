        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&sdtRecibo.Clear()
	For each Order EmpCod,RcbDta,RcbCod
		Where EmpCod = &EmpCod
		Where RcbDstCod = &PesCod when &PesCod <>0
		Where RcbDta >= &RcbDtaIni and RcbDta <= &RcbDtaFim
		&sdtReciboItem = new()
		&sdtReciboItem.EmpCod = EmpCod
		&sdtReciboItem.RcbCod = RcbCod
		&sdtRecibo.Add(&sdtReciboItem)
		
	Endfor
	If &sdtRecibo.Count >0 
		&WebSession.Set('ReciboImp',&sdtRecibo.ToXml())
		&ServerTime = ServerTime()
		RCOOpenWindow1.LinkOpen = RELJAS020.Link(&ServerTime,'AVULSO')
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		Msg('ATENÇÃO,Nenhum recibo encontrado para o período!')
	EndiF

EndEvent

Event &PesCod.IsValid

	Do 'GetPessoa'

EndEvent

Sub 'GetPessoa'

	If &PesCod = 0
		&PesRaz = 'Todos os Clientes'
	Else
		
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			&PesRaz = PesRaz
			Exit
		When none
			&PesRaz = 'Nenhum cliente encontrado'
			&PesCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
