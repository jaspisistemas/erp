      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'
	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'Capa'
	&WizardStep.Title = 'Capa NFS-e'
	&WizardStep.Description = 'Capa NFS-e'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'DadosNFSE'
	&WizardStep.Title = 'Dados NFS-e'
	&WizardStep.Description = 'Dados NFS-e'
	&WizardSteps.Add(&WizardStep)

	If &NfsTipNF <> 'S'
		&WizardStep = new()
		&WizardStep.Code = !'Itens'
		&WizardStep.Title = 'Itens NFS-e'
		&WizardStep.Description = 'Itens NFS-e'
		&WizardSteps.Add(&WizardStep)
	EndIf

	&WizardStep = new()
	&WizardStep.Code = !'Totais'
	&WizardStep.Title = 'Totais'
	&WizardStep.Description = 'Totais'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Transmitir'
	&WizardStep.Title = 'Transmitir'
	&WizardStep.Description = 'Transmitir'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'Capa'
		&WebSession.Remove(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim())
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	&SessionGuidAux = iif(&SessionGuid.IsEmpty(), GUID.NewGuid(), &SessionGuid)
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsUnderlineWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraNFSe'

	wwNotasServico.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'Capa'
			WizardStepWC.Object = wpNFSCapa.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'DadosNFSE'
			WizardStepWC.Object = wpNFSDadosNFSE.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'Itens'
			WizardStepWC.Object = wpNFSItens.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'Totais'
			WizardStepWC.Object = wpNFSTotais.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'Transmitir'
			WizardStepWC.Object = wpNFSTransmitir.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim()))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&NfsTipNF = 'S'
	For Each Order EmpCod, NfsCod
		Where EmpCod = &WizardData.Capa.EmpCod
		Where NfsCod = &WizardData.Capa.NfsCod
		
		&NfsTipNF = NfsTipNF
		Exit
	EndFor

EndSub


]]></Source>
