      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	ItemCostura.Object = wcOrdemCostura_item.Create(&EmpCod, &OcsCod)
	do 'LoadCostura'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWOrdemCostura.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCapa'

	OrdCostura_capa.Link(&EmpCod, &OcsCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpImprimeFicha.PopUp(&EmpCod, &OcsCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLimpar'

	OrdCostura_item.Link(&EmpCod, &OcsCod, 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	do 'LocalizaProduto'

EndEvent

Event Enter

	Do Case
		Case &OcsProNroCor.IsEmpty()
			msg('Informe Código do Corte!')
			&OcsProNroCor.SetFocus()
			
		case &ProNomGra.IsEmpty()
			msg('Informe Descrição Produto!')
			&ProNomGra.SetFocus()
		Case &OcsQtd < &maiorAptQtd and &maiorAptQtd > 0
			msg('Corte já possui lançamentos, e por isso não pode ter quantidade menor que: ' + trim(toformattedString(&maiorAptQtd)))
			&OcsQtd.SetFocus()
		Otherwise
			prcOrdCostura_item.Call(&EmpCod, &OcsCod, &OcsItm, &PrOCod, &ProGraCod, &OcsQtd, &OcsNfeProItem, &ProNomGra, &OcsProNroCor)
			ItemCostura.Refresh()
			do 'limpaCampos'
			&ProRef.SetFocus()
	EndCase

EndEvent

Sub 'LoadCostura'

	&maiorAptQtd.SetEmpty()
	
	For Each Order EmpCod, OcsCod
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod

		&OcsCliCod = OcsCliCod
		
		For Each Order EmpCod, OcsCod, OcsItm
			Where OcsItm = &parOcsItm
			&ProRef 		= OcsProGraRef
			&OcsQtd 		= OcsQtd
			&OcsItm 		= OcsItm
			&ProNomGra 		= OcsProGraNom
			&OcsProNroCor 	= OcsProNroCor
			&OldProCod 		= OcsProCod
			&maiorAptQtd	= OcsMaioQTd
			Exit
		EndFor
		
		Exit
	When None
		wwOrdemCostura.Link()
	EndFor
	
	RetornaNomePessoa.Call(&EmpCod, &OcsCliCod, &PesRaz)

EndSub

Sub 'limpaCampos'

	&OcsNfeProItem.SetEmpty()
	&OcsItm.SetEmpty()
	&ProRef.SetEmpty()
	&ProCod.SetEmpty()
	&ProGraCod.setEmpty()
	&ProNomGra.SetEmpty()
	&OcsQtd.SetEmpty()
	&OldProCod.SetEmpty()
	&maiorAptQtd.SetEmpty()

EndSub

Sub 'localizaProduto'

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &AuxProNomGra, &IsAChouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ProdutoMensagem)
	if &OldProCod <> &ProCod or &ProNomGra.IsEmpty()
		&ProNomGra = &AuxProNomGra
	Endif
	 &OldProCod = &ProCod

EndSub


]]></Source>
