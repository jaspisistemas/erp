      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	PnGeral.Width = 900
	PnGeral.Height = 100

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&IsSemDuplicata = False
	For Each ORder EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where CreCod = &CreCod
		if CreSts = Status_Duplicata.CANCELADA
			
			If not CreCheCod.IsEmpty() and not CreCheCod.IsNull()
				ChequeTerceiros_AlteraStatus.Call(EmpCod, CreCheCod, MotivoCheque.CANCELADO)
			Endif
			
			return
			
		EndIF
		
		If CreFrpPgtoTip = TipoDuplicata.CHEQUEP or CreFrpPgtoTip = TipoDuplicata.CHEQUET
			TxtCancelar.Caption = 'ATENÇÃO! Esta duplicata é do tipo CHEQUE, Nro.:' + trim(CreDupNro) + ' CLI/FOR.:' + trim(CreCliRaz)+', se cancelar essa duplicata, o cheque será excluido!'
		Else
			TxtCancelar.Caption = 'Deseja cancelar a duplicata Nro.:' + trim(CreDupNro) + ' CLI/FOR.:' + trim(CreCliRaz)+ ' e a GNRE de Recibo: '+ Trim(&GNRENumRec)+ ' ?'
		EndIf
		Exit
		
	When None
		
		TxtCancelar.Caption = 'Deseja cancelar, apenas a GNRE, de Recibo: '+ Trim(&GNRENumRec) + '?'
		&IsSemDuplicata = True
		
	EndFor

EndEvent

Event Enter

	If &IsSemDuplicata = False
		CancelarDuplicata.call(&EmpCod,&FilCod,&CreCod, &Mensagem)
		if &Mensagem.IsEmpty()
			prcDeletaGNRE.Call(&EmpCod, &FilCod, &GNRENumRec)
			Return
		Else
			msg(&Mensagem)
		EndIF
	Else
		prcDeletaGNRE.Call(&EmpCod, &FilCod, &GNRENumRec)
		Return
	EndIf

EndEvent


]]></Source>
