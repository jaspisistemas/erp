      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProcessando.Visible = 0
//	if &DeOndeVem = 'WWDEVOLUCAOVENDA'
//		TextBlockPedCliObs.Caption = 'Obs.Cadas.Cliente:'
//	EndIF

	RetornaAutorizacao.Call('DEVOLUCAOABREESTOQUE', Status_SimNao.Sim, 1, &AutNiv)
	TextBlockTitle.Caption = 'Abrir Pedido de Devolução Nº: '+trim(str(&PedCod))+'?'		
	
	&link = &DeOndeVem.Trim() + '.aspx'
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		If PedSts <> Status_Pedido.FECHADO
			Link(&link)
		EndIF
		
		&PedCliCodRaz = PedCliCodRaz
		&PedDtaEms = PedDtaEms
		&PedDtaFat = PedDtaFat
		&FilCodNom = FilCodNom
		
		msg('ATENÇÃO!! Mudando o status do pedido, de fechado para aberto, você fica responsável pelas alterações no estoque!')
		msg('A NF de entrada "CASO EXISTA" não será cancelada e nem excluída, se essa for a intenção favor fazer pelo Monitora Notas!')
		msg('Essa Operação não afetará informações do Financeiro!')
		
		&PedObsEst = PedObsEst
		
		&PedCliObs = PedCliObsCli
		If PedCliObsCli.IsEmpty()
			&PedCliObs.Visible = 0
		EndIF
	
		If PedObsEst.IsEmpty()
			&PedObsEst.Visible = 0
		EndIF
		
		&PedObsGer = PedObsGer
		If PedObsGer.IsEmpty()
			&PedObsGer.Visible = 0
		EndIF
		
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False
	&FilCod.Visible = False
	&PedDtaFat.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoBtnConfirmar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_BtnConfirmar.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_BtnConfirmar.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_BtnConfirmar.Result = !'Yes'
		Do 'Do Action BtnConfirmar'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelarAbertura'

	LInk(&link)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Action BtnConfirmar'

	tbConfirmar.Visible = 0
	tbProcessando.Visible = 1
	
	&ProgressId = trim(Str(&EmpCod)) + trim(Str(&FilCod)) + trim(Str(&PedCod)) + 'ABRIR'
	apagaProgress.Call(&ProgressId)
	scaProgressBar.ProcessId = &ProgressId
	scaProgressBar.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar.Start()
	
	AtualizaEstoqueGerencialDevolucao_submit.submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &PedCod, &PedDtaFat, Status_Pedido.ABERTO, &Context.PesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (not &PedObsGer.IsEmpty())
		&PedObsGer.Visible = False
		PedObsGer_Cell.Class = !'Invisible'
	Else
		&PedObsGer.Visible = True
		PedObsGer_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (Not &PedObsEst.IsEmpty())
		&PedObsEst.Visible = False
		PedObsEst_Cell.Class = !'Invisible'
	Else
		&PedObsEst.Visible = True
		PedObsEst_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf
	If Not (not &PedCliObs.IsEmpty())
		&PedCliObs.Visible = False
		PedCliObs_Cell.Class = !'Invisible'
	Else
		&PedCliObs.Visible = True
		PedCliObs_Cell.Class = !'col-xs-12 CellAttributeRed'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar.OnComplete

	if &DeOndeVem = 'RETURN'
		Return
	Else
		Link(&link)
	Endif

EndEvent


]]></Source>
