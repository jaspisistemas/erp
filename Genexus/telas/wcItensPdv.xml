      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('VENDAREMOVEITEM', Status_SimNao.nao, 1, &VENDAREMOVEITEM)
	retornaAutorizacao.Call('VENDABTNREMOVETUDO', Status_SimNao.nao, 1, &VENDABTNREMOVETUDO)
	btnLimparTudo.Visible = (&VENDABTNREMOVETUDO > 0)
	&EliminarItem.Visible = (&VENDAREMOVEITEM > 0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbProdutos.Height = 330
	Grid.Rows = 10

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&Qtd = 0
	For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&gridPedItmCod = PedItmCod
		&gridPedQtd =  PedQtd
		If PedItmDsc >= 100
			&gridProNom = substr(ProNomGra, 1, 30)+' -BRINDE-'
		Else
			&gridProNom = substr(ProNomGra, 1, 40)
		EndIf
		
		&gridPedVlrItm = PedVlrItm
		if PedItmPrm <> domPedItmPrm.NORMAL
			&gridPedVlrItm.ForeColor = RGB(230,45,45)
		Else
			&gridPedVlrItm.ForeColor = RGB(0,0,0)
		EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&EliminarItem.FromImage(ActionDelete)
	&EliminarItem.TooltipText = "Deletar Item"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&Qtd += 1
		load
		if &Qtd >= 7
			Exit
		EndIF
	EndFor

EndEvent

Event 'DoBRINDES'

	iF &PedItmCod > 0
		WPBRIndeprodutopedido.Link(&EmpCod, &FiLCod, &PedCod,&PedItmCod)
	Else
		msg('Selecione o item clicando na grid.')	
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVisualizarItens'

	pdvm_TodosItens.Link(&EmpCod, &FiLCod, &PedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoLimparTudo'

	if &VENDABTNREMOVETUDO > 0
		wpLimparPedido.Link(&EmpCod, &FiLCod, &PedCod)
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEliminarItem'

	If &VENDAREMOVEITEM > 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_EliminarItem.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIf

EndEvent

Event DVelop_ConfirmPanel_EliminarItem.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_EliminarItem.Result = !'Yes'
		Do 'Do EliminarItem'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do EliminarItem'

	If &gridPedItmCod <> 0
	    DeletaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &gridPedItmCod)
	    pdvm_venda.Link(&PedCod)
		
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Grid.OnLineActivate

	&PedItmCod = &gridPedItmCod

EndEvent


]]></Source>
