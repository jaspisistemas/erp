        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&SdtTipEtq_SELECIONAD.Clear()
	&SdtTipEtq_SELECIONAD_TRUE.Clear()
	&sdtTipEtq.Clear()
	&PadDtaMod = ServerDate()
	&PadDtaHorMod = ServerNow()
	&SdtTipEtq_SELECIONAD.fromJson(&WebSession.Get('TIPOETIQUETAPRODUTO'))
	PadraoUsuarioHora.Call('L', '#TPETIQUETA_PRODUTO#', 0, &EmpCod, &PadObs, &PadDtaMod,&PadDtaHorMod,&PadTemPer)
	&SdtTipEtq_SELECIONAD_TRUE.FromJson(&PadObs)
	
	If &SdtTipEtq_SELECIONAD_TRUE.Count > 0
		
		For &SdtTipEtq_SELECIONAD_Item in &SdtTipEtq_SELECIONAD
			&sdtTipEtqItem = new()
			&sdtTipEtqItem.SEL = false
			For &SdtTipEtq_SELECIONAD_TRUE_Item in &SdtTipEtq_SELECIONAD_TRUE
				if &SdtTipEtq_SELECIONAD_TRUE_Item.CD = &SdtTipEtq_SELECIONAD_Item.CD
					&sdtTipEtqItem.SEL = true
					&sdtTipEtqItem.NWD = &SdtTipEtq_SELECIONAD_TRUE_Item.NWD
				EndiF
			EndFor
		
			&sdtTipEtqItem.CD = &SdtTipEtq_SELECIONAD_Item.CD
			&sdtTipEtqItem.DES = &SdtTipEtq_SELECIONAD_Item.DES
			
			&sdtTipEtq.Add(&sdtTipEtqItem)
		EndFor
	Else
		For &SdtTipEtq_SELECIONAD_Item in &SdtTipEtq_SELECIONAD
			&sdtTipEtqItem = new()
			&sdtTipEtqItem.SEL = false
			&sdtTipEtqItem.CD = &SdtTipEtq_SELECIONAD_Item.CD
			&sdtTipEtqItem.DES = &SdtTipEtq_SELECIONAD_Item.DES
			&sdtTipEtq.Add(&sdtTipEtqItem)
		EndFor
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtTipEtqs.Rows = 10
	GridsdtTipEtqsPaginationBar.RowsPerPageSelectedValue = GridsdtTipEtqs.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtTipEtqsCurrentPage = GridsdtTipEtqs.CurrentPage
	&GridsdtTipEtqsPageCount = GridsdtTipEtqs.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqs.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqsPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtTipEtqsPaginationBar.SelectedPage = !'Previous'
			GridsdtTipEtqs.PreviousPage()
		Case GridsdtTipEtqsPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtTipEtqs.CurrentPage
			&PageToGo += 1
			GridsdtTipEtqs.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtTipEtqsPaginationBar.SelectedPage)
			GridsdtTipEtqs.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtTipEtqsPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtTipEtqs.Rows = GridsdtTipEtqsPaginationBar.RowsPerPageSelectedValue
	GridsdtTipEtqs.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&FinalisdtTipEtq.clear()
	For &sdtTipEtqItem in &sdtTipEtq
		if &sdtTipEtqItem.SEL = true
			&FinalisdtTipEtqItem = new()
			&FinalisdtTipEtqItem.CD = &sdtTipEtqItem.CD
			&FinalisdtTipEtqItem.DES = &sdtTipEtqItem.DES
			&FinalisdtTipEtqItem.NWD = &sdtTipEtqItem.NWD
			&FinalisdtTipEtq.add(&FinalisdtTipEtqItem)
		EndIf
	EndFor
	
	&PadObs = &FinalisdtTipEtq.ToJson()
	PadraoUsuarioHora.Call('G', '#TPETIQUETA_PRODUTO#', 0, &EmpCod, &PadObs, &PadDtaMod,&PadDtaHorMod,'P')
	return

EndEvent


