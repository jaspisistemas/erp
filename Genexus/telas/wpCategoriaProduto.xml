      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWCATEGORIAPRODUTOS', Status_SimNao.Sim, 2, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	do 'MontaComboImpressora'
	
	&EmpCod = &parmEmpCod
	&GrupCod = &parmGrupCod
	RetornaEmpresaModulo.Call(&EmpCod,ModuloSistema.COOPERCU,&PossuiModulo)
	do 'LoadGrupo'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GrupCom.TooltipText = "Caso informado Comissão no Grupo do Produto, Substituirá a Comissão Configurada para o Vendedor."
	&GrupDscMax.TooltipText = "Desconto Máximo Aceitado em um Produto, 0 - Não Aceita desconto."
	&GrupAnaSin.TooltipText = "Sintético: São os Pais da Hierarquia não sendo possíveis sua seleção no Cadastro dos Produtos (Somente Sintéticos aceitam filhos na Hierarquia). Analíticos: São os filhos da Hierarquia e os mesmos não possuem continuidade nela."

	Do 'AttributesSecurityCode'
	&GrupCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWCategoriaProdutos.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &GrupHie.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Código Hierárquico'), DVMessageType.error, &GrupHie.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &GrupNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Descrição'), DVMessageType.error, &GrupNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&GrupAnaSin = 'A')
		&GrupDscMax.Visible = False
		GrupDscMax_Cell.Class = !'Invisible'
	Else
		&GrupDscMax.Visible = True
		GrupDscMax_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&GrupAnaSin = 'A')
		&GrupCom.Visible = False
		GrupCom_Cell.Class = !'Invisible'
	Else
		&GrupCom.Visible = True
		GrupCom_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&GrupAnaSin = 'A')
		&GrupNCM.Visible = False
		GrupNCM_Cell.Class = !'Invisible'
	Else
		&GrupNCM.Visible = True
		GrupNCM_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&GrupAnaSin = 'A')
		&GrupPerAcr.Visible = False
		GrupPerAcr_Cell.Class = !'Invisible'
	Else
		&GrupPerAcr.Visible = True
		GrupPerAcr_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&GrupAnaSin = 'A')
		&GrupCatCod.Visible = False
		GrupCatCod_Cell.Class = !'Invisible'
	Else
		&GrupCatCod.Visible = True
		GrupCatCod_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&GrupAnaSin = 'A')
		&GrupSmt.Visible = False
		GrupSmt_Cell.Class = !'Invisible'
	Else
		&GrupSmt.Visible = True
		GrupSmt_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&GrupAnaSin = 'A')
		&GrupImpCod.Visible = False
		GrupImpCod_Cell.Class = !'Invisible'
	Else
		&GrupImpCod.Visible = True
		GrupImpCod_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&GrupAnaSin = 'A')
		&GrupSpedNatRec.Visible = False
		GrupSpedNatRec_Cell.Class = !'Invisible'
	Else
		&GrupSpedNatRec.Visible = True
		GrupSpedNatRec_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	
	TableArracoamento.Visible = (&PossuiModulo = 'S' and &GrupAnaSin = 'A')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &GrupAnaSin.IsValid

	do 'AttributesSecurityCode'

EndEvent

Event &GrupHie.IsValid

	&GrupHie = &GrupHie.Replace(',','.')
	
	GrupoProdutosPaiHierarquico.call(&EmpCod, &GrupCod, &GrupHie, &GrupHie, &PaizaoMensagem, &GrupPaiCod, &GrupPaiHie, &IsErroHierarquia)
	If &IsErroHierarquia = true
		msg(&PaizaoMensagem)
	EndIF

	if &PaizaoMensagem.IsEmpty() and &parmGrupCod = 0
		&PaizaoMensagem = '### --- SERÁ CRIADO UMA NOVA HIERARQUIA --- ###'
	EndIF

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	
	if &CheckRequiredFieldsResult = true
		//ValidaNomeGrupoRepetido.Call(&EmpCod, &GrupCod, &GrupNom, &ErroGrupo)
		GrupoProdutosPaiHierarquico.call(&EmpCod, &GrupCod, &GrupHie, &GrupHie, &PaizaoMensagem, &GrupPaiCod, &GrupPaiHie, &IsErroHierarquia)
		
		Do Case
			CAse not &ErroGrupo.IsEmpty()
				msg(&ErroGrupo)
				
			Case &IsErroHierarquia = true
				msg(&PaizaoMensagem)
				
			Otherwise
			
				GravaGrupoProdutos.Call(&EmpCod, &GrupCod, &GrupNom, &PaizaoMensagem, &GrupAnaSin, &GrupHie, &GrupCom, &GrupDscMax, &GrupSmt,&GrupArr, &GrupNCM, &GrupCatCod, &GrupImpCod, &GrupSpedNatRec, &GrupPerAcr, &Context.UserName)
				
				if &mode = TrnMode.Insert
					wpCategoriaProduto.Link(TrnMode.Insert, &Context.EmpCod, 0)
				Else
					wwCategoriaProdutos.Link()
				Endif
		EndCase
	EndIF

EndEvent

Sub 'MontaComboImpressora'

	&GrupImpCod.AddItem(0,'SEM IMPRESSORA PADRAO')
	For Each Order EmpCod, EmpImpCod
		Where EmpCod = &Context.EmpCod		
		Where EmpImpTip like '%CUPOM%'
		
		&Mensagem = EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
		&GrupImpCod.AddItem(EmpImpCod,&Mensagem)
		
	EndFor

EndSub

Sub 'LoadGrupo'

	For Each Order EmpCod, GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &GrupCod
		&GrupNom = GrupNom
		&GrupHie = GrupHie
		&GrupAnaSin = GrupAnaSin
		&GrupDscMax = GrupDscMax
		&GrupCom = GrupCom
		
		&GrupHie.Enabled = 0
		&GrupSmt = GrupSmt
		&GrupArr = GrupArr
		
		&GrupNCM = GrupNCM
		&GrupPerAcr = GrupPerAcr
		&GrupCatCod = GrupCatCod
		&GrupImpCod = GrupImpCod
		&GrupSpedNatRec = GrupSpedNatRec
		
		GrupoProdutoPossuiFilho.Call(EmpCod, GrupCod, GrupHie, &IsExiste)
		if &IsExiste = true
			&GrupAnaSin.Enabled = 0
		EndIF
	
		GrupoProdutosPaiHierarquico.call(&EmpCod, &GrupCod, &GrupHie, &GrupHie, &PaizaoMensagem, &GrupPaiCod, &GrupPaiHie, &IsErroHierarquia)

		Exit
	When None
		&EmpCod = &Context.EmpCod
		&GrupDscMax = 100
		&GrupSmt = true
		&GrupArr = False
		&GrupNCM = 99
		&GrupPerAcr = 0
		&GrupCatCod = 0
		&GrupImpCod = 0
		&GrupSpedNatRec = ''
	EndFor

EndSub


]]></Source>
