      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		
		&MDFeNum = MDFeNum
		&MDFeDtaEms = MDFeDtaEms
		&FilCodNom = FilCodNom
		&MDFeVlrTot = MDFeVlrTot
		&MDFeChv = MDFeChv
		&MDFeProt = MDFeProt
		
		If MDFeChv.IsEmpty()
			msg('MDFe não possui a chave da MDFe.')
		EndIF
		
		Exit
	EndFor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	MdfeEveSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Deletar.FromImage(ActionDelete)
	&Deletar.TooltipText = "Deletar Motorista"
	
	&Actions.Clear()
	&Actions.AddItem(0, 'WWP_ActionGroupCaption')
	&Actions.AddItem(1, 'Autorizar Evento')

	Do Case
		Case MdfeEveSts = Status_MDFe.Digitando
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case MdfeEveSts = Status_MDFe.Cancelado
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case MdfeEveSts = Status_MDFe.Autorizado
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case MdfeEveSts = Status_MDFe.Encerrado
			MdfeEveSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			MdfeEveSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	wwMDFe.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Actions.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &Actions = 1
			Do 'Do Autorizar'
	EndCase
	&Actions = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdicionar'

	Do Case
		Case &MDFeMotNom.Trim().IsEmpty()
			msg('Nome do motorista é obrigatório!')
		Case &erroc <> 0
			msg('CPF do motorista inválido!')
		Case &MDFeChv.IsEmpty()
			msg('MDFe não possui a chave de acesso, só pode incluir condutor em uma MDFe se a mesma estiver autorizada!')
		Case &MDFeProt.IsEmpty()
			msg('MDFe não possui número do protocolo, consulte o MDFe no SEFAZ!')
		OtherWise
			EventoMotorista.call('ADD',&EmpCod,&FilCod,&MDFeCod,0,&MDFeMotCpf,&MDFeMotNom)
			Refresh keep
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do Autorizar'

	loadWWPContext.Call(&Context)
	ValidaCpfCnpj.Call(&MDFeMotCpf, &erroc, 'N')
	
	GravaXmlInclusaoCondutorMDFe.Call(EmpCod, FilCod, MDFeCod,MdfeEveCod, MdfeEveMotCpf,MdfeEveMotNom,&Context.PesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &MDFeMotCpf.IsValid

	Do 'Motorista'

EndEvent

Event &Deletar.Click

	EventoMotorista.call('DEL',EmpCod,FilCod,MDFeCod,MdfeEveCod,MdfeEveMotCpf,MdfeEveMotNom)
	Refresh keep

EndEvent

Sub 'Motorista'

	If not &MDFeMotCpf.Trim().IsEmpty()
		ValidaCpfCnpj.Call(&MDFeMotCpf, &erroc, 'N')
		For each order EmpCod,PesCpf
			Where EmpCod = &EmpCod
			Where PesCpf = &MDFeMotCpf	
			&MDFeMotNom = PesRaz
			Exit
		EndFor
	EndIf

EndSub


]]></Source>
