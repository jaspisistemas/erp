      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	If &Mode = TrnMode.Delete
		retornaAutorizacao.Call('WWCOBRANCA', Status_SimNao.Sim, 3, &AutNiv)
	Else
		retornaAutorizacao.Call('WWCOBRANCA', Status_SimNao.Sim, 2, &AutNiv)
	EndIf
	LoadWWPContext.Call(&Context)
	Do 'Duplicata'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CreFunCod.Visible = False
	WCCobrancaPagamentos.Object = CobrancaPagamentos.Create(&EmpCod, &FilCod, &CreCod)
	WCCobrancaCobrancas.Object = CobrancaCobrancas.Create(&EmpCod, &FilCod, &CreCod)
	WCEmail.Object = wcEmailContato.Create(&EmpCod, &CreCliCod	)
	WCTelefone.Object = wcTelefones.Create(&EmpCod, &CreCliCod	)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

 	&CrePrmPag = SErverDate()

	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
	If not &PadObs.IsEmpty()
		&CreMetCod = val(Substr(&PadObs, 1, 8))
		&CreResCob = val(Substr(&PadObs, 9, 8))
	Else
		&CreMetCod = 1
		&CreResCob = 1
	EndIF

	&Hora = '18:00:00'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'Duplicata'
	&CreFunCod = &Context.PesCod

EndEvent

Event &Hora.IsValid

	formataHora.Call(&Hora, &Hora)

EndEvent

Event Enter

	formataHora.Call(&Hora, &Hora)
	
	Do Case
		Case &CreMetCod.IsEmpty()
			msg('ATENÇÃO! O método é obrigatório, favor informar!')
			&CreMetCod.SetFocus()
		Case &CreResCob.IsEmpty()
			msg('ATENÇÃO! O resultado é obrigatório, favor informar!')
			&CreResCob.SetFocus()
		Case &CrePrmPag.IsEmpty()
			msg('ATENÇÃO! A data da promessa é obrigatória, favor informar!')
			&CrePrmPag.SetFocus()
		Otherwise
		
		&PadObs = padL(trim(str(&CreMetCod)), 8, ' ')
		&PadObs += padL(trim(str(&CreMetCod)), 8, ' ')
		
		PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
		

			GravaCobranca.call(&EmpCod,&FilCod,&CreCod,&CreCobObs,&CreMetCod,&CreResCob,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
			Return
	EndCase

EndEvent

Sub 'Duplicata'

	For Each Order EmpCod,FilCod,CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		&CreCliCod    = CreCliCod
		&CreCliCodRaz = CreCliCodRaz
		&CreCliEndCob = CreCliEndCob
		&CreVlrDup    = CreVlrDup
		&CreCliCobCep = CreCliCobCep
		&CreDtaVct    = CreDtaVct
		&CreVlrSdo    = CreVlrSdo
		&PesCidCodNom = trim(str(CreCliCobCidCod))+' - '+trim(CreCliCobCidNom)
		&CreDtaEms = CreDtaEms
		&CreDupNro = CreDupNro
		&CreSts    = CreSts
		&CreVenCod = CreVenCod
		&CrePedCod = CrePedCod
		exit
	EndFor

EndSub


