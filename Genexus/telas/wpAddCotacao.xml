      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod

	txtobs.Caption = ''
	txtobs.ForeColor= RGB(255,0,0)
	
	if &parCotComCod.IsEmpty()//novo
		&CotComDtaEms = serverdate()
		
		if &wwpContext.PesIsVen = true
			&CotComFunCod = &wwpContext.PesCod
			do 'loadFuncionario'
		Else
			&CotComFunRaz = 'INFORME O COMPRADOR'
		Endif
	
	Else //update
		&EmpCod = &parEmpCod
		&CotComCod = &parCotComCod
		do 'loadCotacao'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable8.Width = 200

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserCancelar'

	wwpActions.WCPopup_Close('0')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &CotComLctCod.IsValid

	do 'loadTipoLancamento'

EndEvent

Event &CotComFunCod.IsValid

	do 'loadFuncionario'

EndEvent

Event Enter

	do 'loadTipoLancamento'
	do 'loadFuncionario'
	
	Do CAse
		CAse &CotComNom.IsEmpty()
			txtObs.Caption = 'Descrição da cotação obrigatório!'
			&CotComNom.SetFocus()
			
		Case &IsErroCotComLctCod = true or &CotComLctCod.IsEmpty()
			txtObs.Caption = 'Operação de lançamento obrigatório!'
			&CotComLctCod.SetFocus()
			
		CAse &CotComFunCod.IsEmpty() or &IsErroCotComFunCod = true
			txtObs.Caption = 'Funcionário obrigatório!'
			&CotComFunCod.SetFocus()
			
		Case &CotComDtaLim.IsEmpty()
			txtObs.Caption = 'Data limite para preenchimento da cotação deve ser informado!'
			&CotComDtaLim.SetFocus()
			
		Otherwise
			prcGravaDadosCapaCotacao.Call(&EmpCod, &CotComCod, &CotComFilCod, &CotComNom, &CotComLctCod, &CotComFunCod, &CotComDtaLim,&CotComObs,&CotComCod)
			
			wwpActions.WCPopup_Close(trim(str(&CotComCod)))
	EndCAse

EndEvent

Sub 'loadFuncionario'

	&CotComFunRaz = 'INFORME O COMPRADOR'
	&IsErroCotComFunCod = false
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CotComFunCod
		
		&CotComFunRaz = PesRaz
		if PesIsVen = false or PesSts = Status_AtivoInativo.INATIVO			
			&IsErroCotComFunCod = true
		Endif
		
		Exit
	When None
		&IsErroCotComFunCod = true
	EndFor

EndSub

Sub 'loadCotacao'

	For Each Order EmpCod, CotComCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		
		&CotComDtaEms = CotComDtaEms
		&CotComFunCod = CotComFunCod
		do 'loadFuncionario'
		
		&CotComPrzDia = CotComPrzDia
		&CotComObs = CotComObs
		&CotComDtaLim = CotComDtaLim
		
		&CotComLctCod = CotComLctCod
		do 'loadTipoLancamento'
		
		&CotComFilCod = CotComFilCod
		&CotComNom = CotComNom

		Exit
	EndFor

EndSub

Sub 'loadTipoLancamento'

	&IsErroCotComLctCod = false
	&CotComLctNom = 'INFORME OPERAÇÃO DE ENTRADA'
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &CotComLctCod
		
		&CotComLctNom = LctNom
		if LctAtuSal = Status_EntradaSaida.Saida
			&IsErroCotComLctCod = true
		Endif
	
		Exit
	When none
		&IsErroCotComLctCod = true
	EndFor

EndSub


]]></Source>
