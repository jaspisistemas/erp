        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	Do 'LoadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&FilCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do case
		case &OldLctCod = &LctCod
			Msg('Mesma operação, não é possível!')
		Case &LctCod.IsEmpty()
			Msg('Tipo Lançamento Obrigatório')
		Otherwise
			AtualizaTipoLancamentoPedidoVenda.call(&EmpCod,&FilCod,&PedCod,&LctCod,&OldLctCod, &Context.UserName)
			return
	EndCase

EndEvent

Event &LctCod.IsValid

	txtaviso.Caption = ''
	prcRetornaDadosTipoLancamentoDados.call(&EmpCod, &LctCod, &LctRetCus, &LctInfPrc, &LctTabColCod)
	Do Case
		CAse (&OldLctTabColCod <> &LctTabColCod and &LctTabColCod > 0)
			txtaviso.Caption = 'VALORES UNITÁRIOS SERÃO ATUALIZADOS!'
		Case &OldLctRetCus = Status_SimNao.Sim or &OldLctInfPrc = Status_SimNao.Nao
			txtaviso.Caption = 'VALORES UNITÁRIOS SERÃO ATUALIZADOS!'
		Case &LctRetCus = Status_SimNao.Sim or &LctInfPrc = Status_SimNao.Nao
			txtaviso.Caption = 'VALORES UNITÁRIOS SERÃO ATUALIZADOS!'
	EndCAse

EndEvent

Sub 'LoadPedido'

	For each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedCliCodRaz = PedCliCodRaz
		&OldLctCod = LctCod
		&OldLctInfPrc = LctInfPrc
		&OldLctRetCus = LctRetCus
		&OldLctTabColCod = TabColCod
		
		&LctCod = LctCod
		
		Exit
	EndFor

	prcRetornaDadosTipoLancamentoDados.call(&EmpCod, &LctCod, &LctRetCus, &LctInfPrc, &LctTabColCod)
	Do Case
		CAse (&OldLctTabColCod <> &LctTabColCod and &LctTabColCod > 0)
			txtaviso.Caption = 'VALORES UNITÁRIOS SERÃO ATUALIZADOS!'
		Case &OldLctRetCus = Status_SimNao.Sim or &OldLctInfPrc = Status_SimNao.Nao
			txtaviso.Caption = 'VALORES UNITÁRIOS SERÃO ATUALIZADOS!'
		Case &LctRetCus = Status_SimNao.Sim or &LctInfPrc = Status_SimNao.Nao
			txtaviso.Caption = 'VALORES UNITÁRIOS SERÃO ATUALIZADOS!'
	EndCAse

EndSub


]]></Source>
