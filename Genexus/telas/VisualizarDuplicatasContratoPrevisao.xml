      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&OcultarCanceladas = true
	&OcultarPagas = true
	&OcultarParciais = true

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'GetDados'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&DupIcone.ColumnHeaderClass = !'WWActionColumn'
	&DupSts.ColumnHeaderClass = !'WWColumn'
	CreCod.ColumnHeaderClass = !'WWColumn'
	CreDupNro.ColumnHeaderClass = !'WWColumn'
	CreVlrDup.ColumnHeaderClass = !'WWColumn'
	CreVlrSdo.ColumnHeaderClass = !'WWColumn'
	CreDtaVct.ColumnHeaderClass = !'WWColumn'
	CreBloNro.ColumnHeaderClass = !'WWColumn'
	CrePlanCod.ColumnHeaderClass = !'WWColumn'
	CreCbrNom.ColumnHeaderClass = !'WWColumn'

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = grid.CurrentPage

EndEvent

Event Grid.Load

	&DupIcone.Enabled = 0
	Do case
		case (CreVlrSdo <> CreVlrDup) and (not CreDtaPrmPag.IsEmpty()) and (CreSts <> Status_Duplicata.CANCELADA)
			&DupSts = 'P'
			&DupIcone.FromImage(IconVerde)
			
		case CreVlrDup = CreVlrSdo and CreSts = Status_Duplicata.ATIVO
			&DupSts = 'A'
			&DupIcone.FromImage(IconAzul)
			
		case CreSts = Status_Duplicata.CANCELADA
			&DupSts.SetEmpty()
			&DupSts = 'C'
			&DupIcone.FromImage(IconVermelho)
		otherwise 
			&DupSts = 'A'
			&DupIcone.FromImage(IconAzul)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DupIcone.FromImage(iconVerde)
	&DupIcone.TooltipText = ""

	Do Case
		Case &DupSts = 'C'
			&DupIcone.ColumnClass = !'WWActionColumn WWColumnDanger WWColumnDangerFirstColumn'
			&DupSts.ColumnClass = !'WWColumn WWColumnDanger'
			CreCod.ColumnClass = !'WWColumn WWColumnDanger'
			CreDupNro.ColumnClass = !'WWColumn WWColumnDanger'
			CreVlrDup.ColumnClass = !'WWColumn WWColumnDanger'
			CreVlrSdo.ColumnClass = !'WWColumn WWColumnDanger'
			CreDtaVct.ColumnClass = !'WWColumn WWColumnDanger'
			CreBloNro.ColumnClass = !'WWColumn WWColumnDanger'
			CrePlanCod.ColumnClass = !'WWColumn WWColumnDanger'
			CreCbrNom.ColumnClass = !'WWColumn WWColumnDanger'
		Case &DupSts = 'P' and CreVlrSdo = 0
			&DupIcone.ColumnClass = !'WWActionColumn WWColumnSuccess WWColumnSuccessFirstColumn'
			&DupSts.ColumnClass = !'WWColumn WWColumnSuccess'
			CreCod.ColumnClass = !'WWColumn WWColumnSuccess'
			CreDupNro.ColumnClass = !'WWColumn WWColumnSuccess'
			CreVlrDup.ColumnClass = !'WWColumn WWColumnSuccess'
			CreVlrSdo.ColumnClass = !'WWColumn WWColumnSuccess'
			CreDtaVct.ColumnClass = !'WWColumn WWColumnSuccess'
			CreBloNro.ColumnClass = !'WWColumn WWColumnSuccess'
			CrePlanCod.ColumnClass = !'WWColumn WWColumnSuccess'
			CreCbrNom.ColumnClass = !'WWColumn WWColumnSuccess'
		Case &DupSts = 'P' and CreVlrSdo > 0
			&DupIcone.ColumnClass = !'WWActionColumn WWColumnInfo WWColumnInfoFirstColumn'
			&DupSts.ColumnClass = !'WWColumn WWColumnInfo'
			CreCod.ColumnClass = !'WWColumn WWColumnInfo'
			CreDupNro.ColumnClass = !'WWColumn WWColumnInfo'
			CreVlrDup.ColumnClass = !'WWColumn WWColumnInfo'
			CreVlrSdo.ColumnClass = !'WWColumn WWColumnInfo'
			CreDtaVct.ColumnClass = !'WWColumn WWColumnInfo'
			CreBloNro.ColumnClass = !'WWColumn WWColumnInfo'
			CrePlanCod.ColumnClass = !'WWColumn WWColumnInfo'
			CreCbrNom.ColumnClass = !'WWColumn WWColumnInfo'
		Otherwise
			&DupIcone.ColumnClass = 'WWActionColumn'
			&DupSts.ColumnClass = 'WWColumn'
			CreCod.ColumnClass = 'WWColumn'
			CreDupNro.ColumnClass = 'WWColumn'
			CreVlrDup.ColumnClass = 'WWColumn'
			CreVlrSdo.ColumnClass = 'WWColumn'
			CreDtaVct.ColumnClass = 'WWColumn'
			CreBloNro.ColumnClass = 'WWColumn'
			CrePlanCod.ColumnClass = 'WWColumn'
			CreCbrNom.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do case
		case (CreVlrSdo <> CreVlrDup) and (not CreDtaPrmPag.IsEmpty()) and (CreSts <> Status_Duplicata.CANCELADA)
			&DupSts = 'P'
			&DupIcone.FromImage(IconVerde)
			
		case CreVlrDup = CreVlrSdo and CreSts = Status_Duplicata.ATIVO
			&DupSts = 'A'
			&DupIcone.FromImage(IconAzul)
			
		case CreSts = Status_Duplicata.CANCELADA
			&DupSts.SetEmpty()
			&DupSts = 'C'
			&DupIcone.FromImage(IconVermelho)
		otherwise 
			&DupSts = 'A'
			&DupIcone.FromImage(IconAzul)
	EndCase
	CreCbrNom.Visible = true
	if CreRecPag = ReceberPagar.Pagar
		CreCbrNom.Visible = false
	EndIf

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoEditarDuplicatas'

	GravaDuplicatasTemporariasContratoPrevisao_Existentes.Call(&EmpCod, &FilCod, &Context.PesCod, &SerItmCod)
	ConfirmaDuplicatasContratoPrevisao.Call(&SerItmCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	MonitoraContratoPrevisaoCliente.Link()
	//return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'GetDados'

	For each order EmpCod, SerItmCod
		where EmpCod = &EmpCod
		where SerItmCod = &SerItmCod
		&SerCliCodRaz = SerCliCodRaz
		&SerItmAbv = SerItmAbv
		&SerItmTip = SerItmTip
		&SerItmRecPag = SerItmRecPag
		exit
	EndFor

EndSub

