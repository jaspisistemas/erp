      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&GrupAnaSin = 'A'
	loadwwpContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	retornaPrimeiroGrupo.Call(&Context.EmpCod, &GrupCod)
	for Each order EmpCod, GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &GrupCod
		&AuxGrupCodNom = GrupCodNom
		Exit
	EndFor
	&GrupCodNom = &AuxGrupCodNom
	
	
	RetornaConfSistema.Call(&Context.EmPCod, &Context.FilCod, domConfSistema.TCon032_MargemPadraoProduto, &CfgVlr)
	&ProIMC = val(retornaSoNumeros.Udp(&CfgVlr))

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &GrupCodNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Grupo'), DVMessageType.error, &GrupCodNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &ProCatCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Categoria'), DVMessageType.error, &ProCatCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &GrupCodNom.IsValid

	Do 'ValidaGrupo'

EndEvent

Event Enter

	btnEnter.Visible = 0
	do 'GravaTudo'
	btnEnter.Visible = 1

EndEvent

Sub 'ValidaGrupo'

	RetornaCodigoCategoriaProduto.Call(&EmpCod, &GrupCodNom, &GrupCod, &Grupnom, &GrupHie)

EndSub

Sub 'GravaTudo'

	do 'CheckRequiredFields'
	
	if &CheckRequiredFieldsResult = True
		
		if &GrupCod.IsEmpty()
			msg('Informe Corretamente Grupo de Produtos!')
			&GrupCodNom.SetFocus()
		Else
			
			For Each Order tmpNFeCod
				Where tmpNFeCod = &tmpNFeCod
				Where tmpProRef.IsEmpty()
				
				&tmpEmixCod = tmpEmixCod
				
				&RepetidoMensagem.SetEmpty()
				&ProBar = retornaSoNumeros.Udp(tmpNfeProBar)
				
				ValidaCodigoreferenciaRepetido.Call(&EmpCod, 0, 0, &ProBar, &RepetidoMensagem)
				if &RepetidoMensagem.IsEmpty()
					&sdtGravaProduto.ProCod = 0
					&sdtGravaProduto.ProRef = ''
					&sdtGravaProduto.ProBar = &ProBar
					&sdtGravaProduto.ProNom = tmpProNom
					&sdtGravaProduto.Prosts = Status_AtivoInativo.ATIVO
					
					&ProEmbCod.setempty()
					RetornaPrimeiraEmbalagemUnidade.call(&EmpCod, tmpUnd, &ProEmbCod)
					if &ProEmbCod.IsEmpty()
						&sdtGravaProduto.ProEmbCod = 1
					Else
						&sdtGravaProduto.ProEmbCod = &ProEmbCod
					Endif
					
					&sdtGravaProduto.MarCod = 1
					&sdtGravaProduto.ProSetCod = 1
					&sdtGravaProduto.GrupCod = &GrupCod
					&sdtGravaProduto.ProTipDef = definicao.REVENDA
					&sdtGravaProduto.ProNcmCod = tmpNcmCod
					&tmpNcmCEST = retornaSoNumeros.Udp(tmpNcmCEST)
					&sdtGravaProduto.ProNcmCest = val(&tmpNcmCEST)
					&sdtGravaProduto.ProCatCod = &ProCatCod
					&sdtGraVaProduto.TabPrc1 = 0.01
					&sdtGravaProduto.ProPadForCod = 0
				 	&sdtGravaProduto.ProTipCus = TipoCusto.UltimaCompra
					&sdtGravaProduto.ProPadUltCmp = 'C' //PADRAO ULTIMA COMPRA
					&sdtGravaProduto.ProVlrCusFix = 0
					&sdtGravaProduto.ProIMCTot = &ProIMC
					&sdtGravaProduto.ProIMC = &ProIMC
					&sdtGravaProduto.ProDet = ''
					&sdtGravaProduto.ProPesLiq = 0
					&sdtGravaProduto.ProDesMax = 100
					&sdtGravaProduto.ProQtdEmb = 0
					&sdtGravaProduto.ProInfCmp = Status_simNao.Nao
					&sdtGravaProduto.ProReqVen = false
					&sdtGravaProduto.ProReqQtd = false
					&sdtGravaProduto.ProRepItm = False
					&sdtGravaProduto.ProSolLot = SolicitarLote.NAO_CONTROLAR
					&sdtGravaProduto.ProObrAnp = Status_SimNao.Nao
					&sdtGravaProduto.ProQtdCmpEmb = 0
					
					&sdtGraVaProduto.proEstTip = TipoEstoque.ATUALIZAR_ESTOQUE
					&sdtGraVaProduto.ProTip = TipoProduto.Novo
					
					GravaProdutoImportacao.Call(TrnMode.Insert, &EmpCod, &Context.FilCod, &Context.UserName, &sdtGraVaProduto, &OutProCod, &OutProRef)
					
					If tmpPedCliCnpj.IsEmpty()
						&ForCNPJ = tmpPedCliCpf
					Else
						&ForCNPJ = tmpPedCliCnpj
					EndIF
					
					FornecedorProduto_AtualizaCodBarras.Call(tmpNFeCod, &EmpCod, &ForCNPJ, tmpProForCod, &ProBar, &OutProRef, tmpEntCFOP,tmpCFOP, tmpProQtdCmpEmb, &OutProCod, &tmpEmixCod)
				Endif
			EndFor
		
			Return
		Endif
	Endif

EndSub


]]></Source>
