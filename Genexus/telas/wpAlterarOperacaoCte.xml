Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &LctCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Novo Tipo Lançamento'), DVMessageType.error, &LctCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadTemporaria'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&LctCod = CteLctCod
		RetornaNomeTipoLancamento.Call(&EmpCod, CteLctCod, &LctNom)
		&LctNom = trim(str(CteLctCod)) + ' - ' + trim(&LctNom)
		
		Exit
	EndFor

EndSub


