      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	
	retornaAutorizacao.Call('WWPRODUTO', Status_SimNao.Sim, 3, &AutNiv)
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon031_TipoLctoBalanco, &CfgVlr)
	&balLctCod = val(&CfgVlr)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 450
	&EmpCod.Visible = False
	&ProCod.Visible = False
	Grid.Rows = 5
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	txtAviso.Caption = ''
	txtAviso.ForeColor = rgb(255,0,0)
	do 'loadProduto'
	
	btnEnter.SetFocus()

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	&status = PedNovStsNom

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	btnEnter.Enabled = 0
	do 'loadProduto'
	RetornaAutorizacaoAdministrador.Call(&EmpCod, &Context.PesCod, &IsAdm)
	
	if (&IsEstaEmAlgumaReceita = false and &IsPossuiPedidos = false) or (&IsAdm = true or &Context.Old_Perfil = 3)
		DeletaProduto.Call(&EmpCod, &ProCod, &ProGraCod, &IsPossuiPedidos,&Context.UserName)
		msg('Produto Eliminado com Sucesso!')
		Return
	Else
		msg('Produto possui movimentação em Pedidos, Somente administradores podem eliminar produto, caso nao seja Elimine dos pedidos e das receitas de produtos!')
	EndIf
	btnEnter.Enabled = 1

EndEvent

Sub 'loadProduto'

	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		&ProCodNom = ProGraRefNom
		Exit
	When None
		Return
	EndFor
	
	RetornaIsPodeExcluirProdutoGrade.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &IsEstaEmAlgumaReceita, &IsPossuiPedidos)
	
	if (&IsEstaEmAlgumaReceita = true or &IsPossuiPedidos = true) and  (&IsAdm = true or &Context.PesCod < 0)
		txtAviso.Caption = 'Produto possui Movimentação, tenha certeza que deva remover o produto, processo não poderá ser revertido!'
	EndIf
	
	GXUITabsPanel_tbElimi.HideTab(2)
	IF &IsPossuiPedidos = TRUE
		GXUITabsPanel_tbElimi.ShowTab(2)
		
	EndIF

EndSub


]]></Source>
