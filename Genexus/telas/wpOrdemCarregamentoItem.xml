      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	do 'loadOrdemCarregamento'
	&ZerarSaldo.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbsaldo.Width = 450
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	For each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedQtd > 0
		
		&PedItmCod = PedItmCod
		&PedQtd    = RetornaQuantidadePedido.Udp(EmpCod,FilCod,&PedCodOciRef, 0, ProCod, ProGraCod)
		&PedVlrItm = PedVlrItm
		&ProCod    = ProCod
		&ProNom    = ProNom
		&PedVlrUnt = PedVlrUnt
		&PedVlrUntDsc = PedVlrUntDsc
		&PedVlrUntComDsc = PedVlrUntComDsc
		&PedQtdEmb = PedQtdEmb
		&PedItmDsc = PedItmDsc
		&PedVlrTab = PedVlrTab
		&GridPedItmPagQtdTot = PedItmPagQtdTot
		
		&PedQtdDsp = &PedQtd - RetornaQtdRetirada.Udp(EmpCod,FilCod,ProCod,&PedCodOciRef)
		
		&auxPedQtd = PedQtd
		
		load
		
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoAdicionarProdutos'

	wpSelecionaProdutosOrdemcarregamento.Popup(&EmpCod, &FilCod, &PedCod)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoVoltar'

	Do Case
		Case &DeOndeVem = 'WWPEDIDOVENDA'
			wwPedidoVenda.Link()
		Case &DeOndeVem = 'WWPEDIDOVENDAAGR'
			wwPedidoVendaAgr.Link()
		Otherwise
			wwOrdemcarregamento.Link()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCapaOrdem'

	wpOrdemCarregamentos.Link(&DeOndeVem, Trnmode.Update, &EmpCod, &FilCod, &PedCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	&Varchar = ServerTime()
	&NomeArquivo = 'OrdCarr' + trim(str(&PedCod))
	RCOOpenWindow1.LinkOpen = RELJAS002.Link(&EmpCod, &FilCod, &PedCod, &wwpContext.PesCod, &NomeArquivo, 'N', &Varchar, false, false)
//	RCOOpenWindow1.LinkOpen = RELJAS113.Link(&EmpCod, &FilCod, &PedCod, &wwpContext.PesCod, &NomeArquivo, 'N', &Varchar, false)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFinalizarOrdem'

	&AutNiv = RetornaAutorizacao.UDP('VENDAFECHAESTOQUE', Status_SimNao.Nao, 1)
	RetornaConfSistema.Call(&wwpContext.EmpCod, &wwpContext.FilCod, domConfSistema.TCon009_FecharComEstoque, &FechaPedidoSomenteComEstoque)
	
	
	
	If &AutNiv > 0
		For Each ORder EmpCod, FilCod, PedCod
			where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			&IsSemEstoque = false
			If &FechaPedidoSomenteComEstoque = 'S' //FECHA PEDIDO SOMENTE COM ESTOQUE
				&IsSemEstoque = VerificaProdutoSemEstoque.Udp(EmpCod, FilCod, PedCod)
			EndIf
			
			//		if &LiberaCreditoPedido = 'S'
			//			&IsPodeFaturar = RetornaIsPodeFaturar.Udp(EmpCod, FilCod, PedCod)
			//		EndIF
			
			VerificaLoteInformadoPedidoCompra.Call(EmpCod, FilCod, PedCod, &IsTodosInformados, &Mensagem)
			
			&IsPodeFaturarOrdemCarregamento = true
			If PedStsGer = Pedido_gerado.OrdemCarregamento
				ValidaItemSelecionaOrdemCarregamento.call(EmpCod, FilCod, PedCod, &IsPodeFaturarOrdemCarregamento)
			endif

			Do Case
				Case &IsPodeFaturarOrdemCarregamento = false
					msg('Ordem de Carregamento com Quantidades Superiores ao Pedido Origem')
					
				Case &IsTodosInformados <> true
					wpinformalotesfaltantespedidoVenda.Link(&DeOndeVem, EmpCod, FilCod, PedCod)
				Case &FechaPedidoSomenteComEstoque = 'S' and &IsSemEstoque = true
					msg('No pedido existe produtos que não possuem estoque suficiente! [CONF58]')
					
					//			Case &LiberaCreditoPedido = 'S' and &IsPodeFaturar = false
					//				msg('Pedido não liberado para Faturamento! Falta Liberação do Crédito! [CONF23]')
					
				Case LctAtuSal = Status_EntradaSaida.Nenhum
					msg('Pedido em Operação que não atualiza saldos, não permitido para fazer nota!')
					
				Case (PedSts <> Status_Pedido.ABERTO) And (PedSts <> Status_Pedido.SEPARANDO)
					msg('Somente pedidos com o status estoque "ABERTO" ou "SEPARANDO" pode fazer nota!')
					
				Otherwise
					
					RetornaTotalDuplicatasDoPedido.Call(EmpCod, FilCod, PedCod, &TotalPago)
					RetornaTotalCreditoDoPedido.Call(EmpCod, FilCod, PedCod, &TotalCredito)
					&PedVlrSld = (PedVlrLiq - &TotalPago - &TotalCredito)
					
				Do Case
					Case &PedVlrSld > 0 and PedStsFin <> status_financeiro.FECHADO 
						wppedido_fechafinanceiroagr.call('WWPEDIDOVENDAAGR', EmpCod, FilCod, PedCod, 0, false)
//						wpSelecionaProdutosNFe.Link(&DeOndeVem, EmpCod, FilCod, PedCod)
					Otherwise 
						GravaNotaTemporariaVenda.Call(EmpCod, FilCod, PedCod, '55')
						wpSelecionaProdutosNFe.Link(&DeOndeVem, EmpCod, FilCod, PedCod)
				EndCase
			
			EndCase
	
			Exit
		EndFor
	Else
		msg('Não Autorizado ao Nível de Fechar Estoque Pedido Venda. [VENDAFECHAESTOQUE]')
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	loadwwpContext.Call(&wwpContext)
	
	RetornaValorSaldo.Call(&EmpCod, &FilCod, &PedCod, &PedCodOciRef, &CreVlrSdo, &Mensagem)
	txtqtdSal.Caption = trim(&Mensagem)
	
	Padraousuario.Call('L', '#ZERASALDOFUTURO#'+trim(str(&Pedcod)), &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	&ZerarSaldo = iif(&PadObs = '1', true, false)

EndEvent

Sub 'loadOrdemCarregamento'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		TextblockTitle.Caption = 'Ordem Carregamento: ' + trim(str(PedCod))
		
		&PedCodOciRef = PedCodOciRef
		Exit
	Endfor

EndSub


]]></Source>
