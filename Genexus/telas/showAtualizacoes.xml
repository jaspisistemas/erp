Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Compilacao.Call(false, &Compilacao, &IsExecutaUpdate, &DisEmpVer, &DisEmpCmp)

EndEvent

Event FreeStyleGrid1.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&sdtGridVersaoItem 	= &sdtGridVersoes.CurrentItem
	Novidade.Visible	= IIf(&sdtGridVersaoItem.data = &Today, True, False)
	Novidade.Caption	= IIf(&sdtGridVersaoItem.data = &Today, 'Atualizado hoje', '')

EndEvent

Event FreeStyleGrid2.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	for &sdtGridVersaoItemTipo in &sdtGridVersaoItem.tipos
		&Tipo = &sdtGridVersaoItemTipo.tipo
		load
	endfor

EndEvent

Event FreeStyleGrid3.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	for &sdtGridVersaoItemTipoItem in &sdtGridVersaoItemTipo.Itens
		&CodigoItemFormatado = &sdtGridVersaoItemTipoItem.codigoFormatado
		&titulo = &sdtGridVersaoItemTipoItem.titulo
		&Descricao = &sdtGridVersaoItemTipoItem.descricao
		
		&Titulo.TooltipText = &sdtGridVersaoItemTipoItem.tarefa
		load
	endfor

EndEvent

Event 'DoMaisVersoes'

	WWversao.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	do 'Load'

EndEvent

Sub 'Load'

	&sdtGridVersoes = CarregaAtualizacoes()
	
	&VersaoVarChar	= 'Você está na Versão: ' + Trim(Str(&DisEmpCmp))
	WWPActions.WCPopup_UpdateTitle(&VersaoVarChar)

EndSub


