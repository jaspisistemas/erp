      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	do 'loadProduto'
	do 'loadNcm'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'loadNcm'
	if &IsErroNcm = true
		msg('Não Localizado NCM ou fora da Vigencia!')
	Else
		GravaNcmProduto.Call(&EmpCod, &ProCod, &NovNcmCod, &NovProNcmCest, &Context.UserName)
		Return
	Endif

EndEvent

Event &NovNcmCod.IsValid

	do 'loadNcm'

EndEvent

Sub 'loadProduto'

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&ProGraRef = ProGraRef
		&ProNomGra = ProNomGra
		
		&NcmCod = NcmCod
		&ProNcmCest = ProNcmCest
		&NovNcmCod = NcmCod
		&NovNcmDes = NcmDes
		&NovProNcmCest = ProNcmCest
		
		Exit
	EndFor

EndSub

Sub 'loadNcm'

	&NovNcmDes.SetEmpty()
	&IsErroNcm = true
	For Each Order NcmCod
		Where NcmCod = &NovNcmCod
		&NovNcmDes = NcmDes	
		&IsErroNCM = false
		
		if NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()
			&NovNcmDes = ' FIM DA VIGENCIA DO NCM: ' + trim(str(NcmCod))
			&IsErroNCM = true
		Endif
	
		Exit
	When none
		Do CAse
			CAse &NovNcmCod =  0
				&NovNcmDes = 'CÓDIGO 00000000 - SERVIÇOS'
				&IsErroNCM = false
			CAse &NovNcmCod =  99
				&NovNcmDes = 'CÓDIGO NCM NÃO INFORMADO!'
			Otherwise
				&NovNcmDes = 'CÓDIGO NCM NÃO CADASTRADO/INVÁLIDO!'
		EndCAse
	EndFor

EndSub


]]></Source>
