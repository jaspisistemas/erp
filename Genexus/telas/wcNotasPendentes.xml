      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtAlerta.Caption = ''
	txtAlerta.ForeColor = RGB(178,0,0)
	&AvisoVencimentoMensagem = ''
	
	&Count = 0
	For Each Order EmpCod,NfeProTer,NfeSts, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_NFe.Digitando
		Where not NfeNum.IsEmpty()
		
		if ModCod = '55'
			&Count55 += 1
		Else
			&Count65 += 1
		Endif
	EndFor

	if &Count55 > 0 or &Count65 > 0
		if &Count55 > 0
			&AvisoVencimentoMensagem = 'Atenção, Existem ('+ trim(str(&Count55)) + ') NF Modelo 55 pendentes de Autorização!'
			&AvisoVencimentoMensagem += newLine()
		Endif
		if &Count65 > 0
			&AvisoVencimentoMensagem += 'Atenção, Existem ('+ trim(str(&Count65)) + ') NF Modelo 65 pendentes de Autorização!'
		Endif
	EndIF
	
	&Count = 0
	For Each Order EmpCod,CteSts ,FilCod, CteCod
		Where EmpCod = &EmpCod
		Where CteSts = Status_NFe.Digitando
		&Count += 1
	EndFor
	if &Count > 0
		if not &AvisoVencimentoMensagem.IsEmpty()
			&AvisoVencimentoMensagem += NewLine()
		EndiF
	
		&AvisoVencimentoMensagem = 'Atenção, Existem ('+ trim(str(&Count)) + ') nota(s) de Transporte pendentes de Autorização!'
	EndIF
	
	txtAlerta.Caption = &AvisoVencimentoMensagem

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&AvisoVencimentoMensagem <> '')
		DVPanel_TableContent_Cell.Class = !'Invisible'
	Else
		DVPanel_TableContent_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
