      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&EmpCod = &inEmpCod
	&CxPdvCod = &inPdvCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid_TitlesCategories.GridInternalName = Grid.InternalName
	&CxSts = nullvalue(&CxSts)
	Form.Caption = ' CAIXA'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CxDtaHorIni = serverNow()
	&CxDtaHorIni = &CxDtaHorIni.AddDays(-15)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	CxSts.ColumnHeaderClass = !'WWColumn hidden-xs'
	&SaldoMoeda.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&AdicionarAjustes = !'<i class="fas fa-pen"></i>'
	
	&ImprimirCAixa = !'<i class="fas fa-print"></i>'
	
	&CxUsuDin = CxUsuDin+CxUsuChq
	&SaldoMoeda = &CxUsuDin - CxVlrFin
	Do Case
		Case CxSts = Status_AbertoFechado.Aberto
			CxSts.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case CxSts = Status_AbertoFechado.Fechado
			CxSts.ColumnClass = !'WWColumn hidden-xs WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			CxSts.ColumnClass = 'WWColumn hidden-xs'
	EndCase
	Do Case
		Case &SaldoMoeda < 0
			&SaldoMoeda.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case &SaldoMoede = 0
			&SaldoMoeda.ColumnClass = !'WWColumn WWColumnBold WWColumnBoldSingleCell'
		Case &SaldoMoeda > 0
			&SaldoMoeda.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Otherwise
			&SaldoMoeda.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadGridState'

if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"CXPDVCOD"
				&CxPdvCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"CXSTS"
				&CxSts.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"CXDTAHORINI"
				&CxDtaHorIni.FromString(&GridStateFilterValue.Value)
				&CxDtaHorIni_To.FromString(&GridStateFilterValue.ValueTo)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Endif

EndSub

Sub 'SaveGridState'

if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"CXPDVCOD", "", not &CxPdvCod.IsEmpty(), 0, &CxPdvCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"CXSTS", "", not &CxSts.IsEmpty(), 0, &CxSts, '')
	WWP_GridStateAddFilterValue(&GridState, !"CXDTAHORINI", "", not (&CxDtaHorIni.IsEmpty() AND &CxDtaHorIni_To.IsEmpty()), 0, &CxDtaHorIni.ToString().Trim(), &CxDtaHorIni_To.ToString().Trim())

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Endif

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"CAIXA"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &AdicionarAjustes.Click

	wpConferenciaCaixa.Popup(EmpCod, CxPdvCod, CxCod)
	Refresh

EndEvent

Event &ImprimirCAixa.Click

	wpLancamentosCaixa.Link(EmpCod, CxPdvCod, CxCod)

EndEvent


]]></Source>
