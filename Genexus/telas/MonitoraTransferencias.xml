        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	GridSDT_MovimentoTransferencias.Rows = Page.Rows
	GridSDT_MovimentoTransferencias_TitlesCategories.GridInternalName = GridSDT_MovimentoTransferencias.InternalName
	GridSDT_MovimentoTransferenciasPaginationBar.RowsPerPageSelectedValue = GridSDT_MovimentoTransferencias.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CreCredito.SetEmpty()
	&CreDebito.SetEmpty()
	&MovDtaCon = ServerDate() - 7  
	&MovDtaCon_To = ServerDate()

EndEvent

Event Refresh

	&CreCredito.SetEmpty()
	&CreDebito.SetEmpty()
	&SDT_MovimentoTransferencia.Clear()
	RetornaSDT_MovimentoTransferencia.Call(&EmpCod,&OrigemCtabanCod,&DestinoCtabanCod,&MovVlr,&MovDtaCon,&MovDtaCon_To,&SDT_MovimentoTransferencia)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridSDT_MovimentoTransferenciasCurrentPage = GridSDT_MovimentoTransferencias.CurrentPage
	&GridSDT_MovimentoTransferenciasPageCount = GridSDT_MovimentoTransferencias.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSDT_MovimentoTransferencias.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CreMovCod = &SDT_MovimentoTransferencia.CurrentItem.CreMovCod
	&CreMovCtaBanCod = &SDT_MovimentoTransferencia.CurrentItem.CreMovCtaBanCod
	&CreMovCtaBanNom = &SDT_MovimentoTransferencia.CurrentItem.CreMovCtaBanNom
	&CreMovVlr = &SDT_MovimentoTransferencia.CurrentItem.CreMovVlr
	&CreMovDoc = &SDT_MovimentoTransferencia.CurrentItem.CreMovDoc
	
	&gridMovDtaCon = &SDT_MovimentoTransferencia.CurrentItem.MovDtaCon
	
	&DebMovCod = &SDT_MovimentoTransferencia.CurrentItem.DebMovCod
	&DebMovDoc = &SDT_MovimentoTransferencia.CurrentItem.DebMovDoc
	&DebMovCtaBanCod = &SDT_MovimentoTransferencia.CurrentItem.DebMovCtaBanCod
	&DebMovCtaBanNom = &SDT_MovimentoTransferencia.CurrentItem.DebMovCtaBanNom
	&DebMovVlr = &SDT_MovimentoTransferencia.CurrentItem.DebMovVlr
	
	&CreCredito	+= &SDT_MovimentoTransferencia.CurrentItem.CreMovVlr	
	&CreDebito +=  &SDT_MovimentoTransferencia.CurrentItem.DebMovVlr
	&CreMovVlr.ForeColor = RGB(0,0,255)
	&DebMovVlr.ForeColor = RGB(255,0,0)

EndEvent

Event GridSDT_MovimentoTransferenciasPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridSDT_MovimentoTransferenciasPaginationBar.SelectedPage = !'Previous'
			GridSDT_MovimentoTransferencias.PreviousPage()
		Case GridSDT_MovimentoTransferenciasPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridSDT_MovimentoTransferencias.CurrentPage
			&PageToGo += 1
			GridSDT_MovimentoTransferencias.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridSDT_MovimentoTransferenciasPaginationBar.SelectedPage)
			GridSDT_MovimentoTransferencias.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridSDT_MovimentoTransferenciasPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridSDT_MovimentoTransferencias.Rows = GridSDT_MovimentoTransferenciasPaginationBar.RowsPerPageSelectedValue
	GridSDT_MovimentoTransferencias.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRelatorio'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	PadraoUsuario.Call('G','SDT_MOVIMENTOTRANSFERENCIA',&Context.PesCod,&Context.EmpCod,&SDT_MovimentoTransferencia.ToJson(),&Today)
	
	RCOOpen.LinkOpen = RELJAS140.link(&EmpCod,&Context.PesCod,&MovDtaCon,&MovDtaCon_To,&OrigemCtabanCod,&DestinoCtabanCod)
	RCOOpen.OpenWindow(True, 500, 500, True, 0, 0, False)

EndEvent

Event 'DoVoltar'

	return

EndEvent


