      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	&EmpCod = &parEmpCod
	
	do 'loadEmpresa'
	
	if &Context.Old_Perfil <> 3
		&EmpCod.Enabled = 0
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &EmpCod.IsValid

	do 'loadEmpresa'

EndEvent

Event Enter

	&EmpCod.Enabled = 0
	Compilacao.Call(true, &Compilacao, &isExecutaUpdate, &DisEmpVer, &DisEmpCmp)	
	ppJASPI_Rotinas_WSDL.Call(&EmpCod, &EmpCodSec, &Compilacao, &ppJaspi_RotinasSdtEstruturaMenus, &erro)
	If &Erro = 0
		ppJASPI_Widgets_WSDL.Call(&EmpCod, &EmpCodSec, &Compilacao, &ppJASPI_WidgetssdtWidgets_sdtWidgetsItem, &erro)
		If &Erro = 0
			padraousuario.Call('G', 'TESTE', 1, 1, &ppJASPI_WidgetssdtWidgets_sdtWidgetsItem.ToXml(), &padDtaMod )
			GravaWidgets.Call(&EmpCod, &ppJASPI_WidgetssdtWidgets_sdtWidgetsItem)
			
			
			if &ppJaspi_RotinasSdtEstruturaMenus.SdtMod.Modulos.Count > 0
				GravaMenus.Call(&EmpCod, &ppJaspi_RotinasSdtEstruturaMenus)
				msg('Menus Atualizados com Sucesso!')
				if &EmpCod = &Context.EmpCod //So carrega as novas configuracoes se a empresa logada for a mesma da selecionada.
					ProcLoadInicio.Call(&Context.EmpCod, &Context.FilCod, &IsOkLicenca, &IsOkAcesso)
				Endif
			
			Else
				msg('Não localizado Módulos para o Cliente')
			EndIF
		Else
			msg('Erro ao Syncronizar Menus!')
		EndIF
	EndIf
	
	&EmpCod.Enabled = 1

EndEvent

Sub 'loadEmpresa'

For Each Order EmpCod
	Where EmpCod = &EmpCod
	&EmpRaz = EmpRaz
	&EmpCodSec = EmpCodSec
	Exit
EndFor

EndSub


]]></Source>
