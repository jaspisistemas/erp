      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Form.HeaderRawHTML = '<link rel="shortcut icon" href="Resources/jaspi.png" type="image/x-icon">'
	Form.HeaderRawHTML += '<link rel="icon" href="Resources/jaspi.png" type="image/x-icon">'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &UserPasswordNew = &UserPasswordNewConf
		&User = GAMRepository.GetUserByLogin(&UserAuthTypeName, &UserName, &Errors)
		If &Errors.Count = 0
			&ChangePwdOK = &User.ChangePassword(&UserPassword, &UserPasswordNew, &Errors)
			If &ChangePwdOK
				commit
				
				&AdditionalParameter.RememberUserType = &UserRememberMe
				&LoginOK = GAMRepository.Login(&UserName, &UserPasswordNew, &AdditionalParameter, &Errors )
				If &LoginOK
					&URL = GAMRepository.GetLastErrorsURL()
					&UserNick = &GAMUser.GetName()
					
					If upper(&UserNick) = 'SUPORTE.JASPI'
						&QtdEmpCod = RetQtdEmp.udp()
						If &QtdEmpCod > 1
							WWAdmin.Link()
						Else
							For Each ORder EmpCod, FilCod
								ProcLoadInicio.Call(EmpCod, FilCod, &IsLicenciado,&IsOkAcesso)
								Exit
							EndFor
						EndIF
					Else
						If Not &GAMUser.GetExternalId().IsEmpty()
							ProcLoadInicio.Call(0,0, &IsLicenciado,&IsOkAcesso)
						EndIF
					EndIF
					
					If &URL.IsEmpty()
						Dashboard.Link()
					Else
						Link(&URL)
					Endif
				Else
					Do 'DisplayMessages'
				EndIf
			Else
				Do 'DisplayMessages'
			Endif
		Else
			Do 'DisplayMessages'
		Endif
	Else
		Msg("A Nova Senha e a Confirmação não Correspondem.")
	Endif

EndEvent

Sub 'DisplayMessages'

	For &Error in &Errors
		Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
	EndFor

EndSub


]]></Source>
