      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbALERTANAOCADASTRADO.Visible = 0
	&HojeData = serverdate()
	RetornaAutorizacao.Call('WWBALANCO', Status_SimNao.Sim, 2, &AutNiv)

	&EmpCod = &AuxEmpCod
	&FilCod = &AuxFiLCod
	&BalCod = &AuxBalCod
	&ProGraCod = 1
	textMsg.Caption = ''
	estoquelocacao.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbALERTANAOCADASTRADO1.Height = 80
	estoquelocacao.Width = 100
	&ProCod.Visible = False
	&ProGraCod.Visible = False
	wcProBal.Object = wcProdutosBalanco.Create(&EmpCod, &FilCod, &BalCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadBalanco'

EndEvent

Event 'DoEliminarItem'

	Do 'loadProduto'
	If &ProCod <> 0 and &ProGraCod <> 0 and &erro = 0
		RemoveProdutoBalanco.Call(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod, &RemovidoMensagem)
		If not &RemovidoMensagem.IsEmpty()
			do 'limpaCampos'
			wcProBal.refresh()
			
			textMsg.Caption = &RemovidoMensagem.Trim()
			textMsg.ForeColor = RGB(180,20,10)
		EndIF
		&ProGraRef.SetEmpty()
		&ProGraRef.SetFocus()
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnLote'

	do 'loadProduto'
    If (&ProCod <> 0 and &ProGraCod <> 0) and &erro = 0
		if (&ProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &ProGraCod = 1)
			
			GravaProdutoBalanco.Call(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod, &BalQtd, &InseridoMensagem, &AtualizadoMensagem)
			Do Case
				Case not &AtualizadoMensagem.IsEmpty()
					textMsg.Caption = &AtualizadoMensagem.Trim()
					textMsg.ForeColor = RGB(0,160,40)
					
				Case not &InseridoMensagem.IsEmpty()
					textMsg.Caption = &InseridoMensagem.Trim()
					textMsg.ForeColor = RGB(0,0,160)
			EndCase
	        
			BalancoProdutoLote.Popup(TrnMode.Update, &EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod)
			
			do 'limpaCampos'	
			&ProGraRef.SetEmpty()
			wcProBal.Refresh()
		Else
			msg('Produto com Variação, é preciso inserir o Código da Variação!')
		EndIF
	
    EndIF
	
	&ProGraRef.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharBal'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWBalanco.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInicializar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Inicializar_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Inicializar_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpInicializarBalanco.Create(&EmpCod, &FilCod, &BalCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImportarColetor'

	wpImportarBalanco.Popup(&EmpCod, &FilCod, &BalCod)
	wcProBal.refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoViaCodigoBarras'

	wpBalancoItemCodigoBarras.Link(&AuxEmpCod, &AuxFilCod, &AuxBalCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DobtnImprimir'

	wpImprimirBalanco.Popup(&EmpCod, &FilCod, &BalCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFecharBalanco'

	do 'loadBalanco'
	If &BalSts = Status_Pedido.ABERTO
		&AutNiv = RetornaAutorizacao.UDP('FECHARBALANCOESTOQUE', Status_SimNao.Nao, 1)
		if &AutNiv > 0
			VerificaLoteInformadoBalanco.Call(&EmpCod, &FilCod, &BalCod, 0, 0, &IsTodosInformados)
			
			if &IsTodosInformados = TRUE //TUDO CERTO

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	FecharBalanco_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

Else //AJUSTAR ERROS
				wpInformaLotesFaltantesBalanco.Link('WWBALANCO', &EmpCod, &FilCod, &BalCod)
			Endif
		Else
			msg('Não Autorizado ao Nível de Fechar a Balanço de Estoque. [FECHARBALANCOESTOQUE]')
		EndiF		
	Else
		msg('Somente Balanço Aberto pode ser Fechado!')
	EndIf

EndEvent

Event FecharBalanco_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpFecharBalanco.Create(&EmpCod, &FilCod, &BalCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&EmpCod = &AuxEmpCod
	&FilCod = &AuxFiLCod
	&BalCod = &AuxBalCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Inicializar_Modal.Close

	wcProBal.refresh()

EndEvent

Event FecharBalanco_Modal.Close

	wwBalanco.Link()

EndEvent

Event 'F4Produto'

 4
	PromptProdutoGradeRef.Popup(&EmpCod, &ProCod, &ProGraCod, &ProGraRef)
	&ProGraRef.SetFocus()

EndEvent

Event &ProGraRef.IsValid

	tbALERTANAOCADASTRADO.Visible = 0
	RetornaProdutoReferencia.Call(&EmpCod, &ProGraRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	
	&BalQtd = VerificaExisteProdutoBalanco.UDP(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod)
	Do 'loadProduto'
	&BalQtd.SetFocus()

EndEvent

Event Enter

    do 'loadProduto'
    If (&ProCod <> 0 and &ProGraCod <> 0) and &erro = 0
		if (&ProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &ProGraCod = 1)
			
			GravaProdutoBalanco.Call(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod, &BalQtd, &InseridoMensagem, &AtualizadoMensagem)
			Do Case
				Case not &AtualizadoMensagem.IsEmpty()
					textMsg.Caption = &AtualizadoMensagem.Trim()
					textMsg.ForeColor = RGB(0,160,40)
					
				Case not &InseridoMensagem.IsEmpty()
					textMsg.Caption = &InseridoMensagem.Trim()
					textMsg.ForeColor = RGB(0,0,160)
			EndCase
			&ProGraRef.SetEmpty()
	        do 'limpaCampos'
			
			wcProBal.Refresh()
		Else
			msg('Produto com Variação, é preciso inserir o Código da Variação!')
		EndIF
	
    EndIF
	
	&ProGraRef.SetFocus()

EndEvent

Sub 'loadBalanco'

	For each Order EmpCod, FilCod, BalCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where BalCod = &BalCod
			if BalDta = &HojeData
				tbEstoqueData.Visible = 0
			Else
				txtMensagemAvisoData.Caption = 'Modificando estoque do dia: '+ trim(toformattedString(BalDta))
			Endif
		
			&BalDta = BalDta
			&AuxFim = &HojeData.AddDays(1)
			&DataBaseBalDta = BalDta.AddDays(1)
			&EstDataVarchar.Caption = 'Estoque '+ trim(toformattedString(BalDta))
			
			&FilCodNom = FilCodNom
			&BalSts = BalSts
			If BalSts <> Status_Pedido.ABERTO
				wwbalanco.Link()
			EndIF
		Exit 
	EndFor

EndSub

Sub 'loadProduto'

	textMsg.Caption = ''
	&ProSolLot.SetEmpty()
	estoquelocacao.Visible = 0
	
    For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
	    Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&ProSolLot = ProSolLot
        &ProNom = ProNomGra
		&ProIsGra = ProIsGra
        &erro = 0
		if ProSolLot = SolicitarLote.SIM_CONTROLAR
			estoquelocacao.Visible = 1
		Endif
		
	    Exit
    When none
		tbALERTANAOCADASTRADO.Visible = 1
		
        &erro = 1
		If &ProCod <> 0 or not &ProGraRef.IsEmpty()
	        &ProNom = 'Produto nao localizado.'
			msg(&ProNom)
			textMsg.Caption = &ProNom
			textMsg.ForeColor = RGB(180,0,0)
		Else
			Refresh
		EndIf
		
    EndFor
	
	RetornaEstoquePedido.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, Status_Pedido.ABERTO, &EstLoc, &EstQtd,&EstSdo, &Mensagem)
	
	if &BalDta <> &HojeData
		EstoqueAnteriorFicha.Call(&EmpCod, &FilCod, &ProCod, &ProGracod, 1, &DataBaseBalDta, &AuxFim, &EstData)
		&EstDataVarchar = RetirazerosDepoisVirgula.UDP(&EstData.ToFormattedString())
	Else
		&EstData = &EstQtd
	Endif
	&EstQtdVarchar = RetirazerosDepoisVirgula.UDP(&EstQtd.ToFormattedString())

EndSub

Sub 'limpaCampos'

	&EstData = 0
	&EstDatavarchar = '0'
	&EstQtdVarchar = '0'
    &BalQtd = 0
    &ProCod = 0
    &ProNom = ''

EndSub


