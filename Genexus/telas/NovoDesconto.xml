Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &DesTip.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Tipo:'), DVMessageType.error, &DesTip.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CbrCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','L.Cobrança'), DVMessageType.error, &CbrCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &DesPlanCodTrf.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', 'Selecione um Plano de Contas para a Tarifa.', DVMessageType.error, &DesPlanCodTrf.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &DesPlanCodDesc.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', 'Selecione um Plano de Contas para o Desconto.', DVMessageType.error, &DesPlanCodDesc.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &DesOpe.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', 'Selecione o tipo de lançamento', DVMessageType.error, &DesOpe.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

