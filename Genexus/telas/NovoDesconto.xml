EndEvent

Event Enter

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult = true
		if not &DesVlr.IsEmpty()
			GravaDesconto.Call(&mode, &EmpCod, &DesCod, &DesDta, &DesTip, &CbrCod, &DesVlr, &DesPlanCodDesc, &DesPlanCodTrf, &DesMovCodCre, &DesMovCodTxa, &DesSts,&DesOpe)
			Do 'loadLclCobranca'
			prcValidaCaixaAberto.Call(&EmpCod, &CtaBanCod, &DesDta, &IsCaixaFechado, &Msg)
			if &Count >= 1 
				if &IsCaixaFechado = false and &DesSts = Status_AbertoFechado.Aberto //se tiver fechado nao mexe financeiro nem altera ?
					GravaFinanceiroDesconto.Call(&EmpCod, &DesCod,&DesOpe)
					wwDesconto.Link()
				else
					msg(&msg)
				EndIf
			else
				msg('Atenção! Nenhuma duplicata selecionada para descontar.')
				WpSelecionaDuplicatasDesconto.Popup(&EmpCod, &DesCod)
			EndIf
		else
			msg('Para finalizar o desconto é necessário informar o valor da tarifa.')
		EndIf
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

