      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWDESCONTO', Status_SimNao.Sim, 2, &AutNiv)
	
	if &mode = TrnMode.Insert
		&DesDta = ServerDate()
		&DesSts = Status_AbertoFechado.Aberto
	else
		Do 'loadDesconto'
		if &DesSts = Status_AbertoFechado.Fechado
			&DesDta.Enabled = 0
			&DesVlr.Enabled = 0
			textAtencao.Visible = 0
			&DesPlanCodDesc.Enabled = 0
			&DesPlanCodTrf.Enabled = 0
			&DesTip.Enabled = 0
			&CbrCod.Enabled = 0
		Else
			&DesDta.Enabled = 1
			&DesVlr.Enabled = 1
			&DesPlanCodDesc.Enabled = 1
			&DesPlanCodTrf.Enabled = 1
			&DesTip.Enabled = 1
			&CbrCod.Enabled = 1
		EndIf
		
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&CbrCodNom.Visible = False
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'CheckSecurityForActions'

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	&DesItmSts.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = Grid.PageCount
	&GridCurrentPage = Grid.CurrentPage
	&Count.SetEmpty()
	&TotalMoeda.SetEmpty()

EndEvent

Event Grid.Load

	&DesItmSts.SetEmpty()
	&Count += 1
	&DesDupItmCod = DesDupItmCod
	&DesCreCod = DesCreCod
	&DesFilCod = DesFilCod
	Do 'loadDuplicata'
	&TotalMoeda += &CreVlrDup
	
	Do case
		case &CreSts = Status_Duplicata.DESCONTADA and &DesSts = Status_AbertoFechado.Aberto
			&DesItmSts = 'N' //Em negociação
			
		case &CreSts = Status_Duplicata.ATIVO or &CreSts = Status_Duplicata.EM_REMESSA
			&DesItmSts = 'E' //Extornada
			
		case &CreSts = Status_Duplicata.DESCONTADA and &DesSts = Status_AbertoFechado.Fechado
			&DesItmSts = 'D' //descontada
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Remover.FromImage(ico_error)
	&Remover.TooltipText = ""
	If (&DesSts = Status_AbertoFechado.Aberto)
		&Remover.Class = !'Attribute10_Bold1'
	Else
		&Remover.Class = !'Invisible'
	Endif
	&ActionGroupGrid.Clear()
	&ActionGroupGrid.AddItem(0, 'WWP_ActionGroupCaption')
	If (&DesSts = Status_AbertoFechado.Fechado and &CreSts = Status_Duplicata.Descontada)
		&ActionGroupGrid.AddItem(1, 'Extornar')
	Endif
	If &ActionGroupGrid.Count = 1
		&ActionGroupGrid.Class = !'Invisible'
	Else
		&ActionGroupGrid.Class = !'Attribute'
	EndIf

