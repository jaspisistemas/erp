	RemoveFinanceiroDesconto.Call(&EmpCod, &DesCod, 1) //niv 1 nao deleta a capa nem as duplicatas selecionadas (tabelas Desconto e DescontoDuplicatas)
	Refresh
	NovoDesconto.Link(TrnMode.Update, &EmpCod, &DesCod)

