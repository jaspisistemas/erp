Sub 'loadLclCobranca'

	For each order EmpCod, CbrCod
		where EmpCod = &EmpCod
		where CbrCod = &CbrCod
		&CtaBanCod = CbrCtaBanCod
		exit
	EndFor

EndSub

Sub 'loadDuplicata'

	&CreCliCodRaz.SetEmpty()
	&CreDtaEms.SetEmpty()
	&CreDtaVct.SetEmpty()
	&CreDupNro.SetEmpty()
	
	For each order EmpCod, FilCod, CreCod
		where EmpCod = &EmpCod
		where FilCod = &DesFilCod
		where CreCod = &DesCreCod
		&CreCliCodRaz = CreCliCodRaz
		&CreDtaEms = CreDtaEms
		&CreDtaVct = CreDtaVct
		&CreDupNro = CreDupNro
		&CreVlrDup = CreVlrDup
		&CreVlrSdo = CreVlrSdo
		&CreSts = CreSts
		
		If CreNovCliRaz_Formula.Length() > 30
			&CreNovCliRaz = substr(CreNovCliRaz_Formula, 1, 30) + '...'
		Else
			&CreNovCliRaz = CreNovCliRaz_Formula	
		EndIf
		
		exit
	EndFor

EndSub

Sub 'loadDesconto'

	For each order EmpCod, DesCod
		where EmpCod = &EmpCod
		where DesCod = &DesCod
		&DesDta = DesDta
		&DesTip = DesTip
		&CbrCod = CbrCod
		&DesVlr = DesVlr
		&DesSts = DesSts
		&DesPlanCodDesc = DesPlanCodDesc
		&DesPlanCodTrf = DesPlanCodTrf
		&DesMovCodTxa = DesMovCodTxa
		&DesMovCodCre = DesMovCodCre
		&DesOpe = DesOpe
		exit
	EndFor

EndSub


