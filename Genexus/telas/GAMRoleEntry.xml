      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SecurityPolicies = GAMRepository.GetSecurityPolicies(&Filter, &Errors)
	&RoleSecurityPolicyId.AddItem(0,"WWP_GAM_None")
	
	For &SecurityPolicy in &SecurityPolicies
		&RoleSecurityPolicyId.AddItem(&SecurityPolicy.Id,&SecurityPolicy.Name)
	EndFor
	If &Mode <> GAMAPiMode.Insert
		&Role.Load(&Id)
		&RoleId = &Role.Id
		&RoleGUID = &Role.GUID
		&RoleName = &Role.Name
		&RoleDescription = &Role.Description
		&RoleExternalId = &Role.ExternalId
		&RoleSecurityPolicyId = &Role.SecurityPolicyId
	Endif
	If &Mode = TrnMode.Display
		BtnEnter.Visible = False
	Endif
	If &Mode = TrnMode.Display or &Mode = TrnMode.Delete
		&RoleSecurityPolicyId.Enabled = False
		&RoleName.Enabled = False
		&RoleDescription.Enabled = False
		&RoleExternalId.Enabled = False
		If &Mode = TrnMode.Delete
			BtnEnter.Caption = "Delete"
		endif
	Endif
	&Role.Id	= &Id

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&Role.Load(&Id)
	Do Case
		Case &Mode = GAMAPiMode.Insert or &Mode = GAMAPiMode.Update
			&Role.Name = &RoleName
			&Role.Description = &RoleDescription
			&Role.ExternalId = &RoleExternalId
			&Role.SecurityPolicyId = &RoleSecurityPolicyId
			&Role.Save()
		Case &Mode = GAMAPiMode.Delete
			&Role.Delete()
	EndCase
	If &Role.Success()
		Commit
		return
	Else
		&Errors = &Role.GetErrors()
		For &Error in &Errors
			Msg(Format(!"%1 (GAM%2)", &Error.Message, &Error.Code))
		EndFor
	Endif

EndEvent


]]></Source>
