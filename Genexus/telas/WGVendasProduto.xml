      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	retornaAutorizacao.Call('WGVENDASPRODUTO', Status_SimNao.Sim, 1, &AutNiv)
	&EmpCod = &Context.EmpCod
	&PedDtaFat = &Today - 30
	&PedDtaFat_Go = &Today
	If &Context.PesIsVen = true
		retornaAutorizacao.Call('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1, &AutNivTel)
		If &AutNivTel = 0
			&PedVenCod = &Context.PesCod
			&PedVenCod.Enabled = 0
			Do 'Vendedor'
		EndIF
	EndIF
	Do "SetQueryViewerParametersExample"
	Do "SetObjectNameExample"

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do "SetQueryViewerParametersExample"
	Do "SetObjectNameExample"

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRelatorio'

	WpRankingProduto.Call()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedVenCod.IsValid

	Do 'Vendedor'
	Do "SetQueryViewerParametersExample"
	Do "SetObjectNameExample"

EndEvent

Sub "SetObjectNameExample"

	// Change query or dataprovider in runtime
	QueryViewer1.ObjectName = "QVendasProduto"			// Or QueryViewer1.ObjectName = &CharacterVariable

EndSub

Sub "SetQueryViewerParametersExample"

	// Set query or dataprovider parameters in runtime

	&Parameters = New()
	// Date parameter
	&Parameter = New()
	&Parameter.Name = "PedDtaFat"
	&Parameter.Value = &PedDtaFat.ToString() 				// Or &Parameter.Value = &NumericVariable.ToString().Trim()
	&Parameters.Add(&Parameter)

	// Date parameter
	&Parameter = New()
	&Parameter.Name = "PedDtaFat_Go"
	&Parameter.Value = &PedDtaFat_Go.ToString()		// Or &Parameter.Value = &DateVariable.ToString()
	&Parameters.Add(&Parameter)
	
	// Date parameter
	&Parameter = New()
	&Parameter.Name = "EmpCod"
	&Parameter.Value = &EmpCod.ToString().Trim()		// Or &Parameter.Value = &DateVariable.ToString()
	&Parameters.Add(&Parameter)
	
	&Parameter = New()
	&Parameter.Name = "PedVenCod"
	&Parameter.Value = &PedVenCod.ToString().Trim()		// Or &Parameter.Value = &DateVariable.ToString()
	&Parameters.Add(&Parameter)

EndSub

Sub 'Vendedor'

	If &PedVenCod = 0
		&PedVenRaz = 'TODOS OS VENDEDORES'
	Else
		For each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &PedVenCod
			Where PesIsVen = True
			&PedVenRaz = PesRaz
			Exit
		When none
			msg('Vendedor não encontado ou pessoa não é vendedor!')
			&PedVenRaz = 'VENDEDOR NÃO ENCONTRADO'
			&PedVenCod.SetFocus()
		EndFor
	EndIf

EndSub


]]></Source>
