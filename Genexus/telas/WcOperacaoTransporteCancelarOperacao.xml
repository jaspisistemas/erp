      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'GetCIOT'

EndEvent

Event 'DoConfirmar'

	Do Case
		Case &OpeNroCiot.IsEmpty()
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O número do CIOT é obrigatório', DVMessageType.regular, "", DVMessageBoolean.True,""))
			&OpeNroCiot.SetFocus()
			
		Case &OpeMotCan.IsEmpty()
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'O motivo do Cancelamento é obrigatório.', DVMessageType.regular, "", DVMessageBoolean.True,""))
			&OpeMotCan.SetFocus()
			
		Case &OpeTerCan = False
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", 'Você precisa estar ciente de que o cancelamento não poderá ser desfeito.', DVMessageType.regular, "", DVMessageBoolean.True,""))
			&OpeTerCan.SetFocus()
			
		OtherWise
			
			prcNovoEFrete_Login.Call(&Token, &ProtocoloServico, &StatusLogin)
			
			If &StatusLogin = 200
				prcNovoEfrete_PEFCancelarOperacao.Call(&Token, &parmOpeCod, &OpeNroCiot, &OpeTerCan, &OpeMotCan, &StatusCode)				
				If &StatusCode = 200
					WWPActions.WCPopup_Close('')
				EndIf
				
			Else
				Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &StatusLogin.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
			EndIf
			
			If not &Token.Trim().IsEmpty()
				prcNovoEFrete_Logout.Call(&Token, &StatusLogOut)
			EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndCase

EndEvent

Event 'DoCancelar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'GetCIOT'

	For Each Order EmpCod, FilCod, OpeCod
		Where EmpCod 	= &parmEmpCod
		Where FilCod	= &parmFilCod
		Where OpeCod	= &parmOpeCod
		
		&OpeNroCiot		= OpeNroCiot
		
		Exit
	EndFor

EndSub


]]></Source>
