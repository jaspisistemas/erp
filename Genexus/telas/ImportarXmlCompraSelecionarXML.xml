      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbprogresso.Visible = 0
	textlink.Link = "https://www.nfe.fazenda.gov.br/portal/consulta.aspx?tipoConsulta=completa&tipoConteudo=XbSeqxE8pl8="
	textlink.LinkTarget = '_blank'
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&ManifestacaoVarchar = ''

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'LoadVariablesFromWizardData'

	asdd.Height = 75
	UnnamedTable2.Height = 70

	Do 'AttributesSecurityCode'
	&DeOndeVem.Visible = False
	&PedFilCod.Visible = False
	&PedCliCpfCnpj.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do Case
		Case &DeOndeVem	= 'WWPEDIDOVENDA'
			Explanation.Caption	= 'Bem vindo ao assistente de importação de XML. Nesta tela você poderá importar um arquivo XML e logo em seguida salvar os dados da VENDA no sistema.'
		Case &DeOndeVem	= 'WWPEDIDOCOMPRA'
			Explanation.Caption	= 'Bem vindo ao assistente de importação de XML. Nesta tela você poderá importar um arquivo XML e logo em seguida salvar os dados da COMPRA no sistema.'
		OtherWise
			Explanation.Caption	= 'Bem vindo ao assistente de importação de XML. Nesta tela você poderá importar um arquivo XML e logo em seguida salvar os dados da DEVOLUÇÃO no sistema.'
	EndCase
	
	iF &PedFilCod <> 0 //Se Veio preenchido é pq esta vindo da tela aonde iniciou o lançamento ex: wwpedicoCompra, é a filial de lançamento
		&FilCod = &PedFilCod
	Else
		&FilCod = &Context.FilCod
	EndIf

EndEvent

Event Enter

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &HasValidationErrors
		Do 'SaveVariablesToWizardData'
		ImportarXmlCompra(!'SelecionarXML', !'Envolvidos', false)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSelecionarArquivo'

	wpSelecionaNfManifestacao.Popup(&Context.EmpCod, &PedCod,&ManifestacaoVarchar)
	//volta do popup ai da o refresh aonde pega o parametro preenchido e importa o xml
	
	
	refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadVariablesFromWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&DeOndeVem = &WizardData.SelecionarXML.DeOndeVem
	&PedCod = &WizardData.SelecionarXML.PedCod
	&PedFilCod = &WizardData.SelecionarXML.PedFilCod
	&PedCliCodRaz = &WizardData.SelecionarXML.PedCliCodRaz
	&PedCliCpfCnpj = &WizardData.SelecionarXML.PedCliCpfCnpj

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'SaveVariablesToWizardData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardData.FromJson(&WebSession.Get(&WebSessionKey))
	&WizardData.SelecionarXML.DeOndeVem = &DeOndeVem
	&WizardData.SelecionarXML.PedCod = &PedCod
	&WizardData.SelecionarXML.PedFilCod = &PedFilCod
	&WizardData.SelecionarXML.PedCliCodRaz = &PedCliCodRaz
	&WizardData.SelecionarXML.PedCliCpfCnpj = &PedCliCpfCnpj
	&WebSession.Set(&WebSessionKey, &WizardData.ToJson())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbDadosPedido.Visible = (&PedCod > 0)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	if Substr(&ManifestacaoVarchar, 1, 1) = 'S'
		
		&AuxManCod = val(Substr(&ManifestacaoVarchar,  2, 8))
		&NomeTemporario = &DeOndeVem.Trim() + 'IMPXMLCOMPRA' + trim(str(&Context.EmpCod)) + trim(Str(&Context.PesCod)) + '-'
		NotaTemporariaApaga.Call(&NomeTemporario)	
		&tmpNFeCod = &NomeTemporario + '1'
		
		tbprogresso.Visible = 1
		scaProgressBar1.ProcessId = &tmpNFeCod
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&tmpNFeCod)
		scaProgressBar1.Start()
		
		GravaXmlNotaTemporariaManifesto_Submit.Submit(&tmpNFeCod, &EmpCod, &FilCod, &tmpNFeCod, &PedCod, &AuxManCod, '', 'S')
		
	Endif

EndEvent

Event FileUpload1.UploadComplete

	//&WebSession.Set('S', 'FilWPIMP')
	&NomeTemporario = &DeOndeVem.Trim() + 'IMPXMLCOMPRA' + trim(str(&Context.EmpCod)) + trim(Str(&Context.PesCod)) + '-'
	NotaTemporariaApaga.Call(&NomeTemporario)
	
	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&NomeArquivoXml = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			&tmpNFeCod = &NomeTemporario + '1'
			
			tbprogresso.Visible = 1
			scaProgressBar1.ProcessId = &tmpNFeCod
			scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&tmpNFeCod)
			scaProgressBar1.Start()
//			msg(&NomeArquivoXml)
			removetagvazias.call(&NomeArquivoXml)
			
			
			GravaXmlNotaTemporariaManifesto_Submit.Submit(&tmpNFeCod, &EmpCod, &FilCod, &tmpNFeCod, &PedCod, 0, &NomeArquivoXml, 'S')
			
		EndiF
	EndFor
	
	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent

Event ScaProgressBar1.OnComplete
	
	for Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNFeCod
		
		Do CAse
			CAse tmpNfeNFSe = 'NFE'
				ImportarXmlCompra(!'SelecionarXML', !'Envolvidos', false)
				
			CAse tmpNfeNFSe = 'NFSE'
				&SessionGuidAux = GUID.NewGuid()
	
				&WebSessionKey = 'wpImportarNFSe_Data' + &SessionGuidAux.ToString().Trim()
				&WizardDataImportar = new()	
				&WizardDataImportar.SelecioneXML.DeOndeVem = &DeOndeVem
				&WizardDataImportar.SelecioneXML.PedCod = &PedCod
				&WizardDataImportar.SelecioneXML.PedCliCodRaz = &PedCliCodRaz
				&WizardDataImportar.SelecioneXML.PedCliCpfCnpj = &PedCliCpfCnpj
				&WizardDataImportar.SelecioneXML.PedFilCod = &PedFilCod
				&WizardDataImportar.SelecioneXML.tmpNFeCod = &tmpNFeCod
				
				
				&WebSession.Set(&WebSessionKey, &WizardDataImportar.ToJson())
				
				wpImportarNFSe.Link('SelecioneXML', 'Envolvidos', false, &SessionGuidAux)
			
		EndCase

		Exit
	EndFor

EndEvent


]]></Source>
