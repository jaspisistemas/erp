      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WWCONTAS', Status_SimNao.Sim, 2, &AutNiv)

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&CtabanCod.Visible = False
	&addCtaFunIsPad.Visible = False
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 15

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'loadConta'

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&RemoverFuncionario = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&CtaFunCod = CtaFunCod
	&CtaFunIs = CtaFunIs
	&CtaFunIsPad = CtaFunIsPad
	&CtaFunIsCx = CtaFunIsCx
	&CtaFunIsPag = CtaFunIsPag
	&CtaFunIsRec = CtaFunIsRec
	
	Do 'loadFuncionarioGrid'

EndEvent

Event 'DoGravar'

	For each line in Grid
		if not &CtaFunCod.IsEmpty()
			GravaContasFinanceiro.Call(&EmpCod, &CtabanCod, &CtaFunCod, &CtaFunIsPad, &CtaFunIsRec, &CtaFunIsPag, &CtaFunIsCx)
		EndIf
	EndFor
	AtualizaContaPadraoFuncionario.Call(&EmpCod, &CtabanCod) //ADD QUE FALTOU JDF
	
	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	if not &FunCod.IsEmpty()
		GravaContasFinanceiro.Call(&EmpCod,&CtabanCod,&FunCod, &addCtaFunIsPad, &addCtaFunIsRec, &addCtaFunIsPag, &addCtaFunIsCx) //Vai add
		AtualizaContaPadraoFuncionario.Call(&EmpCod, &CtabanCod) //ADD QUE FALTOU JDF
		Refresh
	else
		msg('Atenção! Selecione o Funcionário que deseja adicionar.')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&FunCod.SetEmpty()
	&FunCod.SetFocus()

EndEvent

Event &FunCod.IsValid

	&addCtaFunIsPad = Status_SimNao.Nao
	&addCtaFunIsCx = Status_SimNao.Sim
	&addCtaFunIsPag = Status_SimNao.Sim
	&addCtaFunIsRec = Status_SimNao.Sim
	Do 'loadFuncionario'
	do 'loadContasFuncionario'

EndEvent

Event &RemoverFuncionario.Click

	DeletaContasFuncionario.Call(&EmpCod,&CtabanCod,&CtaFunCod)
	Refresh

EndEvent

Sub 'loadContasFuncionario'

	For each order EmpCod,CtabanCod,CtaFunCod
		where EmpCod = &EmpCod
		where CtabanCod = &CtabanCod
		where CtaFunCod = &FunCod
		&CtaFunIs = CtaFunIs
		&addCtaFunIsPad = CtaFunIsPad
		&addCtaFunIsCx = CtaFunIsCx
		&addCtaFunIsPag = CtaFunIsPag
		&addCtaFunIsRec = CtaFunIsRec
		
		exit
	EndFor

EndSub

Sub 'loadFuncionario'

	For each order EmpCod,PesCod,PesSts,PesIsFun
		where EmpCod = &EmpCod
		where PesCod = &FunCod
		where PesSts = Status_AtivoInativo.ATIVO
		where PesIsFun = true
		&PesRaz = PesRaz
		exit
	when none
		if not &FunCod.IsEmpty()
			msg('Atenção! Esta pessoa não é um Funcionário.')
		EndIf
		&PesRaz.SetEmpty()
		&FunCod.SetEmpty()
		&FunCod.SetFocus()
	EndFor

EndSub

Sub 'loadFuncionarioGrid'

	For each order EmpCod,PesCod,PesSts,PesIsFun
		where EmpCod = &EmpCod
		where PesCod = &CtaFunCod
		
		&gridPesRaz = PesRaz
				
		exit
	when none
		&gridPesRaz = 'NÃO DEFINIDO'
	EndFor

EndSub

Sub 'loadConta'

	For each order EmpCod,CtabanCod
		where EmpCod = &EmpCod
		where CtabanCod = &CtabanCod
		&CtaBanNom = CtaBanNom
		exit
	EndFor

EndSub


]]></Source>
