        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	&ProgressId2 = '2wpImportarProduto' + trim(Str(&wwpContext.EmpCod)) + trim(Str(&wwpContext.FilCod)) + trim(Str(&wwpContext.PesCod))
	prcApagarImportarProdutos.Call(&ProgressId2)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Grid.Rows = Page.Rows5

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = Grid.currentPage

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Add.FromImage(ActionInsert)
	&Add.TooltipText = ""

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoGravaTabelaProdutos'

	btnGravaTabelaProdutos.Visible = 0
	&Isaguarde = true
	scaProgressBar1.ProcessId = &ProgressId2
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId2)
	scaProgressBar1.Start()
	
	GravaProdutosIMportadosTabelaProdutos.Submit(&ProgressId2, &ProgressId2, &wwpContext.EmpCod, &wwpContext.FilCod, &wwpContext.UserName)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FileUpload1.UploadComplete

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	Do Case
		Case &PrimeiraLinha = 0
			msg('ATENÇÃO! Coluna código primeira Linha não pode ser vazio!')
		Otherwise			
			&sdtProdutosXls.Clear()
			
			For &FileUploadData in &FileUploadDataColl
				If not &FileUploadData.File.IsEmpty()
					&File.Source=&FileUploadData.File
					&selectedURL = &File.GetAbsoluteName() /// Pega o local temporario
					&File.Close()
					
					
					//btnGravaTabelaProdutos.Visible = 0
					&Isaguarde = true
					&ProgressId2 = '2wpImportarProduto' + trim(Str(&wwpContext.EmpCod)) + trim(Str(&wwpContext.FilCod)) + trim(Str(&wwpContext.PesCod))
					&ProgressId2 = &ProgressId2.trim()
					scaProgressBar2.ProcessId = &ProgressId2
					scaProgressBar2.UpdateProgressURL = retornaProgresso.Link(&ProgressId2)
					scaProgressBar2.Start()
					
					&sdtCamposImportacao.PrimeiraLinha = &PrimeiraLinha
					&sdtCamposImportacao.ColProCod = &ColProCod 
					&sdtCamposImportacao.ColDescricao = &ColDescricao
					&sdtCamposImportacao.ColvlrCus = &ColvlrCus
					&sdtCamposImportacao.ColValorVenda = &ColValorVenda
					&sdtCamposImportacao.ColNCM = &ColNCM
					&sdtCamposImportacao.ColCEST = &ColCEST
					&sdtCamposImportacao.ColCatCod = &ColCatCod
					&sdtCamposImportacao.ColEmbalagem = &ColEmbalagem
					&sdtCamposImportacao.ColGRUPO = &ColGRUPO
					&sdtCamposImportacao.ColMarca = &ColMarca
					&sdtCamposImportacao.Mostrar = &MostrarSomenteNaoCadastrado
					&sdtCamposImportacao.ColMarcaNome = &ColMarcaNome
					&sdtCamposImportacao.ColGTIN = &ColGTIN
					&sdtCamposImportacao.ColEstoque = &ColEstoque
					&sdtCamposImportacao.ColLocacao = &ColLocacao
					&sdtCamposImportacao.ColLocacaoExt = &ColLocacaoExt
					
					PadraoUsuarioHora.Call('G', '#IMPPRODUTOXLS#', &wwpContext.PesCod, &wwpContext.EmpCod, &sdtCamposImportacao.ToXml(), &PadDtaMod, &PadDtaHorMod, 'P')
					ImportaProdutosXLS.Submit(&ProgressId2,  &ProgressId2, &EmpCod, &selectedURL, &sdtCamposImportacao)
					
				EndIf
			endfor
	EndCase
	
	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent

Event ScaProgressBar2.OnComplete

	Refresh

EndEvent

Event &Add.Click

	&sdtGravaProduto.ProCod = IpProCod
	&sdtGravaProduto.ProRef = IpProRef
	&sdtGravaProduto.ProBar = IpProBar
	&sdtGravaProduto.ProNom = IpProNom
	&sdtGravaProduto.MarCod = IpMarCod
	&sdtGravaProduto.ProSetCod = IpSetCod
	&sdtGravaProduto.ProEmbCod = IpEmbCod
	&sdtGravaProduto.ProNcmCod = IpNcmCod
	&sdtGravaProduto.ProNcmCest = IpProNcmCest
	&sdtGravaProduto.ProCatCod = IpCatCod
	&sdtGravaProduto.TabPrc1 = IpTabPrc1
	
	&sdtGravaProduto.GrupCod = IpGrupCod
	&sdtGravaProduto.IsPoupop = true

	&WebSession.Set('DADOSDEFAUT_PRODUTO', &sdtGravaProduto.ToXml())
	
	Produtos.Popup('', Trnmode.Insert, IpEmpCod, IpProCod, IpProRef )

EndEvent

Event scaProgressBar1.OnComplete

	&Isaguarde = false
	btnGravaTabelaProdutos.Visible = 1

EndEvent


