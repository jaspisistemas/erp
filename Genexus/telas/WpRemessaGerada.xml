Event Start

	Donwload_.LinkTarget = '_blank'
	If &link <> ''
		TableDow.Visible = true
		Donwload_.Link = link(&link)
	Else
		TableDow.Visible = False	
	EndIf

	&Randon = ServerNow()
	&tamanho = &link.Length()
	&tamanho = &tamanho-11
	&arquivo = substr(&link,&tamanho,15)
