      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&bollPedQtd = false

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid_DWC.Class = !'Invisible WCD_' + upper(Grid.InternalName)
	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadPedido'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridCurrentPage = Grid.CurrentPage
//	&GridRecordCount = Grid.RecordCount
	&GridPageCount = Grid.PageCount

EndEvent

Event Grid.Load

	&AuxPedQtdEmb = PedQtdEmb
	&AuxPedQtd = PedQtd
	&PedProEmbQtd = PedProEmbQtd
	
	Do Case
		Case PedProEmbQtd <> 1 and PedProEmbQtd > 0
			&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			
			&PedQtd = &Varchar
			
			&Varchar = trim(toformattedString(&PedProEmbQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' X ' + trim(&Varchar) 
			
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' (' + trim(&Varchar) + ')'
			
		Case PedProEmbQtd < 0
			&PedProEmbQtd = &PedProEmbQtd *-1
			&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd = trim(&Varchar)
			
			&Varchar = trim(toformattedString(&PedProEmbQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' / ' + trim(&Varchar) 
			
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' (' + trim(&Varchar) + ')'
			
		Otherwise
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd = trim(&Varchar)
	EndCase
	
	&Varchar = trim(toformattedString(PedQtdCan))
	RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
	&PedQtdCan = &Varchar

	&Varchar = trim(toformattedString(PedVlrUnt))
	RetiraZerosDepoisVirgulaDuasCasas.Call(&Varchar, &Varchar)
	&PedVlrUnt_Varchar = &Varchar
	
	&Varchar = trim(toformattedString(PedItmDsc))
	RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
	&PedItmDsc_Varchar = &Varchar
	
	&Varchar = trim(toformattedString(PedItmAcr))
	RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
	&PedItmAcr_Varchar = &Varchar
	
	&Varchar = trim(toformattedString(PedVlrUntDsc))
	RetiraZerosDepoisVirgulaDuasCasas.Call(&Varchar, &Varchar)
	&PedVlrUntDsc_Varchar = &Varchar
	 
	&Varchar = trim(toformattedString(PedVlrItm))
	RetiraZerosDepoisVirgulaDuasCasas.Call(&Varchar, &Varchar)
	&PedVlrItm_Varchar = &Varchar
	
	Do case
		Case PedItmPrm = domPedItmPrm.PROMOCAO
			&PedVlrUntDsc_Varchar.ForeColor = RGB(200,0,0)
			&PedVlrItm_Varchar.ForeColor = RGB(200,0,0)
			
		Case PedItmPrm = domPedItmPrm.DESCONTO
			&PedVlrUntDsc_Varchar.ForeColor = RGB(200,0,0)
			&PedVlrItm_Varchar.ForeColor = RGB(200,0,0)
			
		Otherwise
			&PedVlrUntDsc_Varchar.ForeColor = RGB(0,0,0)
			&PedVlrItm_Varchar.ForeColor = RGB(0,0,0)
			
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon"></i>'

	
&Mensagem = ProRefNom

If not PedItmProRefDig.IsEmpty() and not PedItmProRefDig.IsNull() and PedItmProRefDig <> ProGraRef
	&Mensagem += ' (' + trim(PedItmProRefDig) + ')'
Endif
If not PedItmCmp.IsEmpty()
	&Mensagem += ' ' + PedItmCmp.Trim()
EndIF

if ProSolLot = SolicitarLote.SIM_CONTROLAR
	PedItmCmpLotes_PedidoProduto.Call(EmpCod, FilCod, PedCod, PedItmCod, &PedItmCmpLot)
	&Mensagem += ' ' + &PedItmCmpLot
Endif

If not PedNItmPed.IsEmpty() and not PedNItmPed.IsNull() and not PedNum.IsEmpty() and not PedNum.IsNull()
	&Mensagem += ' nItemPed:' + trim(str(PedNItmPed))
Endif

&ProRefNom = &Mensagem
	&CfopCst = format('%1/%2', trim(PedItmCfoCod), trim(PedItmCstCod))

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	RetiraZerosDepoisVirgulaDuasCasas(trim(toformattedString(PedProPesTot)),&varPedProPesTot)

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

