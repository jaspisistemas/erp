        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWAUTORIZACOES', Status_SimNao.Sim, 3, &RotNivReq)
	
	txtFiltrado.ForeColor = rgb(0,60,130)
	txtAviso.ForeColor = rgb(200,0,0)
	&AutNiv.Enabled = 1
	&SubAutNiv.Enabled = 1

	loadwwpContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	do 'CarregaPerfil'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable4.Width = 700
	&FilDescricao.Visible = False
	&FilSomenteAtivas.Visible = False
	&FilSubMenCod.Visible = False
	&FilMenCod.Visible = False
	&FilAutGrpCod.Visible = False
	&EmpCod.Visible = False
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&AutGrpCod = &inAutGrpCod
	
	if 1=2
		AbreWpAutorizacao.Link()
	EndIF

EndEvent

Event Grid.Load

	For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
		
		&AutNiv.Enabled = 1
		&SubAutNiv.Enabled = 1
		
		&RotNom = &SdtAutorizacaRotinasItem.RotNom
		
		if &SdtAutorizacaRotinasItem.SubRotIs = false
			&AutNiv = &SdtAutorizacaRotinasItem.AutNiv
			&AutNiv.Visible = 1
			&SubAutNiv.Visible = 0
			&CodigoRotina =  &SdtAutorizacaRotinasItem.RotAutCod
			&RotAutCod =   &SdtAutorizacaRotinasItem.RotAutCod
			&CodigoRotina.TooltipText = ''
		Else
			&CodigoRotina =  '  |---- [' +&SdtAutorizacaRotinasItem.SubRotCod + ']'
			&SubAutNiv = &SdtAutorizacaRotinasItem.AutNiv 
			&RotAutCod =   &SdtAutorizacaRotinasItem.SubRotCod
			&CodigoRotina.TooltipText = &SdtAutorizacaRotinasItem.RotAutCod.Trim()
			&AutNiv.Visible = 0
			&SubAutNiv.Visible = 1
		Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load
	EndFor

EndEvent

Event Enter

	If &MenCod = 0 and &Descricao.IsEmpty()
		txtAviso.ForeColor = rgb(200,0,0)
		txtAviso.Caption = 'Informe o Menu ou insira uma Descrição, ' + serverTime()
	Else
		do 'CarregaInformacoes'
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoPerfisAcesso'

	WWPerfilUsuarios.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCopiaPerfil'

	wpCopiarPerfil.Popup(0)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AutGrpCod.ControlValueChanged

	do 'CarregaInformacoes'

EndEvent

Event &SomenteAtivas.ControlValueChanged

	do 'CarregaInformacoes'

EndEvent

Event &MenCod.ControlValueChanged

	do 'CarregaInformacoes'

EndEvent

Event &SubMenCod.ControlValueChanged

	do 'CarregaInformacoes'

EndEvent

Event &Descricao.ControlValueChanged

	do 'CarregaInformacoes'

EndEvent

Event &allAutNiv.ControlValueChanged

	if not &allAutNiv.IsEmpty()
		&AuxAutNiv = val(&allAutNiv)
		For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
			If &SdtAutorizacaRotinasItem.SubRotIs = false
				&SdtAutorizacaRotinasItem.AutNiv = &AuxAutNiv
				GravaAutorizacaoPerfil.Call(&EmpCod, &FilAutGrpCod, &SdtAutorizacaRotinasItem.RotAutCod, &AuxAutNiv, &wwpContext.UserName)
			Endif
		EndFor
	
		grid.Refresh()
	Endif
	
	&allAutNiv = ''

EndEvent

Event &allAutNiv.IsValid

	if not &allAutNiv.IsEmpty()
		&AuxAutNiv = val(&allAutNiv)
		For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
			If &SdtAutorizacaRotinasItem.SubRotIs = false
				&SdtAutorizacaRotinasItem.AutNiv = &AuxAutNiv
				GravaAutorizacaoPerfil.Call(&EmpCod, &FilAutGrpCod, &SdtAutorizacaRotinasItem.RotAutCod, &AuxAutNiv, &wwpContext.UserName)
			Endif
		EndFor
	
		grid.Refresh()
	Endif
	
	&allAutNiv = ''

EndEvent

Event &allSubAutNiv.IsValid

	if not &allSubAutNiv.IsEmpty()
		&AuxAutNiv = val(&allSubAutNiv)
		For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
			If &SdtAutorizacaRotinasItem.SubRotIs = true
				&SdtAutorizacaRotinasItem.AutNiv = &AuxAutNiv
				GravaAutorizacaoPerfil.Call(&EmpCod, &FilAutGrpCod, &SdtAutorizacaRotinasItem.SubRotCod, &AuxAutNiv, &wwpContext.UserName)
			Endif
		EndFor
	
		grid.Refresh()
	Endif
	
	&allSubAutNiv = ''

EndEvent

Event &allSubAutNiv.ControlValueChanged

	if not &allSubAutNiv.IsEmpty()
		&AuxAutNiv = val(&allSubAutNiv)
		For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
			If &SdtAutorizacaRotinasItem.SubRotIs = true
				&SdtAutorizacaRotinasItem.AutNiv = &AuxAutNiv
				GravaAutorizacaoPerfil.Call(&EmpCod, &FilAutGrpCod, &SdtAutorizacaRotinasItem.SubRotCod, &AuxAutNiv, &wwpContext.UserName)
			Endif
		EndFor
	
		grid.Refresh()
	Endif
	
	&allSubAutNiv = ''

EndEvent

Event &SubAutNiv.ControlValueChanged

	For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
		If &SdtAutorizacaRotinasItem.SubRotIs = true and &SdtAutorizacaRotinasItem.SubRotCod = &RotAutCod
			&SdtAutorizacaRotinasItem.AutNiv = &SubAutNiv
		Endif
		Exit
	EndFor

//	msg('CVC ' + str(&AutGrpCod) + ' ' + &RotAutCod.Trim() + ' ' + str(&SubAutNiv))
	GravaAutorizacaoPerfil.Call(&EmpCod, &AutGrpCod, &RotAutCod, &SubAutNiv, &wwpContext.UserName)

EndEvent

Event &AutNiv.ControlValueChanged

	For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
		If &SdtAutorizacaRotinasItem.SubRotIs = false and &SdtAutorizacaRotinasItem.RotAutCod = &RotAutCod
			&SdtAutorizacaRotinasItem.AutNiv = &AutNiv
		Endif
	EndFor
	
	msg('CVC ' + str(&AutGrpCod) + ' ' + &RotAutCod.Trim() + ' ' + str(&AutNiv))
	GravaAutorizacaoPerfil.Call(&EmpCod, &AutGrpCod, &RotAutCod, &AutNiv, &wwpContext.UserName)

EndEvent

Event &AutNiv.IsValid

	For &SdtAutorizacaRotinasItem in &SdtAutorizacaRotinas
		If &SdtAutorizacaRotinasItem.SubRotIs = false and &SdtAutorizacaRotinasItem.RotAutCod = &RotAutCod
			&SdtAutorizacaRotinasItem.AutNiv = &AutNiv
		Endif
	EndFor

	msg('CV ' + str(&AutGrpCod) + ' ' + &RotAutCod.Trim() + ' ' + str(&AutNiv))
	GravaAutorizacaoPerfil.Call(&EmpCod, &AutGrpCod, &RotAutCod, &AutNiv, &wwpContext.UserName)

EndEvent

Sub 'CarregaInformacoes'

	If &MenCod > 0 or not &Descricao.IsEmpty()
		&Mensagem = 'Perfil: ' + trim(&AutGrpCod.Text)
		if &MenCod.IsEmpty()
			//			&Mensagem += ' MENU: TODOS'
		Else
			&Mensagem += ' / Menu: ' + trim(&MenCod.Text)
		Endif
		
		if &SubMenCod.IsEmpty()
			if not &MenCod.IsEmpty()
				&Mensagem += ' / SubMenu: TODOS'
			Endif
		Else
			&Mensagem += ' / SubMenu: ' + trim(&SubMenCod.Text)
		Endif
		
		if not &Descricao.IsEmpty()
			&Mensagem += ' / Descrição: ' + trim(&Descricao)
		Endif
		
		&FilDescricao = upper(&Descricao)
		&FilSomenteAtivas = &SomenteAtivas
		&FilSubMenCod = &SubMenCod
		&FilMenCod = &MenCod
		&FilAutGrpCod = &AutGrpCod
		
		txtFiltrado.Caption = &Mensagem
		prcRetornaRotinas.Call(&EmpCod, &AutGrpCod, &MenCod, &SubMenCod, &SomenteAtivas, &FilDescricao, &SdtAutorizacaRotinas)
		txtAviso.ForeColor = rgb(0,120,0)
		txtAviso.Caption = 'Autorizações carregadas: ' + serverTime()
		Refresh
	Endif

EndSub

Sub 'CarregaPerfil'

	For Each Order EmpCod
		Where EmpCod = &EmpCod
		
		if AutGrpSts = Status_ativoInativo.ATIVO
			&Mensagem = format('%1 - %2', trim(str(AutGrpCod)), trim(AutGrpNom))
		Else
			&Mensagem = format('%1 - [INATIVO] %2', trim(str(AutGrpCod)), trim(AutGrpNom))
		Endif
		&AutGrpCod.AddItem(AutGrpCod, &Mensagem)
				
	EndFor

EndSub

