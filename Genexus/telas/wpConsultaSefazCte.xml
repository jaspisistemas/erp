      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SolCod = &parSolCod
	btnImprimir.Visible = 0
	com.ForeColor  = RGB(0,160,40)
	&ProgressLogXml = ''
	txtMsg.Caption = ''
	txtMsg.ForeColor = RGB(210,130,0)
	
	loadWWPContext.Call(&Context)
	
	For each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		TextBlockTitle.Caption = 'Fazendo a Consulta do CT-e no SEFAZ, Nro: ' + trim(str(CteNum))
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Random = Random() * 1000000000
	&ProgressId = 'CnsCTES' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod)) + trim(str(&Random))
	&ProgressId = &ProgressId.trim()
	
	scaProgressBar1.ProcessId = &ProgressId
	scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
	scaProgressBar1.Start()
	
	RecepcaoCte.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &CteCod, &SolCod)

	Do 'AttributesSecurityCode'

EndEvent

Event 'DoMonitoraNotas'

if &DeOndeVem = 'WWCTETERCEIROS'
	wwCteTerceiros.Link()
Else
	WWCTE.Link()
Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		if CteArqXml.IsEmpty()
			If CteModCod = '57'
				GeraXmlCteModelo57.Call(EmpCod, FilCod, CteCod, 'N', &Context.PesCod, &SolCod)
			EndIF
		EndIF
		GeraPdfDacte_web.Call(EmpCod, FilCod, CteCod, &UrlPDF, &UrlFisico)
		
		RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&ProgressLogXml = '')
		DVPanel_TableAttributes_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributes_Cell.Class = !'col-xs-12'
	EndIf
	If not(&ProgressLogXml <> '')
		DVPanel_PanelRetorno_Cell.Class = !'Invisible'
	Else
		DVPanel_PanelRetorno_Cell.Class = !'col-xs-12'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	Do 'AttributesSecurityCode'

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		&ProgressLogXml = ProgressLogXml
		txtMsg.Caption = &ProgressLogXml
		do 'imprimenota'
		
		Exit
	EndFor
	
	apagaProgress.Submit('', &ProgressId)
	Do 'AttributesSecurityCode'

EndEvent

Sub 'imprimenota'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
						
		If not CteArqXml.IsEmpty() and CteSts = Status_NFe.Autorizada
			btnImprimir.Visible = 1
		EndIF
		
		Exit
	EndFor

EndSub


]]></Source>
