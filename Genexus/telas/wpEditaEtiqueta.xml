	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event ControlDesignerEtiqueta.onSalvaConfig

	prcAtualizaJsonEtiqueta.Call(&EmpCod, &TIpEtqCod, &sdtDesignerConfig.ToJson(), &sdtDesignerConfig.height, &sdtDesignerConfig.width)
	wpEditaEtiqueta.Link(&EmpCod, &TIpEtqCod)

EndEvent


