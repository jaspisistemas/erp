      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	
	&FinPedDtaEms = serverdate()
    &IniPedDtaEms = &FinPedDtaEms.AddMonths(-1)
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		&PedCliCodRaz = PesCodRaz
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 493
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = Page.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Grid.Rows = 10

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&Preview = !'<i class="fas fa-map-pin"></i>'

	
if PedItmCmp.Length() > 15
	&PedItmCmp = Substr(PedItmCmp, 1,15) + '...'
Else
	&PedItmCmp = Substr(PedItmCmp, 1,15)
EndIF

	
if PedItmCmpInt.Length() > 15
	&PedItmCmpInt = Substr(PedItmCmpInt, 1,15) + '...'
Else
	&PedItmCmpInt = Substr(PedItmCmpInt, 1,15)
EndIF

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&GridCurrentPage = grid.CurrentPage
	&GridPageCount = Grid.PageCount

EndEvent

Event &Preview.Click

	wpHistoricoItensVendidosObs.Popup(PedCod, PedItmCod)

EndEvent


]]></Source>
