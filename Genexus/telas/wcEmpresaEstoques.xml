Event Start

	RetornaAutorizacao.Call('VINCULAREMPRESA', Status_SimNao.Nao, 0, &AutNiv)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtProdutosOutrasEmpresass.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	loadwwpContext.Call(&wwpContext)
	For EAch Order EmpCod, FilCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &wwpContext.FilCod
		RetornaColunas_Nome.Call(EmpCod, FilTabCod, &SdtColunasTabela)
		Exit
	EndFor

EndEvent

Event GridsdtProdutosOutrasEmpresass.Load

	&GridEmpCod = &sdtProdutosOutrasEmpresas.CurrentItem.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&FazerVinculo = !'<i class="fas fa-pen"></i>'
	If (&AutNiv > 0)
		&FazerVinculo.Class = !'Attribute'
	Else
		&FazerVinculo.Class = !'Invisible'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	sdtProdutosOutrasEmpresas__TabPrc1.Visible = &sdtColunasTabela.Tem1
	sdtProdutosOutrasEmpresas__TabPrc1.Title = &sdtColunasTabela.TabColNom1

	sdtProdutosOutrasEmpresas__TabPrc2.Visible = &sdtColunasTabela.Tem2
	sdtProdutosOutrasEmpresas__TabPrc2.Title = &sdtColunasTabela.TabColNom2
	
	sdtProdutosOutrasEmpresas__TabPrc3.Visible = &sdtColunasTabela.Tem3
	sdtProdutosOutrasEmpresas__TabPrc3.Title = &sdtColunasTabela.TabColNom3
	
	sdtProdutosOutrasEmpresas__TabPrc4.Visible = &sdtColunasTabela.Tem4
	sdtProdutosOutrasEmpresas__TabPrc4.Title = &sdtColunasTabela.TabColNom4
	
	sdtProdutosOutrasEmpresas__TabPrc5.Visible = &sdtColunasTabela.Tem5
	sdtProdutosOutrasEmpresas__TabPrc5.Title = &sdtColunasTabela.TabColNom5
	
	sdtProdutosOutrasEmpresas__TabPrc6.Visible = &sdtColunasTabela.Tem6
	sdtProdutosOutrasEmpresas__TabPrc6.Title = &sdtColunasTabela.TabColNom6
	
	sdtProdutosOutrasEmpresas__TabPrc7.Visible = &sdtColunasTabela.Tem7
	sdtProdutosOutrasEmpresas__TabPrc7.Title = &sdtColunasTabela.TabColNom7
	
	sdtProdutosOutrasEmpresas__TabPrc8.Visible = &sdtColunasTabela.Tem8
	sdtProdutosOutrasEmpresas__TabPrc8.Title = &sdtColunasTabela.TabColNom8
	
	sdtProdutosOutrasEmpresas__TabPrc9.Visible = &sdtColunasTabela.Tem9
	sdtProdutosOutrasEmpresas__TabPrc9.Title = &sdtColunasTabela.TabColNom9
	
	&sdtProdutosOutrasEmpresas.Clear()
	if not &ProForProCod.IsEmpty() and not &AuxProCod.IsEmpty()
		prcRetornaProdutoEstoque.Call(&ProForNumCpfCpnj, &ProForProCod, &sdtProdutosOutrasEmpresas)
	Endif

EndEvent

Event &FazerVinculo.Click

	if &AutNiv > 0
		wpVincularOutraEmpresa.Popup(&ProForNumCpfCpnj, &ProForProCod, &AuxProCod, &GridEmpCod)
		Refresh
	Endif

EndEvent


