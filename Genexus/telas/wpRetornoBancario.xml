      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = 0
	Grid_Empowerer.GridInternalName = Grid.InternalName
	Form.Caption = ' Cadastro de Banco'

	Do 'PrepareTransaction'
	Do 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&Motivos.FromImage(ActionDisplay)
	&Motivos.TooltipText = ""
	
	&RetPlanCod = RetPlanCod
	&RetUtiPlanDup = RetUtiPlanDup

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmar'

	For Each Line in grid
		GravaPlanoContasRetorno.Call(BanCod, EmpCod, RetBanCod, &RetPlanCod, &RetUtiPlanDup)
	EndFor

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMotivos'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpMotivosRetorno.PopUp(EmpCod, BanCod, RetBanCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoExport'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Generate Excel spreadsheet and download it.
	Do 'LoadGridState'
	ExportwpRetornoBancario.Call(&ExcelFilename, &ErrorMessage)
	If (&ExcelFilename <> "")
		Link(&ExcelFilename)
	Else
		msg(&ErrorMessage)
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"BANCOD"
				&BanCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"EMPCOD"
				&EmpCod.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIF

EndSub

Sub 'SaveGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"BANCOD", "", not &BanCod.IsEmpty(), 0, &BanCod, '')
	WWP_GridStateAddFilterValue(&GridState, !"EMPCOD", "", not &EmpCod.IsEmpty(), 0, &EmpCod.ToString().Trim(), '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIF

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"Banco"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
