      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod //Empresa
		Where FilCod = &FilCod //Filial
		Where CteCod = &CteCod //Código da CT-e
		
		If CteStsFin = Status_AbertoFechado.Aberto //Se o Status do Financeiro for Aberto
			Return //Retorna porquê não pode cancelar algo que não foi criado 
		EndIf
		
		&CteNum = CteNum //Número da CT-e
		Do 'BuscaDuplicata' //Busca a Duplicata com base no código da CT-e
		
		TxtMsg.Caption = 'Deseja cancelar o financeiro da CT-e de Nro.: ' + Trim(Str(CteNum)) + ' / TRANS.: ' + Trim(Str(CteTomCod)) + '-' + Trim(CteTomRaz) + ' / FOR.: ' + Trim(Str(CteDesCod)) + '-' + Trim(CteDesRaz) + '?'
		
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	CancelarDuplicata.Call(&EmpCod, &FilCod, &CreCod, &Mensagem) //Tenta cancelar a Duplicata
	If &Mensagem.IsEmpty() //Se conseguiu cancelar a duplicata 
		PrcAbrirFinanceiroCte.Call(&EmpCod, &FilCod, &CteCod) //Abre novamente o Financeiro da CT-e
		Return 
	Else
		&Mensagem += '!'
		Msg(&Mensagem) //Se não conseguiu cancelar a duplicata por motivos específicos, emite a mensagem e não faz nada
	EndIf

EndEvent

Sub 'BuscaDuplicata'

	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod 	= &EmpCod //Empresa
		Where FilCod 	= &FilCod //Filial
		Where CreDupNro = Trim(Str(&CteNum)) //Número da CT-e
		
		&CreCod = CreCod //Código da Duplicata 
		
		Exit
		
	EndFor

EndSub


]]></Source>
