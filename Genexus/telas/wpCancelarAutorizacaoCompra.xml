      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	RetornaAutorizacao.Call('CANCELARAUTORIZACAO', Status_SimNao.Sim, 1, &AutNiv)
	
	For Each ORder EmpCod, ACmpCod
		Where EmpCod = &EmpCod
		Where ACmpCod = &ACmpCod
		
		&ACmpDtaEms = ACmpDtaEms
		&ACmpForCod = ACmpForCod
		&ACmpForNomMan = ACmpForNomMan
		
		RetornaNomeFilial_12.Call(EmpCod, ACmpFilCod, &FilRaz)
		&FilCodnom = trim(Str(ACmpFilCod)) + ' - ' + trim(&FilRaz)
		
		if AcmpAutSts <> domAcmpAutSts.ABERTO
			return
		Endif
		
		Exit
	When none
		return
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	prcAtualizaStatusAutorizacaoCompra.Call(&EmpCod, &ACmpCod, domAcmpAutSts.CANCELADO, &wwpContext.UserName)
	Return

EndEvent


]]></Source>
