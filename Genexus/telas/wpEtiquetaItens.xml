      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	&TipEtqCod = &parTipEtqCod
	
	&EmpImpCod.Clear()	
	&EmpImpCod.AddItem(0, 'Impressoras Padrão não selecionada')
	For Each Order EmpCod, EmpImpCod
		Where EmpCod = &Context.EmpCod
		where EmpImpTip = domTipoImpressora.ETIQUETA or EmpImpTip = domTipoImpressora.ETIQUETA1 or EmpImpTip = domTipoImpressora.ETIQUETA2 or EmpImpTip = domTipoImpressora.ETIQUETA3
		//Where EmpImpFilCod.IsEmpty() or EmpImpFilCod.IsNull() //or EmpImpFilCod in &CollFilCod
		&Mensagem = EmpImpPC.Trim() + '|'+ EmpImpNom.Trim()
		&EmpImpCod.AddItem(EmpImpCod,&Mensagem)
	when None
		&EmpImpCod.Clear()	
		&EmpImpCod.AddItem(0, 'Impressoras NÃO cadastradas')
	EndFor
	
	do 'loadEtiqueta'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable14.Width = 270
	tbImagemModelo.Width = 250
	tbImagemHtml.Width = 260

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserSair'

	wpTIposEtiquetas.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserSalvarConfiguracao'

	do 'CheckRequiredFields'
	if &CheckRequiredFieldsResult
		prcSalvaCapaModeloEtiquetaProduto.Call('UPD', &EmPCod, &TipEtqCod, &TipEtqForm, &TipEtQtdCol, &TipETqModBas, &TipEtqNom, &TipEtqFor, &TipEtqAlt, &TipEtqLar, &TipEtqEspCol, &TipEtqMrgEsq, &TipEtqMrgDir, &TipEtqSts, &EmpImpCod, &TipEtqGap, &TipEtqSpe, &TipEtqDen)
		txtCapaSalva.Caption = 'Alterações Salvas: ' + ServerTime()
	Endif

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAbrirEditor'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpEditaEtiqueta.Call(&EmPCod, &parTipEtqCod)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &TipEtqNom.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Nome Etiqueta (Identificação)'), DVMessageType.error, &TipEtqNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	prcValidaNomeEtiqueta.Call(&EmPCod, &TipEtqCod, &TipEtqNom.ToUpper(), &TipEtqModBas, &TipEtQtdCol, &TipEtqForm, &IsDuplicado)
	if &IsDuplicado = true and &TipEtqSts = Status_AtivoInativo.ATIVO
		Msg(DVMessageGetBasicNotificationMsg('', 'Nome Etiqueta (Identificação) Já utilizado em outra etiqueta de mesmo Modelo Base, Mesma Qtd Coluna e mesmo Tipo!', DVMessageType.error, &TipEtqNom.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	Endif

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbEspacamentoColunaVazio.Visible = (&TipEtQtdCol <= 1)
	tbEspacamentoColuna.Visible = (&TipEtQtdCol > 1)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Refresh

	do 'loadEtiqueta'

EndEvent

Sub 'loadEtiqueta'

	For Each ORder EmpCod, TipEtqCod
		Where EmpCod = &EmPCod
		Where TipEtqCod = &TipEtqCod
		
		&TipEtqFor = TipEtqFor
		&TipEtqSts = TipEtqSts
		&TipEtqMrgEsq = TipEtqMrgEsq
		&TipEtqMrgDir = TipEtqMrgDir
		&TipEtqEspCol = TipEtqEspCol
		&TipEtQtdCol = TipEtQtdCol
		&TipEtqLar = TipEtqLar
		&TipEtqAlt = TipEtqAlt
		&TipEtqModBas = TipEtqModBas
		&TipEtqForm = TipEtqForm
		&TipEtqNom = TipEtqNom
		
		&EmpImpCod = TipEtqPadImpCod
		&TipEtqGap = TipEtqGap
		&TipEtqSpe = TipEtqSpe		
		&TipEtqDen = TipEtqDen		
				
		
		&sdtDesignerConfig.FromJson(TipEtqJson)
		
		if &sdtDesignerConfig.image.IsEmpty()			
			tbImagemModelo.Visible = 1
			tbImagemHtml.Visible = 0
			&Varchar = 'EtiqPro'+&TipEtqModBas
			&ModeloBaseImagem.FromImage(&Varchar)
		Else
			tbImagemHtml.Visible = 1
			tbImagemModelo.Visible = 0
			imagehtml.Caption = Format(!"<img src='%1' />", &sdtDesignerConfig.image)
		Endif
	
		Exit	
		
	EndFor

	prcRetornaPErsonalizacao.Call(&EmpCod, &TIpETqCod, &sdtConfigEtiqueta)
	txtOrigemCliente.Visible = &sdtConfigEtiqueta.IsSolicita_PES
	txtOrigemPreco.Visible = &sdtConfigEtiqueta.IsSolicita_TAB_COL1 or &sdtConfigEtiqueta.IsSolicita_TAB_COL2
	do 'AttributesSecurityCode'

EndSub


