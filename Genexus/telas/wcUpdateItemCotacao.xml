      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtAvisoAlerta.ForeColor = RGB(255,0,0)
	do 'getEmbalagens'
	loadWWPContext.Call(&wwpContext)
	PadraoUsuarioHora.Call('L', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	&IsTrazerComPreco = iif(Substr(&PadObs,1,1) = '0', false, true)
	&SeleiconarCarregar = iif(Substr(&PadObs,2,1) = '0', false, true)
	
	txtMsg.Caption = ''
	&CotCOmItmCod = &parCotCOmItmCod
	do 'loadItem'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	prcUpdateItemCotacao.Call(&EmpCod, &CotComCod, &CotComItmCod,  &CotComProQtd, &CotComProEmbCod)
	txtMsg.Caption = 'Produto: ' + trim(&CotComProRef) + ' - ' + trim(&CotComProNom) + ', salvo com sucesso!'
	&AuxCotComItmCod = &CotComItmCod
	do 'getProximoRegistro'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserSair'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAnterior'

	&AuxCotComItmCod = &CotComItmCod
	do 'getRegistroAnterior'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserProximo'

	&AuxCotComItmCod = &CotComItmCod
	do 'getProximoRegistro'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &SeleiconarCarregar.Click

	do 'GravarPadrao'

EndEvent

Event &IsTrazerComPreco.Click

	do 'GravarPadrao'

EndEvent

Sub 'getEmbalagens'

	&CotComProEmbCod.Clear()
	For Each Order EmpCod, EmbCod
		Where EmpCod = &EmpCod
		&Mensagem = EmbUnd.Trim() + ' - ' + trim(EmbNom)
		&CotComProEmbCod.AddItem(EmbCod, &Mensagem)
	EndFor

EndSub

Sub 'GravarPadrao'

	&PadObs = iif(&IsTrazerComPreco = false, '0', '1')
	&PadObs += iif(&SeleiconarCarregar = false, '0', '1')
	PadraoUsuarioHora.Call('G', &Pgmname, &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')

EndSub

Sub 'loadItem'

	For Each Order EmpCod, CotComCod, CotComItmCod
		where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod = &CotComItmCod
		
		&CotComProRef = CotComProRef
		&CotComProNom = CotComProNom
		&MenorCotComProForCod = CotComProMenForCod
		
		&CotComProQtd = CotComProQtd
		&CotComProEmbCod = CotComProEmbCod
		
		Exit
	EndFor

EndSub

Sub 'getProximoRegistro'

	&IsTem = false
	For Each Order EmpCod, CotComCod, CotComItmCod
		where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod > &AuxCotComItmCod
	
		if &IsTrazerComPreco = true
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				where CotComProForSts = StatusProdutoCotado.COTADO
				&IsTem = true
				Exit
			When None
				&IsTem = false
			EndFor
			
			if &IsTem = true				
				&CotCOmItmCod = CotComItmCod
				&CotComProRef = CotComProRef
				&CotComProNom = CotComProNom
				&MenorCotComProForCod = CotComProMenForCod
				&CotComProQtd = CotComProQtd
				&CotComProEmbCod = CotComProEmbCod
				Exit
			Endif
		Else
			&CotCOmItmCod = CotComItmCod
			&CotComProRef = CotComProRef
			&CotComProNom = CotComProNom
			&MenorCotComProForCod = CotComProMenForCod
			&CotComProQtd = CotComProQtd
			&CotComProEmbCod = CotComProEmbCod
			Exit
		Endif
	
	EndFor

EndSub

Sub 'getRegistroAnterior'

	&IsTem = false
	For Each Order EmpCod, CotComCod, (CotComItmCod)
		where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod < &CotComItmCod
		
		if &IsTrazerComPreco = true
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				where CotComProForSts = StatusProdutoCotado.COTADO
				&IsTem = true
				Exit
			When None
				&IsTem = false
			EndFor
			
			if &IsTem = true				
				&CotCOmItmCod = CotComItmCod
				&CotComProRef = CotComProRef
				&CotComProNom = CotComProNom
				&MenorCotComProForCod = CotComProMenForCod
				&CotComProQtd = CotComProQtd
				&CotComProEmbCod = CotComProEmbCod
				Exit
			Endif		
		Else			
			&CotCOmItmCod = CotComItmCod
			&CotComProRef = CotComProRef
			&CotComProNom = CotComProNom
			&MenorCotComProForCod = CotComProMenForCod
			&CotComProQtd = CotComProQtd
			&CotComProEmbCod = CotComProEmbCod
			Exit
		Endif
	EndFor

EndSub


