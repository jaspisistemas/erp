      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbJustificativa.Height = 60
	&IsPodePodeExcluir.Visible = False
	&PodeAlterarAutNiv.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadPedido'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do 'loadPedido'
	If &IsPodeEliminar = true
		
		If &Mensagem.IsEmpty()
			msg('Favor informar um motivo do cancelamento do pedido!')
			&Mensagem.SetFocus()
		Else		
			wpConfirmaCancelamentoPedidoDevolucao.Popup(&EmpCod, &FilCod, &PedCod, &Mensagem)
			Return
		Endif
		
	EndIf

EndEvent

Sub 'loadPedido'

	&IsPodeEliminar = true
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		If PedSts = Status_Pedido.CANCELADO
			Return
		EndIF
		
		If PedStsFin = Status_Pedido.FECHADO
			Msg('Pedido não pode ser Cancelado, Possui Status de Fechado parte Financeira!')
			&IsPodeEliminar = false
		EndIf
		
		If PedSts <> Status_Pedido.ABERTO
			Msg('Pedido não pode ser Cancelado, É preciso abrir o Estoque do pedido!')
			&IsPodeEliminar = false
		EndIf
	
		&FilCodNom = FilCodNom
		&PedCliRaz = PedCliRaz
		Exit
	When none
		&IsPodeEliminar = false
	EndFor

EndSub


]]></Source>
