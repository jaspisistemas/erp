      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&Context = LoadWWPContext.Udp() 
	&EmpCod = &Context.EmpCod
	&PesCod = &Context.PesCod
	&EnviarXml = true
	&SomenteNotasAutorizadas = Status_SimNao.Sim
	&Data = serverdate()
	&Data = &Data.AddMonths(-1)
	&dia = day(&Data)
	&Ano = Year(&Data)
	&Mes = month(&Data)
	&TipoNota = 'P'
	Progress.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&PesCod.Visible = False
	Grid1_Empowerer.GridInternalName = Grid1.InternalName
	Grid1.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	For &SdtEmailAgrupadosItem in &SdtEmailAgrupados
		&IsMarcado.Enabled = 1
		
		&GridEmail =  &SdtEmailAgrupadosItem.PesEml
		&GridQtde =  &SdtEmailAgrupadosItem.PesQtd

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		Load
		
	EndFor

EndEvent

Event 'DoCarregarEmail'

	BuscaDadosdeEmail.call(&EmpCod,&SdtEmailAgrupados)
	GRID1.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&GridCurrentPage = Grid1.CurrentPage
	&GridPageCount = grid1.PageCount

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&ColEmail.Clear()
	For each Line in Grid1
		If &IsMarcado = true
			&ColEmail.Add(&GridEmail)
		EndIf
	Endfor
	
	If &ColEmail.Count > 0
		&ProgressId = 'Emailagrupado' + trim(Str(&Context.EmpCod)) + trim(Str(&Context.FilCod)) + trim(Str(&Context.PesCod))
		&ProgressId = &ProgressId.trim()
		
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		Progress.Visible = 1
		
		EnviaEmailAgrupado.submit('EnviaEmailAgrupado',&ProgressId,&EmpCod,&FilCod,&Mes,&Ano,&TipoNota,&EnviarXml,&EnviaPdfNota,&SomenteNotasAutorizadas,&ColEmail)
//		EnviaEmailAgrupado.Call(&ProgressId,&EmpCod,&FilCod,&Mes,&Ano,&TipoNota,&EnviarXml,&EnviaPdfNota,&SomenteNotasAutorizadas,&ColEmail)
	Else
		msg('Marque ao menos 1 para o qual deseja receber as notas!')
	EndIf

EndEvent

Event scaProgressBar1.OnComplete

	for Each Order ProgressId
		Where ProgressId = &ProgressId
		If not ProgressLogXml.IsEmpty()
			msg(ProgressLogXml)
		EndIF
		Exit
	EndFor

	btnCancel.Visible = 1
	btnEnter.Visible = 1
	Progress.Visible = 0

EndEvent


]]></Source>
