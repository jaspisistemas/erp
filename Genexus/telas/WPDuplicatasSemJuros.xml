      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPDUPLICATASSEMJUROS', Status_SimNao.Sim, 1, &AutNiv)
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod
	&PesCod = &Context.PesCod
	&FinalData = serverdate()
	&SomenteViaRetorno = true
	&Data = &FinalData.AddDays(-30)
	&Quantidade = 3

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&SomenteGeraBoleto <> true)
		&CreCbrCod.Visible = False
		CreCbrCod_Cell.Class = !'Invisible'
	Else
		&CreCbrCod.Visible = True
		CreCbrCod_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &SomenteGeraBoleto.Isvalid

	do 'AttributesSecurityCode'

EndEvent

Event 'f4'

 4
	promptCliente.Popup(&EmpCod, &CreCliCod)
	&CreCliCod.SetFocus()

EndEvent

Event &CreCliCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &CreCliCod, &CreCliRaz)

EndEvent

Event Enter

	if &TipoRelatorio = 'P'
		RCOOpenWindow1.LinkOpen = RELJAS041.link(&context.EmpCod,&context.FilCod,&Data, &FinalData, &Quantidade, &SomenteGeraBoleto, &CreCbrCod, &CreCliCod, &Ordenar, &ListarPagamentosSuperiores, &AdicionarProtestos, &SomenteViaRetorno)
		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	Else
		RELJAS041E.call(&context.EmpCod,&context.FilCod,&Data, &FinalData, &Quantidade, &SomenteGeraBoleto, &CreCbrCod, &CreCliCod, &Ordenar, &ListarPagamentosSuperiores, &AdicionarProtestos, &SomenteViaRetorno, &ExcelFilename, &ErrorMessage)
		If (&ExcelFilename <> "")
			Link(&ExcelFilename)
		Else
			msg(&ErrorMessage)
		Endif
	endif

EndEvent


]]></Source>
