      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaProdutoReferencia.Call(&EmPCod, &ParProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarqtd, &Mensagem)
	if &ProCod.IsEmpty()
		wwpactions.WCPopup_Close('')
	Endif

	For each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&LctCod = LctCod
		&PedDtaEms = PedDtaEms
		&PedDtaVct = PedDtaVct
		&PedVenCod = PedVenCod
		
		&TabCod = TabCod 
		&TabColCod = TabColCod
		
		Exit
	EndFor

	&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
	RetornaPrecoUnitarioTipo.Call(&EmpCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, 0, &PedItmPrm)
	tbAvisoPromocao.Visible = (&PedItmPrm = domPedItmPrm.PROMOCAO)
	
	CalcularComissaoPorDescontoNoPedido.call(&EmpCod,&PedVenCod,&LctCod,&TabCod,&TabColCod,&PedVlrTab,&sdtComissao)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1_Empowerer.GridInternalName = Grid1.InternalName
	Grid1.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	For &sdtComissaoItem in &sdtComissao
		
		&Moeda = &sdtComissaoItem.ComVlr
		&ComDscTax  = &sdtComissaoItem.ComPer
		&ComissaoMoeda  = &sdtComissaoItem.comvlrCom
		&Mensagem = &sdtComissaoItem.Mensagem
		
		load
		
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wwpactions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
