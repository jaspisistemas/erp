Sub 'loadDadosNota'

	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&FilCodNom = FilCodNom
		&CteRemRaz = trim(str(CteRemCod)) + ' - ' + trim(CteRemRaz)
		&CteNum = CteNum
		&CteChv = CteChv
		&CteDtaEms = CteDtaEms
		&CteSts = CteSts
		Exit
	EndFor

