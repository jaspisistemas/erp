        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	&GridCurrentPage = 1
	&GridCurrentPage.Visible = False
	&GridPageCount = -1
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'loadDadosNota'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&deleteComprovante.FromImage(ActionDelete)
	&deleteComprovante.TooltipText = ""
	If (CteEveSts= Status_Nfe.Digitando)
		&deleteComprovante.Class = !'DeleteAttribute'
	Else
		&deleteComprovante.Class = !'Invisible'
	Endif
	&AlterarComprovante.FromImage(ActionUpdate)
	&AlterarComprovante.TooltipText = ""
	
	&comboOptions.Clear()
	&comboOptions.AddItem(0, 'WWP_ActionGroupCaption')
	If (CteEveSts = Status_NFe.Digitando)
		&comboOptions.AddItem(1, 'Autorizar Entrega')
	Endif
	If (CteEveSts = Status_Nfe.Autorizada)
		&comboOptions.AddItem(2, 'Enviar E-mail')
	Endif
	If (CteEveSts = Status_Nfe.Autorizada)
		&comboOptions.AddItem(3, 'Imprimir Entrega')
	Endif
	If &comboOptions.Count = 1
		&comboOptions.Class = !'Invisible'
	Else
		&comboOptions.Class = !'Attribute'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	If CteEveSts <> Status_NFe.Digitando
		&AlterarCarta.FromImage(ActionDisplay)
		If CteEveSts = Status_NFe.Autorizada
			CteEveSts.ForeColor = RGB(0,160,40)			
		Else
			CteEveSts.ForeColor = RGB(160,40,0)
		EndiF
	Else
		CteEveSts.ForeColor = RGB(0,0,0)
		&AlterarCarta.FromImage(ActionUpdate)
	EndIf

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			&GridCurrentPage -= 1
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			&GridCurrentPage += 1
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			&GridCurrentPage = &PageToGo
			Grid.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	&GridCurrentPage = 1
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &comboOptions.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &comboOptions = 1
			Do 'Do AutorizarEntrega'
		Case &comboOptions = 2
			Do 'Do Email'
		Case &comboOptions = 3
			Do 'Do ImprimirDOc'
	EndCase
	&comboOptions = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraCte'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWCTe.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoInsert'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	wpNovaEntrega.PopUp(&EmpCod, &FiLCod, &CteCod, 0)
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

