Event Start

	//CARTAO
	retornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon107_PlanoRecCartao, &TCon044_PlanoRecCliente)
	if &TCon044_PlanoRecCliente.IsEmpty()
		retornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &TCon044_PlanoRecCliente)
	Endif
	&PedDtaFat = serverdate()
	
	RetornaCodigoPlanoContas.Call(&EmpCod, &TCon044_PlanoRecCliente, &CarPlanCod)
	do 'bandeira'
	
	do 'loadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 650
	UnnamedTable5.Height = 60
	UnnamedTable4.Width = 600
	UnnamedTable3.Width = 600
	UnnamedTable2.Width = 600
	wb1.Width = 600
	tab2.Height = 45
	&PedVlrLiqSaldo.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRedefinir'

	ApagaTemporariaPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, TipoDuplicata.CARTAOC)
	ApagaTemporariaPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, TipoDuplicata.CARTAOD)
	do 'loadPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoRedefinirConfirmar'

 9
		ApagaTemporariaPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, TipoDuplicata.CARTAOC)
		ApagaTemporariaPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, TipoDuplicata.CARTAOD)
	do 'GravaCartoes'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'GravaCartoes'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ValorCredito.IsValid

	if &ValorDebito.IsEmpty() and &ValorCredito.IsEmpty()
		&ValorDebito = &PedVlrLiqSaldo
	Endif

EndEvent

Event 'Voltar'

 2
	return

EndEvent

Event &CreCarNroAut.IsValid

	btnEnter.SetFocus()

EndEvent

Event 'ConfirmarDescontos'

 10
		Do 'GravaCartoes'

EndEvent

Sub 'loadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PedCliCod = PedCliCod
		&PedVlrLiq = PedVlrLiq
		Exit
	EndFor
	
	retornaTotalTemporariaDP1.Call(&EmpCod, &FilCod, &PedCod, &TotCreVlrDup, &TotMovItmVlr,&CarMovItmVlr,&CarMovItmJur,&CarMovItmDes, &TotChequeTerceiros, &TotChequeProPrio, &PixMoeda, &DepositoMoeda)
	&PedVlrLiqSaldo = round(((&PedVlrLiq + &CarMovItmJur - &CarMovItmDes ) - (&TotCreVlrDup + &TotMovItmVlr + &CarMovItmVlr + &TotChequeTerceiros+&TotChequeProPrio+&PixMoeda+&DepositoMoeda)),2)
	&ValorCredito = &PedVlrLiqSaldo
	
	ValorTotalReceber.Caption = trim(toformattedString(&PedVlrLiqSaldo))
	if &PedVlrLiqSaldo > 0
		ValorTotalReceber.ForeColor = RGB(0,100,255)
	Else
		ValorTotalReceber.ForeColor = RGB(255,100,0)
	Endif

EndSub

Sub 'bandeira'

	//BANDEIRA
	For Each Order EmpCod, BanCarCod, BanCarNom
		Where EmpCod = &EmpCod
		Where BanCarNom = 'CARTAO_PDV'
		Where BanCarCtaFilCod = &FilCod
		&BanCarCod = BanCarCod
		Exit
	When None
		For Each Order EmpCod, BanCarCod
			Where EmpCod = &EmpCod
			Where BanCarCtaFilCod = &FilCod
			
			&BanCarCod = BanCarCod
			Exit
		EndFor	
	EndFor

EndSub

Sub 'GravaCartoes'

	if &ValorDebito > 0
		&sdtPgto  = new()
		&sdtPgto.FrpPgtoCod = 5
		&sdtPgto.FrpPgtoTip = TipoDuplicata.CARTAOD
		&sdtPgto.CreDtaEms = &PedDtaFat

		&sdtPgto.CreDtaVct = &PedDtaFat
		&sdtPgto.creVlrDup = &ValorDebito
		&sdtPgto.PlanCod = &CarPlanCod

		//Cartao
		&sdtPgto.CreCarArqc = &CreCarArqc
		&sdtPgto.CreCarNroAut = &CreCarNroAut
		&sdtPgto.CarParQtd = 1
		&sdtPgto.BanCarCod = &BanCarCod
		&sdtPgto.CarForPag = 1
		
		do 'GravaFormaSelecionada'

	Endif
	
	if &ValorCredito > 0
		&QtdParcelas = RetornaSoNumeros.Udp(&QtdParcelas)
		&CarParQtd = val(&QtdParcelas)
		if &CarParQtd.IsEmpty()
			&CarParQtd = 1
		Endif
						
		&sdtPgto  = new()
		&sdtPgto.FrpPgtoCod = 8
		&sdtPgto.FrpPgtoTip = TipoDuplicata.CARTAOC
		&sdtPgto.CreDtaEms = &PedDtaFat

		&sdtPgto.CreDtaVct = &PedDtaFat+30
		&sdtPgto.creVlrDup = &ValorCredito
		&sdtPgto.PlanCod = &CarPlanCod

		//Cartao
		&sdtPgto.CreCarArqc = &CreCarArqc
		&sdtPgto.CreCarNroAut = &CreCarNroAut
		&sdtPgto.CarParQtd = &CarParQtd
		&sdtPgto.BanCarCod = &BanCarCod
		&sdtPgto.CarForPag = 2
		
		do 'GravaFormaSelecionada'
	Endif
	
	return

EndSub

Sub 'GravaFormaSelecionada'

	MontaDuplicatasPedidoVenda01_JDF.Call('ADD', &EmpCod, &FilCod, &PedCod, &sdtPgto)

EndSub


