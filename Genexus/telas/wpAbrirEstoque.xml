      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbConfirmar.Visible = 1
	tbProgresso.Visible = 0
	
	loadWWPContext.Call(&Context)
	&AutNiv = RetornaAutorizacao.UDP('ABRIRBALANCOESTOQUE', Status_SimNao.Nao, 1)
	if &AutNiv < 1
		wwpActions.WCPopup_Close('')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoacaoFechar'

	wwpActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&Mensagem = 'Deseja Mesmo Abrir o Balanço: ' + trim(str(&BalCod)) + ', fazendo assim a movimentação de Estoque?'

EndEvent

Event Enter

	do 'getBalanco'
	if &IsPodeContinuar = true
		tbProgresso.Visible = 1
		tbConfirmar.Visible = 0
		&ProgressID = 'ABRIRBAL'+serverTime()	
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		AbrirBalanco.Submit(&ProgressId, &ProgressId, &EmpCod, &FilCod, &BalCod, &Context.PesCod)
	Endif

EndEvent

Event ScaProgressBar1.OnComplete

	wwpActions.WCPopup_Close('')

EndEvent

Sub 'getBalanco'

	&IsPodeContinuar = false
	For Each Order EmpCod, FilCod, BalCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where BalCod = &BalCod
		
		if BalSts = BalStsPrc
			&IsPodeContinuar = true
		Else
			msg('Balanço não pode ser fechado pois está em movimentação: '+ trim(BalStsPrc.EnumerationDescription()))
		Endif
	
		Exit
	EndFor

EndSub


]]></Source>
