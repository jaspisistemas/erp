      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext(&Context)
	&EmpCod 	=	&Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FileUpload1.UploadComplete

	For &FileUploadData In &FileUploadDataColl
		&File.Source	= &FileUploadData.File
		&Extensao		= &FileUploadData.Extension
		&NomeArquivo	= &File.GetAbsoluteName()
		&File.Close()
		
		Do Case
			Case &Extensao.ToLower().Trim() = 'xml'
			GravarOperacaoComXml.Call(&NomeArquivo, &OpeCod)
			
			&WebSession.Remove('WPOperacaoTransporte_Data')
			&WPOperacaoTransporteData.Inicio.EmpCod = &Context.EmpCod
			&WPOperacaoTransporteData.Inicio.FilCod = &Context.FilCod
			&WPOperacaoTransporteData.Inicio.OpeCod = &OpeCod
			&WebSession.Set('WPOperacaoTransporte_Data', &WPOperacaoTransporteData.ToJson())
			WPOperacaoTransporte.Call(!'BemVindo', !'Inicio', False)
		EndCase
	EndFor
	
	&FileUploadDataColl.Clear()
	FileUpload1.Clear()

EndEvent


]]></Source>
