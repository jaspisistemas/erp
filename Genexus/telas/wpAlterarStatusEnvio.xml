      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&wwpContext)
	do 'loadPedido'
	//RETORNA FORMAS PAGAMENTOS
	RetornaFormasPagamento.Call(&wwpContext.EmpCod, 'R', 'S', &wwpContext.PesCod, &wwpContext.TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	&PedFrpPgtoCod.Clear()
	For &sdtFormasPagamentoItem in &sdtFormasPagamento	
		&DescricaoVarchar = &sdtFormasPagamentoItem.FrpPgtoCodExib + ' - ' + &sdtFormasPagamentoItem.FrpPgtoNom
		&PedFrpPgtoCod.AddItem(&sdtFormasPagamentoItem.FrpPgtoCod, &DescricaoVarchar)
	EndFor
	//RETORNA FORMAS PAGAMENTOS

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	tbadd.Width = 130

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	GravaClientePedido.Call(&EmpCod, &FilCod, &PedCod, &PedTraRedCod, &PedObsEst, &PedObsFin, &PedFrpPgtoCod, &SdtPessoaUnica, &PedStsEnv, &wwpContext.UserName)
	Return

EndEvent

Sub 'loadPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		//DADOS ENTREGADOR
		&SdtPessoaUnica.Fromxml(PedObsEnt)
		&PedFrpPgtoCod = PedFrpPgtoCod
		&PedTraRedCod = PedTraRedCod		
		&PedObsEst = PedObsEst
		&PedObsFin = PedObsFin
		&PedStsEnv = PedStsEnv
		
		Exit
	EndFor

EndSub


]]></Source>
