        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event FileUpload1.UploadComplete

	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			&File.Source=&FileUploadData.File
			&NomeArquivoXml = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			GravaXmlCte.Call(&EmpCod, &NomeArquivoXml, '', &CteCod)	
		EndiF
	EndFor

	if &FileUploadDataColl.Count > 0
		wpCteImportados.Link(&NomeTemporario)
	Endif

	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent

Event Refresh

	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

EndEvent


]]></Source>
