      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	&CtaFecSts = FechaAbre.AbERTURA

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		&CtaBanCodNom = CtaBanCodNom
		Exit
	EndFor

	For Each Order EmpCod, CtabanCod, (FecCod)
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		&CtaFecDta = FecDta
		&CtaFecSts = FecSts
		Exit
	EndFor

	&FecSts = 'S'//FechaAbre.FecharNOVO
	&FecDta = serverdate()

EndEvent

Event Enter

	&AuxFecSts.FromString(&FecSts)
	&FecHor = &FecDta
	Do Case
		CAse &AuxFecSts = FechaAbre.FecharNOVO and &CtaFecDta > &FecDta
			msg('Não é possível FECHAR CAIXA com data anterior ao Último Fechamento!')
		CAse &AuxFecSts = FechaAbre.AbERTURA and &CtaFecDta < &FecDta
			msg('Não é possível ABRIR CAIXA com data superior ao Último Fechamento!')
			
		Otherwise
			prcGravaFechamentoMonitoraSaldo.Call(&EmpCod, &CtaBanCod, &FecHor, &AuxFecSts, &Context.PesCod, 'S', &FecCod)
			Return
	EndCase

EndEvent


]]></Source>
