      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	Do 'Conta'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)
	WorkWithLink.Link = WWMovimento.Link(&AuxMovCtaBanCod)

	For each Movimento
		where EmpCod = &EmpCod and MovCod = &MovCod
		Form.Caption = MovDta.ToString()
		&Exists = True

	When none
		Form.Caption = "WWP_RecordNotFound"
		&Exists = False
	Endfor

	If (&Exists)
		&SelectedTabCode = &TabCode
		Tabs.ActivePageControlName = &SelectedTabCode
		Do 'LoadTabs'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Tabs.TabChanged

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&SelectedTabCode = Tabs.ActivePageControlName
	&LoadAllTabs = false
	Do 'LoadTabs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadTabs'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If &LoadAllTabs OR &SelectedTabCode = '' OR &SelectedTabCode = !"General"
		GeneralWC.Object = MovimentoGeneral.Create(&EmpCod, &MovCod)
	EndIf
	If &LoadAllTabs OR &SelectedTabCode = !"Item"
		ItemWC.Object = MovimentoItemWC.Create(&EmpCod, &MovCod)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'Conta'

	For each Order EmpCod,MovCod
		Where EmpCod=  &EmpCod
		Where MovCod = &MovCod
		&AuxMovCtaBanCod = MovCtaBanCod
		Exit
	EndFor

EndSub


]]></Source>
