      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtAplicacaoNova.Visible = 0

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Page.Rows
	&Grid1CurrentPage = 1
	&Grid1CurrentPage.Visible = False
	&Grid1PageCount = -1
	Grid1PaginationBar.RowsPerPageSelectedValue = Grid1.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmPCod
		Where ProCod = &Procod
		txtProdutoNome.Caption = ProRefNom
		Exit
	Endfor

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&Grid1PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserAction1 = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case Grid1PaginationBar.SelectedPage = !'Previous'
			&Grid1CurrentPage -= 1
			Grid1.PreviousPage()
		Case Grid1PaginationBar.SelectedPage = !'Next'
			&Grid1CurrentPage += 1
			Grid1.NextPage()
		Otherwise
			&PageToGo.FromString(Grid1PaginationBar.SelectedPage)
			&Grid1CurrentPage = &PageToGo
			Grid1.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Grid1PaginationBar.RowsPerPageSelectedValue
	&Grid1CurrentPage = 1
	Grid1.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &AplNom.IsValid

	do 'GetAplicacao'

EndEvent

Event &UserAction1.Click

	prcAddRemoveAplicacao.Call('DEL', &EmPCod, &Procod, AplCod, AplNom, ProAplOrd)
	Refresh

EndEvent

Event Enter

	&AplNom = &AplNom.ToUpper()
	&AplNom = &AplNom.Replace(';', '')
	prcAddRemoveAplicacao.Call('ADD', &EmPCod, &Procod, 0, &AplNom, &ProAplOrd)
	Refresh
	&AplNom.SetEmpty()
	&ProAplOrd.SetEmpty()
	
	&AplNom.SetFocus()

EndEvent

Sub 'GetAplicacao'

	&ProAplOrd = 0
	&AplCod = 0
	For Each Order EmpCod, AplNom //LOCALIZA APLICACAO
		Where EmpCod = &EmPCod
		Where AplNom = &AplNom
		&AplCod = AplCod
		txtAplicacaoNova.Visible = 0
		Exit
	When none
		txtAplicacaoNova.Visible = 1
	EndFor
	
	if &AplCod > 0		
		For Each Order EmpCod, ProCod, AplCod //GRAVA APLICACAO PRODUTO
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			Where AplCod = &AplCod
			
			&ProAplOrd = ProAplOrd
			
			Exit
		EndFor
	Endif

EndSub


]]></Source>
