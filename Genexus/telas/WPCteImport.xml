      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&CteCod = 0
	
	Do Case
		Case &Tipo = 1
			TextNOme.Caption = 'Selecione o arquivo XML,PDF ou XLSX da NF-e'
		Case &Tipo = 2
			TextNOme.Caption = 'Selecione o arquivo XML do CT-e'
		Case &Tipo = 3
			TextNOme.Caption = 'Selecione o arquivo PDF da COOPERATIVA LAR'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableMain.Height = 400

	Do 'AttributesSecurityCode'
	&IsUtilizaIa.Visible = False
	&ValorDescarga.Visible = False
	&IsRetDescargaFrete.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	TableDescarga.Visible = (&IsRetDescargaFrete = True)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &IsRetDescargaFrete.Click

	Do 'AttributesSecurityCode'

EndEvent

Event FileUpload1.UploadComplete

	For &FileUploadData in &FileUploadDataColl
		If not &FileUploadData.File.IsEmpty()
			//			msg('Arquivo Encontrado!')
			&File.Source = &FileUploadData.File
			&Extensao = &FileUploadData.Extension
			&NomeArquivo = &File.GetAbsoluteName() /// Pega o local temporario
			&File.Close()
			
			//=====Se a extesão nao for csv, envia mensagem=====
			Do Case
				Case &Extensao.ToLower().Trim() = 'xml' //Arquivo Correto, Iniciando CT-e!
				If &Tipo = 1// Nfe
					GravaCteComXml.Call(&EmpCod,&FilCod,&CteCod, &Context.FilCod, &Context.PesCod, &NomeArquivo, &Mensagem)
					
					If &Mensagem.IsEmpty()
						&WizardData.Geral.EmpCod = &EmpCod
						&WizardData.Geral.FilCod = &FilCod
						&WizardData.Geral.CteCod = &CteCod
						&WebSession.Set('WPCTE_Data', &WizardData.ToJson())
						WWpActions.WCPopup_Close('OK')
						
						//						WPCte(!'Capa', !'Geral', false)
					else
						msg(&Mensagem)
					EndIf
				Else
					//ct-e subcontratação
					GravaCteComXmlSub.Call(&EmpCod,&FilCod,&CteCod, &Context.FilCod, &Context.PesCod, &NomeArquivo, &Mensagem)
					
					If &Mensagem.IsEmpty()
						&WizardData.Geral.EmpCod = &EmpCod
						&WizardData.Geral.FilCod = &FilCod
						&WizardData.Geral.CteCod = &CteCod
						&WebSession.Set('WPCTE_Data', &WizardData.ToJson())
						WWpActions.WCPopup_Close('OK')
						
						//						WPCte(!'Capa', !'Geral', false)
					else
						msg(&Mensagem)
					EndIf
				EndiF
			
				Case &Extensao.ToLower().Trim() = 'pdf' // Arquivo LAR, OU NFE Iniciando CT-e!
					If &Tipo = 3// arquivo LAR 
						GravaCteComPdf.Call(&EmpCod,&FilCod,&CteCod,&NomeArquivo,&IsRetDescargaFrete,&ValorDescarga,&IsSucess, &Mensagem)
						
						If not &Mensagem.IsEmpty()
							msg(DVMessageGetBasicNotificationMsg.Udp(!"Error!", &Mensagem ,DVMessageType.error, "", DVMessageBoolean.True,"") )
						EndIF
						
					Else
						//NFE-PDF
						&UserMessage = GravaCteComIa(&EmpCod,&FilCod,&NomeArquivo,&CteCod)
						&IsSucess = CodeIsSucesso(&UserMessage.code)
						
						if not CodeIsSucesso(&UserMessage.code)
							Msg(DVMessageGetBasicNotificationMsg(&UserMessage.title,&UserMessage.message,&UserMessage.type,'',true,'',''))
						endif
					endif
				
					
					If &IsSucess = true 
						&WizardData.Geral.EmpCod = &EmpCod
						&WizardData.Geral.FilCod = &FilCod
						&WizardData.Geral.CteCod = &CteCod
						&WebSession.Set('WPCTE_Data', &WizardData.ToJson())
						WWpActions.WCPopup_Close('OK')
//						WPCte(!'Capa', !'Geral', false)
					Endif
				
				Case &Extensao.ToLower().Trim() = 'xlsx' or  &Extensao.ToLower().Trim() = 'xls' // Arquivo complemento lar,  CT-e!
					GravaCteComExcel.Call(&EmpCod,&FilCod,&CteCod,&NomeArquivo,&IsSucess)
					If &IsSucess = true
						WWpActions.WCPopup_Close('XLS')
//						WWCte.Call()
					EndIf
	
				Otherwise
					msg( DVMessageGetBasicNotificationMsg.Udp(!"Error!", "Arquivo incorreto!" ,DVMessageType.error, "", DVMessageBoolean.True,"") )
			EndCase
		Else
			msg( DVMessageGetBasicNotificationMsg.Udp(!"Error!", "Arquivo vazio!" ,DVMessageType.error, "", DVMessageBoolean.True,"") )
		EndiF
	EndFor
	
	&FileUploadDataColl.clear()
	FileUpload1.Clear()

EndEvent


]]></Source>
