      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	&AptDtaLctIni = serverdate()
	&AptDtaLctFin = serverdate()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&ProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)
	
	Do Case
		CAse &TipoRelatorio = 'D'
			RCOOpenWindow1.LinkOpen = RELJAS107_S.Link(&EmpCod, &FilCod, &PesCod, &AptDtaLctIni, &AptDtaLctFin, &ProForCod, &ProCod)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		CAse &TipoRelatorio = 'T'
			RCOOpenWindow1.LinkOpen = RELJAS107_T.Link(&EmpCod, &FilCod, &PesCod, &AptDtaLctIni, &AptDtaLctFin, &ProForCod, &ProCod)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			//		RCOOpenWindow1.LinkOpen = RELJAS107.Link(&EmpCod, &FilCod, &PesCod, &AptDtaLctIni, &AptDtaLctFin, &ProForCod)
			//		RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent

Event &PesCod.IsValid

	if &PesCod.IsEmpty()
		&PesRaz = 'TODOS OS FUNCIONARIOS'
	Else
		RetornaNomeFuncionario.Call(&EmpCod, &PesCod, &PesIsFun, &PesRaz)
	EndIF

EndEvent

Event &ProForCod.IsValid

	if &ProForCod.IsEmpty()
		&ProForRaz = 'TODOS OS FORNECEDORES'
	Else
		RetornaNomePessoa.Call(&EmpCod, &ProForCod, &ProForRaz)
	EndIF

EndEvent


]]></Source>
