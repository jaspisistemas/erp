      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)
	&FilCod = &Context.FilCod
	&EmpCod = &Context.EmpCod
	&FilCodNom = trim(Str(&Context.FiLCod)) + ' - ' + trim(&Context.FilRaz)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&IncluirVendasPerdidas.TooltipText = "Utilizar as Quantidades Canceladas dos Pedidos para Cálculo de Estoque Mínimo."
	&IncluirVendasAbertas.TooltipText = "Usando essa opção o Sistema irá somar também as quantidades Vendidas dos Pedidos com status em ABERTO e SEPARANDO"
	&InicialCalculo.TooltipText = "Data da Primeira Movimentação de Entrada do Produto. Antes dessa data não será possível o Cálculo Mínimo."
	&ProPadForCod.TooltipText = "Fornecedor Padrão do Produto"
	&DiasApuracao.TooltipText = "O Cálculo de Estoque Mínimo é montado em cima da quantidade Vendida em um Período de Apuração. Então informe o período de vendas. Recomenda-se no mínimo 60 Dias."
	&ProCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&IncluirVendasAbertas  = Status_SimNao.Sim
	&IncluirVendasPerdidas = Status_SimNao.Sim
	
    &iniPedDtaEms = &Today - 61
	&finPedDtaEms = &Today -1

	do 'DiasApuracao'
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilPrzEst = FilPrzEst
		Exit
	EndFor

EndEvent

Event &iniPedDtaEms.IsValid

	do 'DiasApuracao'
	do 'loadProduto'

EndEvent

Event &finPedDtaEms.IsValid

	do 'DiasApuracao'
	do 'loadProduto'

EndEvent

Event &ProRef.IsValid

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQTd, &ProBarQtd, &ErroMensagem)
	do 'loadProduto'

EndEvent

Event &IncluirVendasAbertas.IsValid

	do 'loadProduto'

EndEvent

Event &IncluirVendasPerdidas.IsValid

	do 'loadProduto'

EndEvent

Sub 'loadProduto'

	RetornaDadosCalculoMinimo.Call(&EmpCod, &FilCod, &ProCod, &iniPedDtaEms, &finPedDtaEms, &IncluirVendasAbertas, &IncluirVendasPerdidas, &TotalDiasBase, &InicialCalculo, &EstMin, &QuantidadeVendida, &QuantidadeCancelada, &UtilizadaProducao)
	
	wcgridPedidos.Object = wcPedidoCalculoMinimo.Create(&EmpCod, &FilCod, &ProCod, 1, &iniPedDtaEms, &finPedDtaEms,&IncluirVendasAbertas)
	wcNewPedidos.Object  = wcPedidosApuradosMinimo.Create(&EmpCod, &FilCod, &ProCod, 1, &iniPedDtaEms, &finPedDtaEms,&IncluirVendasAbertas)
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProNom = ProNom
		&ProPadForCod = ProPadForCod
		do 'getFornecedor'
		
		&EstCom = 0
		&EstVen = 0
		&EstPrd = 0
		&EstQtd = 0
		&EstSdo = 0
		&AuxEstSug = 0
		&EstFabMin = 0
		
		For Each Order EmpCod, FilCod, ProCod, ProGraCod
			Where FilCod = &FilCod
			Where ProGraCod = &ProGraCod
			
			&EstQtd = EstQtd
			&EstPrd = EstPrd
			&EstSdo = EstSdo
			
			&EstCom = EstCom
			&EstVen = EstVen
			&EstFabMin = EstFabMin
			&AuxEstSug = EstSug
		EndFor


		Exit
		
	EndFOr

	If &EstMin < &EstFabMin
		&EstSug = &EstFabMin - &EstSdo
	Else
		&EstSug = &EstMin - &EstSdo
	EndIF

EndSub

Sub 'getFornecedor'

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &ProPadForCod
		&PesRaz = PesRaz
		Exit
	When none
		&PesRaz = 'FORNECEDOR PADRAO NAO ENCONTRADO'
	EndFor

EndSub

Sub 'DiasApuracao'

	&diasApuracao = &finPedDtaEms - &iniPedDtaEms

EndSub


]]></Source>
