      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('FRETEFECHAFINANCEIRO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	
	&sdtPedidos.fromXml(&WebSession.Get('CONFFECHAFRETE'))
	
	PadraoUsuario.Call('L', &Pgmname, &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
	if not &padObs.IsEmpty() 
		&CbrCod = val(Substr(&padObs,1,8))
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = 5
	GridsdtPedidossPaginationBar.RowsPerPageSelectedValue = GridsdtPedidoss.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridsdtPedidossCurrentPage = GridsdtPedidoss.CurrentPage
	&GridsdtPedidossPageCount = GridsdtPedidoss.PageCount

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidoss.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PlanHie = &sdtPedidos.CurrentItem.PlanHie
	do 'PlanoEscolhido'

EndEvent

Event GridsdtPedidossPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Previous'
			GridsdtPedidoss.PreviousPage()
		Case GridsdtPedidossPaginationBar.SelectedPage = !'Next'
			&PageToGo = GridsdtPedidoss.CurrentPage
			&PageToGo += 1
			GridsdtPedidoss.GotoPage(&PageToGo)
		Otherwise
			&PageToGo.FromString(GridsdtPedidossPaginationBar.SelectedPage)
			GridsdtPedidoss.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridsdtPedidossPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridsdtPedidoss.Rows = GridsdtPedidossPaginationBar.RowsPerPageSelectedValue
	GridsdtPedidoss.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&padObs = padL(trim(str(&CbrCod)), 8, '0')
	PadraoUsuario.Call('G', &Pgmname, &Context.PesCod, &Context.EmpCod, &padObs, &PadDtaMod)
	
	&isErro = false
	for &sdtPedidosItem in &sdtPedidos
		if &sdtPedidosItem.PlanHie.IsEmpty()
			&isErro = true
			msg('Frete: ' + trim(str(&sdtPedidosItem.PedCod)) + ' Não possui Plano de Contas!')
			Exit
		EndIf
	EndFor
	
	if &isErro = false
		FechaConhecimentoFretes.Call(&Context.EmpCod, &Context.FilCod, &CbrCod, &sdtPedidos, &Context.UserName)
		Return
	EndIF

EndEvent

Sub 'PlanoEscolhido'

	For Each Order EmpCod, PlanHie
		Where EmpCod = &EmpCod
		Where PlanHie = &PlanHie
		&PlanCodNom = PlanCodNom
		Exit
	EndFor

EndSub


]]></Source>
