      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&LogarConta = false
	&EmailTeste = false
	
	For Each Order EmpCod, EmpEmlCod
		Where EmpCod = &EmpCod
		Where EmpEmlCod = &EmpEmlCod
		If EmpEmlCnf = '1'
			&LogarConta = true
			&EmailTeste = true
		EndIF
		Exit			
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&LogarConta = false
	&EmailTeste = false
	&EmpEmlCnf = '2'
	
	For Each Order EmpCod, EmpEmlCod
		Where EmpCod = &EmpCod
		Where EmpEmlCod = &EmpEmlCod
		
		&EmpEml = EmpEml
		
		&SMTPSession.Sender.Name = EmpRaz
		&SMTPSession.Sender.Address = EmpEml
		&SMTPSession.Authentication = EmpEmlAut
		&SMTPSession.Secure = EmpEmlSec
		&SMTPSession.Timeout        = 25
		&SMTPSession.Host 			= EmpEmlHos
		&SMTPSession.UserName 		= EmpEmlUsr
		&SMTPSession.Password 		= DecryptSenhaEmail.Udp(EmpCod, EmpEmlCod, EmpEml)
		&SMTPSession.Port 			= EmpEmlPor
	
	
		Exit
	EndFor
	
	&SMTPSession.Login()
	if &SMTPSession.ErrCode <> 0
		msg(&SMTPSession.ErrDescription)
	else
		&LogarConta = true
		
		//=====Insere o assunto da mensagem=====
		&MailMessage.Subject = 'Teste de Envio E-Mail'
		
		//=====Adiciona 1º Destinatário de email=====
		&MailRecipient.Address = &EmpEml
		//&MailRecipient.Name = 'Cicrano'
		&MailMessage.To.Add(&MailRecipient)
		
		&MailMessage.Text = 'Se você estiver visualizando esse e-mail, significa que as configurações da conta ficarão corretas!'

		&SMTPSession.Send(&MailMessage)
		If &SMTPSession.ErrCode <> 0
			msg(&SMTPSession.ErrDescription)
			
		Else
			&EmailTeste = true
			&EmpEmlCnf = '1'
			msg('Conta Verificada Com Sucesso!')
		EndIF
	EndIf
	
	//finaliza login
	&SMTPSession.Logout()
	
	StatusEmailEmpresa.Call(&EmpCod, &EmpEmlCod, &EmpEmlCnf)

EndEvent


]]></Source>
