      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = Page.Rows
	DDO_Grid.GridInternalName = Grid.InternalName
	Form.Caption = ' Apontamentos'

	Do 'PrepareTransaction'
	Do 'LoadGridState'
	If &OrderedBy < 1
		&OrderedBy = 1
		Do 'SetDDOSortedStatus'
	EndIf
	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	GridPaginationBar.RowsPerPageSelectedValue = Grid.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&OcsCod = &parOcsCod
	
	do 'LoadOrdemCostura'

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)

	Do 'SaveGridState'

	Do 'InitializeTotalizers'
	&GridCurrentPage = Grid.CurrentPage
	&GridPageCount = Grid.PageCount
	Do 'CalculateTotalizers'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&OcsCod = &parOcsCod

EndEvent

Event GridPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridPaginationBar.SelectedPage = !'Previous'
			Grid.PreviousPage()
		Case GridPaginationBar.SelectedPage = !'Next'
			Grid.NextPage()
		Otherwise
			&PageToGo.FromString(GridPaginationBar.SelectedPage)
			Grid.GotoPage(&PageToGo)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid.Rows = GridPaginationBar.RowsPerPageSelectedValue
	Grid.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DDO_Grid.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case DDO_Grid.ActiveEventKey = !'<#OrderASC#>' OR DDO_Grid.ActiveEventKey = !'<#OrderDSC#>'
			&OrderedBy.FromString(DDO_Grid.SelectedValue_get)
			&OrderedDsc = iif(DDO_Grid.ActiveEventKey = !'<#OrderDSC#>', true, false)
			Do 'SetDDOSortedStatus'
			Grid.FirstPage()
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&deleteLancamento.FromImage(ActionDelete)
	&deleteLancamento.TooltipText = ""
	
	RetornaNomeEtapaGrupo.Call(EmpCod, AptProCod, AptEtpCod, &CtrNom)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoSair'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWOrdemCostura.Call()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'SetDDOSortedStatus'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DDO_Grid.SortedStatus = &OrderedBy.ToString().Trim() + !':' + iif(&OrderedDsc, !'DSC', !'ASC')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(&PgmName + !"GridState") = !""
		&GridState.FromXml(LoadGridState.Udp(&PgmName + !"GridState"))
	Else
		&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc
	Do 'SetDDOSortedStatus'

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"OCSITM"
				&OcsItm.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"APTETPCOD"
				&AptEtpCod.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"OCSCOD"
				&OcsCod.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
	If not &GridState.PageSize.Trim().IsEmpty()
		Grid.Rows = &GridState.PageSize.ToNumeric()
	EndIf
	Grid.CurrentPage = &GridState.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIF

	&OcsCod = &parOcsCod

EndSub

Sub 'SaveGridState'

	&OcsCod = &parOcsCod
	
	if 1=2

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&GridState.FromXml(&Session.Get(&PgmName + !"GridState"))

	// Save grid state in session.
	&GridState.OrderedBy = &OrderedBy
	&GridState.OrderedDsc = &OrderedDsc
	&GridState.FilterValues.Clear()
	WWP_GridStateAddFilterValue(&GridState, !"OCSITM", "", not &OcsItm.IsEmpty(), 0, &OcsItm.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"APTETPCOD", "", not &AptEtpCod.IsEmpty(), 0, &AptEtpCod.ToString().Trim(), '')
	WWP_GridStateAddFilterValue(&GridState, !"OCSCOD", "", not &OcsCod.IsEmpty(), 0, &OcsCod.ToString().Trim(), '')

	&GridState.PageSize = str(Grid.Rows)
	&GridState.CurrentPage = Grid.CurrentPage
	SaveGridState.Call(&PgmName + !"GridState",  &GridState.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	EndIf

EndSub

Sub 'PrepareTransaction'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TrnContext = new()
	&TrnContext.CallerObject = &Pgmname
	&TrnContext.CallerOnDelete = True
	&TrnContext.CallerURL = &HTTPRequest.ScriptName + !"?" + &HTTPRequest.QueryString
	&TrnContext.TransactionName = !"Apontamentos"

	&Session.Set(!"TrnContext", &TrnContext.ToXml())

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'InitializeTotalizers'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&TotAptQtd = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'CalculateTotalizers'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For Each
		using DSwpOrdemCostura_Lancamentos(&OcsItm, &AptEtpCod, &OcsCod)
		defined by AptAtiCod
		&TotAptQtd = AptQtd + &TotAptQtd
		
	EndFor
	&TotValueAptQtd = &TotAptQtd.ToFormattedString()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &OcsItm.Click

	do 'loadProduto'

EndEvent

Event &OcsItm.IsValid

	do 'loadProduto'

EndEvent

Event &deleteLancamento.Click

	Apontamentos.Popup(TrnMode.Delete, EmpCod, AptDtaLct, AptCod)
	Refresh

EndEvent

Sub 'loadProduto'

	&GrupCod = 0
	&ProCod.SetEmpty()	
	
	For Each Order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &ocsItm
		&ProCod = OcsProCod
		Exit
	EndFor
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&GrupCod = GrupCod
		Exit
	EndFor

EndSub

Sub 'LoadOrdemCostura'

	&Count = 0
	
	For Each Order EmpCod, OcsCod
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		
		//PRODUTOS
		&Count = 0
		For Each Order EmpCod, OcsCod, OcsItm
			&Count +=1
			&OcsProGraNom = '[ITEM: ' +trim(str(OcsItm)) + '] '+ OcsProNroCor.Trim() + ' - ' + OcsProGraNom.Trim()
			&OcsItm.AddItem(OcsItm, &OcsProGraNom)
		EndFor
		
		Exit
	EndFor
	
	if &Count > 1
		&OcsProGraNom = '0 - TODOS OS PRODUTOS'
		&OcsItm.AddItem(0, &OcsProGraNom)
	EndIF

EndSub


