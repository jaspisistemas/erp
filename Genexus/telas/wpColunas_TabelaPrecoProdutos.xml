Event Start

	RetornaAutorizacao.Call('WWPEDIDOCOMPRA', Status_SimNao.Nao, 1, &AutNiv)
	LoadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&TabCod = &parTabCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Group.Width = 350

	Do 'AttributesSecurityCode'
	&EmpCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'loadPadrao'
	do 'loadColunas'

EndEvent

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&AutNiv >= 1)
		&IsMargemLuc.Visible = False
		IsMargemLuc_Cell.Class = !'Invisible'
	Else
		&IsMargemLuc.Visible = True
		IsMargemLuc_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf
	If Not (&AutNiv >= 1)
		&IsProVlrCus.Visible = False
		IsProVlrCus_Cell.Class = !'Invisible'
	Else
		&IsProVlrCus.Visible = True
		IsProVlrCus_Cell.Class = !'col-xs-12 DataContentCell'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

//	if not &TabCod.IsEmpty()
		Do 'GravaPadrao'
		return
//	else
//		msg('ATENÇÃO! Não é possível salvar sem preenchar o código da Tabela!')
//	EndIf

EndEvent

Sub 'loadColunas'

	RetornaColunasTabelasNomes.Call(&EmpCod, &TabCod, &TabColNom, &TabColNom2, &TabColNom3,&TabColNom4,&TabColNom5,&TabColNom6,&TabColNom7,&TabColNom8,&TabColNom9)
	&IsCol1.Caption = Upper(&TabColNom)
	&IsCol2.Caption = Upper(&TabColNom2)
	&IsCol3.Caption = Upper(&TabColNom3)
	&IsCol4.Caption = Upper(&TabColNom4)
	&IsCol5.Caption = Upper(&TabColNom5)
	&IsCol6.Caption = Upper(&TabColNom6)
	&IsCol7.Caption = Upper(&TabColNom7)
	&IsCol8.Caption = Upper(&TabColNom8)
	&IsCol9.Caption = Upper(&TabColNom9)

EndSub

Sub 'loadPadrao'

	&PadObs.SetEmpty()
	PadraoUsuario.Call('L','COL_WWTABELAPRECOPRODUTO',&wwpContext.PesCod,&EmpCod,&PadObs,&Today)
	&SDT_wwTabelaPrecoProduto.FromJson(&PadObs)
//	&TabCod = &SDT_wwTabelaPrecoProduto.TabCod
	&IsMarNom = &SDT_wwTabelaPrecoProduto.IsMarNom
	&IsNcmCod = &SDT_wwTabelaPrecoProduto.IsNcmCod
	&IsProPesLiqPrd = &SDT_wwTabelaPrecoProduto.IsProPesLiqPrd
	if &AutNiv >= 1
		&IsProVlrCus = &SDT_wwTabelaPrecoProduto.IsProVlrCus
	EndIf
	&IsProGraBar = &SDT_wwTabelaPrecoProduto.IsProGraBar
	&IsProGraEstLoc = &SDT_wwTabelaPrecoProduto.IsProGraEstLoc
	&IsProGraEstQtd = &SDT_wwTabelaPrecoProduto.IsProGraEstQtd
	&IsProGraEstSdo = &SDT_wwTabelaPrecoProduto.IsProGraEstSdo
	&IsEmbVol  = &SDT_wwTabelaPrecoProduto.IsEmbVol
	&IsGrupCod = &SDT_wwTabelaPrecoProduto.IsGrupCod
	&IsCol1 = &SDT_wwTabelaPrecoProduto.IsCol1
	&IsCol2 = &SDT_wwTabelaPrecoProduto.IsCol2
	&IsCol3 = &SDT_wwTabelaPrecoProduto.IsCol3
	&IsCol4 = &SDT_wwTabelaPrecoProduto.IsCol4
	&IsCol5 = &SDT_wwTabelaPrecoProduto.IsCol5
	&IsCol6 = &SDT_wwTabelaPrecoProduto.IsCol6
	&IsCol7 = &SDT_wwTabelaPrecoProduto.IsCol7
	&IsCol8 = &SDT_wwTabelaPrecoProduto.IsCol8
	&IsCol9 = &SDT_wwTabelaPrecoProduto.IsCol9
	&IsMargemLuc = &SDT_wwTabelaPrecoProduto.IsMargemLuc

EndSub

Sub 'GravaPadrao'

//	&SDT_wwTabelaPrecoProduto.TabCod = &TabCod
	&SDT_wwTabelaPrecoProduto.IsMarNom = &IsMarNom
	&SDT_wwTabelaPrecoProduto.IsNcmCod = &IsNcmCod
	&SDT_wwTabelaPrecoProduto.IsProPesLiqPrd = &IsProPesLiqPrd
	&SDT_wwTabelaPrecoProduto.IsProGraBar = &IsProGraBar
	if &AutNiv >= 1
		&SDT_wwTabelaPrecoProduto.IsProVlrCus = &IsProVlrCus
	EndIf
	&SDT_wwTabelaPrecoProduto.IsProGraEstLoc = &IsProGraEstLoc
	&SDT_wwTabelaPrecoProduto.IsProGraEstQtd = &IsProGraEstQtd
	&SDT_wwTabelaPrecoProduto.IsProGraEstSdo = &IsProGraEstSdo
	&SDT_wwTabelaPrecoProduto.IsEmbVol = &IsEmbVol 
	&SDT_wwTabelaPrecoProduto.IsGrupCod = &IsGrupCod
	&SDT_wwTabelaPrecoProduto.IsCol1 = &IsCol1
	&SDT_wwTabelaPrecoProduto.IsCol2 = &IsCol2 
	&SDT_wwTabelaPrecoProduto.IsCol3 = &IsCol3
	&SDT_wwTabelaPrecoProduto.IsCol4 = &IsCol4
	&SDT_wwTabelaPrecoProduto.IsCol5 = &IsCol5
	&SDT_wwTabelaPrecoProduto.IsCol6 = &IsCol6
	&SDT_wwTabelaPrecoProduto.IsCol7 = &IsCol7
	&SDT_wwTabelaPrecoProduto.IsCol8 = &IsCol8
	&SDT_wwTabelaPrecoProduto.IsCol9 = &IsCol9
	&SDT_wwTabelaPrecoProduto.IsMargemLuc = &IsMargemLuc
	PadraoUsuario.Call('G','COL_WWTABELAPRECOPRODUTO',&wwpContext.PesCod,&EmpCod,&SDT_wwTabelaPrecoProduto.ToJson(),&Today)

EndSub

