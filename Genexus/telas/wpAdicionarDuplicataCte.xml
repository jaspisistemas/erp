      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)
	//RETORNA FORMAS PAGAMENTOS
	RetornaFormasPagamento.Call(&Context.EmpCod, 'R', '', &Context.PesCod, &Context.TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	&PedFrpPgtoCod.Clear()
	For &sdtFormasPagamentoItem in &sdtFormasPagamento	
		&DescricaoVarchar = &sdtFormasPagamentoItem.FrpPgtoCodExib + ' - ' + &sdtFormasPagamentoItem.FrpPgtoNom
		&PedFrpPgtoCod.AddItem(&sdtFormasPagamentoItem.FrpPgtoCod, &DescricaoVarchar)
	EndFor

	//RETORNA FORMAS PAGAMENTOS	
	
	&Codigo3 = 1
	&CteDupDtaVct = serverdate()	

	For Each Order EmpCod, FilCod, CteCod	
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CteNum = CteNum
		&CteVlrRecSer = CteVlrRecSer
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable3.Width = 700

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'ValidaFormaPagamento'
	
	Do Case
		Case &CteDupDtaVct.IsEmpty()
			Msg('ATENÇÃO! Data de vencimento não pode ser vazia.')
		Case &CteDupDtaVct < &Today
			Msg('ATENÇÃO! Data de vencimento não pode ser menor que a data de hoje.')
		Case &NfeDupVlr <= 0
			Msg('ATENÇÃO! Valor da duplicata não pode ser menor ou igual a zero.')
		Otherwise
			
			NovaDUplicataCte_Tipo.Call('ADD', &EmpCod, &FilCod, &CteCod, 0, '', &CteDupDtaVct, &NfeDupVlr, &CteCbrCod, &Codigo3, &PedFrpPgtoCod)
			GravaDuplicatasAReceberCte.Call(&EmpCod, &FilCod,&CteCod, &Context.PesCod)
			Return
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Return

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &PedFrpPgtoCod.IsValid

	do 'ValidaFormaPagamento'

EndEvent

Event Refresh

	RetornaTotalDuplicatasCTe.Call(&EmpCod, &FilCod, &CteCod, &TotMovItmVlr, &CarMovItmVlr, &TotDebVlrDup, &TotCreVlrDup, &TotalMoeda )
	&Diferenca = &CteVlrRecSer - &TotalMoeda
	&NfeDupVlr = &diferenca //inicia com valor de diferença

EndEvent

Sub 'ValidaFormaPagamento'

	if &Codigo3.IsEmpty()
		&Codigo3 = 1
	Endif

EndSub


]]></Source>
