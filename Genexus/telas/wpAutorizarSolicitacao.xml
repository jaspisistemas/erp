Sub 'getProduto'

	For Each ORder EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &PedLibProCod
		Where ProGraCod = &PedLibProGraCod
		&ProRef = ProGraRef
		&ProNom = ProNomGra
		Exit
	EnDfor

EndSub

Sub 'loadAutorizacao'

		For Each Order EmpCod, FilCod, PedCod, PedLibItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedLibItm = &PedLibItm
			&PedLibCliCod	= PedLibCliCod			
			&PesRaz = RetornaNomePessoa.Udp(EmpCod, PedLibCliCod)
			
			&PedLibObs	= PedLibObs
			
			&PedLibProCod	= PedLibProCod
			&PedLibProGraCod	= PedLibProGraCod
			do 'getProduto'
			
			&PedLibSolDta	= PedLibSolDta
			&PedLibSolFun	= PedLibSolFun
			&SolPesRaz = RetornaNomePessoa.Udp(EmpCod, PedLibSolFun)
			
			&PedLibSts	= PedLibSts
			&PedLibTip	= PedLibTip
			
			&PedLibAutDta		= PedLibAutDta
			&PedLibAutFun		= PedLibAutFun
			
			If PedLibSolPedQtd > 0
				&SolicitarQtd = true
			EndIF
		
			&SolicitarValor = 'S'
			If PedLIbSolPedVlr > 0 
				&SolicitarValor = 'V'
			Endif
			If PedLibSolPedDesc > 0
				&SolicitarValor = 'D'
			EndIF
			
			&PedLibSolPedQtd 	= PedLibSolPedQtd
			&PedLibSolPedVlr 	= PedLIbSolPedVlr
			&PedLibSolPedDesc 	= PedLibSolPedDesc
			&PedLibRea = PedLIbRea
			
			btnBtnDesautorizar.Visible = 0
			btnBtnAutorizar.Visible = 0
			btnAprovarReavaliacao.Visible = 0
			btnBloquearReavaliacao.Visible = 0
			Do Case
				Case PedLibSts = StatusLiberacao.Autorizado and PedLIbRea = 0
					&AvisoSolicitacao = 'SOLICITAÇÃO APROVADA'
					IconAmarelo.FromImage(iconVerde)
					&PedLibSolPedDesc	= PedLibAutPedDesc
					&PedLibSolPedQtd	= PedLibAutPedQtd
					&PedLibSolPedVlr	= PedLibAutPedVlr
					
				Case PedLibSts = StatusLiberacao.NaoAutorizado and PedLIbRea = 0
					IconAmarelo.FromImage(Iconvermelho)
					&AvisoSolicitacao = 'SOLICITAÇÃO REPROVADA'
					
				Case PedLIbRea = 1
					IconAmarelo.FromImage(iconAzul)
					&AvisoSolicitacao = 'EM REAVALIAÇÃO'
					btnAprovarReavaliacao.Visible = 1
					btnBloquearReavaliacao.Visible = 1
					
				Otherwise
					btnBtnDesautorizar.Visible = 1
					btnBtnAutorizar.Visible = 1
					IconAmarelo.FromImage(IconAmarelo)
					&AvisoSolicitacao = 'SOLICITAÇÃO PENDENTE'
			EndCAse
					
			&PedLIbAutObs 		= PedLibAutObs

			Exit
		When none
			Return
		EndFor
	
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			&TabPrc1 = RetornaPrecoUnitarioVenda.UDP(EmpCod, TabCod, TabPrmCod, &PedLibProCod, &PedLibProGraCod, TabColCod, PedDtaEms, PedDtaVct)
			
			If PedSts <> Status_Pedido.ABERTO
				msg('Nada é possível modificar aqui. Pedido não esta mais Aberto!')
			EndIF
		
			For Each Order EmpCod, FilCod, PedCod, ProCod, ProGraCod
				Where ProCod = &PedLibProCod
				Where ProGraCod = &PedLibProGraCod
				
				&atuPedLibSolPedDesc = PedItmDsc
				&atuPedLibSolPedQtd = PedQtd
				&atuPedLibSolPedVlr = PedVlrUnt
				Exit
			EndFor
			
			Exit
		EndFor
	
		For Each Order EmpCod, ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &PedLibProCod
			
			&ProVlrCus = ProVlrCus
			&ProQtdEmb = ProQtdEmb
			
			Exit
		EndFor

EndSub


]]></Source>
