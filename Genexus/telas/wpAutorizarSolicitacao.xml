Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If Not (&SolicitarValor = 'D')
		&PedLibSolPedDesc.Visible = False
		PedLibSolPedDesc_Cell.Class = !'Invisible'
	Else
		&PedLibSolPedDesc.Visible = True
		PedLibSolPedDesc_Cell.Class = !'DataContentCell'
	EndIf
