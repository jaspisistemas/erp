        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&WizardSteps = new()

	&WizardStep = new()
	&WizardStep.Code = !'SelecioneXML'
	&WizardStep.Title = 'Selecione XML'
	&WizardStep.Description = 'Selecione XML'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Envolvidos'
	&WizardStep.Title = 'Envolvidos'
	&WizardStep.Description = 'Envolvidos'
	&WizardSteps.Add(&WizardStep)

	&WizardStep = new()
	&WizardStep.Code = !'Documentos'
	&WizardStep.Title = 'NFe'
	&WizardStep.Description = 'NFe'
	&WizardSteps.Add(&WizardStep)

	If &CurrentStep.IsEmpty()
		&CurrentStepAux = !'SelecioneXML'
		&WebSession.Remove(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim())
	Else
		&CurrentStepAux = &CurrentStep
	EndIf
	&SessionGuidAux = iif(&SessionGuid.IsEmpty(), GUID.NewGuid(), &SessionGuid)
	Do 'LoadWizardStepWC'
	StepTitles.Object = WizardStepsUnderlineWC.Create(&WizardSteps, &CurrentStepAux)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDoVoltarPDV'

	wwCteTerceiros.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadWizardStepWC'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &CurrentStepAux = !'SelecioneXML'
			WizardStepWC.Object = wpImportarCTeSelecioneXML.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'Envolvidos'
			WizardStepWC.Object = wpImportarCTeEnvolvidos.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
		Case &CurrentStepAux = !'Documentos'
			WizardStepWC.Object = wpImportarCTeDocumentos.Create(&Pgmname + !'_Data' + &SessionGuidAux.ToString().Trim(), &PreviousStep, &GoingBack, &SessionGuidAux)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


