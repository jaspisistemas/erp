      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	LoadWWPContext.Call(&Context)
	WorkWithLink.Link = WWEntradaProducao.Link()

	For each EntradaProducao
		where EmpCod = &EmpCod and FilCod = &FilCod and PrdCod = &PrdCod
		Form.Caption = PrdDtaEnt.ToString()
		&Exists = True

	When none
		Form.Caption = "WWP_RecordNotFound"
		&Exists = False
	Endfor

	If (&Exists)
		&SelectedTabCode = &TabCode
		Tabs.ActivePageControlName = &SelectedTabCode
		Do 'LoadTabs'
	Endif

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Tabs.TabChanged

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&SelectedTabCode = Tabs.ActivePageControlName
	&LoadAllTabs = false
	Do 'LoadTabs'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadTabs'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If &LoadAllTabs OR &SelectedTabCode = '' OR &SelectedTabCode = !"General"
		GeneralWC.Object = EntradaProducaoGeneral.Create(&EmpCod, &FilCod, &PrdCod)
	EndIf
	If &LoadAllTabs OR &SelectedTabCode = !"PrdItm"
		PrdItmWC.Object = EntradaProducaoPrdItmWC.Create(&EmpCod, &FilCod, &PrdCod)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


