        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WPAGRUPARPEDIDO', Status_SimNao.Nao, 1, &AutNiv)
	RetornaAutorizacao.Call('WPAGRUPARPEDIDOCOMPRA', Status_SimNao.Nao, 1, &CompraAutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &Context.FilCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid_Empowerer.GridInternalName = Grid.InternalName
	Grid.Rows = 0
	Grid2_Empowerer.GridInternalName = Grid2.InternalName
	Grid2.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&OqueFazer = 'A'
	
	do 'QualAbaTrabalhar'

EndEvent

Event Grid.Load

 //AGRUPAR TUDO
	
	for &sdtPedidosItem in &sdtPedidos

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&removePedido.FromImage(ActionDelete)
	&removePedido.TooltipText = "Remove Pedido"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&gridPedCliCodRaz = &sdtPedidosItem.PedCliCodRaz
		
		&index = &sdtPedidos.IndexOf(&sdtPedidosItem)
		If &index = 1
			&gridOqueAcontece = 'UM NOVO PEDIDO SERÁ CRIADO, PARA RECEBER O AGRUPAMENTO'
			&gridOqueAcontece.ForeColor = RGB(0,160,40)
			&gridPedVlrLiq = &AgrTudPedVlrLiq
			&gridPedCod = 0
			&removePedido.Visible = 0
			
			load
			
			&removePedido.Visible = 1
			&gridOqueAcontece = 'PEDIDO SERÁ CANCELADO e PRODUTOS GRAVADOS NO NOVO PEDIDO'
			&gridOqueAcontece.ForeColor = RGB(160,40,0)
		Else
			&gridOqueAcontece = 'PEDIDO SERÁ CANCELADO e PRODUTOS GRAVADOS NO NOVO PEDIDO'
			&gridOqueAcontece.ForeColor = RGB(160,40,0)
			&removePedido.Visible = 1
		EndiF

		&gridPedCod = &sdtPedidosItem.PedCod
		&gridPedVlrLiq = &sdtPedidosItem.PedVlrLiq
	
		
		
		load
	EndFor

EndEvent

Event Grid2.Load

 //VALOR
	&AgrpVlrPedCod = 0
	&AgrpVlrPedVlrAgr = 0
	&AgrpVlrPedVlrLiq = 0
	&AgrpVlrPedVlrAgr = 0
	&AgrpVlrNovPedVlrLiq = 0
	&AgrpVlrPedCliCod = 0
	
	for &sdtPedidosItem in &sdtPedidos
		&grid2PedCod = &sdtPedidosItem.PedCod
		&grid2PedCliCodRaz = &sdtPedidosItem.PedCliCodRaz
		&grid2PedVlrLiq = &sdtPedidosItem.PedVlrLiq
		&grid2PedStsFin = &sdtPedidosItem.PedStsFin
		
		&index = &sdtPedidos.IndexOf(&sdtPedidosItem)
		If &index = 1
			&AgrpVlrPedCod = &sdtPedidosItem.PedCod
			&AgrpVlrPedVlrLiq = &sdtPedidosItem.PedVlrLiq	
			&AgrpVlrPedCliCod = &sdtPedidosItem.PedCliCod
			&AgrpLctTip		  = &sdtPedidosItem.LctTip
			&grid2OqueAcontece = 'RECEBERÁ O VALOR AGRUPADO'
			&grid2OqueAcontece.ForeColor = RGB(0,160,40)
		Else
			&AgrpVlrPedVlrAgr += &sdtPedidosItem.PedVlrLiq
			
			&grid2OqueAcontece = 'FINANCEIRO SERÁ FECHADO NO PED.' + trim(str(&AgrpVlrPedCod))
			&grid2OqueAcontece.ForeColor = RGB(160,40,0)
		EndIF
	
		&AgrpVlrNovPedVlrLiq = &AgrpVlrPedVlrAgr + &AgrpVlrPedVlrLiq

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&removePedido2.FromImage(ActionDelete)
	&removePedido2.TooltipText = "Remove Pedido"

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		load
	EndFor

EndEvent

Event 'DoRemoverPedidos'

	&sdtPedidos.Clear()
	do 'somaSDT'
	grid.Refresh()
	grid2.Refresh()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'CarregaPedido'
	do 'AddPedidoSdt'
//	&OqueFazer.Visible = &sdtPedidos.Count = 0
	&PedCod.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoConfirmarAgrupamento'

	if &OqueFazer = 'A' //SOMENTE VALORES
		gravaAgrupamentoValores.Call(&sdtPedidos, &Context.PesCod, &Mensagem,&IsErroPedido)
		if not &Mensagem.IsEmpty()
			msg(&Mensagem)
		EndIF
		If &IsErroPedido = false // agrupado com sucesso então limpa grids e sdt.
			Do 'RemovePedido'
		EndIf
	Else // Agrupar Todos os Pedidos em 1 Novo Pedido:B
		gravaAgrupamentoTotal.Call(&sdtPedidos, &Context.PesCod, &Context.UserName, &Mensagem,&IsErroPedido)
		If not &Mensagem.IsEmpty()
			msg(&Mensagem)
		EndIF
		If &IsErroPedido = false // agrupado com sucesso então limpa grids e sdt.
			Do 'RemovePedido'
		EndIf
		//msg('Opção de agrupamento ainda não desenvolvida!')//, Agrupar Todos os Pedidos em 1 Novo Pedido:B
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoDesagrupar'

	wpDesagruparPedido.Popup()
	Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &OqueFazer.IsValid

	do 'QualAbaTrabalhar'

EndEvent

Event &PedCod.IsValid

	do 'CarregaPedido'

EndEvent

Event &removePedido.Click

	&auxPedCod = &gridPedCod
	do 'DeletePedidoSDT'
	do 'somaSDT'
	grid.Refresh()
	grid2.Refresh()

EndEvent

Event &removePedido2.Click

	&auxPedCod = &grid2PedCod
	do 'DeletePedidoSDT'
	do 'somaSDT'
	grid.Refresh()
	grid2.Refresh()

EndEvent

Sub 'QualAbaTrabalhar'

	If &OqueFazer = 'A' //Agrupar Somente Valores dos Pedidos:A
		GXUITabsPanel_tabsAgrup.HideTab(2)
		GXUITabsPanel_tabsAgrup.showTab(1)
		GXUITabsPanel_tabsAgrup.SelectTab(1)
	
	Else //Agrupar Todos os Pedidos em 1 Novo Pedido:B
		GXUITabsPanel_tabsAgrup.HideTab(1)
		GXUITabsPanel_tabsAgrup.showTab(2)
		GXUITabsPanel_tabsAgrup.SelectTab(2)
	EndIF

EndSub

Sub 'AddPedidoSdt'

	do 'CarregaPedido'
	
	if &IsErroPedido = false
		&IsAchouPedido = false
		for &sdtPedidosItem in &sdtPedidos
			if &sdtPedidosItem.PedCod = &PedCod
				&IsAchouPedido = true
				msg('Pedido já Adicionado anteriormente!')
				Exit
			EndiF
		EndFor
		
		if &IsAchouPedido = false
			&sdtPedidosItem = new()
			&sdtPedidosItem.PedCod = &PedCod
			&sdtPedidosItem.FiLCod = &Context.FilCod
			&sdtPedidosItem.EmPCod = &Context.EmpCod
			&sdtPedidosItem.PedCliCodRaz = &PedCliCodRaz
			&sdtPedidosItem.PedCliCod = &PedCliCod
			&sdtPedidosItem.PedVlrLiq = &PedVlrLiq
			&sdtPedidosItem.LctTip = &LCtTip
			&sdtPedidosItem.PedStsFin = &PedStsFin
			&sdtPedidos.Add(&sdtPedidosItem)
			
			do 'somaSDT'
			
			grid.Refresh()
			grid2.Refresh()
		EndIf
	EndIF

EndSub

Sub 'CarregaPedido'

	//Agrupar Somente Valores dos Pedidos:A, 
	//Agrupar Todos os Pedidos em 1 Novo Pedido:B
	
	&PedCliCodRaz = ''
	&PedCliCod = 0
	&PedVlrLiq = 0
	&LCtTip.SetEmpty()
	&IsErroPedido = true
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &pedCod
		
		&PedCliCodRaz = PedCliCodRaz
		&PedCliCod = PedCliCod
		&PedVlrLiq = PedVlrLiq
		&LCtTip = LctTip
		&PedStsFin = PedStsFin
		
		validaPedidoAgrupamentoTotal.Call(EmpCod, FilCod, PedCod, &OqueFazer, &AgrpVlrPedCliCod, &AgrpLctTip, &IsErroPedido, &Mensagem)
	
		if not &Mensagem.IsEmpty()
			msg(&Mensagem)
		EndIF
		
		Exit
	When None
		If &PedCod = 0
			&PedCliCodRaz = 'INFORME O PEDIDO'
		Else
			&PedCliCodRaz = 'PEDIDO NÃO ENCONTRADO'
			msg(&PedCliCodRaz)
			&PedCod.SetFocus()
		EndIF
	EndFor

EndSub

Sub 'DeletePedidoSDT'

	For &sdtPedidosItem in &sdtPedidos
		if &sdtPedidosItem.PedCod = &auxPedCod
			&index = &sdtPedidos.IndexOf(&sdtPedidosItem)
			&sdtPedidos.Remove(&index)
			Exit
		EndIF
	EndFor

EndSub

Sub 'RemovePedido'

	&SdtPedidos.Clear()	
	do 'somaSDT'
	grid.Refresh()
	grid2.Refresh()

EndSub

Sub 'somaSDT'

	&AgrTudPedVlrLiq = 0
	For &sdtPedidosItem in &sdtPedidos
		&AgrTudPedVlrLiq += &sdtPedidosItem.PedVlrLiq
	EndFor

EndSub


