        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	Do Case
		CASE &IdiomaDeclaracao = 1 AND &Modelo = 1 //PORTUGUES
			RCOOpenWindow1.LinkOpen = RELJAS061.Link(&EmpCod, &DecCod,&IdiomaDeclaracao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		CASE &IdiomaDeclaracao = 2 AND &Modelo = 1 //Ingles
			RCOOpenWindow1.LinkOpen = RELJAS061_EN.Link(&EmpCod, &DecCod,&IdiomaDeclaracao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		CASE &IdiomaDeclaracao = 3 AND &Modelo = 1//Espanhol
			RCOOpenWindow1.LinkOpen = RELJAS061_ES.Link(&EmpCod, &DecCod,&IdiomaDeclaracao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
			
		//muda o modelo
		CASE &IdiomaDeclaracao = 1 AND &Modelo = 2 //PORTUGUES
			RCOOpenWindow1.LinkOpen = RELJAS161.Link(&EmpCod, &DecCod,&IdiomaDeclaracao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		CASE &IdiomaDeclaracao = 2 AND &Modelo = 2 //Ingles
			RCOOpenWindow1.LinkOpen = RELJAS061_EN.Link(&EmpCod, &DecCod,&IdiomaDeclaracao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		CASE &IdiomaDeclaracao = 3 AND &Modelo = 2//Espanhol
			RCOOpenWindow1.LinkOpen = RELJAS061_ES.Link(&EmpCod, &DecCod,&IdiomaDeclaracao)
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

EndEvent


