        <Source><![CDATA[
Event Start

	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &CteDocAntChv.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Chave de acesso do CT-e'), DVMessageType.error, &CteDocAntChv.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CteDocAntCnpj.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','CNPJ/CPF'), DVMessageType.error, &CteDocAntCnpj.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CteDocAntUf.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','UF'), DVMessageType.error, &CteDocAntUf.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CteDocAntIns.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','IE'), DVMessageType.error, &CteDocAntIns.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf
	If &CteDocAntRaz.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Razão'), DVMessageType.error, &CteDocAntRaz.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &CteDocAntCnpj.IsValid

	If not &CteDocAntCnpj.Trim().IsEmpty()
		ValidaCpfCnpj.Call(&CteDocAntCnpj, &ErroCnpj, &ObrigatorioCpfCnpj)
		do 'GetPessoa'
	EndIf

EndEvent

Event &CteDocAntIns.IsValid

	prcValidaInscricaoEstadual.Call(&CteDocAntIns, &CteDocAntUf, &InsSimNao, &CteDocAntIns)

EndEvent

Event &CteDocAntChv.IsValid

	&CteDocAntChv = trim(RetornaSoNumeros.Udp(&CteDocAntChv))
	If not &CteDocAntChv.Trim().IsEmpty()
		&CteModCod = SubStr(trim(&CteDocAntChv),21,2) // TEM QUE SER MODELO 57
		
		If &CteModCod <> '57'
			
			msg('CHAVE INVÁLIDA! Só é permitido adicionar documento Modelo 57 CT-e.')
			&IsErro = true
		Else
			ValidaChaveNota.Call(&CteDocAntChv,&IsErro)
			If &CteDocAntCnpj.IsEmpty()
				&CteDocAntCnpj = Substr(&CteDocAntChv,7,14)
			EndIf
		EndIf
	EndIf

EndEvent

Event Enter

	Do 'CheckRequiredFields'
	If &CheckRequiredFieldsResult = True
		Do Case
			Case &ErroCnpj = 1
				Msg('ATENÇÃO! CPF/CNPJ Inválido!')
			Case &InsSimNao = 'N'
				msg('Inscrição Estadual Inválida!')
			Case &IsErro = true
				msg('ATENÇÃO! Não foi possível adicionar esta chave de nota pois a mesma não é válida. Verifique!')
			OtherWise
				
				GravaCteDocAnt.Call(&EmpCod,&FilCod,&CteCod,&CteDocAntCnpj,&CteDocAntIns,&CteDocAntUf,&CteDocAntRaz,&CteDocAntChv)
				msg('Nota Adicionada/atualizada')
				&CteDocAntCnpj = ''
				&CteDocAntIns = ''
				&CteDocAntRaz = ''
		EndCase	
	EndIf

EndEvent

Sub 'GetPessoa'

	For eacH Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCnpj = &CteDocAntCnpj when &CteDocAntCnpj.Length() > 14
		Where PesCpf = &CteDocAntCnpj when &CteDocAntCnpj.Length() <= 14
		&CteDocAntUf = PesCidUfeCod
		&CteDocAntIns = PesInsEst
		&CteDocAntRaz = PesRaz
		exit
	EndFor

EndSub


]]></Source>
