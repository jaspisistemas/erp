      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	RetornaAutorizacao.Call('WWPRECOCOMBINADO', Status_SimNao.Sim, 1, &AutNiv)
	
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	RetornaNomePessoa.Call(&EmpCod, &PesCod, &PesRaz)
	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchou, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	
	if &PesCod <> 0 or not &ProRef.IsEmpty()
		
		For Each Order EmpCod, PesCod, EspProCod, EspProGraCod
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod when &PesCod <> 0
			Where EspProCod = &ProCod when &ProCod <> 0
			Where EspProGraCod = &ProGraCod when &ProGraCod > 1
			
			GravaProdutoCombinado.Call(EmpCod, PesCod, EspProCod, EspProGraCod, 'DEL', &Data, &Data, 0, 0, 0, 0, 0, 0,0,0,0, &Context.PesCod)
		EndFor
		Return
	Else
		msg('Selecione um Cliente ou um Produto!')
	EndIF

EndEvent

Event &PesCod.IsValid

	RetornaNomePessoa.Call(&EmpCod, &PesCod, &PesRaz)

EndEvent

Event &ProRef.IsValid

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchou, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	RetornaNomePessoa.Call(&EmpCod, &PesCod, &PesRaz)

EndEvent


]]></Source>
