      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&wwpContext)
	PadraoUsuario.Call('G', trim(str(&PedCod)), &wwpContext.PesCod, &wwpContext.EmpCod, '', &PadDtaMod)
	
	&PedQtd.Enabled = 1
	do 'ValidaPedido'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	UnnamedTable1.Width = 800
	Grid.Rows = 50

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PedItmCod = PedItmCod
	do 'getsdt'

EndEvent

Event Refresh

	loadWWPContext.Call(&wwpContext)
	PadraoUsuario.Call('L',  trim(str(&PedCod)), &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	&sdtPedidoProduto.fromJson(&PadObs)
	
	&PedQtd.Enabled = 1

	

	&GridPageCount = grid.PageCount

EndEvent

Event &PedQtd.IsValid

	&SaldoPedQtd = (PedQtd - PedQtdFat_FORMULA)
	if &SaldoPedQtd < 0
		&SaldoPedQtd = 0
	Endif

	if &SaldoPedQtd < &PedQtd
		&PedQtd = &SaldoPedQtd
	Endif
	
	// Pega o (total a cancelar -  (sdo não carregado - total pago) = total não crédito))
	&PedQtdCre = (&PedQtd - (&SaldoPedQtd - PedItmPagQtdTot)     )
	&PedVlrItm = iif(PedItmPagQtdTot > 0, PedItmPagVlrTot / PedItmPagQtdTot,0)
	//ex: 3    =     4    - (       5     -       4        ) = 1 )
	//quantidade que terei quegerar um crédito para  o cliente
	
	&IsAchou = false
	For &sdtPedidoProdutoItem in &sdtPedidoProduto
		if PedItmCod = &sdtPedidoProdutoItem.PedItmCod
			&IsAchou = true
			&sdtPedidoProdutoItem.PedQtd = &PedQtd
			&sdtPedidoProdutoItem.PedQtdCre = &PedQtdCre
			&sdtPedidoProdutoItem.ProGraRef = ProGraRef
			&sdtPedidoProdutoItem.ProNom = ProNomGra
			&sdtPedidoProdutoItem.PedVlrItm = (&PedVlrItm * &PedQtdCre)
			Exit
		Endif
	EndFor

	if &IsAchou = false
		&sdtPedidoProdutoItem = new()
		&sdtPedidoProdutoItem.PedQtd = &PedQtd
		&sdtPedidoProdutoItem.PeditmCod = PedItmCod
		&sdtPedidoProdutoItem.PedQtdCre = &PedQtdCre
		&sdtPedidoProdutoItem.ProGraRef = ProGraRef
		&sdtPedidoProdutoItem.ProNom = ProNomGra
		&sdtPedidoProdutoItem.PedVlrItm = (&PedVlrItm * &PedQtdCre)
		&sdtPedidoProduto.Add(&sdtPedidoProdutoItem)
	Endif
	
	PadraoUsuario.Call('G', trim(str(&PedCod)), &wwpContext.PesCod, &wwpContext.EmpCod, &sdtPedidoProduto.ToJson(), &PadDtaMod)

EndEvent

Event Enter

	&IsCredito = false
	For Each line in grid
		&SaldoPedQtd = (PedQtd - PedQtdFat_FORMULA)
		if &SaldoPedQtd < 0
			&SaldoPedQtd = 0
		Endif
		
		if &SaldoPedQtd < &PedQtd
			&PedQtd = &SaldoPedQtd
		Endif
		
		// Pega o (total a cancelar -  (sdo não carregado - total pago) = total não crédito))
		&PedQtdCre = (&PedQtd - (&SaldoPedQtd - PedItmPagQtdTot)     )
		//ex: 3    =     4    - (       5     -       4        ) = 1 )
		//quantidade que terei que gerar um crédito para  o cliente
		
		&IsAchou = false
		For &sdtPedidoProdutoItem in &sdtPedidoProduto
			if PedItmCod = &sdtPedidoProdutoItem.PedItmCod
				&IsAchou = true
				&sdtPedidoProdutoItem.PedQtd = &PedQtd
				If &PedQtdCre > 0
					&sdtPedidoProdutoItem.PedQtdCre = &PedQtdCre
					&IsCredito = true
				EndIf
				
				Exit
			Endif
		EndFor
		
		if &IsAchou = false
			&sdtPedidoProdutoItem = new()
			&sdtPedidoProdutoItem.PedQtd = &PedQtd
			If &PedQtdCre > 0
				&sdtPedidoProdutoItem.PedQtdCre = &PedQtdCre
				&IsCredito = true
			EndIf
			&sdtPedidoProdutoItem.PeditmCod = PedItmCod
			&sdtPedidoProduto.Add(&sdtPedidoProdutoItem)
		Endif
	Endfor

	PadraoUsuario.Call('G', trim(str(&PedCod)), &wwpContext.PesCod, &wwpContext.EmpCod, &sdtPedidoProduto.ToJson(), &PadDtaMod)
	
	If &IsCredito = true  //sim ao menos um item tem crédito
		wpCreditoAgro.call(&EmpCod, &FiLCod, &PedCod)//passa o padrao usuario pq o sdt colection não deu pra passar.
		return
	Else
		AtualizaQuantidadesPedido.Call(&EmpCod, &FiLCod, &PedCod, &sdtPedidoProduto, &wwpContext.UserName)
		Return
	EndIf

EndEvent

Sub 'GetSdt'

	For &sdtPedidoProdutoItem in &sdtPedidoProduto
		if &sdtPedidoProdutoItem.PeditmCod = &PedItmCod
			&PedQtd = &sdtPedidoProdutoItem.PedQtd
			Exit
		EndIf
	EndFor

EndSub

Sub 'ValidaPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where PedCod = &PedCod
		
		if PedSts <> Status_Pedido.ABERTO //or PedStsFin <> status_Financeiro.ABERTO
			return
		Endif
		
		Exit
	EndFor

EndSub


]]></Source>
