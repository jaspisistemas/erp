      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedItmCod = &PedItmCod
		
		RetiraZerosDepoisVirgulaxCasas(0, trim(toformattedString(PedItmIcm)),&PedItmIcm)
		&PedItmIcm += '%'
		RetiraZerosDepoisVirgulaxCasas(0, trim(toformattedString(PedItmIcmSt)),&PedItmIcmSt)
		&PedItmIcmSt += '%'
		RetiraZerosDepoisVirgulaxCasas(0, trim(toformattedString(PedItmIcmStPob)),&PedItmIcmStPob)
		&PedItmIcmStPob += '%'
		RetiraZerosDepoisVirgulaxCasas(0, trim(toformattedString(PedItmIpi)),&PedItmIpi)
		&PedItmIpi += '%'
		RetiraZerosDepoisVirgulaxCasas(0, trim(toformattedString(PedItmAcr)),&PedItmAcr)
		&PedItmAcr += '%'
		RetiraZerosDepoisVirgulaxCasas(0, trim(toformattedString(PedItmDsc)),&PedItmDsc)
		&PedItmDsc += '%'
		
		&ProDedIcms = ProDedIcms		
		&ProDedIpi = ProDedIpi
		
		RetornaFilialBaseImposto.Call(EmpCod, PedFatFilCod, &FilBasIMp)
		RetornaRegimeTributarioFilial.Call(EmpCod, &FilBasIMp, &FilRegTrib, &FilCidUfeCod)
		tbDeduzir.Visible = (&FilRegTrib <> RegimeTributario.simplesNacional)
		
		If ProSolLot = SolicitarLote.SIM_CONTROLAR
			&PedItmCmpLot = PedItmCmpLot	
		Else
			&PedItmCmpLot = ''
		EndIf
		Exit
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
