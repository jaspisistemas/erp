      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&EmpCod.Visible = False
	&DestinoPesCod.Visible = False

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Do 'GetDestino'

EndEvent

Event 'DoExcluirFavoritos'

	ExcluirFavoritosUsuario.Call(&EmpCod,&DestinoPesCod)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//Code block: LoadWWPContext
	LoadWWPContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &OrigemPesCod.ControlValueChanged

	Do 'GetOrigem' //P/ retorno do PopUp

EndEvent

Event &OrigemPesCod.IsValid

	Do 'GetOrigem'

EndEvent

Event Enter

	Do case
		case &OrigemPesCod.IsEmpty()
			msg('Você deve selecionar um usuário para Origem dos Favoritos!')
		case &DestinoPesCod.IsEmpty()
			msg('Você não selecionou um usuário válido para destino dos Favoritos')
		case &DestinoPesCod = &OrigemPesCod
			msg('Pô Suporte ! Não da pra copiar do mesmo usuário para o mesmo usuário!')
		otherwise
			CopiaFavoritosUsuario.Call(&EmpCod,&OrigemPesCod,&DestinoPesCod)
			msg('Favoritos copiados com sucesso! Para visualizar corretamente é necessário reiniciar o login.')
	EndCase

EndEvent

Sub 'GetOrigem'

	if not &OrigemPesCod.IsEmpty()
		For each order EmpCod,PesCod,PesSts
			where EmpCod = &EmpCod
			where PesCod = &OrigemPesCod
			where PesSts = Status_AtivoInativo.ATIVO
			where PesIsFun = true or PesIsVen = true
			&OrigemPesRaz = PesRaz
			exit
		when none
			msg('Usuário inválido, ou não está ativo!')
			&OrigemPesCod.SetEmpty()
			&OrigemPesRaz.SetEmpty()
		EndFor
	else
		&OrigemPesRaz.SetEmpty()
	EndIf

EndSub

Sub 'GetDestino'

	For each order EmpCod,PesCod,PesSts
		where EmpCod = &EmpCod
		where PesCod = &DestinoPesCod
		where PesSts = Status_AtivoInativo.ATIVO
		where PesIsFun = true or PesIsVen = true
		&DestinoPesCodRaz = PesCodRaz
		exit
	when none
		msg('Erro! Não localizado Usuário solicitado.')
		return
	EndFor

EndSub


]]></Source>
