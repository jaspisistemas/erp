			Pdvm_venda.Link(PedCod)
//		Else
//			msg('ATENÇÃO! Limite de crédito atingido. Dirija-se ao caixa para fazer acerto.')
//		EndIf
//	Else
//		Pdvm_venda.Link(PedCod)
//	EndIf
