      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	txtMensagemSalvarProduto.Caption = ''
	loadWWPContext.Call(&wwpContext)
	RetornaTabelaColunaFilial.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &FilTabCod, &FilTabColCod)
	&PedDtaEms = serverdate()
	do 'GetContrato'
	do 'GetPedidoNota'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid2.Rows = 0
	Grid1.Rows = Page.Rows
	&Grid1CurrentPage = 1
	&Grid1CurrentPage.Visible = False
	&Grid1PageCount = -1
	Grid1PaginationBar.RowsPerPageSelectedValue = Grid1.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	&Grid1PageCount = Grid1.PageCount
	&Grid1CurrentPage = Grid1.CurrentPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&Grid1PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid2.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DoImprimir = !'<i class="far fa-file-pdf"></i>'

	&CreDupNroWithTags = CreDupNro
	If CreFrpPgtoTip = TipoDuplicata.DINHEIRO
		&CreDupNroWithTags = !"<span class='fas fa-money-bill-alt TagBeforeText'></span>" + &CreDupNroWithTags
	EndIf
	If CreFrpPgtoTip = TipoDuplicata.DUPLICATA
		&CreDupNroWithTags = !"<span class='fas fa-barcode TagBeforeText'></span>" + &CreDupNroWithTags
	EndIf
	If CreFrpPgtoTip = TipoDuplicata.CHEQUET or CreFrpPgtoTip = TipoDuplicata.CHEQUEP
		&CreDupNroWithTags = !"<span class='fas fa-money-check TagBeforeText'></span>" + &CreDupNroWithTags
	EndIf
	If CreFrpPgtoTip = TipoDuplicata.CARTAOC or CreFrpPgtoTip = TipoDuplicata.CARTAOD
		&CreDupNroWithTags = !"<span class='fas fa-credit-card TagBeforeText'></span>" + &CreDupNroWithTags
	EndIf
	If CreFrpPgtoTip = TipoDuplicata.PIX
		&CreDupNroWithTags = !"<span class='fas fa-qrcode TagBeforeText'></span>" + &CreDupNroWithTags
	EndIf
	If CreFrpPgtoTip = TipoDuplicata.DEPOSITO
		&CreDupNroWithTags = !"<span class='fas fa-exchange-alt TagBeforeText'></span>" + &CreDupNroWithTags
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserUpdate = !'<i class="fas fa-pen"></i>'
	
	&UserAction1 = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case Grid1PaginationBar.SelectedPage = !'Previous'
			&Grid1CurrentPage -= 1
			Grid1.PreviousPage()
		Case Grid1PaginationBar.SelectedPage = !'Next'
			&Grid1CurrentPage += 1
			Grid1.NextPage()
		Otherwise
			&PageToGo.FromString(Grid1PaginationBar.SelectedPage)
			&Grid1CurrentPage = &PageToGo
			Grid1.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Grid1PaginationBar.RowsPerPageSelectedValue
	&Grid1CurrentPage = 1
	Grid1.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'GetProduto'
	
	Do Case
		CAse &IsAchouProduto = false
			txtMensagemSalvarProduto.Caption = 'Produto não localizado ou não informado'
			txtMensagemSalvarProduto.ForeColor = RGB(255,0,0)
			&ProRef.SetFocus()
		CAse &PedQtd <= 0
			txtMensagemSalvarProduto.Caption = 'Quantidade não informada'
			txtMensagemSalvarProduto.ForeColor = RGB(255,0,0)
			&PedQtd.SetFocus()
		Case &PedVlrUnt.IsEmpty()
			txtMensagemSalvarProduto.Caption = 'Valor unitário não informado'
			txtMensagemSalvarProduto.ForeColor = RGB(255,0,0)
			&PedVlrUnt.SetFocus()
		Otherwise
			if &SerItmProId = 0
				txtMensagemSalvarProduto.Caption = 'Produto adicionado com sucesso!'
				txtMensagemSalvarProduto.ForeColor = RGB(0,102,51)
			Else
				txtMensagemSalvarProduto.Caption = 'Produto alterado com sucesso!'
				txtMensagemSalvarProduto.ForeColor = RGB(0,100,200)
			Endif		
			
			prcGravaItemContrato.call(&EmpCod, &SerItmCod, &SerItmProId, &SerItmProCod, &SerItmProGraCod, &PedQtd, &PedVlrUnt)
			
			&PedQtd.SetEmpty()
			&PedVlrUnt.SetEmpty()
			&ProRef.SetEmpty()
			&SerItmProId = 0
			&ProRef.Enabled = 1
			
			&ProRef.SetFocus()
			
			do 'GetTotalContrato'			
			
			grid1.Refresh()
	EndCAse

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserCancelar'

	&SerItmProId = 0
	&PedQtd.SetEmpty()
	&PedVlrUnt.SetEmpty()
	&ProRef.SetEmpty()
	
	&ProRef.Enabled = 1
	&ProRef.SetFocus()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &ProRef.IsValid

	do 'GetProduto'
	
	if &PedVlrUnt.IsEmpty()
		&PedVlrUnt = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &FilTabCod, '', &SerItmProCod, &SerItmProGraCod, &FilTabColCod, &PedDtaEms, &PedDtaEms)
	Endif

EndEvent

Event &UserAction1.Click

	prcDeletaProduto.Call(EmpCod, SerItmCod, SerItmProId)
	Grid1.Refresh()
	do 'GetTotalContrato'
	
	&ProRef.Enabled = 1
	&ProRef.SetEmpty()
	&PedQtd.SetEmpty()
	&PedVlrUnt.SetEmpty()
	
	&ProRef.SetFocus()

EndEvent

Event &UserUpdate.Click

	&SerItmProId = SerItmProId
	&SerItmProCod = SerItmProCod
	&SerItmProGraCod = SerItmProGraCod
	
	&PedQtd = SerItmProQtd
	&PedVlrUnt = SerItmProVlrUnt
	
	do 'GetProdutoEdit'
	
	&ProRef.Enabled = 0
	&PedQtd.SetFocus()

EndEvent

Sub 'GetContrato'

	For Each ORder EmpCod, SerItmCod
		Where EmpCod = &EmpCod
		Where SerItmCod = &SerItmCod
		
		&FIlCod = SerFilCod
		&SerItmDiaVct = SerItmDiaVct
		&SerItmCbrCod = SerItmCbrCod
		&PedDtaEms = SerItmDtaInicio
		&SerItmVlr = SerItmVlr
		Exit
	EndFor

EndSub

Sub 'GetPedidoNota'

	//GET PEDIDO
	For Each ORder EmpCod, FilCod, (PedCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FIlCod
		Where PedSerItmCod = &SerItmCod
		Where PedSts <> Status_Pedido.CANCELADO
		
		&PedCod = PedCod
		&PedVlrLiq = PedVlrLiq
		Exit
	EndFor

	//GET NOTA
	if &PedCod > 0
		For Each order EmpCod, NfeFilCod, NfePedCod, (NfeCod)
			Where EmpCod = &EmpCod
			Where NfeFilCod = &FIlCod
			Where NfePedCod = &PedCod
			Where NfeSts = Status_NFe.Autorizada or NfeSts = Status_NFe.Digitando
			Where NfeNum > 0
			&NfeNum = NfeNum
			&NfeVlrTot = NfeVlrTot
			Exit
		EndFor
	
		For Each order EmpCod, NfsFilCod, NfsPedCod, (NfsCod)
			Where EmpCod = &EmpCod
			Where NfsFilCod = &FIlCod
			Where NfsPedCod = &PedCod
			Where NfsSts = Status_NFe.Autorizada or NfsSts = Status_NFe.Digitando
			Where NfsNum > 0
			&NfsNum = NfsNum
			&NfsVlrTot = NfsVlrTot
			Exit
		EndFor
	EndIf

EndSub

Sub 'GetProdutoEdit'

	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &SerItmProCod
		Where ProGraCod = &SerItmProGraCod
		&ProRef = ProGraRef
		&ProNom = ProNomGra
		Exit
	EndFor

EndSub

Sub 'GetProduto'

	RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &SerItmProCod, &SerItmProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)

EndSub

Sub 'GetTotalContrato'

	For Each ORder EmpCod, SerItmCod
		Where EmpCod = &EmpCod
		Where SerItmCod = &SerItmCod
		
		&PedDtaEms = SerItmDtaInicio
		&SerItmVlr = SerItmVlr
		Exit
	EndFor

EndSub


