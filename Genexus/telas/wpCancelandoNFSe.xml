      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&SolCod = &parSolCod
	btnImprimir.Visible = 0
	com.ForeColor  = RGB(0,160,40)
	&ProgressLogXml = ''
	txtMsg.Caption = ''
	txtMsg.ForeColor = RGB(210,130,0)
	
	loadWWPContext.Call(&WwpContext)

	//parm(in:&EmpCod, , in:&Nfscod, in:&SolCod);

	

	&Random = Random() * 1000000000
	&ProgressId = 'CnsNFeS' + trim(Str(&EmpCod)) + trim(Str(&WwpContext.PesCod)) + trim(str(&Random))
	&ProgressId = &ProgressId.trim()
	
	If &HttpRequest.Method = HttpMethod.Get
		scaProgressBar1.ProcessId = &ProgressId
		scaProgressBar1.UpdateProgressURL = retornaProgresso.Link(&ProgressId)
		scaProgressBar1.Start()
		
		RecepcaoNFSe.Submit(&ProgressId, &ProgressId, &EmpCod, &Nfscod, &SolCod)
	EndiF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoMonitoraNFSe'

	wwNotasServico.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoImprimir'

	GeraPdfDanfeNFSe.Call(&EmpCod, &NfsCod, &UrlPDF, &UrlFisico)
	RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event scaProgressBar1.OnComplete

	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		&ProgressLogXml = ProgressLogXml
		txtMsg.Caption = &ProgressLogXml
		do 'imprimenota'
		
		Exit
	EndFor
	
	apagaProgress.Submit('', &ProgressId)

EndEvent

Sub 'imprimenota'

	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NfsCod
						
		If not NfsArqXml.IsEmpty() and (NfsSts = Status_NFe.Autorizada or NfsSts = Status_NFe.Cancelada)
			btnImprimir.Visible = 1
		EndIF
		
		Exit
	EndFor

EndSub


]]></Source>
