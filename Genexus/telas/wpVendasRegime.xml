      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&HojeData = serverdate()
	&finPedDtaFat = &HojeData
	&iniPedDtaFat = &HojeData.AddMonths(-12)
	
	&LctAtuSal = status_EntradaSaida.Saida
	&PedSts = Status_Pedido.FECHADO
	&LctGerFin = Status_SimNao.Sim
	
	loadWWPContext.Call(&wwpContext)
	&EmpCod = &wwpContext.EmpCod
	&FilCod = &wwpContext.FilCod
	
	padraoUsuario.Call('L', '#COMBORAMOWPVENDASREGIME#', &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	&RatCod.FromJson(&PadObs)
	if &RatCod.Count = 0
		For Each Order EmpCod, RatCod
			Where EmpCod = &EmpCod
			&RatCod.Add(RatCod)
		EndFor
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&DDO_TitleSettingsIcons = GetWWPTitleSettingsIcons()
	Do 'LoadComboRatCod'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'Operacao'
	
	
	do Case
		Case &IsOperacao = true
			&LctCod.SetFocus()
			
		Otherwise
			padraoUsuario.Call('G', '#COMBORAMOWPVENDASREGIME#', &wwpContext.PesCod, &wwpContext.EmpCod, &RatCod.ToJson(), &PadDtaMod)
			RCOOpenWindow1.LinkOpen = RELJAS146.Link(&EmpCod, &FilCod, &iniPedDtaFat, &finPedDtaFat, &LctAtuSal,&PedSts,&PedNovStsCod,&LctGerFin, &LctCod, &ListarClientes) 
			RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
	EndCase

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	Dashboard.Link()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Combo_RatCod.OnOptionClicked

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&RatCod.FromJson(Combo_RatCod.SelectedValue_get)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'LoadComboRatCod'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//&RatCod initial value has to be loaded manually at the beginning of this Subrutine
	For Each
		Where EmpCod = &EmpCod
		&Combo_DataItem = new()
		&Combo_DataItem.ID = RatCod.ToString().Trim()
		&Combo_DataItem.Title = RatCodNom
		&RatCod_Data.Add(&Combo_DataItem)
	EndFor
	Combo_RatCod.SelectedValue_set = &RatCod.ToJson()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event &LctCod.IsValid

	do 'Operacao'

EndEvent

Sub 'Operacao'

	&IsOperacao = false
	&LctNom = 'TODAS AS OPERAÇÕES'
	If &LctCod <> 0
		For Each Order EmpCod, LctCod
			Where EmpCod = &EmpCod
			Where LctCod = &LctCod
			&LctNom = LctNom
			Exit
		When None
			&LctNom = 'TODAS AS OPERAÇÕES'
			msg(&LctNom)
			&IsOperacao = true
		EndFor
	EndIF

EndSub


]]></Source>
