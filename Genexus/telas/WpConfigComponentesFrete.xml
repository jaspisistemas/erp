        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&Context)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridComponentesFrete.Rows = Page.Rows
	&GridComponentesFreteCurrentPage = 1
	&GridComponentesFreteCurrentPage.Visible = False
	&GridComponentesFretePageCount = -1
	GridComponentesFretePaginationBar.RowsPerPageSelectedValue = GridComponentesFrete.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&EmpCod = &parmEmpCod
	&FilCod = &parmFilCod
	
	//Busca as configurações do TCon168
	RetornaConfSistema.Call(&parmEmpCod, &parmFilCod, domConfSistema.TCon168_ComponentesFrete, &ComponentesFrete)
	&SdtComponentesFrete.FromJson(&ComponentesFrete)

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridComponentesFretePageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridComponentesFrete.Load

	//Carrega as configurações
	For &SdtComponentesFreteItem In &SdtComponentesFrete

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&DeleteRows = !'<i class="fas fa-times"></i>'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

		&gridEmpCod			= &SdtComponentesFreteItem.EmpCod	//Empresa
		&gridCtePreCod 		= &SdtComponentesFreteItem.CtePreCod	//Código do Componente
		&gridCteNomPreCom	= &SdtComponentesFreteItem.CteNomPreCom	//Nome do Componente
		&gridCteDesIcmsCom	= &SdtComponentesFreteItem.CteDesIcmsCom	//Destacar ICMS?
		&gridCtePrePagCom	= &SdtComponentesFreteItem.CtePrePagCom	//Pagar Comissão?
		
		Load		
	EndFor

EndEvent

Event GridComponentesFretePaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridComponentesFretePaginationBar.SelectedPage = !'Previous'
			&GridComponentesFreteCurrentPage -= 1
			GridComponentesFrete.PreviousPage()
		Case GridComponentesFretePaginationBar.SelectedPage = !'Next'
			&GridComponentesFreteCurrentPage += 1
			GridComponentesFrete.NextPage()
		Otherwise
			&PageToGo.FromString(GridComponentesFretePaginationBar.SelectedPage)
			&GridComponentesFreteCurrentPage = &PageToGo
			GridComponentesFrete.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event GridComponentesFretePaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridComponentesFrete.Rows = GridComponentesFretePaginationBar.RowsPerPageSelectedValue
	&GridComponentesFreteCurrentPage = 1
	GridComponentesFrete.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	&AuxCtePreCod	= 0
	&SdtComponentesFrete2.Clear()
	//Adiciona os Itens do Grid na Sdt
	//Linhas se NENHUMA informação serão ignoradas
	For each line in GridComponentesFrete
		
		If Not &gridCteNomPreCom.IsEmpty() Or &gridCteDesIcmsCom = True Or &gridCtePrePagCom = True
			
			If &gridCteNomPreCom.IsEmpty()
				&gridCteNomPreCom = 'RETORNO VAZIO'
			EndIf
			
			&AuxCtePreCod 							+= 1
			&SdtComponentesFreteItem2 				= New()
			&SdtComponentesFreteItem2.EmpCod 		= &gridEmpCod	//Empresa
			&SdtComponentesFreteItem2.CtePreCod 	= &AuxCtePreCod	//Código do Componente
			&SdtComponentesFreteItem2.CteNomPreCom	= Upper(&gridCteNomPreCom)	//Nome do Componente
			&SdtComponentesFreteItem2.CteDesIcmsCom	= &gridCteDesIcmsCom	//Destacar ICMS?
			&SdtComponentesFreteItem2.CtePrePagCom	= &gridCtePrePagCom	//Pagar Comissão?
			&SdtComponentesFrete2.Add(&SdtComponentesFreteItem2)
		EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	Endfor
	
	//Se houver itens atualiza a configuração
	If &SdtComponentesFrete2.Count > 0
		&ComponentesFrete = &SdtComponentesFrete2.ToJson()
		prcGravaTCon168.Call(&EmpCod, &TConCod, &ComponentesFrete, &Context.UserName)
		Return
	Else
		Msg('É necessário preecher algum campo.')
	EndIf

EndEvent

Event 'DoAddRows'

	//Adiciona uma nova linha
	&gridEmpCod			= &parmEmpCod
	GridComponentesFrete.Load()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &DeleteRows.Click

	//Apaga a linha
	&gridCtePreCod.SetEmpty()		
	&gridCteNomPreCom.SetEmpty()	
	&gridCteDesIcmsCom = False	
	&gridCtePrePagCom  = False

EndEvent


]]></Source>
