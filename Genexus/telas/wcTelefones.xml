        <Source><![CDATA[
Event Start

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Telefone_Empowerer.GridInternalName = Telefone.InternalName
	Telefone.Rows = 5
	&TelefoneCurrentPage = 1
	&TelefoneCurrentPage.Visible = False
	&TelefonePageCount = -1
	TelefonePaginationBar.RowsPerPageSelectedValue = Telefone.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&TelefonePageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&TelefoneCurrentPage = Telefone.CurrentPage
	&TelefoneRecordCount = Telefone.RecordCount
	&TelefonePageCount = tELEFONE.PageCount

EndEvent

Event Telefone.Load

	&ContatoDepartamentovar = PesFonConTip.EnumerationDescription()+ ' - ' + PesFonCon.Trim()

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event TelefonePaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case TelefonePaginationBar.SelectedPage = !'Previous'
			&TelefoneCurrentPage -= 1
			Telefone.PreviousPage()
		Case TelefonePaginationBar.SelectedPage = !'Next'
			&TelefoneCurrentPage += 1
			Telefone.NextPage()
		Otherwise
			&PageToGo.FromString(TelefonePaginationBar.SelectedPage)
			&TelefoneCurrentPage = &PageToGo
			Telefone.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event TelefonePaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Telefone.Rows = TelefonePaginationBar.RowsPerPageSelectedValue
	&TelefoneCurrentPage = 1
	Telefone.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent


]]></Source>
