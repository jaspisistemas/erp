        <Source><![CDATA[
Event Start

	loadwwpContext.call(&wwpContext)

	do 'loadMarketplace'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	do 'getTransportadora'
	if &IsErrotranspor = false
		prcGravaPedidoVendaMarketplace.Call(&EmpCod, &MrkCod, &MrkPedSku, &wwpContext, &MrkPadTraCod)
		wwpActions.WCPopup_Close('S')
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoUserAction1'

	wwpActions.WCPopup_Close('N')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &MrkPadTraCod.IsValid

	do 'getTransportadora'

EndEvent

Sub 'loadMarketplace'

	For Each ORder EmpCod, MrkCod
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		
		&MrkPadTraCod = MrkPadTraCod
		
		Exit
	EndFor

	if not &MrkPadTraCod.IsEmpty()
		do 'getTransportadora'
	EndIf

EndSub

Sub 'getTransportadora'

	&IsErrotranspor = false
	For Each ORder EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &MrkPadTraCod
		
		&MrkPadTraRaz = PesRaz
		Do CAse
			CAse PesIsTra = false or PesSts = status_AtivoInativo.INATIVO
				&IsErrotranspor = true
				msg('Pessoa informado não é uma Transportadora ou esta inativada!')
		EndCase
		
		
		Exit
	When None
		&IsErrotranspor = true
		msg('Transportadora não informada!')
	EndFor

EndSub


