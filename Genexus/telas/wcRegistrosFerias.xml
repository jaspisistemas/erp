      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&HojeData = serverdate()
	retornaAutorizacao.Call('WWCONTROLEFERIAS', Status_SimNao.Nao, 1, &AutNivWWCONTROLEFERIAS)
	tbControleferias.Visible = &AutNivWWCONTROLEFERIAS > 1

	retornaAutorizacao.Call('WWPAGAMENTORESCISAO', Status_SimNao.Nao, 1, &AutNivWWPAGAMENTORESCISAO)
	tbPagamentoFerias.Visible = &AutNivWWPAGAMENTORESCISAO > 1

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid2.Rows = 0
	Grid.Rows = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	FPagTip.ColumnHeaderClass = !'WWColumn'
	FPagSts.ColumnHeaderClass = !'WWColumn'
	
	FerItemTip.ColumnHeaderClass = !'WWColumn'
	FerItemIni.ColumnHeaderClass = !'WWColumn'
	FerItemFin.ColumnHeaderClass = !'WWColumn'
	FerItemDias.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridPageCount = grid.PageCount
	&GridCurrentPage = grid.CurrentPage

EndEvent

Event Grid2.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	Do Case
		Case FPagTip = TipoPagamentoFolha.Rescisao
			FPagTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case FPagTip = TipoPagamentoFolha.Ferias
			FPagTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Otherwise
			FPagTip.ColumnClass = 'WWColumn'
	EndCase
	Do Case
		Case FPagSts = Status_Folha.Aberto
			FPagSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case FPagSts = Status_Folha.Pago
			FPagSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell'
		Case FPagSts = Status_Folha.PagoParcial
			FPagSts.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			FPagSts.ColumnClass = 'WWColumn'
	EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&UserAction1 = !'<i class="fas fa-times"></i>'

	Do Case
		Case FerItemTip.ToString().Trim() = !"P"
			FerItemTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagSuccess WWColumnTagSuccessSingleCell'
		Case FerItemTip.ToString().Trim() = !"G"
			FerItemTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell'
		Case FerItemTip.ToString().Trim() = !"A"
			FerItemTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Case FerItemTip.ToString().Trim() = !"F"
			FerItemTip.ColumnClass = !'WWColumn WWColumnTag WWColumnTagWarning WWColumnTagWarningSingleCell'
		Otherwise
			FerItemTip.ColumnClass = 'WWColumn'
	EndCase
	FerItemIni.ColumnClass = iif(FerItemIni > &HojeData, !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell', !'WWColumn')
	FerItemFin.ColumnClass = iif(FerItemIni > &HojeData, !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell', !'WWColumn')
	FerItemDias.ColumnClass = iif(FerItemIni > &HojeData, !'WWColumn WWColumnTag WWColumnTagInfo WWColumnTagInfoSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &UserAction1.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	DVelop_ConfirmPanel_UserAction1.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event DVelop_ConfirmPanel_UserAction1.Close

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If DVelop_ConfirmPanel_UserAction1.Result = !'Yes'
		Do 'Do UserAction1'
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Sub 'Do UserAction1'

	if &AutNivWWCONTROLEFERIAS > 2
		prcRemoveRegistroFerias.Call(EmpCod, PesCod, PesRecCod, FerAnoBas, FerItemCod)
		Refresh
	Else
		&Mensagem = 'Não autorizado a rotina [WWCONTROLEFERIAS] Requerido nível 3'
		msg(&Mensagem)
	EndIf

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub


]]></Source>
