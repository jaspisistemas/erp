        <Source><![CDATA[
Event Start

	&imagemMarketplace.FromImage(mercadoLivre)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Cell_Grid1_DWC.Class = !'Invisible WCD_' + upper(Grid1.InternalName)
	Grid1.Rows = Page.Rows
	&Grid1CurrentPage = 1
	&Grid1CurrentPage.Visible = False
	&Grid1PageCount = -1
	&acoesConfiguData = new()
	
	&acoesConfiguDataItem = new()
	&acoesConfiguDataItem.Title = 'Configurações Padrões'
	&acoesConfiguDataItem.EventKey = !'Configuracoes'
	&acoesConfiguDataItem.IsDivider = False
	&acoesConfiguData.Add(&acoesConfiguDataItem)
	
	&acoesConfiguDataItem = new()
	&acoesConfiguDataItem.Title = 'Importar - Anúncios do Marketplace'
	&acoesConfiguDataItem.EventKey = !'ImportarProdutosMarketplace'
	&acoesConfiguDataItem.IsDivider = False
	&acoesConfiguData.Add(&acoesConfiguDataItem)
	
	Grid1PaginationBar.RowsPerPageSelectedValue = Grid1.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&Grid1PageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&Grid1CurrentPage = grid1.CurrentPage
	&Grid1PageCount = Grid1.PageCount

EndEvent

Event Grid1.Load

	if MrkItmLink.IsEmpty() or MrkItmLink.IsNull()
		prcGravaProdutosImportadosCompleto.Call(EmpCod, MrkCod, MrkItmCod, MrkItmLogVarchar)
	EndIf

	&ImagemProduto.FromURL(MrkUrlImgPri)
	&userVisualizar.Link = MrkItmLink
	&userVisualizar.LinkTarget = '_blank'
	
	

//	txtCodigoLoja.Caption = 'Código Loja: ' + trim(MrkItmSku)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid
	&userVisualizar = !'<i class="fas fa-search"></i>'
	
	&DetailWebComponent = !'<i class="fas fa-angle-right ArrowIcon fas fa-chevron-right"></i>'
	
	&Acoes.Clear()
	&Acoes.AddItem(0, 'WWP_ActionGroupCaption')
	If (MrkProCod.IsEmpty() or MrkProCod.IsNull())
		&Acoes.AddItem(1, 'Relacionar')
	Endif
	&Acoes.AddItem(2, 'Editar')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case Grid1PaginationBar.SelectedPage = !'Previous'
			&Grid1CurrentPage -= 1
			Grid1.PreviousPage()
		Case Grid1PaginationBar.SelectedPage = !'Next'
			&Grid1CurrentPage += 1
			Grid1.NextPage()
		Otherwise
			&PageToGo.FromString(Grid1PaginationBar.SelectedPage)
			&Grid1CurrentPage = &PageToGo
			Grid1.GotoPage(&PageToGo)
	EndCase
	Refresh

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Grid1PaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Grid1.Rows = Grid1PaginationBar.RowsPerPageSelectedValue
	&Grid1CurrentPage = 1
	Grid1.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &Acoes.Click

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case &Acoes = 1
			Do 'Do userRelacionar'
		Case &Acoes = 2
			Do 'Do userEditar'
	EndCase
	&Acoes = 0

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

