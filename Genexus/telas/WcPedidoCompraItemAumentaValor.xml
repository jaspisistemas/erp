      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadwwpContext.Call(&WwpContext)

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItensPedido.Rows = Page.Rows
	&GridItensPedidoCurrentPage = 1
	&GridItensPedidoCurrentPage.Visible = False
	&GridItensPedidoPageCount = -1
	GridItensPedidoPaginationBar.RowsPerPageSelectedValue = GridItensPedido.Rows

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Refresh

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//The variable '&GridItensPedidoPageCount' must be assigned manually in order to get a correct behaviour of the Pagination Bar.
	ProGraRef.ColumnHeaderClass = !'WWColumn'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&GridItensPedidoCurrentPage = GridItensPedido.CurrentPage
	&GridItensPedidoPageCount 	= GridItensPedido.PageCount

EndEvent

Event GridItensPedido.Load

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	//this code should be inside the For Each used to load the grid

	&PedVlrUntVarchar = trim(toformattedString(PedVlrUnt)) 
RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntVarchar, &PedVlrUntVarchar)
	&PedVlrUntDscVarchar = trim(toformattedString(PedVlrUntDsc)) 
RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntDscVarchar, &PedVlrUntDscVarchar)
	ProGraRef.ColumnClass = iif(ProSts = Status_Produto.Inativo, !'WWColumn WWColumnTag WWColumnTagDanger WWColumnTagDangerSingleCell', !'WWColumn')

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	&PedVlrItm 		= PedVlrItm
	
	&AuxPedQtdEmb 	= PedQtdEmb
	&AuxPedQtd 		= PedQtd
	&PedProEmbQtd 	= PedProEmbQtd
	Do Case
		Case PedProEmbQtd <> 1 and PedProEmbQtd > 0
			&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			
			&PedQtd = &Varchar
			
			&Varchar = trim(toformattedString(&PedProEmbQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' X ' + trim(&Varchar) 
			
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' (' + trim(&Varchar) + ')'
			
		Case PedProEmbQtd < 0
			&PedProEmbQtd = &PedProEmbQtd *-1
			&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd = trim(&Varchar)
			
			&Varchar = trim(toformattedString(&PedProEmbQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' / ' + trim(&Varchar) 
			
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd += ' (' + trim(&Varchar) + ')'
			
		Otherwise
			&Varchar = trim(toformattedString(&AuxPedQtd)) 
			RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
			&PedQtd = trim(&Varchar)
	EndCase

EndEvent

Event GridItensPedidoPaginationBar.ChangePage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do Case
		Case GridItensPedidoPaginationBar.SelectedPage = !'Previous'
			&GridItensPedidoCurrentPage -= 1
			GridItensPedido.PreviousPage()
		Case GridItensPedidoPaginationBar.SelectedPage = !'Next'
			&GridItensPedidoCurrentPage += 1
			GridItensPedido.NextPage()
		Otherwise
			&PageToGo.FromString(GridItensPedidoPaginationBar.SelectedPage)
			&GridItensPedidoCurrentPage = &PageToGo
			GridItensPedido.GotoPage(&PageToGo)
	EndCase
	Refresh

