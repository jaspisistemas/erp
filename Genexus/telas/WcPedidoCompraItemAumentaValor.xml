EndEvent

Event GridItensPedidoPaginationBar.ChangeRowsPerPage

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	GridItensPedido.Rows = GridItensPedidoPaginationBar.RowsPerPageSelectedValue
	&GridItensPedidoCurrentPage = 1
	GridItensPedido.FirstPage()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoCancelar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event &QtdEmX.ControlValueChanged

	Do 'AtualizaValores'

EndEvent

Event &CustoEmX.ControlValueChanged

	Do 'AtualizaValores'

EndEvent

Event Enter

	&ItensAlterados = 0
	For Each Line In GridItensPedido
		prcAtualizaValorQuantidadeItemCompra.Call(&parmEmpCod, &parmFilCod, &parmPedCod, PedItmCod, &AuxPedQtd, &AuxPedVlrItm, &PedVlrItm, &AuxPedVlrUnt, &WwpContext.UserName, &IsComplete)
		If &IsComplete = True
			&ItensAlterados += 1
		EndIf
	EndFor

	If &ItensAlterados >= 1
		Msg('Foram alterados o total de ' + Trim(Str(&ItensAlterados)) + ' itens!')
		WWPActions.WCPopup_Close('')
	Else
		Msg('Não foi possível realizar a alteração.')
	EndIf

EndEvent

Sub 'AtualizaValores'

	For Each Line In GridItensPedido
		
		&AuxPedVlrItm 		= PedVlrUntDsc*(1+&CustoEmX/100)
		
		&AuxPedVlrUnt 		= PedVlrUnt*(1+&CustoEmX/100)
		&PedVlrUntVarchar	= trim(toformattedString(&AuxPedVlrUnt)) 
		RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntVarchar, &PedVlrUntVarchar)

		&PedVlrUntDscVarchar = trim(toformattedString(&AuxPedVlrItm)) 
		RetiraZerosDepoisVirgulaDuasCasas.Call(&PedVlrUntDscVarchar, &PedVlrUntDscVarchar)
		
		&AuxPedQtd 		= PedQtd*(1+&QtdEmX/100)
		&AuxPedQtdEmb 	= PedQtdEmb*(1+&QtdEmX/100)
		&PedProEmbQtd 	= PedProEmbQtd
		
		Do Case
			Case PedProEmbQtd <> 1 and PedProEmbQtd > 0
				&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
				RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
				
				&PedQtd = &Varchar
				
				&Varchar = trim(toformattedString(&PedProEmbQtd)) 
				RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
				&PedQtd += ' X ' + trim(&Varchar) 
				
				&Varchar = trim(toformattedString(&AuxPedQtd)) 
				RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
				&PedQtd += ' (' + trim(&Varchar) + ')'
				
			Case PedProEmbQtd < 0
				&PedProEmbQtd = &PedProEmbQtd *-1
				&Varchar = trim(toformattedString(&AuxPedQtdEmb)) 
				RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
				&PedQtd = trim(&Varchar)
				
				&Varchar = trim(toformattedString(&PedProEmbQtd)) 
				RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
				&PedQtd += ' / ' + trim(&Varchar) 
				
				&Varchar = trim(toformattedString(&AuxPedQtd)) 
				RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
				&PedQtd += ' (' + trim(&Varchar) + ')'
				
			Otherwise
				&Varchar = trim(toformattedString(&AuxPedQtd)) 
				RetiraZerosDepoisVirgula.Call(&Varchar, &Varchar)
				&PedQtd = trim(&Varchar)
		EndCase
		
		&PedVlrItm = &AuxPedVlrItm * &AuxPedQtd
		
	EndFor

EndSub


