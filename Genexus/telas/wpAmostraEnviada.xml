      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	loadWWPContext.Call(&Context)
	
	if &PedStsEnv = Status_Rastreamento.Enviada
		form.Caption = 'Marcar as Amostras como Enviadas'
		RetornaAutorizacao.Call('WWAMOSTRAS', Status_SimNao.Sim, 2 ,&AutNiv)
	Else
		form.Caption = 'Cancelamento Envio das Amostras'
		RetornaAutorizacao.Call('WWAMOSTRAS', Status_SimNao.Sim, 2 ,&AutNiv)
	EndIF

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Do 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PEdCod
		
		&RasPedCliCod = PedCliCod
		&RasPedCliNom = PedCliRaz
		&RasCorCod = PedEnvCod
		Exit
	EndFor

EndEvent

Sub 'CheckRequiredFields'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	&CheckRequiredFieldsResult = True
	If &RasCorCod.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg('', Format('WWP_RequiredAttribute','Cód.Rastreio'), DVMessageType.error, &RasCorCod.InternalName, DVMessageBoolean.True, ''))
		&CheckRequiredFieldsResult = False
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'AttributesSecurityCode'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not(&PedStsEnv <>  Status_Rastreamento.Pendente)
		DVPanel_TableAttributes_Cell.Class = !'Invisible'
	Else
		DVPanel_TableAttributes_Cell.Class = !'col-xs-12'
	EndIf
	tbconf.Visible = (&PedStsEnv =  Status_Rastreamento.Pendente)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Event Enter

	if &PedStsEnv = Status_Rastreamento.Enviada
		do 'CheckRequiredFields'
		if &CheckRequiredFieldsResult = True
			Rastreamento_Finaliza.Call(&EmpCod, &FilCod, &PEdCod, Status_Rastreamento.Enviada, &RasCorCod, &PedDtaDsp, &Context.UserName)
			AtualizaEstoqueEntradaSaida.Submit('AtualizaEstoqueEntradaSaida', &EmpCod, &FilCod, &PEdCod, Status_Pedido.FECHADO)
			Return
		EndiF
	Else
		Rastreamento_Finaliza.Call(&EmpCod, &FilCod, &PEdCod, Status_Rastreamento.Pendente, &RasCorCod, &PedDtaDsp, &Context.UserName)
		AtualizaEstoqueEntradaSaida.Submit('AtualizaEstoqueEntradaSaida', &EmpCod, &FilCod, &PEdCod, Status_Pedido.ABERTO)
		Return
	EndIF

EndEvent


]]></Source>
