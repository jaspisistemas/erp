      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	retornaAutorizacao.Call('WPMETAVENDEDOR', Status_SimNao.Sim, 1, &AutNiv)
	
	&PesCod = &parPesCod	
	&PesMetAno = Year(serverdate())

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	do 'LoadMeses'

EndEvent

Event 'DoGrafico'

	GrfMetasVendedor.Link('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'f4'

 4
	promptVendedor.Popup(&EmpCod, &PesCod)
	&PesCod.SetFocus()

EndEvent

Event &PesCod.IsValid

	if &OldPesCod <> &PesCod
		do 'LoadMeses'
	EndiF
	&OldPesCod = &PesCod

EndEvent

Event &PesMetAno.IsValid

	if &OldPesMetAno <> &PesMetAno
		do 'LoadMeses'
	EndIf
	&OldPesMetAno = &PesMetAno

EndEvent

Event Enter

	RetornaNomeVEndedor.Call(&EmpCod, &PesCod, &PesIsVen, &PesRaz)
	&BaseAno = year(Serverdate())
	&MenorAno = &BaseAno - 1
	&MaiorAno = &BaseAno + 1
	do Case
		Case &PesCod.IsEmpty() or  &PesIsVen = false
			msg('Informe o Vendedor!')
			&PesCod.SetFocus()
		Case &PesMetAno < &MenorAno or &PesMetAno > &MaiorAno
			msg('Ano Ref. inválido! Ano mínimo ' + trim(str(&MenorAno)) + ', Ano Máximo ' + trim(str(&MaiorAno)))
			&PesMetAno.SetFocus()
		Otherwise
			
			GravaMEtaVendedor.Call(&EmpCod, &PesCod, &PesMetAno, &JanPesMetVlr,&FevPesMetVlr,&MarPesMetVlr,&AbrPesMetVlr,&MaiPesMetVlr,&JunPesMetVlr,&JulPesMetVlr,&AgoPesMetVlr,&SetPesMetVlr,&OutPesMetVlr,&NovPesMetVlr,&DezPesMetVlr)
			msg('Meta atualizada com sucesso!')
			&PesCod.SetFocus()
	EndCase

EndEvent

Sub 'LoadMeses'

	&JanPesMetVlr.SetEmpty()
	&FevPesMetVlr.SetEmpty()
	&MarPesMetVlr.SetEmpty()
	&AbrPesMetVlr.SetEmpty()
	&MaiPesMetVlr.SetEmpty()
	&JunPesMetVlr.SetEmpty()
	&JulPesMetVlr.SetEmpty()
	&AgoPesMetVlr.SetEmpty()
	&SetPesMetVlr.SetEmpty()
	&OutPesMetVlr.SetEmpty()
	&NovPesMetVlr.SetEmpty()
	&DezPesMetVlr.SetEmpty()
	RetornaNomeVEndedor.Call(&EmpCod, &PesCod, &PesIsVen, &PesRaz)
	
	For Each Order EmpCod, PesCod, PesMetAno
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesMetAno = &PesMetAno
		Do Case
			CAse PesMetMes = 1
				&JanPesMetVlr = PesMetVlr
			CAse PesMetMes = 2
				&FevPesMetVlr = PesMetVlr
			CAse PesMetMes = 3
				&MarPesMetVlr = PesMetVlr
			CAse PesMetMes = 4
				&AbrPesMetVlr = PesMetVlr
			CAse PesMetMes = 5
				&MaiPesMetVlr = PesMetVlr
			CAse PesMetMes = 6
				&JunPesMetVlr = PesMetVlr
			CAse PesMetMes = 7
				&JulPesMetVlr = PesMetVlr
			CAse PesMetMes = 8
				&AgoPesMetVlr = PesMetVlr
			CAse PesMetMes = 9
				&SetPesMetVlr = PesMetVlr
			CAse PesMetMes = 10
				&OutPesMetVlr = PesMetVlr
			CAse PesMetMes = 11
				&NovPesMetVlr = PesMetVlr
			CAse PesMetMes = 12
				&DezPesMetVlr = PesMetVlr
		EndCase
	EndFor

EndSub


]]></Source>
