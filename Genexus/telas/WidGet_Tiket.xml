      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	tbinvisi.Visible = 0 
	LoadWWPContext.Call(&Context)
	&EmpCod = &Context.EmpCod
	&FilCod = &ParmFilCod
	
	&Month = Month(&Today)
	&Ano = Year(&Today)
	
	&PedDtaFat = YMDtoD(&Ano,&Month,1)
	&PedDtaFat_Go = &Today
	
	prcTotalVendasHojeTicketMedio.Call(&EmpCod, &FilCod, &PedDtaFat, &PedDtaFat_Go, &HojePedVlrLiq, &MediaMensalMoeda)
	&ValueCard1 = &MediaMensalMoeda
	&ValueCard3 = &HojePedVlrLiq

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoTotalizar'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	Totalizar_Modal.Confirm()

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Totalizar_Modal.OnLoadComponent

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	WWPAux_WC.Object = wpTotalizaPedidos.Create(&FinMedioMoeda, &medioMoeda, &PedidoMoeda, &QtdPedidos, &FinQtdPedido, &FinPedidoMoeda)

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event MoreInfoTableCard3.Click

	RetornaAutorizacao.Call('WWOFICINAMECANICA', Status_SimNao.Nao, 1, &AutNiv)
	if &AutNiv > 0
		WWOficinaMecanica.Link()
	Else
		RetornaAutorizacao.Call('WWPEDIDOBALCAO', Status_SimNao.Nao, 1, &AutNiv)
		if &AutNiv > 0
			wwPedidoBalcao.Link()
		Else
			RetornaAutorizacao.Call('WWPEDIDOVENDA', Status_SimNao.Nao, 1, &AutNiv)
			if &AutNiv > 0
				WWPEDIDOVENDA.Link()
			Endif
		Endif
	Endif

EndEvent

Event MoreInfoTableCard1.Click

	RetornaTotalPedidosVendaGrid.Call(&EmpCod, &FilCod, 0, Status_Pedido.FECHADO, &PedStsFin, 0,&PedStsCrd, &PedDtaEms, &PedDtaEms_To, &PedDtaFat, &PedDtaFat_Go, 0, 0, 'V', &FinMedioMoeda,&medioMoeda,&PedidoMoeda,&QtdPedidos,&FinQtdPedido,&FinPedidoMoeda)
	//wpTotalizaPedidos.Popup(&FinMedioMoeda,&medioMoeda,&PedidoMoeda,&QtdPedidos,&FinQtdPedido,&FinPedidoMoeda)
	
	Totalizar_Modal.Confirm()

EndEvent


]]></Source>
