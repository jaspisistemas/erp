        <Source><![CDATA[// 1) Create a table with attributes: ProgressId, ProgressValue (both Character(20))
// 2) Make the changes indicated in the following procs: scaProgressBarTest, scaGetProgress

Event 'StartExecution' 	
	scaProgressBar1.ProcessId = !'progressBar1'
	scaProgressBar1.UpdateProgressURL = scaGetProgress.Link(!'progressBar1') 
	scaProgressBar1.SubmitProgressURL = scaSubmitProcess.Link(!'progressBar1')
	scaProgressBar1.Start()
EndEvent

Event scaProgressBar1.OnComplete
	msg(scaProgressBar1.ProcessId +  !" execution finished.")	
EndEvent

]]></Source>
