      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start
	//RETORNO DO ADM, COM CODIGO DE AUTENTICACAO MERCADO LIVRE, ...
	For &item in &HttpRequest.QueryString.SplitRegEx('&')
		&par = &item.SplitRegEx('=')
		
		if &par.Count >= 2
			&chave = &par.Item(1)
			&valor = &par.Item(2)
			
			do case
				case &chave = 'code'
					&Code = &valor
				case &chave = 'guid'
					&State = &valor
			endcase
		endif
	Endfor	

	loadWWPContext.Call(&Wwpcontext)	
	prcCredentialsMercadoLivre.Call(&Wwpcontext.EmpCod, &State)
	wpMarketplaces.Link()

EndEvent
]]></Source>
