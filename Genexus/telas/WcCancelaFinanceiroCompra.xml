      <Part type="c44bd5ff-f918-415b-98e6-aca44fed84fa">
        <Source><![CDATA[
Event Start

	&CancelarDuplicatas 			= Status_SimNao.Sim
	&CancelarPagamentosDuplicatas	= Status_SimNao.Sim
	&AlterarFinanceiro 				= Status_SimNao.Sim
	
	LoadWWPContext.Call(&Context)
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		If PedStsFin <> Status_Financeiro.FECHADO
			WWPActions.WCPopup_Close('')
		EndIF
		
	EndFor

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event 'DoFechar'

	WWPActions.WCPopup_Close('')

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */



	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndEvent

Event Enter

	If &Mensagem.IsEmpty()
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", "Por Favor, informar um motivo para o cancelamento do fincanceiro!" ,DVMessageType.regular, "", DVMessageBoolean.True,""))
		&Mensagem.SetFocus()
	Else
		CancelaStatusFinanceiroPedido.Call(&EmpCod, &FilCod, &PedCod, &Mensagem, &Context.PesCod)
		WWPActions.WCPopup_Close('Ok')
	EndIf

EndEvent


]]></Source>
