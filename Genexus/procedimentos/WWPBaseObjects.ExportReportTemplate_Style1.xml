      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Header
	if &Context.EmpCod = 0
		loadWWPContext.Call(&Context)
	Endif

	For Each ORder EmpCod, FilCod
		Where EmpCod = &Context.EmpCod
		Where FilCod = &Context.FilCod
		&AppName = FilFan
		&Phone = FilFonNum
		&Mail = FilEml
		&AddressLine1 = FilLogNro + ' - ' + FilBai.Trim()
		&AddressLine2 = FilCidCodNomUfe
		Exit
	EndFor

	Print printTitle
End 
Footer
	&PageInfo = "Page: " + &Page.ToString().Trim()
	&DateInfo = "Date: " + &Today.ToFormattedString()
	Print printFooter
End

]]></Source>
