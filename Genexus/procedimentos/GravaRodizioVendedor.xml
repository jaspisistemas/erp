      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod
	Where EmpCod = &EmpCod
	
	RodInt = &RodInt
	RodIntLig = &RodIntLig 
	RodIntVen = &RodIntVen
	RodExt = &RodExt
	RodExtLig = &RodExtLig
	RodExtVen = &RodExtVen
	RotIntSemVda = &RotIntSemVda
	RotIntSemVdaDias = &RotIntSemVdaDias
	
	Exit
EndFor

Commit

For Each Order EmpCod, RodExcVenCod
	Where EmpCod = &EmpCod
	delete
EndFor

Commit

For &sdtPessoaItem in &sdtPessoa
	new
		EmpCod = &EmpCod
		RodExcVenCod = &sdtPessoaItem.PesCod
	EndNew

EndFor

Commit
]]></Source>
