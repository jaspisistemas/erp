      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

&SdtCliente.JspSts = 'E999'

if &IsAcessoConcedido = true
	
	&CteDocAntChv = trim(RetornaSoNumeros.Udp(&ChvCte))
	If not &CteDocAntChv.Trim().IsEmpty()
		&CteModCod = SubStr(trim(&CteDocAntChv),21,2) // TEM QUE SER MODELO 57
		
		If &CteModCod <> '57'
			&SdtCliente.JspSts = 'E998'
			&SdtCliente.JspObs = 'CHAVE INVÁLIDA! Só é permitido adicionar documento Modelo 57 CT-e.'
			return
		Else
			ValidaChaveNotaReturnMsg.Call(&CteDocAntChv,&Mensagem)
			&SdtCliente.JspObs = &Mensagem
			if not &Mensagem.IsEmpty()
				&SdtCliente.JspSts = 'E996'
				return
			Endif
			
			&SdtCliente.Cnpj = Substr(&CteDocAntChv,7,14)
		EndIf
	EndIf

	ValidaCpfCnpj.Call(&SdtCliente.Cnpj, &ErroCnpj, 'S')
	if &ErroCnpj = 1
		&SdtCliente.JspSts = 'E995'
		&SdtCliente.JspObs = 'CNPJ/CPF contido na chave digita, está inválido.'
		return
	Endif

	do 'GetPessoa'
	&SdtCliente.JspSts = 'J200'
		
Endif


Sub 'GetPessoa'

	For eacH Order EmpCod,PesCod
		Where EmpCod = &wwpContext.EmpCod
		Where PesSts = Status_AtivoInativo.ATIVO
		Where PesCnpj = &SdtCliente.Cnpj when &SdtCliente.Cnpj.Length() > 14
		Where PesCpf = &SdtCliente.Cnpj when &SdtCliente.Cnpj.Length() <= 14
		&SdtCliente.CidUf = PesCidUfeCod
		&SdtCliente.InsEst = PesInsEst
		&SdtCliente.Raz = PesRaz
		exit
	When none
		For eacH Order EmpCod,PesCod
			Where EmpCod = &wwpContext.EmpCod
			Where PesSts = Status_AtivoInativo.inatIVO
			Where PesCnpj = &SdtCliente.Cnpj when &SdtCliente.Cnpj.Length() > 14
			Where PesCpf = &SdtCliente.Cnpj when &SdtCliente.Cnpj.Length() <= 14
			&SdtCliente.CidUf = PesCidUfeCod
			&SdtCliente.InsEst = PesInsEst
			&SdtCliente.Raz = PesRaz
			exit
		EndFor
	EndFor

	For Each ORder EmpCod, UfeCod
		Where EmpCod = &wwpContext.EmpCod
		Where UfeCod = &SdtCliente.CidUf
		
		&SdtCliente.CidUfN = UfeNom
		Exit
	EndFor


EndSub
]]></Source>
