      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &mode = TrnMode.Update
	For Each Order EmpCod,PesCod,PesRecCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesRecCod = &PesRecCod
		
		PesRecDtaAdm = &PesRecDtaAdm
		PesRecDtaReg = &PesRecDtaReg
		PesRecDtaDem = &PesRecDtaDem 
		
	EndFor
Else
	New
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesRecCod = &PesRecCodMax + 1
		PesRecDtaAdm = &PesRecDtaAdm
		PesRecDtaReg = &PesRecDtaReg
		PesRecDtaDem = &PesRecDtaDem	
	Endnew
EndIf

Commit
	
		

If not &Obs.IsEmpty()
	For Each Order EmpCod, PesCod, (PesFunObsCod)
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&newPesFunObsCod = PesFunObsCod
		Exit
	EndFor
	&newPesFunObsCod += 1
	
	new
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesFunObsCod = &newPesFunObsCod
		PesFunObsUsuCod = &wwpContextPesCod
		PesFunObsDtaHor = ServerNow()
		PesFunObs = &Obs
	EndNew
EndIF
]]></Source>
