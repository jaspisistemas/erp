      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//ATUALIZA O STATUS DA VIAGEM
For Each Order EmpCod, FilCod, ViaCod
	Where EmpCod = &parmEmpCod
	Where FilCod = &parmFilCod
	Where ViaCod = &parmViaCod
	
	Do Case
		Case &parmViaSts 	= 'T' //SE ATUALIZAR PARA EM TRÂNSITO
			//VAI APENAS ATUALIZAR O STATUS
			ViaSts 			= 'T'
			
		Case &parmViaSts 	= 'F' //SE ATUALIZAR PARA FINALIZADO
			
			ViaSts			= 'F'			//ATUALIZA O STATUS
			ViaDtaChe		= &parmViaDtaChe	//ADICIONA A DATA DE CHEGADA
			ViaVeiFinKM 	= &parmViaVeiFinKm	//ADICIONA O KM FINAL DO VEÍCULO	
			ViaVeiTotKM 	= ViaVeiIniKM - &parmViaVeiFinKm	//ATUALIZA O TOTAL RODADO
			
			//MARCA TODAS AS CARGAS COMO ENTREGUES
			For Each Order EmpCod, FilCod, ViaCod, ViaCarCod
				Where ViaCarSts = 'T'
				
				ViaCarSts 		= 'E'
				
				Commit
				
			EndFor
		
			VeiUltKm		= ViaVeiFinKM + ViaVeiTotKM	//ATUALIZA A QUILOMETRAGEM DO VEICULO
			PesQtdVia 		+= 1	//ATUALIZA A QUANTIDADE DE VIAGENS DO MOTORISTA
		
	EndCase
	
	Exit
EndFor
Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
