      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Mensagem.SetEmpty()
For Each Order EmpCod, FilCod, PrdCod, PrdItmCod, PrdProEstLotCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PrdCod = &PrdCod
	Where PrdItmCod = &PrdItmCod
	
	&PrdProEstLotCod = trim(toformattedString(PrdProEstLotVct))
	
	if (PrdProEstLotCod <> '#SEM_LOTE' and not PrdProEstLotCod.IsEmpty()) or not PrdProEstLotVct.IsEmpty()
		if &Mensagem.IsEmpty()
			if PrdProEstLotCod = '#SEM_LOTE'
				&Mensagem += 'LT:' + trim(toformattedString(PrdProEstLotVct))
			Else				
				&Mensagem += 'LT:' + trim(PrdProEstLotCod)
			EndIF
			
			if not PrdProEstLotVct.IsEmpty() and (&PrdProEstLotCod <> PrdProEstLotCod) and (PrdProEstLotCod <> '#SEM_LOTE')
				&Mensagem += ' VCT:' + trim(toformattedString(PrdProEstLotVct))
			Endif
			
			iF NOT PrdProEstLotFab.IsEmpty() and (PrdProEstLotCod <> '#SEM_LOTE')
				&Mensagem += ' FAB:' + trim(toformattedString(PrdProEstLotFab))
			EndIf
			
			&Mensagem += ' QTD: ' + trim(toformattedString(PrdProEstLotQtd))
			
		Else	
			
			if PrdProEstLotCod = '#SEM_LOTE'
				&Mensagem += '; LT:' + trim(toformattedString(PrdProEstLotVct))
			Else				
				&Mensagem += '; LT:' + trim(PrdProEstLotCod)
			EndIF
			if not PrdProEstLotVct.IsEmpty() and (&PrdProEstLotCod <> PrdProEstLotCod) and (PrdProEstLotCod <> '#SEM_LOTE')
				&Mensagem += ' VCT:' + trim(toformattedString(PrdProEstLotVct))
			Endif
			&Mensagem += ' QTD:' + trim(toformattedString(PrdProEstLotQtd))
			
		Endif
	Endif
EndFor

if &Mensagem.IsEmpty()
	&Mensagem = 'LOTE_NAO_INFORMADO'
Endif

]]></Source>
