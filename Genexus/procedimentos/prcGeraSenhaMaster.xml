      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[



do while (&isOk = false)

	&Length = 35 // Defina o comprimento desejado para a string aleatória
    &RandomNumber = 0
    For &i = 1 to &Length
        &RandomNumber = Random() * 1000
        &RandomVarchar = &RandomVarchar + &RandomNumber.ToString().Trim()
    Endfor

	&PesSenChvCmp = Substr(&RandomVarchar, 1, 30)
	
	for Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesSenChvCmp = &PesSenChvCmp
		Exit
	When None
		&isOk = true
	EndFor

EndDo


RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&TipoCodigoBarras = TipoCodigoBarras.CODE128C
&LinkFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras.ToString()) + trim(&PesSenChvCmp) + '.jpg'
&LinkVirtual = &sdtConfiguracoesPasta.PastaDiretorioTempvir + trim(&TipoCodigoBarras.ToString()) + trim(&PesSenChvCmp) + '.jpg'

&File.Source = &LinkFisico
If not &File.Exists()	
	ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, trim(&PesSenChvCmp), trim(&PesSenChvCmp))
EndIF
]]></Source>
