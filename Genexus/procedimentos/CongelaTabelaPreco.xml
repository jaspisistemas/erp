      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Total = 40
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

For Each Order EmpCod, TabCod
	Where EmpCod = &EmPCod
	Where TabCod = &TabCod
	&Total += 1
	For Each Order EmpCod, TabCod, ProCod, ProGraCod
		Where TabAltCod = &OldTabAltCod
		&Total += 1
	EndFor
EndFor

For Each Order EmpCod, TabCod
	Where EmpCod = &EmPCod
	Where TabCod = &TabCod
	
	&OldTabAltCod = TabUltAlt
	TabUltAlt += 1
	&NewTabAltCod = TabUltAlt
	
	if (&newTabProDtaFin > TabDtaFin or (not TabDtaFin.IsEmpty() or not TabDtaFin.IsNull())) and not &newTabProDtaFin.IsEmpty()
		TabDtaFin = &newTabProDtaFin		
	EndIF

	if TabIsAntAcr = true
		TabDtaVct = &TabDtaVct
	Endif

	For Each Order EmpCod, TabCod, ProCod, ProGraCod
		Where TabAltCod = &OldTabAltCod
		&ProCod = ProCod
		&ProGraCod = ProGraCod
		
		&Count += 1
		If &Count > 0
			&Percentual = round((&Count / &Total) * 100, 0)
		EndIF
		If &Percentual >= 100
			&Percentual = 99
		EndIf
		do 'Atualiza'
		
		If (TabProDtaFin > &TabDtaFin) or TabProDtaFin = &TabDtaFin or (TabProDtaFin.IsEmpty())  or (TabProDtaFin.IsNull())
			TabProDtaFin = &TabDtaFin
			
			commit
			
			GravaItemAlterado.Call(EmpCod, TabCod, ProCod, ProGraCod, &NewTabAltCod, TabPrc1, TabPrc2, TabPrc3, TabPrc4, TabPrc5, TabPrc6, TabPrc7, TabPrc8, TabPrc9, &NewTabProDtaIni, &newTabProDtaFin, &TabDtaVct, TabPerAcr, TabPerAnt)
		EndIf
	EndFor

	Exit
EndFor

Commit 


For Each Order EmpCod, TabCod, TabCglCod
	Where EmpCod = &EmPCod
	Where TabCod = &TabCod
	Where TabCglCod = &OldTabAltCod
	TabCglDtaFin = &TabDtaFin
When none
	new
		EmpCod = &EmPCod
		TabCod = &TabCod
		TabCglCod = &OldTabAltCod
		TabCglDtaFin = &TabDtaFin
	EndNEw
EndFOr

&Count += 1
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

For Each Order EmpCod, TabCod, TabCglCod
	Where EmpCod = &EmPCod
	Where TabCod = &TabCod
	Where TabCglCod = &NewTabAltCod
	TabCglDtaFin.SetEmpty()
When none
	new
		EmpCod = &EmPCod
		TabCod = &TabCod
		TabCglCod = &NewTabAltCod
		TabCglDtaFin.SetEmpty()
	EndNEw
EndFOr

cOMMIT


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
	
EndSub

]]></Source>
