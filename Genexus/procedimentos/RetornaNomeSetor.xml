        <Source><![CDATA[

&SetNom = ''
if &SetCod > 0
	For Each Order EmpCod, SetCod
		Where EmpCod = &EmpCod
		Where SetCod = &SetCod
		
		&SetNom = SetNom
		Exit
	When none
		&SetNom = 'SETOR NÃO LOCALIZADO'
	EndFor
EndIf
]]></Source>
