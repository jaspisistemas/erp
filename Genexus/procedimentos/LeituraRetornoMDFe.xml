<Object parentGuid="9bbd5271-0e6e-4b96-abef-fa6edd198f06" user="WINJEAN\jeanfae" versionDate="2025-07-21T13:35:12.0000000Z" lastUpdate="2025-07-17T14:54:45.0000000Z" checksum="bba775bcd8f0b5f8254e64206b6b3883" fullyQualifiedName="LeituraRetornoMDFe" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="16741e13-4284-4f08-ad44-31ed5a95742e" name="LeituraRetornoMDFe" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Leitura Retorno MDFe" parent="ComunicaNFe" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDFeCod
	&MDFeChv = MDFeChv
	
	&PastaDanfeData = str(year(MDFeDtaEms),4,0)+padl(trim(str(month(MDFeDtaEms),2,0)),2,'0')
	
	Exit
EndFor

&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + 'MDFe'+trim(&MDFeChv)+'-sit.xml'
&Nome_retorno_correto2 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + 'MDFe'+trim(&MDFeChv)+'-pro-rec.xml'
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + 'MDFe'+trim(&MDFeChv)+'-sit.err'
&Nome_retorno_erro2 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + 'MDFe'+trim(&MDFeChv)+'-pro-rec.err'

&File.Source = trim(&Nome_retorno_erro)
If &File.Exists()
	
	&ResultadoAbertura =   DFROpen(&Nome_retorno_erro)    
	Do while dfrnext() = 0 
		&ResultadoAbertura = DFRGTxt(&CampoUnico)
		&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
	EndDo
	&ResultadoAbertura = DFRClose()
	
	&File.Delete()
	
	&Tentativa = 99
	&SolSts = Status_Solicitacao.Falha
	&SolMsg = &conteudo_arquivo
ELSE
	
	&File.Source = trim(&Nome_retorno_erro2)
	&conteudo_arquivo = ''
	If &File.Exists()
		
		&ResultadoAbertura =   DFROpen(&Nome_retorno_erro2)    
		Do while dfrnext() = 0 
			&ResultadoAbertura = DFRGTxt(&CampoUnico)
			&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
		EndDo
		&ResultadoAbertura = DFRClose()
		
		&File.Delete()
		
		&Tentativa = 99
		&SolSts = Status_Solicitacao.Falha
		&SolMsg = &conteudo_arquivo
		
	else
		&File.Source = trim(&Nome_retorno_correto)  // assincrono será desativada 30/06/2024
		If &File.Exists()
			
			&retorno_xml.Open(&Nome_retorno_correto)
			&retorno_xml.ReadType(1,'cStat')
			&NfeAutSts = &retorno_xml.Value
			
			&retorno_xml.ReadType(1,'xMotivo')
			&NfeAutMsg = &retorno_xml.Value
			
			&retorno_xml.ReadType(1,'dhRecbto')
			&NfeAutDatHorRec = &retorno_xml.Value
			
			&retorno_xml.ReadType(1,'nProt')
			&NfeAutNumPro = &retorno_xml.Value
			
			if not &NfeAutSts.IsEmpty()
				&Tentativa = 99
				
				do 'Gravasolicitacao'
				
			EndIf
			&SolMsg = &NfeAutMsg
			&retorno_xml.close()
		Else
			&File.Source = trim(&Nome_retorno_correto2)  // assincrono será desativada 30/06/2024
			If &File.Exists()
				
				&retorno_xml.Open(&Nome_retorno_correto2)
				&retorno_xml.ReadType(1,'cStat')
				&NfeAutSts = &XMLReader.Value
				
				&retorno_xml.ReadType(1,'xMotivo')
				&NfeAutMsg = &XMLReader.Value
				
				&ret = &retorno_xml.ReadType(1, 'protMDFe') 
				if &ret <> 0
					&retorno_xml.Read()
					
					Do While &retorno_xml.Name <> 'protMDFe'
						Do Case
							Case &retorno_xml.Name = 'infProt'
								&XMLReader.Read()
								
								Do while &retorno_xml.Name <> 'infProt'
									Do Case
										Case &retorno_xml.Name = 'nProt'
											&NfeAutNumPro = &XMLReader.Value
											
										Case &retorno_xml.Name = 'digVal'
											&NfeAutDigVal = &XMLReader.Value
											
										Case &retorno_xml.Name = 'cStat'
											&NfeAutSts = &XMLReader.Value
											
										Case &retorno_xml.Name = 'xMotivo'
											&NfeAutMsg = trim(&XMLReader.Value)
									Endcase
									
									&retorno_xml.Read()
									
									if &retorno_xml.EOF = true
										Exit
									endif
								EndDo
						EndCase
						
						&retorno_xml.Read()
						
						if &XmlReader.EOF = true
							Exit
						endif
					EndDo			
				EndIF
				
				&retorno_xml.close()
				
				//			&mensagem = 'Status Retorno: ' + trim(str(&cStat)) + ' - ' + trim(&xMotivo)
				//			&SolMsg = &mensagem
				if not &NfeAutSts.IsEmpty()
					&Tentativa = 99
					do 'Gravasolicitacao'
				endIf
				&SolMsg = &NfeAutMsg
			EndIf
			
			
		EndIF
	EndIF
EndIF

if &SolSts <> Status_Solicitacao.Pendente
	if not &ArquivoPronto.IsEmpty()
		&file.Source = &ArquivoPronto.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

	if not &Nome_retorno_correto.IsEmpty()
		&file.Source = &Nome_retorno_correto.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

	if not &Nome_retorno_erro.IsEmpty()
		&file.Source = &Nome_retorno_erro.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

EndIF

Sub 'Gravasolicitacao'
	
	Do Case
		Case &NfeAutSts  = '101' //CANCELADA
			&SolSts = Status_Solicitacao.Finalizada
			
			AtualizaNumeroProtocoloMDFe.Call('CANCELA_NFE', &EmpCod, &FilCod, &MDfeCod, &NfeAutSts, &NfeAutNumLot, &NfeAutNumRec, &NfeAutDatHorRec, &NfeAutMsg, &NfeAutNumPro, &NfeAutDigVal, Status_MDFe.Cancelado, &SolPesCod)
			
			do 'ArquivoPronto'
			
		Case &NfeAutSts = '100' //AUTORIZADA
			&SolSts = Status_Solicitacao.Finalizada
			
			AtualizaNumeroProtocoloMDFe.Call('AUTORIZA_NFE', &EmpCod, &FilCod, &MdfeCod, &NfeAutSts, &NfeAutNumLot, &NfeAutNumRec, &NfeAutDatHorRec, &NfeAutMsg, &NfeAutNumPro, &NfeAutDigVal, Status_MDFe.Autorizado, &SolPesCod)
			
			do 'ArquivoPronto'
			
		Case &NfeAutSts = '132' //ENCERRADO
			&SolSts = Status_Solicitacao.Finalizada
			
			AtualizaNumeroProtocoloMDFe.Call('ENCERRA_MDFE', &EmpCod, &FilCod, &MdfeCod, &NfeAutSts, &NfeAutNumLot, &NfeAutNumRec, &NfeAutDatHorRec, &NfeAutMsg, &NfeAutNumPro, &NfeAutDigVal, Status_MDFe.Encerrado, &SolPesCod)
			
			do 'ArquivoPronto'
		Otherwise
			&SolSts = Status_Solicitacao.Falha
	EndCase
EndSub


sub 'ArquivoPronto'
	&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFenviado.Trim() +"Autorizados\" + trim(&PastaDanfeData) +"\MDFe"+&MDfeChv.trim()+'-procMDFe.xml'
//	&LogGUID = GUID.NewGuid()
//	GravaLogDev.Call(&EmpCod, &FilCod, &LogGUID, &Pgmname, 'arquivopronto', &ArquivoPronto)
	&file.Source = &ArquivoPronto
	if &file.Exists()
		GravaArquivoXmlMDFe.Call(&EmpCod, &FilCod, &MDFeCod, &ArquivoPronto)
	EndIf
EndSub
]]></Source>
