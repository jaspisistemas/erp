      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsErro = False

For Each Order EmpCod,PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &CreCliCod
	
	&VenPesUltVenDta = serverdate() - RodIntVen
	&VenPesPrxLig = serverdate() - RodIntLig
		
	if (&PedVenCod <> PesExtVenCod and &PedVenCod <> PesIntVenCod)
		&IsErro = true
		
		If (PesIntVenCod <= 1 and PesUltVenDta < &VenPesUltVenDta and PesDtaCad < &VenPesUltVenDta) and (PesPrxLig < &VenPesPrxLig)
			&IsErro = False
		EndiF
	EndIF

	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
