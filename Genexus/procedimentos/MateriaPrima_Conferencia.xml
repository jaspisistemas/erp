      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	where ProCod = &ProCod
	Where ProTipDef in (Definicao.FABRICADO, Definicao.SUBPRODUTO, Definicao.SEMIACABADO)
	Where ProSepIsKit = true //UTILIZAR OS ITENS DA RECEITA PARA CONFERENCIA DO PEDIDO
	
	&ProQtdPro = ProQtdPro
	&AuxProRecUltCod = ProRecUltCod
	
	For Each Order EmpCod,ProCod,RecItmCod
		If &ProQtdPro <> 0 and RecProQtd > 0
			
			retornaProdutoEstoque.Call(EmpCod, RecProCod, &ProEstProCod)
			&RecProCod = &ProEstProCod
			&RecProNom = RecProNom
			&RecProBar = RecProBar
			&RecProRef = RecProRef
			&RecProQtdUnt = (RecProQtdUnt) * &EstFab
			
			&SubProduto = 'N'
			If (ProSepIsKit = true)
				&SubProduto = 'S'
			Else
				&QuantiaUtilizada = &RecProQtdUnt	
				do 'addSdt'
			EndIf
		EndIF
				
		If &RecProQtdUnt > 0 and &SubProduto = 'S' //Verifica Receitas a dentro.
			MateriaPrima_Conferencia1.Call('N', EmpCod, &FilCod, &ProEstProCod, &RecProQtdUnt, &ProQtdPro, &ProRecUltCod, &sdtMateriaPrima)
			
			If &ProRecUltCod = 0
				&QuantiaUtilizada = &RecProQtdUnt	
				&SubProduto = 'N'
				do 'addSdt'
			EndIF
		EndIF
	EndFor
EndFor


Sub 'AddSdt'
	&IsAchou = false
	For &sdtMateriaPrimaItem in &sdtMateriaPrima
		if &sdtMateriaPrimaItem.ProCod = &RecProCod
			&sdtMateriaPrimaItem.QuantiaUtilizada += &QuantiaUtilizada //(&QuantiaUtilizada * &QtdRecProQtd) * &EstFab
			&IsAchou = true
			Exit
		EndIf
	EndFor
	
	If &IsAchou = false
		&sdtMateriaPrimaItem  = NEW()
		&sdtMateriaPrimaItem.ProCod = &RecProCod
		&sdtMateriaPrimaItem.ProGraCod = 1
		&sdtMateriaPrimaItem.ProNom = &RecProNom
		&sdtMateriaPrimaItem.SubProduto = &SubProduto
		//&sdtMateriaPrimaItem.RecProVlrCus = &RecProVlrCusUnt
		//&sdtMateriaPrimaItem.EstQtd = &EstQtd
		&sdtMateriaPrimaItem.EstSdo = &EstQtd
		&sdtMateriaPrimaItem.ProRef = &RecProRef
		&sdtMateriaPrimaItem.ProBar = &RecProBar
		&sdtMateriaPrimaItem.ProEstProCod = &ProEstProCod
		&sdtMateriaPrimaItem.QuantiaUtilizada = &QuantiaUtilizada //(&QuantiaUtilizada * &QtdRecProQtd) * &EstFab
		&sdtMateriaPrima.Add(&sdtMateriaPrimaItem)
	Endif
EndSub
]]></Source>
