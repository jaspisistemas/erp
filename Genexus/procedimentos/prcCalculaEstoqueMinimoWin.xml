      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&HojeData = ServerDate()
&IsExecutou = false
&sdtAgendadorFiltros.FromXml(&AgdFiltro)
&QtdDiasApuracao  = 0
&QtdDiasRepeticao = 0

For &sdtAgendadorFiltrosItem in &sdtAgendadorFiltros
	
	Do case
		case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDQTDDIASAPURACAO' //Qtd dias apuração
			&QtdDiasApuracao = val(&sdtAgendadorFiltrosItem.AgdValue)
			
		case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDQTDDIASREPETICAO' //Qtd dias repetição
			&QtdDiasRepeticao = val(&sdtAgendadorFiltrosItem.AgdValue)
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDINCVENABE' //Incluir Vendas Abertas
			&IncluirVendasAbertas = iif(&sdtAgendadorFiltrosItem.AgdValue = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDINCVENPER' //Incluir vendas perdidas
			&IncluirVendasPerdidas = iif(&sdtAgendadorFiltrosItem.AgdValue = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDINCMAIMEN' //Incluir Maior Menor
			&IncluirMaiorMenor = iif(&sdtAgendadorFiltrosItem.AgdValue = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
			
	EndCase
EndFor

&iniPedDtaEms = &HojeData.AddDays(- &QtdDiasApuracao )
&finPedDtaEms = &HojeData
&limiteData = &HojeData.AddDays(-&QtdDiasRepeticao)

&FilPrzEst = 0
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
    &FilPrzEst = FilPrzEst
	Exit
EndFor

&Total = 0
&Count = 0

&AuxGrupHie = &GrupHie.Trim() + '.'
For Each Order EmpCod,ProCod,ProSts,ProUltAtuCalMin
	Where EmpCod = &EmpCod
	Where ProCod > 0
	Where ProSts = Status_Produto.ATIVO
	where ProUltAtuCalMin <= &limiteData or ProUltAtuCalMin.IsNull() or ProUltAtuCalMin.IsEmpty()
	&Total += 1
EndFor

//PRODUTOS VENDIDO NO PERIODO
For Each Order EmpCod,ProCod,ProSts,ProUltAtuCalMin
	Where EmpCod = &EmpCod
	Where ProCod > 0
	Where ProSts = Status_Produto.ATIVO
	where ProUltAtuCalMin <= &limiteData  or ProUltAtuCalMin.IsNull() or ProUltAtuCalMin.IsEmpty()
	
	ProUltAtuCalMin = &HojeData
	If ProPadForCod <> &AuxProPadForCod
		&AuxProPadForCod = ProPadForCod
		&PesForPrzTot = RetornaDiasSeguracaoFornecedor.Udp(EmpCod, ProPadForCod)
	EndIf
	
	&TotalDiasBase = &PesForPrzTot + &FilPrzEst + ProMarSeg + ProSetPrzEst
	
	&TotalVendido = 0
	&TotalCancelado = 0
	
	&MaiorVendidaCancelada = 0
	&MenorVendidaCancelada = 0
	&MaiorVendida = 0
	&MenorVendida = 0
	
	&InicialCalculo = RetornaDataPrimeiraSaida.Udp(EmpCod, &FilCod, ProCod, 1)
	If (&InicialCalculo < &iniPedDtaEms)
		&InicialCalculo = &iniPedDtaEms
	EndiF
	
	&ProCod = ProCod
	
	do 'SomaPedidoProdutos'
	if &IncluirMaiorMenor <> Status_SimNao.Sim
		&TotalCancelado -= (&MenorVendidaCancelada + &MaiorVendidaCancelada)
	Endif

	If &TotalCancelado < 0
		&TotalCancelado = 0
	EndIF
	
	if &IncluirMaiorMenor <> Status_SimNao.Sim
		&TotalVendido -= (&MaiorVendida + &MenorVendida)
	Endif

	If &TotalVendido < 0
		&TotalVendido = 0
	EndIF		

	if &IncluirVendasPerdidas = Status_SimNao.Sim
		&TotalVendido += &TotalCancelado
	EndIF
	
	&DiasApuracao = (&finPedDtaEms - &InicialCalculo)
	
	if &DiasApuracao = 0
		&EstMin = &TotalVendido
	else
		&EstMin = (&TotalVendido / &DiasApuracao) 
		If &TotalDiasBase <> 0
			&EstMin = &EstMin * &TotalDiasBase
		EndiF
	endif
	&EstMin += &UtilizadaProducao
	GravaEstoqueMinimo.Call(EmpCod, &FilCod, ProCod, 1, &EstMin, &TotalDiasBase, &TotalVendido, &InicialCalculo, &finPedDtaEms)

	commit
EndFor


sub 'SomaPedidoProdutos'
	&UtilizadaProducao.SetEmpty()
	prcSelecionaPedidos_MinimoReceitaAgendador.Call(&EmpCod, &FilCod, &ProCod, &UtilizadaProducao)
	
	For Each Order EmpCod, FilCod, PedProEstProCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedProEstProCod = &ProCod
		Where PedDtaFic >= &InicialCalculo and PedDtaFic <= &finPedDtaEms
		//		Where PedDtaFat >= &InicialCalculo and PedDtaFat <= &finPedDtaEms when &IncluirVendasAbertas <> Status_SimNao.Sim
		Where LctCalMin = Status_SimNao.Sim
		Where LctAtuEst = Status_EntradaSaida.Saida
		Where (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO) or (PedSts in (Status_Pedido.FECHADO,Status_Pedido.SEPARANDO,Status_Pedido.ABERTO) and &IncluirVendasAbertas = Status_SimNao.Sim)
		
		If &MenorVendidaCancelada = 0
			&MenorVendidaCancelada = PedQtdCan
		EndIF
		
		If &MenorVendida = 0
			&MenorVendida = PedQtd
		EndIF
	
		&TotalVendido += PedQtd
		&TotalCancelado += PedQtdCan
				
		If PedQtd > &MaiorVendida
			&MaiorVendida = PedQtd
		EndIF	
		
		If PedQtdCan > &MaiorVendidaCancelada
			&MaiorVendidaCancelada = PedQtdCan
		EndIF
		
		If &MenorVendida > PedQtd and PedQtd > 0
			&MenorVendida = PedQtd
		EndIF
		
		if &MenorVendidaCancelada > PedQtdCan and PedQtdCan > 0
			&MenorVendidaCancelada = PedQtdCan
		EndIF
	EndFor
EndSub
]]></Source>
