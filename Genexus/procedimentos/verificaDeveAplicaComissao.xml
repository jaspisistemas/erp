      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, LctPagCom, PedAplCom
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedVenCod = &PedVenCod or (PedItmVenCod = &PedVenCod) or (PedRspCod = &PedVenCod) or  &PedVenCod = 0
	Where (PedDtaFat >= &iniPedDtaEms and PedDtaFat <= &fimPedDtaEms and PedSts = Status_Pedido.FECHADO) or (PedDtaEms >= &iniPedDtaEms and PedDtaEms <= &fimPedDtaEms and PedSts <> Status_Pedido.FECHADO)
	Where LctPagCom = Status_SimNao.Sim
	Where PedAplCom = 'S'
	&IsTem1 = true
	Exit
EndFor

	
if &IsTem1 = true //APLICA COMISSAO
	AplicaComissao.Call(&ProgressId, &EmpCod, &FilCod, &PedVenCod, &iniPedDtaEms, &fimPedDtaEms)
Endif
]]></Source>
