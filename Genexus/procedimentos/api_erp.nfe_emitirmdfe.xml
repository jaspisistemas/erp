      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	For Each ORder EmpCod, FilCod, NfeCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Exit
	When none
		&sdtRetornowbsetc.sts = 'E998'
		&sdtRetornowbsetc.obs = 'CTe não localizado!'
		return
	Endfor
	
	ValidaNfeMdfe.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &IsAchou)
	
	If &IsAchou = False
		GravaMdfe_Nfe.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &MdfeCod)
		
		&sdtRetornowbsetc.c1 = trim(str(&FilCod))
		&sdtRetornowbsetc.c2 = trim(str(&MdfeCod))
		&sdtRetornowbsetc.sts = 'J200'
		&sdtRetornowbsetc.obs = ''
		return
	Else
		&sdtRetornowbsetc.sts = 'E997'
		&sdtRetornowbsetc.obs = 'ATENÇÃO! Já existe um MDFe com status AUTORIZADO utilizando esta NF-e!'
		return
	EndIf
Else
	&sdtRetornowbsetc.sts = 'E999'
	&sdtRetornowbsetc.obs = 'Nada mais aqui!'
	return
Endif
]]></Source>
