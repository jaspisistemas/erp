      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do Case
	Case &OqueFazer = 'ALT'
		For Each Order EmpCod, FilCod, CteCod, CteDupCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CteCod = &CteCod
			Where CteDupCod = &inCteDupCod
			
			CteDupNro = &CteDupNro
			CteDupVlr = &CteDupVlr	
			CteDupDtaVct = &CteDupDtaVct
			CteDupCbrCod = &CteCbrCod
			
			Exit
		EndFor
		
		Commit
		
	Case &OqueFazer = 'ADD'
		&Parcela = &qtdParcela
		&PedVlrBas = &CteDupVlr
		
		&CreVlrDup = round((&PedVlrBas / &Parcela),2)
		&ResCreVlrDup = round(&PedVlrBas,2) - (round((&PedVlrBas / &Parcela),2) * &Parcela)
		
		&ParMax  = &Parcela
		&Parcela = 1
		
		&AuxCteDupDtaVct = &CteDupDtaVct
		
		&CteDupCod = 0 
		For Each Order EmpCod, FilCod, CteCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where CteCod = &CteCod
			
			&CreCbrCod = FilCbrCod
			&CteCliCod = CteTomCod
			do 'GetCliente'
			For Each Order EmpCod, FilCod, CteCod, (CteDupCod)
				&CteDupCod = CteDupCod				
				Exit
			EndFor
			Exit
		EndFor
	
		Do while &Parcela <= &ParMax
			&CteDupCod += 1
			
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				CteCod = &CteCod
				CteDupCod = &CteDupCod	
				
				CteDupCreSeq = 0
				CteDupFilCod = 0
				
				CteDupFrpPgtoCod = &CteDupFrpPgtoCod
				
				&AuxCreDupNro = trim(str(CteNum)) +'-'+ltrim(str(&CteDupCod))
				CteDupNro =  trim(&AuxCreDupNro)

				if &Parcela = 1
					CteDupVlr = (&CreVlrDup + &ResCreVlrDup)
				else
					CteDupVlr = &CreVlrDup
				endif
				
				CteDupDtaVct = &AuxCteDupDtaVct
				
			    do Case
					Case &CreCbrCod <> 0
						CteDupCbrCod = &CreCbrCod
					Case &PedCliCbrCod = 0
				        CteDupCbrCod = 1
				    Otherwise
				        CteDupCbrCod = &PedCliCbrCod
			    EndCase
			 	//FIM DUPLICATA
			EndNew
			
			&Parcela += 1
			&AuxCteDupDtaVct = &AuxCteDupDtaVct.AddMonths(1)
		EndDo
		
		commit
		
	Case &OqueFazer = 'DEL'
		For Each Order EmpCod, FilCod, CteCod, CteDupCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where CteCod = &CteCod
			Where CteDupCod = &inCteDupCod
			&CteDupFiLCod = CteDupFilCod
			&CteDupCreSeq = CteDupCreSeq
			
				CancelarDuplicata.call(&EmpCod,&CteDupFiLCod,&CteDupCreSeq, &Mensagem)
				If &Mensagem.IsEmpty() //se nao teve impedimento nenhum, deleta
					delete
				EndIf
			Exit
		EndFor
		
		commit
		
	
EndCase


sub 'GetCliente'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CteCliCod
		&PedCliCbrCod = PesCbrCod
		Exit
	EndFor
EndSub
]]></Source>
