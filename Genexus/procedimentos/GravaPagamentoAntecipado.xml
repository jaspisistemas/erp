      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,CreCod,FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
 
	&CreMaxPagCod = CreMaxPagCod
	Exit
EndFor

&auxCreMaxPagCod = &CreMaxPagCod+1
For each Order EmpCod,MovCod
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	
	MovCreCod    = &CreCod
	MovCreFilCod = &FilCod
	MovCrePagCod = &auxCreMaxPagCod
	&MovDtaCon = MovDtaCon
	Do 'GravaPagamento'	
	Exit
EndFor

COMMIT

AtualizaSaldoDuplicata.Call(&EmpCod,&CreCod,&FilCod)

Sub 'GravaPagamento'
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CreCod = &CreCod
		CrePagCod = &auxCreMaxPagCod
		CrePagDta = &MovDtaCon
		CrePagVlr = &CrePagVlr
		CrePagTip = TipoDuplicataBaixa.Total
		CrePagVlrJur = &CrePagVlrJur
		CrePagVlrDsc = &CrePagVlrDsc
		CreMovCod    = &MovCod
		CreMovItmCod = 	&MovItmCod
		CrePagSts = Status_Caixa.Lancado
	EndNew
EndSub
]]></Source>
