        <Source><![CDATA[&sdtConfiguracoesPasta = RetornaConfiguracoesPastas.Udp(&EmpCod, &FilCod)
&IsErroaqrquivo = False
&Averbacao = ''
&Sequence = ''
&Datetime = ''
&Application = ''

Do 'MontaChave'
&HttpClient.host = &Host.trim()
&httpClient.Secure = false
&HttpClient.AddHeader('Content-type','text/xml')
Do 'PegaArquivos'

Sub 'MontaChave'
	For each Order EmpCod,FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		&SoNumero = RetornaSoNumeros.Udp(FilCpj)
		If FilAmbEms = TAmb.Homologacao
			&Host = FilQctHomHost
			&FilQctCodSeg = 'QRC'
			&FilQctCodAut = 'TESTE'
			&FilQctDtaFim = CTOD('01/10/2018')
//			&httpClient.BaseUrl = FilQctHomBase
			&httpClient.Port = val(FilQctHomPort)
		Else
			&Host = FilQctProHost
			&FilQctCodAut = FilQctCodAut
			&FilQctCodSeg = FilQctCodSeg
			&FilQctDtaFim = FilQctDtaFim
//			&httpClient.BaseUrl = FilQctProBase
			&httpClient.Port = val(FilQctProPort)
		EndIf
	EndFor

	&Validade = substr(trim(str(Year(&FilQctDtaFim))),3,2)+Padl(str(Month(&FilQctDtaFim)),2,'0')+PadL(str(Day(&FilQctDtaFim)),2,'0')
	&ID = tRIM(&SoNumero)+Upper(TRIM(&FilQctCodSeg))+trim(&Validade)+'.'+&FilQctCodAut
EndSub


//#####ID#####
//USERID: 14 caracteres quando for CNPJ ou 11 caracteres quando for CPF;
//EDIÇÃO: 3 caracteres indicando a seguradora, exemplo: QRC, BRD, TOK, etc...;
//VALIDADE: 6 caracteres indicando a data de validade do mesmo no formato
//AAMMDD;
//SEPARADOR: 1 caractere sempre um “ponto” [.];
//AUTENTICAÇÃO: 16 caracteres, indicando o Hash de autenticação do Token; 


Sub 'PegaArquivos'
	For each Order EmpCod,FilCod,MDFeCod,MDFeCteItm	
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		
		&auxFilCod = MDFeCteFilCod
		&auxCteCod = MDFeCteCod	
		Do 'CTe'
	When none
		&IsErroaqrquivo = True
		msg('Nenhum documento em anexo encontrado!')
	EndFor
EndSub


Sub 'CTe'
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &auxFilCod
		Where CteCod = &auxCteCod
		&CteSer = CteSer
		&CteNum = CteNum
		&auxCteNum = CteNum
		&CteChv = CteChv
		&CteVlrTotPreSer = CteVlrTotPreSer
		&CteRemRaz = CteRemRaz
		&PastaDanfeNota = str(year(CteDtaEms),4,0)+padl(trim(str(month(CteDtaEms),2,0)),2,'0')
		&CteArqXml = CteArqXml
		
		&AnoMes = str(year(CteDtaEms),4,0)+padl(trim(str(month(CteDtaEms),2,0)),2,'0')
		&PastaAutorizadas = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + 'Autorizados/' + &AnoMes.trim() + '/' + &CteChv.Trim() + '-procCTe.xml'
		&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFenviado.Trim() + 'BancoDeDados/' + CteChv.Trim() + '-jaspi.xml'
		
		&File.Source = &PastaAutorizadas
		If &File.Exists()
			&Varchar = '/averba?Token='+&ID+'&Id='+&CteChv+'.xml'
			&HttpClient.AddFile(&PastaAutorizadas)
		Else
			GravaXmlCteIntegracaoQRC.Call(EmpCod, FilCod, CteCod, &sdtConfiguracoesPasta)
			&File.Source = &PastaBancoDados
			If &File.Exists()
				
				&Varchar = '/averba?Token='+&ID+'&Id='+&CteChv+'.xml'
				&HttpClient.AddFile(&PastaAutorizadas)
			EndIF
		EndIf			
		Exit
	EndFor
	
	If &IsErroaqrquivo = false
	
	&HttpClient.Timeout = 15
	&HttpClient.Execute('POST',&Varchar)
	If &httpClient.ErrCode = 0
		Msg('Comunicação Quorum Ok')
		&response = &HttpClient.ToString()
//		Msg('teste ' +&response )
		//começa leitura
		&XmlReader.OpenFromString(&response)
		&ret = &XmlReader.ReadType(1, 'Averbacao') 
		if &ret <> 0
			&XmlReader.Read()
			Do while &XmlReader.Name <> 'Averbacao'
				Do Case
					Case &XmlReader.Name = 'Request'
						&XmlReader.Read() //Avanca para o primeiro campo da tag...
						Do 'Request'
					Case &XmlReader.Name = 'Response'
						&XmlReader.Read() //Avanca para o primeiro campo da tag...
						Do 'Response'
				EndCase
				&XmlReader.Read()
				
				if &XmlReader.EOF
					Exit
				endif
			EndDo
		EndIf

		//termina leitura	

		If not &Averbacao.Trim().IsEmpty()
			msg('Averbação realizada com Sucesso! Protocolo:'+&Protocolo+' Tipo:'+&Tipo+' Chave:'+&Chave)
			&MdfeSegCnpj = '72.145.931/0001-99' 
			&MdfeSegResCnpj = '72.145.931/0001-99'
			&MdfeSegNom = 'SWISS RE CORPORATE SOLUTIONS BRASIL SEGUROS S.A.'
			&MdfeSegNroApo = ''
			&MdfeSegQCTXml = &response
			Do 'GravaSeguro'
		EndIf
	
	Else 
		msg(&httpClient.ErrDescription)
	EndIf
EndIf
EndSub


Sub 'Request'
	
	Do while &XmlReader.Name <> 'Request'
		Do Case 
			Case &XmlReader.Name = 'Sequence'
				&Sequence = &XmlReader.Value		
			Case &XmlReader.Name = 'DateTime'
				&Datetime = &XmlReader.Value	
			Case &XmlReader.Name = 'Application'
				&Application = &XmlReader.Value
			Case &XmlReader.Name = 'Server'
				&Server = &XmlReader.Value
			Case &XmlReader.Name = 'Token'
				&Token = &XmlReader.Value
		EndCase
		&XmlReader.Read()
		
		if &XmlReader.EOF
			Exit
		endif
	EndDo
EndSub


Sub 'Response'
	
	Do while &XmlReader.Name <> 'Response'
		Do Case 
			Case &XmlReader.Name = 'Docs'
				&XmlReader.Read()
				Do while &XmlReader.Name <> 'Docs'
					Do Case 
						Case &XmlReader.Name = 'Doc'
							&XmlReader.Read()
							&arquivo = &XmlReader.GetAttributeByName('Arquivo')
							Do 'doc'							
					EndCase
					&XmlReader.Read()
					
					if &XmlReader.EOF
						Exit
					endif
				EndDo
			Case &XmlReader.Name = 'Doc'
				&XmlReader.Read()
				&arquivo = &XmlReader.GetAttributeByName('Arquivo')
				Do 'doc'
		EndCase
	
		&XmlReader.Read()
		
		if &XmlReader.EOF
			Exit
		endif
	EndDo
EndSub

Sub 'doc'
	Do while &XmlReader.Name <> 'Doc'
		Do Case 
			Case &XmlReader.Name = 'Tipo'							
				&Tipo = &XmlReader.Value		
			Case &XmlReader.Name = 'Chave'
				&Chave = &XmlReader.Value	
			Case &XmlReader.Name = 'Averbacao'
				&Averbacao = trim(&XmlReader.Value)
				Msg('averb '+&Averbacao)
			Case &XmlReader.Name = 'Protocolo'
				&Protocolo = &XmlReader.Value
			Case &XmlReader.Name = 'Erro'
				&Erro = &XmlReader.Value
				Msg('Erro: '+trim(&Erro))
		EndCase
		&XmlReader.Read()
		
		if &XmlReader.EOF
			Exit
		endif
	EndDo
EndSub



Sub 'GravaSeguro'
	For Each Order EmpCod, FilCod, MDFeCod,MdfeSegCod
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeSegCod = 1
		MdfeSegRes = &MdfeSegRes
		MdfeSegResCnpj = &MdfeSegResCnpj
		MdfeSegNom = &MdfeSegNom
		MdfeSegCnpj = &MdfeSegCnpj
		MdfeSegNroApo = &MdfeSegNroApo
		
	When none
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MDFeCod
			MdfeSegCod = 1
			MdfeSegRes = &MdfeSegRes
			MdfeSegResCnpj = &MdfeSegResCnpj
			MdfeSegNom = &MdfeSegNom
			MdfeSegCnpj = &MdfeSegCnpj
			MdfeSegNroApo = &MdfeSegNroApo
		EndNew
	EndFor

	commit
	
	//averbações
	For Each Order EmpCod, FilCod, MDFeCod,MdfeSegCod
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeSegCod = 1
		Where MdfeSegNroAve = trim(&Averbacao)
		MdfeSegQCTXml = &MdfeSegQCTXml
	When none
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MDFeCod
			MdfeSegCod = 1
			MdfeSegNroAve = trim(&Averbacao)
			MdfeSegQCTXml = &MdfeSegQCTXml
		EndNew
	EndFor

	commit
EndSub

