      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	RetornaProdutoReferencia.Call(&EmpCod, &tmpProRef, &tmpProCod, &tmpProGraCod, &ErptmpProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &MensagemErro)
	
	For each Order EmpCod,ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &tmpProCod
		
		&tmpProRef = ProRef
		&tmpProBar = ProBar	
		&erptmpNcmCod = NcmCod
		&ProCatCod = ProCatCod
		&erptmpNcmCEST = str(ProNcmCest)
		&erpProEmbUnd = ProEmbUnd
		&ProSts = ProSts
		exit
	EndFor
	
	&MaisCodigos = &tmpProRef.Trim() + ' | ' + trim(&tmpProBar)
	
	For Each Order EmpCod, ProCod, ProGraCod, ProBarRef
		Where EmpCod = &EmpCod
		Where ProCod = &tmpProCod
		Where ProGraCod = 1
		Where ProBarTip = 'A' OR ProBarTip = 'O' 
		&OutrosCodigosMensagem += ' | ' + trim(ProBarRef)
	EndFor
	
	&MaisCodigos += &OutrosCodigosMensagem
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
