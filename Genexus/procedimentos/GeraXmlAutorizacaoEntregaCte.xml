<Object parentGuid="d5f687c3-2181-4efd-94e2-024651619340" user="SRVORDIG\Administrador" versionDate="2024-02-01T13:08:45.0000000Z" lastUpdate="2024-02-01T13:07:30.0000000Z" checksum="be854958f6fb314e2fdac107cb840f73" fullyQualifiedName="GeraXmlAutorizacaoEntregaCte" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="32e5d585-9f10-495d-aec0-38a151f85f6f" name="GeraXmlAutorizacaoEntregaCte" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Gera Xml Autorizacao Entrega Cte" parent="prccce" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
LoadWWPContext.Call(&Context)
&PesCod = &Context.PesCod

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&Hoje = serverdate()
RetornaVersaoNotas.Call(VersaoNota.VersaoCTe,&VersaoNF)

GravaSolicitacao.Call(&EmpCod, &FilCod, &CteCod, &CteEveCod, TipoSolicitacao.evento_CTE, &PesCod, &SolCod)
	
//dados da Cte
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	&cUF = substr(str(FilCidUfeIbge,7,0),1,2)
	&FilFusHor = FilFusHor
	&FilAmbEms = FilAmbEms
	&FilCpj = RetornaSoNumeros.Udp(FilCpj)
	&CteChv = CteChv

    Exit
EndFor

&nomeArquivo 	= &CteChv.Trim() + '-' + padL(trim(str(&CteEveCod)),2,'0') 
&ID 			= 'ID110180' + &CteChv + padL(trim(str(&CteEveCod)),2,'0')
&IdLote 		= trim(str(&FilCod)) + trim(str(&CteCod)) + trim(str(&CteEveCod))

&ano = str(YEAR(&hoje))
&mes = str(MONTH(&hoje))
&dia = str(DAY(&hoje))
&hojeHora = TAdd(servernow(), -100)

&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hojeHora))),2, '0') + ':00'
&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + trim(&nomeArquivo) + '-ped-eve.xml'

&ArqNota.Open(&Nome_enviar)

// START DOC xml
&ArqNota.WriteStartDocument(Encoding.UTF_8)
&ArqNota.WriteStartElement('eventoCTe')
&ArqNota.WriteAttribute('versao', &VersaoNF)
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/cte')

&ArqNota.WriteStartElement('infEvento')
&ArqNota.WriteAttribute('Id', &ID)
&ArqNota.WriteElement('cOrgao', &cUF)
&ArqNota.WriteElement('tpAmb',&FilAmbEms)
If &FilCpj.Trim().Length() > 11
	&ArqNota.WriteElement('CNPJ', &FilCpj)
Else
	&ArqNota.WriteElement('CPF', &FilCpj)
EndIf
&ArqNota.WriteElement('chCTe', &CteChv)

&ArqNota.WriteElement('dhEvento',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' + &hora + '-' + trim(&FilFusHor))
&ArqNota.WriteElement('tpEvento', '110180')
&ArqNota.WriteElement('nSeqEvento',trim(str(&CteEveCod)))
&ArqNota.WriteStartElement('detEvento')
&ArqNota.WriteAttribute('versaoEvento', &VersaoNF)
&ArqNota.WriteStartElement('evCECTe')
&ArqNota.WriteElement('descEvento','Comprovante de Entrega do CT-e')

For each Order EmpCod, FilCod, CteCod, CteEveCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteEveCod = &CteEveCod
	&ano = str(YEAR(CteEveDtaEnt))
	&mes = str(MONTH(CteEveDtaEnt))
	&dia = str(DAY(CteEveDtaEnt))
	&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hojeHora))),2, '0') + ':'+PadL(trim(str(Second(&hojeHora))),2, '0')
	
	&ArqNota.WriteElement('nProt',trim(CteAutNumPro))
    &ArqNota.WriteElement('dhEntrega',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' +&hora+'-'+&FilFusHor)
    &ArqNota.WriteElement('nDoc',trim(CteEveDoc))
	&ArqNota.WriteElement('xNome',trim(CteEveNom))
//	&ArqNota.WriteElement('latitude','')
//	&ArqNota.WriteElement('longitude','')
	&MyBase64EncodedString = ToBase64(&CteChv)
	&CryptoHash.Algorithm = CryptoHashAlgorithm.SHA1 //&CryptoHash is of CryptoHash type.
	&resultstringSHA1 = &CryptoHash.Compute(&MyBase64EncodedString) 
	&ArqNota.WriteElement('hashEntrega',trim(&resultstringSHA1))
	&ArqNota.WriteElement('dhHashEntrega',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' +&hora+'-'+&FilFusHor)
	
	For each Order EmpCod, FilCod, CteCod, CteEveCod,CteEveChv
		&ArqNota.WriteStartElement('infEntrega') ///infEntrega
		&ArqNota.WriteElement('chNFe',CteEveChv)
		&ArqNota.WriteEndElement()//infEntrega
	EndFor

EndFor

&ArqNota.WriteEndElement()
&ArqNota.WriteEndElement()
&ArqNota.WriteEndElement()
&ArqNota.Close()

wpAutorizaCCeRecepcaoCte.Link(&EmpCod, &FilCod, &CteCod, &CteCceCod, &SolCod)
]]></Source>
