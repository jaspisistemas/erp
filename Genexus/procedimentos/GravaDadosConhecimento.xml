      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where LctAtuSal = &LctAtuSal
	
	if PedCnhEms.IsEmpty()
		If not &FrtDtaEms.IsEmpty()
			PedCnhEms = &FrtDtaEms 
		Else
			PedCnhEms = serverdate()
		EndIF
	EndIF
	
	PedCnhVlr = &PedCnhVlr
	PedCnhFrt = &PedCnhFrt
	PedCnhTraCod = &PedCnhTraCod
	Exit
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
