      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &PedTmpDupCod <> 0
	For Each Order EmpCod, FilCod, PedCod, PedTmpDupCod	
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedTmpDupCod = &PedTmpDupCod
		
		PedTmpDupNro = &PedTmpDupNro
		PedTmpFrpPgtoCod = &PedTmpFrpPgtoCod
		PedTmpDupVct = &PedTmpDupVct
		//PedTmpPrz
		PedTmpDupVlr = &PedTmpDupVlr
		//		PedTmpDupTxa
		//		PedTmpDupBanCarCod
		//		PedTmpDupCreDeb
		//		PedTmpDupCarArqc
		//		PedTmpDupCarNroAut
		//		PedTmpDupCarJur
		//		PedTmpDupCarDes
		PedTmpDupCbrCod = &PedTmpDupCbrCod
		PedTmpCtaBanCod = &CtabanCod
		PedTmpDtaPag = &MovDtaCon
		PedTmpPlanCod = &PlanCod
		PedTmpCreCliCod = &CreCliCod
		PedTmpObs = &DinMovCplMan
		Exit
	EndFor
Else
	For each order EmpCod,FilCod,PedCod,(PedTmpDupCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedTmpDupCod = PedTmpDupCod
		Exit
	EndFor
	
	&PedTmpDupCod += 1
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedTmpDupCod = &PedTmpDupCod
		//PedTmpRenOriCod = &CreRenOriCod  //ACHO QUE NAO VO USAR :(
		//PedTmpCreCod
		PedTmpDupNro = 'REN' + trim(str(&PedTmpDupCod))
		PedTmpFrpPgtoCod = &PedTmpFrpPgtoCod
		PedTmpDupVct = &PedTmpDupVct
		//PedTmpPrz
		PedTmpDupVlr = &PedTmpDupVlr
		//		PedTmpDupTxa
		//		PedTmpDupBanCarCod
		//		PedTmpDupCreDeb
		//		PedTmpDupCarArqc
		//		PedTmpDupCarNroAut
		//		PedTmpDupCarJur
		//		PedTmpDupCarDes
		PedTmpDupCbrCod = &PedTmpDupCbrCod
		PedTmpCtaBanCod = &CtabanCod
		PedTmpDtaPag = &MovDtaCon
		PedTmpSts = Status_SimNao.Nao
		PedTmpPlanCod = &PlanCod
		
		PedTmpObs = &DinMovCplMan
		PedTmpCreCliCod = &CreCliCod
		//PedTmpNovCliRaz
		//PedTmpBanCod
		//PedTmpAgeCod
		//PedTmpConCod
		//PedTmpTitNom
		//PedTmpTitCpf
		//PedTmpTitRg
		//PedTmpTitFon
		//PedTmpObs
		//PedTmpDtaEms
	Endnew	
Endif

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
