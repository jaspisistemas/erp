      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&XmlReader.OpenFromString(&CteCCeArqXml)
&ret = &XmlReader.ReadType(1, 'retEventoCTe') 
if &ret <> 0
	&XmlReader.Read()
	
	//	LEITURA XML
	Do while &XmlReader.Name <> 'retEventoCTe'
		Do Case
			Case &XmlReader.Name = 'infEvento'
				&XmlReader.Read() //Avanca para o primeiro campo da tag...
				Do 'infEvento'
		EndCase
		
		&XmlReader.Read()		
		if &XmlReader.EOF
			Exit
		endif
	EndDo
EndIf

&XmlReader.close()


//IDENTIFICACAO
Sub 'infEvento'
	Do while &XmlReader.Name <> 'infEvento'
		Do Case 
			Case &XmlReader.Name = 'tpAmb'
				&SdtXmlCteCce.tpAmb = &XmlReader.Value	
			Case &XmlReader.Name = 'cStat'
				&SdtXmlCteCce.cStat = &XmlReader.Value
			Case &XmlReader.Name = 'xMotivo'
				&SdtXmlCteCce.XMotivo = &XmlReader.Value
			Case &XmlReader.Name = 'chCTe'
				&SdtXmlCteCce.chCTe = &XmlReader.Value
			Case &XmlReader.Name = 'tpEvento'
				&SdtXmlCteCce.tpEvento = &XmlReader.Value			
			Case &XmlReader.Name = 'nSeqEvento'
				&SdtXmlCteCce.NSeqEvento = &XmlReader.Value
			Case &XmlReader.Name = 'dhRegEvento'
				&SdtXmlCteCce.dhRegEvento = &XmlReader.Value
			Case &XmlReader.Name = 'nProt'
				&SdtXmlCteCce.nProt = &XmlReader.Value
		EndCase

		&XmlReader.Read()
		if &XmlReader.EOF
			Exit
		endif		
		
	EndDo
EndSub

]]></Source>
