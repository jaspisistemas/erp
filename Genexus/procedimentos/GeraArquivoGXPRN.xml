      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&NomArq = &SdtConfiguracoesPasta.PastaDiretorioTempFis + 'GXPRN.INI'
&link = &SdtConfiguracoesPasta.PastaDiretorioTempVir + 'GXPRN.INI'

&file.source = &NomArq
if &File.Exists()
	&File.Delete()
EndIf
&File.Close()

&ResultadoAbertura = DfwOpen(&NomArq,'','', 0, 'ISO-8859-1') 

&Gravar = '[General_Config_info]'
do 'gravaArquivo'
&Gravar = 'Version=3'
do 'gravaArquivo'
&Gravar = 'CheckPaperSize=0'
do 'gravaArquivo'
&Gravar = 'XOffset=0'
do 'gravaArquivo'
&Gravar = 'YOffset=0'
do 'gravaArquivo'

For &sdtImpressorasSelecionadasItem in &sdtImpressorasSelecionadas
	for Each Order EmpCod, EmpImpCod
		Where EmpCod = &EmpCod
		Where EmpImpCod = &sdtImpressorasSelecionadasItem.EmpImpCod
		&Gravar = '['+EmpImpTip+']'
		do 'gravaArquivo'
		&Gravar = 'Printer='+EmpImpNom
		do 'gravaArquivo'
		&Gravar = 'Mode=1'
		do 'gravaArquivo'
		&Gravar = 'Orientation=1'
		do 'gravaArquivo'
		&Gravar = 'PaperSize=9'
		do 'gravaArquivo'
		&Gravar = 'Scale=100'
		do 'gravaArquivo'
		&Gravar = 'Copies=1'
		do 'gravaArquivo'
		&Gravar = 'DefaultSource=15'
		do 'gravaArquivo'
		&Gravar = 'PrintQuality=600'
		do 'gravaArquivo'
		&Gravar = 'Color=1'
		do 'gravaArquivo'
		&Gravar = 'Duplex=1'
		do 'gravaArquivo'
		&Gravar = 'XOffset=0'
		do 'gravaArquivo'
		&Gravar = 'YOffset=0'
		do 'gravaArquivo'
		exit
	EndFor
EndFor

&ResultadoAbertura = dfwclose()

link(&link)

sub 'gravaArquivo'
	&ResultadoNext=  dfwptxt(&Gravar,400)                          // Grava Linha 
	&ResultadoNext = dfwnext()                                         // Próxima Linha
EndSUb

]]></Source>
