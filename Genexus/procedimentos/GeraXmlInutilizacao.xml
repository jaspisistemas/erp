      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&HojeData = serverdate()
&Ano = substr(str(year(&HojeData),4,0),3,2) 

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&CNPJ = retornaSoNumeros.Udp(FilCpj)
	&FilCidUfeCod = RetornaCodigoSiglaEstado.UDP(0, FilCidUfeCod)
	Exit
EndFor

&Serie = val(&NfeSer)
GravaInutilizacao.Call(&EmpCod, &FilCod,0, &FilInuCod, &Ano, &FilInuNroIni, &FilInuNroFin, &ModCod, &Serie, '', '', &PesCod, Status_NFe.Digitando)

GravaSolicitacao.Call(&EmpCod, &FilCod, &FilInuCod, 0, TipoSolicitacao.Inutilizar_NFE, &PesCod, &SolCod)

RetornaVersaoNotas.Call(VersaoNota.VersaoNFe_4, &VersaoNF)

&id = &FilCidUfeCod+ &ano + PadL(&CNPJ, 14, '0') + &ModCod + padl(trim(&NfeSer),3,'0') + padl(trim(str(&FilInuNroIni,9,0)),9,'0')+padl(trim(str(&FilInuNroFin,9,0)),9,'0')

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() +trim(&id)+'-ped-inu.xml'
&Chave = 'ID'+ &id.Trim()

//Abrir o arquivo XML
&XmlWriter.Open(&Nome_enviar)

//Start no Documento
&XmlWriter.WriteStartDocument('UTF-8')

&XmlWriter.WriteStartElement('inutNFe')
&XmlWriter.WriteAttribute('versao', &VersaoNF)
&XmlWriter.WriteAttribute('xmlns', 'http://www.portalfiscal.inf.br/nfe')

&XmlWriter.WriteStartElement('infInut')
&XmlWriter.WriteAttribute('Id',&Chave)

&XmlWriter.WriteElement('tpAmb',&sdtConfiguracoesPasta.FilAmbEms)
&XmlWriter.WriteElement('xServ','INUTILIZAR')
&XmlWriter.WriteElement('cUF',&FilCidUfeCod)
&XmlWriter.WriteElement('ano',&Ano)

&XmlWriter.WriteElement('CNPJ',padl(&CNPJ,14,'0'))

&XmlWriter.WriteElement('mod',&ModCod)
&XmlWriter.WriteElement('serie',&NfeSer)

&XmlWriter.WriteElement('nNFIni',&FilInuNroIni)
&XmlWriter.WriteElement('nNFFin',&FilInuNroFin)

&XmlWriter.WriteElement('xJust',&xJust.Trim())

&XmlWriter.WriteEndElement()
&XmlWriter.WriteEndElement()
&XmlWriter.Close()

wpInutilizaNumeroRecepcao.Link(&DeOndeVem, &EmpCod, &FilCod, &FilInuCod, &SolCod)
]]></Source>
