      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TotalDuplicatas = 0
&TotalDinheiro = 0

//TOTAL DE DUPLICATAS, CHEQUES, CARTAO
For Each Order EmpCod, FilCod, CrePedCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
    Where CrePedCod = &PedCod
	Where CreSts <> Status_Duplicata.CANCELADA
	
	If CreFrpPgtoTip = TipoDuplicata.DINHEIRO
	    &TotalDinheiro += CreVlrDup
	Else
	    &TotalDuplicatas += CreVlrDup
	EndIF
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
