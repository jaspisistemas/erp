      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&PedCriCod = 0
For Each Order EmpCod, FilCod, PedCod, (PedCriCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&PedCriCod = PedCriCod
	Exit
EndFor
&PedCriCod += 1

new
	EmpCod = &EmpCod
	FilCod = &FilCod
	PedCod = &PedCod
	PedCriCod = &PedCriCod
	PedCriTip = &PedCriTip
	PedCriDtaHor = serverNow()
	PedCriFunCod = &PesCod
EndNew

commit
]]></Source>
