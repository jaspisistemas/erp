      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

If &CteCCeCod = 0
	For Each Order EmpCod, FilCod, CteCod, (CteCCeCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&auxCteCCeCod = CteCCeCod
		exit
	EndFor
	&auxCteCCeCod += 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteCCeCod = &auxCteCCeCod
		CteCCeDta = &CteCCeDta
		CteCCeHor = &CteCCeHor
		CteCCeSts = Status_Nfe.Digitando
	EndNew
	
	Commit
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteCCeCod = &auxCteCCeCod
		CteCCeInfCod = 1
		CteCCeGrp    = &CteCCeGrp
		CteCCeCam    = &CteCCeCam
		CteCCeVlr    = &CteCCeVlr
	EndNew
	Commit
	
Else

	For Each Order EmpCod, FilCod, CteCod, CteCCeCod,(CteCCeInfCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteCCeCod = &CteCCeCod
		&CteCCeInfCod = CteCCeInfCod
		exit
	EndFor

	&CteCCeInfCod+=1

	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteCCeCod = &CteCCeCod
		CteCCeInfCod = &CteCCeInfCod
		CteCCeGrp    = &CteCCeGrp
		CteCCeCam    = &CteCCeCam
		CteCCeVlr    = &CteCCeVlr
	EndNew 

	commit
EndIf




]]></Source>
