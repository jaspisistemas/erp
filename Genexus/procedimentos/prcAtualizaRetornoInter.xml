      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where CreCbrCtaBanBanCod = '077'
	Where CreRecPag = ReceberPagar.Receber
	Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
	Where CbrTipBol = TipoBoleto.Hibrido
	where CrbRegAut = Status_SimNao.Sim
	Where CreVlrSdo = CreVlrDup
	Where CreDtaVct >= serverdate()
	Where not CreDtaRet.IsEmpty() and not CreDtaRet.IsNull()
	Where CreBloNro.IsEmpty() or CreBloNro.IsNull()
	Where not CreCodSol.IsEmpty() and not CreCodSol.IsNull()
	
	&CreCbrCtaBanCrt = trim(CreCbrCtaBanCrt)+trim(CreCbrCtaBanCrtDig)
	prcRecuperarCobranca_Inter.Call(EmpCod, FilCod, &PesCod, CreCbrCod, CreCbrChaTra, &CreCbrCtaBanCrt, CreCodSol, &RecuperarMensagem, &SdtRecuperarCobranca_Inter)
	If &RecuperarMensagem.IsEmpty()
		prcAtualizaDadosRetorno_Inter.Call(EmpCod, CreCod, &SdtRecuperarCobranca_Inter)
	EndIf
	
Endfor
]]></Source>
