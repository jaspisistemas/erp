      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,CteCod,CtePreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod 
	Where CtePreCod = &GridCtePreCod
	CteVlrPreCom 	= &GridCteVlrPreCom
	CteNomPreCom 	= &GridCteNomPreCom
	CteDesIcmsCom 	= &CteDesIcmsCom
	CtePrePagCom	= &CtePrePagCom //Pagar comissão?
	exit
EndFor

commit

AtualisaBaseCalculoCte.Call(&EmpCod,&FilCod,&CteCod)
]]></Source>
