      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaSoNumeros.Call(&parCpfCnpj, &CpfCnpj)
If not &CpfCnpj.IsEmpty()
	For each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where CteSts = Status_NFe.Importada
		Where CteTomCod.IsEmpty() or CteTomCod.IsNull() or CteDesCod.IsNull() or CteDesCod.IsEmpty()
		
		&CteDesCnpj = RetornaSonumeros.Udp(CteTomCnpj)
		if &CteDesCnpj.IsEmpty()
			&CteDesCnpj = RetornaSonumeros.Udp(CteTomCpf)
		Endif
		if &CteDesCnpj = &CpfCnpj
			CteTomCod = &PesCod
		Endif
		
		 &CteDesCnpj = RetornaSonumeros.Udp(CteDesCnpj)
		if &CteDesCnpj.IsEmpty()
			&CteDesCnpj = RetornaSonumeros.Udp(CteDesCpf)
		Endif
		if &CteDesCnpj = &CpfCnpj
			CteDesCod = &PesCod
		Endif
		
	ENdFOr
	
	
	commit
EndIf
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
