      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtClientes.Clear()
&AuxPesFonNum = retornaSoNumeros.Udp(&AuxPesquisa)
&AuxPesFonNum1 = FormataFONE.Udp(&AuxPesquisa)

If not &AuxPesFonNum.IsEmpty()
	
	&NewFon = '%' + trim(&AuxPesquisa) + '%'
	&NewFon = &NewFon.Replace(' ', '%')
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where (PesFonNum like &AuxPesFonNum1) or (PesFonNum = &AuxPesFonNum1) or (PesFonNum like &NewFon)
		&sdtClientesItem = new()
		&sdtClientesItem.PesCod = PesCod
		&sdtClientesItem.PesRaz = PesRaz
		&sdtClientesItem.PesCodRaz = PesCodRaz
		&sdtClientesItem.PesSts = PesSts
		&sdtClientesItem.Localizou = PesFonNum
		&sdtClientes.Add(&sdtClientesItem)	
		
		if &sdtClientes.Count > 50
			Exit
		Endif
	EndFor
EndIF

if not &AuxPesquisa.IsEmpty()
	&PEsRaz = &AuxPesquisa.Replace(' ', '%')
	For Each Order EmpCod, PesRaz
		Where EmpCod = &EmpCod
		Where PesRaz like '%'+&PEsRaz when &PEsRaz.Length() > 4
		Where PesRaz like &PEsRaz when &PEsRaz.Length() <= 4
		
		&sdtClientesItem = new()
		&sdtClientesItem.PesCod = PesCod
		&sdtClientesItem.PesRaz = PesRaz
		&sdtClientesItem.PesCodRaz = PesCodRaz
		&sdtClientesItem.PesSts = PesSts
		&sdtClientesItem.Localizou = PesPrmFon
		&sdtClientes.Add(&sdtClientesItem)	
		
		if &sdtClientes.Count > 50
			Exit
		Endif
	EndFor
Endif
]]></Source>
