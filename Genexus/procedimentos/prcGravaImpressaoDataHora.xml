      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, EmpImpCod
	Where EmpCod = &EmpCod
	Where EmpImpCod = &EmpImpCod
	&FIimpPC = EmpImpPC
	&EmpImpTip = EmpImpTip
	&EmpImpNom = EmpImpNom
	
	Exit
EndFor

&FIcod = 0
For Each ORder FIempCod, (FIcod)
	where FIempCod = &EmpCod
	&FIcod = FIcod
	Exit
EndFor
&FIcod += 1

new
	FIempCod 	= &EmpCod
	FIcod 		= &FIcod
	
	FIimpPC 	= &FIimpPC //Monitor
	FIimpTip	= &EmpImpTip //tipo CUPOM, Matricial
	FIimpNom    = &EmpImpNom //Nome da impressora
	
	FIsts 		= 'P' //PENDENTE
	FImsg 		= ''
	FIrelNam 	= &FIrelNam
	FiFilCod 	= &FiFilCod
	FiPedCod 	= &FiPedCod
	FiUsuCod    = &FiUsuCod
	FirelInfAdi	= &FirelInfAdi
	FiNfeCod 	= &FiNfeCod
	FiDtaIni 	= &FiDtaIni
	FiDtaEms    = &FiDtaEms
	
EndNEw

Commit
]]></Source>
