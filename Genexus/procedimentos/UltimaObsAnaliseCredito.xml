      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For each Order EmpCod, FilCod, (PedCod)
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	where PedCliCod = &PedCliCod
	Where PedCod <> &PedCod
	Where not PedObsAna.IsEmpty()
	&PedObsAna = PedObsAna
	
	Exit
Endfor
]]></Source>
