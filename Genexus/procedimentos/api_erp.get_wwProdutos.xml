      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	&wwProdutos.temMais = 'N'
	&wwProdutos.qtd = 0
	
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwProdutos.pA = '0'
	&wwProdutos.pT = '0'
	&wwProdutos.p1 = '0'
	&wwProdutos.p2 = '0'
	&wwProdutos.p3 = '0'
	&wwProdutos.p4 = '0'
	&wwProdutos.p5 = '0'
	&IsPaginaOk = false
	
	if not &VarProSts.IsEmpty() and not &VarProSts = 'T'
		&ProSts.FromString(&VarProSts)
	Endif

	For Each ORder EmpCod, ProNom
		Where EmpCod = &wwpContext.EmpCod
		Where ProNom like &ProNom or ProBar like &ProNom or ProRef like &ProNom or (ProBarRef_Comp like '%*'+&ProNom)  when not &ProNom.IsEmpty()
		Where ProRef = &ProRef when not &ProRef.IsEmpty()
		Where ProSts = &ProSts when not &VarProSts = 'T' and not &VarProSts.IsEmpty()
		Where ProSts <> Status_Produto.EXCLUIDO when &VarProSts = 'T'
		Where MarCod = &MarCod when not &MarCod.IsEmpty()
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwProdutos.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				
				&wwProdutos.qtd += 1
				
				&wwProdutosItem = New()
				&wwProdutosItem.Cod = ProCod
				&wwProdutosItem.Ref = ProRef
				&wwProdutosItem.Nom = ProNom
				&wwProdutosItem.MarN = MarNom
				&wwProdutosItem.Sts = ProSts
				
				&wwProdutos.Item.Add(&wwProdutosItem)
			Endif
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
	
	When none
		&wwProdutos.temMais = 'X'
		&wwProdutos.qtd = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwProdutos.pA = trim(str(&Pagina))
		&wwProdutos.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwProdutos.p1, &wwProdutos.p2, &wwProdutos.p3, &wwProdutos.p4, &wwProdutos.p5)
		
	Endif

	For &wwProdutosItem in &wwProdutos.item
		RetornaImagemPrincipal180_imguri.Call(&wwpContext.EmpCod, &wwProdutosItem.Cod, TipoImagemProduto.IMAGEM_VENDA, &ProImg180, &wwProdutosItem.ImgUrl, &IsSemImagem)
	EndFor


Endif



]]></Source>
