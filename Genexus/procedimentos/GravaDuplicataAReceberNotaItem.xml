      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &TCon044_PlanoRecCliente)
RetornaCodigoPlanoContas.Call(&EmpCod, &TCon044_PlanoRecCliente, &PlanCod)

For Each Order EmpCod, FilCod, CreCod //Duplicatas
	Where EmpCod = &EmpCod
	Where FilCod = &NfeDupFilCod
	Where CreCod = &NfeDupCreCod and &NfeDupCreCod <> 0 //ja cadastradas
	Where CreSts <> Status_Duplicata.CANCELADA			
	
		&NfeDupCreCod = CreCod
		
		if CreAdmCod.IsEmpty() or CreAdmCod.IsNull() //POR HORA FIZ ISSO. POIS AS NOTAS EMITIDAS AUTOMATICAS DO ADM NAO DEVEM SER ALTERADAS. JDF
			
			CrePedCod = &PedCod
			CreFilPgt = &FilCod
			
			CreCliCod = &PedCliCod
			CreVenCod = &PedVenCod
			CreDtaVct = &NfeDupVct
			CreCbrCod = &NfeCbrCod
			CreDupNro = &NfeDupNro
			if not &NfeDtaEms.IsEmpty()
				CreDtaEms = &NfeDtaEms
			EndiF
			
			if CreVlrDup = CreVlrSdo
				CreVlrDup = &NfeDupVlr
				CreVlrSdo = &NfeDupVlr
			EndIF
			
			CreRecPag = ReceberPagar.Receber
			CrePlanCod = &PlanCod
		Endif
	
		//CreAbvDup = RetornaTipoOrigemDuplicata.udp(EmpCod, FilCod, CrePedCod, CreRenDstCod, CreFrtCod, CreNfeCod)
	Exit
When None
	UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &NfeDupFilCod, &NfeDupCreCod)
	
	new            
		EmpCod = &EmpCod			
		FilCod = &NfeDupFilCod
		CreCod = &NfeDupCreCod
		
		CreFilPgt = &FilCod
		CreRecPag = ReceberPagar.Receber
		CreCliCod = &PedCliCod
		CreDupNro = &NfeDupNro
		
		if &NfeDtaEms.IsEmpty()
			CreDtaEms = serverdate()
		Else
			CreDtaEms = &NfeDtaEms		
		EndiF
		
		CreVlrDup = &NfeDupVlr
		CreVlrSdo = &NfeDupVlr
		CreDtaVct = &NfeDupVct
		CreCbrCod = &NfeCbrCod		
		CrePedCod = &PedCod
		
		Do Case
			Case &Tipo = 'NFE'
				CreNfeCod = &NfeCod
				CreNfeFilCod = &FilCod
				CreOriDup = OrigemDuplicata.FechamentoNota
			Case &Tipo = 'CTE'
				CreCteCod = &NfeCod
				CreCteFilCod = &FilCod
				CreOriDup = OrigemDuplicata.ConhecimentoFrete
		EndCase
		
		CreBloNro = '' 
		CreVenCod = &PedVenCod
		CreFrpPgtoCod= &CreFrpPgtoCod
		CreSts = Status_Duplicata.ATIVO
		CrePlanCod = &PlanCod
	EndNew

EndFor

commit

AtualizaSaldoDuplicata.Call(&EmpCod, &NfeDupCreCod, &NfeDupFilCod)
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
