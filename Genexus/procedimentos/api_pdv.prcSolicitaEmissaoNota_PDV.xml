        <Source><![CDATA[


&tmpNFeCod = trim(str(&EmpCod)) + trim(Str(&FilCod)) + trim(str(&PedCod))
GravaNotaTemporariaVenda_PDV.Call(&EmpCod, &FilCod, &PedCod, '65')

//agora grava CPF na nota

if not &PesCpf.IsEmpty() or not &PesCnpj.IsEmpty()
	GravaClienteTemporariaModelo65.Call(&tmpNFeCod, &PesTip, &PesCnpj, &PesCpf, &PesRaz)
EndIf

GravaNotaFiscalModelo65_PDV.Call(&EmpCod, &FilCod, &PedCod, &tmpNFeCod, &NfeGuid, &NfeCod)
]]></Source>
