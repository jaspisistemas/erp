      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SDT_PessoaTelefones.Clear()

For each order EmpCod, PesCod, PesFonCod
	where EmpCod = &EmpCod
	where PesCod = &PesCod
	
	&SDT_PessoaTelefonesItem = new()
	&SDT_PessoaTelefonesItem.IsEnviar = iif(PesFonTpo = TipoTelefone.CELULAR_WHATS, true, false)
	&SDT_PessoaTelefonesItem.PesFonCod = PesFonCod
	&SDT_PessoaTelefonesItem.PesFonNum = PesFonNum
	&SDT_PessoaTelefonesItem.PesFonCon = PesFonCon
	
	&SDT_PessoaTelefonesItem.PesFonWhatsBol = PesFonWhatsBol
	&SDT_PessoaTelefonesItem.PesFonWhatsFat = PesFonWhatsFat
	&SDT_PessoaTelefonesItem.PesFonWhatsPed = PesFonWhatsPed
	
	&SDT_PessoaTelefones.Add(&SDT_PessoaTelefonesItem)
EndFor

]]></Source>
