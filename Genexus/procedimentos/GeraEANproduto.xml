      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	
	ValidaEan13.Call(ProCod, '', &ProBar, &ErroEan13Mensagem)
	ValidaCodigoReferenciaRepetido.Call(EmpCod, ProCod, 1, &ProBar, &ErroEan13Mensagem)
	do While Not &ErroEan13Mensagem.IsEmpty()
		&Codigo8 = Random() * 100000000
		&ProBar =  '333' + padL(trim(str(&Codigo8)), 9, '0')
		digitoEAN13.Call(&ProBar, &ProBar)
		ValidaCodigoReferenciaRepetido.Call(EmpCod, ProCod, 1, &ProBar, &ErroEan13Mensagem)
	EndDo

	ProBar = &ProBar
	Exit
EndFor

Commit
]]></Source>
