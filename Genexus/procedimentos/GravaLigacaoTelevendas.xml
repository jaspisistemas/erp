      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&HojeDataHora = serverNow()
&sdtVinculos = RetornaVinculos.Udp(&EmpCod, &PesCod)

For &sdtVinculosItem in &sdtVinculos
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &sdtVinculosItem.PesCod
		&PesVinCod = &sdtVinculosItem.PesCod
		
		&PesSacCod = 0
		&PesSacCod = PesSacCodMax
		If &sdtVinculosItem.PesCod <> &PesCod
			&auxPesSacDlg = 'AUT.VINCULO.PESSOA:'+ trim(str(&PesCod)) + ' ' + &PesSacDlg.Trim()
		Else
			&auxPesSacDlg = &PesSacDlg
		EndIF
		
		do 'GravaNovoDialogo'
		Exit
	EndFor
EndFor

commit

For &sdtVinculosItem in &sdtVinculos
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &sdtVinculosItem.PesCod
		
		PesPrxLig = RetornaUltimaLigacaoAgendada.Udp(EmpCod, PesCod, 'I')
		PesPrxVis = RetornaUltimaLigacaoAgendada.Udp(EmpCod, PesCod, 'E')
		
		If &PesSacIsVen = true and &PesVenIntExt = Status_InternoExterno.INTERNO and &PesSacTipObs = 'I'
			//EH VENDEDOR INTERNO QUE FEZ O COMENTARIO, ganha o cliente
			PesIntVenCod = &VenPesCod
		EndIF
		If &PesSacIsVen = true and &PesVenIntExt = Status_InternoExterno.EXTERNO and &PesSacTipObs = 'E'
			//EH VENDEDOR EXTERNO QUE FEZ O COMENTARIO, ganha o cliente
			PesExtVenCod = &VenPesCod
		EndIF
	EndFor
	
EndFor

Commit


Sub 'GravaNovoDialogo'
	&PesSacCod += 1
	New
		EmpCod = &EmpCod
		PesCod = &PesVinCod
		PesSacCod = &PesSacCod
		PesSacDta = &HojeDataHora
		PesSacPrxLig = &PesSacPrxLig
		PesSacDlg = &auxPesSacDlg
		PesSacVenCod = &VenPesCod	
		PesSacFunCod = &PesSacFunCod
		PesSacTipObs = &PesSacTipObs
	EndNEw
EndSUb
]]></Source>
