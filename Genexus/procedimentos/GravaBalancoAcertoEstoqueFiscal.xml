      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon031_TipoLctoBalanco, &TCon031_TipoLctoBalanco)
&LctCod = iif(&TCon031_TipoLctoBalanco.IsEmpty(), 0, Val(&TCon031_TipoLctoBalanco))

&NfeCod.SetEmpty()
&Balsts = Status_Pedido.ABERTO

//LOCaliza Balanco feito Data de Hoje
//balanco Automatico
For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalFunCod = -1
	Where BalObs = 'AJUSTE ESTOQUE / CUSTO / VENDA'
	Where BalDta = serverdate()
	Where BalTip = TipoBalanco.Fiscal
	&BalCod = BalCod
	&NfeCod = BalNfeCod
	&Balsts = BalSts
	
	Exit
EndFor

if &BalCod.IsEmpty()
	UltimoCodigoEmpresa.Call(domParCod.BALANCO, &EmpCod, &FilCod, &BalCod)
	
	//gravaBalanco
	New
		EmpCod = &EmpCod
		BalCod = &BalCod
		FilCod = &FilCod
		BalFunCod = -1
		BalDta = serverdate()
		BalObs = 'AJUSTE ESTOQUE / CUSTO / VENDA'
		BalSts = Status_Pedido.ABERTO
		BalStsPrc = AtualizandoEstoquePedido.Aberto
		BalTip = TipoBalanco.Fiscal
		BalNfeCod = 0
	EndNew
	
	Commit
	
	//Grava item Balanco
	GravaProdutoBalanco.Call(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod, &BalQtd, &InseridoMensagem, &AtualizadoMensagem)
Else
	if &Balsts <> Status_Pedido.ABERTO
		AtualizaEstoqueFiscal.Call(&EmpCod, &FilCod, &NfeCod, Status_nFe.Cancelada)
	EndIf
	
	//Grava item Balanco
	GravaProdutoBalanco.Call(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod, &BalQtd, &InseridoMensagem, &AtualizadoMensagem)
EndiF


For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	&PedCliCod = 1
	if FilPesCod > 0 
		&PedCliCod = FilPesCod
	EndiF

	&BalDta = BalDta
	&FilTabCod = FilTabCod
	
    BalSts = Status_Pedido.FECHADO
	BalStsPrc = AtualizandoEstoquePedido.fechado
	&NfeCod = BalNfeCod
	if BalNfeCod = 0
		UltimoCodigoEmpresa.Call(domParCod.NOTAFISCAL, &EmpCod, &FilCod, &NfeCod)
		BalNfeCod = &NfeCod
	EndIF
	
    do 'addCapaPedido'
	
	For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&ProVlrCus = ProVlrCus
		&EstQtd = EstQtdFis
		&BalOrd = BalOrd
		
		do 'InsereItem'
    EndFor
EndFor

commit
 
AtualizaTotaisNFe.Call(&EmpCod, &FilCod, &NfeCod, 0)

AtualizaEstoqueFiscal.Call(&EmpCod, &FilCod, &NfeCod, Status_nFe.Autorizada)

//For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
//	Where EmpCod = &EmpCod
//	Where FilCod = &FilCod
//	Where BalCod = &BalCod
//	
//	EstProStsBal = retornaProdutoBalanco.Udp(EmpCod, FilCod, ProCod, ProGraCod)
//EndFor

//commit


Sub 'InsereItem'
	For Each Order EmpCod, FilCod, NfeCod, (NfeItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		&NfeItmCod = NfeItmCod
		Exit
	EndFor

	&NfeItmCod += 1
    &Diferenca = (&BalQtd - &EstQtd)
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		NfeCod = &NfeCod
		NfeItmCod = &NfeItmCod
		NfeProCod = &ProCod
		NfeProGraCod = &ProGraCod

		NfeProQtd    = &Diferenca
		NfeProVlrUnt = &ProVlrCus
	EndNew
EndSub


Sub 'addCapaPedido'
	for Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
			
			NfeDtaEms = &BalDta
			NfeProTer = Nota_ProPriaTerceira.BALANCO
			NfeSts = Status_nfe.Autorizada
			NfeCliCod = &PedCliCod
			NfeLctCod = &LctCod
			NfeDtaFat = &BalDta
			NfeTipFrt = TipoFrete.SemFrete
			
			for Each Order EmpCod, FilCod, NfeCod, NfeItmCod
				Where NfeProCod = &ProCod
				Where NfeProGraCod = &ProGraCod
				Delete
			EndFor
		Exit
	When none
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			NfeCod = &NfeCod
			
		    NfeDtaEms = &BalDta
			NfeProTer = Nota_ProPriaTerceira.BALANCO
			NfeSts = Status_nfe.Autorizada
			NfeCliCod = &PedCliCod
			NfeLctCod = &LctCod
			NfeDtaFat = &BalDta
			NfeTipFrt = TipoFrete.SemFrete
		EndNew
		
		commit
	EndFOr

EndSub
]]></Source>
