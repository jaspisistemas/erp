      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[ 
&AuxParEntrada = RetornaSoNumeros.Udp(&ParEntrada)

if Substr(&ParEntrada,1,1) = '+'
	&ParSaida = &ParEntrada
Else
	If &AuxParEntrada <> ''
		If &AuxParEntrada.Length() = 10 //(44) 9976-1894
			&ParSaida = '(' + Substr(&AuxParEntrada, 1, 2) + ') ' +
			Substr(&AuxParEntrada, 3, 4) 
			
			if &ParSaida.Length() = 9
				&ParSaida += '-' + Substr(&AuxParEntrada, 7, 4)
			EndIF
			
		Else //(44) 29976-1894
			&ParSaida = '(' + Substr(&AuxParEntrada, 1, 2) + ') ' +
			Substr(&AuxParEntrada, 3, 5)
			
			if &ParSaida.Length() = 10
				&ParSaida += '-' + Substr(&AuxParEntrada, 8, 4)
			EndIf
			
		EndIf
	EndIF
Endif
]]></Source>
