      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For each Order EmpCod,CtabanCod,FecSts,(FecCod) //pega o ultimo fechamento da conta
	Where EmpCod = &EmpCod
	Where CtabanCod = &CtaBanCod
	Where FecCod < &ResFecCod	when &ResFecCod <> 0
	Where FecSts = FechaAbre.FecharNOVO
	Where FecStsLct = FechaAbre.FecharNOVO or FecStsLct = FechaAbre.Fechar
	
	&FecDta = FecDta
	if FecStsLct = FechaAbre.FecharNOVO 
		&SaldoAnterior = FecVlrFin
	else
		do 'TabelaSaldo'
	Endif
	
	DO 'SomaDebitoCredito'
	
	Exit
when none
	&FecDta = &DataSaldo
	do 'TabelaSaldo'
	DO 'SomaDebitoCredito'
EndFor


Sub 'TabelaSaldo'
	
	For each Order EmpCod,CtabanCod,(SdoDta)
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtabanCod
		Where SdoDta <= &FecDta
		&AuxFecDta = &FecDta
		&SaldoAnterior = SdoAnt
		&Creditos = SdoEnt
		&Debitos = SdoSai
		&SaldoDia = SdoAtu
		
		Exit
	When none
		&SaldoAnterior = 0
		&Creditos = 0
		&Debitos = 0
		&SaldoDia = 0
	EndFor
	
EndSub


Sub 'SomaDebitoCredito'

	&SaldoDia = &SaldoAnterior
	&Creditos = 0
	&Debitos = 0
	
	For each Order EmpCod,MovCtaBanCod,MovFecCod,MovDtaCon,MovHor,MovCod
		Where EmpCod = &EmpCod
		Where MovCtaBanCod = &CtaBanCod
		Where MovFecCod = &ResFecCod
		Where MovDtaCon > &AuxFecDta when not &AuxFecDta.IsEmpty() and &ResFecCod.IsEmpty()
		Where MovSts <> Status_Caixa.Cancelado or MovSts.IsNull() or MovSts.IsEmpty()
		
		&MovVlr = MovVlr
		
		If MovCreDeb = 'C'   //Crédito
			If not MovDtaCon.IsEmpty()
				&SaldoDia += &MovVlr
				&Creditos += &MovVlr //Total Crédito
			EndIf		
		Else
			&MovVlr = (&MovVlr * -1)
			If not MovDtaCon.IsEmpty()
				&SaldoDia += &MovVlr
				&Debitos += &MovVlr //Total Débito
			EndIf		
		EndIf
	EndFor

EndSub
]]></Source>
