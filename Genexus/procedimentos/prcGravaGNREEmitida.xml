      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
//
////## Define o nome dos Arquivos
//
//&parmXML 		= 	&sdtConfiguracoesPasta.PastaNFretorno+Trim(&nomeFinal)+'_guias-pro-rec.xml'
//&parmPDF 		= 	&sdtConfiguracoesPasta.PastaNFretorno+Trim(&nomeFinal)+'_guias-gnre.pdf'
		
	For Each Order EmpCod, FilCod, GNRETipo
		Where EmpCod 		= &EmpCod
		Where FilCod 		= &FilCod
		Where GNRENumRec	= &GNRENumRec
		Where GNREChavNot	= &GNREChavNot
		
		GNREVlrTot	= 	&GNREVlrTot			//## Valor	Total 		da GNRE		
		GNRELotPDF 	= 	&parmPDF			//## Arquivo em PDF		da GNRE		
		GNRELotXML 	= 	&parmXML			//## Arquivo em XML		da GNRE		
		GNRESts		= 	&GNRESts
		GNREErros	= 	&GNREErros
		
		Exit
	When None

		New										//## Atribui ao BD um novo registro	
			EmpCod 		=	&EmpCod				//## Código da Empresa				
			FilCod 		= 	&FilCod				//## Código da Filial				
			GNRENumRec 	= 	&GNRENumRec			//## Número do Recibo 	da GNRE		
			GNREChavNot = 	&GNREChavNot		//## Chave 				da Nfe	
			GNRETipo 	= 	&GNRETipo			//## Receita 			da GNRE		
			GNREVlrTot	= 	&GNREVlrTot			//## Valor	Total 		da GNRE	
			If Not &parmPDF.IsEmpty()
				GNRELotPDF 	= 	&parmPDF			//## Arquivo em PDF		da GNRE	
			EndIf
			If Not &parmXML.IsEmpty()
				GNRELotXML 	= 	&parmXML			//## Arquivo em XML		da GNRE	
			EndIf
			GNRESts		= 	&GNRESts
			GNREErros	= 	&GNREErros
		EndNew
	EndFor
	Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
