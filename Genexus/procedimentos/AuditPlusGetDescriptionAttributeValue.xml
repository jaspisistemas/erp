      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&AuditRecordID = &AuditRecordIDIn

For Each
	Where AuditRecordId = &AuditRecordID
	&AuditRecordTableGuid = AuditRecordTableGuid
	&AuditRecordKeyValue = AuditRecordKeyValue
	exit
EndFor

Do 'GetDescription'

Do While &AuditRecordAttributesNewValue.IsEmpty() AND Not &AuditRecordID.IsEmpty()
	For Each
		order (AuditRecordId)
		Where AuditRecordTableGuid = &AuditRecordTableGuid
		Where AuditRecordKeyValue = &AuditRecordKeyValue
		Where AuditRecordId < &AuditRecordID
			&AuditRecordID = AuditRecordId
			exit
	When None
		&AuditRecordID.SetEmpty()
	EndFor

	Do 'GetDescription'
EndDo

Sub 'GetDescription'
	If Not &AuditRecordID.IsEmpty()
		For Each
			Where AuditRecordAttributesIsDescriptionAttribute
			Where AuditRecordId = &AuditRecordID
			If AuditRecordOperation = "DELETE"
				&AuditRecordAttributesNewValue = AuditRecordAttributesOldValue
			Else
				&AuditRecordAttributesNewValue = AuditRecordAttributesNewValue
			Endif	
			Exit
		EndFor
	EndIf
EndSub
]]></Source>
