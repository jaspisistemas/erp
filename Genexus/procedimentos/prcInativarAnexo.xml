      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each ORder AnxCod, AnxEmpCod
	Where AnxCod = &AnxCod
	Where AnxEmpCod = &EmpCod
	
	AnxEmpIsUse = false
	
	Exit
When none
	New
		AnxCod = &AnxCod
		AnxEmpCod = &EmpCod		
		AnxEmpIsUse = false	
	EndNew
	
EndFor

commit


if &IsTemRemoverProduto = true
	For Each ORder EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProAnxCod = &AnxCod
		ProAnxCod = ''
	EndFor	

	Commit
ENdif

]]></Source>
