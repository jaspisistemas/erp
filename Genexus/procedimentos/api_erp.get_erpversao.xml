      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizarTabelas, &wwpContext)

if &IsAcessoConcedido = true
	&sdtRetornoWbsEtc.sts = 'J999'
	&sdtRetornoWbsEtc.obs = 'Versão não localizada'
				
	//PRIMEIRA EMPRESA
	For Each Order EmpCod
		
		Do CAse 
			Case &OqueFazer = 'ERP' //VERSAO PARA O ERP
				&sdtRetornoWbsEtc.sts = 'J200'
				&sdtRetornoWbsEtc.obs = ''
				&sdtRetornoWbsEtc.c1 = EmpVerSmartNew //VERSAO LIBERADA
				&sdtRetornoWbsEtc.c2 = EmpVerSmart //VERSAO MINIMA LIBERADA
				&sdtRetornoWbsEtc.c3 = EmpSmartLink.Trim() //LINK GOOGLE PLAY OU LINK LOCAL
				&sdtRetornoWbsEtc.c4 = format('https://app.jaspi.com.br/appjaspi/app/erp/android_v%1.apk', EmpVerSmartNew.Trim())
				
			Case &OqueFazer = 'MESA'
				&sdtRetornoWbsEtc.sts = 'J200'
				&sdtRetornoWbsEtc.obs = ''
				&sdtRetornoWbsEtc.c1 = EmpVerMesas //VERSAO LIBERADA
				&sdtRetornoWbsEtc.c2 = EmpVerMesas //VERSAO MINIMA LIBERADA
				&sdtRetornoWbsEtc.c3 = EmpSmartLink.Trim() //LINK GOOGLE PLAY OU LINK LOCAL
				&sdtRetornoWbsEtc.c4 = format('https://app.jaspi.com.br/appjaspi/app/mesa/android_v%1.apk', EmpVerMesas.Trim())
		EndCAse
	
		Exit
	EndFor

Endif
]]></Source>
