      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod 	= &tmpNFeCod
	Where tmpNfeItmCod 	= &tmpNfeItmCod
	
	tmpNfeSitCod 		= &tmpNfeSitCod
	tmpCFOP 		= &tmpCFOP
	tmpPedQtd 		= &tmpPedQtd
	tmpPedVlrUnt 	= &tmpPedVlrUnt
	tmpProVlrFrt 	= &tmpProVlrFrt
	tmpPedVlrTot 	= &tmpPedVlrTot
	tmpProBasVlrIcm = &tmpProBasVlrIcm
	tmpProPerIcm 	= &tmpProPerIcm
	tmpProVlrIcm 	= &tmpProVlrIcm
	tmpProBasVlrIcmSt = &tmpProBasVlrIcmSt
	tmpProPerIcmSt 	= &tmpProPerIcmSt
	tmpProVlrIcmSt 	= &tmpProVlrIcmSt
	tmpProBasVlrIpi = &tmpProBasVlrIpi
	tmpProPerIpi 	= &tmpProPerIpi
	tmpProVlrIpi 	= &tmpProVlrIpi
	tmpProPerDif    = &tmpProPerDif
	tmpProVlrDif	= &tmPproVlrDif
	
	tmpProVlrPIS = &tmpProVlrPIS
	tmpProVlrCOFINS = &tmpProVlrCOFINS 
	tmpProPerCOFINS = &tmpProPerCOFINS
	tmpProPerPIS = &tmpProPerPIS
	tmpProBasCofins = &tmpProBasPIS
	tmpProBasPIS = &tmpProBasPIS
	
	tmpNfeCstPIS = &tmpNfeCstPIS
	tmpNfeCstCofins.FromString(&tmpNfeCstPIS.ToString())
	 
EndFor

Commit

]]></Source>
