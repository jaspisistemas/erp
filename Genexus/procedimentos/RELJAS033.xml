      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	
	if &AgruparPorDia = 'S'
		&titulo = 'PRODUTOS VENDIDOS AO CLIENTE POR DATA EMISSÃO'
		&Filtro = 'CLIENTE: ' + trim(str(&PedCliCod)) + ' A PARTIR DE: ' + trim(toformattedString(&PedDtaFat))
		
		print Cabecalho
		
		print tituloA
		print Filtro
	Else
		&titulo = 'PRODUTO FATURADOS AO CLIENTE NO PERÍODO'
		&Filtro = 'CLIENTE: ' + trim(str(&PedCliCod)) + 'DE: ' + trim(toformattedString(&PedDtaFat)) + ' ATÉ ' + trim(ToformattedString(&PedDtaFat_to))
		
		print Cabecalho
		
		print tituloB
		print Filtro
	EndIF
End

if &AgruparPorDia = 'S'
	For Each 
		Order EmpCod, FilCod, PedCliCod, PedSts, LctGerFin, PedDtaEms when &Ordenar = 'C'
		Order EmpCod, FilCod, PedCliCod, PedSts, LctGerFin, (PedDtaEms) when &Ordenar = 'D'
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCliCod = &PedCliCod 
		Where PedSts = Status_Pedido.FECHADO
		Where LctGerFin = Status_SimNao.Sim
		Where LctAtuSal = Status_EntradaSaida.Saida
		Where PedDtaEms >= &PedDtaFat //and PedDtaFat <= &PedDtaFat_to
		
		&PedQtd = PedQtd
		&PedVlrItm = PedVlrUntComDsc_FORMULA
		Print ProdutoA
	EndFor
Else
	&TotPedQtd    = 0
	&TotPedQtdCan = 0
	&TotPedVlrItm = 0
	For Each Order EmpCod, FilCod, PedCliCod, PedSts, LctGerFin, ProCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCliCod = &PedCliCod 
		Where PedSts = Status_Pedido.FECHADO
		Where LctGerFin = Status_SimNao.Sim
		Where LctAtuSal = Status_EntradaSaida.Saida
		Where PedDtaFat >= &PedDtaFat and PedDtaFat <= &PedDtaFat_to
		
		&PedQtd = 0 
		&PedQtdCan = 0 
		&PedVlrItm = 0 
		For Each Order EmpCod, FilCod, PedCliCod, PedSts, LctGerFin, ProCod, PedDtaFat
			&PedQtd    += PedQtd
			&PedQtdCan += PedQtdCan
			&PedVlrItm += PedVlrItmComDsc
		EndFor
		&TotPedQtd    += &PedQtd
		&TotPedQtdCan += &PedQtdCan
		&TotPedVlrItm += &PedVlrItm
		
		Print ProdutoB
		
	EndFor
	If &TotPedQtd <> 0 or &TotPedVlrItm <> 0
		Print TotalB
	EndIf

EndIF



Footer
	print Rodape
End
]]></Source>
