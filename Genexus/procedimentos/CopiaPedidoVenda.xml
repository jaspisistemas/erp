      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem = ''

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
    
	UltimoCodigoEmpresa.Call(domParCod.PEDIDO, EmpCod, FilCod, &NovoPedCod)
	
    New
		EmpCod = EmpCod
        FilCod = FilCod
        PedCod = &NovoPedCod
        LctCod = &NovLctCod
        PedCliCod = &NovPedCliCod
        PedDtaEms = &NovPedDtaEms
		PedVenCod = &NovPedVenCod
		TabCod = &NovTabCod
		TabPrmCod = &NovTabPrmCod
		TabColCod = &NovTabColCod
		PedHorEms = ServerTime()
		PedDtaFat = nullvalue(PedDtaFat)
		PedHorFat.SetEmpty()
		
		PedDtaFic = nullvalue(PedDtaFic)
		
		PedDtaDsp = nullvalue(PedDtaDsp)
		PedHorDsp.SetEmpty()
		
		
		PedDtaEmb = nullvalue(PedDtaEmb)
		PedHorEmb.SetEmpty()
		PedDtaEmb.SetEmpty()
		PedDtaEmba.SetEmpty()
		PedDtaEbal.SetEmpty()
		
		PedDtaSep = nullvalue(PedDtaSep)
		PedDtaSep.SetEmpty()
		PedHorSep.SetEmpty()
		
		PedStsCrd = Status_Autorizado.NAO_AUTORIZADO
		PedDtaCrd.SetEmpty()
		
		PedStsEnv = Status_Rastreamento.Pendente 

		
        PedSts = Status_Pedido.ABERTO
        PedStsFin = Status_Financeiro.ABERTO
		
		PedStsAna.SetEmpty()
		PedNovStsCod.SetEmpty()
		PedNovStsFinCod.SetEmpty()
		PedStsCod.SetEmpty()
		PedStsFinCod.SetEmpty()
		
		PedVlrAgr = 0
		PedCodAgr = 0
		PedCnhEms.SetEmpty()
		PedCnhTraCod.SetEmpty()
		PedCnhFrt.SetEmpty()
		PedCnhVlr = 0
		PedRomCha = PedRomCha
		PedRomCrt = PedRomCrt
	
		PedStsPrd.SetEmpty()
		PedDtaPrv.SetEmpty()
		PedBlq = Status_SimNao.Nao
		PedStsDigBlk = &PedStsDigBlk
		PedQtdVol = 0
		PedEspVol = ''
		PedPesTot = 0		
		PedVlrGnre = 0
		PedVlrIpi = 0
    EndNew
EndFor

Commit


For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
    new
		EmpCod = EmpCod
        FilCod = FilCod
        PedCod = &NovoPedCod
        PedItmCod = PedItmCod
        PedQtdCan = 0
    EndNew
EndFor

commit

CriticasPedido.Call(&EmpCod, &FilCod, &NovoPedCod, TipoCriticaPedido.Digitado, &FunPesCod)

//GRAVA PREÇOS UNITARIOS CONFORME ALTERACAO NOS CAMPOS /COLUNA / TABELA
AtualizaPrecosPedidoVenda.Call(&EmpCod, &FilCod, &NovoPedCod, false)
	
//AtualizaEstoqueGerencialVenda.Call(&EmpCod, &FilCod, &NovoPedCod, &NovPedDtaEms, &FunPesCod, Status_Pedido.ABERTO)
AtualizaPedidoEstoqueVendidoComprado.Call(&EmpCod, &FilCod, &NovoPedCod)

PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &NovoPedCod)

&Mensagem = 'Copia de Pedido concluído. Gerado Pedido Número: ' + trim(str(&NovoPedCod))
]]></Source>
