      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&DATABASE = YMDtoD(&Ano, &Mes, 1)
&DataBase = EOM(&DATABASE)

&TotalNumeric = 100
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'


Do 'OpenDocument'

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor


&Filtro = 'REF: ' + trim(UPPER(CMonth(&DataBase))) + '/'+trim(str(&Ano))
if &ConsiderarPedidosAbertos = true
	&TituloEstoqueSaldo = 'Saldo'
Else
	&TituloEstoqueSaldo = 'Estoque'
EndIF

&CellRow = 1

Do 'WriteColumnTitles'

&auxGrupHie = &GrupHie.Trim() + '.'
&AuxInicio = &DataBase.AddDays(1)
&AuxFim = Serverdate()
&AuxFim = &AuxFim.AddDays(1)

For Each 
	Order EmpCod, FilCod, ProGraRefPadL when &OrdemExibicao = 'C'
	Order EmpCod, FilCod, ProNom, ProGraNom when &OrdemExibicao = 'N'
	Order EmpCod, FilCod, GrupHiePadL when &OrdemExibicao = 'G'
	
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	Where (ProIsGra <> true) or (ProIsGra.IsNull() or ProIsGra.IsEmpty()) or ProGraCod > 1
	Where ProTipDef = &ProTipDef when not &ProTipDef.IsEmpty()
	Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	Where ProSts = &ProSts when Not &ProSts.IsEmpty()
	where ProSts <> Status_Produto.EXCLUIDO when &ProSts.IsEmpty()
	Where MarCod = &MarCod when not &MarCod.IsEmpty()
	
//	EstoqueAnteriorFicha.Call(EmpCod, FilCod, ProCod, ProGraCod, 1, &AuxInicio, &AuxFim, &EstQtd)
	EstoqueAnterior_Inventario.Call(EmpCod, FilCod, ProCod, ProGraCod, 1, &DataBase, &EstQtd)
	
	//SOMENTE PRODUTOS COM ESTOQUE:A, 
	//ACRESCENTAR PRODUTOS SEM ESTOQUE:B, 
	//SOMENTE PRODUTOS SEM ESTOQUE:C
	If (&EstQtd > 0 and &FiltrarProdutos = 'A') or (&FiltrarProdutos = 'B') or (&EstQtd <= 0 and &FiltrarProdutos = 'C')
		
		If &OrdemExibicao = 'G' and &OldGrupHie <> GrupHie
			if &IsTotaliza = true				
				If (&PrecoVenda = true or &PrecoCusto = true)
					&Total = 'TOTAL'
					&TotalPrintVenda = &TotalVenda
					&TotalPrintCusto = &TotalCusto
					do 'Total'
					&IsTotaliza = false
				EndIF
				
				&TotalCusto = 0
				&TotalVenda = 0
			EndIF
			
			&OldGrupHie = GrupHie
			&GrupNomCmp = GrupCodNom
			do 'TotalGrupo'
			&IsTotaliza = true
		EndIF		
		
		
		&PedVlrUnt = 0
		&TotPedVlrUNt = 0
		&ProVlrCus = 0
		&TotProVlrCus = 0
		
		&TotPedVlrUNt = 0
		If &PrecoCusto = true //CUSTO
			&ProVlrCus = ProVlrCus
			
			If &EstQtd > 0 and &ProVlrCus > 0
				&TotProVlrCus = &ProVlrCus * &EstQtd
			EndIF
			
			&TotalCusto += &TotProVlrCus
			&TotalGeralCusto += &TotProVlrCus
		EndiF
		
		If &PrecoVenda = true //VENDA
			&ProCod = ProCod 
			&ProGraCod = ProGraCod
			do 'getPrecoVenda'
			
			If &EstQtd > 0 and &PedVlrUnt > 0
				&TotPedVlrUNt = &PedVlrUnt * &EstQtd
			EndIF			
			
			&TotalVenda += &TotPedVlrUNt
			&TotalGeralVenda += &TotPedVlrUNt
		EndIF
		
		&ProGraRef = ProGraRef
		
		&EstLoc = ''
		
		if &impProPadForCod.IsEmpty()
			&EstLoc = EstLoc
		Else
			do 'GetCodigoFornecedor'
		Endif
		
		&AuxProTipDef = ProTipDef
		&ProNomGra = ProNomGra
		&ProEmbUnd = ProEmbUnd
		&NcmCod = NcmCod
		&ProPesLiq = ProPesLiqPrd
		do 'GravaProduto'
	EndiF
	
	&CountAux += 1
	if &CountAux > 300
		&Count += 1
		If &Count > 0
			&Percentual = round((&Count / &TotalNumeric) * 100, 0)
		EndIF
		If &Percentual >= 100
			&Percentual = 99
		EndIf
		do 'Atualiza'
		&CountAux = 0
	Endif
EndFor

If (&PrecoVenda = true or &PrecoCusto = true) and &IsTotaliza = true
	&Total = 'TOTAL'
	&TotalPrintVenda = &TotalVenda
	&TotalPrintCusto = &TotalCusto
	Do 'Total'
EndIF

If (&PrecoVenda = true or &PrecoCusto = true)
	&Total = 'GERAL'
	&TotalPrintVenda = &TotalGeralVenda
	&TotalPrintCusto = &TotalGeralCusto
	Do 'Total'
EndIF

do 'CloseDocument'

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		//ProgressLogXml = &NomeArquivo
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			//ProgressLogXml = &NomeArquivo
		Endnew
	endfor
	
	commit	
EndSub

Sub 'GetCodigoFornecedor'
	For Each Order EmpCod, ProCod, ProForCod
		Where EmpCod = &EmpCod
		Where (ProCod = &ProCod)
		Where ProForCod = &impProPadForCod
		&EstLoc = ProForProCod
		Exit
	EndFor
EndSub


Sub 'getPrecoVenda'
	For Each Order EmpCod, TabCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where TabCod = &FilTabCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		Do Case
			Case &TabColCod = 1
				&PedVlrUnt = TabPrc1
				
			Case &TabColCod = 2
				&PedVlrUnt = TabPrc2
				
			Case &TabColCod = 3
				&PedVlrUnt = TabPrc3
				
			Case &TabColCod = 4
				&PedVlrUnt = TabPrc4
				
			Case &TabColCod = 5
				&PedVlrUnt = TabPrc5
				
			Case &TabColCod = 6
				&PedVlrUnt = TabPrc6
				
			Case &TabColCod = 7
				&PedVlrUnt = TabPrc7
				
			Case &TabColCod = 8
				&PedVlrUnt = TabPrc8
				
			Case &TabColCod = 9
				&PedVlrUnt = TabPrc9
		EndCase		
	EndFor
EndSub


Sub 'CloseDocument'
	&ExcelDocument.Save()
	Do 'CheckStatus'
	&ExcelDocument.Close()
EndSub

Sub 'CheckStatus'
	If (&ExcelDocument.ErrCode <> 0)
		&erroMEnsagem = &ExcelDocument.ErrDescription
		&ExcelDocument.Close()
		Return
	EndIf
EndSub

sub 'TotalGrupo'
	&CellRow +=1
	
	&ExcelDocument.Cells(&CellRow,3).Bold = True
	&ExcelDocument.Cells(&CellRow,3).Color = 11
	&ExcelDocument.Cells(&CellRow,3).Text = &GrupNomCmp.trim()
EndSUb


sub 'Total'
	&CellRow +=1
	
//	&ExcelDocument.Cells(&CellRow,1).Bold = False
//	&ExcelDocument.Cells(&CellRow,1).Color = 11
//	&ExcelDocument.Cells(&CellRow,1).Text = &ProGraRef.Trim()
//	&ExcelDocument.Cells(&CellRow,2).Bold = False
//	&ExcelDocument.Cells(&CellRow,2).Color = 11
//	&ExcelDocument.Cells(&CellRow,2).Text = &EstLoc.trim()
//	&ExcelDocument.Cells(&CellRow,3).Bold = False
//	&ExcelDocument.Cells(&CellRow,3).Color = 11
//	&ExcelDocument.Cells(&CellRow,3).Text = &ProNomGra.trim()
//	
//	&ExcelDocument.Cells(&CellRow,4).Bold = False
//	&ExcelDocument.Cells(&CellRow,4).Color = 11
//	&ExcelDocument.Cells(&CellRow,4).Number = trim(toformattedString(&EstQtd))
	
	&ExcelDocument.Cells(&CellRow,5).Bold = true
	&ExcelDocument.Cells(&CellRow,5).Color = 11
	&ExcelDocument.Cells(&CellRow,5).Text = &Total.Trim()
	
	&Coluna = 6
	If &PrecoVenda = true //Unit. Venda
//		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
//		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
//		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &PedVlrUnt
		
		&Coluna += 1
		
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &TotalPrintVenda
		
		&Coluna += 1
	EndIF
	
	if &PrecoCusto = true //Unt.Custo
//		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
//		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
//		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &ProVlrCus
		
		&Coluna += 1
		
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &TotalPrintCusto
	EndIf
EndSub


Sub 'WriteColumnTitles'

	
	&CellRow+=2
	&ExcelDocument.Cells(&CellRow,1).Bold = True
	&ExcelDocument.Cells(&CellRow,1).Color = 14
	&ExcelDocument.Cells(&CellRow,1).Text = "INVENTÁRIO PRODUTOS"
	
	&CellRow +=1
	
	&ExcelDocument.Cells(&CellRow,1).Bold = True
	&ExcelDocument.Cells(&CellRow,1).Color = 11
	&ExcelDocument.Cells(&CellRow,1).Text = "Código"
	&ExcelDocument.Cells(&CellRow,2).Bold = True
	&ExcelDocument.Cells(&CellRow,2).Color = 11
	if &impProPadForCod.IsEmpty()
		&ExcelDocument.Cells(&CellRow,2).Text = "Locação"
	Else
		&ExcelDocument.Cells(&CellRow,2).Text = "Cód.Forn."
	Endif

	&ExcelDocument.Cells(&CellRow,3).Bold = True
	&ExcelDocument.Cells(&CellRow,3).Color = 11
	&ExcelDocument.Cells(&CellRow,3).Text = "Descrição"
	
	&ExcelDocument.Cells(&CellRow,4).Bold = True
	&ExcelDocument.Cells(&CellRow,4).Color = 11
	&ExcelDocument.Cells(&CellRow,4).Text = &TituloEstoqueSaldo
	
	&ExcelDocument.Cells(&CellRow,5).Bold = True
	&ExcelDocument.Cells(&CellRow,5).Color = 11
	&ExcelDocument.Cells(&CellRow,5).Text = "UND"
	
	
	&ExcelDocument.Cells(&CellRow,6).Bold = True
	&ExcelDocument.Cells(&CellRow,6).Color = 11
	&ExcelDocument.Cells(&CellRow,6).Text = "NCM"
	
	&Coluna = 7
	If &PrecoVenda = true //Unit. Venda
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = True
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Text = "Unt.Venda"
		
		&Coluna += 1
		
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = True
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Text = "Tot.Venda"
		
		&Coluna += 1
	EndIF
	
	if &PrecoCusto = true //Unt.Custo
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = True
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Text = "Unt.Custo"
		
		&Coluna += 1
		
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = True
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Text = "Tot.Custo"
	EndIf

	&Coluna += 1
	
	&ExcelDocument.Cells(&CellRow,&Coluna).Bold = True
	&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
	&ExcelDocument.Cells(&CellRow,&Coluna).Text = "Peso"
	
	&Coluna += 1
	
	&ExcelDocument.Cells(&CellRow,&Coluna).Bold = True
	&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
	&ExcelDocument.Cells(&CellRow,&Coluna).Text = "Definição"
EndSub

sub 'GravaProduto'
	&CellRow +=1
	
	&ExcelDocument.Cells(&CellRow,1).Bold = False
	&ExcelDocument.Cells(&CellRow,1).Color = 11
	&ExcelDocument.Cells(&CellRow,1).Text = &ProGraRef.Trim()
	&ExcelDocument.Cells(&CellRow,2).Bold = False
	&ExcelDocument.Cells(&CellRow,2).Color = 11
	&ExcelDocument.Cells(&CellRow,2).Text = &EstLoc.trim()
	&ExcelDocument.Cells(&CellRow,3).Bold = False
	&ExcelDocument.Cells(&CellRow,3).Color = 11
	&ExcelDocument.Cells(&CellRow,3).Text = &ProNomGra.trim()
	
	&ExcelDocument.Cells(&CellRow,4).Bold = False
	&ExcelDocument.Cells(&CellRow,4).Color = 11
	&ExcelDocument.Cells(&CellRow,4).Number = &EstQtd
	
	&ExcelDocument.Cells(&CellRow,5).Bold = False
	&ExcelDocument.Cells(&CellRow,5).Color = 11
	&ExcelDocument.Cells(&CellRow,5).Text = &ProEmbUnd.Trim()
	
	&ExcelDocument.Cells(&CellRow,6).Bold = False
	&ExcelDocument.Cells(&CellRow,6).Color = 11
	&ExcelDocument.Cells(&CellRow,6).Text = &NcmCod.toFormattedString()
	
	&Coluna = 7
	If &PrecoVenda = true //Unit. Venda
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &PedVlrUnt
		
		&Coluna += 1
		
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &TotPedVlrUNt
		
		&Coluna += 1		
	EndIF
	
	if &PrecoCusto = true //Unt.Custo
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &ProVlrCus
		
		&Coluna += 1
		
		&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
		&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
		&ExcelDocument.Cells(&CellRow,&Coluna).Number = &TotProVlrCus
	EndIf
	
	&Coluna += 1
	
	&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
	&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
	&ExcelDocument.Cells(&CellRow,&Coluna).Number = &ProPesLiq
	
	&Coluna += 1
	
	&ExcelDocument.Cells(&CellRow,&Coluna).Bold = False
	&ExcelDocument.Cells(&CellRow,&Coluna).Color = 11
	&ExcelDocument.Cells(&CellRow,&Coluna).Text = &AuxProTipDef
EndSub


Sub 'OpenDocument'
	&File.Source = &FilenameFisico
	if &File.Exists()
		&File.Delete()
	Endif
	
	&ExcelDocument.Open(&FilenameFisico)
	&ExcelDocument.AutoFit = 1
	Do 'CheckStatus'
	&ExcelDocument.Clear()
	
EndSub
