      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//LOCALIZAR NFSe em DIGITACAO
prcRetornaNotaFiscalServicoDigitacao.Call(&EmpCod, &FilCod, &PedCod, &NfsCod)

if &NfsCod > 0
	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NfsCod
		
		//DELETA ITENS DA NOTA EM DIGITACAO	
		For Each Order EmpCod, NfsCod, NfsItmCod
			delete
		EndFor
		
		Exit
	EndFor
	
	Commit
Endif

&PedVlrItm = 0

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	//INTEMEDIARIO
	&wpNFSData.Capa.NfsIntIs = false
	//	&wpNFSData.Capa.NfsIntCliCod = NfsIntCliCod 
	//	&wpNFSData.Capa.NfsIntRaz = NfsIntRaz 
	//	&wpNFSData.Capa.NfsIntFonNum = NfsIntFonNum 
	//	&wpNFSData.Capa.NfsIntCNPJ = NfsIntCNPJ 
	//	&wpNFSData.Capa.NfsIntCidCod = NfsIntCidCod 
	//	&wpNFSData.Capa.NfsIntEml = NfsIntEml 
	
	//TOMADOR
	&PedCliCod  = PedCliCod 
	&wpNFSData.Capa.NfsCliCod = PedCliCod 
	do 'GetTomador'
	&wpNFSData.Capa.NfsCliRaz = &PesRaz 
	&wpNFSData.Capa.NfsCliFonNum = &PesPrmFon 
	&wpNFSData.Capa.NfsCliTipPes = &PesTip 
	&wpNFSData.Capa. NfsCliCep = &PesEntCep 
	&wpNFSData.Capa.NfsCliLog = &PesEntLog 
	&wpNFSData.Capa.NfsCliNro = &PesEntNro 
	&wpNFSData.Capa.NfsCliBai = &PesEntBai
	
	//NfsCliCidCodNom = &wpNFSData.Capa.NfsCliCidCodNom
	
	&wpNFSData.Capa.NfsCliCidCod = &PesEntCidCod 
	&wpNFSData.Capa.NfsCliCidIbge = &PesEntCidIbge 
	&wpNFSData.Capa.NfsCliCidNom = &PesEntCidNom 	
	&wpNFSData.Capa.NfsCliCidUfCod = &PesEntUfeCod
	&wpNFSData.Capa.NfsCliCpl = &PesEntCpl 
	&wpNFSData.Capa.NfsCliEml = &PesPrmEml 
	&wpNFSData.Capa.NfsCliCnpj = &PesCnpj 
	&wpNFSData.Capa.NfsCliInsEst = &PesInsEst
	&wpNFSData.Capa.NfsCliInsMun = &PesInsMun 
	&wpNFSData.Capa.NfsCliCPF = &PesCpf
	
	&wpNFSData.Capa.NfsDtaEms = serverdate()
	&wpNFSData.Capa.NfsHorEms = serverTime()
	&wpNFSData.Capa.NfsProTer = Nota_ProPriaTerceira.PROPRIA 
	
	&wpNFSData.Capa.NfsPedCod = PedCod
	&wpNFSData.Capa.NfsPedFilCod = FilCod
	&wpNFSData.Capa.NfsFilCod = FilCod
	&wpNFSData.Capa.NfsLctCod = LctCod
	&wpNFSData.Capa.NfsTipEmi = TipoEmitenteNFSe.Prestador
	&PedFatFilCod = FilCod
	
	//&wpNFSData.Capa.NfsNum
	//&wpNFSData.Capa.NfsSer = 0	
	
	&wpNFSData.Capa.NfsTipNF = 'S'
	&NfsTipNF = 'S'

	//GRAVA CAPA NFSe
	prcGravaCapaNFSe_Pedido.Call(&EmpCod, &NfsCod, &wpNFSData)
		
	if not PedVeiPla.IsEmpty() and not PedVeiPla.IsNull() and PedVeiPla.Length() > 6
		&NfsDisSer = 'PLACA: ' + trim(PedVeiPla)
	Endif

	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where ProTipDef = definicao.SERVICO
		where PedQtd > 0
		Where PedVlrUnt > 0
		
		if &wpNFSData.DadosNFSE.ProCod.IsEmpty()
			&wpNFSData.DadosNFSE.ProCod = ProCod
			&wpNFSData.DadosNFSE.ProGraCod = ProGraCod
		EndIf		
		
		if &NfsTribNac.IsEmpty() and ( not ProTribNac.IsEmpty() and not ProTribNac.IsNull())
			&NfsTribNac = ProTribNac
			&NfsNbs = NcmCod
		Endif
		
		if &NfsDisSer.IsEmpty()
			if PedItmCmp.IsEmpty()
				&NfsItmProNom = ProNomGra.Trim()
				&NfsDisSer = ProNomGra.Trim()
			Else
				&NfsItmProNom = PedItmCmp.Trim()
				&NfsDisSer = PedItmCmp.Trim()
			Endif
		Else
			if PedItmCmp.IsEmpty()
				&NfsItmProNom = ProNomGra.Trim()
				&NfsDisSer += ', ' +  ProNomGra.Trim()
			Else
				&NfsItmProNom = PedItmCmp.Trim()
				&NfsDisSer += ', ' +  PedItmCmp.Trim()
			Endif
		EndIf
	
		&wpNFSData.Itens.NfsItmProCod = ProCod
		&wpNFSData.Itens.NfsItmProGraCod =ProGraCod
		&wpNFSData.Itens.NfsItmValTot = PedVlrItm
		&wpNFSData.Itens.NfsItmEmbUnd = ''
		&wpNFSData.Itens.NfsItmValUnt = PedVlrUnt
		&wpNFSData.Itens.NfsItmQtd = PedQtd
		&wpNFSData.Itens.NfsItmProNom = &NfsItmProNom
		&wpNFSData.Itens.ProRef = ProRef
		&wpNFSData.Itens.NfsItmCod = 0
		
		prcGravaItemNFSe.Call(&EmpCod, &NfsCod, &wpNFSData)
		
		&PedVlrItm += PedVlrItm
	EndFor

	&wpNFSData.DadosNFSE.NfsItmValTot = &PedVlrItm
	&wpNFSData.DadosNFSE.NfsTribNac = &NfsTribNac 
	&wpNFSData.DadosNFSE.NfsNbs = &NfsNbs 
	
	&wpNFSData.DadosNFSE.NfsDisSer = &NfsDisSer	
	prcGravaDadosNFSe.Call(&EmpCod, &NfsCod, &wpNFSData)
	
	Exit
EndFor
	
sub 'GetTomador'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		
		&PesRaz = PesRaz		
		&PesPrmFon = PesPrmFon
		&PesTip = PesTip
		&PesCpf = PesCpf 
		&PesCnpj = PesCnpj
		&PesInsMun = PesInsMun
		
		&PesInsEst = PesInsEst
		&PesEntBai = PesEntBai
		&PesEntCep = PesEntCep
		&PesEntLog = PesEntLog 
		&PesEntNro = PesEntNro
		&PesEntCpl = PesEntCpl
		
		&PesPrmEml = PesPrmEml
		
		&PesEntCidCod = PesEntCidCod
		&PesEntCidNom = PesEntCidNom
		&PesEntUfeCod = PesEntUfeCod
		&PesEntCidIbge = PesEntCidIbge
		Exit
	EndFor
endSub
]]></Source>
