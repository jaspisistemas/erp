      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do case
	case &OqueFazer = 'INS'
		Do 'InserirEditar'
	case &OqueFazer = 'UPD'
		Do 'InserirEditar'
	case &OqueFazer = 'DEL'
		//Do 'Deletar'
	case &OqueFazer = 'INA' //Inativar
		//Do 'Inativar'
	case &OqueFazer = 'ULTVC' //Atualizar ultimo vct
		Do 'AtualizaUltimoVct'
EndCase

Commit

Sub 'InserirEditar'
	if &SerItmCod = 0
		UltimoCodigoEmpresa.Call(domParCod.SERVICOCLIENTE,&EmpCod,0,&SerItmCod)
		
		New
			EmpCod = &EmpCod
			SerItmCod = &SerItmCod
			SerFilCod = &SerFilCod
			SerCod = &SerCod
			SerCliCod = &SerCliCod
			SerCliNom = &SerCliNom
			if &SerItmAbv.IsEmpty()
				SerItmAbv = trim(str(&SerItmCod))
			Else
				SerItmAbv = &SerItmAbv
			EndIf
			
			SerItmCbrCod = &SerItmCbrCod
			SerItmPlanCod = &SerItmPlanCod
			SerItmVlr = &SerItmVlr
			SerItmTipPlan = &SerItmTipPlan
			SerItmQtdMes = &SerItmQtdMes
			SerItmTip = &SerItmTip
			SerItmDtaInicio = &SerItmDtaInicio
			SerItmDtaFim = &SerItmDtaFim
			SerItmSts = &SerItmSts
			SerItmDiaVct = &SerItmDiaVct
			SerItmDesc = &SerItmDesc
			SerItmRecPag = &SerItmRecPag
			SerItmLctCod = &SerItmLctCod
			SerItmAtuMan = &SerItmAtuMan
			SerItmIsEmiNFe = &SerItmIsEmiNFe
			SerItmIsEmiNFSe = &SerItmIsEmiNFSe
			
		EndNew
	Else
		
		For each order EmpCod,SerItmCod
			where EmpCod = &EmpCod
			where SerItmCod = &SerItmCod
			
			SerFilCod = &SerFilCod
			SerCod = &SerCod
			SerCliCod = &SerCliCod
			SerCliNom = &SerCliNom
			if &SerItmAbv.IsEmpty()
				SerItmAbv = trim(str(&SerItmCod))
			Else
				SerItmAbv = &SerItmAbv
			EndIf
			SerItmCbrCod = &SerItmCbrCod
			SerItmPlanCod = &SerItmPlanCod
			SerItmVlr = &SerItmVlr
			SerItmTipPlan = &SerItmTipPlan
			SerItmQtdMes = &SerItmQtdMes
			SerItmTip = &SerItmTip
			SerItmDtaInicio = &SerItmDtaInicio
			SerItmDtaFim = &SerItmDtaFim
			SerItmSts = &SerItmSts
			SerItmDiaVct = &SerItmDiaVct
			SerItmDesc = &SerItmDesc
			SerItmRecPag = &SerItmRecPag
			SerItmLctCod = &SerItmLctCod
			SerItmAtuMan = &SerItmAtuMan
			SerItmIsEmiNFe = &SerItmIsEmiNFe
			SerItmIsEmiNFSe = &SerItmIsEmiNFSe
			exit
		EndFor
	Endif
EndSub


Sub 'AtualizaUltimoVct'
	
	&UltDtaVct.SetEmpty()
	&IsAchou = false
	For Each Order EmpCod, FilCod, CreSerItmCod, CreOriDup, CreSts, (CreDtaVct)
		Where EmpCod = &EmpCod
		Where FilCod = &SerFilCod
		Where CreSerItmCod = &SerItmCod
		Where CreOriDup = OrigemDuplicata.MensalidadeServico
		Where CreSts = Status_AtivoInativo.ATIVO
		&UltDtaVct = CreDtaVct
		&IsAchou = true
		exit		
	EndFor	
	
	if &IsAchou = true
		For each order EmpCod,SerFilCod,SerItmCod
			where EmpCod = &EmpCod
			Where SerFilCod = &SerFilCod
			where SerItmCod = &SerItmCod
			SerItmUltVct = &UltDtaVct
			exit
		EndFor
	EndIf
	
EndSub
]]></Source>
