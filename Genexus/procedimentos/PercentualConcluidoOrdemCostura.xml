      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//parm(in:&EmpCod, in:&OcsCod, in:&OcsItm, in:&OcsProCod, in:&OcsQtd, out:&AptQtd);

&AptQtd = 0
&GrupCtrOrd = 0
//PRODUTO
RetornaQuantasEtapas.Call(&EmpCod, &OcsCod, &OcsItm, &GrupCtrOrd) //GRUPO
	

&QuantidadeTotal = &OcsQtd * &GrupCtrOrd
	
//APONTAMENTOS
For Each Order EmpCod,AptOcsCod,AptOcsItm
	Where EmpCod = &EmpCod
	Where AptOcsCod = &OcsCod
	Where AptOcsItm = &OcsItm	
	
	&AptQtd += AptQtd
EndFor

if &AptQtd > 0 and &QuantidadeTotal > 0 //CALCULA
	&PercentualConcluido = (&AptQtd * 100) / &QuantidadeTotal
	Do case
		Case &PercentualConcluido.IsEmpty()
			&PercentualConcluido = 0.01
		Case &PercentualConcluido > 100
			&PercentualConcluido = 100
	EndCase
Endif


]]></Source>
