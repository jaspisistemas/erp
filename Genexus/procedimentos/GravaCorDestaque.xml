        <Source><![CDATA[&DstHexVarchar = &Varchar
FormataHexaRGB.Call(&DstHexVarchar, &R, &G, &B)

For Each ORder EmpCod, DstCod
	Where EmpCod = &EmpCod
	Where DstCod = &DstCod
	DstHex = &DstHexVarchar
	DstR = &R
	DstB = &B
	DstG = &G
	Exit
EndFor

Commit
]]></Source>
