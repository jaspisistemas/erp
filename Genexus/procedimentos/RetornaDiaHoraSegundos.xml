      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Segundo = &inHoraSegundos
&minuto = 0
&Hora = 0
&Dia = 0

//comentei porque queria ver em horas quanto da 
//TAYGRA
//if &Segundo >= 86400 //DIA
//	&Dia = trunc(&Segundo / 86400, 0)
//	&Segundo = &Segundo - (&Dia * 86400)
//	
//	if &Dia > 0
//		&TotHora = trim(str(&dia)) + 'D '
//	Endif
//Endif

if &Segundo >= 3600 //HORA
	&Hora = trunc(&Segundo / 3600, 0)
	&Segundo = &Segundo - (&Hora * 3600)
Endif

if &Segundo >= 60 //MINUTO
	&minuto = trunc(&Segundo / 60, 0)
	&Segundo = &Segundo - (&minuto * 60)
Endif

if &Hora < 100
	&TotHora += padL(trim(toformattedString(&Hora)),2,'0')+':'
Else
	&TotHora += trim(toformattedString(&Hora))+':'
Endif

&TotHora += padL(trim(str(&minuto)),2,'0')+':'
&TotHora += padL(trim(str(&Segundo)),2,'0')
]]></Source>
