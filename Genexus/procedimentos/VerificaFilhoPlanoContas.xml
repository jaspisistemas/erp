      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsExiste = false

&AuxPlanHie = &PlanHie.Trim() + '.'

For Each Order EmpCod, PlanCod
	Where EmpCod = &EmpCod
	Where PlanCod <> &PlanCod
	Where PlanHie like &AuxPlanHie
	Where PlanPaiCod = &PlanPaiCod when &PlanPaiCod <> 0
	
	&IsExiste = true
	
	Exit
EndFor

//VERIFICA MOVIMENTO
For Each Order EmpCod, PlanCod, MovCod, MovItmCod
	Where EmpCod = &EmpCod
	Where PlanCod = &PlanCod

	&IsExiste = true
	Exit
EndFor
]]></Source>
