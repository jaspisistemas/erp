      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = UPPER('Estoque Disponível')
	print Cabecalho
End
&auxGrupHie = &GrupHie.Trim() + '.'
Print Titulos

For each 
	Order EmpCod,FilCod,ProGraRef when &OrdemExibicao = 'C'
	Order EmpCod,FilCod,ProNomGra when &OrdemExibicao = 'N'
	Order EmpCod,FilCod,EstLoc When &OrdemExibicao = 'L'
	
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	Where ProSts = &ProSts when not &ProSts.IsEmpty()
	where ProSts <> Status_Produto.EXCLUIDO when &ProSts.IsEmpty()
	Where ProTipDef = &ProTipDef when not &ProTipDef.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	Where ProPadForCod = &ProPadForCod When &ProPadForCod <> 0 
	Where ProCod = &ProCod When &ProCod <> 0
	Where ProClsPrdCod = &ProClsPrdCod when not &ProClsPrdCod.IsEmpty()
	where MarCod = &MarCod when not &MarCod.IsEmpty()
	Where not EstLoc.IsEmpty() when &SomenteComLocacao = Status_SimNao.Sim
	Where EstLoc like &EstLoc when not &EstLoc.Trim().IsEmpty()
	
	&ProGraRef = ProGraRef
	&ProNomGra = ProNomGra
	&ProNomGra 		= GxGetMLi(ProNomGra, 1, 45)
	&auxProNomGra     = GxGetMLi(ProNomGra, 2, 45)
	&NcmCod  = NcmCod
	&MarNom  = MarNom
	&ProGraEstAbe = 0
	&AuxEstLoc = EstLoc
	&EstQtdVarChar 	= Trim(ToFormattedString(EstQtd))
	RetiraZerosDepoisVirgula.Call(&EstQtdVarChar, &EstQtdVarChar)
//	&AuxEstQtd = EstQtd  //estoque
	&EstSdoVarChar 	= Trim(ToFormattedString(EstSdo))
	RetiraZerosDepoisVirgula.Call(&EstSdoVarChar, &EstSdoVarChar)
	
	&ProQtdMinVarchar = Trim(ToFormattedString(ProQtdMin))
	RetiraZerosDepoisVirgula.Call(&ProQtdMinVarchar, &ProQtdMinVarchar)

	Do Case
		Case EstSdo = 0
			&EstAbeVarchar = Trim(ToFormattedString(EstQtd)) 
			
		Case EstSdo < EstQtd
			&ProGraEstAbe = (EstSdo - EstQtd) * -1 
			&EstAbeVarchar = Trim(ToFormattedString(&ProGraEstAbe)) 
		OtherWise
			&ProGraEstAbe = (EstSdo - EstQtd)
			&EstAbeVarchar = Trim(ToFormattedString(&ProGraEstAbe)) 
			//			&ProGraEstAbe = (EstSdo - EstQtd)
	EndCase

	RetiraZerosDepoisVirgula.Call(&EstAbeVarchar, &EstAbeVarchar)

	&ProPesLiqPrd = ProPesLiqPrd
	
	Do Case
		Case &ComSaldo = true and EstQtd > 0 
			Print Dados			
		Case &ComSaldo = False
			Print Dados
	EndCase
	
	If not &auxProNomGra.Trim().IsEmpty()
		Print dadosCpl
	EndIf
	Noskip
	Print Linha

EndFor

Footer
	print Rodape
End

