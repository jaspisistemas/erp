&EstTipAno = &PedDtaFat.Year()
&EstTipMes = &PedDtaFat.Month()
//SOMA O ESTOQUE ANO MES.
&EstTipQtd = 0
For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &PRoGraCod when &PRoGraCod > 1
	Where ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
	
	For Each Order EmpCod, FilCod, ProCod, ProGraCod, (EstTipAno), (EstTipMes)
		Where EstTipAno <= &EstTipAno
		Where EstTipMes <= &EstTipMes or EstTipAno < &EstTipAno
		
		&EstTipQtd += EstQtd
		Exit
	EndFor
EndFor

