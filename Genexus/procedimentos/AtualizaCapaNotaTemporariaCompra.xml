      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNfeCod
	
	
	&tmpTotPro += tmpPedVlrTot
	&tmpTotBasIcm += tmpProBasVlrIcm
	&tmpTotVlrIcm += tmpProVlrIcm
	&tmpTotBasSt += tmpProBasVlrIcmSt
	&tmpVlrSt += tmpProVlrIcmSt
	&tmpTotIpi += tmpProVlrIpi
		
	Exit
EndFor

&tmpTotNFe = (&tmpTotPro+&tmpVlrSt+&tmpTotIpi+&tmpTotFrt+&tmpTotSeg+&tmpTotOut) - &tmpTotDsc



For Each Order tmpNFeCod
	Where tmpNFeCod = &tmpNfeCod
	tmpModCod = &tmpModCod
	tmpNfeDtaDsp = &tmpNfeDtaDsp
	tmpNfeDtaEms = &tmpNfeDtaEms
	tmpNfeChv = &tmpNfeChv
	tmpNfeSer = &tmpNfeSer
	tmpNfeNum = &tmpNfeNum
	tmpNfeFatFilCod = &tmpNfeFatFilCod
	
	tmpTotPro = &tmpTotPro
	tmpTotFrt = &tmpTotFrt
	tmpTotSeg = &tmpTotSeg
	tmpTotOut = &tmpTotOut
	tmpTotDsc = &tmpTotDsc
	tmpTotPed = &tmpTotPed
	tmpTotBasIcm = &tmpTotBasIcm
	tmpTotVlrIcm = &tmpTotVlrIcm
	tmpTotBasSt = &tmpTotBasSt
	tmpVlrSt = &tmpVlrSt
	tmpTotIpi = &tmpTotIpi
	tmpTotNFe = &tmpTotNFe
	
	tmpNfePesBrt = &tmpNfePesBrt
	tmpNfeQtdVol = &tmpNfeQtdVol
	tmpNfeEspVol = &tmpNfeEspVol
		
	Exit
EndFor


commit
]]></Source>
