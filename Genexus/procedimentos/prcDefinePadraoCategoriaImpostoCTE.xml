      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//acha primeira categoria
For Each ORder EmpCod, CatCod
	Where EmpCod = &EmpCod
	Where CatSts = Status_AtivoInativo.ATIVO or CatSts.IsEmpty() or CatSts.IsNull()
	&CatCod = CatCod
	Exit
EndFor


//Atualiza Configuracao
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	if FilTConCod.IsEmpty() or FilTConCod.IsNull()
		FilTConCod = 1
		&TConCod = 1
		commit
	Else
		&TConCod = FilTConCod
	EndIF	
	
	Exit
EndFor

For Each Order EmpCod, TConCod
	Where EmpCod = &EmpCod
	Where TConCod = &TConCod
	
	TCon209 = &CatCod
	
	Exit
EndFor

Commit

]]></Source>
