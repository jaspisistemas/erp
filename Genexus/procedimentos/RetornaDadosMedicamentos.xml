      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	
&ProMedAnv = '' 
&ProMedMot = '' 
&ProMedVlrMax = 0
	
For Each Order EmpCod,ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProMedObr = Status_simNao.Sim
	
	&ProMedAnv = ProMedAnv 
	&ProMedMot = ProMedMot 
	&ProMedVlrMax = ProMedVlrMax
	Exit
EndFor
	
]]></Source>
