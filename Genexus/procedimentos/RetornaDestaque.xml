      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&DstCod.SetEmpty()
For Each Order EmpCod, DstNom
	Where EmpCod = &EmpCod
	Where DstNom = &DstNom
	&DstCod = DstCod	
	Exit
When none
	Do Case
		Case &DstNom = 'EMISSAO CERTIFICADO'
			UltimoCodigoEmpresa.Call(domParCod.DESTAQUE, &EmpCod, 0, &DstCod)
			
			New
				EmpCod = &EmpCod
				DstCod = &DstCod
				DstNom = &DstNom
				DstHex = '1977D4'
				DstR = 25
				DstG = 119
				DstB = 212
				DstCodNom = trim(Str(&DstCod))+' - '+&DstNom.Trim()
			EndNew
		
			Commit
	EndCase

EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
