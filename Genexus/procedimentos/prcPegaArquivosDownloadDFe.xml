      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

//if &IsPodeExecutar = true
	&verManDta = serverdate()
	&verManDta = &verManDta.AddDays(-10)
	
	For Each Order EmpCod, ManCod
		Where EmpCod = &EmpCod
		Where ManFilCod  = &FilCod
		Where ManDta > &verManDta
		Where ManEveSol = 210210 //ciencia
		Where ManXmlNfe.IsEmpty() or ManXmlNfe.IsNull()
		
		GravaXmlNota.Call(EmpCod, ManCha,ManNsu, &sdtConfiguracoesPasta, &IsExisteXml)
		
	EndFor
//Endif


//
]]></Source>
