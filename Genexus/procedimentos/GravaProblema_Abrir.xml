      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,PblCod
	Where EmpCod = &EmpCod
	Where PblCod = &PblCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PROBLEMASOLUCAO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&PblCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1,'','', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PblSts', trim(PblSts), trim(&Status_Problema), &LogErpRegGUID )
	Endif

	PblSts = &Status_Problema
	
	exit
EndFor

Commit

]]></Source>
