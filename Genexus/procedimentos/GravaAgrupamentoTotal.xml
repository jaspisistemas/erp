<Object parentGuid="8da77125-38dc-420b-82a4-3656faad838d" user="WINJEAN\jeanfae" versionDate="2025-10-08T19:05:21.0000000Z" lastUpdate="2025-10-03T16:53:17.0000000Z" checksum="cc0cc36296e62ecf2574826f85c29023" fullyQualifiedName="GravaAgrupamentoTotal" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="d9e558c5-ae7f-4884-a63a-5738f8e6aecf" name="GravaAgrupamentoTotal" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Grava Agrupamento Total" parent="AgruparPedido" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Pedido Destino
&DestinoPedCod = 0
&PedVlrAgr = 0

For &sdtPedidosItem in &sdtPedidos
	
	If &DestinoPedCod = 0
		&DestinoPedCod = &sdtPedidosItem.PedCod	
		&destinoFilCod = &sdtPedidosItem.FiLCod
		&AgrpVlrPedCliCod = &sdtPedidosItem.PedCliCod
		&AgrpLctTip		  = &sdtPedidosItem.LctTip
	EndIF

	validaPedidoAgrupamentoTotal.Call(&sdtPedidosItem.EmPCod, &sdtPedidosItem.FilCod, &sdtPedidosItem.PedCod, 'B', &AgrpVlrPedCliCod, &AgrpLctTip, &IsErroPedido, &Mensagem)
	
	if &IsErroPedido = true
		return
	EndIf
EndFor

//Pedido Destino
&DestinoPedCod = 0
&PedVlrAgr = 0

&MensagemAgrupamento = 'PEDIDOS AGRUPADOS: '
For &sdtPedidosItem in &sdtPedidos
	
	if &DestinoPedCod = 0
		//aqui vamos criar um novo pedido
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &sdtPedidosItem.EmPCod
			Where FilCod = &sdtPedidosItem.FiLCod
			Where PedCod = &sdtPedidosItem.PedCod
			CopiaPedidoVenda.Call(&sdtPedidosItem.EmpCod, &sdtPedidosItem.FilCod, &sdtPedidosItem.PedCod, LctCod, PedCliCod, PedDtaEms, PedVenCod, TabCod, TabPrmCod, TabColCod, &FunPesCod, PedStsDigBlk, &NovoPedCod, &Mensagem)
			Exit
		EndFor
		&MensagemAgrupamento += trim(Str(&sdtPedidosItem.PedCod))
		
		&EmpCod = &sdtPedidosItem.EmPCod		
		&DestinoPedCod = &NovoPedCod
		&destinoFilCod = &sdtPedidosItem.FiLCod
		
		//altera pedido para cancelado
		AtualizaEstoqueGerencialCompra.Call(&sdtPedidosItem.EmpCod, &sdtPedidosItem.FilCod, &sdtPedidosItem.PedCod, &PedDtaFat, &sdtPedidosItem.EmpCod,  Status_Pedido.CANCELADO)
	Else
		&MensagemAgrupamento += ', ' + trim(Str(&sdtPedidosItem.PedCod))
		
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where EmpCod = &sdtPedidosItem.EmPCod
			Where FilCod = &sdtPedidosItem.FiLCod
			Where PedCod = &sdtPedidosItem.PedCod
			where PedQtd > 0
			
			&sdtAddPedidoProduto = new()			
			&sdtAddPedidoProduto.PedItmAcr = PedItmAcr
			&sdtAddPedidoProduto.PedItmDsc = PedItmDsc
			&sdtAddPedidoProduto.PedItmIpi = PedItmIpi
			&sdtAddPedidoProduto.PedItmIcmSt = PedItmIcmSt
			&sdtAddPedidoProduto.PedItmIcmStPob = PedItmIcmStPob
			&sdtAddPedidoProduto.PedItmIcm = PedItmIcm
			&sdtAddPedidoProduto.PedQtdEmb = PedQtdEmb
			&sdtAddPedidoProduto.PedProEmbQtd = PedProEmbQtd
			&sdtAddPedidoProduto.PedItmCmp = PedItmCmp
			
			&sdtAddPedidoProduto.PedItmAjuIpiBas = PedItmAjuIpiBas
			&sdtAddPedidoProduto.PedItmAjuIcmBas = PedItmAjuIcmBas
			&sdtAddPedidoProduto.PedItmAjuIcmStBas = PedItmAjuIcmStBas
			&sdtAddPedidoProduto.PedItmAjuPisBas = PedItmAjuPisBas
			
			&sdtAddPedidoProduto.PedItmPis = PedItmPis
			&sdtAddPedidoProduto.PedItmCofins = PedItmCofins
			
			&sdtAddPedidoProduto.PedItmAjuIcmVlr =PedItmAjuIcmVlr
			&sdtAddPedidoProduto.PedItmAjuCofinsVlr  = PedItmAjuCofinsVlr
			&sdtAddPedidoProduto.PedItmAjuIcmsStPobVlr  = PedItmAjuIcmsStPobVlr
			&sdtAddPedidoProduto.PedItmAjuIcmStVlr  = PedItmAjuIcmStVlr
			&sdtAddPedidoProduto.PedItmAjuIpiVlr  = PedItmAjuIpiVlr 
			&sdtAddPedidoProduto.PedItmAjuPisVlr  = PedItmAjuPisVlr
			
			GravaItemPedidoCompra.Call(&EmpCod, &destinoFilCod, &DestinoPedCod, 0, ProCod, ProGraCod, PedQtd, PedVlrUnt, &sdtAddPedidoProduto, &sdtProdutoLote, &inseridoMensagem, &AlteradoMensagem, &wwpContextUserName, 'S')
			
			//grava pedido kit
			//&PedItmCod
		EndFor
		
		AtualizaEstoqueGerencialCompra.Call(&sdtPedidosItem.EmpCod, &sdtPedidosItem.FilCod, &sdtPedidosItem.PedCod, &PedDtaFat, &sdtPedidosItem.EmpCod,  Status_Pedido.CANCELADO)
		
	EndIF
EndFor

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &destinoFilCod
	Where PedCod = &DestinoPedCod
	PedObsGer += &MensagemAgrupamento
	Exit
EndFor

Commit



if &IsErroPedido = False
	&Mensagem = 'Pedidos Agrupados Com Sucesso!'
		return
EndIf
]]></Source>
