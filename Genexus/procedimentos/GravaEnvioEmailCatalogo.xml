      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&EmlCod = 0
For Each Order EmpCod, EmlTip, (EmlCod)
	Where EmpCod = &EmpCod
	Where EmlTip = &EmlTip
	&EmlCod = EmlCod
	Exit
EndFor
&EmlCod += 1

For &ItemSdtEmail in &SdtEmail
	&EmlUrlTot += &ItemSdtEmail.EmlUrl.Trim() +'; '
EndFor

New
	EmpCod = &EmpCod
	EmlTip = &EmlTip
	EmlCod = &EmlCod
	EmlAss = &EmlAss
	EmlTipEml = &EmlTipEml
	EmlDtaEms = Serverdate()
	EmlHorEms = serverTime()
	EmlDtaEnv = nullvalue(EmlDtaEnv)
	EmlHorEnv = nullvalue(EmlHorEnv)
	EmlSts = Status_Solicitacao.Pendente
	EmlFilCod = &EmlFilCod
	EmlSeqCod = &EmlSeqCod
	EmlSeqItmCod = &EmlSeqItmCod
	EmlObs = &EmlObs
	EmlPesCod = &PesCod
	EmlPedPDF = &EnviarEmailPDF
	EmlPedExcell = &EnviarEmailExcell
	EmlPedImp = False
	EmlUrlTot = &EmlUrlTot
endnew

commit

For &ItemSdtEmail in &SdtEmail
	&EmlItmCod = 0
	For Each Order EmpCod, EmlTip, EmlCod, (EmlItmCod)
		Where EmpCod = &EmpCod
		Where EmlTip = &EmlTip
		Where EmlCod = &EmlCod
		&EmlItmCod = EmlItmCod
		Exit
	EndFor
	&EmlItmCod += 1
	
	new
		EmpCod = &EmpCod
		EmlTip = &EmlTip
		EmlCod = &EmlCod
		EmlItmCod = &EmlItmCod
		EmlUrl = &ItemSdtEmail.EmlUrl
	EndNew
	
	commit
EndFor

]]></Source>
