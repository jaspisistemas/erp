        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

RetornaConfSistema.Call(&Context.EmpCod, &Context.FilCod, domConfSistema.Tcon085_ValorPontos, &Tcon085_ValorPontos)
&Tcon085_ValorPontos = &Tcon085_ValorPontos.Trim()
RetornaSoNumeros.Call(&Tcon085_ValorPontos, &Tcon085_ValorPontos)

&ValorPontosMoeda = val(&Tcon085_ValorPontos)
if &ValorPontosMoeda > 0
	&ValorPontosMoeda = (&ValorPontosMoeda / 100)
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

print Cabecalho

if &AptDtaLctIni = &AptDtaLctFin and (not &AptDtaLctFin.IsEmpty())
	&Periodo = 'DIA: ' + trim(toformattedString(&AptDtaLctIni))
Else
	&Periodo = 'PERÍODO: ' + trim(toformattedString(&AptDtaLctIni)) + ' À ' + trim(toformattedString(&AptDtaLctFin))
EndIf

print Funcionario

&AuxPesCod = 0 
For Each 
	Order EmpCod, AptFunCod, AptDtaLct when &Ordem = 'C'
	Order EmpCod, AptFunNom, AptFunCod, AptDtaLct when &Ordem = 'N'
Where EmpCod = &EmpCod
Where AptOcsCod = &OcsCod when not &OcsCod.IsEmpty()
Where AptOcsProNroCor = &parOcsProNroCor when not &parOcsProNroCor.IsEmpty()
Where AptFunCod = &PesCod when not &PesCod.IsEmpty()
Where (AptDtaLct >= &AptDtaLctIni or &AptDtaLctIni.IsEmpty()) and (AptDtaLct <= &AptDtaLctFin or &AptDtaLctFin.IsEmpty())
	
	&AptQtd = AptQtd
			
	if &AuxPesCod <> AptFunCod
		if not &AuxPesCod.IsEmpty()
			&Mensagem = ''
			if &IsErroEtapaSemPontos = true
				&Mensagem = '#ETAPA SEM PONTOS INFORMADOS#'
			Endif
		
			print Total
						
			&IsErroEtapaSemPontos = false
			&QtdPecas = 0
			&QtdPontos = 0
			&ValorTotalGeral = 0
		EndIf
		
		&FunPesRaz = trim(AptFunNom)
		&OldAptDtaLct.SetEmpty()
	EndIf

	&AptEtpCod = AptEtpCod
	&AptOcsCod = AptOcsCod
	&AptOcsItm = AptOcsItm
	do 'GetCORTE'

	&QtdPecas += AptQtd
	&SomaQtdPecas += AptQtd
	
	&TotPontos = &AptQtd * &GrupCTrQtd
	&ValorTotal = &TotPontos * &ValorPontosMoeda
	&QtdPontos += &TotPontos
	&SomaQtdPontos += &TotPontos
	&ValorTotalGeral += &ValorTotal
	&ValorTotalDia  += &ValorTotal
	&SomaValorTotalGeral += &ValorTotal
	&Count += 1
	&QtdPecasDia += AptQtd

	&AuxPesCod = AptFunCod
EndFor


if &QtdPecas > 0	
	&Mensagem = ''
	if &IsErroEtapaSemPontos = true
		&Mensagem = '#ETAPA SEM PONTOS INFORMADO#'
	Endif

	print Total
Endif

print TotalGeral

Sub 'GetCORTE'
	&OcsProNroCor.SetEmpty()
	&OcsProGraNom.SetEmpty()
	&GrupCTrQtd.SetEmpty()
	&CTrNom.SetEmpty()
	
	For Each order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &AptOcsCod
		Where OcsItm = &AptOcsItm
		
		&OcsProNroCor = OcsProNroCor
		&OcsProGraNom = OcsProGraNom
		
		For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
			Where OcsEtpItm = &AptEtpCod
			&CTrNom = OcsEtpGrupNom
			&GrupCTrQtd = OcsEtpQtd
			Exit
		EndFor
		Exit
	EndFor

	if &GrupCTrQtd <= 0
		&GrupCTrQtd = 0
		&IsErroEtapaSemPontos = true
	EndiF
EndSub
