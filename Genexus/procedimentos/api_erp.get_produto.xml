<Object parentGuid="9ce80e22-bc71-45b5-9700-e3f9cead4c4e" user="WINJEAN\jeanfae" versionDate="2026-01-21T14:58:39.0000000Z" lastUpdate="2026-01-21T14:40:42.0000000Z" checksum="27a9f4dd16a4646850ed35e9694be422" fullyQualifiedName="api_erp.get_produto" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="57deb3a3-7ce5-489d-9669-938db1bc39f7" name="get_produto" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_produto" parent="api_erp.Produto" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	RetornaConfSistema_CadastroProduto.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtConfSistema_CadastroProduto)
	
	For Each ORder EmpCod, ProCod
		Where EmpCod = &wwpContext.EmpCod
		Where ProCod = &ProCod
		Where ProSts <> Status_Produto.EXCLUIDO //excluidos nao.
		
		&sdtProduto.sts = 'J200'
		&sdtProduto.obs = 'OK'
		
		&sdtProduto.Cod = ProCod
		&sdtProduto.Psts = ProSts
		//&sdtProduto.GraCod
		&sdtProduto.Ref = ProRef
		&sdtProduto.Nom = ProNom
		&sdtProduto.Bar = ProBar
		&sdtProduto.MarN = MarNom.Trim()
		&sdtProduto.MarC = MarCod
		
		&sdtProduto.Scod = ProSetCod
		&sdtProduto.Snom = ProSetNom
		&sdtProduto.Ecod = ProEmbCod
		&sdtProduto.Enom = format('%2 | %3', trim(ProEmbUnd), trim(ProEmbNom))
		&sdtProduto.Gcod = GrupCod
		&sdtProduto.Gnom = format('%1 - %2', GrupHie.Trim(), GrupNomCmp.Trim())
		&sdtProduto.Ccod = ProCatCod
		&sdtProduto.Cnom = ProCatNom.Trim()
		
		&NcmCod = NcmCod
		&NcmCestCod = ProNcmCest
		&sdtProduto.Ncm = NcmCod
		&sdtProduto.Cest = ProNcmCest
		do 'getNomeCest'
		&sdtProduto.CestN = &NcmCestCodDes
		
		&sdtProduto.EstMin = retiraZerosDepoisVirgulaxCasas.Udp(0, ProQtdMin.ToFormattedString())
		&sdtProduto.EstMax = retiraZerosDepoisVirgulaxCasas.Udp(0, ProQtdMax.ToFormattedString())
		&sdtProduto.TCus = ProTipCus.ToString()
		
		if not ProVlrCus.IsEmpty() and not ProVlrCus.IsNull()
			&sdtProduto.VCusFix = trim(ProVlrCus.ToFormattedString())
		Else
			&sdtProduto.VCusFix = trim(ProVlrCusFix.ToFormattedString())
		Endif
		&sdtProduto.VCusFix = &sdtProduto.VCusFix.Replace(',','.')
		&sdtProduto.TDef = ProTipDef.ToString()
		&sdtProduto.Pori = '0' //NACIONAL
		
		Exit
	When None
		if &ProCod > 0
			&sdtProduto.sts = 'E999'
			&sdtProduto.obs = trim(&ProCod.ToString()) + ' Produto não Localizado!'
		Else
			&sdtProduto.sts = 'J200'
			&sdtProduto.obs = 'NEW'
			
			&MarCod.SetEmpty()
			&MarNom.SetEmpty()
			&SetCod.SetEmpty()
			&SetNom.SetEmpty()
			&EmbCod.SetEmpty()
			&EmbNom.SetEmpty()
			&GrupCod.SetEmpty()
			&GrupNomCmp.SetEmpty()
			For Each Order EmpCod
				Where EmpCod = &wwpContext.EmpCod
				
				For Each Order EmpCod, MarCod
					&MarCod = MarCod
					&MarNom = MarNom
					Exit
				EndFor
				
				For Each Order EmpCod, SetCod
					&SetCod = SetCod
					&SetNom = SetNom
					Exit
				EndFor
				
				For Each Order EmpCod, EmbCod
					&EmbCod = EmbCod
					&EmbNom = EmbUnd.Trim() + ' | ' + EmbNom.Trim()
					Exit
				EndFor
				
				For Each Order EmpCod, GrupAnaSin, GrupHiePadL
					Where GrupAnaSin = 'A'
					&GrupCod = GrupCod
					&GrupNomCmp = GrupNomCmp
					&GrupHie = GrupHie
					Exit
				EndFor
				
				For Each Order EmpCod, CatCod
					Where CatSts = Status_AtivoInativo.ATIVO
					&CatCod = CatCod
					&CatNom = CatNom
					Exit
				EndFor
				
				
				Exit
			Endfor
			
			//&ProIMC = val(&sdtConfSistema_CadastroProduto.TCon032_MargemPadraoProduto)
			//&ProIMCTot = &ProIMC
			//&ProInfCmp = iif(&sdtConfSistema_CadastroProduto.TCon125_AddComplementoProduto = 'S', Status_SimNao.Sim, Status_SimNao.Nao)
			
			//&ProCatCod = 1
			//&ProDesMax = 100
			//&ProEmbCod = 1
			
			//&ProReqQtd = false
			//&ProReqVlr = false
			//&ProRepItm = false
			//&ProPadUltCmp = 'C'
			//&ProEstTip = TipoEstoque.ATUALIZAR_ESTOQUE
			
			&sdtProduto.Cod = 0
			//&sdtProduto.GraCod
			&sdtProduto.Psts = Status_Produto.ATIVO
			&sdtProduto.Ref = ''
			&sdtProduto.Nom = ''
			&sdtProduto.Bar = ''
			&sdtProduto.MarN = &MarNom
			&sdtProduto.MarC = &MarCod
			
			&sdtProduto.Scod = &SetCod
			&sdtProduto.Snom = &SetNom
			&sdtProduto.TDef = Definicao.REVENDA
			&sdtProduto.Ecod = &EmbCod
			&sdtProduto.Enom = &EmbNom
			&sdtProduto.Gcod = &GrupCod
			&sdtProduto.Gnom = format('%1 - %2', &GrupHie.Trim(), &GrupNomCmp.Trim())
			&sdtProduto.Ccod = &CatCod
			&sdtProduto.Cnom = &CatNom
			&sdtProduto.Ncm = 99
			&sdtProduto.Cest = 0
			//&sdtProduto.EstMin = '0'
			&sdtProduto.TCus = TipoCusto.UltimaCompra
			
			&sdtProduto.Pori = trim(ProOriTriCod.ToFormattedString())
			
		Endif
	EndFor


	//GETPRECOS
	if &sdtConfSistema_CadastroProduto.TCon130_MostrarTabelaPreco <> 'N'
		retornaAutorizacaoApi.Call('WWTABELAPRECO', &wwpContext, &AutGrpCod, &TabelaPrecoAutNiv)
		if &TabelaPrecoAutNiv > 1
			
			padraousuario.Call('L', '#TABELASSELECIONADAS#', 1, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
			if not &PadObs.IsEmpty()
				&UMTabCod = trim(Substr(&PadObs, 1, 5))
				&DOISTabCod = trim(Substr(&PadObs, 6, 5))
			Else
				For Each order EmpCod, FilCod
					Where EmpCod = &wwpContext.EmpCod
					Where FilCod = &wwpContext.FilCod
					
					&UMTabCod = FilTabCod
					&DOISTabCod = FilTabPrmCod
					
					Exit
				EndFor
			Endif			
			
			
			if not &UMTabCod.IsEmpty()

				RetornaConfiguracoesTabelaVenda.Call(&wwpContext.EmpCod, &UMTabCod, &UMTabALtCod, &TabNom, &UmTabRecCol, &UMTabIsPerCol1)
			
				&sdtProdutoPrecos = new()
				&sdtProdutoprecos.ord = 1
				&sdtProdutoprecos.tabC = &UMTabCod
				&sdtProdutoprecos.tabN = "TABELA: " + trim(&UMTabCod) +' - "'+trim(&TabNom)+'"'
				
//				padraousuario.Call('L', '#PRODUTOPRECOOPC', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
//				if &PadObs.IsEmpty()					
//					&PadObs = trim(Str(&sdtConfSistema_CadastroProduto.TCon108_CasasDecimais)) + 'N'
//					if &UmTabRecCol = true
//						&PadObs += 'S'
//					Else
//						&PadObs += 'N'
//					Endif
//				Endif
//				&sdtConfSistema_CadastroProduto.TCon108_CasasDecimais = Val(Substr(&PadObs,1,1))
//				&txtPercentuais = Substr(&PadObs,2,1)
//				&txtRecalcu = Substr(&PadObs,3,1)
//				do 'padraoColunas'
				
				&TabCod = &UMTabCod
				RetornaPrecoVendaProduto.Call(&wwpContext.EmpCod, &TabCod, &ProCod, &TabPrc1, &TabPrc2, &TabPrc3, &TabPrc4, &TabPrc5, &TabPrc6, &TabPrc7, &TabPrc8, &TabPrc9, &Perc1, &Perc2, &Perc3, &Perc4, &Perc5, &Perc6, &Perc7, &Perc8, &Perc9)
				&sdtProdutoprecos.v1 = trim(&TabPrc1.ToFormattedString())
				&sdtProdutoprecos.v2 = trim(&TabPrc2.ToFormattedString())
				&sdtProdutoprecos.v3 = trim(&TabPrc3.ToFormattedString())
				&sdtProdutoprecos.v4 = trim(&TabPrc4.ToFormattedString())
				&sdtProdutoprecos.v5 = trim(&TabPrc5.ToFormattedString())
				&sdtProdutoprecos.v6 = trim(&TabPrc6.ToFormattedString())
				&sdtProdutoprecos.v7 = trim(&TabPrc7.ToFormattedString())
				&sdtProdutoprecos.v8 = trim(&TabPrc8.ToFormattedString())
				&sdtProdutoprecos.v9 = trim(&TabPrc9.ToFormattedString())
				
				&sdtProdutoprecos.v1 = &sdtProdutoprecos.v1.Replace(',', '.')
				&sdtProdutoprecos.v2 = &sdtProdutoprecos.v2.Replace(',', '.')
				&sdtProdutoprecos.v3 = &sdtProdutoprecos.v3.Replace(',', '.')
				&sdtProdutoprecos.v4 = &sdtProdutoprecos.v4.Replace(',', '.')
				&sdtProdutoprecos.v5 = &sdtProdutoprecos.v5.Replace(',', '.')
				&sdtProdutoprecos.v6 = &sdtProdutoprecos.v6.Replace(',', '.')
				&sdtProdutoprecos.v7 = &sdtProdutoprecos.v7.Replace(',', '.')
				&sdtProdutoprecos.v8 = &sdtProdutoprecos.v8.Replace(',', '.')
				&sdtProdutoprecos.v9 = &sdtProdutoprecos.v9.Replace(',', '.')

				RetornaColunas_Nome.Call(&wwpContext.EmpCod, &UMTabCod, &SdtColunasTabela)				
				&sdtProdutoprecos.n1 = &SdtColunasTabela.TabColNom1
				&sdtProdutoprecos.n2 = &SdtColunasTabela.TabColNom2
				&sdtProdutoprecos.n3 = &SdtColunasTabela.TabColNom3
				&sdtProdutoprecos.n4 = &SdtColunasTabela.TabColNom4
				&sdtProdutoprecos.n5 = &SdtColunasTabela.TabColNom5
				&sdtProdutoprecos.n6 = &SdtColunasTabela.TabColNom6
				&sdtProdutoprecos.n7 = &SdtColunasTabela.TabColNom7
				&sdtProdutoprecos.n8 = &SdtColunasTabela.TabColNom8
				&sdtProdutoprecos.n9 = &SdtColunasTabela.TabColNom9
				
				&sdtProdutoprecos.t1 = &SdtColunasTabela.Tem1
				&sdtProdutoprecos.t2 = &SdtColunasTabela.Tem2
				&sdtProdutoprecos.t3 = &SdtColunasTabela.Tem3
				&sdtProdutoprecos.t4 = &SdtColunasTabela.Tem4
				&sdtProdutoprecos.t5 = &SdtColunasTabela.Tem5
				&sdtProdutoprecos.t6 = &SdtColunasTabela.Tem6
				&sdtProdutoprecos.t7 = &SdtColunasTabela.Tem7
				&sdtProdutoprecos.t8 = &SdtColunasTabela.Tem8
				&sdtProdutoprecos.t9 = &SdtColunasTabela.Tem9

				&sdtProduto.precos.Add(&sdtProdutoPrecos)
			Endif
		
			if not &DOISTabCod.IsEmpty()
				
				RetornaConfiguracoesTabelaVenda.Call(&wwpContext.EmpCod, &DOISTabCod, &DOISTabALtCod, &TabNom, &DOISTabRecCol, &DOISTabIsPerCol1)
		
				&sdtProdutoprecos = new()
				&sdtProdutoprecos.ord = 2
				&sdtProdutoprecos.tabC = &DOISTabCod
				&sdtProdutoprecos.tabN = "TABELA: " + trim(&DOISTabCod) +' - "'+trim(&TabNom)+'"'
//				padraousuario.Call('L', '#PRODUTOPRECO2OPC', &Context.PesCod, &Context.EmpCod, &PadObs, &PadDtaMod)
//				if &PadObs.IsEmpty()					
//					&PadObs = trim(Str(&sdtConfSistema_CadastroProduto.TCon108_CasasDecimais)) + 'N'
//					if &DOISTabRecCol = true
//						&PadObs += 'S'
//					Else
//						&PadObs += 'N'
//					Endif
//				Endif
//				&sdtConfSistema_CadastroProduto.TCon108_CasasDecimais = Val(Substr(&PadObs,1,1))
//				do 'padraoColunas'

				&TabCod = &DOISTabCod
				RetornaPrecoVendaProduto.Call(&wwpContext.EmpCod, &TabCod, &ProCod, &TabPrc1, &TabPrc2, &TabPrc3, &TabPrc4, &TabPrc5, &TabPrc6, &TabPrc7, &TabPrc8, &TabPrc9, &Perc1, &Perc2, &Perc3, &Perc4, &Perc5, &Perc6, &Perc7, &Perc8, &Perc9)
				&sdtProdutoprecos.v1 = trim(&TabPrc1.ToFormattedString())
				&sdtProdutoprecos.v2 = trim(&TabPrc2.ToFormattedString())
				&sdtProdutoprecos.v3 = trim(&TabPrc3.ToFormattedString())
				&sdtProdutoprecos.v4 = trim(&TabPrc4.ToFormattedString())
				&sdtProdutoprecos.v5 = trim(&TabPrc5.ToFormattedString())
				&sdtProdutoprecos.v6 = trim(&TabPrc6.ToFormattedString())
				&sdtProdutoprecos.v7 = trim(&TabPrc7.ToFormattedString())
				&sdtProdutoprecos.v8 = trim(&TabPrc8.ToFormattedString())
				&sdtProdutoprecos.v9 = trim(&TabPrc9.ToFormattedString())

				RetornaColunas_Nome.Call(&wwpContext.EmpCod, &DOISTabCod, &SdtColunasTabela)				
				&sdtProdutoprecos.n1 = &SdtColunasTabela.TabColNom1
				&sdtProdutoprecos.n2 = &SdtColunasTabela.TabColNom2
				&sdtProdutoprecos.n3 = &SdtColunasTabela.TabColNom3
				&sdtProdutoprecos.n4 = &SdtColunasTabela.TabColNom4
				&sdtProdutoprecos.n5 = &SdtColunasTabela.TabColNom5
				&sdtProdutoprecos.n6 = &SdtColunasTabela.TabColNom6
				&sdtProdutoprecos.n7 = &SdtColunasTabela.TabColNom7
				&sdtProdutoprecos.n8 = &SdtColunasTabela.TabColNom8
				&sdtProdutoprecos.n9 = &SdtColunasTabela.TabColNom9
				
				&sdtProdutoprecos.t1 = &SdtColunasTabela.Tem1
				&sdtProdutoprecos.t2 = &SdtColunasTabela.Tem2
				&sdtProdutoprecos.t3 = &SdtColunasTabela.Tem3
				&sdtProdutoprecos.t4 = &SdtColunasTabela.Tem4
				&sdtProdutoprecos.t5 = &SdtColunasTabela.Tem5
				&sdtProdutoprecos.t6 = &SdtColunasTabela.Tem6
				&sdtProdutoprecos.t7 = &SdtColunasTabela.Tem7
				&sdtProdutoprecos.t8 = &SdtColunasTabela.Tem8
				&sdtProdutoprecos.t9 = &SdtColunasTabela.Tem9

				&sdtProduto.precos.Add(&sdtProdutoPrecos)
			Endif
		Endif
	Endif
Endif

sub 'getNomeCest'
	For Each Order NcmCod, NcmCestCod
		Where NcmCod = &NcmCod
		Where NcmCestCod = &NcmCestCod
		&NcmCestCodDes = NcmCestCodDes
		Exit
	When none
		&NcmCestCodDes = '000000 - CEST NÃO DISPONIVEL/INFORMADO'
	EndFor
EndSub
]]></Source>
