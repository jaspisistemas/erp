      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Pedido Destino
&DestinoPedCod = 0
&PedVlrAgr = 0

For &sdtPedidosItem in &sdtPedidos
	
	If &DestinoPedCod = 0
		&DestinoPedCod = &sdtPedidosItem.PedCod	
		&destinoFilCod = &sdtPedidosItem.FiLCod
		&AgrpVlrPedCliCod = &sdtPedidosItem.PedCliCod
		&AgrpLctTip		  = &sdtPedidosItem.LctTip
	EndIF

	validaPedidoAgrupamentoTotal.Call(&sdtPedidosItem.EmPCod, &sdtPedidosItem.FilCod, &sdtPedidosItem.PedCod, 'A', &AgrpVlrPedCliCod, &AgrpLctTip, &IsErroPedido, &Mensagem)
	
	if &IsErroPedido = true
		return
	EndIf
EndFor

//Pedido Destino
&DestinoPedCod = 0
&PedVlrAgr = 0

For &sdtPedidosItem in &sdtPedidos

	if &DestinoPedCod = 0
		&EmpCod = &sdtPedidosItem.EmPCod
		&DestinoPedCod = &sdtPedidosItem.PedCod
		&destinoFilCod = &sdtPedidosItem.FiLCod
	Else
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &sdtPedidosItem.EmPCod
			Where FilCod = &sdtPedidosItem.FiLCod
			Where PedCod = &sdtPedidosItem.PedCod
			&PedVlrAgr += PedVlrLiq
			PedVlrAgr = (PedVlrLiq * -1)
			PedCodAgr = &DestinoPedCod
			PedStsFin = Status_Financeiro.FECHADO
			
			CriticasPedido.Call(EmpCod, FilCod, PedCod, TipoCriticaPedido.FinanceiroAgrupado, &FunPesCod)
			CriticasPedido.Call(EmpCod, FilCod, PedCod, TipoCriticaPedido.FechadoFinanceiro, &FunPesCod)
			Exit
		EndFor
	
	EndIF
EndFor

if &DestinoPedCod <> 0 and &PedVlrAgr > 0
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &destinoFilCod
		Where PedCod = &DestinoPedCod
		PedVlrAgr = &PedVlrAgr
		PedCodAgr = PedCod
		CriticasPedido.Call(EmpCod, FilCod, PedCod, TipoCriticaPedido.FinanceiroAgrupado, &FunPesCod)
		Exit
	EndFor
EndIf
	
Commit

if &IsErroPedido = False
	&Mensagem = 'Pedidos Agrupados Com Sucesso!'
		return
EndIf
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
