      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&MarketPlaceID = '8aec0a32736646889676c911f341768a'
&EmpCodSec ='POR HORA NAO USA'
&IsTem = true

&limite = 50

Do while &IsTem = true
	&Page += 1
	HostWebServiceJaspiADM.Call(&EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
//	&EmpWebHost = '192.168.100.3'//FASE DE TESTE
//	&EmpWebBaseUrl = 'adm16'
	
	&HttpClient.Host = &EmpWebHost //servidor  sistema.efrete.com
	&HttpClient.Port = &EmpWebPor
	&HttpClient.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	&HttpClient.Secure = 0 //false
	
	&LongVarchar  =  '<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:adm="ADM_JASPI">'
	&LongVarchar +=  '   <soapenv:Header/>'
	&LongVarchar +=  '   <soapenv:Body>'
	&LongVarchar +=  '      <adm:ppJASPI_ZoopPagamentos.Execute>'
	&LongVarchar +=  '         <adm:Clicodsec>'+&EmpCodSec+'</adm:Clicodsec>'
	&LongVarchar +=  '         <adm:Codigozoop>'+trim(&Seller) +'</adm:Codigozoop>'
	&LongVarchar +=  '      </adm:ppJASPI_ZoopPagamentos.Execute>'
	&LongVarchar +=  '   </soapenv:Body>'
	&LongVarchar +=  '</soapenv:Envelope>'
	
	////ADICIONANDO CABEÇALHO DE COMUNICAÇÃO
	&HttpClient.AddHeader('Content-Type','text/xml;charset=UTF-8')
	&HttpClient.AddHeader('SOAPAction', '"ADM_JASPIaction/APPJASPI_ZOOPPAGAMENTOS.Execute"')
	&HttpClient.AddString(&LongVarchar) //ADICIONANDO PARAMETROS
	&HttpClient.Execute('POST','appjaspi_zooppagamentos.aspx') //FAZENDO POST DE COSNULTA  https://dev.efrete.com:6061/Services/LogonService.asmx?WSDL NÃO FIZ POR WSDL POIS RETORNAVA ERRO
	//
	If &HttpClient.ErrCode = 0 //sem erro de comunicação
		&LongVarchar = ''
		&longvarchar = &HttpClient.toString()	
		&longvarchar = strReplace(&longvarchar,'<?xml version = "1.0" encoding = "utf-8"?>', '')
		&longvarchar = strReplace(&longvarchar,'<SOAP-ENV:Envelope xmlns:SOAP-ENV="http://schemas.xmlsoap.org/soap/envelope/" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:SOAP-ENC="http://schemas.xmlsoap.org/soap/encoding/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">', '')
		&longvarchar = strReplace(&longvarchar,'<SOAP-ENV:Body>', '')
		&longvarchar = strReplace(&longvarchar,'</SOAP-ENV:Body>', '')
		&longvarchar = strReplace(&longvarchar,'</SOAP-ENV:Envelope>', '')
		
		&longvarchar = strReplace(&longvarchar,'<ppJASPI_ZoopPagamentos.ExecuteResponse xmlns="ADM_JASPI">', '')
		&longvarchar = strReplace(&longvarchar,'</ppJASPI_ZoopPagamentos.ExecuteResponse>', '')
		&longvarchar = strReplace(&longvarchar,'<Mensagemout xmlns="ADM_JASPI">', '')
		&longvarchar = strReplace(&longvarchar,'</Mensagemout>', '')
		
		&Erro = 0
	Else
		&Erro = 1
		&Mensagem = &HttpClient.ErrDescription.ToString()
	EndIf
	
	&zoopEvents.FromJson(&LongVarchar)
	&IsTem = &zoopEvents.has_more //TEM MAIS PRA VIR.
	
	for &zoopEventsItem in &zoopEvents.items
		&GravaZOOP = ''
		&GravaZOOP = &zoopEventsItem.payload.ToJson()
		&zoopEvent = new()
		&zoopEvent.fee_details.Clear()
		&zoopEvent.history.Clear()
		&zoopEvent.FromJson(&GravaZOOP)
		//padraousuario.Call('G','&zoopEvent'+ trim(str(&Page)), 1, 1, &zoopEvent.ToJson(), &PadDtaMod)
		Do CAse
			Case UPPER(&zoopEvent.resource) = 'TRANSACTION'
				if upper(&zoopEvent.status) <> 'FAILED'
					prcGravaRegistroEntradaZoop.Call(&EmpCod, &FilCod, &zoopEvent, &GravaZOOP)
				Endif
			Case UPPER(&zoopEvent.resource) = 'RECEIVABLE'
				prcGravaRegistroEntradaZoop_Recebimento.Call(&EmpCod, &FilCod, &zoopEvent, &GravaZOOP)
		EndCAse
	EndFor	
	&zoopEvents.items.Clear()
EndDo
]]></Source>
