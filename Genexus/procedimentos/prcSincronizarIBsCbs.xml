      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod
	Where EmpCod = &EmpCod
	&EmpCodSec = EmpCodSec
	&EmpSyncIbs = EmpSyncIbs
EndFor

if &EmpSyncIbs.IsEmpty()
	&Data = ymdtod(2025,10,1)
	&DataTimesTamp = DatetoTimestamp.Udp(&Data)
Else
	&DataTimesTamp = DateTimeToTimestamp.Udp(&EmpSyncIbs)
Endif


&Varchar = '&CodigoAutenticacao='+&EmpCodSec.Trim() + '&DataTimesTamp='+trim(str(&DataTimesTamp))

&HttpClient.Execute('GET', 'https://adm.jaspi.com.br/impostos/ibscbs?'+&Varchar.Trim())

if &HttpClient.StatusCode = 200 //Nao deu erro de servidor
	&sdtImpostos.FromJson(&HttpClient.ToString())
	
	if &sdtImpostos.sts = 'J200'
		
		prcGravaImpostos.Call(&sdtImpostos)
		&Mensagem = 'Tabelas Sincronizadas'
		&IsOk = true
	Else
		&Mensagem = &sdtImpostos.sts + ' - ' + &sdtImpostos.msg
	Endif	
Else
	&Mensagem = trim(str(&HttpClient.StatusCode)) + ' ['+&HttpClient.ErrDescription+']'
Endif
]]></Source>
