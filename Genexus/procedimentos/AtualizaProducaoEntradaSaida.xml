      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &Sinal = '+' //SOMAR
	&AuxEstTipQtd = &PedQtd
Else //DIMINUIR
	&AuxEstTipQtd = &PedQtd * -1
EndIF	

&EsseAno = YMDtoD(year(Serverdate()), 1, 1)

If not &PedDtaFat.IsEmpty()
	&DataProducao = &PedDtaFat
	
	&EstTipAno = year(&PedDtaFat)
	&EstTipMes = month(&PedDtaFat)
Else
	&DataProducao = serverdate()
	
	&EstTipAno = year(Serverdate())
	&EstTipMes = month(Serverdate())
EndIF

For Each Order EmpCod, FilCod ProCod, ProGraCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Exit
When None
    New   //ESTOQUE
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstLoc = ''
		EstABC_Ren = 'D'
		EstABC_Qtd = 'D'
		EstUltEnt = nullvalue(EstUltEnt)
		EstUltSai = nullvalue(EstUltSai)
		EstUltFab = nullvalue(EstUltFab)
		EstQtd = 0
		EstPrd = 0
		EstVen = 0
		EstCom = 0
		EstMin = 0
		EstFabMin = 0
		EstFab = 0
    EndNew
EndFor

&auxEstTipCus = 0 
//IF &EstTipEntSai = Status_EntradaSaida.Entrada //ENTRADA
	&auxEstTipCus = (&EstTipCus * &AuxEstTipQtd)
	
//EndIf

For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstTipCod, EstTipAno, EstTipMes
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstTipCod = &EstTipCod
	Where EstTipAno = &EstTipAno
	Where EstTipMes = &EstTipMes
	
	if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
		EstTipQtd += &AuxEstTipQtd		
		EstTipCus += &auxEstTipCus //CUSTO MEDIO
	Endif

	If EstTipCus < 0
		EstTipCus = 0
	EndIF
	
	Exit
When None
	
	do 'MES_ANTERIOR'

	New
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstTipCod = &EstTipCod
		EstTipAno = &EstTipAno
		EstTipMes = &EstTipMes
		EstTipQtd = &AntEstTipQtd + &AuxEstTipQtd
		EstTipCus = &AntEstTipCus + &auxEstTipCus
	EndNew
EndFor

commit

UltimasDatasEstoqueProducao.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &EstUltFab)

For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
		Do Case 
			//		Case &EstTipCod = 1 //EMPRESA
			//			EstQtd += &AuxEstTipQtd
			Case &EstTipCod = 2 //PRODUCAO
				
				//			if &DataProducao >= &EsseAno 
				EstPrd += &AuxEstTipQtd
				//			EndIF
				//		Case &EstTipCod = 3 //FISCAL
				//			EstQtdFis += &AuxEstTipQtd
		EndCase	
		EstVen = EstVen_FORMULA
		EstCom = EstCom_FORMULA
	Else
		EstQtd = 0
		EstVen = 0
		EstCom = 0
		EstSug = 0
	Endif

	//EstUltSai = &EstUltSai
	//EstUltEnt = &EstUltEnt
	EstUltFab = &EstUltFab //JDF so atualiza essa
	
	if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
		EstSug = round(((EstMin + EstVen) - (EstQtd + EstCom + EstPrd)),0) //SEPARADO POR CAUSA DA FORMULA //JDF
	Endif

EndFor

commit

////SEPARADO POR CAUSA DA FORMULA //JDF
//For Each Order EmpCod, FilCod, ProCod, ProGraCod
//	Where EmpCod = &EmpCod
//	Where FilCod = &FilCod
//	Where ProCod = &ProCod
//	Where ProGraCod = &ProGraCod
//	
//	EstSug = EstSug_FORMULA
//EndFor
//Commit

Sub 'MES_ANTERIOR'
    &AntEstTipQtd = 0
    &AntEstTipCus = 0
	
    For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstTipCod, (EstTipAno), (EstTipMes)
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
	    Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where EstTipCod = &EstTipCod
		//Where EstTipAno = &EstTipAno
		
        &AntEstTipQtd = EstTipQtd
        &AntEstTipCus = EstTipCus
        exit
    EndFor
EndSub
]]></Source>
