      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedPraParNom.SetEmpty()
&Vencimentos.SetEmpty()
&sdtVencimentos.Clear()

For Each order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&PedDtaEms = PedDtaEms
		
	For Each order EmpCod, FilCod, PedCod, PedVctCod
		&Dias = PedVctDta - &PedDtaEms
		
		Do Case
			Case &Dias > 9999
				&PedPraParNom += '999 '
			Case &Dias < -999
				&PedPraParNom += '-99 '
			Otherwise
				&PedPraParNom += PadL(trim(str(&Dias)), 3, '0') + ' '
		EndCase
		
		if &Vencimentos.IsEmpty()
			&Vencimentos += trim(toformattedString(PedVctDta))
		Else
			&Vencimentos += ' - '  + trim(toformattedString(PedVctDta))
		EndIf
		
		&sdtVencimentosItem = new()
		&sdtVencimentosItem.CreDtaVct = PedVctDta
		&sdtVencimentos.Add(&sdtVencimentosItem)

	EndFor
EndFor

if &sdtVencimentos.Count = 0
	&Data = &PedDtaEms + 1
	&Vencimentos = trim(toformattedString(&Data))
	
	&sdtVencimentosItem = new()
	&sdtVencimentosItem.CreDtaVct = &Data
	&sdtVencimentos.Add(&sdtVencimentosItem)
Endif
]]></Source>
