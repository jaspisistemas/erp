      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//https://maps.googleapis.com/maps/api/distancematrix/json?units=imperial&origins=Washington,DC&destinations=New+York+City,NY&key=YOUR_API_KEY
// chave conta google = AIzaSyDdHcaJMXFrR4xEUPi_OacVSFNBdI-Gf_c
&SaidaVarchar = ''

For each Order EmpCod,CidCod
	Where EmpCod = &EmpCod
	Where CidCod = &OpeOriCidCod
	Where UfeCod = &OpeOriCidUfe
	
	&OriCidNom = CidNom
	Exit
EndFor


For each Order EmpCod,CidCod,UfeCod
	Where EmpCod = &EmpCod
	Where CidCod = &OpeDstCidCod
	Where UfeCod = &OpeDstCidUfe
	
	&DstCidNom = CidNom
	Exit
EndFor

&OriCidNom = &OriCidNom +'-'+&OpeOriCidUfe

&DstCidNom = &DstCidNom +'-'+&OpeDstCidUfe

If not &DstCidNom.Trim().IsEmpty() and not &OriCidNom.Trim().IsEmpty()
	
	&httpClient.Host = 'maps.googleapis.com'
	&httpClient.Port = 80
	&httpClient.BaseUrl = '/maps/api/distancematrix/json'
	&httpClient.Secure = True
//	&httpClient.Timeout = 10
	&httpClient.Execute("GET", '?units=metric&origins='+&OriCidNom+'&destinations='+&DstCidNom+'&mode=driving&language=pt-BR&key=AIzaSyDdHcaJMXFrR4xEUPi_OacVSFNBdI-Gf_c')
 	
	padraoUsuario.Call('G', '#OPERACAOTRANSPORTE', &Context.PesCod, &Context.EmpCod, &HttpClient.toString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
	If &httpClient.ErrCode = 0
	
		&DistanceMatrixResponse.FromJson(&httpClient.ToString())
		If &DistanceMatrixResponsedistance.distance.value.Trim() <> ''
			&SaidaVarchar = trim(&DistanceMatrixResponsedistance.distance.text)
		Else
			Msg('Distância não encontrada!')
		EndIf
	Else 
		msg(&httpClient.ErrDescription)
	EndIF
EndIf

If not &SaidaVarchar.Trim().IsEmpty()
	&SaidaVarchar  = &SaidaVarchar.Replace('Km','')
	&SaidaVarchar  = &SaidaVarchar.Replace('KM','')
	&SaidaVarchar  = &SaidaVarchar.Replace(' ','')
	&OpeViaDstPer  = val(&SaidaVarchar.Replace(' ',''))
EndIf

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
