      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[// O conteúdo da tag Integrador deve ser uma CONSTANTE, pois é ela quem identifica seu sistema de gestão,
//Suporte e-FRETE:	Seguem credenciais para uso em ambiente de homologação:
//Integrador:		JASPI SISTEMAS DE INFORMÁTICA
//CNPJ:				21826923000177
//Usuário:			usuario@jaspi
//Senha:			usuario#jaspi
//Hash:				b754b48e-8c22-4cfc-bb0a-3524a76284c9

LoadWWPContext(&Context)
//Config do Servidor
HostWebServiceEfrete.Call(&EmpWebHost, &ExecuteUrl, '', '', &Hash)
&ExecuteUrl			+= 'Pef/AdicionarPagamento'

&HttpClient.Host	= 	&EmpWebHost
&HttpClient.Secure	= 	1
		
//Header do Xml
&HttpClient.AddHeader(!'Content-Type', !'application/json')
&HttpClient.AddHeader(!'Accept-Encoding', !'gzip, deflate, br')

//Realiza o Envio ao WebService
&JSONOpeDtaLib	= Trim(Str(Year(&parmOpeDtaLib))) + '-' + Trim(Str(Month(&parmOpeDtaLib))) + '-' + Trim(Str(Day(&parmOpeDtaLib)))
&OpePgtNro 		= Padl(Str(&Context.EmpCod),6,'0') + Padl(Str(&Context.FilCod),6,'0')+ Padl(Str(&parmOpePgtCod),6,'0')	
&OpePgtDoc		= &parmOpePgtDoc + '-' + Trim(Str(&parmOpePgtCod))
	
For Each Order EmpCod, FilCod, OpeCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	Where OpeCod = &parmOpeCod
	
	&JSONBody	=	'{'
	&JSONBody	+=	'    "CodigoIdentificacaoOperacao": "'+	Trim(&parmOpeNroCiot) +'",'
	&JSONBody	+=	'    "Pagamentos": ['
	&JSONBody	+=	'        {'
	&JSONBody	+=	'            "IdPagamentoCliente": "'+ &OpePgtNro +'",'
	&JSONBody	+=	'            "DataDeLiberacao": "'+ Trim(&JSONOpeDtaLib) +'",'
	&JSONBody	+=	'            "Valor": "'+ Trim(Str(&parmOpePgtVal)) +'",'
	If OpeEmiGra = True
		&JSONBody	+=	'          "TipoPagamento": "'+ PefServiceTipoPagamento.TransferenciaBancaria +'",'
	Else
		&JSONBody	+=	'          "TipoPagamento": "'+ PefServiceTipoPagamento.eFRETE +'",'
	EndIf
	&JSONBody	+=	'            "Categoria": "'+ &parmOpePgtCat +'",'
	&JSONBody	+=	'            "Documento": "'+ Trim(&OpePgtDoc) +'",'
	&JSONBody	+=	'            "InformacoesBancarias": {'
	&JSONBody	+=	'                "InstituicaoBancaria": "'+ Trim(&parmOpePgtBan) +'",'
	&JSONBody	+=	'                "Agencia": "'+ Trim(&parmOpePgtAge) +'",'
	&JSONBody	+=	'                "Conta": "'+ Trim(&parmOpePgtCon) +'",'
	&JSONBody	+=	'                "TipoConta": "'+ Trim(&parmOpePgtConTip) +'"'
	&JSONBody	+=	'            },'
	If Not &parmOpePgtInfAdd.IsEmpty()
		&JSONBody	+=	'            "InformacaoAdicional": "'+ Trim(&parmOpePgtInfAdd) +'"'
	EndIf
	&JSONBody	+=	'        }'
	&JSONBody	+=	'    ],'
	If Not &Token.IsEmpty()
		&JSONBody	+=	'    "Token": "' + Trim(&Token) +'",'
	EndIf
	&JSONBody	+=	'    "Integrador": "'+ &Hash.Trim() +'",'
	&JSONBody	+=	'    "Versao": "3"'
	&JSONBody	+=	'}'
	
	Exit
EndFor

&HttpClient.AddString(Trim(&JSONBody))
&HttpClient.Execute('POST',&ExecuteUrl)
		
padraoUsuario.Call('G', '#EFRETEADICIONAPAGAMENTO', &Context.PesCod, &Context.EmpCod, &JSONBody, &PadDtaMod)

If &HttpClient.StatusCode = 200
	&JSONBody 		= &HttpClient.ToString()
	&PosicaoSucesso = StrSearch(&JSONBody, '"Sucesso"')
	&PosicaoSucesso = &PosicaoSucesso + 11
	
	&Status = SubStr(&JSONBody, &PosicaoSucesso, 4)
	
	If &Status = 'true'
		Do 'AdicionaPagamento'
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!",'Pagamento adicionado com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))
		&StatusCode		= 200
	Else	
		&PosicaoSucesso = StrSearch(&JSONBody, '"Mensagem"')
		&PosicaoSucesso = &PosicaoSucesso + 13
		
		&PosicaoFinal	= StrSearch(&JSONBody, '"Codigo"')
		&PosicaoFinal	= &PosicaoFinal - &PosicaoSucesso - 8
		&Status			= SubStr(&JSONBody, &PosicaoSucesso, &PosicaoFinal)
		
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!",'Ocorreu um erro ao adicionar o pagamento. ERRO: '+ Trim(&Status), DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf
	padraoUsuario.Call('G', '#EFRETEMOTORISTARESPOSTA', &Context.PesCod, &Context.EmpCod, &JSONBody, &PadDtaMod)
Else
	Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &HttpClient.StatusCode.ToString() + ":" + &HttpClient.ErrDescription, DVMessageType.error, "", DVMessageBoolean.True,""))
EndIf

Sub 'AdicionaPagamento'
				
		New
			EmpCod			= &Context.EmpCod
			FilCod			= &Context.FilCod
			OpeCod			= &parmOpeCod
			OpePgtCod		= &parmOpePgtCod
			OpePgtNro		= &OpePgtNro
			OpeDtaLib		= &parmOpeDtaLib
			OpePgtVal		= &parmOpePgtVal
			OpePgtTip		= &parmOpePgtTip
			OpePgtCat		= &parmOpePgtCat
			OpePgtDoc		= &OpePgtDoc	
			OpePgtBan		= &parmOpePgtBan
			OpePgtAge		= &parmOpePgtAge
			OpePgtCon		= &parmOpePgtCon
			OpePgtConTip	= &parmOpePgtConTip	
			OpePgtInfAdd	= &parmOpePgtInfAdd
			OpePgtSts		= Status_AtivoInativo.ATIVO
			OpePgtSit		= Status_AbertoFechado.Fechado
		EndNew
		
		Commit
		
EndSub
]]></Source>
