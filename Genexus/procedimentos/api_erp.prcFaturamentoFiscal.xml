<Object parentGuid="f7a9321b-7dc0-4d0d-b851-ccf805fb6a31" user="WINJEAN\jeanfae" versionDate="2025-06-30T11:45:07.0000000Z" lastUpdate="2025-06-27T19:15:38.0000000Z" checksum="a9343d0c3595076857e8285f7385aab8" fullyQualifiedName="api_erp.prcFaturamentoFiscal" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="73de2f0e-c89d-4d4a-bdab-49edecaacbe3" name="prcFaturamentoFiscal" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Faturamento Fiscal" parent="api_erp.prdwid" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//parm(in:&EmpCod, in:&collFilCod, in:&Mes, in:&Ano, in:&WD_FATURAMENTOFISCALAutNiv, in:&WD_FATURAMENTOFISCALCTEAutNiv, inout:&sdtRetornoWbsEtc);


//cte
if &WD_FATURAMENTOFISCALCTEAutNiv > 0
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod in &collFilCod 
		//Where CteLctAtuGra.IsEmpty() or CteLctAtuGra.IsNull() or CteLctAtuGra = Status_SimNao_PS.Sim //atualizar Grafico //JDF nao sei se precisa.
		//CteDtaEms
		Where CteAnoEms = &Ano
		Where CteMesEms = &Mes When not &Mes.IsEmpty()
		Where CteProTer = Nota_ProPriaTerceira.PROPRIA
		Where CteSts = Status_NFe.Autorizada
		
		&CteMoeda += CteVlrTotPreSer
		&CteQuantidade += 1
	EndFor

	if &CteMoeda > 0 and &CteQuantidade > 0
		&CteMediaMoeda = Round(&CteMoeda/&CteQuantidade, 2)
	Endif

	&sdtRetornoWbsEtc.c1 = trim(toformattedString(&CteMoeda)) //total Cte
	&sdtRetornoWbsEtc.c2 = trim(toformattedString(&CteMediaMoeda)) //media
	&sdtRetornoWbsEtc.c3 = trim(toformattedString(&CteQuantidade)) //qtd cte
EndIf

//nfe
if &WD_FATURAMENTOFISCALAutNiv > 0
	//ATUALIZA DATAS DE FATURAMENTO
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod in &collFilCod
		Where  (NfeDtaFat.IsEmpty() or NfeDtaFat.IsNull()) or (NfeDtaFat_Mes.IsEmpty() or NfeDtaFat_Mes.IsNull())
		or (NfeDtaFat_Ano.IsEmpty() or NfeDtaFat_Ano.IsNull())
			
		&NfeDtaFat = NfePedDtaFat_FORMULA
		NfeDtaFat = &NfeDtaFat
		if &NfeDtaFat.IsEmpty()
			NfeDtaFat_Mes = 0
			NfeDtaFat_Ano = 0
		Else
			NfeDtaFat_Mes = &NfeDtaFat.Month()
			NfeDtaFat_Ano = &NfeDtaFat.Year()
		Endif
	
	EndFor
	
	commit
	

	For Each Order EmpCod, FilCod, NfeFin, NfeDtaFat_Ano
		Where EmpCod = &EmpCod
		Where FilCod in &collFilCod
		where NfeDtaFat_Ano = &Ano
		Where NfeDtaFat_Mes = &Mes when not &Mes.IsEmpty()
		Where (NfeSts = Status_Nfe.Autorizada) or (NfeProTer = Nota_ProPriaTerceira.TERCEIROS and NfeSts = Status_Nfe.Digitando) 
		Where NfeFin = NotaFinalidade.EmissaoNormal
		Where NfeLctGerFin = Status_SimNao.Sim
		
		If NfeEntSai = Status_EntradaSaida.Saida
			&NfeSaidaMoeda += NfeVlrTot
		Else
			&NfeEntradaMoeda += NfeVlrTot
		Endif		
		
	EndFor

	Do CAse
		CAse &NfeEntradaMoeda > &NfeSaidaMoeda and &NfeEntradaMoeda > 5000
			
			&Count =  &NfeEntradaMoeda / 5000
			&Count += 1
			&BaseMoeda = &Count*5000
			
		CAse &NfeSaidaMoeda > &NfeEntradaMoeda and &NfeSaidaMoeda > 5000
		
			&Count = &NfeSaidaMoeda / 5000
			&Count += 1
			&BaseMoeda = &Count*5000
//			&BaseMoeda = round((&NfeSaidaMoeda + 5000),0)
			
		Otherwise
			&BaseMoeda = 5000
	EndCAse


		&sdtRetornoWbsEtc.c4 = trim(toformattedString(&NfeSaidaMoeda)) //Total Saida
		&sdtRetornoWbsEtc.c5 = trim(toformattedString(&NfeEntradaMoeda)) //Total Entrada
		&sdtRetornoWbsEtc.c6 = trim(toformattedString(&BaseMoeda)) //Base Graficoooo
Endif
]]></Source>
