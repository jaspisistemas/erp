      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ProgressLogXml = ''
&Percentual = 0
&ProgressIni = serverNow()
&PerCount = 0
&PercentualTotal = 100

do 'Atualiza'

For Each Order IpPro 
	where IpPro = &ProgressId
	
	For Each Order IpPro, IpProItm
		delete
	EndFor
When none
	new
		IpPro = &ProgressId
		IpDtaHor = serverdate()
	EndNew
EndFor

Commit
	

&Linha = &sdtCamposImportacao.PrimeiraLinha
&Excel.Open(&selectedURL)
If &Excel.ErrCode <> 0
	msg(&Excel.ErrDescription)
Else
	Do While &Fim < 10
		
		Do 'LimpaCampos'
		
		&ProRef = iif(&sdtCamposImportacao.ColProCod > 0, trim(&Excel.Cells(&Linha,&sdtCamposImportacao.ColProCod).Text), '') // Código do Produto		
		
		If &ProRef.IsEmpty()
			&Fim += 1
		Else			
			Do 'GetProduto'
			If &IsAchou = True 
				Do 'GravaSdt'
			EndIf			
			&Fim = 0
		EndIf
		&Linha += 1
		
		&AuxCount += 1
		if &AuxCount > 500
			&PerCount += 1
			Do 'Percentual'
			&AuxCount = 0
		Endif
	EndDo

EndIf

&Percentual = 100
&ProgressFin = serverNow()
//&ProgressLogXml = &sdtProdutosXls.ToJson()
do 'Atualiza'
	

sub 'GravaSdt'
	
	
	&IpProItm += 1
	new
		IpPro = &ProgressId
		IpProItm = &IpProItm		
		IpEmpCod     = &EmpCod
		IpProCod     = &ProCod
		IpProRef     = &ProRef
		IpProNom     = &ProNom
		IpMensagem   = &Mensagem
		IpIsAchou    = &IsAchou
	EndNEw

	commit
EndSub


sub 'Percentual'
	&PerCount += 1
	If &PerCount > 0
		&Percentual = round((&PerCount / &PercentualTotal) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
EndSub


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &ProgressLogXml 
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &ProgressLogXml 
		Endnew
	endfor

	commit
EndSub

Sub 'LimpaCampos'
	&Mensagem = ''
	&IsErro = 'N'	
	&ProCod.SetEmpty()
	&ProRef.SetEmpty()
	&ProNom.SetEmpty()	
EndSub

Sub 'GetProduto'
	&IsAchou = false
	&ProCod = 0
	If not &ProRef.IsEmpty()
	    For Each Order EmpCod, ProRef, ProCod
			Where EmpCod = &EmpCod
		    Where ProRef = &ProRef 
			
			&IsAchou = true
			&ProCod = ProCod
			&ProNom = ProNom
			Exit
		EndFor
	EndIf
EndSub

]]></Source>
