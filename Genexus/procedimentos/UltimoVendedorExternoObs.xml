      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, (PesSacDta)
	Where EmpCod = &EmpCod
	Where PesCod in &PedCliCod
	Where PesSacIsVen = true or PesSacVenCod = 1
	Where PesSacVenIntExt = Status_InternoExterno.EXTERNO or PesSacVenCod = 1
	Where PesSacVenDem.IsEmpty() or PesSacVenDem.IsNull()
	where not PesSacPrxLig.IsEmpty()
	Where PesSacTipObs = 'E'
	
	if PesSacPrxLig > &PesUltVenDta
		&PesIntVenCod = PesSacVenCod
	EndIF
	
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
