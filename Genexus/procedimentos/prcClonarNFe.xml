//		&sdtCadastroTabelaImpostoCbs.CImpGruImpCod <> &NfeCliGruImpCod or
//		&sdtCadastroTabelaImpostoCbs.CImpCatCod <> &ProCatCod)
//		
//		&sdtCadastroTabelaImpostoCbs = new()
//		&sdtCadastroTabelaImpostoCbs.EmpCod = &EmpCod
//		&sdtCadastroTabelaImpostoCbs.CImpTbFilCod = &FilBasImp
//		&sdtCadastroTabelaImpostoCbs.CImpLctCod = &NfeLctCod
//		&sdtCadastroTabelaImpostoCbs.CImpOriUfeCod = &CImpOriUfeCod
//		&sdtCadastroTabelaImpostoCbs.CImpDstUfeCod = &NfeCliCidUF
//		&sdtCadastroTabelaImpostoCbs.CImpGruImpCod = &NfeCliGruImpCod
//		&sdtCadastroTabelaImpostoCbs.CImpCatCod = &ProCatCod
//		&sdtCadastroTabelaImpostoCbs.CImpDtaIni = serverdate()
//		prcRetornaConfiguracaoImposto.Call(&sdtCadastrotabelaImpostoCbs)
//		
//	Endif

	&NfeCfoCod = ''
	&ImpAlqMVA = 0
	
	//ICMS
	&NfeProTaxIcms = 0
	&NfeProTaxRedIcms = 0
	
	//S.T
	&NfeProTaxIcmsSt = 0
	&NfeProTaxRedIcmsSt = 0
	
	&NfeProTaxCofins = 0
	&NfeCstCofins = NF_CstCofins.COF07
	&NfeProTaxPIS = 0
	&NfeCstPIS = NF_CstPIS.CST07
	&NfeCstIpi = '99'
	&NfeIpiEnq.SetEmpty()
	
	&NfeProTaxIpi = 0
	&NfeSitCod.SetEmpty()
	&NfeProTaxDif = 0
	&NfeProCBenef = ''
	&IsAchou = 0
	&ImpIcmsMotDes = ''
	&ImpTaxFecop = 0
	For Each Order EmpCod,CImpTbFilCod,CImpLctCod,CImpOriUfeCod,CImpDstUfeCod,CImpGruImpCod,CImpCatCod,(CImpDtaIni)
	Where EmpCod = &EmpCod
	Where CImpTbFilCod = &FilBasImp
	Where CImpLctCod = &NfeLctCod
	Where CImpOriUfeCod = &CImpOriUfeCod
	Where CImpDstUfeCod = &NfeCliCidUF
	Where CImpGruImpCod = &NfeCliGruImpCod
	Where CImpCatCod = &ProCatCod
	Where CImpDtaIni = serverdate()
		
		&IsAchou = 1 
		
		&NfeSitCod = CImpCstCod
		&NfeProCBenef = CImpCBenef
		&ImpIcmsMotDes = CImpIcmsMotDes
		&ImpTaxFecop = CImpTaxFecop
		&NfeCfoCod = CImpCfoCod

		&ImpAlqMVA = CImpAlqMVA
		&NfeProTaxIcms = CImpAlqIcmInt
		&NfeProTaxRedIcms = CImpRedAlqIcmInt

		//S.T.
		&NfeProTaxIcmsSt = CImpAlqIcmExt
		&NfeProTaxRedIcmsSt = CImpRedAlqIcmExt
		
		&Varchar = CImpCstPisCofins.ToString()
		&NfeCstCofins.FromString(&Varchar)
		
		&NfeProTaxCofins = CImpCofins
		
		&NfeProTaxPIS = CImpPis
		&NfeCstPIS = CImpCstPisCofins
		&NfeCstIpi = CImpCstIpi
		&NfeIpiEnq = CImpIpiEnq
		&NfeProTaxIpi = CImpIpi
		&NfeProTaxDif = CImpDif
		exit
	EndFor

EndSub

Sub 'GrupoImpostoCliente'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NfeCliCod
		&NfeCliGruImpCod = PesGruImpCod
		exit
	EndFor
EndSub
