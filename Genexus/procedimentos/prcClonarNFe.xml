        <Source><![CDATA[For Each Order EmpCod,FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCodFat
	
	if FilBasImp = 0
		&FilBasImp = FilCod
	Else
		&FilBasImp = FilBasImp
	EndIF	
EndFor

RetornaRegimeTributarioFilial.Call(&EmpCod, &FilBasImp, &FilRegTrib, &CImpOriUfeCod)

For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	UltimoCodigoEmpresa.Call(domParCod.NOTAFISCAL, &EmpCod, &FilCodFat, &NewNfeCod)
	&NfeNum = 0
	&NfeSer = ''
	&NfeCliCidUF = NfeCliCidUF
	&NfeCliCod = NfeCliCod
	Do 'GrupoImpostoCliente'
	if ModCod = '55' //só aceita oque vem como parametro para modelo '55' (NFe)
		&NfeFin = &ParNfeFin
		&NfeEntSai = &ParNfeEntSai
		&NfeLctCod = &ParNfeLctCod
	else
		&NfeFin = NfeFin //não altera, usa o mesmo para NFCe / '65'
		&NfeEntSai = NfeEntSai
		&NfeLctCod = NfeLctCod
	EndIf
	
	if (&NfeFin = NotaFinalidade.EmissaoDevolucao or &NfeFin = NotaFinalidade.EmissaoComplementar) and ModCod = '55' //este if não foi feito junto com o de cima pois teria que verificar 2x para setar vazio no else
		&NfeChvRef = NfeChv //se for devolução, pega a chave para usar na chave referenciada
	else
		&NfeChvRef.SetEmpty() //se não for devolução, grava vazio
	EndIf
	
	new		
		EmpCod = &EmpCod
		FilCod = &FilCodFat
		NfeCod = &NewNfeCod
		NfeEntSai = &NfeEntSai
		NfeLctCod = &NfeLctCod 
		NfeDtaEms = serverdate()
		NfeDtaDsp = serverdate()
		NfeHorEms = ServerTime()
		NfeNum = &NfeNum
		NfeFin = &NfeFin
		NfeProTer = &NfeProTer
		NfeCNF = 0
		NfeSer = &NfeSer
		NfeSts = Status_NFe.Digitando
		NfeChv = ''
		NfeEmiGnre = Status_SimNao.Nao	
		NfeArqXml = ''
		NfeAutDatHorRec = ''
		NfeAutDigVal = ''
		NfeAutMsg = ''
		NfeAutNumLot = ''
		NfeAutNumPro = ''
		NfeAutNumRec = ''
		NfeAutSts = ''
	EndNEw
	
	Exit
EndFor

Commit

if not &NfeChvRef.IsEmpty()
	&sdtNotasReferenciadasItem = new()
	&sdtNotasReferenciadasItem.NfeDocRefNfe = retornasoNumeros.Udp(&NfeChvRef)
	&sdtNotasReferenciadasItem.NfeDocRefMod = Substr(&NfeChvRef, 21, 2)
	&sdtNotasReferenciadas.Add(&sdtNotasReferenciadasItem)
	prcGravaDocumentosReferenciados.Call(&EmpCod, &FilCodFat, &NewNfeCod, &sdtNotasReferenciadas)
Endif

For Each Order EmpCod, FilCod, NfeCod, NfeDocRefCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	&NfeDocRefCod += 1
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		NfeCod = &NfeCod
		NfeDocRefCod = &NfeDocRefCod
	EndNew
	
EndFor

Commit

For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	
	&NfeProCod = NfeProCod
	&NfeProGraCod = NfeProGraCod
	Do 'GetProduto'
	If &IgnoraTabelaImposto = Status_SimNao.Sim
		Do 'TabImposto'
	Else
		&IsAchou = 0
		&NfeSitCod = ''
		&NfeProCBenef = ''
		&ImpIcmsMotDes = ''
		&ImpTaxFecop = 0
		&NfeCfoCod =''
		&ImpAlqMVA = 0
		&NfeProTaxIcms = 0
		&NfeProTaxRedIcms = 0
		&NfeProTaxIcmsSt = 0
		&NfeProTaxRedIcmsSt = 0
		&NfeProTaxCofins = 0
		&NfeCstCofins.SetEmpty()
		&NfeProTaxPIS = 0
		&NfeCstPIS.SetEmpty()
		&NfeCstIpi.SetEmpty()
		&NfeIpiEnq = 0
		&NfeProTaxIpi = 0
		&NfeProTaxDif = 0 
	EndIf
	
	new
		EmpCod = &EmpCod
		FilCod = &FilCodFat
		NfeCod = &NewNfeCod
		NfeItmCod = NfeItmCod
		
		If &IsAchou = 1 
			NfeSitCod = &NfeSitCod
			
			NfeProCBenef = &NfeProCBenef
			NfeProMotDes = &ImpIcmsMotDes
			NfeProTaxFCPIcmsSt = &ImpTaxFecop
			NfeCfoCod =	&NfeCfoCod
			
			NfeProTaxMvaSt = &ImpAlqMVA
			NfeProTaxIcms = &NfeProTaxIcms
			NfeProTaxRedIcms = &NfeProTaxRedIcms
			
			//S.T.
			NfeProTaxIcmsSt = &NfeProTaxIcmsSt
			NfeProTaxRedIcmsSt = &NfeProTaxRedIcmsSt
			
			NfeProTaxCofins = &NfeProTaxCofins
			NfeCstCofins = &NfeCstCofins
			NfeProTaxPIS = &NfeProTaxPIS
			NfeCstPIS = &NfeCstPIS
			NfeCstIpi  = &NfeCstIpi
			NfeIpiEnq = &NfeIpiEnq 
			
			NfeProTaxIpi = &NfeProTaxIpi
			NfeProTaxDif = &NfeProTaxDif
		EndIf
	EndNew
	
	
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod,NfeProLotCod
		New
			EmpCod = &EmpCod
			FilCod = &FilCodFat
			NfeCod = &NewNfeCod
			NfeItmCod = NfeItmCod
			NfeProLotCod  = NfeProLotCod
		Endnew
	EndFor
EndFor


Commit

ObsAutomaticaNFe.call(&EmpCod, &FilCodFat, &NewNfeCod)


Sub 'GetProduto'
	For each Order EmpCod,ProCod,ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &NfeProCod
		Where ProGraCod = &NfeProGraCod
		&ProCatCod = ProCatCod
		exit
	EndFor

EndSub

Sub 'tabImposto'
	//JDF TEm que buscar os impostos e calcular os impostos. hoje so esta mudando cfop, e taxcas.
//	if (&sdtCadastroTabelaImpostoCbs.EmpCod <> &EmpCod or
//		&sdtCadastroTabelaImpostoCbs.CImpTbFilCod <> &FilBasImp or
//		&sdtCadastroTabelaImpostoCbs.CImpLctCod <> &NfeLctCod or
