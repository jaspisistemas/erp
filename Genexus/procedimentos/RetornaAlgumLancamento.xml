      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAlgum = false
For Each Order EmpCod, FinAno, FinMes
	Where EmpCod = &EmpCod
	Where FinAno = &FinAno
	Where FinMes = &FinMes
	&IsAlgum = true
	Exit
EndFor

if &IsAlgum = false
	
	For Each Order EmpCod, (FinAno), (FinMes)
		Where EmpCod = &EmpCod
		
		&OldFinAno = FinAno
		&OldFinMes = FinMes
		
		Exit
	EndFor

	if &OldFinAno.IsEmpty()
		&D1PlanHie = '1.'
		&D2PlanHie = '2.'
		&D3PlanHie = '3.'
		&D4PlanHie = '4.'
		
		For Each Order EmpCod, PlanHie
			Where EmpCod = &EmpCod
			Where PlanHie like &D1PlanHie or PlanHie like &D2PlanHie or PlanHie like &D3PlanHie or PlanHie like &D4PlanHie
			
			New
				EmpCod = EmpCod
				PlanCod = PlanCod
				FinAno = &FinAno
				FinMes = &FinMes
				FinVlr = 0
			EndNEw
		EndFor
	
	Else
		For Each Order EmpCod, FinAno, FinMes
			Where EmpCod = &EmpCod
			Where FinAno = &OldFinAno
			Where FinMes = &OldFinMes
			
			New
				EmpCod = &EmpCod
				FinAno = &FinAno
				FinMes = &FinMes
				FinVlr = 0
			EndNEw
			
		EndFor
	EndIF

	Commit
EndIF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
