      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	
For Each Order GNRENovEmpCod			//## Busca a configuração atráves dos parâmetros		##\\
	Where GNRENovEmpCod		=	&EmpCod	//## Código da Empresa 		(por parâmetro)				##\\
	Where GNRENovFilCod		= 	&FilCod	//## Código da Filial 		(por parâmetro) 			##\\
	Where GNRENovUfeCod		= 	&UfeCod	//## Uf de Emissão 			(por parâmetro)				##\\
	Where GNRETip			=	&GNRETip//## ICMS, FCP ou DIFAL		(por parâmetro)				##\\
	
	GNRENovRec		= 	&GNRENovRec		//## Receita da GNRE		(por parâmetro)				##\\
	GNRENovDet 		= 	&GNRENovDet		//## Detalhamento da GNRE	(por parâmetro)				##\\
	GNREDocOri		= 	&GNREDocOri		//## Doc. Origem da GNRE	(por parâmetro)				##\\
	GNRENovPro		= 	&GNRENovPro		//## Produto da GNRE		(por parâmetro)				##\\
	
	Exit
When None
	New 
		GNRENovEmpCod 	= 	&EmpCod			//## Código da Empresa 		(por parâmetro)				##\\
		GNRENovFilCod 	= 	&FilCod			//## Código da Filial 		(por parâmetro) 			##\\
		GNRENovUfeCod 	= 	&UfeCod			//## Uf de Emissão 			(por parâmetro)				##\\
		GNRENovRec		= 	&GNRENovRec		//## Receita da GNRE		(por parâmetro)				##\\
		GNRENovDet 		= 	&GNRENovDet		//## Detalhamento da GNRE	(por parâmetro)				##\\
		GNREDocOri		= 	&GNREDocOri		//## Doc. Origem da GNRE	(por parâmetro)				##\\
		GNRENovPro		= 	&GNRENovPro		//## Produto da GNRE		(por parâmetro)				##\\
		GNRETip			=	&GNRETip		//## ICMS, FCP ou DIFAL		(por parâmetro)				##\\
		
	EndNew
EndFor
Commit


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
