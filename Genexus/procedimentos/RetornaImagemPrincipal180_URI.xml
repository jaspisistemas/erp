      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod, ProImgCod
	Where EmpCod = &EmpCod
	Where ProCod = &PrOCod
	Where ProImgPri = true
	where ProImgTip = &ProImgTip 
	
	&ProImg180 = ProImg180
	&VarcharCaminho = ProImg180.ImageURI
	&IsSemImagem = false
	
	Exit
When none
	&IsSemImagem = true
	
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		
		&VarcharCaminho = EmpDirVir.Trim() + '/' + Produto_Sem_Imagem180.Link()
		Exit
	EndFor
Endfor
]]></Source>
