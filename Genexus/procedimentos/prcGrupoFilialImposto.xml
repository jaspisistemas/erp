      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod or &EmpCod = 0
	&AuxEmpCod = EmpCod
	&FilCod = FilCod
	
	&FilRaz = FilRaz
	&tbFilRegTrib = FilRegTrib
	&TbImpUfeCod = FilCidUfeCod
	do 'addGrupoFilialImposto'
EndFor


Sub 'addGrupoFilialImposto'
	For Each ORder EmpCod
		Where EmpCod = &AuxEmpCod
		Where TbImpFilCod = &FilCod
		if TbFilRegTrib.IsEmpty() or TbFilRegTrib.IsNull()
			TbFilRegTrib = &tbFilRegTrib
		EndIf
		
		if TbImpUfeCod.IsEmpty() or TbImpUfeCod.IsNull()
			TbImpUfeCod = &TbImpUfeCod
		EndIf
		
		Exit
	When none
		new
			EmpCod = &AuxEmpCod
			TbImpFilCod = &FilCod
			TbImpFilNom = &FilRaz
			TbFilRegTrib = &tbFilRegTrib
			TbImpUfeCod = &TbImpUfeCod
			TbImpFilCodNom = format('%1 - %2', trim(str(&FilCod)), trim(&FilRaz))
		EndNEw
	EndFor
	
	Commit
EndSub



]]></Source>
