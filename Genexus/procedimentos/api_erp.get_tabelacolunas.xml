      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	
	TimestampToDate.Call(&dtavigenciatmpsec, &VigenciaData )
	//&Padobs = trim(str(&dtavigenciatmpsec)) + '-'+&VigenciaData.ToFormattedString()
	//padraousuario.Call('G', &Pgmname, 0, 0, &Padobs, &PadDtaMod)
//	if &VigenciaData.IsEmpty()
//		&VigenciaData = serverdate()
//	Endif

	if not &Status.IsEmpty() and &Status <> 'T'
		&TabSts.FromString(&Status)
	Endif

	&FilCod = &parFilCod
	if &FilCod.IsEmpty()
		&FilCod = &wwpContext.FilCod
	EndIf
	
	For EAch Order EmpCod, TabCod
		Where EmpCod = &wwpContext.EmpCod
		Where TabDtaIni <= &VigenciaData and &VigenciaData <= TabDtaFin when not &dtavigenciatmpsec.IsEmpty()
		Where TabSts = &TabSts when not &Status.IsEmpty() and &Status <> 'T'
		Where  TabSts = StatusTabela.Promocao or  TabSts = StatusTabela.NormalAtiva when &Status.IsEmpty() or &Status = 'T'
		&IsPode = false
		
		if TabIsAllFil = true
			&IsPode = true
		Else
			For Each Order EmpCod, TabCod, TabFilCod
				Where TabFilCod = &FilCod
				&IsPode = true
				Exit
			EndFor
		Endif
		
		If &IsPode = true
			
			if TabSts = StatusTabela.Promocao
				&wwTabelas.qtd += 1
				
				&wwTabelasItem = new()
				&wwTabelasItem.TabCod = TabCod
				&wwTabelasItem.TabNom = TabNom
				&wwTabelasItem.TabColCod = 0
				&wwTabelasItem.TabColNom = ''
				&wwTabelasItem.TabSts = TabSts
				&wwTabelas.Item.Add(&wwTabelasItem)
			Else
				For Each Order EmpCod, TabCod, TabColCod
					&wwTabelas.qtd += 1
					
					&wwTabelasItem = new()
					&wwTabelasItem.TabCod = TabCod
					&wwTabelasItem.TabNom = TabNom
					&wwTabelasItem.TabColCod = TabColCod
					&wwTabelasItem.TabColNom = TabColNom
					&wwTabelasItem.TabSts = TabSts
					&wwTabelas.Item.Add(&wwTabelasItem)
				EndFor
			Endif
		
		Endif
		
	when none
		
	EndFor
	
Endif
]]></Source>
