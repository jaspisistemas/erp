      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'TRANSFERÊNCIA DE PRODUTOS'
	print Cabecalho
End

For Each Order EmpCod, TrsCod
	Where EmpCod = &EmpCod
	Where TrsCod = &TrsCod
	
	&Status = upper(TrsSts.EnumerationDescription())
	
	print tituloTransf
	print tituloProduto
	
	For Each ORder EmpCod, TrsCod, TrsItmCod
		&ProCod = TrsSaiProCod
		do 'loadNomeProduto'
		&TrsSaiProNom = &ProNom
		
		&ProCod = TrsEntProCod
		do 'loadNomeProduto'
		&TrsEntProNom = &ProNom
		
		&TrsEntPedQtd = TrsEntPedQtd
		&TrsSaiPedQtd = TrsSaiPedQtd
		
		print itemProduto
	EndFor

	Exit
EndFor

Footer
	print Rodape
End


Sub 'loadNomeProduto'
	
	&ProNom = ''
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		WHere ProCod = &ProCod
		&ProNom = ProNom
		Exit
	EndFor
	
EndSub
]]></Source>
