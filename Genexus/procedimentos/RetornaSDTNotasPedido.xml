      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SdtNotaPedido.Clear()
For Each Order EmpCod, NfeFilCod,NfePedCod,NfeSts
	Where EmpCod = &EmpCod
	Where NfeFilCod = &FilCod
	Where NfePedCod = &PedCod
	Where NfeSts = Status_NFe.Autorizada
	
	&SdtNotaPedidoItem = new()
	&SdtNotaPedidoItem.EmpCod = EmpCod
	&SdtNotaPedidoItem.FilCod = FilCod
	&SdtNotaPedidoItem.NfeCod = NfeCod
	&SdtNotaPedidoItem.NfeFilCod = NfeFilCod
	&SdtNotaPedidoItem.NFePedCod = NfePedCod
	&SdtNotaPedido.Add(&SdtNotaPedidoItem)
	
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
