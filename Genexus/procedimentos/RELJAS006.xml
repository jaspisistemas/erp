      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	print Cabecalho
End


For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PEsCod
	
	&PesLog = PesLog.Trim()
	If not PesNro.IsEmpty()
		&PesLog += ', ' + trim(PesNro)
	EndIF

	print DadosTransportadora
	
	//TELEFONE
	For Each Order EmpCod, PesCod, PesFonCod
		&TipoFone = PesFonTpo.EnumerationDescription()
		&Operadora = PesFonOpe.EnumerationDescription()
		Print Telefone
	EndFor
	
	Exit
EndFor

]]></Source>
