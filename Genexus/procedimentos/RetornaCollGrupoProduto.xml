      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ColGrupCod.Clear()
&auxGrupHie = trim(&GrupHie)+'.'
for Each Order EmpCod, GrupCod
	Where EmpCod = &EmpCod
	Where GrupHie like &auxGrupHie or GrupHie = &GrupHie
	Where GrupAnaSin = 'A'
	&ColGrupCod.Add(GrupCod)
EndFor
]]></Source>
