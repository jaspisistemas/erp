      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//CALCULA A COMISSÃO DO MOTORISTA NA VIAGEM
&CteVlrPreCom = 0	// Valor Bruto, sem a %
For Each Order EmpCod, FilCod, CteViaCod
	Where EmpCod	= &parmEmpCod	// Empresa
	Where FilCod 	= &parmFilCod	// Filial
	Where CteViaCod	= &parmViaCod	// Viagem relacionada
	
	&AuxCteVlrRecSer = CteVlrRecSer
//	Msg(Trim(Str(&AuxCteVlrRecSer)) + ' 1')
	If CtePosPre	= Status_SimNao.Sim	  // Possui Prestações
		//Busca Valores
		For Each Order EmpCod, FilCod, CteCod, CtePreCod
			Where CtePrePagCom = True	//Marcados para pagar comissão			
			&CteVlrPreCom	+= CteVlrPreCom	//Valor da prestação
//			Msg(Trim(Str(&AuxCteVlrRecSer)) + ' PRESTACAO')
		When None
			&CteVlrPreCom 	+= &AuxCteVlrRecSer
//			Msg(Trim(Str(&AuxCteVlrRecSer)))

		EndFor
	Else
		&CteVlrPreCom 		+= CteVlrRecSer
//		Msg(Trim(Str(&AuxCteVlrRecSer)) + ' ELSE')
	Endif

	&CteVlrTotPreSer		+= CteVlrRecSer
	
EndFor

//Busca a % de Comissão do Motorista 
Do 'BuscaMotorista'

//Calcula o Valor da comissão
If &PesPorCom > 0
	&ViaCteMotVlr = &CteVlrPreCom*(&PesPorCom/100)
EndIf

For Each Order EmpCod, FilCod, ViaCod
	Where EmpCod = &parmEmpCod
	Where FilCod = &parmFilCod
	Where ViaCod = &parmViaCod
	
	ViaCTEVlrCom = &CteVlrPreCom
	ViaValFre	 = &CteVlrTotPreSer
	ViaCteMotVlr = &ViaCteMotVlr
	Exit
EndFor

Sub 'BuscaMotorista'
	
	For Each Order EmpCod, FilCod, ViaCod
		Where EmpCod = &parmEmpCod
		Where FilCod = &parmFilCod
		Where ViaCod = &parmViaCod
		
		&PesCod 	= PesCod
		&PesPorCom 	= PesPorCom
		
		Exit
	EndFor
	
EndSub
]]></Source>
