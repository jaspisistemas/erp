      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, MenCod, SubMenCod, RotOrd
	Where EmpCod = &EmpCod
	Where MenCod = &MenCod or not &Descricao.isEmpty()
	//Where MenCod = &MenCod when not &MenCod.IsEmpty()
	Where SubMenCod = &SubMenCod or (not &Descricao.isEmpty()) or (not &MenCod.IsEmpty() and &SubMenCod.IsEmpty())
	
	
	if (RotNom like '%'+&Descricao or RotAutCod like '%'+&Descricao) or &Descricao.IsEmpty()
		
		&sdtAutorizacaoRotinasItem  = New()
		
		&sdtAutorizacaoRotinasItem.AutNiv = 0
		&sdtAutorizacaoRotinasItem.RotAutCod = RotAutCod
		&sdtAutorizacaoRotinasItem.RotNom = RotNom
		&sdtAutorizacaoRotinasItem.SubRotIs = false
		
		&AutCod = RotAutCod
		do 'GetAutorizacao'
		&sdtAutorizacaoRotinasItem.AutNiv = &AutNiv
		
		if &SomenteAtivas = 'T' or &SomenteAtivas.IsEmpty() or (&AutNiv = 0 and &SomenteAtivas = 'N') or (&AutNiv > 0 and &SomenteAtivas = 'S')
			&sdtAutorizacaoRotinas.Add(&sdtAutorizacaoRotinasItem)
		Endif
	EndIf


	For Each Order EmpCod, MenCod, SubMenCod, RotOrd, SubRotCod
		Where SubRotAutNom like '%'+&Descricao or SubRotCod like '%'+&Descricao when not &Descricao.IsEmpty()
		
		&sdtAutorizacaoRotinasItem  = New()
		
		&sdtAutorizacaoRotinasItem.AutNiv = 0
		&sdtAutorizacaoRotinasItem.RotAutCod = RotAutCod
		&sdtAutorizacaoRotinasItem.SubRotCod = SubRotCod 
		&sdtAutorizacaoRotinasItem.RotNom = SubRotAutNom
		&sdtAutorizacaoRotinasItem.SubRotIs = true
		
		&AutCod = SubRotCod
		do 'GetAutorizacao'
		if &SomenteAtivas = 'T' or &SomenteAtivas.IsEmpty() or (&AutNiv = 0 and &SomenteAtivas = 'N') or (&AutNiv > 0 and &SomenteAtivas = 'S')
			&sdtAutorizacaoRotinasItem.AutNiv = &AutNiv			
			&sdtAutorizacaoRotinas.Add(&sdtAutorizacaoRotinasItem)
		Endif
	EndFor
EndFor


Sub 'GetAutorizacao'
	&AutNiv = 0
	For Each Order EmpCod, AutGrpCod, AutCod
		Where EmpCod = &EmpCod
		Where AutGrpCod = &AutGrpCod
		Where AutCod = &AutCod
		&AutNiv = AutNiv
		
		Exit
	EndFor
EndSub
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
