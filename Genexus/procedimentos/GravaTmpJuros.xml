      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FunCod,TmpJurCliCod,TmpJurCod
	Where EmpCod = &EmpCod
	Where FunCod = &FunCod
	Where TmpJurCliCod = &TmpJurCliCod
	Where TmpJurCod = &TmpJurCod
	
	TmpJurCliCod = &TmpJurCliCod
	TmpJurCreDup = &TmpJurCreDup
	TmpJurDtaIni = &TmpJurDtaIni
	TmpJurDtaFim = &TmpJurDtaFim 
	TmpJurDia    = &TmpJurDia
	TmpJurTxaJur = &TmpJurTxaJur 
	TmpJurTxaMlt = &TmpJurTxaMlt
	TmpJurVlrTit = &TmpJurVlrTit
	TmpJurOutVlr = &TmpJurOutVlr
	TmpJurVlrJur = &TmpJurVlrJur
	TmpJurVlrMlt = &TmpJurVlrMlt
	TmpJurVlrTot = &TmpJurVlrTot
	
When none
	&auxTmpJurCod = 0
	For Each Order EmpCod,FunCod,TmpJurCliCod,(TmpJurCod)
		Where EmpCod = &EmpCod
		Where FunCod = &FunCod
		Where TmpJurCliCod = &TmpJurCliCod
		&auxTmpJurCod = TmpJurCod
		Exit
	EndFor
	&auxTmpJurCod += 1
	New 
		EmpCod = &EmpCod
		FunCod = &FunCod
		TmpJurCod = &auxTmpJurCod
		TmpJurCliCod = &TmpJurCliCod
		TmpJurCreDup = &TmpJurCreDup
		TmpJurDtaIni = &TmpJurDtaIni
		TmpJurDtaFim = &TmpJurDtaFim 
		TmpJurDia    = &TmpJurDia
		TmpJurTxaJur = &TmpJurTxaJur 
		TmpJurTxaMlt = &TmpJurTxaMlt
		TmpJurVlrTit = &TmpJurVlrTit
		TmpJurOutVlr = &TmpJurOutVlr
		TmpJurVlrJur = &TmpJurVlrJur
		TmpJurVlrMlt = &TmpJurVlrMlt
		TmpJurVlrTot = &TmpJurVlrTot
	EndNew
	
EndFor


commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
