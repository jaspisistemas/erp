      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For &SdtReceituarioItem in &SdtReceituario
	&EmpCod = &SdtReceituarioItem.EmpCod
	&RctCod = &SdtReceituarioItem.RctCod
	do 'Escreverdados'
EndFor

Sub 'Escreverdados'
	
	For each order EmpCod,RctCod 
		Where EmpCod = &EmpCod
		Where RctCod = &RctCod
		
		RctSts = Status_Receituario.Transmitido
		RctDtaTra = ServerNow()
	EndFor
EndSub
]]></Source>
