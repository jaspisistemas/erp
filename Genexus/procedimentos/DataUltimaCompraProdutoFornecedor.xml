      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedDtaFat.SetEmpty()

For Each Order EmpCod, ProCod, PedSts, PedCliCod, (PedDtaFat)
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where PedCliCod = &PedCliCod
	Where PedSts = Status_Pedido.FECHADO
	Where LctTip = TipoLancamento.EntradaMercadoria
	Where LctAtuFor = Status_SimNao.Sim
	&PedDtaFat = PedDtaFat
	Exit
EndFor
]]></Source>
