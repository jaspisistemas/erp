      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where  NfeCod = &NfeCod
	
	
	
	New
		UltimoCodigoEmpresa.Call(domParCod.MDFE, EmpCod, FilCod,&MDFeCod)
		UltimoCodigoEmpresa.Call(domParCod.MDFENUM, EmpCod, FilCod,&newMDFENum)
		EmpCod = EmpCod
		FilCod = FilCod
		MDFeCod = &MDFeCod
		MDFeNum = &newMDFENum
		&MdfeSer = RetornaSerieNF.Udp(domParCod.MDFESER, &EmpCod, &FilCod)
		MDFeSer = &MdfeSer
		MDFeDtaEms = serverdate()
		MDFeHorEms = serverTime()
		MDFeDtaSai = serverdate()
		MDFeHorSai = serverTime()
		MDFeSts = Status_MDFe.Digitando
		MDFeTipTra = MDFe_TipoTransporte.ETC
		MDFeTipEmt = MDFe_TipoEmitente.NaoPrestador
		MDFeModCod = '58'
		MDFeTipMod = TipoModalidade.Rodoviario
		MDFeOriUfeCod = FilCidUfeCod		
		MDFeDstUfeCod = NfeCliCidUF
		MDFeProPre = ''
		MDFeLotCarCep = FilCep
		MDFeLotDesCep = NfeCliCep
		
		If NfeCliTipPes = TipoPessoa.FISICA
			MdfeConCnpj  = NfeCliCpf
		Else
			MdfeConCnpj =  NfeCliCnpj
		EndIf

		MdfeConRaz = NfeCliRaz
		&CteTerUfe = NfeCliCidUF
		&CteTerCidCod = NfeCliCidCod
		do 'getcidadetermino'
		&CteTerCidNom = NfeCliCidNom
		
		MDFeDesCidCod = NfeCliCidCod
		&CteIniUfe = FilCidUfeCod
		&CteIniCidCod = FilCidCod
		&MDFeCarCidCod = FilCidCod
	EndNew

	commit
	New 
		MDFeCarCod    = 1
		MDFeCarCidCod = &MDFeCarCidCod
		EndNew
	commit
	
	&NfeChv = NfeChv
	&CteVlrTotPreSer = NfeVlrTot
	If NfePesBrt > 0
		&CteQtdTotKg = NfePesBrt
	Else
		&CteQtdTotKg = NfePesLiq
	EndIf
	&FilCpj = FilCpj
	
EndFor

commit

MDFE_NFE.Call('ADD', &EmpCod, &FilCod, &MDFeCod, 0, &FilCod, &NfeCod,&NfeChv,&MDFeNfeChv2,&MDFeCidIBGE,&CteTerCidNom,&CteTerUfe,&CteVlrTotPreSer,&CteQtdTotKg,&FilCpj)
MDFe_TotalizarNotas.Call(&EmpCod, &FilCod, &MDFeCod, &countCteNumeric, &countNfeNumeric, &totalNumeric, &PesoBrutoMoeda, &TotalMoeda)

Sub 'getcidadetermino'
	For each order EmpCod,UfeCod,CidCod
		Where EmpCod = &EmpCod
		Where UfeCod = &CteTerUfe
		Where CidCod = &CteTerCidCod
		&MDFeCidIBGE = CidIBGE 
		Exit
	EndFor
EndSub
]]></Source>
