      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&AuxCbrUltRem = &CbrUltRem
if &CbrUltRem.IsEmpty()
	For each Order EmpCod,RemCbrCod,(RemNum)
		Where EmpCod = &EmpCod
		Where RemCbrCod = &CbrCod
		&AuxCbrUltRem = RemNum
		Exit
	EndFor
Endif

loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'DUPLICATAS DA REMESSA'
	print Cabecalho
End
Do 'LocCobranca'
Print Menu
&count = 0

For each Order EmpCod,RemCbrCod,RemNum
	Where EmpCod = &EmpCod
	Where RemCbrCod = &CbrCod
	Where RemNum = &AuxCbrUltRem
	&SdtDuplicatasRemessa.FromXml(RemTxt)
		
		For each Order EmpCod,RemCbrCod,RemNum
			&RemFilCod = RemFilCod
			&RemCreSeq = RemCreSeq
			&RemCreDupNro = RemCreDupNro
			&CreDtaEms = CreDtaEms
			&CreVlrDup = CreVlrDup
			&CreDtaVct = CreDtaVct
			&CrePedCod = CrePedCod
			&CreCliCodRaz = CreCliCodRaz
			
			&Mensagem.SetEmpty()
			for &SdtDuplicatasRemessaItem in &SdtDuplicatasRemessa
				if &SdtDuplicatasRemessaItem.CreCod = RemCreSeq
					&Mensagem = &SdtDuplicatasRemessaItem.Mensagem
					Exit
				Endif			
			EndFor
		
			if &Mensagem.IsEmpty()	
				&Mensagem = 'Registrado com sucesso!'
				Print Duplicatas
				noSkip
				print DuplicatasTraco
			Else
				Print Duplicatas
				Print Alerta
				noSkip
				print DuplicatasTraco
			EndiF
		
			&TotCreVlrDup += &CreVlrDup
			&count+=1
		EndFor	
EndFor

Print Total

Footer
	print Rodape
End

Sub 'LocCobranca'
	For each Order EmpCod,CbrCod
		Where EmpCod = &EmpCod
		Where CbrCod = &CbrCod
		&CbrNom = CbrCodNom
		Exit
	EndFor
EndSub
]]></Source>
