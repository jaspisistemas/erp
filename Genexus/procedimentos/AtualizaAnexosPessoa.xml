      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PesCod, PesAnxCod
	Where PesAnxGuid.IsEmpty() or PesAnxGuid.IsNull() or PesAnxGuidExt.IsEmpty() or PesAnxGuidExt.IsNull() or PesAnxGuidNom.IsEmpty() or PesAnxGuidNom.IsNull()
	
	&PesAnxGuid.SetEmpty()
	&PesAnxGuid = PesAnxGuid
	if PesAnxGuid.IsEmpty() or PesAnxGuid.IsNull()
		&PesAnxGuid = GUID.NewGuid()
		PesAnxGuid = &PesAnxGuid
		Commit
	Endif
	
	prcSalvaArquivoFisicamente_Ajuste.Call(EmpCod, 1, PesCod, PesAnxCod, &PesAnxGuid)
EndFor
]]></Source>
