      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod,FilCod,OpeCod,OpeImpCod
	Where EmpCod 	= &EmpCod
	Where FilCod 	= &FilCod
	Where OpeCod	= &OpeCod
	Where OpeImpCod	= 1
	
	If OpeSts = Status_Ciot.Digitando
		OpeImpIRRF 	= &OpeImpIRRF
		OpeImpSest 	= &OpeImpSest
		OpeImpInss 	= &OpeImpInss
		OpeImpIssqn = &OpeImpIssqn
		OpeImpOut 	= &OpeImpOut
	EndIf
	
	exit
When none
	
	New
		EmpCod		= &EmpCod
		FilCod 		= &FilCod
		OpeCod 		= &OpeCod
		OpeImpCod 	= 1	
		OpeImpIRRF 	= &OpeImpIRRF
		OpeImpSest 	= &OpeImpSest
		OpeImpInss 	= &OpeImpInss
		OpeImpIssqn = &OpeImpIssqn
		OpeImpOut 	= &OpeImpOut
		
	EndNew
	commit
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
