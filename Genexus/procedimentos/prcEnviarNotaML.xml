      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//pedido
For Each Order EmpCod, MrkCod, MrkPedSku
	Where EmpCod = &EmpCod
	Where MrkCod = &MrkCod
	Where MrkPedSku = &MrkPedSku
	&MrkPedShipSku = MrkPedShipSku
	&MrkPedNfDtaHor = MrkPedNfDtaHor
	exit
EndFor

For Each ORder EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &Nfecod
	
	&sdtConfiguracoesPasta = RetornaConfiguracoesPastas.Udp(EmpCod, FilCod)
	&NfeArqXml = NfeArqXml
	
	
	&AnoMes = str(year(NfeDtaEms),4,0)+padl(trim(str(month(NfeDtaEms),2,0)),2,'0')
	&PastaAutorizadas = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "Autorizados\" + &AnoMes.trim() + "\" + NfeChv.Trim() + '-procNFe.xml'
	&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\" + NfeChv.Trim() + '-jaspi.xml'
	
	//XML
	&File.Source = &PastaAutorizadas
	If &File.Exists()
		&IsTemXml = true
	Else
		GravaXmldoBancoDados.Call(EmpCod, FilCod, NfeCod, 0, &sdtConfiguracoesPasta)
		&File.Source = &PastaBancoDados
		If &File.Exists()
			&IsTemXml = true		
		EndIF
	endif
	
EndFor

prcMercadolivreRefreshToken.Call(&EmpCod, &MrkCod, &MrkSession, &IsSucesso)

if &IsTemXml = true
	
	if &IsSucesso = true 
		&HttpClient.AddHeader('Content-Type', 'application/xml')
		&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
		
		//XML

&HttpClient.AddString(&NfeArqXml)
		
		if not &MrkPedNfDtaHor.IsEmpty()
			&HttpClient.Execute('PUT', 'https://api.mercadolibre.com/shipments/'+&MrkPedShipSku+'/invoice_data/?siteId=MLB')
		Else
			&HttpClient.Execute('POST', 'https://api.mercadolibre.com/shipments/'+&MrkPedShipSku+'/invoice_data/?siteId=MLB')
		Endif
	
		&LongVarchar = "Status: " + &HttpClient.StatusCode.ToString()+' GUID:' +&MrkGuid
		&LongVarchar += "Erro: " + &HttpClient.ErrDescription
		&LongVarchar += "Retorno: " + &HttpClient.ToString()
		&LongVarchar += &HttpClient.ToString()
		padraoUsuario.Call('G', 'TESTEfiscaldocuments'+&MrkPedShipSku, 1, 1,&LongVarchar, &PAdDtaMod)
		
		//JDF fiscal_documents
//		&HttpClient.AddHeader('Content-Type', 'multipart/form-data')
//		&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
		
//		//XML
//		&File.Source = &PastaAutorizadas
//		If &File.Exists()
//			&HttpClient.AddFile(&PastaAutorizadas, 'fiscal_document')
//		Else
//			&HttpClient.AddFile(&PastaBancoDados, 'fiscal_document')
//		endif
//		
//		&HttpClient.Execute('POST', 'https://api.mercadolibre.com/packs/'+&MrkPedSku+'/fiscal_documents')
//		
//		&LongVarchar = "Status: " + &HttpClient.StatusCode.ToString()+' GUID:' +&MrkGuid
//		&LongVarchar += "Erro: " + &HttpClient.ErrDescription
//		&LongVarchar += "Retorno: " + &HttpClient.ToString()
//		&LongVarchar += &HttpClient.ToString()
//		padraoUsuario.Call('G', 'TESTEfiscaldocuments', 1, 1,&LongVarchar, &PAdDtaMod)
		
		
		If &HttpClient.StatusCode = 200 or &HttpClient.StatusCode = 201
			&sdtNotaEnviada.FromJson(&HttpClient.ToString())
			
			if not &sdtNotaEnviada.fiscal_key.isempty()
				For Each ORder EmpCod, MrkCod, MrkPedSku
					Where EmpCod = &EmpCod
					Where MrkCod = &MrkCod
					Where MrkPedSku = &MrkPedSku
					
					MrkPedNfDtaHor = serverNow()
					Exit
				EndFor
				
				Commit
				prcAtualizaStatusInterno.Call(&EmpCod, &MrkCod, &MrkPedSku)
			Endif
		Else
			msg('Falha catastrófica! ' + &HttpClient.StatusCode.ToString() + ' ' +&HttpClient.ToString())
		Endif
		
	Else
		msg('Falha catastrófica Session! ' + &HttpClient.StatusCode.ToString())
	Endif
	
Else
	msg('Falha catastrófica Xml! ' + &HttpClient.StatusCode.ToString())
Endif


]]></Source>
