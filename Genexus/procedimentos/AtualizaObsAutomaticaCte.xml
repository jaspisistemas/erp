      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod

	if not CtePlc.IsEmpty()
		&PlacaMensagem = 'Reboque: ' + trim(CtePlc)
	Endif
	
	if not CtePlcTra.IsEmpty()
		&Tracao = 'Tracao: ' + trim(CtePlcTra)
	Endif
	
	If not CteDocTra.Trim().IsEmpty()
		&CteDocTra = 'DT: '+ TRIM(CteDocTra)
	EndIf

	If not CteNroCon.Trim().IsEmpty()
		&CteNroCon = 'CONTAINER: '+ TRIM(CteNroCon)
	EndIf

	If not CteCiotNro.Trim().IsEmpty()
		&CteCiotNro = 'CIOT: '+ TRIM(CteCiotNro)
	EndIf

	If not CteCpfMot.Trim().IsEmpty() and not CteNomMot.Trim().IsEmpty()
		&CteMotorista = 'Motorista: '+ TRIM(CteCpfMot)+' - '+CteNomMot.Trim()
	EndIf

	If not CteAveCodLim.Trim().IsEmpty() 
		&auxCteAveCodLim = 'COD. LIB LIMITE: '+ TRIM(CteAveCodLim)
	EndIf
	
	CteObsAut = &CteDocTra.Trim() + ' ' + &Tracao.Trim() + ' '+ &PlacaMensagem.Trim() + ' ' + &CteNroCon.Trim() + ' ' + &CteCiotNro.Trim() +' '+&CteMotorista.Trim()+' '+&auxCteAveCodLim.Trim() 
	CteObsAut = CteObsAut.Trim() +' '+ &LeiImpostoMensagem.Trim()
	
	Exit
EndFor


Commit
]]></Source>
