      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	If &TipoFornecedor = 'B'
		&titulo = UPPER('Estoque Produtos do Fornecedor')
	Else
		&titulo = UPPER('Estoque Fornecedor Padrão')
	EndIf
	
	print Cabecalho
End
&EstoqueFornecedor.FromXml(&websession.get('sdtFornecedorEst'))
&ProForRaz = trim(str(&auxPesCod))+'-'+&auxPesRaz
Print Topo 
For &EstoqueFornecedorItem in &EstoqueFornecedor
	&ProNomGra = &EstoqueFornecedorItem.ProGraRef+' -'+&EstoqueFornecedorItem.ProNomGra
	&EstQtd = &EstoqueFornecedorItem.EstQtd
	&EstSdo = &EstoqueFornecedorItem.EstSdo
	&EstSug = &EstoqueFornecedorItem.EstSug
	Print Detalhe
EndFor


Footer
	print Rodape
End
]]></Source>
