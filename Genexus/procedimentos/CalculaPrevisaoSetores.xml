      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Soma Total Produzindo
For Each Order EmpCod, FilCod, OrdSts, OrdProSetCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdSts = Status_Producao.EmProducao
	
	
	If &ProSetCod <> OrdProSetCod
		if &ProSetCod <> 0
			do 'addSetor'
		EndIF
		&OrdDtaPrvPed.SetEmpty()
		&ProSetCod = OrdProSetCod
		do 'GetSetor'
		&QtdProduzindoMetros = 0
		&QtdProduzindoQuantidade = 0
	EndIF

	if &OrdDtaPrvPed < OrdDtaPrvPed
		&OrdDtaPrvPed = OrdDtaPrvPed
	EndIF
	
	&ProCod = OrdProCod
	do 'GetProduto'
	
	&OrdProQtdSem = OrdProPrd - OrdProQtdSem
	if &OrdProQtdSem < 0
		&OrdProQtdSem = 0
	EndiF

	&QtdProduzindoMetros += (&OrdProQtdSem * &ProTam)
	&QtdProduzindoQuantidade += &OrdProQtdSem
EndFor

If &QtdProduzindoMetros > 0 or &QtdProduzindoQuantidade > 0
	do 'addSetor'	
EndIf

&ProSetCod = 0
&OrdDtaPrvPed.SetEmpty()
&QtdProduzindoMetros.SetEmpty()
&QtdProduzindoQuantidade.SetEmpty()

//Soma total Pedidos /Aberto
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedSts = Status_Pedido.ABERTO
	Where PedStsPrd <> Status_Producao.EmProducao and PedStsPrd <> Status_Producao.Produzido
	Where PedStsDigBlk <> true or LctTip <> TipoLancamento.OrcamentoVenda 
	Where PedNovStsNom <> 'PROGRAMADO' or (PedNovStsNom = 'PROGRAMADO' and (PedDtaPrv <= Serverdate() or PedDtaPrv <= &PedDtaPrv))
	
	If &ProSetCod <> ProSetCod
		if &ProSetCod <> 0
			do 'addSetor'
		EndIF

		&ProSetCod = ProSetCod
		do 'GetSetor'
		&QtdAbertoMetros = 0
		&QtdAbertoQuantidade = 0
	EndIF
	
	&ProCod = ProCod
	do 'GetProduto'
	
	&OrdProQtdSem = PedQtd //- OrdProQtdSem
	if &OrdProQtdSem < 0
		&OrdProQtdSem = 0
	EndiF

	&QtdAbertoMetros += (&OrdProQtdSem * &ProTam)
	&QtdAbertoQuantidade += &OrdProQtdSem
EndFor

If &QtdAbertoMetros > 0 or &QtdAbertoQuantidade > 0
	do 'addSetor'
	&QtdAbertoMetros = 0
	&QtdAbertoQuantidade = 0
	&ProSetCod = 0
EndIf

&SdtSetor.Sort('SetNom')

Sub 'GetSetor'
	For Each ORder EmpCod, SetCod
		Where EmpCod = &EmpCod
		Where SetCod = &ProSetCod
		&MaximaProducao = SetPrdMax
		&SetNom = SetNom
		Exit
	EndFor
EndSub


Sub 'GetProduto'
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&ProTam = ProTam
		if &ProTam < 0
			&ProTam = 0
		EndIF
		Exit
	EndFor
EndSub

sub 'addSetor'
	&IsAchou = false
	For &SdtSetorItem in &SdtSetor
		if &SdtSetorItem.SetCod = &ProSetCod
			&SdtSetorItem.QtdPrdMtr += &QtdProduzindoMetros
			&SdtSetorItem.QtdPrd += &QtdProduzindoQuantidade
			&SdtSetorItem.QtdAbrMtr += &QtdAbertoMetros
			&SdtSetorItem.QtdAbr += &QtdAbertoQuantidade
			
			&IsAchou = true
			Exit
		EndIF
	EndFor

	If &IsAchou = false
		&SdtSetorItem = new()
		&SdtSetorItem.SetCod = &ProSetCod
		&SdtSetorItem.SetNom = &SetNom
		&SdtSetorItem.SetPrdMax = &MaximaProducao
		&SdtSetorItem.QtdPrdMtr = &QtdProduzindoMetros
		&SdtSetorItem.QtdPrd = &QtdProduzindoQuantidade
		&SdtSetorItem.DataPrd = &OrdDtaPrvPed
		&SdtSetorItem.QtdAbrMtr = &QtdAbertoMetros
		&SdtSetorItem.QtdAbr = &QtdAbertoQuantidade
		&SdtSetor.Add(&SdtSetorItem)
	EndIF
EndSUb


]]></Source>
