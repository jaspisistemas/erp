      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&mensagem.SetEmpty()
if &VeiPla.IsEmpty()
	Return
Endif

For Each Order EmpCod,VeiPla, VeiCod
	Where EmpCod = &EmpCod
	Where VeiPla = &VeiPla
	Where VeiCod <> &VeiCod
	&mensagem = 'Placa já cadastrada em outro veículo!'
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
