      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErro = true //COM ERRO
&IsErroTipFrt = false
&IsErroTraCod = false
&Mensagem = ''

&CotNro = ''
&CotObs = ''
&CotVlr = 0
&CotTraCodRaz = ''
//&PedFatFilCod = &NfFilCod

//loadwwpContext.Call(&WwpContext)

If &TabelaPedidoNota = 'N' //NOTA FISCAL
	For Each Order EmpCod, FilCod, NfeEntSai, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &NfFilCod
		Where NfeCod = &NfeCod
		Where NfeEntSai = &Status_EntradaSaida
		
		&outNfeCod = NfeCod
		&PedCliCodRaz = NfeCliCodRaz
		
		//Achou Pedido
		&NfePedCod = NfePedCod
		&PedFilCod = NfeFilCod
		
		if (NfeTipFrt = TipoFrete.Emitente and &FrtOri <> 'E') and (NfeTipFrt = TipoFrete.Destinatario and &FrtOri <> 'D')
			If &FrtOri = 'E'
				&FreteConhecimento = 'EMITENTE'
			Else
				&FreteConhecimento = 'DESTINATÁRIO'
			EndIF
			
			&IsErroTipFrt = true
			&Mensagem = 'ERRO: TIPO DE FRETE DA NFe ESTÁ COMO ' + NfeTipFrt.EnumerationDescription() + ' E A DO CONHECIMENTO COMO ' + &FreteConhecimento.trim()
		EndIF
	
		Exit
	When None
		&Mensagem = 'ERRO: NOTA FISCAL: '+trim(str(&NfeNum))+' NÃO LOCALIZADA NA FILIAL: ' + trim(str(&NfFilCod))
		Return
	EndFor
Else
	&NfePedCod = &PedCod
	&PedFilCod = &parPedFilCod //&WwpContext.FilCod
	&PedFatFilCod = &NfFilCod
EndIF


if &NfePedCod <> 0 //FRETE EH EM CIMA DO PEDIDO.
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &PedFilCod
		Where PedCod = &NfePedCod
		Where PedFatFilCod = &NfFilCod when &NfFilCod > 0
		
		&PedCliCodRaz = PedCliCodRaz
		
		Do Case
			Case not PedCnhFrt.IsEmpty() and not PedCnhFrt.IsNull() and not PedCnhEms.IsEmpty() and (&FrtDoc <> PedCnhFrt or (&FrtDoc = PedCnhFrt and PedCnhEms <> &PedCnhEms))
				&Mensagem = 'ERRO: PEDIDO JA POSSUI CONHECIMENTO: '+ trim(PedCnhFrt) + ' EMISSÃO: '+ trim(dtoc(PedCnhEms))
				&IsErroJaLancado = true
				
			Case PedTraRedCod <> &FrtTraCod and PedTraSaiCod <> &FrtTraCod //VERIFICA TRANS. REDESPACHO
				&IsErroTraCod = true
				&Mensagem = 'ERRO: TRANS. DO FRETE DIFERE COM A DO PEDIDO: ' + trim(str(PedCod)) + ' SAÍDA: ' + trim(PedTraSaiCodRaz) + ' REDESP.: ' + trim(PedTraRedCodRaz)
				
			Otherwise
				&IsErro = false //SEM ERRO
		EndCAse
		
		exit
	When none
		&Mensagem = 'ERRO: PEDIDO NÃO ENCONTRADO NA FILIAL: ' + trim(str(&PedFilCod))
	EndFor

	For Each Order EmpCod, CotPedCod, CotIs
		Where EmpCod = &EmpCod
		Where CotPedCod = &NfePedCod
		Where CotIs = true
		
		&CotNro = CotNro
		&CotObs = CotObs
		&CotVlr = CotVlr
		
		&CotTraCodRaz = CotTraCodRaz
		Exit
	EndFor
Else
	&Mensagem = 'ERRO: PEDIDO NÃO ENCONTRADO'
EndIf
]]></Source>
