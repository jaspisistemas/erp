      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &PesCod.IsEmpty() //INSERT
	//QUando insert inserido os campos no proprio processo de gravar.
Else
	For Each Order EmpCod, PesCod, ComLctCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&IdVarchar = trim(str(ComLctCod))
		prcLogAddSdtLevel.Call(&IdVarchar, 'ComLctCod', trim(str(ComLctCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'ComTabNor', trim(ComTabNor.ToFormattedString()), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'ComTabPrm', trim(ComTabPrm.ToFormattedString()), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesTipCom', trim(PesTipCom.toString()), '', &sdtLogAtributosLevel)
		
	EndFor
Endif
]]></Source>
