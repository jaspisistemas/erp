      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod 
	
	PedStsFut = &PedStsFut  // VendaFutura.BloqueiaVendaFutura = 'S'
	
	//aqui é o pedido de origem de uma ordem de carregamento que no caso ele foi bloqueado como venda futura e 
	
	//Primeiro verificams se esse pedido de origem tem pgto 
	&IsPagto = RetornaUmItemPago.udp(EmpCod, FilCod, PedCod)
	If &IsPagto = False //se não tiver pgto no ENTR.FUTURA cancela o financeiro
		PedStsFin = Status_Financeiro.CANCELADO
		PedStsFinIsPar = false
	EndIf
	
	//Ao abrir uma ordem de carregamento, se não tiver mais nenhuma referencia, do pedido Original volta o financeiro do pedido principal para aberto.
	&IsUmReferenciado = RetornaUmPedidoReferencia.Udp(EmpCod, FilCod, PedCod)
	If &IsUmReferenciado = false and  &IsPagto = False //não tem referencia e não tem pgto
		PedStsFin = Status_Financeiro.ABERTO
		PedStsFinIsPar = false
	EndIf
	
	Exit
EndFor


Commit

PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &Pedcod)

//ATUALIZA TOTAL 
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod 
	
	&OldPedQtdSdo = PedQtd - PedQtdFat
	
	&PedQtdFat = PedQtdFat_FORMULA
	PedQtdFat = &PedQtdFat
	
	&PedQtdSdo = PedQtd - &PedQtdFat
	
	AtualizaEstoqueCompradoVendido.Call(EmpCod, FilCod, ProCod, ProGraCod, &OldPedQtdSdo, &PedQtdSdo, Status_EntradaSaida.Saida)
EndFor

Commit
]]></Source>
