      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&TabPerCol1 = 'COL.1'
&TabPerCol2 = 'COL.2'
&TabPerCol3 = 'COL.3'
&TabPerCol4 = 'COL.4'
&TabPerCol5 = 'COL.5'
&TabPerCol6 = 'COL.6'
&TabPerCol7 = 'COL.7'
&TabPerCol8 = 'COL.8'
&TabPerCol9 = 'COL.9'

For Each Order EmpCod, TabCod, TabColCod
	Where EmpCod = &EmpCod
	Where TabCod = &TabNum
	
	Do Case 
		Case TabColCod = 1 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol1 = Trim(TabColNom)
			
	    Case TabColCod = 2 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol2 = Trim(TabColNom)
			
	    Case TabColCod = 3 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol3 = Trim(TabColNom)
			
	    Case TabColCod = 4 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol4 = Trim(TabColNom)
			
	    Case TabColCod = 5 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol5 = Trim(TabColNom)
			
		Case TabColCod = 6 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol6 = Trim(TabColNom)
			
		Case TabColCod = 7 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol7 = Trim(TabColNom)
			
		Case TabColCod = 8 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol8 = Trim(TabColNom)
			
		Case TabColCod = 9 and SUBSTR(UPPER(TabColNom), 1, 3) <> 'COL'
	        &TabPerCol9 = Trim(TabColNom)
			
    EndCase
EndFor
]]></Source>
