      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsSucesso = false
do 'VerificaHierarquia'
	
If &ColGrupCod.Count > 0
	For each Order EmpCod,GrupHiePadL, GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod in &ColGrupCod
		&sdtCategoriaLojaIntegrada = new()
		
		If GrupLojVirIntUri.Trim().IsEmpty()
			&sdtCategoriaLojaIntegrada.id_externo = GrupCod
			&sdtCategoriaLojaIntegrada.nome = GrupNom.Trim()
			&sdtCategoriaLojaIntegrada.descricao = GrupNomCmp
			If GrupPaiCod <> 0 
				&PaiGrupCod = GrupPaiCod
				do 'BuscaIdPai'				
			EndIf
			do 'realizaconexao'
		EndIf
	EndFor		
EndIf

Sub 'BuscaIdPai'
	For each Order EmpCod, GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &PaiGrupCod
		&sdtCategoriaLojaIntegrada.categoria_pai = GrupLojVirIntUri
		exit
	EndFor
EndSub
	
Sub 'VerificaHierarquia'	
	For each Order EmpCod,GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &GrupCod
		&ColGrupCod.Add(GrupCod)
		If GrupPaiCod <> 0
			&auxGrupCod = GrupPaiCod
			Do 'BuscaPai'	
		EndIf	
	EndFor
EndSub

Sub 'realizaconexao'
	If &sdtCategoriaLojaIntegrada.id_externo <> 0
		If NOT &sdtCategoriaLojaIntegrada.categoria_pai.IsEmpty()
			padraoUsuario.Call('G', '#LOJAINTEGRADACATEGORIAPAI', &PesCod, &EmpCod, &sdtCategoriaLojaIntegrada.toJson(), &PadDtaMod)  // Grava PARAMETRO como um LOG para Consulta
		Else
			padraoUsuario.Call('G', '#LOJAINTEGRADACATEGORIAFILHO', &PesCod, &EmpCod, &sdtCategoriaLojaIntegrada.toJson(), &PadDtaMod)  // Grava PARAMETRO como um LOG para Consulta
		EndIf
		CadastrarCategoriaApiLojaIntegradaPost.Call(&EmpCod,&sdtCategoriaLojaIntegrada)
	EndIf
EndSub

sub 'BuscaPai'
	For each Order EmpCod,GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &auxGrupCod
		&ColGrupCod.Add(GrupCod)
		If GrupPaiCod <> 0
			&auxGrupCod = GrupPaiCod
			Do 'BuscaPai'	
		EndIf
	EndFor
EndSub
]]></Source>
