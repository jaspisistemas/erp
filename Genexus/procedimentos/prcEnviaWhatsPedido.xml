      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&LogGUID = GUID.NewGuid()
&index   = 0
&indes   = trim(str(&index))
&isValid = true

/*
	BUSCA AS MENSAGENS A SEREM ENVIADAS
*/
msg(&Pgmname + ': iniciando busca por itens a serem enviados: PENDENTE, ENVIADO_PARCIAL ou FALHOU', status)
For Each order EmpCod, FilaWhatsGUID
	where EmpCod           = &EmpCod
	where FilaWhatsGUID = &FilaWhatsGUID
	//	where FilaWhatsTip     = TipoFilaEnvioWhats.PEDIDO
	//	where FilaWhatsSts     = Status_FilaWhats.PENDENTE
	//	   or FilaWhatsSts     = Status_FilaWhats.ENVIADO_PARCIAL
	//	   or FilaWhatsSts     = Status_FilaWhats.FALHOU
	//	where FilaWhatsQtdTen  < 3
	//	where FilaWhatsDtaUltTen.IsEmpty() or FilaWhatsDtaUltTen.IsNull()
	//	if DateTimeDifference(now(), FilaWhatsDtaUltTen) >= 300 // 1min = 60s
	
	&index += 1
	&indes = trim(str(&index))
	&isEnviou = false
	&FilaWhatsGUIDs = trim(FilaWhatsGUID.ToString())
	msg(&indes + 'º ' + &FilaWhatsGUIDs + ': iniciando [' + FilaWhatsSts + ']', status)
	
	&PesCod = FilaWhatsDestPesCod
	&PesFonNum = FilaWhatsDestPesFonNum //Fone destino
	
	if not &PesFonNum.IsEmpty()
		&FilaWhatsFilCod = FilaWhatsFilCod
		
		for each order EmpCod, FilaWhatsGUID, FilaWhatsMsgOrd
			where FilaWhatsMsgSts = Status_FilaWhats.PENDENTE
			or FilaWhatsMsgSts = Status_FilaWhats.FALHOU
			
			if FilaWhatsMsgTip = TipoMensagemWhats.DOCUMENTO
				&FilaWhatsMsgGUID = FilaWhatsMsgGUID
				&FilaWhatsMsgArqDirFis = FilaWhatsMsgarqDirFis			
			endif
			
			do case
				case TipoMensagemWhats.TEXTO = FilaWhatsMsgTip
					&UserMessage = JabotiAPI_EnviaTexto(EmpCod,&LogGUID,&PesFonNum,FilaWhatsMsgTxt)
					
				case TipoMensagemWhats.DOCUMENTO = FilaWhatsMsgTip
					&UserMessage = JabotiAPI_EnviaDocumento(EmpCod,&LogGUID,&PesFonNum,FilaWhatsMsgArqDirFisVir,'',FilaWhatsMsgArqNom,FilaWhatsMsgTxt)
					
				otherwise
					&UserMessage = new()
					exit
			endcase
			
			if &UserMessage.isSucess
				FilaWhatsMsgSts = Status_FilaWhats.ENVIADO
				&isEnviou = true
			else
				msg(&indes + 'º ' + &FilaWhatsGUIDs + ': falha ao enviar para o servidor > ' + newline() + &UserMessage.ToJson(), status)
				FilaWhatsMsgSts = Status_FilaWhats.FALHOU
				
				&isValid = false
				exit
			endif
		endfor
		
		FilaWhatsQtdTen += 1
		FilaWhatsDtaUltTen = now()
		if &isValid
			FilaWhatsSts = Status_FilaWhats.ENVIADO
			FilaWhatsDtaEnv = now()
			FilaWhatsLog.SetEmpty()
		else
			if &isEnviou
				FilaWhatsSts = Status_FilaWhats.ENVIADO_PARCIAL
			else
				FilaWhatsSts = Status_FilaWhats.FALHOU
			endif
			
			FilaWhatsLog = &LogGUID.ToString().Trim() + '. ' + &UserMessage.ToJson()
			exit
		endif
	else
		// notifica o sistema de ajuda para inconsistências no telefone
	endif

	msg(&indes + 'º ' + &FilaWhatsGUIDs + ': finalizado', status)
	
	if &index >= 100
		return
	endif
	//	endif
when none
	msg(&indes + 'º: nenhum item foi encontado', status)
	msg(&indes + 'º: finalizado', status)
EndFor

commit 

]]></Source>
