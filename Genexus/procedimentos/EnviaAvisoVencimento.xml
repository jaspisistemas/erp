Sub 'Funcionario'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&FunNom = PesRaz
		
		For Each Order EmpCod, PesCod, PesEmlCod
			&FunEmailContato = PesEml
			Exit
		EndFor
		
		Exit
	EndFor
EndSub


