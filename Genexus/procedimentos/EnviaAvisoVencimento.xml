&EmlSts = Status_Solicitacao.Pendente
&EmlTip = TipoContaEmail.Email_Financeiro

For Each Order EmpCod, EmlTip, EmlCod
	Where EmpCod = &EmpCod
	Where EmlTip = &EmlTip
	Where EmlCod = &EmlCod
	
	HostWebServiceJaspiADM.Call(EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	&EmlSeqCod = EmlSeqCod
	
	do 'Filial'
	Do 'Login'
	
	&PesCod = EmlPesCod
	do 'Funcionario'
	
	&BoletosGerados.Clear()
	For Each Order EmpCod, EmlTip, EmlCod, EmlDupCod
		&CreFilCod = EmlDupFiLCod
		&CreCod = EmlDupCreCod
		
		do 'GeraBoletos'
	EndFor

	&EmlAss = EmlAss
	&EmlObs = EmlObs
    Exit
EndFor

For Each Order EmpCod, EmlTip, EmlCod, EmlItmCod
	Where EmpCod = &EmpCod
	Where EmlTip = &EmlTip
	Where EmlCod = &EmlCod
	
	//Destinatário de email
	
	&Destinatarios.Add(EmlUrl)
EndFor
	
do 'PreencheHTML'
msg('Html Anexado' )

//ADICIONA ARQUIVO
For &BoletosGeradosItem in &BoletosGerados
	if &BoletosGeradosItem.IsBoleto = 1
		&DiretorioFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'envBoleto' + trim(str(&BoletosGeradosItem.CreCod)) + '.pdf'
		
		&File.Source = &DiretorioFisico //PDF
		If &File.Exists()
			//=====Adiciona Anexo a partir de um caminho do servidor=====
			&Attachments.Add(&DiretorioFisico)
			GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &DiretorioFisico )
		EndIF
	EndIF
EndFor

For &BoletosGeradosItem in &BoletosGerados
	if &BoletosGeradosItem.IsBoleto = 2
		&DiretorioFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'envDuplicata' + trim(str(&BoletosGeradosItem.CreCod)) + '.pdf'
		
		&File.Source = &DiretorioFisico //PDF
		If &File.Exists()
			//=====Adiciona Anexo a partir de um caminho do servidor=====
			&Attachments.Add(&DiretorioFisico)
			GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &DiretorioFisico )
		EndIF
	EndIF
EndFor
	

&Result = &JASPI_enviaEmail.SendEmailSafeJson(&HostVarchar, &PortNumeric, &UserNameVarchar, &EmpEmlSen, &imapHost, &imapPort, &imapSsl, &FilRaz, &AddressVarchar, &FunEmailContato, &FilRaz, &Destinatarios, &EmlAss, &Obs, &Attachments, true)
	
&EmailResult.FromJson(&Result)

If &EmailResult.Success = true
    // Marca como enviado
	&EmlMsg = 'Enviado com Sucesso!'
	&Tentativa = 99
	&EmlSts = Status_Solicitacao.Finalizada
Else
	&EmlMsg = &EmailResult.ErrorCode + " - " + &EmailResult.Message
	&Tentativa = 99
	
	&EmlSts = Status_Solicitacao.Falha
EndIf


Sub 'GeraBoletos'
	msg('Gerar Boletos' )
	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &CreFilCod
		Where CreCod = &CreCod
		Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
		
		if &FilFonNum.IsEmpty()
			&FilFonNum = FilFonNum
		EndIF
		&NomeCliente = trim(CreCliRaz)
		
		&sdtBoleto.Clear()
		&sdtBoletoItem = new()
		&sdtBoletoItem.CreCod = CreCod
		&sdtBoletoItem.CreEmpCod = EmpCod
		&sdtBoletoItem.CreFilCod = FilCod
		&sdtboletoItem.BolMod    = CreCbrBolMod
		&sdtBoleto.Add(&sdtBoletoItem)
		
		&isOk = false
		&Boleto = 0
		Do Case
			Case (CreCbrImp = TipoImpressao.GerarBoleto)
				GerarBoleto.Call(&sdtBoleto, false, &IsErro, &ImprimeSdtBoleto)
				if &IsErro = false
					
					&DiretorioFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'envBoleto' + trim(str(CreCod)) + '.pdf'
					&File.Source = &DiretorioFisico
					if &File.Exists()
						&File.Delete()
					EndIf
					
					&Boleto = 1
					RELJAS045_toFile.Call(EmpCod, FilCod, &ImprimeSdtBoleto, &DiretorioFisico)
					&isOk = true
				EndIF
			
			Case (CreCbrImp = TipoImpressao.ImprimirBoleto) and CreBloNro <> ''
				GerarBoleto.Call(&sdtBoleto, false, &IsErro, &ImprimeSdtBoleto)
				if &IsErro = false
					
					&DiretorioFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'envBoleto' + trim(str(CreCod)) + '.pdf'
					&File.Source = &DiretorioFisico
					if &File.Exists()
						&File.Delete()
					EndIf
					
					&Boleto = 1
					RELJAS045_toFile.Call(EmpCod, FilCod, &ImprimeSdtBoleto, &DiretorioFisico)
					&isOk = true
				EndIF
			
			Case (CreCbrImp = TipoImpressao.ImprimirDuplicata)
				
				&DiretorioFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'envDuplicata' + trim(str(CreCod)) + '.pdf'
				&File.Source = &DiretorioFisico
				if &File.Exists()
					&File.Delete()
				EndIf
				
				&sdtDuplicata.Clear()
				&sdtDuplicataItem = new()
				&sdtDuplicataItem.CreCod = CreCod
				&sdtDuplicataItem.EmpCod = EmpCod
				&sdtDuplicataItem.FilCod = FilCod
				&sdtDuplicata.Add(&sdtDuplicataItem)
				
				&Boleto = 2
				RELJAS019_toFile.Call(EmpCod, FilCod, &sdtDuplicata, &DiretorioFisico)
				&isOk = true
		EndCase
		
		if &isOk = true
			&BoletosGeradosItem = new()
			&BoletosGeradosItem.CreCod = CreCod
			&BoletosGeradosItem.CreEmpCod = EmpCod
			&BoletosGeradosItem.CreFilCod = FilCod
			&BoletosGeradosItem.IsBoleto = &Boleto
			&BoletosGerados.Add(&BoletosGeradosItem)
		ENdIF
		
		
		
	EndFor

	msg('Boletos Gerados' )
EndSub

Sub 'Filial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &EmlFilCod
		
	 	&FilRaz = iif(FilFan.IsEmpty() or FilFan.IsNull(), FilRaz, FilFan)
		
		&FilWebLogo = FilWebLogo.Trim()
		&FilSit = FilSit.Trim()
		Exit
	EndFor
EndSub

Sub 'login'
	For Each Order EmpCod, EmpEmlCod
		Where EmpCod = &EmpCod
		Where EmpEmlTip = &EmlTip
		
		If EmpEml = 'nao_responda@jaspi.com.br' or EmpEml = 'nao.responda.jaspi@gmail.com' //adiciona a mensagem dados do remetente
			&EmpEmlCod = EmpEmlCod
			do 'EmailPadrao'
		Else
			&AddressVarchar = EmpEml
			//&FilRaz
			&AuthenticationNumeric = EmpEmlAut
			&SecureNumeric 		= EmpEmlSec
			&TimeoutNumeric        = 600
			&HostVarchar 			= EmpEmlHos
			&UserNameVarchar 		= EmpEmlUsr
			&EmpEmlSen 		= DecryptSenhaEmail.Udp(EmpCod, EmpEmlCod, EmpEml)
			&PortNumeric 			= EmpEmlPor
			&imapHost = EmpEmlImapHos
			&imapPort = EmpEmlImapPor
			&imapSsl = EmpEmlImapSsl
		EndIF
		
		Exit
	When None
		GravaRemetentePadrao.Call(&EmpCod, &EmlTip, &EmpEmlCod)
		do 'EmailPadrao'
	EndFor

	msg('Login Conta Email:' )
EndSub

sub 'EmailPadrao'
		
	EmailPadrao.call(&AddressVarchar, &AuthenticationNumeric, &SecureNumeric, &TimeoutNumeric, &HostVarchar, &UserNameVarchar, &PortNumeric, &imapHost, &imapPort, &ImapSSl)
	&EmpEmlSen = DecryptSenhaEmail.Udp(&EmpCod, &EmpEmlCod, &AddressVarchar)
	
EndSub

