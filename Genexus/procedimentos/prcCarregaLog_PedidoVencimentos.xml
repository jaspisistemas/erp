        <Source><![CDATA[

if &PedCod.IsEmpty() //INSERT
	//QUando insert inserido os campos no proprio processo de gravar.
Else
	For Each Order EmpCod, FilCod, PedCod, PedVctCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
		
		&IdVarchar = trim(str(PedVctCod))
		prcLogAddSdtLevel.Call(&IdVarchar, 'PedVctCod', trim(str(PedVctCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PedVctDta', trim(PedVctDta.ToFormattedString()), '', &sdtLogAtributosLevel)
		
	EndFor
Endif
]]></Source>
