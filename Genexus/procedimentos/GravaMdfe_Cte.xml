      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CteDocVlrTotPro = 0
For each Order EmpCod,FilCod,CteCod,CteDocCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	If CteDocVlrTotPro > &CteDocVlrTotPro
		&CteDocNcmPre = CteDocNcmPre
		&CteDocVlrTotPro = CteDocVlrTotPro
	Else
		If not CteDocNcmPre.IsEmpty()
			&CteDocNcmPre = CteDocNcmPre
		EndIf
	EndIf
EndFor

For each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	New
		UltimoCodigoEmpresa.Call(domParCod.MDFE, EmpCod, FilCod,&MDFeCod)
		UltimoCodigoEmpresa.Call(domParCod.MDFENUM, EmpCod, FilCod,&newMDFENum)
		EmpCod = EmpCod
		FilCod = FilCod
		MDFeCod = &MDFeCod
		MDFeNum = &newMDFENum
		MDFeSer = 1
		MDFeDtaEms = serverdate()
		MDFeHorEms = serverTime()
		MDFeDtaSai = serverdate()
		MDFeHorSai = serverTime()
		MDFeSts = Status_MDFe.Digitando
		MDFeTipTra = MDFe_TipoTransporte.ETC
		MDFeTipEmt = MDFe_TipoEmitente.Prestador
		MDFeModCod = '58'
		MDFeTipMod = TipoModalidade.Rodoviario
		MDFeOriUfeCod = CteIniUfe		
		MDFeDstUfeCod = CteTerUfe
		MDFeProPre = CteCarProPre
		MDFeLotCarCep = CteRemCep
		MDFeLotDesCep = CteDesCep
		If not &CteDocNcmPre.Trim().IsEmpty()
			MDFeProPreNcm = val(&CteDocNcmPre)
		EndIf
	
		&CtePlc = CtePlc
		&CtePlcTra = CtePlcTra
		&CteCpfMot = CteCpfMot
		&CteNomMot = CteNomMot
		If not CteTomCnpj.Trim().IsEmpty()
			MdfeConCnpj =  CteTomCnpj
		Else
			MdfeConCnpj =  CteTomCpf
		EndIf

		MdfeConRaz = CteTomRaz
		&CteTerUfe = CteTerUfe
		&CteTerCidCod = CteTerCidCod
		do 'getcidadetermino'
		MDFeDesCidCod = &MDFeDesCidCod
		&CteIniUfe = CteIniUfe
		&CteIniCidCod = CteIniCidCod
		do 'getcidadeinicio'
		MDFeAveSts = Status_Nfe.Digitando
	EndNew

	commit
	
	New 
		EmpCod = EmpCod
		FilCod = FilCod
		MDFeCod = &MDFeCod
		MDFeCarCod    = 1
		MDFeCarCidCod = &MDFeCarCidCod
	EndNew
	
	commit
	
	If Not &CtePlc.Trim().IsEmpty()
		Do 'ValidaVeiculoReboque'
		Do Case
			Case &VeiTip = VeiculoTipo.Tracao
				MDFe_Veiculo.Call('ADD', EmpCod, FilCod, &MDFeCod, 0, &CtePlc)
			Case &VeiTip = VeiculoTipo.Reboque
				MDFe_Reboque.Call('ADD', EmpCod, FilCod, &MDFeCod, 0, &CtePlc)
		EndCase
	EndIf

	If Not &CtePlcTra.Trim().IsEmpty()
		Do 'ValidaVeiculoTracao'
		Do Case
			Case &VeiTip = VeiculoTipo.Tracao
				MDFe_Veiculo.Call('ADD', EmpCod, FilCod, &MDFeCod, 0, &CtePlcTra)
			Case &VeiTip = VeiculoTipo.Reboque
				MDFe_Reboque.Call('ADD', EmpCod, FilCod, &MDFeCod, 0, &CtePlcTra)
		EndCase
	EndIf


	if not &CteCpfMot.Trim().IsEmpty()
		MDFE_Motorista.Call('ADD', EmpCod, FilCod, &MDFeCod, 0, &CteCpfMot, &CteNomMot)
	EndIF

	//################################# Adiciona seguradora se tiver averbação preenchida no Cte
	If not CteAveCnpjSeq.Trim().IsEmpty()
		&CteAveCnpjSeq = CteAveCnpjSeq
		&CteAveApo = CteAveApo
		Do 'BuscaCadastro'
		New
			EmpCod = EmpCod
			FilCod = FilCod
			MDFeCod = &MDFeCod
			MdfeSegCod = 1
			MdfeSegRef = &SegCod
			MdfeSegRes = ResponsavelSeguro.Contratante
			MdfeSegCnpj = CteAveCnpjSeq
			MdfeSegNom = &SegNom
			MdfeSegNroApo = CteAveApo
		EndNew
		
		Commit
		New
			EmpCod = EmpCod
			FilCod = FilCod
			MDFeCod = &MDFeCod
			MdfeSegNroAve = CteAveNro
		EndNew
		Commit
	EndIf
	
	&CteChv = CteChv
	&CteterCidCod = CteTerCidCod
	&CteTerCidNom = CteTerCidNom
	&CteTerUfe = CteTerUfe
	&CteVlrTotPreSer = CteVlrTotPreSer
	&CteQtdTotKg = CteQtdTotKg
	&CteCiotNro = CteCiotNro
	
	&FilCpj = FilCpj
	
EndFor

commit

MDFE_CTE.Call('ADD', &EmpCod, &FilCod, &MDFeCod, 0, &FilCod, &CteCod,&CteChv,&MDFeCteChv2,&CteterCidCod,&CteTerCidNom,&CteTerUfe,&CteVlrTotPreSer,&CteQtdTotKg,&CteCiotNro,&FilCpj)
MDFe_TotalizarNotas.Call(&EmpCod, &FilCod, &MDFeCod, &countCteNumeric, &countNfeNumeric, &totalNumeric, &PesoBrutoMoeda, &TotalMoeda)

Sub 'ValidaVeiculoReboque'
	&VeiTip.SetEmpty()  
	For Each Order EmpCod, VeiCod
		Where EmpCod = &EmpCod
		Where VeiPla = &CtePlc
		&VeiTip = VeiTip 
		exit
	EndFor
EndSub

Sub 'ValidaVeiculoTracao'
	&VeiTip.SetEmpty()  
	For Each Order EmpCod, VeiCod
		Where EmpCod = &EmpCod
		Where VeiPla = &CtePlcTra
		&VeiTip = VeiTip 
		exit
	EndFor
EndSub


Sub 'getcidadetermino'
	For each order EmpCod,UfeCod,CidIBGE
		Where EmpCod = &EmpCod
		Where UfeCod = &CteTerUfe
		Where CidIBGE = &CteTerCidCod
		&MDFeDesCidCod = CidCod
		Exit
	EndFor
EndSub

Sub 'getcidadeinicio'
	For each order EmpCod,UfeCod,CidIBGE
		Where EmpCod = &EmpCod
		Where UfeCod = &CteIniUfe
		Where CidIBGE = &CteIniCidCod
		&MDFeCarCidCod = CidCod
		Exit
	EndFor
EndSub

Sub 'BuscaCadastro'
	For each order EmpCod,SegCnpj
		Where EmpCod = &EmpCod
		Where retornaSoNumeros.Udp(SegCnpj) = retornaSoNumeros.Udp(&CteAveCnpjSeq)
		&SegNom = SegNom
		&SegCod = SegCod
		Exit
	When none
		UltimoCodigoEmpresa.Call(domParCod.SEGURADORA, &EmpCod,  0, &SegCod)
		ValidaCpfCnpj.call(&CteAveCnpjSeq,0,'')
		if not &CteAveCnpjSeq.IsEmpty() and &CteAveCnpjSeq.Length() > 14
			ConsultaRFB.call(&EmpCod, &CteAveCnpjSeq,&AuxPesRaz,'','','','','','',0,'', '',&HttpClient)
			if not &AuxPesRaz.IsEmpty()
				&SegNom = &AuxPesRaz
			EndiF
		EndIf
	
		New
			EmpCod = &EmpCod
			SegCod = &SegCod
			SegCnpj = &CteAveCnpjSeq
			SegNom = &SegNom
			SegApo = &CteAveApo
		EndNew
	
	commit
	EndFor
EndSub

]]></Source>
