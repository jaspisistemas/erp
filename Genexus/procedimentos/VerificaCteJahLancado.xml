      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CteCod = 0

For Each Order EmpCod, FilCod, CteNum, CteSer, CteModCod, CteTomCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteNum = &CteNum
	Where CteSer = &CteSer
	Where CteModCod = &CteModCod
	Where (CteTomCod = &CteTomCod and &CteTomCod > 0) //or (NfePedCod = &NfePedCod and &NfePedCod > 0)
	Where CteSts <> Status_NFe.Importada and CteSts <> Status_NFe.Excluida
		&CteCod = CteCod
	Exit	
EndFor
]]></Source>
