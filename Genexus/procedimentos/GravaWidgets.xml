      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//MODULOS
If &ppJASPI_WidgetssdtWidgets_sdtWidgetsItem.Count > 0
	For Each Order EmpCod, WidSync
		Where EmpCod = &EmpCod
		
		For Each Order EmpCod, WidSync, WidPesCod
			Where WidOrdUsr.IsEmpty() or WidOrdUsr.IsNull() or WidOrdUsr > 900
			delete
		EndFor
		Delete
	EndFor
	Commit
	
	For &Varchar in &ppJASPI_WidgetssdtWidgets_sdtWidgetsItem
		//&count += 1
		new
			EmpCod = &EmpCod
			WidSync = &Varchar.ErpWidSync
			WidNom = &Varchar.ErpWidNom
			WidOrd = &Varchar.ErpWidCod
			
		EndNew
		&WidOrd = &Varchar.ErpWidCod
		Commit
		
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesExtCod > 0
			
			&PesCod = PesCod
			&WidSync = &Varchar.ErpWidSync
			For Each Order EmpCod, WidSync, WidPesCod
				Where EmpCod = &EmpCod
				Where WidSync = &WidSync
				Where WidPesCod = &PesCod
				Exit
			When None
				do 'NewWidPessoa'
			EndFor
			
		EndFor
		
	EndFor
EndIF

new // esse widget nao esta vinculado a nenhum modulo esta no cadatsro do adm só pra gente saber, posição 3 fixa
	EmpCod = &EmpCod
	WidSync = 'WD_MENSAGENS'
	WidNom = 'Mensagens Do Sistema'
	WidOrd = 3
EndNew
commit

Sub 'NewWidPessoa'
	New
		EmpCod = &EmpCod
		WidSync = &WidSync
		WidPesCod = &PesCod
		WidIsSel = False
		WidOrdUsr = &WidOrd
	EndNEw
	commit
EndSub
]]></Source>
