      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do Case
	Case &mode = TrnMode.Delete          // Deleta saldo e recalcula		
		If not &MovDtaCon.IsEmpty()
			DeleteSaldo.Call(&EmpCod,&CtaBanCod,&MovDtaCon,&MovCreDeb,&MovVlr)
		EndIf
	
	Case &Mode = TrnMode.Insert      //insert saldo		
		If not &MovDtaCon.IsEmpty()	
			InsertSaldo.Call(&EmpCod,&CtaBanCod,&MovDtaCon,&MovCreDeb,&MovVlr)	
		EndIf
	
	Case &Mode = TrnMode.Update		
		If not &AntMovDta.IsEmpty()
			UpdateDelete.Call(&EmpCod,&CtaBanCod,&AntMovDta,&AntMovCreDeb,&AntMovVlr)
		EndIf
		
		If not &MovDtaCon.IsEmpty()
			For Each Order EmpCod,CtabanCod,SdoDta  //Insere o update saldo atual
				Where EmpCod = &EmpCod
				Where CtabanCod = &CtaBanCod
				where SdoDta = &MovDtaCon	
				
				If &MovCreDeb = 'D'
					SdoSai += &MovVlr
				Else
					SdoEnt += &MovVlr
				EndIf
				AtualizasaldoDataMaior.Call(&EmpCod,&CtaBanCod,&MovDtaCon,&MovCreDeb,&MovVlr)
			When none
				Do 'sdoAnt'
				NovoDiaSaldo.Call(&EmpCod,&CtaBanCod,&SdoDia,&MovDtaCon,&MovCreDeb,&MovVlr)
				AtualizasaldoDataMaior.Call(&EmpCod,&CtaBanCod,&MovDtaCon,&MovCreDeb,&MovVlr)
			EndFor
		
			Commit
		EndIf
EndCase


Sub 'sdoAnt' // pega saldo anterior para o novo dia
	&sdoDia = 0
	For Each Order EmpCod,CtabanCod,(SdoDta)
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		Where SdoDta < &MovDtaCon 
		&sdoDia = SdoAtu
		Exit
	EndFor
EndSub
]]></Source>
