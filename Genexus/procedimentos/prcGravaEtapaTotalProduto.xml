      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TabelaVarchar = 'PRODUTOETAPA'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)

For Each ORder EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	&ProRef = ProRef
	Exit
EndFor

For Each ORder EmpCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProEtpFunCod = &ProEtpFunCod
	Where ProEtpCod = &ProEtpCod
	
	&novoProEtpHor = ProEtpHor + &ProEtpHor
	&novoProEtpQtd = ProEtpQtd + &ProEtpQtd
	&oldProEtpMed = ProEtpMed
	
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(&ProRef)
		&LogErpRegCod2 = trim(str(&ProEtpFunCod))
		&LogErpRegCod3 = trim(str(&ProEtpCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		//GERAL
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpHor', trim(ProEtpHor.ToFormattedString()), trim(&novoProEtpHor.ToFormattedString()), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpQtd', trim(ProEtpQtd.ToFormattedString()), trim(&novoProEtpQtd.ToFormattedString()), &LogErpRegGUID )
	Endif

	ProEtpHor = &novoProEtpHor
	ProEtpQtd = &ProEtpQtd
	if ProEtpHor > 0 and ProEtpQtd > 0
		ProEtpMed = ProEtpHor / ProEtpQtd
	Endif
	
	if &LogErpTabIsLog = true
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpMed', trim(&oldProEtpMed.ToFormattedString()), trim(ProEtpMed.ToFormattedString()), &LogErpRegGUID )
	Endif

	Exit
When none
	
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(&ProRef)
		&LogErpRegCod2 = trim(str(&ProEtpFunCod))
		&LogErpRegCod3 = trim(str(&ProEtpCod))
		&LogErpRegTip = TrnMode.Insert
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		//GERAL
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpHor', '', trim(&ProEtpHor.ToFormattedString()), &LogErpRegGUID )
		
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpQtd', '', trim(&ProEtpQtd.ToFormattedString()), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpDtaIni', '', trim(&ProEtpDtaIni.ToFormattedString()), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpDtaFin', '', trim(&ProEtpDtaFin.ToFormattedString()), &LogErpRegGUID )
	Endif

	New
		EmpCod = &EmpCod
		ProCod = &ProCod
		ProEtpFunCod = &ProEtpFunCod
		ProEtpCod = &ProEtpCod
		ProEtpHor = &ProEtpHor
		ProEtpQtd = &ProEtpQtd
		ProEtpMed = &ProEtpMed
		
		if ProEtpHor > 0 and ProEtpQtd > 0
			ProEtpMed = ProEtpHor / ProEtpQtd
		Endif
	
		if &LogErpTabIsLog = true
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, &LogErpRegCod3, &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEtpMed', '', trim(ProEtpMed.ToFormattedString()), &LogErpRegGUID )
		Endif
		
		ProEtpDtaIni = &ProEtpDtaIni
		ProEtpDtaFin = &ProEtpDtaFin
	EndNew

	
EndFor

Commit
]]></Source>
