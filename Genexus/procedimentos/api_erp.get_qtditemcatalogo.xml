      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

If &IsAcessoConcedido = true //Acesso concedido
	
	&sdtRetornoWbsEtc.c4 = ''
	&PedQtd.SetEmpty()
	&PedVlrItm.SetEmpty()
	//valor PedidoProduto
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&Varchar = trim(PedVlrLiq.ToFormattedString())
		retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
		&sdtRetornoWbsEtc.c5 = &Varchar
		
		&QtdItens = 0
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where PedQtd > 0
			&QtdItens += 1
		EndFor
		
		&Varchar = trim(&QtdItens.ToFormattedString())
		retiraZerosDepoisVirgulaxCasas.Call(0,&Varchar,&Varchar)
		&sdtRetornoWbsEtc.c6 = &Varchar
		
			
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where EmpCod = &wwpContext.EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			
			&PedQtd += PedQtd
			&PedVlrItm += PedVlrItmComDsc
			
			&sdtRetornoWbsEtc.c4 = PedItmCmp.Trim()
		EndFor
	EndFor
	
	&Varchar = trim(&PedQtd.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(0,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c1 = &Varchar
	
	&Varchar = trim(&PedVlrItm.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c3 += &Varchar
	
	&PedVlrUnt = 0
	if &PedQtd > 0 and &PedVlrItm > 0
		&PedVlrUnt = &PedVlrItm/&PedQtd
	Endif
	
	&Varchar = trim(&PedVlrUnt.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c2 = &Varchar	
	
	
	&sdtRetornoWbsEtc.sts = 'J200'
	
Else
	&sdtRetornoWbsEtc.sts = 'EFKU'
Endif
]]></Source>
