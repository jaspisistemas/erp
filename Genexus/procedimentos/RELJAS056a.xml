      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'LISTAGEM DE CLIENTES'
	print Cabecalho
//	if &CnpjIE = 'S'
//		print TituloCnpj
//	Else
		Print Titulo
//	EndIF
End

For Each 
	Order EmpCod, PesRaz when &Ordenar = 'A'
	Order EmpCod, PesCod when &Ordenar = 'N'
	Order EmpCod, PesEntUfeCod, PesEntCidNom, PesEntBai, PesEntLog  when &Ordenar = 'E'
	
	Where EmpCod = &EmpCod
	Where PesIntVenCod = &PesIntVenCod or PesExtVenCod = &PesIntVenCod when not &PesIntVenCod.IsEmpty()
	Where PesSts = &PesSts when not &PesSts.IsEmpty()
	Where PesUltVenDta >= &PesUltVenDta when not &PesUltVenDta.IsEmpty()
	Where PesUltVenDta <= &PesUltVenDtaDia when not &PesUltVenDtaDia.IsEmpty()
	where PesDtaCad >= &PesDtaCad when not &PesDtaCad.IsEmpty()
	Where PesEntCidCod = &PesEntCidCod When not &PesEntCidCod.IsEmpty()
	Where PesEntUfeCod = &PesEntUfeCod when not &PesEntUfeCod.IsEmpty()
	Where PesCidAreCod = &PesCidAreCod when not &PesCidAreCod.IsEmpty()
	Where RatCod = &RatCod when not &RatCod.IsEmpty()
	Where PesIsCli = True	
	Where PesReg = &PesReg when &PesReg <> 'T'
	Where PesDtaUltCom >= &PesDtaUltCom when not &PesDtaUltCom.IsEmpty()
	
		&PesEntLog = PesEntLogNro
////		if &CnpjIE = 'S'
//			if PesTip = TipoPessoa.JURIDICA
//				&CpfCnpj = PesCnpj
//				&RgIns = PesInsEst
//			Else
//				&CpfCnpj = PesCpf
//				&RgIns = PesRg
//			EndiF
//		
//			Print ClienteCnpj
//		Else
			Print Cliente
	
			
	//EMAIL
	For Each Order EmpCod, PesCod, PesEmlCod
		&Faturamento = ''
		&Comercializacao = ''
		&Financeiro = ''
		
		If PesEmlPed = true
			&Comercializacao = 'X'	
		EndIF
	
		If PesEmlFat = true
			&Faturamento = 'X'
		EndIF
	
		If PesEmlFin = true
			&Financeiro = 'X'
		EndIF
	
		print Email
	EndFor
			
	//TELEFONE
	For Each Order EmpCod, PesCod, PesFonCod
		&TipoFone = PesFonTpo.EnumerationDescription()
		&Operadora = PesFonOpe.EnumerationDescription()
		
		&Contato = trim(PesFonConTip.EnumerationDescription()) + ' - ' + PesFonCon.Trim()
		Print Telefones
		
	EndFor

	Print Traco
EndFor


Footer
	print Rodape
End
]]></Source>
