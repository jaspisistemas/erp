      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//ACHA O PEDIDO
&PedDtaFat.SetEmpty()
For Each ORder EmpCod, FilCod, (PedDtaFat)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedSerItmCod = &SerItmCod
	Where PedSts = Status_PEdido.FECHADO
	Where PedStsFin = Status_Pedido.FECHADO

	&PedDtaFat = PedDtaFat
	Exit
EndFor
	
	
//ATUALIZA SERVICOCLIENTE	
For Each ORder EmpCod, SerItmCod 
	Where EmpCod = &EmpCod
	Where SerItmCod = &SerItmCod
	
	SerItmUltVct = &PedDtaFat
	
	Exit
EndFor


Commit
]]></Source>
