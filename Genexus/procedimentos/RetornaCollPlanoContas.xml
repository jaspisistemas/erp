      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ColPlanCod.Clear()
&auxPlanHie = trim(&PlanHie)+'.'
for Each Order EmpCod, PlanCod
	Where EmpCod = &EmpCod
	Where PlanHie like &auxPlanHie or PlanHie = &PlanHie
	Where PlanAnaSin = 'A'
	&ColPlanCod.Add(PlanCod)
EndFor
]]></Source>
