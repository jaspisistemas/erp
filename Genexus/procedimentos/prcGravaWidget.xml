      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For each Order EmpCod, WidSync, WidPesCod
	
	Where EmpCod = &EmpCod
	Where WidSync = &WidSync
	Where WidPesCod = &PesCod
	
	WidIsSel = &WidIsSel
	
	if WidSync = 'WD_MENSAGENS'
		WidIsSel = true
	Endif
When none
	
	For each Order EmpCod, WidSync
		Where EmpCod = &EmpCod
		Where WidSync = &WidSync
		&widOrd = WidOrd
		Exit
	EndFor
	
	New 
		EmpCod = &EmpCod
		WidSync = &WidSync
		WidPesCod = &PesCod
		
		WidIsSel = &WidIsSel
		if &WidSync = 'WD_MENSAGENS'
			WidIsSel = true
			WidOrdUsr = 3
		Else
			WidOrdUsr = &widOrd
		Endif
	EndNew
EndFor

Commit
]]></Source>
