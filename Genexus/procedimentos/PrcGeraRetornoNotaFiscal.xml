      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 10
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&Percentual = 3
do 'Atualiza'
	
//CLONAR O PEDIDO 
CopiaPedidoCompra_RetornoRemessa.Call(&EmpCod, &FilCod, &PedCod, &LCtCod, &PedCliCod, &Mensagem, &NovoPedCod)

&Percentual = 5
do 'Atualiza'

//LOCALIZAR AS NTOAS EMITIDAS E DIMINUIR QUANTIDADES DO PEDIDO CLONADO.
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
	Where NfeSts = Status_NFe.Autorizada //AUTORIZADA
	Where NfeEntSai = Status_EntradaSaida.Saida //NOTA SAIDA
	Where NfeLctAtuEst = Status_EntradaSaida.Saida
	Where NfeLctGerFin = Status_SimNao.Sim
	Where NfeFin = NotaFinalidade.EmissaoNormal
	Where NfeDtaEms >= &NfeDtaEms 
	Where NfeLctNfeIndPres = '5' //Operacao presencial Fora do estabelecimento	
	
	&IsAchou = false
	For Each Order EmpCod, FilCod, NfeCod, NfeDocRefCod
		Where NfeDocRefNfe like &NfeDocRefNfe
		&IsAchou = true
		Exit
	EndFor

	if &IsAchou = true
		prcAtualizaNotaRetorno.Call(&EmpCod, &FilCod, &NovoPedCod, NfeProCod, NfeProGraCod, NfeProQtd)
	Endif
EndFor

&Percentual = 8
do 'Atualiza'

atualizaTotaisPedido.Call(&EmpCod, &FilCod, &NovoPedCod, 0, 'C')


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub
]]></Source>
