      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	
	//GRAVA LOG
	&TabelaVarchar = 'PRODUTO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&ProCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'NcmCod', trim(toformattedString(NcmCod)), trim(toformattedString(&NcmCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProNcmCest', trim(toformattedString(ProNcmCest)), trim(toformattedString(&ProNcmCest)), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	NcmCod = &NcmCod
	ProNcmCest = &ProNcmCest
	
	ProDtaHorUltMod = now()
	Exit
EndFor

Commit


AtualizaNcmNotas.Call(&EmpCod,&ProCod,&NcmCod, &ProNcmCest)
]]></Source>
