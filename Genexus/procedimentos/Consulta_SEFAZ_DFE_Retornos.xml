      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, ManCod
	Where EmpCod = &EmpCod
	Where ManCod = &NfeCod
	Where ManFilCod = &FilCod
	
	&NfeChv = ManCha
	Exit
EndFor

&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&NfeChv)+'-sit.xml'
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&NfeChv)+'-sit.err'

&File.Source = trim(&Nome_retorno_erro)
If &File.Exists()
	
	&ResultadoAbertura =   DFROpen(&Nome_retorno_erro)    
	Do while dfrnext() = 0 
		&ResultadoAbertura = DFRGTxt(&CampoUnico)
		&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
	EndDo
	&ResultadoAbertura = DFRClose()
	
	&File.Delete()
	
	&Tentativa = 99
	&SolSts = Status_Solicitacao.Falha
	&SolMsg = &conteudo_arquivo
else
	&File.Source = trim(&Nome_retorno_correto)
	If &File.Exists()
		
		&retorno_xml.Open(&Nome_retorno_correto)
		&retorno_xml.ReadType(1,'cStat')
		&NfeAutSts = &retorno_xml.Value
		
		&retorno_xml.ReadType(1,'xMotivo')
		&NfeAutMsg = &retorno_xml.Value
		
		&retorno_xml.ReadType(1,'dhRecbto')
		&NfeAutDatHorRec = &retorno_xml.Value
		
		&retorno_xml.ReadType(1,'nProt')
		&NfeAutNumPro = &retorno_xml.Value
		
		if not &NfeAutSts.IsEmpty()
			&Tentativa = 99
			
			Do Case
				Case &NfeAutSts  = '101' //CANCELADA
					&SolSts = Status_Solicitacao.Finalizada
					AtualizastatusDfe.call(&EmpCod, &FilCod, &NfeCod, &NfeAutSts,Status_NFe.Cancelada, &SolPesCod)
					//					AtualizaNumeroProtocoloNFe.Call('CANCELA_NFE', &EmpCod, &FilCod, &NfeCod, &NfeAutSts, &NfeAutNumLot, &NfeAutNumRec, &NfeAutDatHorRec, &NfeAutMsg, &NfeAutNumPro, &NfeAutDigVal, Status_NFe.Cancelada, &SolPesCod)
					
					//					do 'ArquivoPronto'
					
				Case &NfeAutSts = '100' or &NfeAutSts = '150' //AUTORIZADA
					&SolSts = Status_Solicitacao.Finalizada
					AtualizastatusDfe.call(&EmpCod, &FilCod, &NfeCod, &NfeAutSts,Status_NFe.autorizada, &SolPesCod)
					
				Case &NfeAutSts = '206' //INUTILIZA
					&SolSts = Status_Solicitacao.Finalizada
					AtualizastatusDfe.call(&EmpCod, &FilCod, &NfeCod, &NfeAutSts,Status_NFe.Inutilizada, &SolPesCod)
					
				Case &NfeAutSts in ('205','302', '301') //DENEGADA
					&SolSts = Status_Solicitacao.Finalizada
					AtualizastatusDfe.call(&EmpCod, &FilCod, &NfeCod, &NfeAutSts,Status_NFe.denegada, &SolPesCod)
				Otherwise
					&SolSts = Status_Solicitacao.Falha
			EndCase
			
		EndIf
		&SolMsg = &NfeAutMsg
		&retorno_xml.close()
	EndIf
EndIF

if &SolSts <> Status_Solicitacao.Pendente
	if not &ArquivoPronto.IsEmpty()
		&file.Source = &ArquivoPronto.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

	if not &Nome_retorno_correto.IsEmpty()
		&file.Source = &Nome_retorno_correto.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

	if not &Nome_retorno_erro.IsEmpty()
		&file.Source = &Nome_retorno_erro.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

EndIF


