      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAutorizado = false
&Mensagem.SetEmpty()
If &PesCod > 0
	For each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedVenCod
		Where PesSenfun = &GAMPassword and ( not PesSenfun.IsEmpty() and not PesSenfun.IsNull())
		
			&IsAutorizado = true
	
		exit
	when none
		&Mensagem = 'USUÁRIO/SENHA INVÁLIDOS OU NÃO DEFINIDOS AO VENDEDOR!'
	EndFor
Else
	&IsAutorizado = true
	&Mensagem = 'AUTORIZADO PELO SUPORTE DO SISTEMA!'
EndIf
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
