      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PedVlrUnt = 0
&PedQtdVend = 0
&PedQtdDev_FORMULA = 0
For Each ORder EmpCod, FilCod, PedCod, ProCod, ProGraCod,LctTip
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCodOciRef
	Where PedItmCod = &PedCodOciRefItm when not &PedCodOciRefItm.IsEmpty()
	Where PedQtdDev_FORMULA < PedQtd when &DevPedItmCod = 0
	Where ProCod = &ProCod
	Where ProGraCod = &PrograCod
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where PedStsGer <> Pedido_Gerado.AgruparFaturar and PedStsGer <> Pedido_Gerado.DevolucaoCompra and PedStsGer <> Pedido_Gerado.Interno
	&PedVlrUnt = PedVlrUntComDsc
	&PedQtdVend = PedQtd	
	&PedItmCmp = PedItmCmp
	&PedItmCmpInt = PedItmCmpInt
	&PedItmVenCod = PedItmVenCod
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
