      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
do case
	case &CteVlrRecSer > 0
		&AuxBaseMoeda = &CteVlrRecSer
	case &CteVlrTotPreSer > 0
		&AuxBaseMoeda = &CteVlrTotPreSer
	Otherwise
		&AuxBaseMoeda = &CteImpVbc
EndCAse

For each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	CteVlrRecSer = &CteVlrRecSer
	CteVlrTotPreSer =  &CteVlrTotPreSer
	CtePosPre = &CtePosPre
	CteCfop   = &CteCfop
	CteNatOpe = &CteNatOpe
	CteImpCst = &CteImpCst
	CteImpVbc = &AuxBaseMoeda
	CteImpAliTotTri = &CteImpAliTotTri
	CteImpTriVlrPis = &CteImpTriVlrPis
	CteImpTriVlrCofins = &CteImpTriVlrCofins
	CteImpTriVlrCsll = &CteImpTriVlrCsll
	CteImpTriAliInss = &CteImpTriAliInss
	CteImpTriVlrInss = (&AuxBaseMoeda * (&CteImpTriAliInss*0.01))
	CteImpTriVlrIr =&CteImpTriVlrIr
	CteImpVlrTotTri = ((&CteVlrTotPreSer * CteImpAliTotTri)*0.01)
	
	&CteDesCod = CteDesCod
	do 'getDestinatario'
	
	//Aqui tem que pegar as configuracoes do IBS e CBS
	//retorna Categoria imposto padrao CTE
	RetornaConfSistema.Call(EmpCod, FilCod, domConfSistema.TCon209_ImpostoProdutoCTE, &TCon209_ImpostoProdutoCTE)
	&CImpCatCod = val(&TCon209_ImpostoProdutoCTE)
	if &CImpCatCod.IsEmpty()
		prcDefinePadraoCategoriaImpostoCTE.call(EmpCod, FilCod, &CImpCatCod)
	Endif
	
	&sdtCadastroTabelaImpostoCbs = new()
	&sdtCadastroTabelaImpostoCbs.Tipo = 'CTE'
	&sdtCadastroTabelaImpostoCbs.EmpCod = EmpCod
	&sdtCadastroTabelaImpostoCbs.CImpTbFilCod = FilCod
	&sdtCadastroTabelaImpostoCbs.CImpLctCod = CteLctCod
	&sdtCadastroTabelaImpostoCbs.CImpOriUfeCod = CteRemUfe
	&sdtCadastroTabelaImpostoCbs.CImpDstUfeCod = CteDesUfe
	&sdtCadastroTabelaImpostoCbs.CImpGruImpCod = &ImpGruImpCod
	&sdtCadastroTabelaImpostoCbs.CImpCatCod = &CImpCatCod
	&sdtCadastroTabelaImpostoCbs.CImpDtaIni = serverdate()
	&sdtCadastroTabelaImpostoCbs.ProCod = 0 //nao tem produto
	&sdtCadastroTabelaImpostoCbs.IsRetornarObs = true //retornar obs
	prcRetornaConfiguracaoImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs)
	
	&sdtImpostoProduto.ProVlrFrt = &AuxBaseMoeda - (CteImpTriVlrIr+CteImpTriAliInss+CteImpTriVlrPis+CteImpTriVlrCofins+CteImpTriVlrCsll)
	 
	//Chamar o Calculador do IBS e CBS
	CalculaImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs, &SdtImpostoProduto)
	
	//Atualizar Valores de IBS e CBS
	CteIbsCST  = &sdtCadastroTabelaImpostoCbs.CImpClsCST
	CteIbsClassTrib = &sdtCadastroTabelaImpostoCbs.CImpClsTrib
	//CteIbsIndDoa
	CteIbsBas = &sdtImpostoProduto.ValorBaseIbsCbs
	CteIbsUfTax  = &sdtCadastroTabelaImpostoCbs.IbsUfTax
	CteIbsUfTaxDif = &sdtCadastroTabelaImpostoCbs.NfeIbsUfPerDif
	CteIbsUfVlrDif = &SdtImpostoProduto.NfeIbsUfVlrDif
	CteIbsUfTaxRed = &sdtCadastroTabelaImpostoCbs.CltClsRedIbs
	CteIbsUfTaxEfe = &sdtCadastroTabelaImpostoCbs.IbsUfTaxEfe
	CteIbsUfVlr = &SdtImpostoProduto.ValorIbsUf
	CteIbsMunTax = &sdtCadastroTabelaImpostoCbs.IbsMunTax
	CteIbsMunTaxDif = &sdtCadastroTabelaImpostoCbs.NfeIbsMunPerDif
	CteIbsMunTaxRed = &sdtCadastroTabelaImpostoCbs.CltClsRedIbs
	CteIbsMunTaxEfe = &sdtCadastroTabelaImpostoCbs.IbsMunTaxEfe
	CteIbsMunVlr = &SdtImpostoProduto.ValorIbsMun
	CteIbsMunVlrDif = &SdtImpostoProduto.NfeIbsMunVlrDif
	
	CteIbsVlrTot = &SdtImpostoProduto.ValorIbsMun + &SdtImpostoProduto.ValorIbsUf
	
	CteCbsTax = &sdtCadastroTabelaImpostoCbs.IbsUnTax
	CteCbsTaxDif = &sdtCadastroTabelaImpostoCbs.NfeCbsPerDif
	CteCbsTaxRed = &sdtCadastroTabelaImpostoCbs.CltClsRedCbs
	CteCbsTaxEfe = &sdtCadastroTabelaImpostoCbs.IbsUnTaxEfe
	
	CteCbsVlrDif = &SdtImpostoProduto.NfeCbsVlrDif
	CteCbsVlr = &SdtImpostoProduto.ValorCbs
	
	CteTribRegCst = &sdtCadastroTabelaImpostoCbs.NfeRegIbsSit
	CteTribRegClassTrib = &sdtCadastroTabelaImpostoCbs.NfeRegIbsClassTrib
	CteTribRegUfTax = &sdtCadastroTabelaImpostoCbs.NfeRegIbsUfeTaxEfe
	CteTribRegUfVlr = &SdtImpostoProduto.NfeRegIbsUfeVlr
	CteTribRegMunTax = &sdtCadastroTabelaImpostoCbs.NfeRegIbsMunTaxEfe
	CteTribRegMunVlr = &SdtImpostoProduto.NfeRegIbsMunVlr
	CteTribRegUnTax = &sdtCadastroTabelaImpostoCbs.NfeRegCbsTaxEfe
	CteTribRegUnVlr = &SdtImpostoProduto.NfeRegCbsVlr
	
	If &IsGeraDuplicatas = true
		CtePosDup = Status_SimNao.Sim
		CteStsFin = Status_Financeiro.ABERTO
	Else
		Do 'DeletaDuplicatas'
		If &Mensagem.Trim().IsEmpty()
			CtePosDup = Status_SimNao.Nao
			CteStsFin = Status_Financeiro.CANCELADO
		EndIf
	EndIf

	Do case
		Case &CteImpCst = ClassificacaoCst.Outros or &CteImpCst = ClassificacaoCst.OutraUF
			CteImpAli = &CteImpAli
			CteImpVlr = (&AuxBaseMoeda * (&CteImpAli*0.01))
			CteImpVlrCre = &CteImpVlrCre
			CteImpPerRed = &CteImpPerRed
			CteConSplNac = Status_SimNao.Nao
		Case &CteImpCst = ClassificacaoCst.Normal
			CteImpAli = &CteImpAli
			CteImpVlr = (&AuxBaseMoeda * (&CteImpAli*0.01)) 
			CteConSplNac = Status_SimNao.Nao
		Case &CteImpCst = ClassificacaoCst.Reduzida
			CteConSplNac = Status_SimNao.Nao
		Case &CteImpCst = ClassificacaoCst.Substituicao
			CteConSplNac = Status_SimNao.Nao
			CteImpVstRet = (CteImpVbcRet * (&CteImpAliRet*0.01)) 
//			CteImpVbcRet = &CteImpVbcRet
			CteImpAliRet = &CteImpAliRet
			CteImpVlrCre = &CteImpVlrCre
			
		Case &CteImpCst = ClassificacaoCst.Simples
			CteConSplNac = Status_SimNao.Sim
			CteImpAli = 0
			CteImpVlr = 0
			CteImpVlrCre = 0
			CteImpPerRed = 0
	EndCase
	
	exit
EndFor


commit

AtualisaBaseCalculoCte.Call(&EmpCod,&FilCod,&CteCod)


Sub 'DeletaDuplicatas'
	DeletarDuplicatasCteAutomatico.Call(&EmpCod, &FilCod, &CteCod,&Mensagem)
EndSub

Sub 'getDestinatario'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CteDesCod
		&ImpGruImpCod = PesGruImpCod
		exit
	EndFor
EndSub
]]></Source>
