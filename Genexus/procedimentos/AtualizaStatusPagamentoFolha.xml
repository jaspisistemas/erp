      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//ATUALIZA STATUS DE TODAS FOLHAS DO ANO/MES

For each order EmpCod,FPagCod
	where EmpCod = &EmpCod
	where FPagAno = &FPagAno
	where FPagMes = &FPagMes
	
	&CountAberto = 0
	&CountFechado = 0
	For each order EmpCod,FPagCod, FPagCtaCod
		if FPagCtaMovCod.IsEmpty() or FPagCtaMovCod.IsNull() 
			&CountAberto += 1
		else //que tem movimento
			&CountFechado += 1
		EndIF
	EndFor

	Do case
		case &CountAberto = 0 and &CountFechado > 0 //só tem fechado
			FPagSts = Status_Folha.Pago
		case &CountFechado > 0 and &CountAberto > 0  //tem aberto e fechado
			FPagSts = Status_Folha.PagoParcial
		otherwise
			FPagSts = Status_Folha.Aberto
	EndCase	
EndFor


Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
