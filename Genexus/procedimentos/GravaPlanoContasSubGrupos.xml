      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AuxPlanHie = &PLanHie.Trim() + '.'

For Each Order EmpCod, PlanCod
	Where EmpCod = &EmpCod
	Where PlanHie like &AuxPlanHie
	
	PlanoCategoriaPaiHierarquico.Call(EmpCod, PlanCod, PlanHie, &NewPlanHie, &PlanNomCmp, &PlanPaiCod, &PlanPaiHie, &IsErroHierarquia, &AntPlanCatTip)
	
	if &IsErroHierarquia = false
		
		PlanHiePadL_Formata.Call(PlanHie, &PlanHiePadL)
		RetornaCodigoComVirgula.Call(PlanHie, &PlanHieVirg)
		
		&PlanNomCmp = &PlanNomCmp.Trim() + ' | ' + PlanNom
		if &PlanNomCmp.Length() > 100
			&PlanNomCmp = Substr(&PlanNomCmp,1, 97) + '...'
		EndIf
	
		PlanNomCmp = &PlanNomCmp 
		PlanPaiCod = &PlanPaiCod
		PlanPaiHie = &planPaiHie
		PlanHieVirg = &PlanHieVirg
		
		PlanCodNomVir = PlanHie.Trim() + ' ' + &PlanNomCmp.trim() + ' ' + &PlanHieVirg
		PlanHiePadL = &PlanHiePadL
	EndIf
EndFor

Commit


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
