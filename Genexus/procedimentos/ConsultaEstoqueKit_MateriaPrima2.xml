      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&QtdRecProQtd = 1

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	where ProCod = &ProCod
	Where ProTipDef in (Definicao.FABRICADO, Definicao.SUBPRODUTO, Definicao.SEMIACABADO)

	&ProQtdPro = ProQtdPro
	&AuxProRecUltCod = ProRecUltCod

	For Each Order EmpCod,ProCod,RecItmCod
		If &ProQtdPro <> 0 and RecProQtd <> 0
			
			retornaProdutoEstoque.Call(EmpCod, RecProCod, &ProEstProCod)
			RetornaQuantidadeEstoque.Call(EmpCod, &FilCod, &ProEstProCod, 1, &EstCom, &EstVen, &EstPrd, &EstQtd, &EstSdo, &EstSug, &EstQtdFis)
			
			if &EstQtd > 0 and RecProQtdUnt > 0
				&EstQtdConProd = round(&EstQtd / RecProQtdUnt, 0)
			Else
				&EstQtdConProd = 0
			Endif
		
			&RecProCod = &ProEstProCod
			&RecProNom = RecProNom
			
			&RecProQtdUnt = (RecProQtdUnt * &QtdRecProQtd) * &EstFab
			&QuantidadeNecessaria = &RecProQtdUnt
			
			&SubProduto = 'N'
			If (RecProTipDef = Definicao.SUBPRODUTO) or (RecProTipDef = Definicao.SEMIACABADO) or (RecProTipDef = Definicao.FABRICADO) //JDF - ELIANDRO - (RecProTipDef = Definicao.FABRICADO) - Nao Considerar no autoalimentar como um subproduto
				&SubProduto = 'S'
			EndIf		
		
			&RecProVlrCusUnt = RecProVlrCusUnt
					
			
			RetornaQuantidadePedido.Call(EmpCod, &FilCod, &PedCod, &EntPedCod, &ProEstProCod, 1, &Pedqtd)
			&EstQtd += &Pedqtd
			If &EstQtd > 0
				do 'DiminuiSdoSdt'
			EndIF
			
			&QuantiaUtilizada = &RecProQtdUnt
			&quantidadeInicial = &RecProQtdUnt
			//If &EstQtd > 0
				If &EstQtd >= &RecProQtdUnt
					&QuantidadeNecessaria = 0
					&RecProQtdUnt = 0
					do 'addSdt'
				Else
					&QuantiaUtilizada = 0
					if &EstQtd > 0
						&QuantiaUtilizada = &EstQtd
						&RecProQtdUnt = &RecProQtdUnt - &EstQtd
					EndiF
				
					If &SubProduto <> 'S' 
						&QuantiaUtilizada = &quantidadeInicial
					Endif
				
					&QuantidadeNecessaria = &RecProQtdUnt
				
					do 'addSdt'
				EndIF
			//EndIf
			&quantidadeInicial = 0
			&QuantiaUtilizada = 0
			//&QuantidadeNecessaria = &RecProQtdUnt
		
			If &QuantidadeNecessaria > 0
				ConsultaEstoqueKit_MateriaPrima3.Call(&PedCod, &EntPedCod, EmpCod, &FilCod, &ProEstProCod, &QuantidadeNecessaria, &ProQtdPro, &ProRecUltCod, &sdtMateriaPrima)
				
				If &ProRecUltCod = 0
					&SubProduto = 'N'
					do 'addSdt'
				EndIF
			EndIF
		EndIF
	EndFor
EndFor

Sub 'DiminuiSdoSdt'
	For &sdtMateriaPrimaItem in &sdtMateriaPrima
		if &sdtMateriaPrimaItem.ProCod = &RecProCod
			&EstQtd -= &sdtMateriaPrimaItem.QuantiaUtilizada
			Exit
		EndIf
	EndFor
EndSub

Sub 'AddSdt'
	&IsAchou = false
	For &sdtMateriaPrimaItem in &sdtMateriaPrima
		if &sdtMateriaPrimaItem.ProCod = &RecProCod
			&sdtMateriaPrimaItem.QuantiaUtilizada += &QuantiaUtilizada //(&QuantiaUtilizada * &QtdRecProQtd) * &EstFab
			&sdtMateriaPrimaItem.QuantidadeInicial += &quantidadeInicial //SABER QUANTO IRIA PRECISAR NO INICIO
			&IsAchou = true
			Exit
		EndIf
	EndFor
	
	If &IsAchou = false
		&sdtMateriaPrimaItem  = NEW()
		&sdtMateriaPrimaItem.ProCod = &RecProCod
		&sdtMateriaPrimaItem.ProGraCod = 1
		&sdtMateriaPrimaItem.ProNom = &RecProNom
		&sdtMateriaPrimaItem.SubProduto = &SubProduto
		&sdtMateriaPrimaItem.RecProVlrCus = &RecProVlrCusUnt
		&sdtMateriaPrimaItem.EstQtd = &EstQtd
		&sdtMateriaPrimaItem.EstSdo = &EstQtd
		&sdtMateriaPrimaItem.ProEstProCod = &ProEstProCod
		&sdtMateriaPrimaItem.QuantiaUtilizada = &QuantiaUtilizada //(&QuantiaUtilizada * &QtdRecProQtd) * &EstFab
		&sdtMateriaPrimaItem.QuantidadeInicial = &quantidadeInicial //SABER QUANTO IRIA PRECISAR NO INICIO
		//&sdtMateriaPrimaItem.EmbUnd = UPPER(RprEmbUnd)
		&sdtMateriaPrimaItem.EstQtdConProd = &EstQtdConProd
		&sdtMateriaPrima.Add(&sdtMateriaPrimaItem)
	Endif
EndSub

]]></Source>
