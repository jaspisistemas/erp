<Object parentGuid="9bbd5271-0e6e-4b96-abef-fa6edd198f06" user="SRVORDIG\Administrador" versionDate="2024-01-10T01:45:02.0000000Z" lastUpdate="2024-01-10T01:15:38.0000000Z" checksum="185f3c6ca24d49d169b3c20ebc30593d" fullyQualifiedName="GravaRetornoCCeCte" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="cef50f47-d25f-4d65-b5b5-f19c8c8cf3c4" name="GravaRetornoCCeCte" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Grava Retorno CCe Cte" parent="ComunicaNFe" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, CteCod, CteCCeCod
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteCCeCod = &CteCceCod
	
    CteCCeStat   = &CteCCeStat
    CteCCexMotivo = &CteCCexMotivo
    CteCCeProt    = &CteCCeProt
	
    If &CteCCeStat in ('135', '136', '573','631')//CCe AUTORIZADA
        CteCCeSts = Status_NFe.Autorizada
    EndIF

	Exit
EndFor

commit

If &CteCCeStat in ('135', '136', '573','631')//CCe AUTORIZADA
	For Each Order EmpCod, FilCod, CteCod, CteCCeCod //CANCELA TODAS AS OUTRAS CARTAS.
		where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteCCeCod <> &CteCceCod
	    CteCCeSts = Status_NFe.Cancelada
	EndFor
EndiF

commit
]]></Source>
