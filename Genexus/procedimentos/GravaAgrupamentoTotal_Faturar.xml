<Object parentGuid="8da77125-38dc-420b-82a4-3656faad838d" user="WIN-JEAN\jean.fae" versionDate="2023-06-15T18:37:30.0000000Z" lastUpdate="2023-06-14T20:39:33.0000000Z" checksum="22a3d5c596d15f6c7e622d8cb2df1b91" fullyQualifiedName="GravaAgrupamentoTotal_Faturar" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="9eb0140d-5759-410c-b91d-2c2929e9ecf3" name="GravaAgrupamentoTotal_Faturar" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Grava Agrupamento Total Faturar" parent="AgruparPedido" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For &sdtPedidosItem in &sdtPedidos
	if &sdtPedidosItem.Localizado = 'N'
		&Index = &sdtPedidos.IndexOf(&sdtPedidosItem)
		&sdtPedidos.Remove(&Index)
	Endif
EndFor

//Pedido Destino
&DestinoPedCod = 0
&PedVlrLiq = 0
&PedVlrFrt = 0

&PedObsNfe = 'NOTA REF. OS PEDIDOS: '
&Cidade = ''
For &sdtPedidosItem in &sdtPedidos
	if &sdtPedidosItem.Localizado <> 'N'
		if &DestinoPedCod = 0
			For Each Order EmpCod, FilCod, PedCod
				Where EmpCod = &sdtPedidosItem.EmPCod
				Where FilCod = &sdtPedidosItem.FiLCod
				Where PedCod = &sdtPedidosItem.PedCod
				
				&destinoFilCod = FilCod
				&EmpCod = EmpCod
				
				//ADICIONA CAMPOS ALTERADOS
				&sdtGravaPedido.PedCliCod = PedCliCod
				&sdtGravaPedido.LctCod = LctCod
				
				&sdtGravaPedido.PedDtaEms = Serverdate()
				&sdtGravaPedido.TabCod = TabCod
				&sdtGravaPedido.TabPrmCod = TabPrmCod
				
				&sdtGravaPedido.TabColCod = TabColCod
				
				//TRANSPORTE
				&sdtGravaPedido.PedTraRedCod = PedTraRedCod
				&sdtGravaPedido.PedTipFrt = PedTipFrt
				
				&sdtGravaPedido.PedTraSaiCod = PedTraRedCod
				&sdtGravaPedido.PedTipSaiFrt = PedTipFrt
				
				//FROM JSON NAO MUDAR
				&sdtGravaPedido.PedObsAna = &sdtPedidos.ToJson()
				
				&sdtGravaPedido.PedFatFilCod = PedFatFilCod
				
				&sdtGravaPedido.PedPrpCod = PedPrpCod
				
				&sdtGravaPedido.PedStsDigBlk = false
				&sdtGravaPedido.PedStsGer = Pedido_Gerado.AgruparFaturar
				
				//PROC, GRAVA PEDIDO
				GravaPedidoVenda.Call(TrnMode.Insert, EmpCod, FilCod, &DestinoPedCod, &sdtGravaPedido, &FunPesCod, &WwpContextUserName)
				
				Exit
			EndFor
			
			AtualizaEstoqueGerencialCompra.Call(&EmpCod, &destinoFilCod, &DestinoPedCod, &PedDtaFat, 1,  Status_Pedido.CANCELADO)
			
			&PedObsNfe += trim(str(&sdtPedidosItem.PedCod))
		Else
			&PedObsNfe += ', ' + trim(str(&sdtPedidosItem.PedCod))
		Endif
		
		if &sdtPedidosItem.PedCliCidCod > 0
			if &CidCod(&sdtPedidosItem.PedCliCidCod) = 0
				&Cidade += ', '+ trim(&sdtPedidosItem.PedCliCidNom)
				&CidCod(&sdtPedidosItem.PedCliCidCod) = 1
			EndIf
		Endif
	   
		&PedVlrLiq += &sdtPedidosItem.PedVlrLiq
		&PedVlrFrt += &sdtPedidosItem.PedVlrFrt
		
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where EmpCod = &sdtPedidosItem.EmPCod
			Where FilCod = &sdtPedidosItem.FiLCod
			Where PedCod = &sdtPedidosItem.PedCod
			where PedQtd > 0
			
			&sdtProdutoLote.Clear()
			RetornaQuantosLotesAdicionados.Call(EmpCod, FilCod, PedCod, PedItmCod, &InformacaoLotes, &sdtProdutoLote)
			
			GravaItemPedidoCompra_Agrupamento.Call(&EmpCod, &destinoFilCod, &DestinoPedCod, &PedItmCod, ProCod, ProGraCod, PedQtd, PedVlrUntComDsc, 0, 0, 0, 0, 0, PedQtdEmb, PedProEmbQtd, PedItmCmp, &sdtProdutoLote, &inseridoMensagem, &AlteradoMensagem, &WwpContextUserName)
			
		EndFor
	Endif
EndFor

AtualizaTotaisPedido.Call(&EmpCod, &destinoFilCod, &DestinoPedCod, 0, 'C')

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmPCod
	Where FilCod = &destinoFilCod
	Where PedCod = &DestinoPedCod
	
	&PedVlrDscGlb.SetEmpty()
	&PedVlrOut.SetEmpty()
	Do Case
		CAse &PedVlrLiq < PedVlrLiq
			&PedVlrDscGlb = PedVlrLiq - &PedVlrLiq
		
		Case &PedVlrLiq > PedVlrLiq
			&PedVlrOut = &PedVlrLiq - PedVlrLiq
	EndCase
	
	if &PedVlrFrt >= &PedVlrOut and &PedVlrOut > 0
		PedFrtFix = &PedVlrOut
	Else
		PedVlrOut = &PedVlrOut
	Endif

	PedVlrDscGlb = &PedVlrDscGlb
	PedObsNfe = &PedObsNfe.Trim() + &Cidade.Trim()
	
	Exit
EndFor

Commit

if &PedVlrDscGlb > 0 or &PedVlrOut > 0
	AtualizaTotaisPedido.Call(&EmpCod, &destinoFilCod, &DestinoPedCod, 0, 'C')
Endif
]]></Source>
