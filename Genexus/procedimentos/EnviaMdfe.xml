      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&LogGUID = GUID.NewGuid()

//csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.ServicePointManager.SecurityProtocol;

&EmlSts = Status_Solicitacao.Pendente
&EmlTip = TipoContaEmail.Email_Faturamento

For Each Order EmpCod, EmlTip, EmlCod
	Where EmpCod = &EmpCod
	Where EmlTip = &EmlTip
	Where EmlCod = &EmlCod
	
	&MdfeCod = EmlSeqCod
	
	do 'Filial'
	Do 'Login'
	
	&PesCod = EmlPesCod
	do 'Funcionario'
		
	do 'Mdfe'

	&EmlAss = EmlAss
	&EmlObs = EmlObs
    Exit
EndFor


	//=====Insere o assunto da mensagem=====
	&mensagem = 'Destinatarios'
	&Destinatarios.Clear()
	For Each Order EmpCod, EmlTip, EmlCod, EmlItmCod
		Where EmpCod = &EmpCod
		Where EmlTip = &EmlTip
		Where EmlCod = &EmlCod
		&mensagem += '; ' + trim(EmlUrl)
		//Destinatário de email
		
		&Destinatarios.Add(EmlUrl)
	EndFor

	do 'mensagem'	
	&mensagem = 'Anexos: '
	
	if not &MdfeArqXml.IsEmpty()
		geraPdfMDFe.Call(&EmpCod, &EmlFilCod, &MdfeCod, &UrlVirtual, &URlFisico)
		
	    //ADICIONA ARQUIVO
		&Attachments.Clear()
		
		&File.Source = &URlFisico //PDF
		If &File.Exists()
			&mensagem += ' ' + trim(&URlFisico)
			do 'mensagem'
			//=====Adiciona Anexo a partir de um caminho do servidor=====
			&Attachments.Add(&URlFisico)
			GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &URlFisico)
		EndIF
	EndIF	
	//XML
		&File.Source = &PastaAutorizadas
		If &File.Exists()
			&mensagem += '; ' + trim(&PastaAutorizadas)
		 	&Attachments.Add(&PastaAutorizadas)
			GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &PastaAutorizadas)
		Else
			GravaXmlMdfeDoBancoDados.Call(&EmpCod, &EmlFilCod, &EmlSeqCod, &sdtConfiguracoesPasta)
			&File.Source = &PastaBancoDados
			If &File.Exists()
				&mensagem += '; ' + trim(&PastaBancoDados)
				do 'mensagem'
				&Attachments.Add(&PastaBancoDados)	
				GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &PastaBancoDados)
			EndIF
		endif				
	
	
	do 'PreencheHTML'
	
&Result = &JASPI_enviaEmail.SendEmailSafeJson(&HostVarchar, &PortNumeric, &UserNameVarchar, &EmpEmlSen, &imapHost, &imapPort, &imapSsl, &FilRaz, &AddressVarchar, &FunEmailContato, &FilRaz, &Destinatarios, &EmlAss, &Obs, &Attachments, true)
	
&EmailResult.FromJson(&Result)

If &EmailResult.Success = true
    // Marca como enviado
	&EmlMsg = 'Enviado com Sucesso!'
	&Tentativa = 99
	&EmlSts = Status_Solicitacao.Finalizada
Else
	&EmlMsg = &EmailResult.ErrorCode + " - " + &EmailResult.Message
	&Tentativa = 99
	
	&EmlSts = Status_Solicitacao.Falha
EndIf


Sub 'Mdfe'
	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &EmlFilCod
		Where MDFeCod = &MdfeCod
		&MdfeSer = MDFeSer
		&MdfeNum = MDFeNum
		&auxMdfeNum = MDFeNum
		&MdfeChv = MDFeChv
		&PastaDanfeNota = str(year(MDFeDtaEms),4,0)+padl(trim(str(month(MDFeDtaEms),2,0)),2,'0')
		&MdfeArqXml = MDFeArqXml
		
		&AnoMes = str(year(MDFeDtaEms),4,0)+padl(trim(str(month(MDFeDtaEms),2,0)),2,'0')
		&PastaAutorizadas = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "Autorizados\" + &AnoMes.trim() + "\MDFe" + &MdfeChv.Trim() + '-procMDFe.xml'
		&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\" + MDFeChv.Trim() + '-jaspi.xml'
		
		Exit
	EndFor
EndSub

Sub 'Filial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &EmlFilCod
		
	 	&FilRaz = iif(FilFan.IsEmpty() or FilFan.IsNull(), FilRaz,FilFan)
		&FilFonNum = FormataFONE.Udp(FilFonNum)
		Exit
	EndFor
EndSub

Sub 'login'
	For Each Order EmpCod, EmpEmlCod
		Where EmpCod = &EmpCod
		Where EmpEmlTip = &EmlTip
		
		If EmpEml = 'nao_responda@jaspi.com.br' or EmpEml = 'nao.responda.jaspi@gmail.com' //adiciona a mensagem dados do remetente
			&EmpEmlCod = EmpEmlCod
			do 'EmailPadrao'
		Else
			&AddressVarchar = EmpEml
			//&FilRaz
			&AuthenticationNumeric = EmpEmlAut
			&SecureNumeric 		= EmpEmlSec
			&TimeoutNumeric        = 600
			&HostVarchar 			= EmpEmlHos
			&UserNameVarchar 		= EmpEmlUsr
			&EmpEmlSen 		= DecryptSenhaEmail.Udp(EmpCod, EmpEmlCod, EmpEml)
			&PortNumeric 			= EmpEmlPor
			&imapHost = EmpEmlImapHos
			&imapPort = EmpEmlImapPor
			&imapSsl = EmpEmlImapSsl
		EndIF
		
		Exit
	When None
		GravaRemetentePadrao.Call(&EmpCod, &EmlTip, &EmpEmlCod)
		do 'EmailPadrao'
	EndFor
EndSub

sub 'EmailPadrao'
	EmailPadrao.call(&AddressVarchar, &AuthenticationNumeric, &SecureNumeric, &TimeoutNumeric, &HostVarchar, &UserNameVarchar, &PortNumeric, &imapHost, &imapPort, &ImapSSl)
	&EmpEmlSen = DecryptSenhaEmail.Udp(&EmpCod, &EmpEmlCod, &AddressVarchar)
		
EndSub

sub 'PreencheHTML'
	
	&Obs =  '<html > '
	&Obs +=  ' <head> '
	&Obs +=  ' <meta http-equiv="Content-Type" content="text/html; charset=utf-8" /> '
	&Obs +=  ' <style type="text/css"> '
	&Obs +=  ' <!-- '
	&Obs +=  ' .A2B {	color: #900; '
	&Obs +=  ' } '
	&Obs +=  ' body,td,th,p { '
	&Obs +=  ' font-size: 13px; '
	&Obs +=  ' color: #000; '
	&Obs +=  ' } '
	&Obs +=  ' body { '
	&Obs +=  ' background-color: #F0F0F0; '
	&Obs +=  ' } '
	&Obs +=  ' a:link { '
	&Obs +=  ' color: #069; '
	&Obs +=  ' text-decoration: none; '
	&Obs +=  ' } '
	&Obs +=  ' a:visited { '
	&Obs +=  ' text-decoration: none; '
	&Obs +=  ' color: #069; '
	&Obs +=  ' } '
	&Obs +=  ' a:hover { '
	&Obs +=  ' text-decoration: underline; '
	&Obs +=  ' } '
	&Obs +=  ' a:active { '
	&Obs +=  ' text-decoration: none; '
	&Obs +=  ' } '
	&Obs +=  ' #A1A { '
	&Obs +=  ' font-size: 22px; '
	&Obs +=  ' } '
	&Obs +=  ' .A3A { '
	&Obs +=  ' color: #069; '
	&Obs +=  ' } '
	&Obs +=  ' --> '
	&Obs +=  ' </style> '
	&Obs +=  ' </head> '
	
	&Obs +=  ' <body> '
	
	&Obs +=  ' <p>Manifesto Eletrônico de Documentos enviado por: '+trim(&FilRaz)
	&Obs +=  ' <p> Nome de Contato: '+ trim(&FunNom) +'<br/> '
	
	if not &FunEmailContato.IsEmpty()
		&Obs +=  ' E-mail de Contato: <a href="mailto:'+ trim(&FunEmailContato) +'">'+ trim(&FunEmailContato) +'</a><br/> '
	EndIF

	if not &FilFonNum.IsEmpty()
		&Obs +=  ' Fone de Contato: '+ trim(&FilFonNum)
	EndIF

	For Each Order EmpCod, FilCod, MDFeCod
		Where EmpCod = &EmpCod
		Where FilCod = &EmlFilCod
		Where MDFeCod = &MdfeCod
		
		&Obs +=  '<p>'
		For Each Order EmpCod, FilCod, MDFeCod
				&Obs +=  'Tração: '+ trim(MDFeVeiPla)+'<br/>'
		EndFor
	
		For Each Order EmpCod, FilCod, MDFeCod
				&Obs +=  'Reboque: '+ trim(MDFeRebPla)+'<br/>'
		EndFor	
		
		For Each Order EmpCod, FilCod, MDFeCod
			&MDFeMotNom = MDFeMotCpf+'-'+trim(MDFeMotNom)
			&Obs +=  'Motorista: '+ trim(&MDFeMotNom)+'<br/>'
		EndFor
	
		&Obs +=  '</p>'
	EndFor


	&Obs +=  ' <p>#Essa mensagem foi enviada por <a href="http://www.jaspi.com.br">JASPI - Soluções em Software</a>, <span class="A2B">não utilize a opção responder o e-mail.</span>#<br/> '
	&Obs +=  ' -------------------------------------------------------------------------------------------------------------------</p>'
	
	If not &EmlObs.IsEmpty()
		&Obs += ' <ul> '
		&Obs +=  ' <li id="A1A">    <strong>'+trim(&EmlObs)+'</strong></li> '
		&Obs += ' </ul> '
		&Obs +=  ' <p>-------------------------------------------------------------------------------------------------------------------</p> '
	EndIF
	
	&Obs +=  ' <p>Prezado cliente,</p> '
	&Obs +=  ' <blockquote> '
	&Obs +=  ' <p>Você está recebendo o Manifesto Eletrônico de Documentos número '+ trim(toformattedString(&auxMdfeNum)) +', série ' +  padl(trim(str(&MdfeSer)), 3, '0')  + ' de ' +trim(&FilRaz)+ 
	'. Além disso, junto com a mercadoria seguirá o DAMDFE (Documento Auxiliar do Manifesto Eletrônico de Documentos), impresso em papel que acompanha o transporte das mesmas. '
	&Obs +=  ' <br/>Anexo à este e-mail você está recebendo também o arquivo XML do Manifesto Eletrônico de Documentos. Este arquivo deve ser armazenado eletronicamente por sua empresa pelo prazo de 05 (cinco) anos, conforme previsto na legislação tributária (Art. 173 do Código Tributário Nacional e § 4º da Lei 5.172 de 25/10/1966). '
	&Obs +=  ' <br/>O DAMDFE em papel pode ser arquivado para apresentação ao fisco quando solicitado. Todavia, se sua empresa também for emitente de MDF-e, o arquivamento eletrônico do XML de seus fornecedores é obrigatório, sendo passível de fiscalização. '
	&Obs +=  ' <br/>Para se certificar que este MDF-e é válido, queira por favor consultar sua autenticidade no site nacional do projeto MDF-e <a href="https://dfe-portal.svrs.rs.gov.br/Mdfe/consulta"> (dfe-portal.svrs.rs.gov.br) </a>, utilizando a chave de acesso contida no DAMDFE.</p> '
	&Obs +=  ' </blockquote> '
	&Obs +=  ' <p> Atenciosamente, '
	&Obs +=  ' <br/> '
	&Obs +=  trim(&FilRaz)+ '.</p> '
	&Obs +=  ' <p>Descrição dos anexos: '
	
	&arquivoXML = &MdfeChv.Trim() + '-procMDFe.xml'
	&ArquivoPDF = &MdfeChv.Trim() + '.pdf'
	&Obs +=  ' <br/>- <span class="A3A">' + trim(&arquivoXML) + '</span> - Esse arquivo é o próprio Manifesto Eletrônico de Documentos, que deve ser guardada pelo período de 05 anos. Ele contém todas as informações do emitente, Remetente, Destinatário, Tomador, Tributação, etc. Esse arquivo, além de guardado, deve ser enviado para o setor de contabilidade. <br/> '
	&Obs +=  ' - <span class="A3A">' + trim(&ArquivoPDF) + '</span> - DAMDFE é o Documento Auxiliar do Manifesto Eletrônico de Documentos, utilizado para acompanhar o trânsito da mercadoria. É uma representação gráfica simplificada do Conhecimento de Transporte Eletrônico, em papel comum e em via única.</p> '
	&Obs +=  ' <p>-------------------------------------------------------------------------------------------------------------------<br/>#Essa mensagem foi enviada por <a href="http://www.jaspi.com.br">JASPI - Soluções em Software</a>, <span class="A2B">não utilize a opção responder o e-mail.</span>#</p> '
	&Obs +=  ' </body> '
	&Obs +=  ' </html> '
EndSUb

Sub 'Mensagem'
	msg(&mensagem  + ' Hora: ' + serverTime(), status)
EndSub

Sub 'Funcionario'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&FunNom = PesRaz
		
		For Each Order EmpCod, PesCod, PesEmlCod
			&FunEmailContato = PesEml
			Exit
		EndFor
		
		Exit
	EndFor
EndSub



Sub 'Exception_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXexceptionType',&GXexceptionType)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionDetails',&GXExceptionDetails)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionStack',&GXExceptionStack)
Endsub

Sub 'Error_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &Err',&Err.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBErr',&gxDBErr.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &GxDbSqlState',&GxDbSqlState)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBTxt',&gxDBTxt)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxOper',&gxOper)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrTbl',&gxErrTbl)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrOpt',&gxErrOpt.ToFormattedString())
Endsub
