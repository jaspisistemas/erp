      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//OK//Niv 1 = Não deleta a capa nem os itens
//OK//Niv 2 = deleta tudo e altera sts da duplicata de volta pra ativo ou em_remessa



For each order EmpCod, DesCod , DesDupItmCod
	where EmpCod = &EmpCod
	where DesCod = &DesCod
	&DesCreCod = DesCreCod
	&DesFilCod = DesFilCod
	
	CancelarDesconto.Call(EmpCod,DesFilCod,DesCreCod,DesCod)
	
	IF &Niv = 2 //só niv 2 deleta DescontoDuplicata
		Delete
	EndIf
EndFor

Commit

For each order EmpCod, DesCod
	where EmpCod = &EmpCod
	where DesCod = &DesCod
	&DesMovCodCre = DesMovCodCre
	&DesMovCodTxa = DesMovCodTxa
	IF &Niv = 2 //só niv 2 deleta Desconto
		delete
	else //se for niv 1 sts = aberto pra editar
		DesSts = Status_AbertoFechado.Aberto
	EndIf
	exit
EndFor
Commit

For Each Order EmpCod,MovCod
	Where EmpCod = &EmpCod
	Where MovCod = &DesMovCodCre or MovCod = &DesMovCodTxa
	
	For each Order EmpCod,MovCod,MovItmCod
		MovItmSts = Status_Caixa.Cancelado
		Commit
	EndFor
	
	AtualizaSaldoConta.Call(TrnMode.Delete,EmpCod,MovCtaBanCod,MovDtaCon,MovCreDeb,MovVlr,&dataVazia,0,'')
	MovSts = Status_Caixa.Cancelado
	Commit
EndFor
