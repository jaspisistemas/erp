      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&QtdItens = 0
For Each Order EmpCod, FilCod, PedCod
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedQtd > 0
	&QtdItens += 1
EndFor
]]></Source>
