      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For EAch Order EmpCod, PesCod, ComLctCod
	Where EmpCod = &EmpCod
	Where PesTipCom.IsEmpty() or PesTipCom.IsNull()
	Do CAse			
		Case ComFatUltCod > 0
			PesTipCom = 'S'
			&PesCod = PesCod
			&ComLctCod = ComLctCod
			&ComTabNor = ComTabNor
			&ComTabPrm = ComTabPrm
			ComTabPrm = 0
			ComTabNor = 0
			&ComFatCod = ComFatUltCod
			do 'atualizaFaturamento' //Atualiza pois a taigra ja estava usando, e agora vai mudar o processo.
			
		CAse ComDscUltCod > 0
			PesTipCom = 'D' //
			
		Otherwise
			PesTipCom = 'N' //
	EndCase	
EndFor

Commit


Sub 'atualizaFaturamento'
	For Each Order EmpCod, PesCod, ComLctCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where ComLctCod = &ComLctCod
		Where ComFatVlr = 0
		
		ComFatTabNor = &ComTabNor 
		ComFatTabPrm = &ComTabPrm
		
		Exit
	When none
		&ComFatCod += 1
		new
			EmpCod = &EmpCod
			PesCod = &PesCod
			ComLctCod = &ComLctCod
			ComFatCod = &ComFatCod
			ComFatVlr = 0
			ComFatTabNor = &ComTabNor 
			ComFatTabPrm = &ComTabPrm
		EndNEw

	EndFor
	Commit
EndSub
]]></Source>
