        <Source><![CDATA[
MT 0
MB 0

loadWWPContext.Call(&Context)
retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
RetornaTabelaFilial.Call(&EmpCod, &FilCod, &FiltabCod)
&PesRaz = &Context.FilRaz

&TipoCodigoBarras = TipoCodigoBarras.CODE128

&IsColuna1 = true
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	&ProCod = EtqProCod
	&ProGraCod = EtqProGraCod
	
	&EtqQtd = EtqQtd
	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto = trim(str(EtqProCod))
	Else
		&CodigoProduto = trim(EtqNovProCod)
	EndIF
	
	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF
	
	do 'GetPreco'
	do 'GetProduto'
	&NomeProduto = ''
	&NomeProduto1 = ''
	&NomeProduto2 = ''
	
	&QtdLInhas = GxMLines(&EtqProNom, 30)
	if &QtdLinhas > 1	
		&NomeProduto  = GxGetMLi(&EtqProNom, 1, 30)
		&NomeProduto1 = GxGetMLi(&EtqProNom, 2, 30)
	Else
		&NomeProduto2 = GxGetMLi(&EtqProNom, 1, 30)
	Endif
	
	&CodBarrasImage.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqProBar) + '.jpg'
	&ProBar = EtqProBar +'-'+ trim(toformattedString(&Today))
	If not EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqProBar, EtqProBar)
		EndIF
		If &File.Exists()
			&CodBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf

	do 'printEtiquetas'
EndFor



sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		if &Coluna1 = false
			
			if not &ValorMoeda.IsEmpty()
				//print EtiquetaModelo001Col1
//				if not &EmbalagemComUnidades.IsEmpty()
//					print Embalagem
//					noskip
//				Endif
//				print SemEmbalagem
				
				if &PrecoPorLitro.IsEmpty()
					print SemPrecoUnitario
					NoSkip
				Else
					print EtiquetaCaixa
					NoSkip
				Endif	
				
				&Coluna1 = true
			EndIF
		else
			if not &ValorMoeda.IsEmpty()
				NoSkip
				//print EtiquetaModelo001Col1
//				if not &EmbalagemComUnidades.IsEmpty()
//					print Embalagem2
//					noskip
//				Endif
//				print SemEmbalagem2
				
				if &PrecoPorLitro.IsEmpty()
					print SemPrecoUnitario2
				Else
					print EtiquetaCaixa2
				Endif
			
				print Traco		
				
				&Coluna1 = false
			EndIF
			
			
		Endif
	
	EndFor
EndSub


Sub 'GetProduto'
	&PrecoPorLitro = ''
	&EmbalagemComUnidades = ''
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&PrecoPorLitro = ''
		
		if &TabPrc1 > 0 and ProEtqUndQtd > 0
			&ValorUnitario = round(&TabPrc1 / ProEtqUndQtd, 2)
			Do CAse
				CAse ProEtqUndRef ='A' //PREÇO POR 1 KG
					&PrecoPorLitro=FORMAT('Preço 1 Kg: R$ %1', trim(toformattedString(&ValorUnitario)))
				CAse ProEtqUndRef ='B' //PREÇO POR 1 LITRO 
					&PrecoPorLitro=FORMAT('Preço 1 Litro: R$ %1', trim(toformattedString(&ValorUnitario)))
				CAse ProEtqUndRef ='C' //PREÇO POR 1 UNIDADE
					&PrecoPorLitro=FORMAT('Preço 1 Unid.: R$ %1', trim(toformattedString(&ValorUnitario)))
			EndCAse
		Endif
	
		&EmbalagemComUnidades = ''
		if &TabPrc1 > 0 and ProEtqEmbQtd > 0
			&CaixaMoeda = &TabPrc1 * ProEtqEmbQtd
			&ProEtqEmbVarchar = trim(toformattedString(ProEtqEmbQtd))
			RetiraZerosDepoisVirgula.Call(&ProEtqEmbVarchar, &ProEtqEmbVarchar)
			Do CAse
				CAse ProEtqEmbRef = 'A' //CAIXA C/ X UNIDADES
					&EmbalagemComUnidades = FORMAT('CX C/%1 R$ %2', trim(toformattedString(&ProEtqEmbVarchar)), trim(ToformattedString(&CaixaMoeda)))
					
				CAse ProEtqEmbRef = 'B'//FARDO C/ X UNIDADES
					&EmbalagemComUnidades = FORMAT('FD C/%1 R$ %2', trim(toformattedString(&ProEtqEmbVarchar)), trim(ToformattedString(&CaixaMoeda)))
					
				CAse ProEtqEmbRef = 'C'//PACOTEC/ X UNIDADES
					&EmbalagemComUnidades = FORMAT('PCT C/%1 R$ %2', trim(toformattedString(&ProEtqEmbVarchar)), trim(ToformattedString(&CaixaMoeda)))
			EndCAse
		Endif
	
		Exit
	EndFor

EndSub


Sub 'GetPreco'
	&ValorMoeda.SetEmpty()
	&TabPrc1 = 0
	For Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &FiltabCod

		For Each Order EmpCod, TabCod, ProCod, ProGraCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			
			if not TabPrc1.IsEmpty()
				&TabPrc1 = TabPrc1
				&ValorMoeda += trim(toformattedString(TabPrc1))
			EndIF
			Exit
		EndFor
	EndFor
EndSub
