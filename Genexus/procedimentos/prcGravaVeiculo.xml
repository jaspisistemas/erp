      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &VeiCod > 0
	For Each Order EmpCod, VeiCod
		Where EmpCod	= &EmpCod
		Where VeiCod	= &VeiCod
		
		VeiMod			= &VeiMod
		VeiSemPlc		= &VeiSemPlc
		if &VeiSemPlc = true
			VeiPla			= '-'+trim(padL(str(&VeiCod),7,'0'))
		Else
			VeiPla			= &VeiPla
		Endif
		
		VeiUfeCod		= &VeiUfeCod
		VeiMarCod		= &VeiMarCod
		VeiAnoFab		= &VeiAnoFab
		VeiAnoMod		= &VeiAnoMod
		VeiCha			= &VeiCha
		VeiComb			= &VeiComb
		VeiCidCod		= &VeiCidCod
		VeiRen			= &VeiRen
		CorCod			= &CorCod
		VeiObs			= &VeiObs
		VeiPro			= &VeiPro
		VeiTip			= &VeiTip
		VeiTipCarr		= &VeiTipCarr
		VeiTipRod		= &VeiTipRod
		VeiTar			= &VeiTar
		VeiCap			= &VeiCap
		VeiCapM3		= &VeiCapM3
		VeiNroEixo		= &VeiNroEixo
		VeiProCod		= &VeiProCod
		VeiProRaz		= &VeiProRaz
		VeiProRNTRC		= &VeiProRNTRC
		VeiProCnpj		= &VeiProCnpj
		VeiProIe		= &VeiProIe
		VeiProUf		= &VeiProUf
		VeiQtdPas		= &VeiQtdPas
		VeiRstUm		= &VeiRstUm
		VeiApiJson		= &VeiApiJson
		VeiUltKm		= &VeiUltKm
		
		Exit
	EndFor

	Commit
Else
	
	UltimoCodigoEmpresa.Call(DomParCod.VEICULO, &EmpCod, 0, &VeiCod)
	New
		EmpCod			= &EmpCod
		VeiCod			= &VeiCod
		VeiSemPlc		= &VeiSemPlc
		if &VeiSemPlc = true
			VeiPla			= '-'+trim(padL(str(&VeiCod),7,'0'))
		Else
			VeiPla			= &VeiPla
		Endif
		
		VeiMod			= &VeiMod
		VeiUfeCod		= &VeiUfeCod
		VeiMarCod		= &VeiMarCod
		VeiAnoFab		= &VeiAnoFab
		VeiAnoMod		= &VeiAnoMod
		VeiCha			= &VeiCha
		VeiComb			= &VeiComb
		VeiCidCod		= &VeiCidCod
		VeiRen			= &VeiRen
		CorCod			= &CorCod
		VeiObs			= &VeiObs
		VeiPro			= &VeiPro
		VeiTip			= &VeiTip
		VeiTipCarr		= &VeiTipCarr
		VeiTipRod		= &VeiTipRod
		VeiTar			= &VeiTar
		VeiCap			= &VeiCap
		VeiCapM3		= &VeiCapM3
		VeiNroEixo		= &VeiNroEixo
		VeiProCod		= &VeiProCod
		VeiProRaz		= &VeiProRaz
		VeiProRNTRC		= &VeiProRNTRC
		VeiProCnpj		= &VeiProCnpj
		VeiProIe		= &VeiProIe
		VeiProUf		= &VeiProUf
		VeiQtdPas		= &VeiQtdPas
		VeiRstUm		= &VeiRstUm
		VeiApiJson		= &VeiApiJson
		VeiStsEfr		= &VeiStsEfr
		VeiUltKm		= &VeiUltKm
	EndNew

Commit
Endif


	
]]></Source>
