        <Source><![CDATA[

For Each Order EmpCod, FilCod
	Where FilCerA1A3 = 'A1'  //A3 NAO DISPONIVEL
	Where not FilCerPsw.IsEmpty() and not FilCerNom.IsEmpty() 
	Where FilVctCer > serverdate() 
	
	RetornaConfiguracoesPastas.Call(EmpCod, FilCod, &PrimeiraEmpresaSdtConfiguracoesPasta)
	
	Exit
EndFor
]]></Source>
