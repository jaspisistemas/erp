      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Total = 30					//## Total de segundos em que o sistema fará a verificação ##\\
&Count = 0					//## Segundo inicial ##\\
&Percentual = 0				//## PErcentual da leitura ##\\

&ProgressIni = serverNow()	//## Data em que o progresso iniciou ##\\
&Mensagem = ''				//## XMLLog do progresso ##\\

do 'Atualiza'				//## Verifica se há um progresso existente ##\\


do 'VerificaXML'


&Percentual = 100			//## Percentual final ##\\
&ProgressFin = serverNow()	//## Data da finalização do Progresso ##\\
do 'Atualiza'				//## Atualiza o Progresso ##\\


Sub 'VerificaXML'			//## Faz a busca do XML através de um caminho físico ##\\
	
	&NomeXML = &SdtConfiguracoesPasta.PastaNFretorno+ trim(&ProBar)+ '-ret-consGTIN.xml'
	&File.Source = &NomeXML

	&Existe = &File.Exists()
	If &Existe = 2 and &Total >= &Count
		
		&Count += 1
		if Mod(&Count,100) = 0
			&Percentual = round((&Count/&Total)* 100, 0)
			
			If &Percentual >= 100	
				&Percentual = 99
			EndIf
			
		EndIF
		
		Do 'Atualiza'
		&Dorme = Sleep(4)
		Do 'VerificaXML'
		
	Else
		
	&Dorme = Sleep(2)
	&Mensagem = 'Consulta Realizada com Sucesso!'

	EndIf
	
EndSub


Sub 'Atualiza'				//## Grava um novo progresso, ou atualiza um existente ##\\
	
	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		ProgressValue = &Percentual
		ProgressLogXml = &Mensagem
	  	ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		  
	When none
		
		New
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &Mensagem
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		EndNew
		
	EndFor
	
	Commit	

EndSub
]]></Source>
