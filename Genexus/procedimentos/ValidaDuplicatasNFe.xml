      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
retornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon075_ValidaNroDuplicata, &TCon075_ValidaNroDuplicata)

For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FatFilCod
	Where NfeCod = &NfeCod
	
	&NfeFilCod = NfeFilCod 
	&NfePedCod = NfePedCod
	
	&NfeDtaEms = NfeDtaEms
	&NfeVlrTot = NfeVlrTot
	if NfeEntSai = Status_EntradaSaida.Entrada
		&ReceberPagar = ReceberPagar.Pagar
	Else
		&ReceberPagar = ReceberPagar.Receber
	EndIf

	For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
		if NfeDupVlr > 0
			&NfeDupVlr += NfeDupVlr
			
//			if &TCon075_ValidaNroDuplicata <> 'S'
//				ValidaNumeroDuplicataRepetido2.Call(EmpCod, &FilCod, NfeDupCreSeq, NfeCliCod, &ReceberPagar, NfeDupNro, &IsErroDuplicataRepetida, &Mensagem)
//			Endif
		
			For &sdtDuplicatasItem in &sdtDuplicatas
				If &sdtDuplicatasItem.CreDupNro = NfeDupNro
					&IsExisteRepetidoTemporaria = true
					Exit
				EndIF
			EndFor
		
			do Case
				CAse &IsExisteRepetidoTemporaria = true and &TCon075_ValidaNroDuplicata <> 'S'//Aceita Repetido? S=SIM N=NAO
					&Mensagem = 'Ajuste os Números das Duplicas, possuem mais de uma duplicata com o mesmo Número: ' + trim(NfeDupNro)
					Return
					
				Case &IsErroDuplicataRepetida = true
					Return
				
				Case NfeDupNro.IsEmpty()
					&Mensagem = 'Número das Duplicatas são obrigatórios!'
					Return
//				case NfeDupVct < &NfeDtaEms
//					&Mensagem = 'Vencimento das Duplicatas devem ser superior a data de Emissão da NFe!'
//					Return
				Case NfeCbrCod.IsEmpty() or NfeCbrCod.IsNull()
					&Mensagem = 'Informe o local de Cobrança para as duplicatas!'
					Return
			EndCase	
			
			if &IsExisteRepetidoTemporaria = false
				&sdtDuplicatasItem = new()
				&sdtDuplicatasItem.EmpCod = &EmpCod
				&sdtDuplicatasItem.FilCod = &FilCod
				&sdtDuplicatasItem.CreCod = NfeDupCreSeq
				&sdtDuplicatasItem.CreDupNro = NfeDupNro
				&sdtDuplicatas.Add(&sdtDuplicatasItem)
			EndIF
		
		Else
			//Verificar Duplicata se tiver Aberta e apagar
			delete
		EndIf
	EndFor

	Exit
EndFOr
 
if &NfeVlrTot <> &NfeDupVlr and &NfeDupVlr > 0
	&Mensagem = 'Soma das Duplicatas difere do Valor da NFe!'
EndiF

Commit

&Count = 0
For Each Order EmpCod, FilCod, NfeCod, NfeSelPedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FatFilCod
	Where NfeCod = &NfeCod
	
	&Count += 1
EndFor

if &Count = 0
	GravaDuplicatasAReceberNota.Call(&EmpCod, &FatFilCod, &NfeCod, 1)
Endif

//if &NfeDupVlr > 0 and &NfePedCod > 0
//	prcBaixaDuplicatareferenciada.Call(&EmpCod, &NfeFilCod, &NfePedCod)
//Endif
]]></Source>
