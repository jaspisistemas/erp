      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ObsNom = &ParObsNom

&ObsNom = RetiraCaracteresEspeciais.Udp(&ObsNom)

For Each Order EmpCod, ObsNom
	Where EmpCod = &EmpCod
	Where ObsNom = &ObsNom
	
	&ObsCod = ObsCod
	Exit
When none	
	UltimoCodigoEmpresa.Call(domParCod.OBSNOTA, &EmpCod, 0, &ObsCod)
	New
		EmpCod = &EmpCod
		ObsCod = &ObsCod
		ObsNom = &ObsNom
	EndNew
	Commit

EndFor
]]></Source>
