      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&MdfePgtParNroMax = 0
&MdfePgtParNro = 0
For each Order EmpCod,FilCod,MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MdfeCod
	
	&MdfePgtParNroMax = MdfePgtParNroMax
	exit
EndFor
	&MdfePgtParNro = &MdfePgtParNroMax+1
New
	EmpCod = &EmpCod
	FilCod = &FilCod
	MDFeCod = &MdfeCod
	MdfePgtParNro = &MdfePgtParNro
	MdfePgtParVct = &MdfePgtParVct
	MdfePgtParVlr = &MdfePgtParVlr
EndNew

commit
]]></Source>
