        <Source><![CDATA[loadwwpContext.Call(&WwpContext)
&IsImprimiu = false
RetornaTefAutorizado.call(&EmpCod, &TefCod, &XmlIMprimir)

//&sdtComprovante.fees = 'teste'
//&sdtComprovante.statement_descriptor = 'teste'
//&sdtComprovante.original_amount = &sdtComprovante.ToJson()

//&XmlIMprimirLongVarchar = &XmlIMprimir.Replace('metadata:{},', '')
//&sdtComprovante.FromJson(&XmlIMprimirLongVarchar)

//&ObservacaoLimiteCredito = &sdtRELJAS_XXX_Nfe.imgCodBarras
//&XmlWriter.Open('teste0.xml')
//&XmlWriter.WriteRawText(&XmlIMprimir)
//&XmlWriter.Close()

//&XmlWriter.Open('teste1.xml')
//&XmlWriter.WriteRawText(&sdtComprovante.ToXml())
//&XmlWriter.Close()

&XmlIMprimirLongVarchar = &XmlIMprimir.Replace('metadata:{},', '')
&sdtComprovante.FromJson(&XmlIMprimirLongVarchar)

//&XmlWriter.Open('teste2.xml')
//&XmlWriter.WriteRawText(&sdtComprovante.ToXml())
//&XmlWriter.Close()


MB 4
MT 2

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &WwpContext.FilCod

	&Endereco = FilLogNro.Trim()
	&Endereco += ' '+FilBai.Trim() 
	&Endereco += ' - '+FilCidNom.Trim()+ '-'+ FilCidUfeCod.Trim()
	
	&CnpjIeIm = 'CNPJ: ' + FilCpj.Trim() + ' / FONE: '+ FilFonNum.Trim()
	
	If FilImg_LogRel.IsEmpty()
		&Image.FromImage('FilialSemImagem')  
	Else
		&Image = FilImg_LogRel
	EndIF
	
	Exit
EndFor


&BandeiraMensagem = UPPER(&sdtComprovante.payment_method.card_brand)

&UmFilRaz = &sdtComprovante.statement_descriptor
print tituloA
print ViaCliente

&Mensagem = ''
//print centralizado
&AutorizacaoMensagem = 'CV: '+&sdtComprovante.payment_authorization.authorizer_id //CV
//print Autorizacao
&AutoMensagem = 'AUTO: '+&sdtComprovante.payment_authorization.authorization_code + ' ARQC: '+&sdtComprovante.arpc//ARQC//AUTORIZACAO


//print traco

&ClienteMensagem = &sdtComprovante.payment_method.holder_name//NOME CLIENTE
&CartaoMensagem = '************' + &sdtComprovante.payment_method.last4_digits //NUMERO CARTAO

//Credito
//VENDA A CREDITO


&DataVarchar = Substr(&sdtComprovante.created_at, 9,2 ) + '/'+Substr(&sdtComprovante.created_at, 6,2 )+ '/'+ Substr(&sdtComprovante.created_at, 1,4)//DATA E HORA
&HoraVarchar = Substr(&sdtComprovante.created_at, 12,8)
&varPedVlrBrt = 'R$ ' + trim(&sdtComprovante.amount) //VALOR APROVADO

print Autorizacao
print DataValor

//print Traco
//&Mensagem = 'Obrigado pela preferência!'
//print centralizado

&IsImprimiu = true
]]></Source>
