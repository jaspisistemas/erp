      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem = ''
For Each Order EmpCod, FilCod, CteCod, CteDupCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	&CteDupFiLCod = CteDupFilCod
	&CteDupCreSeq = CteDupCreSeq
	
	CancelarDuplicata.call(&EmpCod,&CteDupFiLCod,&CteDupCreSeq, &Mensagem)
	If &Mensagem.Trim().IsEmpty() //se nao teve impedimento nenhum, deleta
		delete
	EndIf
	Exit
EndFor
]]></Source>
