        <Source><![CDATA[
HostWebServiceJaspiERP.Call(&EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)

&HttpClient.Host = &EmpWebHost //servidor 
&HttpClient.Port = &EmpWebPor
&HttpClient.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
&HttpClient.Secure = 0 //false

&LongVarchar  =  '<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:erp="ERP">'
&LongVarchar +=  ' <soapenv:Header/>'
&LongVarchar +=  '  <soapenv:Body>'
&LongVarchar +=  '   <erp:ppWbsJaspiDuplicatas_out.Execute>'
&LongVarchar +=  '    <erp:Insdtconfduplicatawbs> '

&LongVarchar += format('<erp:EmpCodSec>%1</erp:EmpCodSec>', trim(&EmpCodSec))

&LongVarchar +=  '   </erp:Insdtconfduplicatawbs>'
&LongVarchar +=  '  </erp:ppWbsJaspiDuplicatas_out.Execute>'
&LongVarchar +=  ' </soapenv:Body>'
&LongVarchar +=  '</soapenv:Envelope>'

//ADICIONANDO CABEÇALHO DE COMUNICAÇÃO
&HttpClient.AddHeader('Content-Type','text/xml;charset=UTF-8')
&HttpClient.AddHeader('SOAPAction', '"ERPaction/APPWBSJASPIDUPLICATAS_OUT.Execute"')
&HttpClient.AddString(&LongVarchar) //ADICIONANDO PARAMETROS
&HttpClient.Execute('POST','appwbsjaspiduplicatas_out.aspx') //FAZENDO POST DE COSNULTA 

If &HttpClient.ErrCode = 0 //sem erro de comunicação
	&LongVarchar = ''
	&longvarchar = &HttpClient.toString()	
	&longvarchar = strReplace(&longvarchar,'<?xml version = "1.0" encoding = "utf-8"?>', '')
	&longvarchar = strReplace(&longvarchar,'<SOAP-ENV:Envelope xmlns:SOAP-ENV="http://schemas.xmlsoap.org/soap/envelope/" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:SOAP-ENC="http://schemas.xmlsoap.org/soap/encoding/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">', '')
	&longvarchar = strReplace(&longvarchar,'<SOAP-ENV:Body>', '')
	&longvarchar = strReplace(&longvarchar,'</SOAP-ENV:Body>', '')
	&longvarchar = strReplace(&longvarchar,'</SOAP-ENV:Envelope>', '')
	
	&longvarchar = strReplace(&longvarchar,'<ppWbsJaspiDuplicatas_out.ExecuteResponse xmlns="ERP">', '')
	&longvarchar = strReplace(&longvarchar,'</ppWbsJaspiDuplicatas_out.ExecuteResponse>', '')
	&longvarchar = strReplace(&longvarchar,'Outsdtconfduplicatawbs', 'sdtConfDuplicataWbs')
	
//	&XmlWriter.Open('recebido.xml')
//	&XmlWriter.WriteRawText(&LongVarchar)
//	&XmlWriter.Close()

	&outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.FromXml(&longvarchar)
	
//	&XmlWriter.Open('FormatadoXML.xml')
//	&XmlWriter.WriteRawText(&outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.ToXml())
//	&XmlWriter.Close()

	//ATUALIZA PADRAO USUARIO
	&Data = &outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.CreDtaVct
	&AuxEmpCod = &outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.EmpCod
	&FilCod = &outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.Filcod
	&CreCod = &outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.CreCod
	&CreCliCod = &outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.CreCliCod	
	
	&PadObs = &Data.ToFormattedString()
	&PadObs += 'JASPI'
	+ PadL(Str(&AuxEmpCod), 8, '0')
	+ PadL(Str(&Filcod), 8, '0')
	+ PadL(Str(&CreCod), 8, '0')
	+ PadL(Str(&CreCliCod), 8, '0')
	+ Str(&outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.Codigo)
	+ &outppWbsJaspiDuplicatas_insdtConfDuplicataWbs.Mensagem
	
	PadraoUsuario.Call('G', '#VENCIMENTODUPLICATAJASPI#', 1, &EmpCod, &PadObs, &PadDtaMod)
	//Endif
Else 
	&mensagem = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
	&mensagem += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
EndIf


]]></Source>
