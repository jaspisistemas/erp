      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[do case
	case &Mode = TrnMode.Insert
		do 'Insert'
	case &Mode = TrnMode.Update
		do 'Update'
	case &Mode = TrnMode.Delete
		do 'Delete'
endcase

Sub 'Insert'
	UltimoCodigoEmpresa.Call(domParCod.LAYOUT, &EmpCod, 0, &LayCod)
	
	&LayCod += 1
	new
		EmpCod = &EmpCod
		LayCod = &LayCod
		LayArq = &sdtLayoutConciliaMaquininha.Campo.ToJson()
		LayNom = &sdtLayoutConciliaMaquininha.sdtLayNom
		LaySeq = &sdtLayoutConciliaMaquininha.sdtLaySeq
		LayTip = Tipo_Layout.MAQUININHA_A
	endnew
	commit
EndSub

Sub 'Update'
	For Each
		order EmpCod, LayCod
		where EmpCod = &EmpCod
		where LayCod = &sdtLayoutConciliaMaquininha.sdtLayCod
		
		LayArq = &sdtLayoutConciliaMaquininha.Campo.ToJson()
		LayNom = &sdtLayoutConciliaMaquininha.sdtLayNom
	EndFor
	commit
EndSub

Sub 'Delete'
	For Each
		order EmpCod, LayCod
		where EmpCod = &EmpCod
		where LayCod = &sdtLayoutConciliaMaquininha.sdtLayCod
		delete
		exit
	EndFor
	commit
EndSub
]]></Source>
