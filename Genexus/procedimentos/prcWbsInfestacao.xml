      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &ppJASPI_InfestacoessdtEstruturaInfestacoes.Culturas.CulturasItems.Count > 0
	For &sdtCulturas in &ppJASPI_InfestacoessdtEstruturaInfestacoes.Culturas.CulturasItems
		For Each Order EmpCod,TlvSiaCod
			Where EmpCod = &EmpCod
			Where TlvSiaCod = &sdtCulturas.TlvSiaCod
			TlvNom = Upper(RetiraCaracteresEspeciais.Udp(&sdtCulturas.TlvNom))
			&TlvCod = TlvCod
			Exit
		When none
			UltimoCodigoEmpresa.Call(domParCod.LAVOURA, &EmpCod,  0, &TlvCod)
			new
				EmpCod = &EmpCod
				TlvCod = &TlvCod
				TlvNom = &sdtCulturas.TlvNom
				TlvSiaCod = &sdtCulturas.TlvSiaCod
			EndNew
		EndFor
		Commit
		atualizaFormulaCultura.call(&EmpCod,&TlvCod)
	EndFor
EndIF
 
If &ppJASPI_InfestacoessdtEstruturaInfestacoes.Infestacoes.InfestacoesItems.Count > 0	
	For &sdtInfestacao in &ppJASPI_InfestacoessdtEstruturaInfestacoes.Infestacoes.InfestacoesItems
		For each Order EmpCod,InfCod
			Where EmpCod = &EmpCod
			Where InfSiaCod = &sdtInfestacao.InfSiaCod
			
			InfNom = &sdtInfestacao.InfNom+'-'+&sdtInfestacao.InfNomIng
			Exit
		When none
			UltimoCodigoEmpresa.Call(domParCod.INFESTACAO, &EmpCod,  0, &InfCod)
			new
				EmpCod = &EmpCod
				InfCod = &InfCod
				InfNom = &sdtInfestacao.InfNom+'-'+&sdtInfestacao.InfNomIng
				InfSiaCod = &sdtInfestacao.InfSiaCod
			EndNew
		EndFor
	
		Commit
	EndFor
EndIF
]]></Source>
