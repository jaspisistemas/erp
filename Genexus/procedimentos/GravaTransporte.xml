      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteDocCod = &CteDocCod
	Where CteInfUndTraTip = &CteInfUndTraTip
	
	CteInfUndTraIde = &CteInfUndTraIde
	CteInfUndTraQtd = &CteInfUndTraQtd
	Msg('Transporte atualizado com sucesso!')
When none
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteDocCod = &CteDocCod
		CteInfUndTraTip = &CteInfUndTraTip
		CteInfUndTraIde = &CteInfUndTraIde
		CteInfUndTraQtd = &CteInfUndTraQtd
		Msg('Transporte cadastrado com sucesso!')
	EndNew
EndFor


Commit
		
]]></Source>
