      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &NfeCceCod = 0
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\"
		&DiretorioDanfeBancoDeDados.Source   =  &PastaBancoDados
		if not &DiretorioDanfeBancoDeDados.Exists()
			&DiretorioDanfeBancoDeDados.Create()
		EndIf
		
		&NomArq = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\" + NfeChv.Trim() + '-jaspi.xml'
		&resultado = DFWOpen(&NomArq,'','',0,'')
		&resultado = DFWPTxt(NfeArqXml)
		&ResultadoNext = dfwnext()
		&resultado = DFWClose()
		Exit
	EndFor
Else
	For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeCCeCod = &NfeCceCod
		
		&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\"
		&DiretorioDanfeBancoDeDados.Source   =  &PastaBancoDados
		if not &DiretorioDanfeBancoDeDados.Exists()
			&DiretorioDanfeBancoDeDados.Create()
		EndIf
		
		&NomArq = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\" + NfeChv.Trim() + '_' + padL(str(NfeCCeEvtCod),2,'0') + '-jaspi.xml'
		&resultado = DFWOpen(&NomArq,'','',0,'')
		&resultado = DFWPTxt(NfeCCeArqXml)
		&ResultadoNext = dfwnext()
		&resultado = DFWClose()
		Exit
	EndFor
EndIF


]]></Source>
