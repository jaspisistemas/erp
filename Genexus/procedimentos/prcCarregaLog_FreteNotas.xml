      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &FrtCod.IsEmpty() //INSERT
	//QUando insert inserido os campos no proprio processo de gravar.
Else
	For Each order EmpCod,FilCod,FrtCod, FrtItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where FrtCod = &FrtCod
		
		&IdVarchar = trim(str(FrtItmCod))
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtItmCod', trim(str(FrtItmCod)), '', &sdtLogAtributosLevel)		
		
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtNfeFilCod', trim(str(FrtNfeFilCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtNfeCod', trim(str(FrtNfeCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtPedFiLCod', trim(str(FrtPedFiLCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtPedCod', trim(str(FrtPedCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtItmVlrCal', trim(FrtItmVlrCal.ToFormattedString()), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtItmVlr', trim(FrtItmVlr.ToFormattedString()), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtItmNot', trim(FrtItmNot), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtItmCte', trim(FrtItmCte), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtItmTip', trim(FrtItmTip), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtNfeNum', trim(str(FrtNfeNum)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtCteCod', trim(str(FrtCteCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'FrtCteFilCod', trim(str(FrtCteFilCod)), '', &sdtLogAtributosLevel)

		
	EndFor
Endif
]]></Source>
