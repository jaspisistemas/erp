        <Source><![CDATA[

//if &TCon083_Markup = 'S' //Utiliza MC
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		where ProSts <> Status_Produto.EXCLUIDO
		
		if &ProVlrCusFix > 0
			ProVlrCusFix = &ProVlrCusFix 
		Endif
	
		//100 - (ProImcTotDsp + ProImcMarLuc)
		//		If ProIMCTot <> ProImcTot_Formula
		//			ProImcMarLuc = 100 - ProIMCTot
		//		EndIf
		
		//		if ProIMCTot > 0
		//			&NovaVenda = round((100 / (ProIMCTot/100)),2)
		//		EndIF
		
		//		ProIMC = round(100 - ((&NovaVenda / 100) * 100), 2)
		//		if ProIMC < 0
		//			ProIMC = ProIMC * -1
		//		EndIF
		
		Exit
	EndFor


	Commit
	
	if &ProVlrCusFix > 0 
		//Else //Utiliza % Acres.
		ProVlrCus_Produto.Call(&EmpCod, &ProCod)	
	Endif
]]></Source>
