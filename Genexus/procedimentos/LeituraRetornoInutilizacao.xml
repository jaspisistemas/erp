      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&FilInuCod = &parFilInuCod

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where FilInuCod = &FilInuCod
	
	&CNPJ = RetornaSoNumeros.Udp(FilCpj)
	&FilCidUfeCod = RetornaCodigoSiglaEstado.Udp(0, FilCidUfeCod)
	&ano = FilInuAno
	&ModCod = FilInuMod
	&NfeSer = trim(Str(FilInuSer))
	&FilInuNroIni = FilInuNroIni
	&FilInuNroFin = FilInuNroFin
	Exit
EndFor

&SolSts = Status_Solicitacao.Pendente
&SolMsg = ''
&id = &FilCidUfeCod.Trim() + &ano.Trim() + &CNPJ.Trim() + &ModCod.Trim() + padl(trim(&NfeSer),3,'0') + padl(trim(str(&FilInuNroIni,9,0)),9,'0')+padl(trim(str(&FilInuNroFin,9,0)),9,'0')

&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&id)+'-inu.xml'
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&id) + '-inu.err'

&File.Source = &Nome_retorno_erro
if &File.Exists()
	&SolSts = Status_Solicitacao.Falha
	&Tentativa = 99
	
	&SolMsg = 'Xml Rejeitado: '
	&ResultadoAbertura = DFROpen(&Nome_retorno_erro)
	&ResultadoNext = 0
	Do while &ResultadoNext = 0
		&Ret =  DFRGTxt(&CampoUnico, 500)	
		&SolMsg += &CampoUnico	
		&ResultadoNext =  DFRNext()
	EndDo
	&resultadoNext = DFRClose()
	
	GravaInutilizacao.Call(&EmpCod, &FilCod,0, &FilInuCod, '', 0, 0, '', 0, '', '', 0, Status_NFe.Cancelada)
else
	
	&File.Source = &Nome_retorno_correto
	if &File.Exists()
		&retorno_xml.Open(&Nome_retorno_correto)
		
	    &retorno_xml.ReadType(1,'cStat')
	    &cStat = &retorno_xml.Value
		
	    &retorno_xml.ReadType(1,'xMotivo')
	    &xMotivo = &retorno_xml.Value
		
	    &retorno_xml.ReadType(1,'dhRecbto')
	    &FilInuDhRec = &retorno_xml.Value
		
	    &retorno_xml.ReadType(1,'nProt')
	    &FilInuProt = &retorno_xml.Value
		
	    if not &cStat.IsEmpty()
			IF &cStat = '102' or &cStat = '256' //NOTA INUTILIZADA
				GravaInutilizacao.Call(&EmpCod, &FilCod,0, &FilInuCod, '', 0, 0, '', 0, &FilInuDhRec, &FilInuProt, 0, Status_NFe.Autorizada)
				
				//GRAVA STATUS DA NOTA INUTILIZADA
				GravaInutilizacaoNotaFiscal.Call(&EmpCod, &FilCod, &NfeSer, &ModCod, &FilInuNroIni, &FilInuNroFin, &xMotivo)
				
				&SolSts = Status_Solicitacao.Finalizada
				&Tentativa = 99
				&SolMsg = &xMotivo
				
			Else
				GravaInutilizacao.Call(&EmpCod, &FilCod,0, &FilInuCod, '', 0, 0, '', 0, '', '', 0, Status_NFe.Cancelada)
				
				&SolMsg = 'Status: '+ &cStat.Trim() + ' - ' + &xMotivo.Trim()
				&SolSts = Status_Solicitacao.Falha
				&Tentativa = 99
			EndIf
		
			
		EndIf
		
		&retorno_xml.close()
	EndIF
EndIf

if &SolSts <> Status_Solicitacao.Pendente
	if not &Nome_retorno_erro.IsEmpty()
		&File.Source = &Nome_retorno_erro
		if &File.Exists()
		    &File.Delete()
		EndIf
	EndIF
	if not &Nome_retorno_correto.IsEmpty()
		&File.Source = &Nome_retorno_correto
		if &File.Exists()
		    &File.Delete()
		EndIf
	EndIF
EndIF
]]></Source>
