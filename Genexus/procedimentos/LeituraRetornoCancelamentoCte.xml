      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&conteudo_arquivo = ''

For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	&CteChv = CteChv
	&PastaDanfeData = str(year(CteDtaEms),4,0)+padl(trim(str(month(CteDtaEms),2,0)),2,'0')
	Exit
EndFor

	
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&CteChv)+'-eve.err' 
&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&CteChv) + '-eve.xml'

&File.Source = &Nome_retorno_erro
if &File.Exists() 
	&ResultadoAbertura =   DFROpen(&Nome_retorno_erro)    

	Do while dfrnext() = 0 
		&ResultadoAbertura = DFRGTxt(&CampoUnico)
		&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
	EndDo
	&ResultadoAbertura = DFRClose()
	
	&File.Delete()
	
	&Tentativa = 99
	&SolSts = Status_Solicitacao.Falha
	&SolMsg = &conteudo_arquivo
else
	&File.Source = &Nome_retorno_correto
	if &File.Exists()

		&retorno_xml.Open(&Nome_retorno_correto)    
		&retorno_xml.ReadType(1, 'infEvento')
		&retorno_xml.Read()  
		Do While (&retorno_xml.Name <> 'infEvento' and &retorno_xml.Name <> '')
			Do Case
				Case &retorno_xml.Name = 'cStat'
					&CteAutSts = &retorno_xml.Value
				Case &retorno_xml.Name = 'dhRegEvento'
					&CteAutDatHorRec = &retorno_xml.Value
				Case &retorno_xml.Name = 'xMotivo'
					&CteAutMsg  = &retorno_xml.Value
				Case &retorno_xml.Name = 'nProt'
					&CteAutNumPro  = &retorno_xml.Value
			EndCase
			&retorno_xml.Read()           
		EndDo
		&retorno_xml.close()
			
		if not &CteAutSts.IsEmpty()
			Do Case
				Case &CteAutSts in ('135', '136')
					&CteAutSts = '101'					
					&mensagem = '135 - CANCELAMENTO DE CTE HOMOLOGADO'
					
					AtualizaNumeroProtocoloCTe.Call('CANCELA_CTE', &EmpCod, &FilCod, &CteCod, &CteAutSts, '', '', &CteAutDatHorRec, &CteAutMsg, &CteAutNumPro, '', Status_NFe.Cancelada, &SolPesCod)
					&SolSts = Status_Solicitacao.Finalizada
					 do 'ArquivoXML'	
				Case &CteAutSts in ('579', '577', '578')
					&mensagem = 'Falha na Comunicação, Fuso horário informado diverge dos servidores sefaz.'
					&SolSts = Status_Solicitacao.Falha
					
				Otherwise
					&mensagem = &CteAutSts.Trim() + ' - ' + trim(&CteAutMsg)
					&SolSts = Status_Solicitacao.Falha
			EndCase
		
			&Tentativa = 99
			&SolMsg = &mensagem
		EndIF
	EndIf
EndIf


Sub 'ArquivoXML'
	&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFenviado.Trim() +'/Autorizados/' + trim(&PastaDanfeData) +'/'+&CteChv.trim()+'_110111_001-procEventoCTe.xml'
	
	&file.Source = &ArquivoPronto
	If &file.Exists()
		GravaArquivoXmlCTECancelado.Call(&EmpCod, &FilCod, &CteCod, &ArquivoPronto)
	EndIf
EndSub
]]></Source>
