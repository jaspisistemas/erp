For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		&ncmCod = NfeNcmCod
		do 'ValidaNCM'
		if &IsErroNcm = true
			&Mensagem += &erroNcmMensagem.Trim()
		EndIf	
	EndFor
	
	Exit
EndFor


if &Mensagem.IsEmpty()
	ValidaDuplicatasNFe.Call(&EmpCod, &FilCod, &NfeCod, &ContextFilCod, &Mensagem)
EndiF

Sub 'ValidaNCM'
	
	&IsErroNCM = false
	&erroNcmMensagem = ''
	For Each Order NcmCod
		Where NcmCod = &NcmCod
		
		if NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()
			&erroNcmMensagem = ' FIM DA VIGENCIA DO NCM: ' + trim(str(NcmCod))
			&IsErroNCM = true
		Endif
		
		Exit
	EndFor
EndSub
]]></Source>
