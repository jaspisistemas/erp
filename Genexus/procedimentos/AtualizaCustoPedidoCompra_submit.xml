      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedQtd <> 0
	
	//Atualiza
	&auxCount += 1
	If &auxCount > 10 and &Total > 0
		&Count += 1
		&Percentual = round((&Count / &Total) * 100, 0)
		&auxCount = 0
		If &Percentual >= 100
			&Percentual = 99
		EndIf
		&ProgressLogXml = &Pgmname + ' ' + ProRef
		do 'Atualiza'
	EndIF
	//Atualiza
	
	&ProCod = ProCod
    do 'UltimaEntradaProduto'
	
EndFor

Sub 'UltimaEntradaProduto'
    For Each Order EmpCod, ProCod
	    Where EmpCod = &EmpCod
	    Where ProCod = &ProCod
		
		valorUltimaCompraProduto_Novo.Call(EmpCod, ProCod, &ProVlrUltCmp, &ProPadForCod)
		
		if ProPadUltCmp = 'C' and &ProPadForCod > 0//Ultima Compra
			ProPadForCod = &ProPadForCod
		EndiF
		
		ProVlrUltCmp = &ProVlrUltCmp
    EndFor

	Commit
	
	ProVlrCus_Produto.Call(&EmpCod, &ProCod)
EndSub


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		Exit
	endfor
	
	commit	
EndSub
]]></Source>
