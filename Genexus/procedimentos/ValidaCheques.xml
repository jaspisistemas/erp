      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErro = false
&MEnsagem  = ''


For &i =  &TalFolIni to &TalFolFin step 1
	&CheNro = &i
	For Each Order EmpCod, TalCtabanCod, CheNro
		Where EmpCod = &EmpCod
		Where TalCtabanCod = &TalCtabanCod
		Where CheNro = &CheNro
		&MEnsagem = 'Atenção: Já possui cheques lançado com a sequência Informada. Cheque Número:' + trim(str(CheNro))
		&IsErro = true
		Return
	EndFor
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
