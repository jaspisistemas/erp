      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Varchar = toformattedString(&FilPedDtaEms)
RetornaSoNumeros.Call(&Varchar, &Varchar)

&PedDeviceRandon = &PdvId.Trim() +trim(&Varchar) //+ '-'
//msg(&PedDeviceRandon)

For Each ORder EmpCod, FilCod, PedDtaEms, PedHorEms
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod	
//	where PedDeviceRandon like '%'+&PdvId.Trim()+'%'
	Where PedDtaEms = &FilPedDtaEms or PedDtaFat = &FilPedDtaEms
	
	&CrePedCod = PedCod
	&PedHorEms = PedHorEms
	&AuxPedDeviceRandon = PedDeviceRandon
	do 'GetDuplicatas'
	
EndFor


Sub 'GetDuplicatas'
	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &Filcod
		Where CrePedCod = &CrePedCod
		Where CreSts <> Status_Duplicata.CANCELADA
		Where CreRecPag = ReceberPagar.Receber
		Where CreVlrSdo > 0
		Where CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
		
		&sdtDuplicatasItem = new()
		&sdtDuplicatasItem.EmpCod = EmpCod
		&sdtDuplicatasItem.FilCod = FilCod
		&sdtDuplicatasItem.CreCod = CreCod
		&sdtDuplicatasItem.CreDtaEms = CreDtaEms
		&sdtDuplicatasItem.CreHorEms = &PedHorEms
		&sdtDuplicatasItem.CrePedCod = CrePedCod
		&sdtDuplicatasItem.CreVlrDup = CreVlrDup
		&sdtDuplicatasItem.CreCarNroAut = CreCarNroAut
		&sdtDuplicatasItem.CreCarBanCod = CreCarBanCod
		&sdtDuplicatasItem.CreCbrNom = &AuxPedDeviceRandon 
		
		&sdtDuplicatas.Add(&sdtDuplicatasItem)
		
	EndFor
EndSub
]]></Source>
