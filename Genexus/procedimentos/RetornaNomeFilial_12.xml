      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&FilRaz = ''
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	&FilRaz = iif(not FilNom.isempty() and not not FilNom.isnull(),trim(str(FilCod))+' - '+trim(Substr(FilNom, 1, 12)), trim(str(FilCod))+' - '+trim(Substr(FilRaz, 1, 12))) 
	Exit
EndFor
]]></Source>
