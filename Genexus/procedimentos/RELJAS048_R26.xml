      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
RetornaTabelaFilial.Call(&EmpCod, &FilCod, &FiltabCod)
&TipoCodigoBarras = TipoCodigoBarras.Code128

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&IsColuna1 = true
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	&EtqQtd = EtqQtd
	&ProCod = EtqProCod
	&ProGraCod = EtqProGraCod
	&Coluna1.SetEmpty()
	&Coluna2.SetEmpty()
	&EtqProQtdEmb.SetEmpty()
	&Coluna3.SetEmpty()
	
	
	&sdtDadosAdicionaisEtiqueta.FromJson(EtqProObsAdi)
	
	
	
	&Coluna2 = 'Emb: '+&sdtDadosAdicionaisEtiqueta.ProDesEtq3
	
	&EtqProQtdEmb = EtqProQtdEmb
	If not EtqProNroLot.Trim().IsEmpty()
		&EtqProNroLot = trim(EtqProNroLot)
		do 'Lote'
		
		
		&Coluna1 = 'Vct: '+dtoc(&EstLotVct)
		&Coluna3 = 'Lote: '+trim(&EtqProNroLot)
	EndIf

	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto += ': ' + trim(str(EtqProCod))
		&Codigo = trim(str(EtqProCod))
	Else
		&CodigoProduto += ': ' + trim(EtqNovProCod)
		&Codigo = trim(EtqNovProCod)
	EndIF

	&EtqProNom = &sdtDadosAdicionaisEtiqueta.ProDesEtq1
	If &EtqProNom.trim().IsEmpty()
		&EtqProNom = EtqProNom.Trim()
		if not EtqProGraNom.IsEmpty()
			&EtqProNom += ' | ' + trim(EtqProGraNom)
		EndIF
	EndIf

	&NomeProduto  = GxGetMLi(&EtqProNom, 1, 40)
	
	&AuxEtqProNom = trim(&sdtDadosAdicionaisEtiqueta.ProDesEtq2)
	&NomeProduto1 = GxGetMLi(&AuxEtqProNom, 1, 40)
	
	Do CAse
		Case EtqProBar.Length() =  13
			&NewProBar = format('%1 %2 %3 %4', substr(EtqProBar, 1, 2), substr(EtqProBar, 3, 7), substr(EtqProBar, 10, 3), substr(EtqProBar, 13, 1))
		Case EtqProBar.Length() =  14
			&NewProBar = format('%1 %2 %3 %4', substr(EtqProBar, 1, 1), substr(EtqProBar, 2, 3), substr(EtqProBar, 5, 8), substr(EtqProBar, 13, 2))
		Otherwise
	EndCase
	
	&CodBarrasImage.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqProBar) + '.jpg'
	If not EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqProBar, EtqProBar)
		EndIF
		If &File.Exists()
			&CodBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf

	do 'printEtiquetas'
EndFor

sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		print EtiquetaModelo001Col1
	EndFor
EndSub
sub 'Lote'
	&EstLotFab.SetEmpty()
	&EstLotVct.SetEmpty()
	For Each Order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = 1
		Where EstLotCod = &EtqProNroLot
		&EstLotFab = EstLotFab
		&EstLotVct = EstLotVct
		exit
	endFor
endSub

]]></Source>
