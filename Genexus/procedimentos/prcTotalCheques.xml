      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&HojeMoeda = 0
&FututoMoeda = 0
For Each Order EmpCod, CheCod
	Where EmpCod = &EmpCod
	Where CheTip = &CheTip
	Where CheMot <> MotivoCheque.COMPENSADO and CheMot <> MotivoCheque.CANCELADO and CheMot <> MotivoCheque.MOTIVO12 and CheMot <> MotivoCheque.SEMREAPRESENTACAO and CheMot <> MotivoCheque.REPASSADO
	
	if CheDtaVct <= &CheDtaVct
		&HojeMoeda += CheVlr	
	EndIF
	
	&FututoMoeda += CheVlr
EndFor
]]></Source>
