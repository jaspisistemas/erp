      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &OqueFazer = 'ADD'
	For Each Order EmpCod, GrupCod, (GrupComItmCod)
		Where EmpCod = &EmpCod
		where GrupCod = &GrupCod
		&GrupComItmCod = GrupComItmCod
		Exit
	EndFor
	&GrupComItmCod += 1
	
	New
		EmpCod = &EmpCod
		GrupCod = &GrupCod
		GrupComItmCod = &GrupComItmCod
		GrupObsCod = &GrupObsCod 
		GrupProCod = &GrupProCod 
		GrupObsComp = &GrupObsComp
	EndNEw
	
Else
	
	For Each Order EmpCod, GrupCod, GrupComItmCod
		Where EmpCod = &EmpCod
		where GrupCod = &GrupCod
		Where GrupObsCod = &GrupObsCod when &GrupObsComp = 'O' //OBSERVACAO
		Where GrupProCod = &GrupProCod when &GrupObsComp = 'P' //COMPLEMENTO
		Where GrupProCod = &GrupProCod when &GrupObsComp = 'A' //COMPOSICAO
		Delete
	EndFor
Endif

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
