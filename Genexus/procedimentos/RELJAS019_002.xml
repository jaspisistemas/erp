      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//ALTERANDO AQUI TEM QUE ALTERAR NO RELJAS030

loadWWPContext.Call(&Context)
&SdtDuplicatas.FromXml(&WEBSESSION.Get('IMPRIMEDUPLICATA'))
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &FilCod
	&FilFan       = FilFan
	&FilLogNro    = FilLogNro
	&FilCepCidUfe = FilCepCidUfe
	&FilFonNum    = FilFonNum 
	&FilCpj       = FilCpj
	
	if &FilCpj.Length() <= 14
		&EmpresaTitulo = 'BENEFICIÁRIO'
		&NotaTitulo = ''
		&NumeroTitulo = ''
		&CnpjCpf = 'CPF'
		&InscricaoVarchar = ''
		&varNota = ''
		&FilInsEst = ''
	Else
		&EmpresaTitulo = 'Empresa'
		&NotaTitulo = 'NOTA FISCAL'
		&NumeroTitulo = 'Numero'
		&CnpjCpf = 'CNPJ'
		&InscricaoVarchar = 'Insc.Estadual'
		&FilInsEst    = FilInsEst
	EndIf

	If not FilImg_LogRel.IsEmpty()
		&Image = FilImg_LogRel
	Else
		&Image.FromImage(FilialSemImagem)
	EndIF
	
	if not FilCpj.IsEmpty()
			&CnpjIeIm = 'CNPJ: ' + trim(FilCpj)
		EndIF
		&FilCpj = FilCpj
		If not FilInsEst.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IE: ' + trim(FilInsEst)
		EndIF
		
		If Not FilInsMun.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IM: ' + trim(FilInsMun)
		EndIF
	
	Exit
EndFor

MB 4
MT 2

&Reconhecer = 'Reconheço(emos) a exatidão desta DUPLICATA de Venda Mercantil com pagamento na importancia acima que pagarei(emos) á, '
&Reconhecer2 = &FilFan.Trim()+' indicados em sua ordem na praça e vencimento acima. '

For &SdtDuplicatasItem in &SdtDuplicatas
	For Each Order EmpCod,FilCod,CreCod
		Where EmpCod  = &SdtDuplicatasItem.EmpCod
		Where FilCod = &SdtDuplicatasItem.FilCod
		Where CreCod = &SdtDuplicatasItem.CreCod
		&CreCliEndCob = CreCliEndCob
		If Not CreNovCliRaz.Trim().IsEmpty()
			&CreCliRaz = CreNovCliRaz
		Else
			&CreCliRaz = CreCliRaz
		EndIf
		
		&CreDupNro = CreDupNro
		&CreVlrDup = CreVlrDup
		&CreCliCobCidNom = 'CEP: ' + CreCliCobCep.Trim() +' - '+ CreCliCobCidNom.Trim()
		&DtaEmissao = trim(str(Day(CreDtaEms)))+' de '+trim(CMonth(CreDtaEms))+' de '+trim(str(year(CreDtaEms)))
		
		&CidNom = retornaNomeCidadeFilial.udp(EmpCod, CreFilPgt)
		&Serverdate = serverdate()
		&DtaAceite = &CidNom.Trim() + ', ' + trim(str(Day(&Serverdate)))+' de '+trim(CMonth(&Serverdate))+' de '+trim(str(year(&Serverdate)))
		
		&CrePedCod = CrePedCod
		&CreDtaVct = CreDtaVct 
		&CreCliCod = CreCliCod
		If CreCliTip = TipoPessoa.JURIDICA
			&CreCliCnpj = CreCliCnpj 
		Else
			&CreCliCnpj = CreCliCpf
		Endif
		&VlrExt = PorExtenso.Udp(CreVlrDup)
		&AuxEmpCod = EmpCod
		&AuxFilCod = FilCod
		&AuxPedCod = CrePedCod
		
		&CreCbrBolMod = CreCbrBolMod
		Do 'ValorPedido'
		Exit
	Endfor
	
	Print CAbecalho
	print Duplicata
	Print Assinatura
	
	if &CreCbrBolMod = Modelo.Carne
		Eject
	Endif
EndFor



Sub 'ValorPedido'
	&PedVlrLiq = 0 
	For Each Order EmpCod,FilCod,PedCod
		Where EmpCod = &AuxEmpCod
		Where FilCod = &AuxFilCod
		Where PedCod = &AuxPedCod
		&PedVlrLiq = PedVlrLiq
		Exit
	EndFor

	if &AuxPedCod > 0 and &FilCpj.Length() > 14
		retornaNotaAutorizadaPedido.Call(&AuxEmpCod, &AuxFilCod, &AuxPedCod, &NfeNUm)
		&varNota = 'NF N°' + trim(toformattedString(&NfeNUm))
	Endif
EndSub
]]></Source>
