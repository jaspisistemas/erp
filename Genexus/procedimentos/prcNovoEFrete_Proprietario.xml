      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[// O conteúdo da tag Integrador deve ser uma CONSTANTE, pois é ela quem identifica seu sistema de gestão,
//Suporte e-FRETE:	Seguem credenciais para uso em ambiente de homologação:
//Integrador:		JASPI SISTEMAS DE INFORMÁTICA
//CNPJ:				21826923000177
//Usuário:			usuario@jaspi
//Senha:			usuario#jaspi
//Hash:				b754b48e-8c22-4cfc-bb0a-3524a76284c9

LoadWWPContext(&Context)
//Config do Servidor
HostWebServiceEfrete.Call(&EmpWebHost, &ExecuteUrl, '', '', &Hash)
&ExecuteURL			+= 'proprietarios/gravar'

&HttpClient.Host	= 	&EmpWebHost
&HttpClient.Secure	= 	1
	
//Header do JSON
&HttpClient.AddHeader(!'Content-Type', !'application/json')
&HttpClient.AddHeader(!'Accept-Encoding', !'gzip, deflate, br')

&IsCelular			= False
&IsTelefoneFixo		= False
&IsOk				= True
&Mensagem			= 'Os seguintes campos são obrigatórios e NÃO estão preenchidos: '
Do 'GetProprietario'

If &IsOk	= True
	&XMLBody	=	'{'
	&XMLBody	+=	'          "CNPJ": "'		+Trim(&XMLPesCPFCNPJ)	+'",'
	&XMLBody	+=	'          "TipoPessoa": "'	+Trim(&XMLPesTip)		+'",'		
	&XMLBody	+=	'          "RazaoSocial": "'+Trim(&XMLPesRaz)		+'",'
	&XMLBody	+=	'          "RNTRC": "'		+Trim(&XMLPesRNTRC)		+'",'
	&XMLBody	+=	'          "Endereco": {'
	&XMLBody	+=	'                  "Bairro": "'			+Trim(&XMLPesBai)			+'",'
	&XMLBody	+=	'                  "Rua": "'			+Trim(&XMLPesLog)			+'",'
	&XMLBody	+=	'                  "Numero": "'			+Trim(&XMLPesNro)			+'",'
	If Not &XMLPesCpl.IsEmpty()
		&XMLBody+=	'                  "Complemento": "'	+Trim(&XMLPesCpl)			+'",'
	EndIf
	&XMLBody	+=	'                  "CEP": "'			+Trim(&XMLPesCep)			+'",'
	&XMLBody	+=	'                  "CodigoMunicipio": "'+Trim(Str(&XMLPesCidIbge))	+'"'
	&XMLBody	+=	'          },'
	&XMLBody	+=	'          "Telefones": {'
	If &IsCelular = True
		&XMLBody+=	'                  "Celular": {'
		&XMLBody+=	'                          "DDD": "'	+Trim(Str(&XMLPesDD))		+'",'
		&XMLBody+=	'                          "Numero": "'	+Trim(&XMLPesFonNum)		+'",'
		If &IsTelefoneFixo = True
			&XMLBody+=	'                    },'
		Else
			&XMLBody+=	'                    }'
		EndIf
	EndIf
	If &IsTelefoneFixo = True
		&XMLBody+=	'                    "Fixo": {'
		&XMLBody+=	'                          "DDD": "'	+Trim(Str(&XMLFixoPesDD))	+'",'
		&XMLBody+=	'                          "Numero": "'	+Trim(&XMLFixoPesFonNum)	+'"'
		&XMLBody+=	'                    }'
	EndIf
	&XMLBody	+=	'          },'
	If Not &Token.IsEmpty()
		&XmlBody	+= 	'          "Token": "'+Trim(&Token)+'",'
	EndIf
	&XmlBody 	+= 	'          "Integrador": "'+ &Hash.Trim() +'",'
	&XmlBody 	+= 	'          "Versao": "3"'
	&XMLBody	+=	'}'
	
	&HttpClient.addString(Trim(&XMLBody))
	&HttpClient.Execute('POST', &ExecuteURL)
	
	padraoUsuario.Call('G', '#EFRETEPROPRIETARIO', &Context.PesCod, &Context.EmpCod, &XMLBody, &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
	
	If &HttpClient.StatusCode = 200
		&XMLBody = &HttpClient.ToString()
		
		&PosicaoSucesso = StrSearch(&XmlBody, '"Sucesso"')
		&PosicaoSucesso = &PosicaoSucesso + 11
		&Status = SubStr(&XmlBody, &PosicaoSucesso, 4)
		
		If &Status = 'true'
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", 'Proprietário gravado/alterado com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))
			&StatusRet = 200
		Else		
			&PosicaoSucesso = StrSearch(&XmlBody, '"Mensagem"')
			&PosicaoSucesso = &PosicaoSucesso + 13
			
			&PosicaoFinal	= StrSearch(&XmlBody, '"Codigo"')
			&PosicaoFinal	= &PosicaoFinal - &PosicaoSucesso - 8
			&Status			= SubStr(&XmlBody, &PosicaoSucesso, &PosicaoFinal)
			&StatusRet		= 0
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Proprietário!", 'Ocorreu um erro ao salvar o proprietário. ERRO: '+ Trim(&Status), DVMessageType.error, "", DVMessageBoolean.True,""))
		EndIf
		padraoUsuario.Call('G', '#EFRETEPROPRIETARIORESPOSTA', &Context.PesCod, &Context.EmpCod, &XMLBody, &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Proprietário!", &HttpClient.StatusCode.ToString() + ":" + &HttpClient.ErrDescription, DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf
Else
	Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", Trim(&Mensagem), DVMessageType.regular, "", DVMessageBoolean.True,""))
EndIf

Sub 'GetProprietario'
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &Context.EmpCod
		Where PesCod = &parmPesCod
		
		//Dados Gerais
		If PesTip = TipoPessoa.FISICA
			If PesCpf.IsEmpty() or PesCpf.IsNull()
				&Mensagem 	+= 'CPF do Proprietário; '
				&IsOk		= False
			Else
				&XMLPesCPFCNPJ 	= RetornaSoNumeros.Udp(PesCpf)
				&XMLPesTip		= 'Fisica'	
			EndIf
		Else
			If PesCnpj.IsEmpty() or PesCnpj.IsNull()
				&Mensagem 	+= 'CNPJ do Proprietário; '
				&IsOk		= False
			Else
				&XMLPesCPFCNPJ	= RetornaSoNumeros.Udp(PesCnpj)
				&XMLPesTip		= 'Juridica'
			EndIf
		EndIf
	
		If PesRaz.IsEmpty() or PesRaz.IsNull()
			&Mensagem 	+= 'Razão Social do Proprietário; '
			&IsOk		= False
		Else
			&XMLPesRaz		= PesRaz 
		EndIf
		If PesRntrc.IsEmpty() or PesRntrc.IsNull()
			&Mensagem 	+= 'RNTRC do Proprietário; '
			&IsOk		= False
		Else	
			&XMLPesRNTRC	= PesRntrc //Registro Nacional de Transportadores Rodoviários de Carga 
		EndIf
		
		//Endereço
		If PesBai.IsEmpty() Or PesBai.IsNull()
			&Mensagem 	+= 'Bairro de residência do Proprietário; '
			&IsOk		= False
		Else
			&XMLPesBai		= PesBai
		EndIf
		
		If PesLog.IsEmpty() or PesLog.IsNull()
			&Mensagem 	+= 'Rua de residência do Proprietário; '
			&IsOk		= False
		Else
			&XMLPesLog		= PesLog 
		EndIf
	
		If PesNro.IsEmpty() or PesNro.IsNull()
			&Mensagem 	+= 'Nro. da residência do Proprietário; '
			&IsOk		= False
		Else
			&XMLPesNro		= PesNro 
		EndIf
	
		&XMLPesCpl		= PesCpl
		
		If PesCep.IsEmpty() or PesCep.ISNull()
			&Mensagem 	+= 'CEP de residência do Proprietário; '
			&IsOk		= False
		Else
			&XMLPesCep		= PesCep 
		EndIf
		
		If PesCidIBGE.IsEmpty() or PesCidIBGE.IsNull()
			&Mensagem 	+= 'Código do Municipio de residência; '
			&IsOk		= False
		Else
			&XMLPesCidIbge	= PesCidIBGE 
		EndIf
		
		//Telefones
		For Each Order EmpCod, PesCod, PesFonCod
			Do Case
				Case PesFonTpo = TipoTelefone.CELULAR or PesFonTpo = TipoTelefone.CELULAR_WHATS
					If PesFonNum.IsEmpty() Or PesFonNum.IsNull()
						&Mensagem 	+= 'Informações de contato do Proprietário; '
						&IsOk		= False
					Else
						&IsCelular 			= True
						&XMLPesDD			= Val(SubStr(RetornaSoNumeros.Udp(PesFonNum), 1, 2))
						&XMLPesFonNum		= SubStr(RetornaSoNumeros.Udp(PesFonNum), 3, 20) 
					EndIf	
				Case PesFonTpo = TipoTelefone.COMERCIAL or PesFonTpo = TipoTelefone.RESIDENCIAL or PesFonTpo = TipoTelefone.OUTROS
					If PesFonNum.IsEmpty() Or PesFonNum.IsNull()
						&Mensagem 	+= 'Informações de contato do Proprietário; '
						&IsOk		= False
					Else
						&IsTelefoneFixo		= True
						&XMLFixoPesDD		= Val(SubStr(RetornaSoNumeros.Udp(PesFonNum), 1, 2))
						&XMLFixoPesFonNum	= SubStr(RetornaSoNumeros.Udp(PesFonNum), 3, 20) 
					EndIf
			EndCase
		EndFor
		
		Exit
	EndFor
	
EndSub
]]></Source>
