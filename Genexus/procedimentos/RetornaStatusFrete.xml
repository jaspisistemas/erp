      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&FrtItmVlrCal = 0
&IsErroValor = false

For Each Order EmpCod, FilCod, FrtCod, FrtItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where FrtCod = &FrtCod
	&FrtItmVlrCal += FrtItmVlrCal
EndFor

If &FrtItmVlrCal > 0
	For Each Order EmpCod, FilCod, FrtCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where FrtCod = &FrtCod
		
		&diferenca = FrtVlrCtb - &FrtItmVlrCal
		
		if &diferenca > 1 or &diferenca < -1
			&IsErroValor = true
			&Mensagem = 'SOMA DAS NOTAS DIFERE DO TOTAL DO CONHECIMENTO!'
			Exit
		Else
			If (FrtPlanCod.IsEmpty() or FrtPlanCod.IsNull() ) and FrtStsFin = Status_Financeiro.ABERTO
				&IsErroValor = true
				&Mensagem = 'PLANO DE CONTAS NÃO ADICIONADO!'
				Exit
			EndIF
		EndIF	
	EndFor
EndIF

if &IsErroValor = false
	For Each Order EmpCod, FilCod, FrtCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where FrtCod = &FrtCod
		
		If FrtPedFiLCod <> 0
			localizaPedidoNotaFrete.Call('P', FrtItmNot, EmpCod, FrtPedFiLCod, FrtNfeFilCod, FrtPedCod, FrtNfeCod, FrtNfeNum, FrtTraCod, FrtItmCte, FrtItmTip, FrtDtaLct, &gridPedCliCodRaz, &Mensagem, &IsgridErro, &IsErroTipFrt, &IsErroTraCod, &NfePedCod, &PedFilCod, &NfeCod, &CotObs, &CotVlr, &CotTraCodRaz, &CotNro, &IsErroJaLancado)
		Else
			localizaPedidoNotaFrete.Call('N', FrtItmNot, EmpCod, FrtPedFiLCod, FrtNfeFilCod, FrtPedCod, FrtNfeCod, FrtNfeNum, FrtTraCod, FrtItmCte, FrtItmTip, FrtDtaLct, &gridPedCliCodRaz, &Mensagem, &IsgridErro, &IsErroTipFrt, &IsErroTraCod, &NfePedCod, &PedFilCod, &NfeCod, &CotObs, &CotVlr, &CotTraCodRaz, &CotNro, &IsErroJaLancado)
		EndIF
		
		
		if &IsgridErro = true or &IsErroTipFrt = true or &IsErroTraCod = true
			Exit		
		EndIF
	When none
		&Mensagem = 'SEM PEDIDO EM ANEXO'	
	EndFor
EndiF

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
