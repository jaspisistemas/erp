      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&MDFeArqXml.SetEmpty()
&IsSucesso = False
do 'PegaArquivoXML'

If not &MDFeArqXml.Trim().IsEmpty()
	&HttpClient.Host = 'webserver.averba.com.br' //servidor
	&HttpClient.timeout = 5
	&HttpClient.Secure = 0
	//&httpclient.AddHeader(!'Accept-Encoding',!'gzip,deflate')
	&httpclient.AddHeader(!'Connection',!'Keep-Alive')
	&httpclient.AddHeader(!'Accept',!'application/json')
	&httpclient.AddHeader(!'Content-type',!'application/json')
	&HttpClient.AddString(&SdtAtm.ToJson())
	&String = '/rest/Auth' 
	&HttpClient.Execute('POST',&String)
	
	padraoUsuario.Call('G', '#AVERBAATMMDFE', &Context.PesCod, &Context.EmpCod, &HttpClient.ToString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
	
	If &HttpClient.ErrCode = 0 //sem erro de comunicação
		&Bearer.fromJson(&HttpClient.ToString())
		
		If not &Bearer.Bearer.IsEmpty()
			//####################################################### AVERVA CTE #######################
			&HttpClient.Host = 'webserver.averba.com.br' //servidor
			&HttpClient.timeout = 5
			&HttpClient.Secure = 0
			&HttpClient.AddHeader(!'Authorization','Bearer '+&Bearer.Bearer.ToString())
			&httpclient.AddHeader(!'Connection',!'Keep-Alive')
			&httpclient.AddHeader(!'Accept',!'application/xml')
			&httpclient.AddHeader(!'Content-type',!'application/xml')
			&HttpClient.AddString(&MDFeArqXml)
			&String = '/rest/MDFe' 
			&HttpClient.Execute('POST',&String)
			
			padraoUsuario.Call('G', '#AVERBAATMMDFE', &Context.PesCod, &Context.EmpCod, &HttpClient.ToString(), &PadDtaMod)
			&longvarchar = ''
			If &HttpClient.ErrCode = 0 //sem erro de comunicação
				&longvarchar = &HttpClient.ToString()
				&longvarchar = &longvarchar.Replace('SdtRetornoAverbacao xmlns="ERP"','Retorno')
				&longvarchar = &longvarchar.Replace('SdtRetornoAverbacao','Retorno')
				
				&SdtRetornoAverbacaoMdfe.FromXml(&longvarchar.ToString())
				padraoUsuario.Call('G', '#AVERBAATMMDFE2', &Context.PesCod, &Context.EmpCod, &SdtRetornoAverbacao.ToXml(), &PadDtaMod)
				
				If not &SdtRetornoAverbacaoMdfe.Declarado.Protocolo.IsEmpty()
					GravaAverbacaoMdfe.Call(&EmpCod,&FilCod,&MdfeCod,&SdtRetornoAverbacaoMdfe) 
					&IsSucesso = True
				Else
					&erroMensagem = 'Erro! Averbação sem Protocolo.'
				EndIf
			Else
				&erroMensagem = 'Autenticado mas com Erro na Averbação!'
			EndIf
		Else
			&erroMensagem = 'ATENÇÃO! "Bearer" está vazio contate o suporte!'
		EndIf
	Else
		&erroMensagem = 'Erro na comunicação!'
	EndIf
Else
	&erroMensagem = 'Arquivo XML do MDF-e não encontado!'
EndIf

Sub 'PegaArquivoXML'
	For Each Order EmpCod,FilCod,MDFeCod
		Where EmpCod = &EmpCod
		where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		Do Case
			Case MDFeSts = Status_Nfe.Autorizada
				&MdfeArqXml = MDFeArqXml
			Case MDFeSts = Status_Nfe.Cancelada
				&MdfeArqXml = MDFeArqXml
		EndCase			
		Exit
	Endfor
EndSub


]]></Source>
