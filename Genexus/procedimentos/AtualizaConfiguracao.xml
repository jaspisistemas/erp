      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	if FilTConCod.IsEmpty() or FilTConCod.IsNull()
		FilTConCod = 1
		&TConCod = 1
		Commit
	Else
		&TConCod = FilTConCod
	EndIF	
	
	Exit
EndFor
RetornaConfSistema.Call(&EmpCod, &FilCod, &domConfSistema, &auxCfgVlr)


//GRAVA LOG
&TabelaVarchar = 'CONFSISTEMA'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
&LogErpRegCod1 = trim(Str(&TConCod))
&LogErpRegTip = TrnMode.Update
&LogErpRegGUID.SetEmpty()	
	
For Each Order EmpCod, TConCod
	Where EmpCod = &EmpCod
	Where TConCod = &TConCod
	
	Do Case		
		Case &domConfSistema = domConfSistema.Tcon002_FilialFaturamento
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TCon002', trim(toformattedString(TCon002)), trim(&CfgVlr), &LogErpRegGUID )
			Endif
			//GRAVA LOG
			
			TCon002 = val(&CfgVlr)
		Case &domConfSistema = domConfSistema.TCon008_DiasVenceGNRE
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TCon008', trim(toformattedString(TCon008)), trim(&CfgVlr), &LogErpRegGUID )
			Endif
			//GRAVA LOG
			
			TCon008 = val(&CfgVlr)
		Case &domConfSistema = domConfSistema.TCon099_DownloadAutomatico	
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TCon099', trim(TCon099.ToString()), trim(&CfgVlr), &LogErpRegGUID )
			Endif
			//GRAVA LOG
			
			TCon099.FromString(&CfgVlr)
	EndCase
	Exit
EndFor


commit
]]></Source>
