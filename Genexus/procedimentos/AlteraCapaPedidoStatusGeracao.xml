      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	PedFicCod = &PedFicCod
	PedStsGer = &PedStsGer
	Exit
EndFor

Commit

if not &PedFicCod.IsEmpty()
	For Each Order EmpCod, FicCod
		Where EmpCod = &EmpCod
		Where FicCod = &PedFicCod
		FicPedCod = &PedCod
		Exit
	EndFor
	Commit
EndIF
]]></Source>
