      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsPagto = false
&PedItmPagQtdTot = 0
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where PedCod = &PedCodOciRef
	Where PedSts = Status_Pedido.ABERTO
	where PedItmPagVlrTot > 0 or PedItmPagQtdTot > 0
	&PedItmPagQtdTot = PedItmPagQtdTot
	Exit
EndFor
]]></Source>
