	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	ValidaRegrasFrete.Call(EmpCod, PedTipFrt, PedDtaEms, PedVlrLiq, TabCod, TabPrmCod, PedCliCod, PedPerFrt, PedFrtFix, 'R', &RedespachoMensagem)
