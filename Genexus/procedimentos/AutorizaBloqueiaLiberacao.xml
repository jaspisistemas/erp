      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do Case
	Case &OqueFazer = 'AUT'
		For Each Order EmpCod, FilCod, PedCod, PedLibItm
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedLibItm = &PedLibItm
			
			&PedLIbSts = PedLibSts
			
			PedLibAutPedQtd = &PedLibAutPedQtd
			PedLibAutPedDesc = &PedLibAutPedDesc
			PedLibAutPedVlr = &PedLibAutPedVlr
			PedLibAutObs = &PedLibAutObs
			PedLibAutDta = serverNow()
			PedLibAutFun = &PesCod
			PedLIbRea = 0
			PedLibSts = StatusLiberacao.Autorizado
			
			&ProCod = PedLibProCod
			&PRoGraCod = PedLibProGraCod
			&PedCliCod = PedLibCliCod
			&PedQtd = &PedLibAutPedQtd
			&PedItmDsc = &PedLibAutPedDesc
			&PedVlrUnt = &PedLibAutPedVlr
			
			Exit
		EndFor
		
		Commit
		
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedCliCod = &PedCliCod
			Where ProCod = &PRoCod
			Where ProGraCod = &ProGraCod
			
			Do Case
				CAse &PedItmDsc > 0
					&PedVlrUnt = PedVlrTab
				CAse &PedVlrUnt > 0
					&PedItmDsc = 0
				Otherwise
					&PedVlrUnt = PedVlrUnt
					&PedItmDsc = PedItmDsc
			EndCAse
			
			if &PedQtd = 0
				&PedQtd = PedQtd
			EndIf
			
			&OldPedItmDsc = PedItmDsc
			&OldPedVlrUnt = PedVlrUnt
			&OldPedQtd = PedQtd
			
			GravaItemPedidoVenda.Call(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod, &PedQtd, PedQtdCan,0, &PedVlrUnt, PedVlrTab, &PedItmDsc, PedItmCmp, PedItmVenCod, PedCodOciRefItm, &MensagemInserido, &MensagemAlterado, &wwpContextUserName)
			Exit
		EndFor
		
		Commit
		
		If &PedLIbSts <> StatusLiberacao.Autorizado
			For Each Order EmpCod, FilCod, PedCod
				Where EmpCod = &EmPCod
				Where FilCod = &FilCod
				Where PedCod = &PedCod
				Where PedLibItm = &PedLibItm
				
				PedLibOldPedQtd = &OldPedItmDsc
				PedLibOldPedVlr = &OldPedVlrUnt
				PedLibOldPedQtd = &OldPedQtd
				
				Exit
			EndFor
			
			commit
		EndIF	
		
	Case &OqueFazer = 'BLO'
		For Each Order EmpCod, FilCod, PedCod, PedLibItm
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedLibItm = &PedLibItm
			
			PedLibAutPedQtd = &PedLibAutPedQtd
			PedLibAutPedDesc = &PedLibAutPedDesc
			PedLibAutPedVlr = &PedLibAutPedVlr
			PedLibAutObs = &PedLibAutObs
			PedLibAutDta = serverNow()
			PedLibAutFun = &PesCod
			PedLIbRea = 0
			PedLibSts = StatusLiberacao.NaoAutorizado
			
			Exit
		EndFor
		
		Commit
		
	Case &OqueFazer = 'BRE' //BLOQUEIA REAVALIACAO
		For Each Order EmpCod, FilCod, PedCod, PedLibItm
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedLibItm = &PedLibItm
			
//			PedLibAutPedQtd = &PedLibAutPedQtd
//			PedLibAutPedDesc = &PedLibAutPedDesc
//			PedLibAutPedVlr = &PedLibAutPedVlr
			PedLibAutObs = &PedLibAutObs
			PedLibAutDta = serverNow()
			PedLibAutFun = &PesCod
			PedLIbRea = 0
			
			Exit
		EndFor
		
		Commit
Endcase



]]></Source>
