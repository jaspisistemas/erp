      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaVersaoNotas.Call(VersaoNota.VersaoNFe_4, &Versao)

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

If &DeOndeVem = 'WWMANIFESTACAO' or &DeOndeVem = 'WWMANIFESTACAO1'
	do 'TableManifestacao'
Else	
	Do 'TableNota'
	
	prcCopiaEnvioEnviado.Call(&EmpCod, &FilCod, &NfeCod)
	//CASO JA ESTEJA AUTORIZADO E NAO TENHA O ARQUIVO .XML AUTORIZADO. JDF, nao funcionou
//	if &IsEnviaProcessamento = true
//		if &ModCod = '55'
//			geraXmlNfeModelo55_4.Call(&EmpCod, &FilCod, &NfeCod, 'S', -1, 'P',  &SolCod)
//		Else
//			geraXmlNfeModelo65_4.Call(&EmpCod, &FilCod, &NfeCod, 'S', -1, 'P', &SolCod)
//		Endif
//	Endif
EndIf

commit

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + trim(&NfeChv) + '-ped-sit.xml'

// Abrir o arquivo XML
&ArqNota.Open(&Nome_enviar)
&ArqNota.WriteStartDocument('UTF-8')
&ArqNota.Indentation = 0

&ArqNota.WriteStartElement('consSitNFe')
&ArqNota.WriteAttribute('versao',&Versao)
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')

&ArqNota.WriteElement('tpAmb',&sdtConfiguracoesPasta.FilAmbEms)
&ArqNota.WriteElement('xServ','CONSULTAR')
&ArqNota.WriteElement('chNFe', &NfeChv)
&ArqNota.WriteEndElement()
&ArqNota.Close()

If &DeOndeVem = 'WWMANIFESTACAO' or &DeOndeVem = 'WWMANIFESTACAO1'
	GravaSolicitacao.Call(&EmpCod, &FilCod, &NfeCod, 0, TipoSolicitacao.Consulta_SEFAZ_DFE, &PesCod, &SolCod)
Else	
	GravaSolicitacao.Call(&EmpCod, &FilCod, &NfeCod, 0, TipoSolicitacao.Consulta_SEFAZ, &PesCod, &SolCod)
EndIf

Sub 'TableNota'
	&IsEnviaProcessamento = false
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&ModCod = ModCod
		&NfeChv = NfeChv
		
		if NfeSts = Status_NFe.Digitando and (not NfeNum.IsEmpty() and not NfeNum.IsNull())
			&IsEnviaProcessamento = true
		Endif
	
		Exit
	EndFor
EndSub

Sub 'TableManifestacao'
	For Each Order EmpCod, ManCod
		Where EmpCod = &EmpCod
		Where ManCod = &NfeCod
		Where ManFilCod = &FilCod
		&NfeChv = ManCha
		Exit
	EndFor
EndSub
]]></Source>
