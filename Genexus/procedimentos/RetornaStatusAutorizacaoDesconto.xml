      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Total = 100
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

Do while &Percentual < 100		
	
	For Each ORder EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		For Each Order EmpCod, FilCod, PedCod, PedLibTip
			Where PedLibTip = &PedLibTip
			Where PedLibCliCod = &PedLibCliCod
			Where PedLibProCod = &PedLibProCod
			Where PedLibProGraCod = &PedLibProGraCod
			
			If PedLibSts = StatusLiberacao.Autorizado and PedLIbRea = 0
				&Percentual += 100
				&ProgressLogXml = 'SOLICITAÇÃO APROVADA!'
				do 'Atualiza'
			Else
				Do CAse
					Case PedLibSts = StatusLiberacao.NaoAutorizado and PedLIbRea = 0
						&Percentual += 100
						&ProgressLogXml = 'SOLICITAÇÃO RECUSADA!'
						do 'Atualiza'
						
					Case PedLIbRea = 1
						//&AvisoSolicitacao = 'EM REAVALIAÇÃO'
						&ProgressLogXml = 'Aguardando Reavaliação...'
						
					Otherwise						
						&ProgressLogXml = 'Solicitação ainda pendente...'
						//&AvisoSolicitacao = 'SOLICITAÇÃO PENDENTE'
				EndCAse
			EndiF
		
			Exit
		EndFor
		
		Exit
	Endfor

	if &Percentual < 100
		&Percentual += 10
		do 'Atualiza'
		
		&Dorme = Sleep(1)
	Endif
Enddo
	
&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &ProgressLogXml
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor

	commit
EndSub
]]></Source>
