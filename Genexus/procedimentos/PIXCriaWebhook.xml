      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[/*
ENDPOINT para a configuração do serviço de notificações acerca de PIX recebidos. 
Somente PIX associados a um txid serão notificados.
	transactionId (txid): identificador único da transação, na perspectiva do usuário recebedor,
	para conciliação de pagamentos recebidos por meio de PIX.
	usuário recebedor: pessoa natural ou jurídica que deseja receber cobranças.
	
Neste ENDPOINT o sistema vai definir a senha '1234' para os certificados que irão no header
da requisição. Posteriormente, será montado o header para a criação. Alguns bancos possuem 
header's especificos, portanto é necessário algumas validações. Posteriormente, irá adicionar
o certificado ao header e executará um PUT na url referente ao banco e o ambiente trabalhado
para então ser criado o webhook.

Responses:
	Sucesso:
		Code 200 = Webhook para notificações acerca de PIX registrado.
	
	Erros:
		Code 400 = Requisição com formato inválido, por exemplo erro de semântica.
		Code 403 = Requisição de participante autenticado que viola alguma regra de autorização. Verifique com o suporte do banco.
		Code 404 = Recurso solicitado não foi encontrado.
		Code 503 = Serviço não disponível no momento. O endpoint neste caso não funciona mais, ou está em manutenção.
*/
&Mensagem	= ''
Do 'GetContaBancaria'

&Password	= '1234'
&LongVarChar	= &PixPutWebhook.ToJson()

If &OAuthMensagem.IsEmpty()
	&HttpClient.AddHeader('Content-Type', 'application/json')
	&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
	&HttpClient.AddHeader('Connection', 'keep-alive')
	&HTTPClient.AddHeader('Authorization', 'Bearer ' + &CbrChaTra.Trim())
	&HttpClient.AddString(&LongVarChar)
	&Execute	+= '/' + &CbrCtaBanPix
	
	CSHARP try
	CSHARP { [!&HttpClient!].AddCertificate([!&PathCert!],[!&Password!]); }
	CSHARP catch (Exception ex)
	CSHARP { [!&ErrorDescription!] = ex.ToString();
	CSHARP }
	
	&HttpClient.Execute('PUT', &Execute)
	If &HttpClient.StatusCode = 200 Or &HttpClient.StatusCode = 201
		&IsWebhookCadastrado	= True
		Do 'AtualizaWebhook'
	Else
		&PixResponseErro.FromJson(&HttpClient.ToString())
		If &Mensagem.IsEmpty()
			&Mensagem	= IIf(&PixResponseErro.detail.IsEmpty(), 'ERRO Criação ' + Trim(Str(&HttpClient.StatusCode)) + ' - ' + &HttpClient.ToString(), 'ERRO Emissão ' + Trim(Str(&HttpClient.StatusCode)) + ' - ' + &PixResponseErro.detail)
			&Mensagem	+= IIf(&ErrorDescription.IsEmpty(), '', ' - Erro CSHARP:' + &ErrorDescription.Trim())
		EndIf
		padraoUsuario.Call('G', 'PUTWEBHOOKJSON_ERRO' + Time(), &PesCod, &EmpCod, &Mensagem, ServerDate())
	EndIf
EndIf

Sub 'AtualizaWebhook'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
				
		CbrWebhookPix	= &PixPutWebhook.webhookUrl
		
		Exit
	EndFor
	Commit
		
EndSub

Sub 'GetContaBancaria'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&Path			= PathToUrl(CtaBanPixCer)
		&InicioPath		= StrSearch(&Path, 'PublicTempStorage', 1)
		&Path			= SubStr(&Path, &InicioPath, &Path.Length())
		&File.Source	= &Path
		&PathCert		= &File.GetAbsoluteName()
		&PathCert		= StrReplace(&PathCert, '/', '\')
		&File.Close()		
		
		Do Case
			Case CbrCtaBanBanCod = '748'
				prcOAuth_SicrediPIX.Call(&EmpCod, &PesCod, CbrCod, &CbrChaTra, &Mensagem)
				&Execute	= IIf(CbrCtaBanPixApi = 'P', 'https://api-pix.sicredi.com.br/api/v2/webhook', 'https://api-pix-h.sicredi.com.br/api/v2/webhook')
			Case CbrCtaBanBanCod = '756'
				&Execute	= IIf(CbrCtaBanPixApi = 'P', 'https://api.sicoob.com.br/pix/api/v2/webhook', 'https://api.sicoob-h.com.br/pix/api/v2/webhook')
				&HttpClient.addHeader('client_id', CtaBanPixCliId)
			Case CbrCtaBanBanCod = '077'
				prcOAuth_Inter.Call(&EmpCod, 0, &PesCod, CbrCod, &CbrChaTra, &Mensagem)			
				&Execute	= IIf(CbrCtaBanPixApi = 'P', 'https://cdpj.partners.bancointer.com.br/pix/v2/webhook', 'https://cdpj-sandbox.partners.uatinter.co/pix/v2/webhook')
				&HttpClient.AddHeader('x-conta-corrente', CbrNroCon.Trim() + CbrNroConDig.Trim())
		EndCase
		
		Exit
	EndFor

EndSub
]]></Source>
