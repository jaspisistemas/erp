      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, TalCtabanCod, (TalCod)
	Where EmpCod = &EmpCod
	Where TalCtabanCod = &TalCtabanCod
	&TalCod = TalCod
	Exit
EndFor
&TalCod += 1

new //GRAVA TALAO
	EmpCod    = &EmpCod
	TalCod    = &TalCod
	TalFolIni = &TalFolIni
	TalFolfin = &TalFolfin
	TalFolQtd = &TalFolQtd
	TalObs    = &TalObs
	TalDTaEnt = &TalDTaEnt
	TalCtabanCod = &TalCtabanCod
EndNew

//GRAVA FOLHAS
For Each Order EmpCod, (CheCod)
	where EmpCod = &EmpCod
	&CheCod = CheCod
	Exit
EndFor

For &i = &TalFolIni to &TalFolfin step 1
	
	&CheCod += 1	
	new
		EmpCod = &EmpCod
		CheCod = &CheCod
		CheTip = TipoCheque.Proprio
		TalCod = &TalCod
		TalCtabanCod = &TalCtabanCod
		CheBanCod = &TalCtaBanBanCod
		CheAgeCod = val(retornaSoNumeros.Udp(&TalCtaBanAge))
		CheCon = &TalCtaBanCrt
		CheNro = &i
		CheVarNro = 'CHQ-'+ trim(str(&i))
		CheMot = MotivoCheque.NAOEMITIDO
	EndNew
EndFor

Commit
]]></Source>
