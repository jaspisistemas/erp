      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&EmpCodSec = &sdtReceivedCte.EmpCodSec

do 'validaEntrada'
do 'buscaPessoa'
do 'downloadArquivos'

if not (&EmpCodSec.IsEmpty() or &EmpCod.IsEmpty() or &FilCod.IsEmpty())
	for &path in &paths
		GravaCteComPdf(&EmpCod, &FilCod, &CteCod, &path, false, 0, &IsSucess, &erroMensagem)
		
		if &CteCod > 0
			//Fazer um update para X para poder ficar como pendente e depois apagar automaticamente caso nao tenha.
			for each order EmpCod, FilCod, CteCod
				where EmpCod = &EmpCod
				where FilCod = &FilCod
				where CteCod = &CteCod
				
				CteSts = Status_NFe.Importada
				
				exit
			endfor
			
			if not &IsSucess
				&RestCode = 400
				&sdtResponseCte.message = format('Erro CTe[%1] %2',trim(&CteCod.ToString()),trim(&erroMensagem))
			endif
		else
			&RestCode = 400
			&sdtResponseCte.message = format('Erro CTe %1',trim(&erroMensagem))
		endif
	endfor
else
	&RestCode = 404
	&sdtResponseCte = new()
	&sdtResponseCte.message = 'Cadastro não localizado'
endif

sub 'validaEntrada'
	do case
		case &sdtReceivedCte.EmpCodSec.IsEmpty()
			&RestCode = 400
			&sdtResponseCte = new()
			&sdtResponseCte.message = 'Informe a empresa'
			return
			
		case &sdtReceivedCte.ctes.IsEmpty()
			&RestCode = 400
			&sdtResponseCte = new()
			&sdtResponseCte.message = 'CT-e não informado'
			return
	endcase
	
	&pathsToDownload = &sdtReceivedCte.ctes.SplitRegEx('\n')
	
	if &pathsToDownload.Count = 0
		&RestCode = 400
		&sdtResponseCte = new()
		&sdtResponseCte.message = 'CT-e informado é inválido'
		return
	endif
	
EndSub

Sub 'buscaPessoa'
	for each Empresa order EmpCod
		where EmpCodSec = &EmpCodSec
		
		&EmpCod = EmpCod
		&FilCod = 1
		
		exit
	when none
		&EmpCod.SetEmpty()
	endfor
EndSub

Sub 'downloadArquivos'
	&sdtConfiguracoesPasta = retornaConfiguracoesPastas(&EmpCod,&FilCod)
	
	gravalogDev(&EmpCod,&FilCod,&logguid,'','&pathsToDownload',&pathsToDownload.toJson())
	
	for &forPath in &pathsToDownload
		&HttpClient.Execute(HttpMethod.Get,&forPath)
		
		if &HttpClient.ErrCode = 0 and &HttpClient.GetHeader('Content-Type') = 'application/pdf'
			&path = &sdtConfiguracoesPasta.PastaDiretorioTempFis + GUID.newGuid().ToString().Trim() + '.pdf'
			&HttpClient.ToFile(&path)
			gravalogDev(&EmpCod,&FilCod,&logguid,'','downloadArquivos',&path)
			
			&paths.Add(&path)
		else
			&RestCode = 400
			&sdtResponseCte = new()
			&sdtResponseCte.message = 'Falha ao fazer download de ' + &forPath
			return
		endif
		
		gravalogDev(&EmpCod,&FilCod,&logguid,'','&HttpClient.ErrDescription',&HttpClient.ErrDescription)
	endfor
EndSub
]]></Source>
