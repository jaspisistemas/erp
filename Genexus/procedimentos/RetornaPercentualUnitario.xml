      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &pedCod
	
	&PedVlrFrt = (PedVlrFrt + PedVlrOut)
	
	&PedVlrDscGlb = PedVlrDscGlb
	
	&DescontoPercentual = 0
	if &PedVlrDscGlb > 0 and PedVlrBrt > 0
		&DescontoPercentual = &PedVlrDscGlb / PedVlrBrt
	EndIF
	
	
	&AcrescimoPercentual = 0
	if &PedVlrFrt > 0 and PedVlrBrt > 0
		&AcrescimoPercentual = &PedVlrFrt / PedVlrBrt
	EndIF
	Exit
EndFor



]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
