      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod 
	&PesRaz = PesRaz
	&PesLog = 'END: ' + trim(PesLog) + ', ' + trim(PesNro) + ' - ' + trim(PesBai)
	&PesCidNom = 'CIDADE: ' + trim(PesCidNom) + ' - ' + trim(PesCidUfeCod) + ' CEP: ' + trim(PesCep)
	
	if PesTip = TipoPessoa.JURIDICA
		If not PesCnpj.IsEmpty()
			&Contato = 'CNPJ: '+ trim(PesCnpj) 
		EndIF	
	Else
		If not PesCpf.IsEmpty()
			&Contato = 'CPF: '+ trim(PesCpf) 
		EndIF	
	EndIF

	if not PesInsEst.IsEmpty()
		&Contato += ' IE: ' + trim(PesInsEst)
	EndIF	
	&Contato = &Contato.Trim()
	
	If not PesPrmFon.IsEmpty()
		&Contato2 += ' F: ' + trim(PesPrmFon)
	EndiF		

	For Each Order EmpCod, PesCod, PesEmlCod
		&Contato2 += ' @: ' + trim(PesEml)
		Exit
	EndFOr

	if Not PesSit.IsEmpty()
		&Contato2 += ' SITE: ' + trim(PesSit)
	EndiF
	&Contato2 = &Contato2.Trim()
	
	Exit
EndFor
]]></Source>
