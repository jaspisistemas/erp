      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'IMPRESSÃO DOS PRODUTOS MODIFICADOS'
	print Cabecalho
End

If &ProPadForCod <> 0
	&Filtro += ' FORNECEDOR.:' + trim(str(&ProForCod))
Else
	&Filtro += 'TODOS FORNECEDORES'
EndIF

If NOT &GrupHie.trim().IsEmpty()
	&Filtro += ' GRP HIERARQUIA:' + trim(&GrupHie)
Else
	&Filtro += ' GRP: TODOS'
EndIF
Print Filtro

Do 'Title'
Print Menu
 &ColGrupCod = RetornaCollGrupoProduto.udp(&EmpCod,&GrupHie)

For Each Order EmpCod ProForCod ProRef 
	Where EmpCod    = &EmpCod
	Where ProForCod = &ProForCod
    Where ProCod    = &ProCod when not &ProCod.IsEmpty()
	Where GrupCod in &ColGrupCod when not &GrupHie.IsEmpty()
	
       If &IsDesconto = true
           ProForDsc = &ProForDsc
       EndIf       
       If &IsAcrescimo = true
           ProForAcr = &ProForAcr
       EndIf       
   		If &IsNewDesconto = true
           ProForRatDsc = &ProForRatDsc
       EndIf       
       If &IsNewAcrescimo = true
           ProForRatAcr = &ProForRatAcr
       EndIf       
   
       If &IsST = true
           ProForIcmSt = &ProForIcmSt
       EndIf       
       If &IsIpi = true
           ProForIpi = &ProForIpi
       EndIf       
       If &IsCusto = true
		   ProForVlrCus = ProForVlrCus + ((ProForVlrCus * &ProForVlrCus) / 100)
       EndIf
	
	commit
	
	ProVlrCus_Produto.Call(EmpCod, ProCod)
EndFor

do 'Printer'

Do 'Confirmado'
Print Mensg

Footer
	print Rodape
End
Sub 'Title'
	&Col1 = 'Desconto'		
	&Col2 = 'Acréscimo'
	&Col3 = 'S.T.'
	&Col4 = 'IPI'
	&Col5 = 'Custo Uni.'
	&col6 = 'Custo Final'
EndSub

Sub 'Confirmado'
	&mensagem = ''
	&mensagem = 'Confirmada a alteração de valores do produto do fornecedor '	
	If &IsDesconto = true
		&mensagem += Newline() + 'DESCONTO: '+ trim(toformattedString(&ProForDsc)) + '%'
	EndIF
	If &IsAcrescimo = true
		&mensagem += Newline() + 'ACRÉSCIMO: '+ trim(toformattedString(&ProForAcr)) + '%'
	EndIF
	If &IsNewDesconto = true
		&mensagem += Newline() + 'Rateio DESCONTO: '+ trim(toformattedString(&ProForRatDsc)) + '%'
	EndIF
	If &IsNewAcrescimo = true
		&mensagem += Newline() + 'Rateio ACRÉSCIMO: '+ trim(toformattedString(&ProForRatAcr)) + '%'
	EndIF
	If &IsST = true 
		&mensagem += Newline() + 'ICMS/S.T.: '+ trim(toformattedString(&ProForIcmSt)) + '%'
	EndIF
	If &IsIpi = true 
		&mensagem += Newline() + 'IPI '+ trim(toformattedString(&ProForIpi)) + '%'
	EndIF
	If &IsCusto = true and &ProForVlrCus <> 0
		&mensagem += Newline() + 'CUSTO '+ trim(toformattedString(&ProForVlrCus)) + '%'
	EndIF
	&mensagem = &mensagem.ToUpper()
EndSub

Sub 'Printer'
	For Each Order EmpCod ProForCod ProRef 
		Where EmpCod    = &EmpCod
		Where ProForCod = &ProForCod
	    Where ProCod    = &ProCod when not &ProCod.IsEmpty()
		Where GrupCod in &ColGrupCod when not &GrupHie.IsEmpty()
		Print Dados
	EndFor
EndSub
]]></Source>
