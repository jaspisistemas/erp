      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TabCod.SetEmpty()
&TabPrmCod.SetEmpty()
&TabColCod.SetEmpty()

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	
	if FilBalTabCod.IsEmpty() or FilBalTabCod.IsNull()
		FilBalTabCod = FilTabCod
		FilBalTabPrmCod = FilTabPrmCod
		FilBalTabColCod = FilTabColCod
		
		Commit
	EndIF
	
	&TabCod = FilBalTabCod
	&TabPrmCod = FilBalTabPrmCod
	&TabColCod = FilBalTabColCod
	
	If &TabColCod.IsEmpty()
		&TabColCod = 1
	EndIF
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
