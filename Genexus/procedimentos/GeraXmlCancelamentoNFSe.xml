      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
retornaConfiguracoesPastas.Call(&EmpCOd, &NfsFilCod, &sdtConfiguracoesPasta)
&hoje = serverdate()    
&VersaoNF = '1.01'

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCOd
	Where FilCod = &NfsFilCod
	&FilCpj = retornaSoNumeros.Udp(FilCpj)
	
	&FilAmbEmsNFSer = FilAmbEmsNFSer
	&FilFusHor = FilFusHor
	&EmpVEr = EmpVer
	
	Exit
EndFor

		
For Each Order EmpCod, NfsCod
	Where EmpCod = &EmpCOd
	Where NfsCod = &NfsCod
	
	NfsMotCan = &NfsMotCan
	NfsMotObs = &NfsMotObs
	
	&NfsChv = retornaSONUmeros.Udp(NfsChv)
		
    Exit
EndFor

commit


//CANCELA ARQUIVOS RETORNOS
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim()+ trim(&NfsChv)+'-env-canc.err'    
&File.Source = &Nome_retorno_erro
If &File.Exists()
    &File.Delete()
EndIf

&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim()+ trim(&NfsChv)+'-ped-cannfse.xml'
&File.source = &Nome_retorno_correto
IF &File.Exists()
    &File.Delete()
EndIf

//GRAVA ARQUIVO CANCELAMENTO .XML
&ano = str(YEAR(&hoje))
&mes = str(MONTH(&hoje))
&dia = str(DAY(&hoje))
//&hojeHora = servernow()
&NfsHorEms = ServerTime()
//&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hceojeHora))),2, '0') + ':00'

&id = 'PRE' + &NfsChv + '101101'//001' //“ID” + tpEvento + chave da NF-e + nSeqEvento

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFSenvio.Trim() + trim(&NfsChv) + '-ped-cannfse.xml'

&ArqNota.Open(&Nome_enviar) //ABRE DOC xml
&ArqNota.WriteStartDocument('UTF-8') //START DOC xml

&ArqNota.WriteStartElement('pedRegEvento')
&ArqNota.WriteAttribute('versao',&VersaoNF) //Versão do leiaute
&ArqNota.WriteAttribute('xmlns','http://www.sped.fazenda.gov.br/nfse')

&ArqNota.WriteStartElement('infPedReg') //Evento, um lote pode conter até 20 eventos
&ArqNota.WriteAttribute('xmlns','http://www.sped.fazenda.gov.br/nfse')
&ArqNota.WriteAttribute('Id',&id) //Chave da nota

&ArqNota.WriteElement('tpAmb', &FilAmbEmsNFSer) //Identificação do Ambiente: 1=Produção /2=Homologação
&ArqNota.WriteElement('verAplic', &EmpVer)

&ArqNota.WriteElement('dhEvento',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' + &NfsHorEms + '-' + trim(&FilFusHor)) //Data e hora do evento no formato AAAA-MM-DDThh:mm:ssTZD 
If &FilCpj.Length() > 11
	&ArqNota.WriteElement('CNPJAutor', &FilCpj) //Informar o CNPJ ou o CPF do autor do Evento
Else
	&ArqNota.WriteElement('CNPJAutor', &FilCpj) //Informar o CNPJ ou o CPF do autor do Evento
EndIf

&ArqNota.WriteElement('chNFSe', &NfsChv) //Chave de Acesso da NF-e vinculada ao Evento   
//&ArqNota.WriteElement('nPedRegEvento', '001')

&ArqNota.WriteStartElement('e101101')
&ArqNota.WriteElement('xDesc', 'Cancelamento de NFS-e') //Cancelamento

&ArqNota.WriteElement('cMotivo', &NfsMotCan) //Codigo cancelameno
&ArqNota.WriteElement('xMotivo', &NfsMotObs) //MOtivo
&ArqNota.WriteEndElement() //e101101

&ArqNota.WriteEndElement() //infPedReg
&ArqNota.WriteEndElement() //pedRegEvento

&ArqNota.Close()

GravaSolicitacao.Call(&EmpCod, &NfsFilCod, &NfsCod, 0, TipoSolicitacao.Cancelar_NFSE, &ContextPesCod, &SolCod)
]]></Source>
