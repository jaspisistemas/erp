      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SdtPodutoLote.Clear()

For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstLotCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGraCod > 1

	&IsAchou = false
	For &SdtPodutoLoteItem in &SdtPodutoLote
		if &SdtPodutoLoteItem.PedProEstLotCod = EstLotCod
			if &OqueFazer = 'A'
				&SdtPodutoLoteItem.PedProEstLotQtd += EstLotQtd
			Else
				&SdtPodutoLoteItem.PedProEstLotQtdAux += EstLotQtd
			Endif
		
			&IsAchou = true
		Endif		
	EndFor

	if &IsAchou = false
		&SdtPodutoLoteItem = new()
		&SdtPodutoLoteItem.PedProEstLotCod = EstLotCod
		if &OqueFazer = 'A'
			&SdtPodutoLoteItem.PedProEstLotQtd = EstLotQtd
		Else
			&SdtPodutoLoteItem.PedProEstLotQtdAux = EstLotQtd
		Endif
		&SdtPodutoLoteItem.PedProEstLotVct = EstLotVct
		&SdtPodutoLote.Add(&SdtPodutoLoteItem)
	Endif
EndFor
]]></Source>
