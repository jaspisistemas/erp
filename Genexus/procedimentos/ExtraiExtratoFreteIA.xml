      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[do 'extraiInformacoes'

if CodeIsSucesso(&UserMessage.code)
	do 'gravaInformacoes'
endif


Sub 'extraiInformacoes'
	do 'buscaNoChatGPT'

	if CodeIsSucesso(&UserMessage.code)
		
		do 'validaInformacoes'
	endif
EndSub

Sub 'gravaInformacoes'
	&HojeData = serverdate()
	
	commit
EndSub

Sub 'validaInformacoes'
	
EndSub

Sub 'buscaNoChatGPT'
	&ConteudoPDF = ConverteArquivoPdfemTxt(&Path)
	
	if &ConteudoPDF.IsEmpty()
		&UserMessage = criaUserMessageError('Não foi possível extrair conteúdo do pdf','')
	else
		&sdtMensagemChatGPT = new()
		&sdtMensagemChatGPTMensagem = new()
		&sdtMensagemChatGPTMensagem.tipo = TipoMensagemChatGPTGx.texto
		&sdtMensagemChatGPTMensagem.conteudo = "Você receberá o conteúdo de um extrato de frete da cooperativa CVale, com registros agrupados por data e nome do produtor rural ('nome integrado'). O conteúdo possui colunas separadas por espaços ou desalinhadas visualmente, como:"
		&sdtMensagemChatGPTMensagem.conteudo += " Nº Viagem | Lote | Nome integrado | Km | Kg Real | Kg Pago | Desc | Valor | Faixa | Tr | Nº Nfe | Total NFe | Chave NFe | Município"
		&sdtMensagemChatGPTMensagem.conteudo += ". Cada viagem ocupa uma linha, e no final de cada agrupamento existe um 'TOTAL VIAGEM' com a soma de Km, Kg Pago e Valor. Por vezes, os dados podem se dividir entre páginas. Extraia todos os dados estruturados conforme o schema JSON"
		&sdtMensagemChatGPT.mensagens.Add(&sdtMensagemChatGPTMensagem)
		
		&sdtMensagemChatGPTMensagem = new()
		&sdtMensagemChatGPTMensagem.tipo = TipoMensagemChatGPTGx.texto
		&sdtMensagemChatGPTMensagem.conteudo = &ConteudoPDF
		&sdtMensagemChatGPT.mensagens.Add(&sdtMensagemChatGPTMensagem)
		
		&sdtMensagemChatGPT.modelo = TipoModeloChatGPT.gpt_4o_2024_08_06
		&sdtMensagemChatGPT.max_tokens = 6000
		
		&sdtMensagemChatGPT.json_schema.name = 'extrato_frete_schema'
		&sdtMensagemChatGPT.json_schema.strict = true
		&sdtMensagemChatGPT.json_schema.schema_sdtGPTModelo_ExtratoCvale = dpGPTModelo_ExtratoCvale()
		
		&sdtRespostaChatGPT = ChatGPT.sendText(&EmpCod,&LogGUID,&sdtMensagemChatGPT)
		
		if CodeIsSucesso(&sdtRespostaChatGPT.UserMessage.code)
			for &json in &sdtRespostaChatGPT.mensagens
				msg(&json,status)
				//			if not &json.IsEmpty()
				//				&sdtGptModelo_ExtratoCVale.FromJson(&json)
				//			endif
				//			exit
			endfor
		else
			&UserMessage = &sdtRespostaChatGPT.UserMessage
		endif
	endif

EndSub
]]></Source>
