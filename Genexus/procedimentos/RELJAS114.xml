      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &FunPesCod
	&Operador = PesRaz
	Exit
EndFor

//&SdtRecibo.FromXml(&webSession.Get('ReciboImp'))

MB 0
MT 0


For Each order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	
	&QtdLinhas = gxMLines(FilRaz, 47)
	&Operador = FilRaz
	if &QtdLinhas > 47
		&UmFilRaz = gxGetMLi(FilRaz, 1, 47)
		&DoisFilRaz = gxGetMLi(FilRaz, 2, 47)
	Else
		&DoisFilRaz = gxGetMLi(FilRaz, 1, 47)
	EndiF 
	&UmFilRaz = UPPER(&UmFilRaz)
	&DoisFilRaz = UPPER(&DoisFilRaz)
	
	if not FilCpj.IsEmpty()
		&CnpjIeIm = 'CNPJ: ' + trim(FilCpj)
	EndIF
	
	If not FilInsEst.IsEmpty()
		If not &CnpjIeIm.IsEmpty()
			&CnpjIeIm += ' - '
		EndIf
		&CnpjIeIm += 'IE: ' + trim(FilInsEst)
	EndIF
	
	If Not FilInsMun.IsEmpty()
		If not &CnpjIeIm.IsEmpty()
			&CnpjIeIm += ' - '
		EndIf
		&CnpjIeIm += 'IM: ' + trim(FilInsMun)
	EndIF
	
	&Endereco = FilLog.Trim() + ', ' + trim(FilNro) + ' - ' + trim(FilBai)
	&Cidade = trim(FilCidNom) + ' - ' + trim(FilCidUfeCod)
	
	
	If Not FilFonNum.Trim().IsEmpty()
		&Cidade += 'F:'+FilFonNum.Trim()
	EndIf

	print Cabecalho
EndFor

&Cont = 0
if &MovCod > 0
	&TipoTitulos = 'RECIBO DE PAGAMENTO'
	&IsImprimeCab = true
	For Each Order EmpCod, MovCod, MovItmCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		
		&MovCreCod = MovCreCod
		&MovCrePagCod = MovCrePagCod
		&auxMovDtaPgt = MovDtaPgt
		&CreDupNro.SetEmpty()
		&CreDtaEms.SetEmpty()
		Do 'ValidaDuplicata'	
		
		if &CreDtaEms.IsEmpty()
			&CreDtaEms = MovDtaPgt
			&CreDupNro = MovDoc			
			&PesRaz = MovCplMan
			&CreDtaVct.SetEmpty()
		Endif
		&MovCplMan = MovItmCpl
		if &IsImprimeCab = true
			&IsImprimeCab = false
			print CabPagamento
		Endif
		
		//		&CreDupNro = 
		//		&CreDtaEms = 
		&CreVlrDup = MovItmVlr
		Print ImprimeTicket
		
		&Cont += 1
		&TotalPagoMoeda += MovItmVlr
	EndFor	
	
	&TotalPago = 'TOTAL PAGO:  ' + trim(toformattedString(&TotalPagoMoeda))
	
	print TotTitulosPagos
	
	for Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		if PesCliCrd > 0
			//IMPRIMIR LIMITE DISPONIVEL
			RetornaCreditoCliente.Call(EmpCod, PesCod, ReceberPagar.Pagar, &CreditoMensagem, &ValorHaverMoeda)
			RetornaCreditoCliente.Call(EmpCod, PesCod, ReceberPagar.Receber, &CreditoMensagem, &UtilizadoPesCliCrd)
			
			&DisponivelPesCliCrd = (PesCliCrd + &ValorHaverMoeda) - &UtilizadoPesCliCrd
			&TotalPago = 'CRÉD.DISP.: R$ ' + trim(toformattedString(&DisponivelPesCliCrd))
			print LimiteDisponivel
		Endif
	
		Exit		
	EndFor	
	
	print Assinatura
Else
	&TipoTitulos = 'TICKETS ABERTOS'
	&IsImprimeCab = true
	For Each Order EmpCod, CreCliCod
		Where EmpCod = &EmpCod
		Where CreCliCod = &CreCliCod
		Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
		Where CreVlrSdo > 0
		Where CreSts <> Status_Duplicata.CANCELADA
		
		&CreDupNro = CreDupNro
		&CreDtaEms = CreDtaEms
				
		if &IsImprimeCab = true
			
			&PesRaz = CreCliCodRaz		
			&IsImprimeCab = false
			print CabPagamento
		Endif
		
		&CreVlrDup = CreVlrSdo
		Print ImprimeTicket
		
		&Cont += 1
		&TotalPagoMoeda += CreVlrSdo
	EndFor
	
	&TotalPago = 'VALOR TOTAL: ' + trim(toformattedString(&TotalPagoMoeda))
	
	
	print TotTitulosPagos

	for Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CreCliCod
		
		if PesCliCrd > 0
			//IMPRIMIR LIMITE DISPONIVEL
			RetornaCreditoCliente.Call(EmpCod, PesCod, ReceberPagar.Pagar, &CreditoMensagem, &ValorHaverMoeda)
			RetornaCreditoCliente.Call(EmpCod, PesCod, ReceberPagar.Receber, &CreditoMensagem, &UtilizadoPesCliCrd)
			
			&DisponivelPesCliCrd = (PesCliCrd + &ValorHaverMoeda) - &UtilizadoPesCliCrd
			&TotalPago = 'CRÉDITO DISP.: R$ ' + trim(toformattedString(&DisponivelPesCliCrd))
			print LimiteDisponivel
		Endif
	
		Exit		
	EndFor	
	
	print Assinatura
	
EndIf


Sub 'ValidaDuplicata'
	For each Order EmpCod,FilCod,CreCod//,CrePagCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &MovCreCod
		//Where CrePagCod = &MovCrePagCod
		
		&PesRaz = CreCliCodRaz
		&CreDupNro = CreDupNro
		&CreDtaEms = CreDtaEms
		&CreDtaVct = CreDtaVct
		&CreVlrDup = CreVlrDup
		//&RcbObs = 'pagamento da duplicata '+ &RcbCreCod.ToString() + ' no dia '+dtoc(CrePagDta)
		exit
	EndFor
EndSub

