      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &parAutGrpCod.Count > 0 
	&AutGrpCod = &parAutGrpCod
Else
	CarregaSdtPerfil_api.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &AutGrpCod, &AutGrpNom)
	&AutNiv = 0
Endif

If &wwpContext.TipoPerfil <> 3 //SUPORTE SISTEMA
	For Each Order EmpCod, AutGrpCod, AutIsAdm
		Where EmpCod = &wwpContext.EmpCod
		Where AutGrpCod in &AutGrpCod
		where AutIsAdm = true //ADM EMPRESA
		&AutNiv = 3			
		Exit
	When none
		For Each Order EmpCod, AutCod, (AutNiv)
			Where EmpCod = &wwpContext.EmpCod
			Where AutGrpCod in &AutGrpCod
			Where AutCod = &AutCod
			&AutNiv = AutNiv			
			Exit
		EndFor
	EndFor
	
	&IsExisteRotinaGravada = IsExisteRotinaGravada.Udp(&wwpContext.EmpCod, &AutCod)
	if &IsExisteRotinaGravada = false
		&AutNiv = 0
	EndIF
Else //ADMINISTRADOR SUPORTE [MASTER]
	&AutNiv = 4
EndIF
]]></Source>
