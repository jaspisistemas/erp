	//			&GxCbb.save(&Arquivo)	
	//		EndIF
	
	//&File.Source = &Arquivo
	//If &File.Exists()
	//&qrcode = loadbitmap(&Arquivo)
	//EndIF
	//	EndIF
	
	//&sdtRelJas_XXX_Nfe.imgQrCode = &qrcode.
	&sdtRelJas_XXX_Nfe.xmlNfe = NfeArqXml
	&sdtRelJas_XXX_Nfe.StsNotaFiscal = NfeSts.ToString()
	
	if NfePedCod > 0
		&nfeFilcod = FilCod
		&NfePedcod = NfePedCod
		do 'GetPedido'
		&sdtRelJas_XXX_Nfe.Crediario = &Crediario
	Endif
	
	
	Exit
EndFor


sub 'GetPedido'
	RetornaConfSistema.Call(&EmpCod, &nfeFilcod, domConfSistema.TCon020_ClientePadraoVista, &CfgVlr)
	
    &VisPedCliCod = val(&CfgVlr)
    If &VisPedCliCod = 0
        &VisPedCliCod = 1
    EndIF

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &nfeFilcod
		Where PedCod = &NfePedcod
		
		
		if &VisPedCliCod <> PedCliCod
			&Crediario = 'CL: ' + trim(PedCliCodRaz)
		Else
			&Crediario = 'CL: ' + 'CONSUMIDOR [' + trim(PedNovCliRaz) + ']' 
		Endif
			
		Exit
	EndFor

EndSub


]]></Source>
