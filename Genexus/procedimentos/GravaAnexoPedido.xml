      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do Case
	Case &OqueFazer = 'ADD' //GRAVA ANEXO
		if &PedAnxCod = 0
			&NewPedAnxCod = 0
			For Each Order EmpCod, FilCod, PedCod, (PedAnxCod)
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where PedCod = &PedCod
				
				&NewPedAnxCod = PedAnxCod
				Exit
			EndFor
			&NewPedAnxCod +=1
			
			new
				EmpCod = &EmpCod
				FilCod = &FilCod
				PedCod = &PedCod
				PedAnxCod = &NewPedAnxCod
				PedAnxDsc = &PedAnxDsc
				PedAnxTipCod = &PedAnxTipCod
				PedAnxArq = &PedAnxArq
				PedAnxMod = serverDate()
			EndNEw
			
			Commit
		Else
			For Each Order EmpCod, FilCod, PedCod, PedAnxCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where PedCod = &PedCod
				Where PedAnxCod = &PedAnxCod
				PedAnxTipCod = &PedAnxTipCod
				PedAnxDsc = &PedAnxDsc
				if not &PedAnxArq.IsEmpty()
					PedAnxArq = &PedAnxArq
				endif
				
				PedAnxMod = serverDate()
				Exit
			EndFor
			
			Commit
		EndIF
		
	Case &OqueFazer = 'DEL' //Deleta ANEXO
		For Each Order EmpCod, FilCod, PedCod, PedAnxCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			where PedAnxCod = &PedAnxCod
			delete
		EndFor
		COMMIT
EndCAse

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
