      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtObservacaoGrupoTot.Clear()

For &sdtObservacaoGrupoItem in &sdtObservacaoGrupo
	if &sdtObservacaoGrupoItem.OGrupNom like '%'+&FiltroProNom+'%' or &FiltroProNom.IsEmpty()
		&sdtObservacaoGrupoTotItem = new()
		&sdtObservacaoGrupoTotItem.OGrupCod = &sdtObservacaoGrupoItem.OGrupCod
		&sdtObservacaoGrupoTotItem.OGrupCodRef = &sdtObservacaoGrupoItem.OGrupCodRef
		&sdtObservacaoGrupoTotItem.OGrupNom = &sdtObservacaoGrupoItem.OGrupNom
		&sdtObservacaoGrupoTotItem.OGrupQtd = &sdtObservacaoGrupoItem.OGrupQtd
		&sdtObservacaoGrupoTotItem.OGrupSel = &sdtObservacaoGrupoItem.OGrupSel
		&sdtObservacaoGrupoTotItem.OGrupVlr = &sdtObservacaoGrupoItem.OGrupVlr
		&sdtObservacaoGrupoTot.Add(&sdtObservacaoGrupoTotItem)
	Endif
EndFor
]]></Source>
