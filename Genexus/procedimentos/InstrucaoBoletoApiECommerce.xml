      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&MsgErro = ''
&MsgSucesso = ''
For Each Order EmpCod,CreCod,CreRecPag
	Where EmpCod = &EmpCod
	Where CreCod = &CreCod
	Where CreRecPag = ReceberPagar.Receber
	
	
	&CreCbrCod = CreCbrCod
	Do 'GetLocalCobraca'
	If &ErroCobraca = 0 and &IschaveTransacao = True
		&SdtBoletoApiECommerceInstrucao.agencia = padL(Substr(trim(&CbrCtaBanAgeCod),1,4),4,'0')
		&SdtBoletoApiECommerceInstrucao.posto   = padL(substr(trim(&CbrCtaBanAgeDig),1,2),2,'0')
		&SdtBoletoApiECommerceInstrucao.cedente = padL(substr(trim(&CbrNroCon),1,5),5,'0')
		&CreBloNro = padL(substr(trim(&CbrCtaBanAgeCod),1,4),4,'0')+padL(substr(trim(&CbrCtaBanAgeDig),1,2),2,'0') + padL(trim(&CbrNroCon),5,'0')+padL(trim(CreBloNro),8,'0')						      // Pega Nosso Número da Duplicata	
		CalculaDigNosNro.Call(&CbrCtaBanBanCod,&CbrCarCod,2,&CreBloNro)      // Calcula Dígito do Nosso Número
		&SdtBoletoApiECommerceInstrucao.nossoNumero = padL(trim(&CreBloNro),9,'0') 
		
		
		Do Case //instrução do pedido
			Case &CreCmdIns = ComandoInstrucao.PEDIDO_BAIXA
				&SdtBoletoApiECommerceInstrucao.instrucaoComando = 'PEDIDO_BAIXA'
			Case &CreCmdIns = ComandoInstrucao.ALTERACAO_OUTROS_DADOS
				&SdtBoletoApiECommerceInstrucao.instrucaoComando = 'ALTERACAO_OUTROS_DADOS'	
			Case &CreCmdIns = ComandoInstrucao.ALTERACAO_VENCIMENTO
				&SdtBoletoApiECommerceInstrucao.instrucaoComando = 'ALTERACAO_VENCIMENTO'
		EndCase

		If &CreCmdIns = 9 //alteração de outros dados
			&SdtBoletoApiECommerceInstrucao.complementoInstrucao = &CreCmdCpl.EnumerationDescription()
		Else
			&SdtBoletoApiECommerceInstrucao.complementoInstrucao = ''
		EndIf
		
		If &CreCmdIns = 4
			&SdtBoletoApiECommerceInstrucao.tipoVencimento = 'DATA_ESPECIFICA'
			&SdtBoletoApiECommerceInstrucao.data1 = dtoc(&CampoData)
		EndIf
		
		If &CreCmdIns = 5 or &CreCmdIns = 2 or &CreCmdIns = 9
			&SdtBoletoApiECommerceInstrucao.valor1 = &CampoTexto
		EndIf
	
		//##################################################################################### chamada ao webservice 
		HostWebServiceBoletoApi.Call('ECOMERCE',748, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor) // Sicredi = 748
		&HttpClient.Host = &EmpWebHost //servidor
		&HttpClient.Secure = 1
		&httpclient.AddHeader(!'Content-type',!'application/json')
		&httpclient.AddHeader('token',trim(&CbrChaTra))
		&String = '/sicredi-cobranca-ws-ecomm-api/ecomm/v1/boleto/comandoInstrucao'
		&httpclient.AddString(&SdtBoletoApiECommerceInstrucao.toJson())
		&HttpClient.Execute('POST',&String)
		//padraoUsuario.Call('G', '#BOLETOAPIECOMMERCEINSTRUCAOENVIO', &Context.PesCod, &Context.EmpCod, &SdtBoletoApiECommerceInstrucao.toJson(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
		//padraoUsuario.Call('G', '#BOLETOAPIECOMMERCEINSTRUCAO', &Context.PesCod, &Context.EmpCod, &HttpClient.toString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
		Do Case
			Case &HttpClient.ErrCode = 0  //HTTP_CREATED  Operação realizada com sucesso
				
				&StdautenticacaoBoletoErro.fromJson(&HttpClient.toString())  // retorna dados de Saida
				&MsgSucesso = 'Comando de Instrução realizado com sucesso!'
//				msg( DVMessageBasicNotification.Udp(!"Regular", "Message description" ,DVMessageType.regular, "", DVMessageBoolean.True) )
// 				msg( DVMessageBasicNotification.Udp(!"Information", "Message description" ,DVMessageType.information, "", DVMessageBoolean.True) )
//				msg( DVMessageBasicNotification.Udp(!"Error!", "Message description" ,DVMessageType.error, "", DVMessageBoolean.True) )
				do 'AtualizaDuplicata'
			Otherwise
				&StdautenticacaoBoletoErro.fromJson(&HttpClient.toString())
				&MsgErro = trim(str(&HttpClient.ErrCode)) +': '+&StdautenticacaoBoletoErro.codigo.Trim()+' Msg: '+&StdautenticacaoBoletoErro.mensagem.Trim() +' Parametro: '+&StdautenticacaoBoletoErro.parametro.Trim()
				
		EndCase
	EndIf
EndFor

	//#################################################################################################################################################
Sub 'GetLocalCobraca'
	&ErroCobraca = 0
	
	For each Order EmpCod,CbrCod,CbrTipImp
		Where EmpCod = &EmpCod
		Where CbrCod = &CreCbrCod
		&CbrCtaBanAgeCod = CbrCtaBanAgeCod
		&CbrCtaBanAgeDig = CbrCtaBanAgeDig
		&CbrCtaBanCrt = CbrCtaBanCrt
		&CbrCtaBanBanCod = CbrCtaBanBanCod
		&CbrNroCon = CbrNroCon
		&CbrCarCod = CbrCarCod
		&CbrDesDia = CbrDesDia
		&CbrQtdDiaDesc = CbrQtdDiaDesc
		&CbrDesAnt  = CbrDesAnt
		&CbrInsBol1 = CbrInsBol1
		&CbrMltVlr  = CbrMltVlr
		&CtaBanNosNro = CtaBanNosNro     // Local Cobrança Nosso Número
		&CrbRegAut = CrbRegAut 
		
		If not CbrChaMas.Trim().IsEmpty() and CrbRegAut = Status_SimNao.Sim // chave master NÃO esta Vazia?
			&CbrChaMas = CbrChaMas                                                 
			If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow() //chave de Transação esta Vencida?
				&CbrChaTra = CbrChaTra
				&IschaveTransacao = true  // pega chave transação jah existente ou a nova no else.
				//"chaveTransacao":"14F671760619965B97FF5CEEB9BE10F4792A9F3BAB8DED900F23A633A4C9FEB5",
				//"dataExpiracao":"2017-04-26T20:15:28.685-03:00"
			Else
				 // If a Chave de Transação esta vencida a mais de 24 Horas tem que gerar Outra.
				AutenticaBoletoApiECommerce.Call(EmpCod,CbrCod,CbrChaMas,&IschaveTransacao,&CbrChaTra) 			
			EndIf
		Else
			&ErroCobraca = 1
			msg( DVMessageBasicNotification.Udp(!"Erro!", 'Chave master inválida ou local de cobrança não habilitado registro automático. Verifique!',DVMessageType.error, "", DVMessageBoolean.True) )
		EndIF
		&CbrJurCod = CbrJurCod             // Local Cobrança Juros Código
		&JurTaxDia = 0
		Do 'Juros'
	EndFor
EndSub

Sub 'Juros'	
	For each Order EmpCod,JurCod,(JurAno),(JurMes)
		Where EmpCod = &EmpCod
		Where JurCod = &CbrJurCod
		&JurTax = JurTax
		&JurTaxDia = JurTaxDia
		Exit
	EndFor
EndSub


Sub 'AtualizaDuplicata'
	&IsComandoExecutado = False
	For Each Order EmpCod,CreCod,CreRecPag,CreCrbRegAut
		Where EmpCod = &EmpCod
		Where CreCod = &CreCod
		Where CreRecPag = ReceberPagar.Receber
		Where CreCrbRegAut = Status_SimNao.Sim
		Do Case
			Case &CreCmdIns = ComandoInstrucao.PEDIDO_BAIXA
				&CreCobObs = 'PEDIDO BAIXA'
				CreSts = Status_Duplicata.CANCELADA
//			Case &CreCmdIns = ComandoInstrucao.PEDIDO_PROTESTO
//				&CreCobObs = 'PEDIDO PROTESTO'
			Case &CreCmdIns = ComandoInstrucao.ALTERACAO_OUTROS_DADOS
				&CreCobObs = 'ALTERACAO OUTROS DADOS'
			Case &CreCmdIns = ComandoInstrucao.ALTERACAO_VENCIMENTO
				CreDtaVct = &CampoData
				&CreCobObs = 'ALTERAÇÃO DE VENCIMENTO PARA NOVO VENCIMENTO EM: '+ DTOC(&CampoData)
//			Case &CreCmdIns = ComandoInstrucao.CANCELAMENTO_ABATIMENTO_CONCEDIDO
//				&CreCobObs = 'CANCELAMENTO ABATIMENTO CONCEDIDO'
//			Case &CreCmdIns = ComandoInstrucao.CONCESSAO_ABATIMENTO
//				&CreCobObs = 'CONCESSAO ABATIMENTO'
//			Case &CreCmdIns = ComandoInstrucao.SUSTAR_PROTESTO_BAIXAR_TITULO
//				&CreCobObs = 'SUSTAR PROTESTO BAIXAR TITULO'
//			Case &CreCmdIns = ComandoInstrucao.SUSTAR_PROTESTO_MANTER_CARTEIRA
//				&CreCobObs = 'SUSTAR PROTESTO MANTER CARTEIRA'
		EndCase
		&IsComandoExecutado = True
		&CreMaxCobCod = CreMaxCobCod
		Exit
	EndFor
	
	If &IsComandoExecutado = True
		&CreMaxCobCod+=1
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CreCod = &CreCod
			CreCobCod = &CreMaxCobCod
			CreObsTip = TipoObservacaoDuplicata.INTERNA
			CreCobObs = &CreCobObs
//			CreMetCod = 1
//			CreResCob = 1
			If &CreCmdIns = ComandoInstrucao.ALTERACAO_VENCIMENTO
				CrePrmPag = &CampoData
				CrePrmPagHor = &Time
			EndIf
			
			CreFunCod = &Context.PesCod
			CreFunNom = &Context.PesRaz
			
			CreCmdIns = &CreCmdIns
			CreCmdCpl = &CreCmdCpl
		EndNew
	EndIf
	
EndSub

]]></Source>
