<Object parentGuid="21e15c47-a3e3-482b-9c7a-4147ea7dbb76" user="WIN-JEAN\jean.fae" versionDate="2024-08-09T17:52:38.0000000Z" lastUpdate="2024-08-08T20:04:49.0000000Z" checksum="4c903d8fe21b5fc4a2b327f618524295" fullyQualifiedName="RetornaIsPodeAlterar_api" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="5be75458-58f8-43a3-a7aa-5c13a61e853e" name="RetornaIsPodeAlterar_api" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Retorna Is Pode Alterar_api" parent="TelevendasPrc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAutorizado = true
CarregaSdtPerfil_api.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &parAutGrpCod, &AutGrpNom)
RetornaAutorizacaoApi.Call('VENDAALTERARPEDIDOSEPARANDO', &wwpContext, &parAutGrpCod, &SeparandoAutNiv)

RetornaAutorizacaoApi.Call('VENDAALTERARPEDIDOFECHADO', &wwpContext, &parAutGrpCod, &FechadoAutNiv)

&AutNivTel = 1
if &wwpContext.PesIsVen = true
	RetornaAutorizacaoApi.Call('TELEVENDATROCARVENDEDOR', &wwpContext, &parAutGrpCod, &AutNivTel)
EndIf

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon058_DigitandoPedido, &TCon058_DigitandoPedido)

RetornaUmItemPago.Call(&EmpCod, &FilCod, &pedCod, &IsPagto)
RetornaUmPedidoReferencia.call(&EmpCod, &FilCod, &pedCod, &IsUmReferenciado)

For Each Order EmpCod, FilCod, PedCod 
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	Do Case
		Case &IsPagto = true //pedido ja tem pgto então não pode alterar.
			&IsAutorizado = false
			
		Case &IsUmReferenciado = true
			&IsAutorizado = false
			
		Case &FechadoAutNiv > 0 //Editar Pedido Fechado
			&IsAutorizado = true
			
		Case &SeparandoAutNiv > 0 and (PedSts = Status_Pedido.SEPARANDO or PedSts = Status_Pedido.ABERTO)
			//Pedido em Separacao/Aberto
			&IsAutorizado = true
			
		CAse &AutNivTel = 0 and PedVenCod <> &wwpContext.PesCod and &wwpContext.PesIsVen = true
			//Pedido Somente do Vendedor
			&IsAutorizado = false
			
		Case (PedSts = Status_Pedido.ABERTO and PedStsCrd <> Status_Autorizado.AUTORIZADO)
			//Pedido Aberto nao Autorizado
			&IsAutorizado = true
			if (&TCon058_DigitandoPedido = 'S') 
				Do Case
					CAse (PedStsDigBlk = true) and PedVenCod <> &wwpContext.PesCod and &AutNivTel = 0
						//Pedido em Digitacao de Outro Vendedor
						&IsAutorizado = false
					Case (PedStsDigBlk = false) and PedVenCod = &wwpContext.PesCod and &AutNivTel = 0
						&IsAutorizado = false
				EndCase
			EndIF
			
		Case PedSts <> Status_Pedido.ABERTO
			//Pedido Aberto já autorizado
			&IsAutorizado = false
			
		Case PedStsCrd = Status_Autorizado.AUTORIZADO and &AutNivTel = 0 
			//Pedido Aberto já autorizado
			&IsAutorizado = false
	EndCase

	Exit
EndFor
]]></Source>
