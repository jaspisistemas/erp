        <Source><![CDATA[
//loadWWPContext.Call(&Context)
//&SdtRecibo.FromXml(&webSession.Get('ReciboImp'))
//If &Context.PesCod = 0
//	Return
//EndIf

MB 4
MT 2

For each Order EmpCod, ACmpCod
	Where EmpCod = &EmpCod
	Where ACmpCod = &AcmpCod
	
	&AuxAcmpCod = &AcmpCod
	
	&ACmpDtaEms = ACmpDtaEms
	&ACmpForNomMan = ACmpForNomMan
	
	&Pescod = ACmpAutCod
	Do 'Pessoa'
	&ACmpAutNome = &PesRaz
	
	&AcmpFilCod = ACmpFilCod
	Do 'Filial'	
	
//	If &PesCnpj.Trim().IsEmpty()
//		&RcbDes1 = trim(RcbDstNom)+' a importância de:'
//	Else
//		&RcbDes1 = trim(RcbDstNom)+' - CPF/CNPJ n° ' + &PesCnpj.Trim()
//	EndIf

	&Pescod = ACmpResCod
	Do 'Pessoa'
	&ACmpResNome = &PesRaz

	print CabecalhoAntes
	Print Cabecalho
	Print Conteudo

//	&RcbCreCod = RcbCreCod
//	&RcbCrePagCod = RcbCrePagCod
//	&RcbObs = ''

//	If &RcbObs.isEmpty()
//		&RcbObs = RcbObs
//	EndIf
//	&Obs = &RcbObs.Trim().ToUpper()
	&nlin = GXMLines(ACmpObs,70)
	&i = 1
	Do While &i <= &nlin
		&RcbDes3 = GXGetMLi(ACmpObs,&i,70)
		Print Extenso
		&i += 1
	Enddo

	&Datadoem = trim(&FilCidNom)+', '+trim(str(day(&ACmpDtaEms)))+' de '+trim(cmonth(&ACmpDtaEms))+' de '+trim(str(year(&ACmpDtaEms)))
	&Datadoem = &Datadoem.ToUpper()

	Print Rodape

	Print Tesoura
EndFor

Sub 'Filial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &AcmpFilCod
		&FilFan    = FilFan.Trim().ToUpper()
		&FilLogNro = FilLogNro.Trim()
		&FilLogNro += ' '+FilBai.Trim() 
		&FilCepCidUfe = FilCepCidUfe.Trim()
		&FilDes = FilCpj.Trim() +'/'+ FilFonNum.Trim()
		&FilCidNom = FilCidNom.Trim()
		&FilCpj = FilCpj.Trim()
		If FilImg_LogRel.IsEmpty()
			&Image.FromImage('FilialSemImagem')  
		Else
			&Image = FilImg_LogRel
		EndIF
		
		Exit
	EndFor
EndSub

Sub 'Pessoa'
	For each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
//		
//		
//		If PesTip = TipoPessoa.FISICA
//			&PesCnpj = PesCpf
//		Else
//			&PesCnpj = PesCnpj
//		EndIf

		&PesRaz = PesRaz
		Exit
	EndFor
EndSub
]]></Source>
