      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&AloPsoMed = 0
For Each Order EmpCod, BioAloCod,(BioDta)
	Where EmpCod = &EmpCod
	Where BioAloCod = &BioAloCod
	Where BioTotPeso > 0 
	If BioTotPeso > 0 and BioQtdAmo > 0
		&AloPsoMed = BioTotPeso/BioQtdAmo
	Else
		&AloPsoMed = 0
	EndIf
	Exit
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
