      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&ErroCobraca	= 0
&IsErro	= False
&IschaveTransacao	= False
&IsWebhookCadastrado	= False

Do 'GetLocalCobranca'

Do Case
	Case &IsErro	= True
		msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", &Mensagem, DVMessageType.regular, "", DVMessageBoolean.True,"") )

	Case &IsChaveTransacao	= False
		//Vai dar a mensagem no autenticar

	OtherWise
		&HttpClient.AddHeader('Authorization', 'Bearer ' + &CbrChaTra)
		&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
		&HttpClient.AddHeader('Connection', 'keep-alive')
		&HttpClient.AddHeader('x-api-key', &CbrApiKey)
		
		&HttpClient.Execute('GET', 'https://api-parceiro.sicredi.com.br/cobranca/boleto/v1/webhook/contratos/?cooperativa=' + &CbrCtaBanAgeCod + '&posto=' + &CbrCtaBanAgeDig + '&beneficiario=' +&CbrCtaBanCrt)
		If &HttpClient.ErrCode	= 0
			&AuxSdtCadastrarWebhook_Sicredi.FromJson(&HttpClient.ToString())
			&IsWebhookCadastrado	= True
			&url	= &AuxSdtCadastrarWebhook_Sicredi.url
			&contrato	= &AuxSdtCadastrarWebhook_Sicredi.idContrato
		EndIf
EndCase

Sub 'GetLocalCobranca'
	
	For each Order EmpCod, CbrCod
		Where EmpCod = &EmpCod
		Where CbrCod = &CbrCod
		
		&CbrApiKey	= CbrApiKey
		If not CbrChaMas.Trim().IsEmpty()
			&CbrChaMas = CbrChaMas                                                 
			If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow()
				&CbrChaTra = CbrChaTra
				&IschaveTransacao = true
			Else
				AutenticaBoletoSicredi.Call(EmpCod, CbrCod, CbrChaMas, CbrApiKey, CbrCtaBanAgeCod, CbrNroCon, &IschaveTransacao, &CbrChaTra) 			
			EndIf
		Else
			&ErroCobraca = 1
			&Mensagem = 'Chave master inválida. Verifique!'
			&IsErro = true
		EndIF
		
		Exit
	EndFor
	
EndSub
]]></Source>
