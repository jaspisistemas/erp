      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//&ProCod FABRICADO
//&RecProCod //MATERIA PRIMA

//Verificar se o Produto Fabricado Esta em alguma Materia-Prima das Suas Materias Primas
For Each order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &RecProCod //464
	
	If ProTipCus = TipoCusto.CustoProdutoEstoque
		&mensagem = 'ERRO: O Produto Encontra-se como Tipo de Custo "Custo Produto Movimenta Estoque" Não permitido para receitas'
		Return
	EndIf
	
	For Each order EmpCod, ProCod, RecItmCod
		
		If &RecProCod = RecProCod or &ProCod = RecProCod
			&mensagem = 'ERRO: O Produto Fabricado Encontra-se Cadastrado como Matéria-Prima no Produto: ' + trim(str(ProCod))
			Return
		EndIf
		
		TesteErroMateriaPrima1.Call(EmpCod, &ProCod, RecProCod, &mensagem)
		
//		If RecProCod = &ProCod
//			&mensagem = 'ERRO: O Produto Fabricado Encontra-se Cadastrado como Matéria-Prima no Produto: ' + trim(str(ProCod))
//		EndIF
		
		if &mensagem <> ''
			Return
		EndIF
	EndFor
		
	if &mensagem <> ''
		Return
	EndIF
EndFor

if &mensagem <> ''
	Return
EndIF
]]></Source>
