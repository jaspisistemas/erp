      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&NcminiVig = CtoD('01/01/2000')
&NcmfinVig = serverdate()
&NcmfinVig = &NcmfinVig.AddDays(15)

//Corrige NCMs com vigencia Final
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where NcmCod <> 99
	Where NcmFinVig >= &NcminiVig and NcmFinVig <= &NcmfinVig
	Where not NcmNovCod.IsEmpty() and not NcmNovCod.IsNull()
	
	&NcmCod = NcmNovCod
	NcmCod = &NcmCod
	ProVarNcm = trim(Str(&NcmCod))
	
//	RetornaPrimeiroCEST.Call(&NcmCod, &ProNcmCest)
//	ProNcmCest = &ProNcmCest
	
	&NfeProCod = ProCod
	do 'AtualizaNotasPendentes'
EndFor

commit

//Corrige CEST 
//For Each Order EmpCod, ProNcmCest
//	Where EmpCod = &EmpCod
//	Where ProNcmCest.IsEmpty() or ProNcmCest.IsNull()
//	Where NcmCod <> 99
//	
//	RetornaPrimeiroCEST.Call(NcmCod, &ProNcmCest)
//	ProNcmCest = &ProNcmCest
//EndFor

Commit


Sub 'AtualizaNotasPendentes'
	For Each order EmpCod, NfeProTer, NfeSts, NfeProCod
		Where EmpCod = &EmpCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_NFe.Digitando
		Where NfeProCod = &NfeProCod
		
		NfeNcmCod = &NcmCod
//		NfeNcmCest = trim(Str(&ProNcmCest))
		
	EndFor

	Commit
EndSub

	
]]></Source>
