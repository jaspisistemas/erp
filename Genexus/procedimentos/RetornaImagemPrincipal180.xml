        <Source><![CDATA[
For Each Order EmpCod, ProCod, ProImgCod
	Where EmpCod = &EmpCod
	Where ProCod = &PrOCod
	Where ProImgPri = true
	where ProImgTip = &ProImgTip 
	&ProImg180 = ProImg180
	&IsSemImagem = false
	Exit
When none
	&ProImg180.FromImage(Produto_Sem_Imagem180)
	&IsSemImagem = true
Endfor
]]></Source>
