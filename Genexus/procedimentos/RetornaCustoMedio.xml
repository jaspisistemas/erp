      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PedVlrCus = 0

For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = 1
       &PedVlrCus = EstQtdCus
    exit
EndFor

If &PedVlrCus <= 0
	&PedVlrCus = RetornaCustoFixo.Udp(&EmpCod, &ProCod)

EndIF
]]></Source>
