      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	delete 
EndFor

commit

For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	&NfeNum = NfeNum
	&PedVlrBas = NfeVlrTot
	Exit
EndFor


For Each Order EmpCod, FilCod, PedCod 
	Where EmpCod = &EmpCod
    Where FilCod = &NfeFilCod
    Where PedCod = &NfePedCod
	
	&PedCbrCod = PedCbrCod
	&CreDupNro = trim(str(&NfeNum))
	   
	&PedDtaFat = serverdate()
	PedTmpDupDtaFat = &PedDtaFat
	&PedCliCbrCod = PedCliCbrCod
    
	
	if PedFrpPgtoTip in ('1', '2', '5')
		&NfeDupFrpPgtoCod = PedFrpPgtoCod
	Else
		&NfeDupFrpPgtoCod = 1 //TipoDuplicata.DUPLICATA
	Endif

	
	if PedPraTipParc = '1'
		RetornaVencimentosParcelasDias.Call(EmpCod, FilCod, PedCod, &PedPraParNom, &DscPar, &sdtVencimentos)
	Else
		&PedPraParNom = PedPraParNom
		RetornaVencimentosParcela.Call(EmpCod, PedCliCidCod, &PedPraParNom, ReceberPagar.Receber, &PedDtaFat, &sdtVencimentos, &DscPar)
	Endif

	For &sdtVencimentosItem in &sdtVencimentos
		&Parcela += 1
		&CreDtaVct(&Parcela) = &sdtVencimentosItem.CreDtaVct 
	EndFor		
		
	&TotalDuplicatas = &PedVlrBas
	
	&CreVlrDup = round((&PedVlrBas / &Parcela),2)
	&ResCreVlrDup = round(&PedVlrBas,2) - (round((&PedVlrBas / &Parcela),2) * &Parcela)
	
	If &TotalDuplicatas > 0
		do 'add'
	EndiF
EndFor

Commit

sub 'add'
	&ParMax  = &Parcela
	&Parcela = 1
	
	Do while &Parcela <= &ParMax
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			NfeCod = &NfeCod
			NfeDupItmCod = &Parcela	

			NfeDupCreSeq = 0
			NfeDupFiLCod = 0
			
			NfeDupFrpPgtoCod = &NfeDupFrpPgtoCod
			
			&AuxCreDupNro = trim(&CreDupNro) +'-'+ltrim(str(&Parcela))
			NfeDupNro =  trim(&AuxCreDupNro)
			
			if &Parcela = 1
				NfeDupVlr = (&CreVlrDup + &ResCreVlrDup)
			else
				NfeDupVlr = &CreVlrDup
			endif
			
			NfeDupVct = &CreDtaVct(&Parcela)
						
			//&PedTmpSem = substr(cdow(&CreDtaVct(&Parcela)), 1, 3)
			//PedTmpSem = &PedTmpSem
			
			//&PedTmpPrz = (&CreDtaVct(&Parcela) - &PedDtaFat) 
			//PedTmpPrz = &PedTmpPrz
			
		    do Case
				Case &CreCbrCod <> 0
					NfeCbrCod = &CreCbrCod
				Case &PedCbrCod <> 0
					NfeCbrCod = &PedCbrCod
				Case &PedCliCbrCod = 0
			        NfeCbrCod = 1
			    Otherwise
			        NfeCbrCod = &PedCliCbrCod
		    EndCase
			
			//PedTmpSts = Status_SimNao.Nao
		EndNew
		
		&Parcela += 1
	EndDo
EndSub
]]></Source>
