        <Source><![CDATA[MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &EtqVolFilCod, &sdtConfiguracoesPasta)
&TipoCodigoBarras = TipoCodigoBarras.CODE128//_40X110

&NumeroPedido = trim(str(&EtqVolPedCod))
&IsLadoDireito = false

//print Cabecalho


For Each Order EmpCod, EtqVolFilCod, EtqVolPedCod, (EtqVolNro)
	Where EmpCod = &EmpCod
	Where EtqVolFilCod = &EtqVolFilCod
	Where EtqVolPedCod = &EtqVolPedCod
	&UltimaCAixaEtqVolNro = EtqVolNro
	Exit
EndFor


For Each Order EmpCod, EtqVolFilCod, EtqVolPedCod, EtqVolNro
	Where EmpCod = &EmpCod
	Where EtqVolFilCod = &EtqVolFilCod
	Where EtqVolPedCod = &EtqVolPedCod
	
	&EtqVolNro = EtqVolNro
	&NumeroCaixa = padL(trim(Str(&EtqVolNro)), 3, '0') + ' / '+ padL(trim(Str(&UltimaCAixaEtqVolNro)), 3, '0')
	
	Do 'GetDadosCliente'
	
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqVolCodBar) + '.jpg'
	If not EtqVolCodBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqVolCodBar,  EtqVolCodBar)
		EndIF
		If &File.Exists()
			&CodigoBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf
	
	&EtqVolNovProNom = gxGetMLi(EtqVolNovProNom, 1, 40)
	&EtqVolNovProNom2 = gxGetMLi(EtqVolNovProNom, 2, 40)
	RetornaFilialFaturamento.Call(&EmpCod, &EtqVolFilCod, &FilRaz, &FiLCidNom, &FilLog, &Contato, &Contato2, &FilImg146_50, &FilFan)
	&EtqVolPedQtd = EtqVolPedQtd
	
//	if &IsLadoDireito = false
		print LadoEsquerdo
//		noSkip
//		&IsLadoDireito = true
//	Else
//		print LadoDireito
//	Endif
EndFor

Sub 'GetDadosCliente'
//	For Each Order EmpCod, PesCod
//		Where EmpCod = &EmpCod
//		Where PesCod = &PedCliCod
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &EtqVolFilCod
		
		&PesRaz = substr(FilRaz,1,100)
		&PesCnpj = FilCpj.Trim()
		&PesFonNum = FilFonNum
		
		Exit
	EndFor
EndSub
]]></Source>
