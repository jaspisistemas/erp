      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order SpedLogEmpCod, SpedLogFilCod, SpedLogGUID
	Where SpedLogEmpCod = &SpedLogEmpCod
	Where SpedLogFilCod = &SpedLogFilCod
	Where SpedLogGUID = &SpedLogGUID

	&SpedLogItm = 0
	For Each Order SpedLogEmpCod, SpedLogFilCod, SpedLogGUID, (SpedLogItm)
		&SpedLogItm = SpedLogItm
		Exit
	EndFor
	&SpedLogItm += 1
	
	New
		SpedLogEmpCod = &SpedLogEmpCod
		SpedLogFilCod = &SpedLogFilCod
		SpedLogGUID = &SpedLogGUID
		SpedLogItm = &SpedLogItm
		SpedLogItmObs = &SpedLogItmObs
	EndNew
	
	Exit
	
When None
	New
		SpedLogEmpCod = &SpedLogEmpCod
		SpedLogFilCod = &SpedLogFilCod
		SpedLogGUID = &SpedLogGUID
		SpedLogDta = serverNow()
		SpedLogTip	= &SpedLogTip
	EndNew
	
	New
		SpedLogEmpCod = &SpedLogEmpCod
		SpedLogFilCod = &SpedLogFilCod
		SpedLogGUID = &SpedLogGUID
		SpedLogItm = 1
		SpedLogItmObs = &SpedLogItmObs
	EndNew
EndFor

Commit
]]></Source>
