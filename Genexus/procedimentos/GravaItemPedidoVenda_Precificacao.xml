      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&MensagemAlterada = ''
&MensagemInserida = ''
&OldPedQtd = 0
&PedQtdFat = 0

For Each Order EmpCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&ProGraRef = ProGraRef
	&GrupCom = GrupCom
	&PedVlrCus = ProVlrCus
	
	&PedVlrCusPrd = 0
	Do Case
		Case ProTipCus = TipoCusto.Receita 
			&PedVlrCusPrd    = ProVlrCusPrd
			
		Case ProTipCus = TipoCusto.CustoProdutoEstoque
			&PedVlrCusPrd    = retornaCustoProducao.Udp(EmpCod, ProEstProCod)				
	EndCase
		
	&ProTipDef = ProTipDef	
	&PedProEstProCod	= ProEstProCod		
	&PedProEstProGraCod = &ProGraCod
	
	Exit
EndFor 


For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&PedDtaFat = PedDtaFat
	&LctAtuEst = LctAtuEst
	&LctAtuSal = LctAtuSal
	&LctAtuPro = LctAtuPro
	&LctTip = LctTip
	&LctGerFin = LctGerFin
	&PedSts = PedSts
	
    For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where PedItmCod = &PedItmCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&OldPedQtd = PedQtd
		&OldPedQtdSdo = PedQtdSdo
		&PedQtdFat = PedQtdFat
		
		&OldPedVlrCus = PedVlrCus
		//&PedVlrCusPrd = PedVlrCusPrd
		If &PedSts = Status_Pedido.FECHADO or &PedSts = Status_Pedido.SEPARANDO
			Do 'AbreEstoque'
		EndIF
		
		PedProEstProCod	   = &PedProEstProCod		
		PedProEstProGraCod = &PedProEstProGraCod			
		
		PedQtd = &PedQtd
		
		If &PedQtdCan >= 0 
			PedQtdCan = &PedQtdCan
		Else
			PedQtdCan = 0
		EndIF
		
		PedVlrCus = &PedVlrCus
		PedVlrCusPrd    = &PedVlrCusPrd
		PedItmCmp = &PedItmCmp
		PedItmVenCod = &PedItmVenCod
		PedProEmbQtd = 0
		PedQtdEmb = &PedQtd
		PedVlrTab = &PedVlrTab
		PedVlrUnt = &PedVlrUnt
		PedItmDsc = &PedItmDsc
		PedItmProRefDig = &PedItmProRefDig
		PedNItmPed = &PedNItmPed
		
		If &PedSts = Status_Pedido.FECHADO or &PedSts = Status_Pedido.SEPARANDO
			do 'FechaEstoque'
		EndIF
		
		if &ProTipDef = Definicao.SERVICO
			&MensagemInserida = 'Serviço ' +trim(&ProGraRef)+ ', atualizado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		Else
			&MensagemInserida = 'Produto ' +trim(&ProGraRef)+ ', atualizado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		EndIF
        Exit
    When none
		&PedItmCod = 0
        For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
			Where EmpCod = &EmpCod
	        Where FilCod = &FilCod
	        Where PedCod = &PedCod
            &PedItmCod = PedItmCod
	        Exit
        EndFor
		
        &PedItmCod += 1
        new
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			PedItmCod = &PedItmCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
			PedProEstProCod	   = &PedProEstProCod		
			PedProEstProGraCod = &PedProEstProGraCod
			PedProEmbQtd = 0
			PedQtdEmb = &PedQtd
			PedQtd = &PedQtd
			PedQtdCan = 0
			PedVlrCus = &PedVlrCus
			PedVlrCusPrd    = &PedVlrCusPrd
			//PedItmIpi
			//PedItmIcmSt
			//PedItmAcr
			
			PedItmCmp = &PedItmCmp
			PedItmVenCod = &PedItmVenCod
			PedVlrTab = &PedVlrTab
			PedVlrUnt = &PedVlrUnt
			PedItmDsc = &PedItmDsc
			//PedItmPrm = &PedItmPrm
			//PedItmCom = &PedItmCom
			PedItmDtaAdd = ServerNow()
			PedCodOciRefItm = &PedCodOciRefItm
			
			//SOMENTE NO INSERT JDF
			PedItmTabDtaVct = &PedItmTabDtaVct
			PedItmTabPerAcr = &PedItmTabPerAcr
			PedItmTabPerAnt = &PedItmTabPerAnt
			
			PedItmProRefDig = &PedItmProRefDig
			
			PedNItmPed = &PedNItmPed
			
			If &PedSts = Status_Pedido.FECHADO or &PedSts = Status_Pedido.SEPARANDO
				Do 'FechaEstoque'
			EndIF
        EndNew
		
		if &ProTipDef = Definicao.SERVICO
			&MensagemInserida = 'Serviço ' +trim(&ProGraRef)+ ', adicionado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		Else
			&MensagemInserida = 'Produto ' +trim(&ProGraRef)+ ', adicionado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		EndIF
		
    EndFor
	Exit
EndFor

commit

AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, 'I')

If  &PedSts <> Status_Pedido.FECHADO and &PedSts <> Status_Pedido.SEPARANDO and &PedSts <> Status_Pedido.CANCELADO
	&AuxPedQtd = &PedQtd - &PedQtdFat
	AtualizaEstoqueCompradoVendido.Call(&EmpCod, &FilCod, &PedProEstProCod, &PedProEstProGraCod, &OldPedQtdSdo, &AuxPedQtd, &LctAtuEst)
EndIF


Sub 'AbreEstoque'		
	//ATUALIZA ESTOQUE
	Do CAse
		CAse &LctAtuEst = Status_EntradaSaida.Entrada //EMPRESA ENTRADA
			if &PedProEstProGraCod > 1 
				AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,1, &OldPedQtd, &OldPedVlrCus, &LctAtuEst, &LctTip, '-', '')
			Endif
			AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,&PedProEstProGraCod, &OldPedQtd, &OldPedVlrCus, &LctAtuEst, &LctTip, '-', '')
			
		CAse &LctAtuEst = Status_EntradaSaida.Saida //EMPRESA SAIDA
			if &PedProEstProGraCod > 1
				AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,1, &OldPedQtd, &OldPedVlrCus, &LctAtuEst, &LctTip, '+', '')
			Endif
			AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,&PedProEstProGraCod, &OldPedQtd, &OldPedVlrCus, &LctAtuEst, &LctTip, '+', '')
	EndCAse
	
	//ATUALIZA PRODUCAO
	Do CAse
		CAse &LctAtuPro = Status_EntradaSaida.Entrada //PRODUCAO ENTRADA
			if &PedProEstProGraCod > 1
				AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, 1, &OldPedQtd, &OldPedVlrCus, &LctAtuPro, '-')
			Endif			
			AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, &PedProEstProGraCod, &OldPedQtd, &OldPedVlrCus, &LctAtuPro, '-')
			
		CAse &LctAtuPro = Status_EntradaSaida.Saida //PRODUCAO SAIDA
			if &PedProEstProGraCod > 1
				AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, 1, &OldPedQtd, &OldPedVlrCus, &LctAtuPro, '+')
			Endif			
			AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, &PedProEstProGraCod, &OldPedQtd, &OldPedVlrCus, &LctAtuPro, '+')
	EndCAse
EndSub

Sub 'FechaEstoque'		
	//ATUALIZA ESTOQUE
	Do CAse
		CAse &LctAtuEst = Status_EntradaSaida.Entrada //EMPRESA ENTRADA
			if &PedProEstProGraCod > 1
				AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '+', '')
			Endif
			AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,&PedProEstProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '+', '')
			
		CAse &LctAtuEst = Status_EntradaSaida.Saida //EMPRESA SAIDA
			if &PedProEstProGraCod > 1
				AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '-', '')
			Endif
			AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &PedProEstProCod,&PedProEstProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '-', '')
	EndCAse
	
	//ATUALIZA PRODUCAO
	Do CAse
		CAse &LctAtuPro = Status_EntradaSaida.Entrada //PRODUCAO ENTRADA
			if &PedProEstProGraCod > 1
				AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, 1, &PedQtd, &PedVlrCus, &LctAtuPro, '+')
			Endif
			AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, &PedProEstProGraCod, &PedQtd, &PedVlrCus, &LctAtuPro, '+')
			
		CAse &LctAtuPro = Status_EntradaSaida.Saida //PRODUCAO SAIDA
			if &PedProEstProGraCod > 1
				AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, 1, &PedQtd, &PedVlrCus, &LctAtuPro, '-')
			Endif
			AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &PedProEstProCod, &PedProEstProGraCod, &PedQtd, &PedVlrCus, &LctAtuPro, '-')
	EndCAse
EndSub
]]></Source>
