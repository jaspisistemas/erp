      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &BalCod = 0 //INSERT
	prcLogAddSdt.Call('BalDta', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('BalFunCod', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('BalObs', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('BalPedCod', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('BalNfeCod', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('BalSts', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('BalTip', '', '', &sdtLogAtributos)
	
Else
	For Each order EmpCod, FilCod, BalCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where BalCod = &BalCod
		
		prcLogAddSdt.Call('BalFunCod', trim(toformattedString(BalFunCod)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('BalDta', trim(toformattedString(BalDta)), '', &sdtLogAtributos)		
		prcLogAddSdt.Call('BalObs', trim(toformattedString(BalObs)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('BalPedCod', trim(toformattedString(BalPedCod)), '', &sdtLogAtributos)		
		prcLogAddSdt.Call('BalNfeCod', trim(toformattedString(BalNfeCod)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('BalSts', trim(BalSts.ToString()), '', &sdtLogAtributos)
		prcLogAddSdt.Call('BalTip', trim(BalTip.tostring()), '', &sdtLogAtributos)
		Exit
	EndFor
Endif
]]></Source>
