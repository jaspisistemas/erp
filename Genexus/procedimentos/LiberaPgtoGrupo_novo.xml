      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem = ''
For each Order EmpCod, FPagCod
	Where EmpCod = &EmpCod
	Where FPagCod = &FPagCod
	Where FPagSts <> Status_Folha.Pago
	where FPagLibPgt = false //somente pra controlar a contagem em WWFOLHAPAGAMENTO
	&IsOK = true
	&ContabilMoeda = FPagTotVlr
	&IsTemDUplicata = false
	&FolPgtVlr = 0
	
	//Contas bancarias
	For each Order EmpCod, FPagCod,FPagCtaCod
		&FolPgtVlr += FPagCtaVlr
		
		if FPagCtaBanCod = 0 	
			&IsOK = false
			&Mensagem += " Existe um ou mais pagamentos sem conta bancária!  "
		EndIf
		If (FPagCtaNroDoc.IsEmpty() or FPagCtaNroDoc.IsNull()) and FPagCtaTip = TipoFolha.ChequePropio
			&IsOK = false
			&Mensagem += " Existe um ou mais pagamentos do: "+trim(str(FPagPesCod))+" do tipo CHEQUE sem preencher o número do documento!  " 
		EndIf
		if &IsOK = false
			exit
		EndIf
	EndFor

	//Duplicatas
	For Each Order EmpCod, FPagCod, FPagDupCod
		&IsTemDUplicata = true
		Exit
	EndFor

	if &ContabilMoeda <> &FolPgtVlr and (&FolPgtVlr > 0 and &IsTemDUplicata = false)
		&IsOK = false
		&Mensagem += " O total dos pagamentos é diferente do valor contábil lançado! VERIFIQUE! "
	EndIf

	if &IsOK = true
		FPagLibPgt = True
	EndIf

	exit 	
when none
	&IsOK = false //se ja tiver liberado, por exemplo
	&Mensagem = "Nenhuma folha disponível para liberar foi encontrada."
EndFor


commit
]]></Source>
