      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&OrdSemProCod = 0
&OrdSemEstQtd = 0
For Each Order EmpCod,ProCod,RecItmCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where RecProTipDef = Definicao.SEMIACABADO
	//&ProGraCod
	&OrdSemProCod = RecProCod
	RetornaQuantidadeEstoque.Call(EmpCod, &FilCod, &OrdSemProCod, 1, &EstCom, &EstVen, &EstPrd, &EstQtd, &EstSdo, &EstSug, &EstQtdFis)
	&OrdSemEstQtd = &EstQtd
	Exit
EndFor
]]></Source>
