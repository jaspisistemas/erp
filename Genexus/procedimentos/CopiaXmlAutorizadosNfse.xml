      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CountNfse = 0
For each Order EmpCod,NfsCliCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod	
	Where NfsCliCod in &ColPesCod when TRIM(&DeondeVem) = 'EMAILAGRUPADO'
	Where NfsDtaEms >= &IniNfeDtaEms and NfsDtaEms <= &FinNfeDtaEms
	Where NfsProTer = &NfsProTer when not &NfsProTer.IsEmpty()
	Where NfsSts = Status_NFe.Autorizada when &SomenteNotasAutorizadas = Status_SimNao.Sim
	&CountNfse += 1
	Msg('Copiando xml das notas de serviço.',status)
	
	&ZipXMLS = trim(str(month(NfsDtaEms))) + trim(str(year(NfsDtaEms))) + '_NFS-E' //nome do arquivo zip
	
	//BUSCAR NOTA AUTORIZADA
	&AnoMesEnviado = PadL(LTrim(str(Year(NfsDtaEms))), 4, '0') + PadL(LTrim(str(Month(NfsDtaEms))), 2, '0')+"\"
	&PastaAutorizada = &sdtConfiguracoesPasta.PastaNFSenviado.Trim() + "autorizados\" + &AnoMesEnviado
	
	&Directory.Source = &PastaAutorizada //Verifica se existe se noa cria.
	if not &Directory.Exists()
		&Directory.Create()
	EndIf
	
	//CRIA DIRETORIO TEMPORARIO
	&PastaTemporaria  = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'xmlNotasServico-'+ trim(&ZipXMLS)
	
	&Directory.Source = &PastaTemporaria //Verifica se existe se noa cria.
	if not &Directory.Exists()
		&Directory.Create()
	Else
		If &CountNfse = 1// primeira nota do envio , mas caso a pasa exist de envios anteriores exclui e cria novamente
			&Directory.Delete()
			&Directory.Create()
		EndIf
	endif
	
	&IsExistDiretorio = true
	
	&ArquivoXML =  trim(&PastaAutorizada) + NfsChv.Trim() + '.xml'
	&ArquivoDestino = &PastaTemporaria +'/'+ NfsChv.Trim() + '.xml'
	
	&File.Source = &ArquivoXML.Trim()		
	if &File.Exists()
		//COPIA PASTA TEMPORARIA
		&File.Copy(&ArquivoDestino)
	else
		&XmlWriter.Open(&ArquivoDestino)
		&XmlWriter.WriteRawText(NfsArqXml)
		&XmlWriter.Close()
	endif
	&File.Close()
	
	
	If &EnviaPdfNota = Status_SimNao.Sim /// envia os pdf
		&ArquivoPdf =  &PastaTemporaria+"\"+ NfsChv.Trim() + '.pdf'
		&File.Source = &ArquivoPdf
		If &File.Exists()
			&File.Delete()
		EndIf
		
		if NfsTipNF = 'S' //Naciona		
			RELJAS148_NAC.Call(EmpCod, NfsCod, &ArquivoPdf)
		Else
			RELJAS148.Call(EmpCod, NfsCod, &ArquivoPdf)
		Endif
		
		&File.Close()
	EndIf
	
Endfor
	
if &IsExistDiretorio = true
	&inputFolderPath =  &PastaTemporaria.Trim()
	&destinoPasta = &PastaTemporaria + ".zip"
	&File.Source = &destinoPasta
	if &File.Exists()
		&File.Delete()
	EndIf
	&File.Close()
	
	//Compacta
	&ZipUtil.ZipFiles(&inputFolderPath, &destinoPasta, &password)
EndIF
]]></Source>
