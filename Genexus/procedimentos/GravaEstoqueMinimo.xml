      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
IniciaEstoque.Call(&EmpCod, &FilCod, &ProCod, 1)

For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	EstMinDia = &EstMinDia
    EstMin    = &EstMin
	EstMinVen = &EstMinVen
	EstMinIni = &EstMinIni
	EstMinFin = &EstMinFin
	Commit
	
	EstDias = 0
	&EstSdo = EstSdo + EstFab

	if EstPrd > 0
		&EstSdo += EstPrd
	EndIF	
	
	If &EstSdo > 0 and &EstMin > 0 and &EstMinDia > 0
		EstDias = round((&EstSdo * &EstMinDia) / &EstMin,0)
	EndIf
	
	EstPrio = OrdPrdPrioridad
	EstSug = round(((EstMin + EstVen) - (EstQtd + EstCom + EstPrd)),0)
	
	Exit   
EndFor

commit
]]></Source>
