      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	&sdtItemNfe.FromJson(&sdtItemNfeLongVarchar)
	
//	padraousuario.Call('G', 'set_cliente', 1, 1, &sdtItemNfe.ToJson(), &PadDtaMod)
//	padraousuario.Call('G', 'set_cliente1', 1, 1, &sdtItemNfeLongVarchar, &PadDtaMod)
	
	&FilCod = &sdtItemNfe.FilCod
	&NfeCod = &sdtItemNfe.NfeCod
	&EmpCod = &wwpContext.EmpCod
	
	&NfeNcmCod = &sdtItemNfe.NfeNcmCod //
	&NfeNcmCest = &sdtItemNfe.NfeNcmCest 
//	&NfeCfoCod = &sdtItemNfe.NfeCfoCod //
//	&NfeSitCod = val(&sdtItemNfe.NfeSitCod) //
	&NfeProQtd = &sdtItemNfe.NfeProQtd //
	&NfeProVlrUnt = &sdtItemNfe.NfeProVlrUnt //
	
    &NfeEmbUnd = &sdtItemNfe.NfeEmbUnd.Trim() //
	&NfeEmbUndTrib =  &sdtItemNfe.NfeEmbUndTrib.Trim() //
	
	&NfeProDadAdi =  &sdtItemNfe.NfeProDadAdi //
	
	&NfeProBarTrib  =  &sdtItemNfe.ProBarTrib //
	&NfeProBar =  &sdtItemNfe.ProBar //
	
//	&NfeProCBenef = &sdtItemNfe.NfeProCBenef 
	
	//		&NfeProBasIcms,
	//		&NfeProTaxIcms,
	//		&NfeProVlrIcms,
	//		&NfeProTaxRedIcms,
	//		&NfeProBasIcmsSt,
	//		&NfeProVlrImcsSt,
	//		&NfeProTaxIcmsSt,
	//		&ImpAlqMVA, 
	//		&NfeProTaxRedIcmsSt,
	//		&NfeProBasIpi,
	//		&NfeProTaxIpi,
	//		&NfeProTaxDif,
	//		&NfeProUFDest, 
	//		&NfeProVlrIpi, 
	//		&NfeCstIpi,
	//		&NfeCstCofins,
	//		&NfeProTaxCofins,
	//		&NfeCstPIS, 
	//		&NfeProTaxPIS, 
	//		&nfeProVlrDif,
	//		&NfeProII_Bas,
	//		&NfeProII_DspAdu,
	//		&NfeProII_IOF,
	//		&NfeProII_vlr,
	//		&NfeProPISRed, 
	//		&NfeProCofinsRed, 
	//		&NfeProVlrPIS,
	//		&NfeProVlrCofins
	
	RetornaProdutoReferencia.Call(&wwpContext.EmpCod, &sdtItemNfe.ProRef, &NfeProCod, &NfeProGraCod, &NfeProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &erroMensagem)
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &wwpContext.EmpCod
		Where ProCod = &NfeProCod
		
		&ProIsGra = ProIsGra
		&ProCatCod = ProCatCod
		&ProOriTriCod = ProOriTriCod
		&ProBasIcmsRet = ProBasIcmsRet
		&ProVlrIcmsRet = ProVlrIcmsRet
		&ProTaxIcmsRet = ProTaxIcmsRet
		
		If ProObrAnp = Status_simNao.Sim		
			&NfeProCodAnp = ProCodAnp
			&NfeProDscAnp = ProDscAnp
			&NfeProPerGlp = ProPerGlp
			&NfeProPerGni = ProPerGni 
			&NfeProPerGnn = ProPerGnn
			&NfeProVlrPar = ProVlrPar
		Else		
			&NfeProCodAnp = 0
			&NfeProDscAnp = ''
			&NfeProPerGlp = 0
			&NfeProPerGni = 0 
			&NfeProPerGnn = 0
			&NfeProVlrPar = 0
		EndiF
	
		//
		&ProPesLiq = ProPesLiqPrd
		
//		&ProIsFabov = ProIsFabov
//		&ProIsIagro = ProIsIagro
//		&ProIsGadoFethab = ProIsGadoFethab 
//		&ProIsSojaFethab = ProIsSojaFethab 
		
//		&ProIncFabov = ProIncFabov
//		&ProIncIagro = ProIncIagro
//		&ProIncGadoFethab = ProIncGadoFethab
//		&ProIncSojaFethab = ProIncSojaFethab
		
		&NfeProRctPen = ProStsRag	
		//
		
		Exit
	EndFor
	
	&NfeProNom = &sdtItemNfe.ProNom
	
	Do Case
		Case &NfeProCod.IsEmpty()
			&sdtRetornowbs.Sts = 'E001'
			&sdtRetornowbs.Obs = 'Informe o Código do Produto!'
			Return
			
		Case &NfeCod = 0
			&sdtRetornowbs.Sts = 'E002'
			&sdtRetornowbs.Obs = 'NFe não localizada'
			Return
			
		CAse &NfeProNom.IsEmpty()
			&sdtRetornowbs.sts = 'E003'
			&sdtRetornowbs.obs = 'Informe a descrição do Produto'
			Return
			
		Case &NfeProQtd <= 0
			&sdtRetornowbs.sts = 'E004'
			&sdtRetornowbs.obs = 'Informe a Quantidade do Produto'
			Return
			
		Case &NfeProVlrUnt <= 0
			&sdtRetornowbs.sts = 'E005'
			&sdtRetornowbs.obs = 'Informe o Valor Unitário (R$ Unit.) do Produto'
			Return
			
		Case &NfeEmbUnd.IsEmpty()
			&sdtRetornowbs.sts = 'E0011'
			&sdtRetornowbs.obs = 'Unidade de medida do produto inválida!'
			Return
	EndCase
		
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		//		&FilTabCod = FilTabCod
		if FilBasImp = 0
			&FilBasImp = FilCod
		Else
			&FilBasImp = FilBasImp
		EndIF
	
		&NfeSts = NfeSts
		RetornaRegimeTributarioFilial.Call(EmpCod, &FilBasImp, &FilRegTrib, &CImpOriUfeCod)
		
		&PedCliCidUfeCod = NfeCliCidUF
		&LctBasImpCod = NfeLctBasImp
		&NfeCliCod = NfeCliCod
		
		If NfeSts <> Status_NFe.Digitando and NfeProTer = Nota_ProPriaTerceira.PROPRIA
			&sdtRetornowbs.Sts = 'E006'
			&sdtRetornowbs.Obs = 'NFe já não esta em modo de digitação, não é possível alterar produtos'
			Return
		Endif
		
		Exit
	When none
		&sdtRetornowbs.Sts = 'E007'
		&sdtRetornowbs.Obs = 'NFe não localizada'
		Return
	EndFor

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NfeCliCod
		&PedCliGruImpCod = PesGruImpCod
		Exit
	When none
		&PedCliGruImpCod = 1
	EndFor
	
	do 'tabImposto'
	if &sdtCadastrotabelaImpostoCbs.CImpIcmsRet <> 'S'
		&ProTaxIcmsRet.SetEmpty()
		&ProBasIcmsRet.SetEmpty()
		&ProVlrIcmsRet.SetEmpty()
	EndIf
	
	do 'ValidaNCM'
	do 'validaCFOP'
	
	do 'TotalItem'
	
	Do Case		
		Case &IsErroNCM = true
			&sdtRetornowbs.sts = 'E008'
			&sdtRetornowbs.obs = &ErrNcmMensagem
			Return
			
		Case not &erroCFOPMensagem.IsEmpty() or &IsErroCFOP = true
			&sdtRetornowbs.sts = 'E009'
			&sdtRetornowbs.obs = &erroCFOPMensagem
			Return
			
		Case not &ErroCSTMensagem.IsEmpty()
			&sdtRetornowbs.sts = 'E010'
			&sdtRetornowbs.obs = &ErroCSTMensagem
			Return
			
		Case (&NfeProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &NfeProGraCod = 1)
			
			&NfeProBasIcmsRet = &ProBasIcmsRet * &NfeProQtd
			&NfeProtaxicmsRet = &ProtaxicmsRet
			if &ProtaxicmsRet > 0 and &NfeProBasIcmsRet > 0 and &sdtCadastrotabelaImpostoCbs.CImpIcmsRet = 'S'
				&NfeProVlrIcmsRet = &NfeProBasIcmsRet - ((&NfeProBasIcmsRet * &ProtaxicmsRet) /100)
			Else
				&NfeProBasIcmsRet = 0
				&NfeProVlrIcmsRet = 0
				&NfeProtaxicmsRet = 0
			Endif	
		
//			GravaNotaFiscalModelo65_Item.      Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &NfeItmCod, &NfeProCod, &NfeProGraCod, &NfeProNom, &NfeProQtd, &NfeProVlrUnt, &NfeProVlrTot, &NfeEmbUnd,&NfeEmbUndTrib, &NfeSitCod,    &ProOriTriCod, &NfeNcmCod, &NfeNcmCest, &NfeCfoCod, &NfeProDadAdi, &NfeProBasIcms,&NfeProTaxIcms,&NfeProVlrIcms,&NfeProTaxRedIcms,&NfeProBasIcmsSt,&NfeProVlrImcsSt,&NfeProTaxIcmsSt,&ImpAlqMVA,&NfeProTaxRedIcmsSt,&NfeProBasIpi,&NfeProTaxIpi,&NfeProTaxDif, &NfeProUFDest, &NfeProVlrIpi, &NfeCstIpi, &NfeCstCofins, &NfeProTaxCofins, &NfeCstPIS, &NfeProTaxPIS, &nfeProVlrDif, &NfeProII_Bas,&NfeProII_DspAdu,&NfeProII_IOF,&NfeProII_vlr,&NfeProCodAnp,&NfeProDscAnp,&NfeProPerGlp, &NfeProPerGni, &NfeProPerGnn, &NfeProVlrPar, &NfeProCBenef, &NfeProPISRed, &NfeProCofinsRed, &NfeProVlrPIS, &NfeProVlrCofins,&NfeProRctPen, &NfeProBasIcmsRet, &NfeProtaxicmsRet, &NfeProVlrIcmsRet, &NfeProBar, &NfeProBarTrib, &NfeNitemPed, &NfeIpiEnq,Status_SimNao.Nao)
			GravaNotaFiscalModelo65_ItemCBSIBS.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &NfeItmCod, &NfeProCod, &NfeProGraCod, &NfeProNom, &NfeProQtd, &NfeProVlrUnt, &NfeProVlrTot, &NfeEmbUnd,&NfeEmbUndTrib, &ProOriTriCod, &NfeNcmCod, &NfeNcmCest, &NfeProDadAdi, &NfeProII_Bas,&NfeProII_DspAdu,&NfeProII_IOF,&NfeProII_vlr,&NfeProCodAnp,&NfeProDscAnp,&NfeProPerGlp, &NfeProPerGni, &NfeProPerGnn, &NfeProVlrPar, &NfeProRctPen, &NfeProBasIcmsRet, &NfeProtaxicmsRet, &NfeProVlrIcmsRet, &NfeProBar, &NfeProBarTrib, &NfeNitemPed, Status_SimNao.Nao, &sdtCadastrotabelaImpostoCbs, &sdtImpostoProduto)
			if &NfeSts = Status_NFe.Digitando
				ObsAutomaticaNFe.call(&wwpContext.EmpCod, &FilCod, &NfeCod)
			EndIf			
			&sdtRetornowbs.sts = 'J200'
			if &NfeItmCod > 0
				&sdtRetornowbs.obs = 'Item alterado com sucesso!'	
			Else
				&sdtRetornowbs.obs = 'Item adicionado com sucesso!'
			Endif
		
			For Each Order EmpCod, FilCod, NfeCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &FilCod
				Where NfeCod = &NFeCod
				&sdtCapaNfe.nfeProVlrTot = trim(NfeProVlrTot.ToFormattedString())
				&sdtCapaNfe.NfeVlrTot = trim(NfeVlrTot.ToFormattedString())
				Exit
			EndFor
		
			&sdtRetornowbs.detalhes = &sdtCapaNfe.ToJson()
			
		Otherwise
			&sdtRetornowbs.sts = 'E011'
			&sdtRetornowbs.obs = 'Produto com Variação, é preciso inserir o Código da Variação!'
			Return	
	EndCase
Endif

Sub 'TotalItem'
	
	&NfeProVlrTot = &NfeProQtd * &NfeProVlrUnt
	
	if &sdtCadastrotabelaImpostoCbs.CImpCstCod in (domSituacaoTributariaVarchar.CST02,domSituacaoTributariaVarchar.CST15, domSituacaoTributariaVarchar.CST53, domSituacaoTributariaVarchar.cst61)
		&ProBasVlrIcm = &NfeProQtd * &ProPesLiq		
	Else
		&ProBasVlrIcm = &NfeProVlrTot
	EndIf

	&sdtImpostoProduto = new()
	&sdtImpostoProduto.ProBasVlrIcm = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasVlrIcmSt = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasVlrIpi = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasPis = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasCofins = &ProBasVlrIcm
	&sdtImpostoProduto.ValorTotalProduto = &ProBasVlrIcm //Total do produto

	CalculaImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs, &sdtImpostoProduto) //Calcula impostos
EndSub

Sub 'validaCFOP'
	
	&erroCFOPMensagem = ''
	&erroMensagem = ''
	&ErroCSTMensagem = ''
	
	&IsErroCFOP = false
	
	For Each Order CfoCod
		Where CfoCod = &sdtCadastrotabelaImpostoCbs.CImpCfoCod
		Exit
	When none
		&erroCFOPMensagem = 'CFOP inválido!'
		&IsErroCFOP = true
	EndFor
	
	&erroCFOPMensagem = validaCfopTabelaImposto.UDP(&wwpContext.EmpCod, &FilBasImp, &LctbasImpCod, &PedCliCidUfeCod, &sdtCadastrotabelaImpostoCbs.CImpCfoCod)
	If not &erroCFOPMensagem.IsEmpty()
		&erroMensagem = &erroMensagem.Trim() + newLine() + &erroCFOPMensagem.Trim()
	EndIF
	&Varchar = &sdtCadastrotabelaImpostoCbs.CImpCstCod.ToString()
	&NfeSitCod = val(&Varchar)
	&ErroCSTMensagem = validaSituacaoTributaria.Udp(&wwpContext.EmpCod, &FilBasImp, &NfeSitCod)
	if not &ErroCSTMensagem.IsEmpty()
		&erroMensagem = &erroMensagem.Trim() + newLine() + &ErroCSTMensagem.Trim()
	EndIF
EndSub

Sub 'ValidaNCM'

	&IsErroNCM = true
	For Each Order NcmCod
		Where NcmCod = &NfeNcmCod		
		&IsErroNCM = false
		
		if NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()
			&ErrNcmMensagem = 'FIM DA VIGENCIA NCM: '+trim(Str(&NfeNcmCod)) + ' ' + NcmDes.Trim()
			&IsErroNCM = true
		Endif
		
		Exit
	When none
		Do CAse
			CAse &NfeNcmCod =  0
				//&NcmDes = 'CÓDIGO 00000000 - SERVIÇOS'
				&IsErroNCM = false
			CAse &NfeNcmCod =  99
				msg('CÓDIGO NCM NÃO INFORMADO!')
			Otherwise
				msg('CÓDIGO NCM NÃO CADASTRADO/INVÁLIDO!')
		EndCAse
	EndFor
EndSub


Sub 'tabImposto'
	
	&sdtCadastroTabelaImpostoCbs = new()
	&sdtCadastroTabelaImpostoCbs.EmpCod = &EmpCod
	&sdtCadastroTabelaImpostoCbs.CImpTbFilCod = &FilBasImp
	&sdtCadastroTabelaImpostoCbs.CImpLctCod = &LctBasImpCod
	&sdtCadastroTabelaImpostoCbs.CImpOriUfeCod = &CImpOriUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpDstUfeCod = &PedCliCidUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpGruImpCod = &PedCliGruImpCod
	&sdtCadastroTabelaImpostoCbs.CImpCatCod = &ProCatCod
	&sdtCadastroTabelaImpostoCbs.CImpDtaIni = serverdate()
	&sdtCadastrotabelaImpostoCbs.ProCod = &NfeProCod
	prcRetornaConfiguracaoImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs)
	
EndSub
]]></Source>
