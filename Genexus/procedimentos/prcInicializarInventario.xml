      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[



&AuxFim = YMDtoD(&InvAno, &InvMes, 1)
&IniPedDtaFat = EOM(&AuxFim)

&IniPedDtaFat = &IniPedDtaFat.AddDays(1)
&FinPedDtaFat = serverdate()

For Each Order InvEmpCod, InvFilCod, InvAno, InvMes, InvProCod, InvProGraCod
	Where InvEmpCod = &InvEmpCOd
	Where InvFilCod = &FilCod
	Where InvAno = &InvAno
	Where InvMes = &InvMes
	
	Delete
EndFor

Commit

For Each Order EmpCod, ProCod
	Where EmpCod = &InvEmpCOd
	Where ProSts = Status_AtivoInativo.ATIVO
	Where ProTipDef <> Definicao.SERVICO and ProTipDef <> Definicao.IMOBILIZADO
	Where ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
	
	&Total += 1
EndFor

&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'


For Each Order EmpCod, ProCod
	Where EmpCod = &InvEmpCOd
	Where ProSts = Status_AtivoInativo.ATIVO
	Where ProTipDef <> Definicao.SERVICO and ProTipDef <> Definicao.IMOBILIZADO
	Where ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
	
	For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
	    Where FilCod = &InvFilCod
		
		if EstQtd > 0
			&InvProQtdAtu = EstQtd
		Endif
		
		Exit
	EndFor	
	
	EstoqueAnteriorFicha.Call(EmpCod, &FilCod, ProCod, ProGraCod, 1, &IniPedDtaFat, &FinPedDtaFat, &AntEstQtd)	
	
	if ProVlrCus > 0 and &AntEstQtd > 0	
		prcGravaItemInventario.Call(EmpCod, &FilCod, &InvAno, &InvMes, ProCod, ProGraCod, &AntEstQtd, &InvProQtdAtu, ProVlrCus)
		
		&Calcula += 1
		if &Calcula >= 50
			&Count += &Calcula
			If &Count > 0
				&Percentual = round((&Count / &Total) * 100, 0)
			EndIF
			If &Percentual >= 100
				&Percentual = 99
			EndIf
			
			do 'Atualiza'
			&Calcula = 0
		EndiF
	EndIF
EndFor


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &sdtEstoque.ToXml()
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &sdtEstoque.ToXml()
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor

	commit
EndSub
]]></Source>
