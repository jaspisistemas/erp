      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CteCod = 0
If &CteProTer = Nota_ProPriaTerceira.PROPRIA
//	For Each Order EmpCod, FilCod, CteNum, NfeSer, ModCod, NfeCod
//		Where EmpCod = &EmpCod
//		Where FilCod = &FilCod
//		Where NfeNum = &NfeNum
//		Where NfeSer = &NfeSer
//		Where ModCod = &ModCod
//		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
//			&NfeCod = NfeCod
//		Exit	
//	EndFor
Else //Terceiros
	For Each Order EmpCod, FilCod, CteNum, CteSer, CteModCod, CteTomCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteNum = &CteNum
		Where CteSer = &CteSer
		Where CteModCod = &ModCod
		Where CteProTer = Nota_ProPriaTerceira.TERCEIROS
		Where (CteTomCod = &CteTomCod and &CteTomCod > 0) //or (CtePedCod = &CtePedCod and &CtePedCod > 0)
		Where CteSts <> Status_NFe.Importada
			&CteCod = CteCod
		Exit	
	EndFor
EndiF
]]></Source>
