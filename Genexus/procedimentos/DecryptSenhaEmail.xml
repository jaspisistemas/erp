      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//https://app.jaspi.com.br/CryptoDecrypt.aspx

&Key = RetornaKeyCryptografia.UDP('EMAIL')
//acesso 'zimutkcfycjugpvg'
Do case 
	CAse &EmpEml = 'nao.responda@jaspisistemas.com.br'
		&EmpEmlSen =  Decrypt64('fA5nNeaSgxznKqzBI5CPUw==', &Key) //!''
	
	Case &EmpEml = 'nao_responda@jaspi.com.br' or &EmpEml = 'nao.responda.jaspi@gmail.com' 
		&EmpEmlSen =  Decrypt64('KYjQGkAQTjhgXFfAaTUqQg==', &Key) 
		
	Case &EmpEml = 'nao.responda.jaspi.01@gmail.com'
		&EmpEmlSen = Decrypt64('lwS/MzpoEwwxpp6DVi6PvA==', &Key) 
		
	Case &EmpEml = 'nao.responda.jaspi.02@gmail.com'
		&EmpEmlSen = Decrypt64('M/WyxW/po2naT/2qeC1U1Q==', &Key) 
				
	Otherwise
	
	For Each Order EmpCod, EmpEmlCod
		Where EmpCod = &EmpCod
		Where EmpEmlCod = &EmpEmlCod
		&EmpEmlSen = Decrypt64(EmpEmlSen, &Key)
		Exit
	EndFor

EndCAse
]]></Source>
