      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&vFlag = 0 
&vNumero = trim(&vNumero)
RetornaSoNumeros.Call(&vNumero, &vNumero)
if &PerSemCpfCgc <> 'S' and &vNumero.IsEmpty()
    &vFlag = 0 
    return 
endif



&CGCCPF.SetEmpty()
if &vNumero.IsEmpty() // Numero AlfaNumerico
    &vFlag = 1
    return
endif

&vCont = 1
&VQtdNum = 0
&vFlag = 0

do while &vCont <= 18
    &vNum = substr(&vNumero, &vCont, 1)
    
    If ((&vNum = '0') Or (&vNum = '1') Or (&vNum = '2') Or (&vNum = '3') Or (&vNum = '4') Or (&vNum = '5') Or (&vNum = '6') Or (&vNum = '7') Or (&vNum = '8') Or (&vNum = '9'))
        
        &CGCCPF  = concat( &CGCCPF, &vNum  )
    endif
    &vCont = &vCont + 1
EndDo

&vNumero1 = val(&CGCCPF )
&VQtdNum  = Len(Trim(&CGCCPF))

If &vNumero1.IsEmpty()
    &vFlag = 1
    return
endif

// O numero do CPF ou CNPJ deve conter 14 digitos
&VQtdfalta = 14 - &VQtdNum

if &VQtdfalta = 1
    &CGCCPF = concat('',&CGCCPF ,'0')
else
    if &VQtdfalta = 2
        &CGCCPF = concat('',&CGCCPF ,'00')
    else
        if &VQtdfalta = 3
            &CGCCPF = concat('',&CGCCPF ,'000')
        else
            if &VQtdfalta = 4
                &CGCCPF = concat('',&CGCCPF ,'0000')
            else
                if &VQtdfalta = 5
                    &CGCCPF = concat('',&CGCCPF ,'00000')
                else
                    if &VQtdfalta = 6
                        &CGCCPF = concat('',&CGCCPF ,'000000')
                    endif
                endif
            endif
        endif
    endif
endif

If (&VQtdNum > 11)
    // Calcular o CNPJ do Cliente
    Do 'Calc_CNPJ'
    
    If (&vFlag = 1)
        // Calcular o CPF do Cliente
        Do 'Calc_CPF'
    EndIf
Else
    // Calcular o CPF do Cliente
    Do 'Calc_CPF'
    
    If (&vFlag = 1)
        // Calcular o CNPJ do Cliente
        Do 'Calc_CNPJ'
    EndIf
EndIf
RETURN

// Rotina de Verificação do Digito do CNPJ
Sub 'Calc_CNPJ'
    // testa CGC
    &vFlag = 0
    &Tot   = 0
    &Pos   = 1
    &Pes   = 5
    &Dig1  = 0
    &Dig2  = 0
    Do While &Pos <= 12
       &Num = val(substr(&CGCCPF , &Pos , 1)) * &Pes
       &Tot = &Tot + &Num
       &Pes = &Pes - 1
       &Pos = &Pos + 1
       If &Pes < 2
           &Pes = 9
       Endif
    Enddo
    &Res = &Tot - int(&Tot/11) * 11
    If &Res = 0 .OR. &Res = 1
        &Dig1 = 0
    Else
        &Dig1 = 11 - &Res
    Endif
    &Tot = 0
    &Pes = 6
    &Pos = 1

    Do While &Pos <= 13
        &Num = val(substr(&CGCCPF , &Pos ,1)) * &Pes
        &Tot = &Tot + &Num
        &Pes = &Pes - 1
        &Pos = &Pos + 1
        If &Pes < 2
           &Pes = 9
        Endif
    Enddo
    &Res = &Tot - int(&Tot / 11) * 11
    If &Res = 0 .OR. &Res = 1
        &Dig2 = 0
    Else
        &Dig2 = 11 - &Res
    Endif
    if val(substr(&CGCCPF,13,1)) <> &Dig1 .OR. val(substr(&CGCCPF,14,1)) <> &Dig2
       &vFlag = 1
    else
       //======= colocar picture no  CNPJ
        &vCGC01 = concat(substr(&CGCCPF ,1,2) , substr(&CGCCPF ,3,3), '.')
        &vCGC03 = concat(substr(&CGCCPF ,6,3) , substr(&CGCCPF ,9,4), '/')
        &vCGC04 = concat(&vCGC01 , &vCGC03 , '.')
        &vNumero = concat(&vCGC04 , substr(&CGCCPF ,13,2), '-')
    Endif
EndSub

// Rotina de Verificação do Digito do CPF
Sub 'Calc_CPF'
    &vFlag = 0
    &Tot   = 0
    &Pos   = 4
    &Pes   = 10
    &Dig1  = 0
    &Dig2  = 0
    Do While &Pos <= 12
       &Num = val(substr(&CGCCPF , &Pos , 1)) * &Pes
       &Tot = &Tot + &Num
       &Pes = &Pes - 1
       &Pos = &Pos + 1
       If &Pes < 2
           &Pes = 9
       Endif
    Enddo
    &Res = &Tot - int(&Tot/11) * 11
    If &Res = 0 .OR. &Res = 1
        &Dig1 = 0
    Else
        &Dig1 = 11 - &Res
    Endif
    &Tot = 0
    &Pes = 11
    &Pos = 4
    Do While &Pos <= 13
        &Num = val(substr(&CGCCPF , &Pos ,1)) * &Pes
        &Tot = &Tot + &Num
        &Pes = &Pes - 1
        &Pos = &Pos + 1
        If &Pes < 2
           &Pes = 9
        Endif
    Enddo
    &Res = &Tot - int(&Tot / 11) * 11
    If &Res = 0 .OR. &Res = 1
        &Dig2 = 0
    Else
        &Dig2 = 11 - &Res
    Endif
    if val(substr(&CGCCPF,13,1)) <> &Dig1 .OR. val(substr(&CGCCPF,14,1)) <> &Dig2
       &vFlag = 1
    else
       //======= colocar picture no  CPF
       &VCPF01 = concat(substr(&CGCCPF ,4,3) , substr(&CGCCPF ,7,3), '.')
       &VCPF02 = concat(substr(&CGCCPF ,10,3) , substr(&CGCCPF ,13,2), '-')
       &vNumero = concat(&VCPF01 ,&VCPF02 , '.')
    Endif
EndSub
]]></Source>
