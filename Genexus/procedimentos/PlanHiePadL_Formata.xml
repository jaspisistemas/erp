      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PlanHiePadL.SetEmpty()

&Caractere = &PlanHie //Retorna Numero e pontos Ex: 10.1.2
do 'soNumeros'

&indexFinal = 1
&IsContinua = true

do while &IsContinua = true //Separa os Nó
	
	&indexFinal = &Numeros.IndexOf('.', &indexFinal)	
	&indexFinal -= 1
	if &indexFinal <= 0
		&indexFinal = &Numeros.Length()
	Endif
	
	&Codigo = Substr(&Numeros, 1, &indexFinal)
	
	&indexFinal += 2
	&QtdLevel += 1
	
	If &Codigo.IsEmpty()
		&IsContinua = false
	Else
		&Numeros = Substr(&Numeros, &indexFinal, 50)
		do 'AddPlanHiesPadL'
	EndIF
	&indexFinal = 1
EndDo

&Codigo = Substr(&Numeros, 1, 50)

do 'AddPlanHiesPadL'

do while &QtdLevel < 5
	&QtdLevel += 1
	&Codigo = '00000'
	do 'AddPlanHiesPadL'
EndDo


sub 'AddPlanHiesPadL'
	if not &PlanHiePadL.IsEmpty()
		&PlanHiePadL += '.'
	EndIf
	&PlanHiePadL += PadL(trim(&Codigo), 5, '0')
EndSub


Sub 'soNumeros'
	&Pos = 1
	&Numeros = ''
	
	Do While &Pos <= 100
		if (substr(&Caractere,&Pos,1) >= '0' and substr(&Caractere,&Pos,1) <= '9') or (substr(&Caractere,&Pos,1) = '.' and not &Numeros.IsEmpty())
			If substr(&Caractere,&Pos,1) = '.'
				&temDepois = Substr(&Caractere, &Pos, 100)
				&temDepois = RetornaSoNumeros.Udp(&temDepois)
				
				if &temDepois <> ''
					&Numeros += substr(TRIM(&Caractere),&Pos,1)
				EndIF
			else
		        &Numeros += substr(TRIM(&Caractere),&Pos,1)
			EndIF
	    Endif
		
	    &Pos += 1
	EndDo
EndSub
]]></Source>
