      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVA LOG
&TabelaVarchar = 'PEDIDOPRODUTO'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
&LogErpRegCod1 = trim(Str(&PedCod))

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
    For Each Order EmpCod FilCod, PedCod, PedItmCod
	    Where PedItmCod = &PedItmCod
		
		if &LogErpTabIsLog = true
			&LogErpRegCod2 = trim(toformattedString(PedItmCod))
			&LogErpRegTip = TrnMode.Update
			&LogErpRegGUID.SetEmpty()
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmAcr', trim(toformattedString(PedItmAcr)), trim(toformattedString(&PedItmAcr)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmDsc', trim(toformattedString(PedItmDsc)), trim(toformattedString(&PedItmDsc)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmIpi', trim(toformattedString(PedItmIpi)), trim(toformattedString(&PedItmIpi)), &LogErpRegGUID )
			
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmIcmSt', trim(toformattedString(PedItmIcmSt)), trim(toformattedString(&PedItmIcmSt)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmIcmStPob', trim(toformattedString(PedItmIcmStPob)), trim(toformattedString(&PedItmIcmStPob)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmIcm', trim(toformattedString(PedItmIcm)), trim(toformattedString(&PedItmIcm)), &LogErpRegGUID )			
		Endif//GRAVA LOG
	
		PedItmAcr 		= &PedItmAcr 
		PedItmDsc 		= &PedItmDsc
		PedItmIpi 		= &PedItmIpi
		PedItmIcmSt 	= &PedItmIcmSt
		PedItmIcmStPob 	= &PedItmIcmStPob
		PedItmIcm 		= &PedItmIcm
		
		Commit
		
		Exit		
	EndFor
	
	Exit	
EndFor

AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, '')
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
