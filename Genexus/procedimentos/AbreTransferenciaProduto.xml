      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 50
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

For Each Order EmpCod, TrsCod
	Where EmpCod = &EmpCod
	Where TrsCod = &trsCod
	
	&TrsSaiFilCod = TrsSaiFilCod 
	&TrsEntFilCod = TrsEntFiLCod
	
	&TrsDtaEms = TrsDtaEms
	
	&OrigemPedCod = TrsSaiPedCod
	do 'insertPedidoCapaOrigem'
	
	&Count = 50
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	&DestinoPedCod = TrsEntPedCod
	do 'insertPedidoCapaDestino'
	
	&TrsEntNfeCod = TrsEntNfeCod
	&TrsEntFilCod = TrsEntFiLCod
	
	TrsSts = Status_Pedido.ABERTO
	Exit
EndFor

Commit

For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &TrsEntFilCod 
	Where NfeCod = &TrsEntNfeCod
	
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		delete
	EndFor
	
	Delete
EndFor

Commit


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
	
	if &ProgressId = 'cmdRecalculo'
		msg('Produto:' + trim(str(&AuxProCod)) + ' Percentual: ' + trim(str(&Percentual)))
	EndIF
EndSub

sub 'insertPedidoCapaDestino'
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &TrsEntFilCod
		Where PedCod = &DestinoPedCod
		
		PedSts = Status_Pedido.ABERTO
		Exit
		
	EndFor

	commit
	
	AtualizaTotaisPedido.Call(&EmpCod, &TrsEntFilCod, &DestinoPedCod, 0, 'C')
		
	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	AtualizaEstoqueEntradaSaida.Call(&EmpCod, &TrsEntFilCod, &DestinoPedCod, Status_Pedido.ABERTO)
	
EndSUb

sub 'insertPedidoCapaOrigem'
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &TrsSaiFilCod
		Where PedCod = &OrigemPedCod
		
			PedSts = Status_Pedido.ABERTO
		Exit
	
	EndFor

	commit

	AtualizaTotaisPedido.Call(&EmpCod, &TrsSaiFilCod, &OrigemPedCod, 0, 'C')
	
	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	AtualizaEstoqueEntradaSaida.Call(&EmpCod, &TrsSaiFilCod, &OrigemPedCod, Status_Pedido.ABERTO)

EndSUb
]]></Source>
