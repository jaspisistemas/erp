        <Source><![CDATA[MT 0
MB 0

&NumeroPedido = trim(str(&EtqVolPedCod))
&IsLadoDireito = false

//print Cabecalho


For Each Order EmpCod, EtqVolFilCod, EtqVolPedCod, (EtqVolNro)
	Where EmpCod = &EmpCod
	Where EtqVolFilCod = &EtqVolFilCod
	Where EtqVolPedCod = &EtqVolPedCod
	&UltimaCAixaEtqVolNro = EtqVolNro
	Exit
EndFor


For Each Order EmpCod, EtqVolFilCod, EtqVolPedCod, EtqVolNro
	Where EmpCod = &EmpCod
	Where EtqVolFilCod = &EtqVolFilCod
	Where EtqVolPedCod = &EtqVolPedCod
	
	
	&EtqVolNro = EtqVolNro
	&NumeroCaixa = padL(trim(Str(&EtqVolNro)), 3, '0') + ' / '+ padL(trim(Str(&UltimaCAixaEtqVolNro)), 3, '0')
	
	Do 'GetDadosCliente'
	Print LadoEsquerdo
	&count = 0
	For Each Order EmpCod, EtqVolFilCod, EtqVolPedCod, EtqVolNro
		&count+=1
		//	If not EtqVolCodBar.IsEmpty()
		//		&File.Source = &NomeImagem
		//		if not &File.Exists()
		//			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqVolCodBar,  EtqVolCodBar)
		//		EndIF
		//		If &File.Exists()
		//			&CodigoBarrasImage.FromURL(&NomeImagem)
		//		EndIF
		//	EndIf
		&AuxEtqVolNovProNom = trim(EtqVolNovRefCod)+' -'+trim(EtqVolNovProNom)
		&EtqVolNovProNom = gxGetMLi(&AuxEtqVolNovProNom, 1, 50)
		//		&EtqVolNovProNom2 = gxGetMLi(EtqVolNovProNom, 2, 50)
		//		RetornaFilialFaturamento.Call(&EmpCod, &EtqVolFilCod, &FilRaz, &FiLCidNom, &FilLog, &Contato, &Contato2, &FilImg146_50, &FilFan)
		&EtqVolPedQtd = EtqVolPedQtd
		
		If &count <= 7  //so cabe 7 produtos por etiqueta
			print Produto
		Else
			Print LinhaBranca //encerra etiqueta anterior
			eject //nova etiqueta
			Print LadoEsquerdo
			print Produto // linha 8
			&count = 1
			
		EndIf
		
	Endfor

	Print LinhaBranca
	eject	
EndFor

Sub 'GetDadosCliente'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &EtqVolFilCod
		
		&PesRaz = substr(FilRaz,1,100)
		&PesCnpj = FilCpj.Trim()
		&PesFonNum = FilFonNum
		
		Exit
	EndFor
EndSub
]]></Source>
