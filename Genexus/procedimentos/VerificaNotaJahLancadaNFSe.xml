      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NfsCod = 0
If &NfsProTer = Nota_ProPriaTerceira.PROPRIA
	For Each Order EmpCod, NfsFilCod, NfsNum, NfsCod
		Where EmpCod = &EmpCod
		Where NfsFilCod = &NfsFilCod
		Where NfsNum = &NfsNum
		Where NfsProTer = Nota_ProPriaTerceira.PROPRIA
			&NfsCod = NfsCod
		Exit	
	EndFor
Else //Terceiros
	For Each Order EmpCod, NfsFilCod, NfsNum, NfsCliCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsFilCod = &NfsFilCod
		Where NfsNum = &NfsNum
		Where NfsProTer = Nota_ProPriaTerceira.TERCEIROS
		Where (NfsCliCod = &NfsCliCod and &NfsCliCod > 0) // or (NfsPedCod = &NfsPedCod and &NfsPedCod > 0)
			&NfsCod = NfsCod
		Exit	
	EndFor
EndiF
]]></Source>
