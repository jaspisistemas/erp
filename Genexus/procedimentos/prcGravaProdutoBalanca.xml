      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[




For Each Order EmpCod, BlcCod, BlcProCod, BlcProGraCod
	Where EmpCod = &EmpCod
	Where BlcCod = &BlcCod
	Where BlcProCod = &ProCod
	Where BlcProGraCod = &ProGraCod
		BlcQtdVal = &BlcQtdVal
		&Mensagem = 'PRODUTO ATUALIZADO'
	Exit
When None
	
	&BlcItmCod = 0
	For Each Order EmpCod, BlcCod, (BlcItmCod)
		Where EmpCod = &EmpCod
		Where BlcCod = &BlcCod
		&BlcItmCod = BlcItmCod
		exit
	EndFor
	&BlcItmCod += 1
	&Mensagem = 'PRODUTO ADICIONADO'
	new
		EmpCod = &EmpCod
		BlcCod = &BlcCod
		BlcItmCod = &BlcItmCod
		BlcProCod = &ProCod
		BlcProGraCod = &ProGraCod
		BlcQtdVal = &BlcQtdVal
		BlcPesUnit = &BlcPesUnit
	EndNEw
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
