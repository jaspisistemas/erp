      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//PEGA DADOS DO PEDIDO
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&LctAtuEst = LctAtuEst
	&PedSts = PedSts
	&PedDtaFat = PedDtaFat
	Exit
EndFor

//SOMENTE SE PEDIDO FOR FECHADO, ENTAO ABRE
if &PedSts in (Status_Pedido.FECHADO, Status_Pedido.SEPARANDO) and &PedDtaFat <> &NovPedDtaFat
	if &LctAtuEst = Status_EntradaSaida.Entrada
		AtualizaEstoqueGerencialCompra.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &PesCod, Status_Pedido.ABERTO)
	Else
		if &LctAtuEst = Status_EntradaSaida.Saida	
			AtualizaEstoqueGerencialVenda.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &PesCod, Status_Pedido.ABERTO)
		EndIF
	EndIf
EndIF

//ALTERA DATAS DO PEDIDO
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&PedCod))
		&LogErpRegTip = TrnMode.Update
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedDtaEms', trim(toformattedString(PedDtaEms)), trim(toformattedString(&NovPedDtaEms)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedDtaFat', trim(toformattedString(PedDtaFat)), trim(toformattedString(&NovPedDtaFat)), &LogErpRegGUID )
	Endif

	PedDtaEms = &NovPedDtaEms
	PedDtaFat = &NovPedDtaFat
	PedDtaFic = &NovPedDtaFat
EndFor

Commit

//VOLTA PEDIDO PARA FECHADO
if &PedSts in (Status_Pedido.FECHADO, Status_Pedido.SEPARANDO) and &PedDtaFat <> &NovPedDtaFat
	if &LctAtuEst = Status_EntradaSaida.Entrada
		AtualizaEstoqueGerencialCompra.Call(&EmpCod, &FilCod, &PedCod, &NovPedDtaFat, &PesCod,  &PedSts)
	Else
		if &LctAtuEst = Status_EntradaSaida.Saida	
			AtualizaEstoqueGerencialVenda.Call(&EmpCod, &FilCod, &PedCod, &NovPedDtaFat, &PesCod, &PedSts)
		EndIF
	EndIf
EndIF
]]></Source>
