      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	
	&SdtGravaPessoa.PesRaz = PesRaz 
	&SdtGravaPessoa.PesFan = PesFan
	&SdtGravaPessoa.PesRazNF = PesRazNf
	
	&SdtGravaPessoa.PesIsCli = PesIsCli
	&SdtGravaPessoa.PesIsFor = PesIsFor
	&SdtGravaPessoa.PesIsFun = PesIsFun
	&SdtGravaPessoa.PesIsVen = PesIsVen
	&SdtGravaPessoa.PesIsTra  = PesIsTra 
	
	&SdtGravaPessoa.PesCidCod = PesCidCod
	&SdtGravaPessoa.PesInsEst = PesInsEst 
	&SdtGravaPessoa.PesCadPro = PesCadPro
	&SdtGravaPessoa.PesRg = PesRg
	&SdtGravaPessoa.PesCnpj = PesCnpj
	&SdtGravaPessoa.PesCpf = PesCpf
	&SdtGravaPessoa.PesTip = PesTip
	&SdtGravaPessoa.PesSuf = PesSuf
	
	&SdtGravaPessoa.PesCliCrd = PesCliCrd 
	
	//Endereço
	&SdtGravaPessoa.PesLog = PesLog
	&SdtGravaPessoa.PesNro = PesNro
	&SdtGravaPessoa.PesBai = PesBai
	&SdtGravaPessoa.PesCep = PesCep
	&SdtGravaPessoa.PesCpl = PesCpl
	
	&SdtGravaPessoa.OriCod = OriCod
	&SdtGravaPessoa.RatCod = RatCod
	&SdtGravaPessoa.PesGruImpCod = PesGruImpCod
	
	&SdtGravaPessoa.PesEmpCodSec = PesEmpSecCod 
	&SdtGravaPessoa.PesDtaVctCer = PesDtaVctCer
	&SdtGravaPessoa.PesEscCtbCod = PesEscCtbCod
	&SdtGravaPessoa.PesObs = PesObs 
	exit
	
EndFor
]]></Source>
