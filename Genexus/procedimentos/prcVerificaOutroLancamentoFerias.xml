      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each ORder EmpCod, FPagCod
	Where EmpCod = &EmpCod
	Where FPagPesCod = &FPagPesCod 
	where FPagAno = &FpagAno 
	Where FPagTip = TipoPagamentoFolha.Ferias
	Where FPagCod <> &FPagCod 
	
	
	For Each Order EmpCod, FPagCod, FPagLcfCod
		
		Do Case 
			Case FPagLcfCod = 15 //Ferias
				&IsExisteFerias = true
				&FolhaFPagItemCpl = FPagItemCpl
			Case FPagLcfCod = 16 
				&IsExisteTercoFerias = true
				&TercoFPagItemCpl= FPagItemCpl
		EndCase
	EndFor

	if &IsExisteFerias = true and &IsExisteTercoFerias = true
		Exit
	EndIf
EndFor

	
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
