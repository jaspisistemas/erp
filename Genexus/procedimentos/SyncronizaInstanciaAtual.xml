      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[SyncronizaInativaInstancia(&LogGUID,&WinAppGUID,&pPgmname)

&json = &ProcessManager.GetCurrentProcess()
&sdtProcessInfo.FromJson(&json)
msg(&Pgmname + ' ['+ &pPgmname + ']: Esta instância: ' + &sdtProcessInfo.ToJson(), status)

&isContinua = false
for each order WinAppGUID
	where WinAppGUID = &WinAppGUID
	where WinAppIsHabilitado = true
	Msg('Aplicativo está habilitado. Ok.', status)
	&WinAppNom = WinAppNom
	
	for each order WinAppInsGUID
		where WinAppInsSts = Status_Instancia.ATIVO
		Msg('Aplicativo possui instância ativa', status)
		
		if WinAppIsCriaNovo
			Msg('Pode registrar esta instância', status)
			do 'RegistraEstaInstancia'
			&isContinua = true
		else
			Msg('Não pode registrar esta instância', status)
		endif
		
		exit
	when none
		// segue o fluxo
		Msg('Aplicativo não possui instância ativa', status)
		do 'RegistraEstaInstancia'
		&isContinua = true
	endfor
	
	exit
when none
	Msg('Aplicativo não está habilitado', status)
endfor

Sub 'RegistraEstaInstancia'
	&WinAppInsGUID = GUID.NewGuid()
	GravaLogDevNew(0,&LogGUID,&Pgmname,'Registrando nova instância', &WinAppNom + ' ' + &WinAppInsGUID.ToString().Trim())
	prcInstanciaApp('NEW',&WinAppGUID,&WinAppInsGUID,&sdtProcessInfo.PID,&WinAppInsLog)
	msg('Registrando instância', status)
EndSub
]]></Source>
