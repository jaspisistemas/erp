      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do case	
	Case &OqueFazer = 'AUTORIZA_CTE_CCE' //INUTILIZA CTE
		For Each Order EmpCod, FilCod, CteCod,CteCCeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CteCod = &CteCod
			Where CteCCeCod = &CteCceCod
			Where CteSts <> &CteSts		
			
			CteCCeSts = &CteSts
			CteCCeStat = &CteAutSts
			CteCCexMotivo = &CteAutMsg
			CteCCeProt = &CteAutNumPro
			Exit
		EndFor
	
		Commit
EndCase

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
