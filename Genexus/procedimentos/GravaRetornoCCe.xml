      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	Where NfeCCeCod = &NfeCceCod
	
    NfeCCecStat   = &NfeCCecStat
    NfeCCexMotivo = &NfeCCexMotivo
    NfeCCeProt    = &NfeCCeProt
	
    If &NfeCCecStat in ('135', '136', '573')//CCe AUTORIZADA
        NfeCCeSts = Status_NFe.Autorizada
    EndIF

	Exit
EndFor

commit


If &NfeCCecStat in ('135', '136', '573')//CCe AUTORIZADA
	For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod //CANCELA TODAS AS OUTRAS CARTAS.
		where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeCCeCod <> &NfeCceCod
	    NfeCCeSts = Status_NFe.Cancelada
	EndFor
EndiF


commit
]]></Source>
