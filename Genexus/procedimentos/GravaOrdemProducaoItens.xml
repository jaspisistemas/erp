      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&OrdCod = 0
&auxGrupHie = trim(&GrupHie) + '.'

//CAPA ORDEM PRODUCAO
For Each Order EmpCod, FilCod, OrdSts, (OrdCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdSts = Status_Producao.Aguardando
	Where OrdGrupHie like &auxGrupHie or OrdGrupHie = &GrupHie when not &GrupHie.IsEmpty()
	Where OrdSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	
	OrdTip = &OrdTip
	OrdDta = serverdate()
	OrdDtaPrd = &DataProducao
	OrdHorPrd = &OrdHorPrd
	OrdDtaFinPrd = &OrdDtaFinPrd
	OrdHorFinPrd = &OrdHorFinPrd
	
	&OrdCod = OrdCod
	
	For Each Order EmpCod, FilCod, OrdCod, OrdItmCod
		delete
	EndFor
	
	For Each Order EmpCod,FilCod,OrdCod,OrdMatItmCod
		delete
	EndFor
	
	Exit
When none
	
	//ERRO NENNHUM PEDIDO
	
	For Each Order EmpCod, FilCod, (OrdCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&OrdCod = OrdCod
		Exit
	EndFor
	&OrdCod += 1
	
	&OrdSts = Status_Producao.Aguardando

	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		OrdCod = &OrdCod
		OrdEntPedCod = 0
		OrdSaiPedCod = 0
		OrdSts = &OrdSts
		OrdTip = &OrdTip
		OrdDta = serverdate()
		OrdDtaPrd = &DataProducao
		OrdSetCod = &SetCod
		OrdGrupHie = &GrupHie
	EndNEw
EndFor

commit


For &sdtOrdemProducaoItem in &sdtOrdemProducao
	&EstFab = &sdtOrdemProducaoItem.EstFab //+ &sdtOrdemProducaoItem.EstFabSem
	
	MateriaPrimaUtilizada1.Call(0,0, &EmpCod, &FilCod, &sdtOrdemProducaoItem.ProCod, &EstFab, 1, &sdtMateriaPrima)
	RetornaPrimeiroSubProduto.call(&EmpCod, &FilCod, &sdtOrdemProducaoItem.ProCod, &sdtOrdemProducaoItem.ProGraCod, &OrdSemProCod, &OrdSemEstQtd)
	
	do 'DebitaEstoqueOrdem'
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		OrdCod  = &OrdCod
		OrdItmCod = &sdtOrdemProducaoItem.OrdItmCod
		OrdProCod = &sdtOrdemProducaoItem.ProCod
		OrdProGraCod = &sdtOrdemProducaoItem.ProGraCod
		OrdProNom = &sdtOrdemProducaoItem.ProNom
		OrdProSetCod = &sdtOrdemProducaoItem.ProSetCod
		OrdProGrupHie = &sdtOrdemProducaoItem.ProGrupHie
		
		OrdProEstPrd = &sdtOrdemProducaoItem.EstPrd
		OrdProPrio =  &sdtOrdemProducaoItem.EstPrio
		OrdProEstSdo = &sdtOrdemProducaoItem.EstSdo
		OrdProEstVen = &sdtOrdemProducaoItem.EstVen
		OrdProEstMin = &sdtOrdemProducaoItem.EstMin
		
		OrdProEstQtd = 0
		if &sdtOrdemProducaoItem.EstQtd > 0
			OrdProEstQtd = &sdtOrdemProducaoItem.EstQtd
		EndIF
	
		OrdProVlrCus = &sdtOrdemProducaoItem.EstVlrCus
		OrdSemProCod = &OrdSemProCod
		OrdSemEstQtd = 0
		if &OrdSemEstQtd > 0
			OrdSemEstQtd = &OrdSemEstQtd
		EndIF
		
//		if &OqueSomar = 'P'
//			OrdProPrd = OrdProEstVen
//		Else
			OrdProPrd = &sdtOrdemProducaoItem.EstFab
//		EndiF
	
		OrdProQtd = OrdProPrd - (OrdSemEstQtd)// + OrdProEstQtd)
		if OrdProQtd < 0
			OrdProQtd = 0
		EndIF
		
		&AuxOrdSemEstQtd = OrdProPrd //- OrdProEstQtd
		OrdProQtdSem =0
		If (OrdProPrd > 0 and &AuxOrdSemEstQtd > 0 and OrdSemEstQtd > 0)
			if OrdSemEstQtd <= &AuxOrdSemEstQtd
				OrdProQtdSem = OrdSemEstQtd
			Else
				OrdProQtdSem = &AuxOrdSemEstQtd
			EndIF		
		EndiF
		
	EndNew
EndFor

commit

&Count = 0
For &sdtMateriaPrimaItem in &sdtMateriaPrima
	
	If &sdtMateriaPrimaItem.QuantiaUtilizada > 0 or &sdtMateriaPrimaItem.QuantidadeInicial > 0
		&Count += 1
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			OrdCod  = &OrdCod
			OrdMatItmCod = &Count
			OrdMatProCod = &sdtMateriaPrimaItem.ProCod
			OrdMatProGraCod = &sdtMateriaPrimaItem.ProGraCod
			OrdMatProQtd = &sdtMateriaPrimaItem.QuantiaUtilizada
			OrdMatProEstQtd = &sdtMateriaPrimaItem.EstQtd
			OrdMatProTipDef = &sdtMateriaPrimaItem.SubProduto
			OrdMatQtdIni = &sdtMateriaPrimaItem.QuantidadeInicial
			OrdMatProEstSdo = &sdtMateriaPrimaItem.EstSdo
			OrdMatProVlrCus = &sdtMateriaPrimaItem.RecProVlrCus
			
		EndNew
	EndiF

EndFor

commit

Sub 'DebitaEstoqueOrdem'
	For Each Order EmpCod, FilCod, OrdCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where OrdCod  = &OrdCod
		
		if OrdSemProCod = &OrdSemProCod
			&OrdSemEstQtd -= OrdProQtdSem
		EndIF
	EndFor
EndSUb
]]></Source>
