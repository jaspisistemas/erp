      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&OcsEtpGrupNom.SetEmpty()
For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
	Where EmpCod = &EmpCod
	Where OcsCod = &OcsCod
	Where OcsItm = &OcsItm
	Where OcsEtpItm = &OcsEtpItm
	
	
	&OcsEtpGrupNom = padL(trim(str(OcsEtpItm)), 2, '0') + ' - '+ trim(OcsEtpGrupNom)
	Exit
EndFor
]]></Source>
