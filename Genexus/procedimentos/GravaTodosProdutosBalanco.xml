      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where MarCod = &MarCod when not &MarCod.IsEmpty()
	Where ProSts = &ProSts When not &ProSts.IsEmpty()
	Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	&Total += 1
EndFor

&Total += 5
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&auxGrupHie = &GrupHie.Trim() + '.'

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where MarCod = &MarCod when not &MarCod.IsEmpty()
	Where ProSts = &ProSts When not &ProSts.IsEmpty()
	Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()

	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	&ProCod = ProCod
	
	For Each Order EmpCod, ProCod, ProGraCod
		&ProGraCod = ProGraCod
		IniciaEstoque.call(&EmpCod, &FilCod, &ProCod, &ProGraCod)
		do 'AddBalanco'
	When none
		&ProGraCod = 1
		IniciaEstoque.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod)
		do 'AddBalanco'
	EndFor    
EndFor

commit


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub


Sub 'AddBalanco'
	For Each Order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		if &Inicializar <> 'B' or (&Inicializar = 'B' and EstQtd < 0)
			new
				EmpCod = &EmpCod
		        FilCod = &FilCod
				BalCod = &BalCod
		        ProCod = &ProCod
				BalQtd = 0
				BalQtdAnt = EstQtd
				BalOrd = servernow()
		    EndNew
			
			EstProStsBal = Status_SimNao.Sim
		Endif
	EndFor
EndSub
]]></Source>
