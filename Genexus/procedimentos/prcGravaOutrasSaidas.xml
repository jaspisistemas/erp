      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedDtaEms = serverdate()

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilPesCod = FilPesCod
	&FilTabCod = FilTabCod
EndFor


//Verifica Pedido Saida
For Each ORder EmpCod, FilCod, (PedCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where LctCod = &LCtCod
	Where PedDtaEms = &PedDtaEms
	Where PedSts = Status_Pedido.FECHADO
	Where PedObsGer = '#PEDIDOJASPI#OUTRASSAIDAS#'
	Where PedCliCod = &FilPesCod
	
	&PedCod = PedCod
	Exit
When None

	UltimoCodigoEmpresa.Call(domParCod.PEDIDO, &EmpCod, &FilCod, &PedCod)
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
	
	    PedDtaEms = &PedDtaEms
		PedHorEms = serverTime()
		
		PedBlq = Status_SimNao.Sim
		PedStsGer = Pedido_Gerado.Interno
		PedStsFin = Status_Financeiro.FECHADO
		
		PedCliCod = &FilPesCod
		LctCod = &LctCod
		
		//PedTraCodSai = 1
		//PedTraCodDsp = 1
		
		PedSts = Status_Pedido.FECHADO
		PedDtaFat = &PedDtaEms
		PedHorFat = serverNow()
		PedDtaFic = &PedDtaEms //DATA FATURAMENTO
		TabCod = &FilTabCod
		
		TabColCod = 1
		PedTipFrt = TipoFrete.SemFrete
		PedPraCod = 1
		
		PedObsGer = '#PEDIDOJASPI#OUTRASSAIDAS#'
	EndNew
	
	Commit
	
EndFor

//GRAVA ITEM
&ProVlrCus = 0
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &PrOCod
	
	&ProVlrCus = ProVlrCus
	
	Exit
EndFor

&PedItmCod = PedItmCod
For Each ORder EmpCod, FilCod, PedCod, (PedItmCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&PedItmCod = PedItmCod
	Exit
EndFor
&PedItmCod += 1
prcGraVaItemTransferenciaPedido.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &PrOCod, &ProGraCod, &PedQtd, &ProVlrCus)	
AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, 'I')
FechaEstoqueTransferenciaPorItem.Call(&EmpCod, &FilCod, &PedCod, Status_Pedido.FECHADO, &PedItmCod)	 
	 
	 
]]></Source>
