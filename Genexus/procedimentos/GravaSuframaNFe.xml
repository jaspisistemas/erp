      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVA NA NFE
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	NfeCliSuf = &NfeCliSuf
	&NfeCliCod = NfeCliCod
	Exit
EndFor

commit


//GRAVA NO CLIENTE
For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &NfeCliCod
	
	if PesSuf.IsEmpty()
		PesSuf = &NfeCliSuf
	EndIF

	Exit
EndFor
Commit
]]></Source>
