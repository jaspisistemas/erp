      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MB 0
MT 0



For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = UPPER('Extrato Declaração de Imposto de Renda')
	print Cabecalho
End

&NfeDtaEms = yMDtoD(&ano,1,1)
&NfeDtaEms_go = YMDtoD(&ano,12,31)
&TotNfeVlrTot = 0
&NfeCliCod = 0
For each Order EmpCod,NfeProTer,NfeSts,NfeCliCod,NfeCliIns,NfeEntSai,NfeDtaEms
	Where EmpCod = &EmpCod
	Where NfeCliCod = &CliCod when &CliCod <> 0
	Where NfeDtaEms >= &NfeDtaEms and NfeDtaEms <= &NfeDtaEms_go
	Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
	Where NfeSts = Status_NFe.Autorizada
	
	If &NfeCliCod <> NfeCliCod
		If &NfeCliCod <> 0 
			Eject
		EndIf
		&NfeCliCod = NfeCliCod
		&NfeCliRaz = NfeCliRaz
		&EndPesCod = NfeCliCod
		Do 'GetEndereco'
		&PesCep = PesCep
		&PesCidNom = trim(NfeCliCidNom) +'-'+NfeCliCidUF
		&PesPrmFon = NfeCliFon
		If NfeCliTipPes = TipoPessoa.FISICA
			&PesCnpj = NfeCliCpf
		Else
			&PesCnpj = NfeCliCpf
		EndIf	
		Print Cliente
	EndIf


	If &NfeCliIns <> NfeCliIns 
		Print ClienteCadpro
		&NfeCliIns = NfeCliIns
		&auxNfeDtaEms = NfeDtaEms
		&Mes = upper(cMonth(&auxNfeDtaEms))
		Print EmitidasMes
	EndIf

	If Month(&auxNfeDtaEms) <> month(NfeDtaEms)
		&auxNfeDtaEms = NfeDtaEms
		&Mes = upper(cMonth(&auxNfeDtaEms))
		Print EmitidasMes
	EndIf

	&NfeDtaEms = NfeDtaEms
	&NfePedCod = NfePedCod
	
	&Varchar = padL(trim(STR(NfeNum)), 9, '0')
	&NumeroSerie = substr(&Varchar, 1, 3) +'.' + substr(&Varchar, 4, 3) + '.' + substr(&Varchar, 7, 3)
	
	&NfeChv = NfeChv
	If NfeEntSai = 'S'
		&NfeVlrTot = NfeVlrTot
		&TotNfeVlrTot += NfeVlrTot
		Print DetailNotas
	Else
		&NfeVlrTot = NfeVlrTot*(-1)
		&TotNfeVlrTot -= NfeVlrTot
		Print DetailNotasDevolucao
	EndIf
EndFor


Print Total


Footer
	print Rodape
End

Sub 'GetEndereco'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &EndPesCod
		&Peslog = Trim(PesLog) +', '+trim(PesNro)+' - '+trim(PesBai) +' '+trim(PesCpl)
		Exit
	EndFor
EndSub

]]></Source>
