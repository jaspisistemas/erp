      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&PedCod))
		&LogErpRegTip = TrnMode.Update
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedCliCod', trim(toformattedString(PedCliCod)), trim(toformattedString(PedCliCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedNovCliRaz', trim(PedNovCliRaz), trim(&NovPedCliRaz), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedNovCliCpfCnpj', trim(PedNovCliCpfCnpj), trim(&PedCliCnpj), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedCliCod', trim(toformattedString(PedNovTip)), trim(toformattedString(&PedCliTip)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedCliCod', trim(toformattedString(PedFicCod)), trim(toformattedString(&PedFicCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedCliCod', trim(toformattedString(PedVlrLmt)), trim(toformattedString(&PedVlrLmt)), &LogErpRegGUID )		
	Endif
	//GRAVA LOG
	
	PedCliCod = &PedCliCod
	PedNovCliRaz = &NovPedCliRaz
	PedNovCliCpfCnpj = &PedCliCnpj
	PedNovTip = &PedCliTip
	PedFicCod = &PedFicCod
	PedVlrLmt = &PedVlrLmt
	
	Exit
EndFor

Commit

if not &PedFicCod.IsEmpty()
	For Each Order EmpCod, FicCod
		Where EmpCod = &EmpCod
		Where FicCod = &PedFicCod
		FicPedCod = &PedCod
		Exit
	EndFor
	Commit
EndIF
]]></Source>
