      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsPodeFaturar = false

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &pedCod
	
	If not PedDtaEmba.IsEmpty() and not PedDtaEmba.IsNull()
		&IsPodeFaturar = true
	EndIF

	Exit
EndFor
]]></Source>
