      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
 
If &OqueFazer = 'ADD'
	For Each Order EtqCod, (EtqItmCod)
		Where EtqCod = &EtqCod
		&EtqItmCod = EtqItmCod
		Exit
	EndFor
	&EtqItmCod += 1
	
	new
		EtqCod = &EtqCod
		EtqItmCod = &EtqItmCod
		
		if &EtqNovProCod.IsEmpty()
			EtqNovProCod = trim(Str(&EtqProCod))
		Else
			EtqNovProCod = &EtqNovProCod
		EndIF
	
		EtqProCod = &EtqProCod
		EtqProNom = &EtqProNom
		EtqProGraCod = &EtqProGraCod
		EtqProGraNom = &EtqProGraNom
		EtqProBar = &EtqProBar
		EtqQtd = &EtqQtd
		EtqProQtdEmb =  &ProQtdEmb
		EtqProNroLot = &ProNroLot
		EtqProObsAdi = &EtqProObsAdi
	EndNew

Else
	For Each Order EtqCod, EtqItmCod
		Where EtqCod = &EtqCod
		Where EtqItmCod = &parmEtqItmCod or &parmEtqItmCod = 0
		Delete
	EndFor
	
EndIF

Commit
]]></Source>
