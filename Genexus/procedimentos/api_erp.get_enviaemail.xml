      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

&SdtRetornoWbsEtc.Sts = 'E999'

if &IsAcessoConcedido = true
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		&FilEnvEml = FilEnvEml
		Exit	
	EndFor

	&SdtEmail.Clear()
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&CteNum = CteNum
		&SdtRetornoWbsEtc.c1 = 'Conhecimento de Transporte ' + trim(toformattedString(&CteNum)) + ' da ' + trim(FilFan)		
		
		&SdtEmail.Clear()
		Do Case
			Case &FilEnvEml = EmailEnvolvidosCte.SomenteRemetente
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.Somentedestinatario
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.SomenteTomador
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.RemetenteDestinatario
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.RemetenteTomador
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.DestinatarioTomador
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.Todos
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)
		EndCase			
		
		Exit
	When none 
		&SdtRetornoWbsEtc.Sts = 'E987'
		&SdtRetornoWbsEtc.obs = 'CTe não localizado'
	EndFor
	
	
	For &ItemSdtEmail in &SdtEmail
		Do Case				
			Case &SdtRetornoWbsEtc.c2.IsEmpty()
				&SdtRetornoWbsEtc.c2 = &ItemSdtEmail.EmlUrl
				
			Case &SdtRetornoWbsEtc.c3.IsEmpty()
				&SdtRetornoWbsEtc.c3 = &ItemSdtEmail.EmlUrl
				
			Case &SdtRetornoWbsEtc.c4.IsEmpty()
				&SdtRetornoWbsEtc.c4 = &ItemSdtEmail.EmlUrl
				
			Case &SdtRetornoWbsEtc.c5.IsEmpty()
				&SdtRetornoWbsEtc.c5 = &ItemSdtEmail.EmlUrl
				
			Case &SdtRetornoWbsEtc.c6.IsEmpty()
				&SdtRetornoWbsEtc.c6 = &ItemSdtEmail.EmlUrl
			
			Case &SdtRetornoWbsEtc.c7.IsEmpty()
				&SdtRetornoWbsEtc.c7 = &ItemSdtEmail.EmlUrl
				
			Otherwise
				Exit
		EndCAse
	EndFor
	
	
	&SdtRetornoWbsEtc.Sts = 'J200'
	
		
Endif
]]></Source>
