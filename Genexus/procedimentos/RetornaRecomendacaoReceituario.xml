      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod,TlvCod,InfCod,RcmTip
	Where EmpCod = &EmpCod
	Where ProCod = &RctProCod
	Where TlvCod = &RctProTlvCod
	Where InfCod = &RctProInfCod
	
	Do Case
		Case RcmTip = Recomendacao.Diagnostico
			&DiaRcmNom = RcmNom
		Case RcmTip = Recomendacao.Intevaloseguranca
			&IntSegRcmNom = RcmNom
		Case RcmTip = Recomendacao.EPI
			&EpiRcmNom = RcmNom
		Case RcmTip = Recomendacao.Orientacaomanejo
			&OriManRcmNom = RcmNom
		Case RcmTip = Recomendacao.OutrasInfo
			&OutRcmNom = RcmNom
		Case RcmTip = Recomendacao.Precaucoes
			&PreRcmNom = RcmNom	
		Case RcmTip = Recomendacao.ModalidadeEpoca and &RctProRcmModAplTip = 1
			&ModAplRcmNom = RcmNom
		Case RcmTip = Recomendacao.ModalidadeEpocaAerea and &RctProRcmModAplTip = 2
			&ModAplRcmNom = RcmNom
			
	EndCase	

EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
