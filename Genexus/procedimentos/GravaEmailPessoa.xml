      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PesCod, PesEml
	Where EmpCod = &EmpCod
	Where PesCod = &PEsCod
	Where PesEml = &PEsEml
	
	Exit
When None
	&PesEmlCod = 0
	For Each Order EmpCod, PesCod, (PesEmlCod)
		Where EmpCod = &EmpCod
		Where PesCod = &PEsCod
		&PesEmlCod = PesEmlCod
		Exit
	EndFor
	&PesEmlCod  += 1
	
	New
		EmpCod = &EmpCod
		PesCod = &PEsCod
		PesEmlCod = &PesEmlCod
		PesEml = &PEsEml
		PesEmlFat = true
		PesEmlFin= true
		PesEmlPed = true
	EndNew

	Commit
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
