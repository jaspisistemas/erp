      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 50
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'
		
For Each Order EmpCod, TrsCod
	Where EmpCod = &EmpCod
	Where TrsCod = &trsCod
	
	&TrsSaiFilCod = TrsSaiFilCod 
	&TrsEntFilCod = TrsEntFiLCod
	&TrsTip = TrsTip
	&TrsDtaEms = TrsDtaEms
	
	Do CAse
		Case TrsTip = 'I' or TrsTip.IsEmpty() or TrsTip.IsNull()
			retornaConfSistema.Call(&EmpCod, &TrsSaiFilCod, domConfSistema.TCon047_TransOrigemProduto, &Varchar)
			&SaidaLctCod.FromString(&Varchar)
			retornaConfSistema.Call(&EmpCod, &TrsEntFilCod, domConfSistema.TCon048_TransDestinoProduto, &Varchar)
			&EntradaLctCod.FromString(&Varchar)
			
		Case TrsTip = 'D' //REMESSA
			retornaConfSistema.Call(&EmpCod, &TrsSaiFilCod, domConfSistema.TCon197_TransOrigemRemessa, &Varchar)
			&SaidaLctCod.FromString(&Varchar)
			retornaConfSistema.Call(&EmpCod, &TrsEntFilCod, domConfSistema.TCon198_TransDestinoRemessa, &Varchar)
			&EntradaLctCod.FromString(&Varchar)
			
		Case TrsTip = 'R' //RETORNO
			retornaConfSistema.Call(&EmpCod, &TrsSaiFilCod, domConfSistema.TCon199_TransOrigemRetorno, &Varchar)
			&SaidaLctCod.FromString(&Varchar)
			retornaConfSistema.Call(&EmpCod, &TrsEntFilCod, domConfSistema.TCon200_TransDestinoRetorno, &Varchar)
			&EntradaLctCod.FromString(&Varchar)
	EndCase

	TrsSaiTipLct = &SaidaLctCod
	TrsEntTipLct = &EntradaLctCod
		
	&OrigemPedCod = TrsSaiPedCod
	do 'insertPedidoCapaOrigem'
	
	&TrsSaiPedCod = TrsSaiPedCod
	If &TrsSaiPedCod.IsEmpty()
		TrsSaiPedCod = &OrigemPedCod
		&TrsSaiPedCod = &OrigemPedCod
	EndiF
	
	Commit
	
	&Count = 50
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	&DestinoPedCod = TrsEntPedCod
	do 'insertPedidoCapaDestino'
	
	If TrsEntPedCod.IsEmpty() or TrsEntPedCod.IsNull()
		TrsEntPedCod = &DestinoPedCod	
	EndIF

	&TrsSaiNfeCod = TrsSaiNfeCod
	&TrsEntNfeCod = TrsEntNfeCod
	
	commit
	
	TrsSts = Status_Pedido.FECHADO
	Exit
EndFor

Commit


//GRAVA NOTA TEMPORARIA
if &TrsTip = 'R' or &TrsTip = 'D' //RETORNO ou REMESSA
	&tmpNFeCod = trim(str(&EmpCod)) + trim(Str(&TrsSaiFilCod)) + trim(str(&TrsSaiPedCod))
	GravaNotaTemporariaVenda.Call(&EmpCod, &TrsSaiFilCod, &TrsSaiPedCod, '55')
	GravaNotaFiscalModelo55.Call('RETURN', &EmpCod, &TrsSaiFilCod, &TrsSaiPedCod, &tmpNFeCod, &PesCod, 'E')
	
	PadraoUsuarioHora.Call('L', 'EMITIRNFE', &PesCod, &EmpCod, &PadObs, &PAdDtaMod, &PAdDtaHorMod, 'T')
	&SdtNotaTransmissao.FromJson(&PadObs)
	&TrsSaiNfeCod = &SdtNotaTransmissao.NfeCod
	
	if &TrsEntNfeCod.IsEmpty()
		&NfeCod = UltimoCodigoEmpresa.Udp(domParCod.NOTAFISCAL, &EmpCod, &TrsEntFilCod)
		&TrsEntNfeCod = &NfeCod
	Else
		
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmpCod
			Where FilCod = &TrsEntFilCod 
			Where NfeCod = &TrsEntNfeCod
			
			For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
				delete
			EndFor
			
			Delete
		EndFor
	Endif

	//ATAULIZA TRANSFERENCIA
	For Each ORder EmpCod, TrsCod
		WherE EmpCod = &EmpCod
		Where TrsCod = &trsCod
		
		TrsSaiNfeCod = &TrsSaiNfeCod 
		TrsEntNfeCod = &TrsEntNfeCod 
		
		Exit
	EndFor

	Commit

	
	//PEGA O CLIENTE DA FILIAL DA NOTA
	For Each Order EmpCod, PesCod
		Where EmpCod =&EmpCod
		Where PesCod = &EntrFilPesCod
		&NfeCliBai = PesBai
		&NfeCliCep = PesCep
		&NfeCliCidCod = PesCidCod
		&NfeCliCidIbge = PesCidIBGE
		&NfeCliCidNom = PesCidNom
		&NfeCliCidUF = PesCidUfeCod
		&NfeCliCnpj = PesCnpj
		&NfeCliCod = PesCod
		
		&NfeCliCpf = PesCpf
		&NfeCliCpl = PesCpl
		&NfeCliEml = PesPrmEml
		&NfeCliEnd = PesLog
		&NfeCliEndNro = PesNro
		
		&NfeCliFon = PesPrmFon
		&NfeCliIns = PesInsEst
		&NfeCliRaz = PesRaz
		&NfeCliSuf = PesSuf
		&NfeCliTipPes = PesTip
		Exit
	EndFor
	
	//GRAVA NOTA ENTRADA
	For EAch Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &SdtNotaTransmissao.NfeFilCod
		Where NfeCod = &SdtNotaTransmissao.NfeCod
		&NfeDtaEms  = NfeDtaEms
		
		new
			FilCod = &TrsEntFilCod
			NfeCod = &TrsEntNfeCod
			NfePedCod = &DestinoPedCod
			
			NfeProTer = NOTa_ProPriaTerceira.TERCEIROS
			NfeLctCod = &EntradaLctCod
			NfeEntSai = Status_EntradaSaida.Entrada
			
			//ATUALIZA DATAS DE FATURAMENTO
			RetornaDataFaturamento.Call(&EmpCod, &TrsEntFilCod, &DestinoPedCod, &NfeDtaEms, &NfeDtaFat)
			NfeDtaFat = &NfeDtaFat
			if &NfeDtaFat.IsEmpty()
				NfeDtaFat_Mes = 0
				NfeDtaFat_Ano = 0
			Else
				NfeDtaFat_Mes = &NfeDtaFat.Month()
				NfeDtaFat_Ano = &NfeDtaFat.Year()
			Endif
		
			//Cliente 
			NfeCliBai = &NfeCliBai 
			NfeCliCep = &NfeCliCep 
			NfeCliCidCod = &NfeCliCidCod 
			NfeCliCidIbge = &NfeCliCidIbge 
			NfeCliCidNom = &NfeCliCidNom 
			NfeCliCidUF = &NfeCliCidUF 
			NfeCliCnpj = &NfeCliCnpj 
			NfeCliCod = &NfeCliCod 
			
			NfeCliCpf = &NfeCliCpf 
			NfeCliCpl = &NfeCliCpl 
			NfeCliEml = &NfeCliEml 
			NfeCliEnd = &NfeCliEnd 
			NfeCliEndNro = &NfeCliEndNro 
			
			NfeCliFon = &NfeCliFon 
			NfeCliIns = &NfeCliIns 
			NfeCliRaz = &NfeCliRaz 
			NfeCliSuf = &NfeCliSuf 
			NfeCliTipPes = &NfeCliTipPes 
			
		EndNew
	EndFor
	
	Commit
	
	For EAch Order EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &SdtNotaTransmissao.NfeFilCod
		Where NfeCod = &SdtNotaTransmissao.NfeCod
		
		new
			EmpCod = &EmpCod
			FilCod = &TrsEntFilCod
			NfeCod = &TrsEntNfeCod
			
			
			if len(NfeCfoCod) >= 4
				RetornaCfopEntrada.call(&EmpCod, &EntradaLctCod, NfeCfoCod, &CfoEmpAprvCredIcmsPer, &tmpEntCFOP)	//AINDA NAO SABEMOS O TIPO LANCAMENTO - JDF
				NfeCfoCod = &tmpEntCFOP
			Endif
		
		EndNEw
		
	EndFor
	
	Commit
	
Endif



&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
	
	if &ProgressId = 'cmdRecalculo'
		msg('Produto:' + trim(str(&AuxProCod)) + ' Percentual: ' + trim(str(&Percentual)))
	EndIF
EndSub

sub 'insertPedidoCapaDestino'
	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &TrsSaiFilCod //CLIENTE DA FILIAL SAIDA
		&EntrFilPesCod = FilPesCod
		&FilTabCod = FilTabCod
	EndFor
	
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &TrsEntFilCod
		Where PedCod = &DestinoPedCod
		
		PedSts = Status_Pedido.FECHADO
		PedDtaEms = &TrsDtaEms
		PedHorEms = serverTime()
		PedCliCod = &EntrFilPesCod
		LctCod = &EntradaLctCod
		PedDtaFat = &TrsDtaEms
		PedHorFat = serverNow()
		PedDtaFic = &TrsDtaEms //DATA FATURAMENTO
		TabCod = &FilTabCod
		
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			delete
		EndFor
		Exit
	When none
		prcInsereCapaTransferencia.Call(&EmpCod, &TrsEntFilCod, &TrsDtaEms, &EntradaLctCod, &EntrFilPesCod, &FilTabCod, &DestinoPedCod)
	EndFor

	commit
	
	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	For Each Order EmpCod, TrsCod, TrsItmCod
		Where EmpCod = &EmpCod
		Where TrsCod = &trsCod
		
		&ProCod = TrsEntProCod
		&ProGraCod = TrsEntProGraCod
		if &ProGraCod.IsEmpty()
			TrsEntProGraCod = 1
			&ProGraCod = 1
		EndIF
	
		do 'getCusto'
		
		retornaProdutoEstoque.Call(EmpCod, TrsEntProCod, &ProEstProCod)
		
		New
			EmpCod = &EmpCod
			FilCod = &TrsEntFilCod
			PedCod = &DestinoPedCod
			
			PedItmCod = TrsItmCod
			ProCod = TrsEntProCod
			ProGraCod = &ProGraCod
			
			PedQtdCan = 0
			PedQtdEmb = TrsEntPedQtd
			PedQtd    = TrsEntPedQtd
			PedVlrUnt = &ProVlrCus			
			
			PedProEstProCod = &ProEstProCod
			PedProEstProGraCod = &ProGraCod
		EndNew	
	EndFor
	
	commit
	
	&Count += 10
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	AtualizaTotaisPedido.Call(&EmpCod, &TrsEntFilCod, &DestinoPedCod, 0, 'C')
		
	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	AtualizaEstoqueEntradaSaida.Call(&EmpCod, &TrsEntFilCod, &DestinoPedCod, Status_Pedido.FECHADO)
	
EndSUb

sub 'insertPedidoCapaOrigem'
	
	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &TrsentFilCod //CLIENTE DO DESTINO
		&SaiFilPesCod = FilPesCod
		&FilTabCod = FilTabCod
	EndFor
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &TrsSaiFilCod
		Where PedCod = &OrigemPedCod
		
			PedSts = Status_Pedido.FECHADO
			PedDtaEms = &TrsDtaEms
			PedHorEms = serverTime()
			PedHorFat = serverNow()
			PedCliCod = &SaiFilPesCod
			LctCod = &SaidaLctCod
			PedDtaFat = &TrsDtaEms
			PedDtaFic = &TrsDtaEms //DATA FATURAMENTO
			TabCod = &FilTabCod
			
			For Each Order EmpCod, FilCod, PedCod, PedItmCod
				delete
			EndFor
		Exit
	When none
		prcInsereCapaTransferencia.Call(&EmpCod, &TrsSaiFilCod, &TrsDtaEms, &SaidaLctCod, &SaiFilPesCod, &FilTabCod, &OrigemPedCod)
	EndFor

	commit

	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	For Each Order EmpCod, TrsCod, TrsItmCod
		Where EmpCod = &EmpCod
		Where TrsCod = &trsCod
		
		&ProCod = TrsSaiProCod
		&ProGraCod = TrsSaiProGraCod
		if &ProGraCod.IsEmpty()
			&ProGraCod = 1
			TrsSaiProGraCod = 1
		EndIf
	
		do 'getCusto'
		
		retornaProdutoEstoque.Call(EmpCod, TrsSaiProCod, &ProEstProCod)
		
		New
			EmpCod = &EmpCod
			FilCod = &TrsSaiFilCod
			PedCod = &OrigemPedCod
			
			PedItmCod = TrsItmCod
			ProCod = TrsSaiProCod
			ProGraCod = &ProGraCod
			
			PedQtdCan = 0
			PedQtdEmb = TrsSaiPedQtd
			PedQtd    = TrsSaiPedQtd
			PedVlrUnt = &ProVlrCus
			
			PedProEstProCod = &ProEstProCod
			PedProEstProGraCod = &ProGraCod
		EndNew	
	EndFor
	
	commit
	
	&Count += 10
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	AtualizaTotaisPedido.Call(&EmpCod, &TrsSaiFilCod, &OrigemPedCod, 0, 'C')
	
	&Count += 5
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	AtualizaEstoqueEntradaSaida.Call(&EmpCod, &TrsSaiFilCod, &OrigemPedCod, Status_Pedido.FECHADO)

EndSUb


sub 'getCusto'
	&ProVlrCus = 0
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&ProVlrCus = ProVlrCus
		
		Exit
	EndFor
EndSub

]]></Source>
