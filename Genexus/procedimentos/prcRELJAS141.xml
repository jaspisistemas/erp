      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsNaoDeuErro = false
//CONFERÊNCIA ITENS PEDIDO
LoadWWPContext.Call(&wwpContext)


PadraoUsuario.Call('L','SDT_CONFITENSPEDIDO',&wwpContext.PesCod,&EmpCod,&PadObs,&Today)
&SDTPedidoProduto.FromJson(&PadObs)

&CountOk.SetEmpty()
&CountDif.SetEmpty()
	
For each order EmpCod,FilCod,PedCod,PedItmCod
	where EmpCod = &EmpCod
	where FilCod = &FilCod
	where PedCod = &PedCod
	
	&PedSepCod = PedSepCod
	&PedConCod = PedConCod
	
	&ProCod = ProCod
	&ProGraCod = ProGraCod
	&ProRef = ProGraRef
	&IsAchouProduto = false
	&PedItmCod = PedItmCod
	
	if ProSepIsKit = true // CONTABILIZAR O KIT E NAO O PRODUTO PRINCIPAL
		&sdtMateriaPrima.Clear()
		MateriaPrima_Conferencia.Call( 'S', EmpCod, FilCod, ProCod, PedQtd, &ProRecUltCod, &sdtMateriaPrima)
		do 'Navega_SdtMateriaPrima'
	Else
		For &SDTPedidoProdutoItem in &SDTPedidoProduto
			if &ProCod = &SDTPedidoProdutoItem.ProCod and &ProGraCod = &SDTPedidoProdutoItem.ProGraCod
				&IsAchouProduto = true
				
				&SDTPedidoProdutoItem.PedQtd += PedQtd
				&SDTPedidoProdutoItem.PeditmCod = PedItmCod
				if &SDTPedidoProdutoItem.PedQtd >= &SDTPedidoProdutoItem.ConPedQtd
					&DifPedQtd = &sdTPedidoProdutoItem.PedQtd - &SDTPedidoProdutoItem.ConPedQtd
				else
					&DifPedQtd = &SDTPedidoProdutoItem.ConPedQtd - &SDTPedidoProdutoItem.PedQtd
				EndIf
				
				exit
			EndIf
		EndFor
		
		if &IsAchouProduto = false
			&SDTPedidoProdutoItem = new()
			&SDTPedidoProdutoItem.ConPedQtd = 0
			&SDTPedidoProdutoItem.PeditmCod = PedItmCod
			&SDTPedidoProdutoItem.PedQtd = PedQtd
			&SDTPedidoProdutoItem.ProBar = ProGraBar
			&SDTPedidoProdutoItem.ProNom = ProNomGra
			&SDTPedidoProdutoItem.ProCod = ProCod
			&SDTPedidoProdutoItem.ProGraCod = ProGraCod
			&SDTPedidoProdutoItem.ProGraRef = ProGraRef
			&SDTPedidoProduto.Add(&SDTPedidoProdutoItem)
		EndIf
	Endif
EndFor

For &SDTPedidoProdutoItem in &SDTPedidoProduto
	&DifPedQtd = &sdTPedidoProdutoItem.PedQtd - &SDTPedidoProdutoItem.ConPedQtd
	if (&SDTPedidoProdutoItem.PedQtd <= 0 and &SDTPedidoProdutoItem.ConPedQtd > 0) or &DifPedQtd <> 0
		&CountDif += 1
	Else
		&CountOk += 1
	EndIf
EndFor

Do 'GravaCriticaHistorico'

Sub 'Navega_SdtMateriaPrima'
	
	For &sdtMateriaPrimaItem in &sdtMateriaPrima
		&IsAchouProduto = false
		
		For &SDTPedidoProdutoItem in &SDTPedidoProduto
			if &sdtMateriaPrimaItem.ProCod = &SDTPedidoProdutoItem.ProCod and &sdtMateriaPrimaItem.ProGraCod = &SDTPedidoProdutoItem.ProGraCod
				&IsAchouProduto = true
				
				&SDTPedidoProdutoItem.PedQtd += &sdtMateriaPrimaItem.QuantiaUtilizada
				&SDTPedidoProdutoItem.PeditmCod = &PedItmCod
				
				if &SDTPedidoProdutoItem.PedQtd >= &SDTPedidoProdutoItem.ConPedQtd
					&DifPedQtd = &sdTPedidoProdutoItem.PedQtd - &SDTPedidoProdutoItem.ConPedQtd
				else
					&DifPedQtd = &SDTPedidoProdutoItem.ConPedQtd - &SDTPedidoProdutoItem.PedQtd
				EndIf
				
				exit
			EndIf
		EndFor
		
		if &IsAchouProduto = false
//			For Each Order EmpCod, ProCod
//				WHere EmpCod = &EmpCod
//				Where ProCod = &sdtMateriaPrimaItem.ProCod
				&SDTPedidoProdutoItem = new()
				&SDTPedidoProdutoItem.ConPedQtd = 0
				&SDTPedidoProdutoItem.PeditmCod = &PedItmCod
				&SDTPedidoProdutoItem.PedQtd = &sdtMateriaPrimaItem.QuantiaUtilizada
				&SDTPedidoProdutoItem.ProBar = &sdtMateriaPrimaItem.ProBar
				&SDTPedidoProdutoItem.ProNom = &sdtMateriaPrimaItem.ProNom
				&SDTPedidoProdutoItem.ProCod = &sdtMateriaPrimaItem.ProCod
				&SDTPedidoProdutoItem.ProGraCod = &sdtMateriaPrimaItem.ProGraCod
				&SDTPedidoProdutoItem.ProGraRef = &sdtMateriaPrimaItem.ProRef
				&SDTPedidoProduto.Add(&SDTPedidoProdutoItem)
//				Exit
//			Endfor
		EndIf
	EndFor

EndSub


Sub 'GravaCriticaHistorico'
	
	If &CountDif = 0
		&HisStsObs = 'PEDIDO CONFERIDO COM SUCESSO! ' + &CountOk.ToFormattedString() + ' Produtos conferidos.'
		&IsNaoDeuErro = true
	else
		&HisStsObs = 'CONFERÊNCIA DOS ITENS DO PEDIDO COM DIVERGÊNCIA! ' + &CountDif.ToFormattedString() + ' Produtos com divergência.'
	EndIf

	//Critica
	For each order EmpCod,FilCod,PedCod,(PedCriCod)
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where PedCod = &PedCod
		&PedCriCod = PedCriCod
		exit
	EndFor
	
	&PedCriCod += 1
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedCriCod = &PedCriCod
		PedCriDtaHor = ServerNow()
		PedCriFunCod = &PedCriFunCod
		PedCriTip = TipoCriticaPedido.Conferencia
	EndNew
	
	//Historico pedido
	For each order EmpCod,FilCod,PedCod,(HisItmCod)
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where PedCod = &PedCod
		&HisItmCod = HisItmCod
		exit
	EndFor
	&HisItmCod += 1
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		HisItmCod = &HisItmCod
		HisStsCod = 0
		HisStsObs = &HisStsObs
	EndNew

	commit
		
EndSub
]]></Source>
