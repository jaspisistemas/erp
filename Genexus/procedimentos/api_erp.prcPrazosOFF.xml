<Object parentGuid="7ec4b584-f6b1-46fc-8891-bf576cc1984d" user="WINJEAN\jeanfae" versionDate="2025-07-15T14:17:37.0000000Z" lastUpdate="2025-07-15T11:43:34.0000000Z" checksum="c22d04f35da8ed70adb74db14f1b3eb9" fullyQualifiedName="api_erp.prcPrazosOFF" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="35f1bcc4-ecd1-410a-8b63-c9657e1af3d4" name="prcPrazosOFF" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Prazos OFF" parent="api_erp.configuracoes" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	&FrpPgtoDtaMod  = now()
	&sdtgetPrazos.sts = 'J200'	
	
	prcRetornaUlimaDataHoraSincronizacao.Call(&DevRandon, 'FORMAPAGAMENTOOFF', &DevTabDtaUltSync, &DevTabAtu)
	
	//Forma Pagamentos
	For Each ORder  EmpCod, FrpPgtoCod
		Where EmpCod = &wwpContext.EmpCod
		Where (FrpPgtoDtaMod > &DevTabDtaUltSync or &DevTabDtaUltSync.IsEmpty()) or FrpPgtoDtaMod.IsEmpty() or FrpPgtoDtaMod.IsNull() or &DevTabAtu = true
		Where FrpPgtoSts = Status_AtivoInativo.ATIVO when &DevTabDtaUltSync.IsEmpty()
		
		if FrpPgtoDtaMod.IsEmpty() or FrpPgtoDtaMod.IsNull()
			FrpPgtoDtaMod  = &FrpPgtoDtaMod
			Commit
		Endif
	
		&sdtgetPrazosForma = new()
		&sdtgetPrazosForma.Cod = FrpPgtoCod
		&sdtgetPrazosForma.CodExib = FrpPgtoCodExib
		&sdtgetPrazosForma.Nom = FrpPgtoNom
		&sdtgetPrazosForma.Sts = FrpPgtoSts
		&sdtgetPrazosForma.Tip = FrpPgtoTip
		&sdtgetPrazos.Forma.Add(&sdtgetPrazosForma)

	EndFor

	//prazos
	For Each ORder EmpCod, PraCod
		Where EmpCod = &wwpContext.EmpCod
		Where (PraDtaHorUltMod > &DevTabDtaUltSync or &DevTabDtaUltSync.IsEmpty()) or PraDtaHorUltMod.IsEmpty() or PraDtaHorUltMod.IsNull() or &DevTabAtu = true
		
		if PraDtaHorUltMod.IsEmpty() or PraDtaHorUltMod.IsNull()
			PraDtaHorUltMod  = &FrpPgtoDtaMod
			Commit
		Endif
		
		&sdtgetPrazosPrazos = new()
		&sdtgetPrazosPrazos.Cod = PraCod
		&sdtgetPrazosPrazos.Nom = PraNom
		&sdtgetPrazosPrazos.MedBlo = PraMedBlo
		&sdtgetPrazosPrazos.TipParc = PraTipParc
		&sdtgetPrazosPrazos.Vis = iif(PraIsVis = true, '1', '0')
		&sdtgetPrazosPrazos.Sts = PraSts
		&sdtgetPrazosPrazos.ColMax = PraColMax
		&sdtgetPrazosPrazos.ColMin = PraColMin
		&sdtgetPrazosPrazos.QtdMax = PraQtdMax
		
		//parcelas
		For Each Order EmpCod, PraCod, PraParCod			
			&sdtgetPrazosParcelas = new()
			&sdtgetPrazosParcelas.Cod = PraParCod
			&sdtgetPrazosParcelas.Nom = PraParNom	
			&sdtgetPrazosPrazos.Parcelas.Add(&sdtgetPrazosParcelas)
		EndFor
	
		&sdtgetPrazos.Prazos.Add(&sdtgetPrazosPrazos)
	Endfor
	
Else
	&sdtgetPrazos.sts = 'E999'
	&sdtgetPrazos.msg = 'logout'
	return	
Endif
]]></Source>
