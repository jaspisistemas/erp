      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//delete
For Each ORder EmpCod, FPagCod
	Where EmpCod = &EmpCod
	Where FPagCod = &FPagCod
	
	//&PesRecCod
	&PesCod = FPagPesCod 
	&FerAnoBas = FPagAno
	
	//Itens
	For Each ORder EmpCod, FPagCod, FPagLcfCod
		
		if FPagTip = TipoPagamentoFolha.Ferias //Se for ferias //atualizar lancamenot ferias
			Do CAse
				CAse FPagLcfCod = 15
					&IsPagamentoFerias = true
				CAse FPagLcfCod = 16
					&IsPagamentoTecoFerias = true
			EndCase
		EndIf

		delete
	EndFor

	//contas
	For Each ORder EmpCod, FPagCod, FPagCtaCod
		delete
	EndFor

	//Duplicata
	For Each ORder EmpCod, FPagCod, FPagDupCod
		Delete
	EndFor

	//adiantamentos
	For Each Order EmpCod, FPagCod, FPagAdiMovCod, FPagAdiMovItmCod
		&FPagAdiMovCod = FPagAdiMovCod
		&FPagAdiMovItmCod = FPagAdiMovItmCod
		do 'AbreAdiantamento'
		delete
	EndFor

	if FPagTip = TipoPagamentoFolha.Ferias //Se for ferias //atualizar lancamenot ferias
		&IsAtualizar = true
	Endif

	delete
ENdFor

Commit

If &IsAtualizar= true
	//AtualizaStatus
	For Each Order EmpCod, FPagCod
		Where EmpCod = &EmpCod
		Where FPagPesCod = &PesCod
		Where FPagAno = &FerAnoBas
		Where FPagTip= TipoPagamentoFolha.Ferias
		
		For Each Order EmpCod, FPagCod,FPagLcfCod		
			Do CAse
				CAse FPagLcfCod = 16 and FPagItemVlr > 0
					&IsTemPagamentoTerco = true
				Case FPagLcfCod = 16 and FPagItemVlr = 0
					&isJaPagoFerias = true 
			EndCAse
			
			Do CAse
				CAse FPagLcfCod = 15 and FPagItemCpl = 'INTEGRALMENTE'
					&IsTemPagamentoFeriasIntegralmente = true
				Case FPagLcfCod = 15 and FPagItemCpl = 'PARCIALMENTE'
					&IsTemPagamentoFeriasParcialmente = true
				Case FPagLcfCod = 15 and FPagItemCpl = 'OUTRO PERIODO'
					&IsTemPagamentoFeriasOutroPeriodo = true
			EndCAse
		EndFor
	Endfor
	
	
	For Each Order EmpCod, PesCod, PesRecCod, FerAnoBas
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		where PesRecCod= &PesRecCod
		where FerAnoBas = &FerAnoBas
		
		Do CAse
			CAse &IsTemPagamentoFeriasOutroPeriodo = true
				FerPgto = 'O' //ja pago as ferias
			CAse &IsTemPagamentoFeriasIntegralmente = true
				FerPgto = 'B' //Pagamento Integralmente
			CAse &IsTemPagamentoFeriasParcialmente = true
				FerPgto = 'A' //Pagamento parcialmente
			Otherwise
				FerPgto = 'P' //PENDENTE
		EndCase
		
		Do CAse
			Case &isJaPagoFerias = true 
				FerPgtoTer = 'O' //ja pago as ferias
			CAse &IsTemPagamentoTerco = true 
				FerPgtoTer = 'B' //Pago Integralmente
			Otherwise
				FerPgtoTer = 'P' //PENDENte
		EndCAse
		
		Exit
	EndFor
	
	Commit
Endif


Sub 'AbreAdiantamento'
	
	For each order EmpCod,MovCod,MovItmCod
		where EmpCod = &EmpCod
		where MovCod = &FPagAdiMovCod
		where MovItmCod = &FPagAdiMovItmCod
		Where MovSts.IsEmpty() or MovSts.IsNull() or MovSts <> Status_Caixa.Cancelado
		Where MovItmSts.IsEmpty() or MovItmSts.IsNull() or MovItmSts <> Status_Caixa.Cancelado
		
		MovFunSts = Status_AbertoFechado.Aberto
		exit
	EndFor
	
EndSub
]]></Source>
