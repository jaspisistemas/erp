        <Source><![CDATA[&sdtPostGPT = &pSdtPostGPT
&Path = ChatGPT.baseUrl() + &Subpath
//gravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'&sdtPostGPT.ToJson',&sdtPostGPT.ToJson())

do 'buscaAutenticacao'
do 'valida'

if CodeIsSucesso(&UserMessage.code)
	&HttpClient = new()
	&HttpClient.AddHeader('Content-Type','application/json')
	&HttpClient.AddHeader('Authorization','Bearer ' + &OpenAPIKey)
	&HttpClient.AddString(&sdtPostGPT.ToJson())
	&HttpClient.Execute(&HTTPMethod,&Path)
	
	&sdtGPT.FromJson(&HttpClient.ToString())
	ChatGPT.prcGravaRequisicao(&EmpCod,&sdtGPT.id,&sdtGPT.model,&sdtGPT.usage.total_tokens,&sdtPostGPT.ToJson(),&HttpClient.ToString())
	
	
	if CodeIsSucesso(&HttpClient.StatusCode)
		&UserMessage = criaUserMessageSucesso('','')
	else
		&UserMessage = criaUserMessageError('',&sdtGPT.error.message)
//		if &sdtGPT.error.code.IsEmpty()
//			&UserMessage = criaUserMessageError('Erro interno','Estrutura SDT não reconhecida. Contate o suporte.')
//		else
//			do case
//				case &sdtGPT.error.code = 'missing_required_parameter'
//					&UserMessage = criaUserMessageError(
//					format('Faltou informar o campo %1',&sdtGPT.error.param)
//					,'')
//				otherwise
//					&UserMessage = criaUserMessageError('',&sdtGPT.error.message)
//			endcase
//		endif
	endif
endif

Sub 'valida'
	// ------------ define modelo padrão  ------------
	if &sdtPostGPT.model.IsEmpty()
		&sdtPostGPT.model = TipoModeloChatGPT.gpt_4o_mini
	else
		&sdtPostGPT.model = &sdtPostGPT.model
	endif
	// -----------------------------------------------
	
	// ------------ define máximo de tokens ------------
	if &sdtPostGPT.max_tokens <= 0
		or &sdtPostGPT.max_tokens > 10000
		&sdtPostGPT.max_tokens = 3000
	else
		&sdtPostGPT.max_tokens = &sdtPostGPT.max_tokens
	endif
	// -------------------------------------------------
	
	if &OpenAPIKey.IsEmpty()
		&UserMessage = criaUserMessageError('OpenAPIKey ausente','')
	endif
EndSub

Sub 'buscaAutenticacao'
	&OpenAPIKey = find(EmpOpenAPIKey,EmpCod=&EmpCod and not EmpOpenAPIKey.IsEmpty() and not EmpOpenAPIKey.IsNull(),'')
	if &OpenAPIKey.IsEmpty()
		&OpenAPIKey = find(EmpOpenAPIKey,not EmpOpenAPIKey.IsEmpty() and not EmpOpenAPIKey.IsNull(),'')
	endif
EndSub

