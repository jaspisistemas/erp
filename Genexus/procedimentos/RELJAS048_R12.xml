      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
//RetornaTabelaFilial.Call(&EmpCod, &FilCod, &FiltabCod)
&TipoCodigoBarras = TipoCodigoBarras.Code128

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&IsColuna1 = 0
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	&EtqQtd = EtqQtd
	&ProCod = EtqProCod
	&ProGraCod = EtqProGraCod
	&Coluna1.SetEmpty()

	do 'GetPreco'
	Do 'getTipoProduto'
	If &ProTip = 2
		&NomeEmpresa = trim(&FilFan)
	Else
		&NomeEmpresa = '* '+trim(&FilFan)+' *'
	EndIf
	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto = trim(str(EtqProCod))
	Else
		&CodigoProduto = trim(EtqNovProCod)		
	EndIF

	
	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF

	&NomeProduto  = GxGetMLi(&EtqProNom, 1, 17)
	&NomeProduto1 = GxGetMLi(&EtqProNom, 2, 17)
	
	&CodBarrasImage.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqProBar) + '.jpg'
	If not EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqProBar, EtqProBar)
		EndIF
		If &File.Exists()
			&CodBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf

	do 'printEtiquetas'
EndFor

sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		Do Case
			Case &IsColuna1 <= 1
				print EtiquetaModelo001Col1
				&IsColuna1 = 2
			Case &IsColuna1 = 2
				noSkip
				print EtiquetaModelo001Col2
				&IsColuna1 = 3
			otherwise
				noSkip
				print EtiquetaModelo001Col3
				&IsColuna1 = 1
		EndCase
	EndFor
EndSub

Sub 'GetPreco'
	&Mensagem = ''
	For Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		//Where TabCod = &FiltabCod
		Where TabCod = &TabCod //, in:&TabColCod1, in:&TabColCod2
		
		For Each Order EmpCod, TabCod, ProCod, ProGraCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			
			if &TabColCod1 > 0
				Do Case
					Case &TabColCod1 = 1
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc1))
					Case &TabColCod1 = 2
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc2))
					Case &TabColCod1 = 3
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc3))
					Case &TabColCod1 = 4
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc4))
					Case &TabColCod1 = 5
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc5))
					Case &TabColCod1 = 6
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc6))
					Case &TabColCod1 = 7
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc7))
					Case &TabColCod1 = 8
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc8))
					Case &TabColCod1 = 9
						&Mensagem = 'R$ '+ trim(toFormattedString(TabPrc9))
				EndCase
			Endif
		
			if &TabColCod2 > 0
				if &TabColCod1 > 0
					&Mensagem += ' / '
				Endif
			
				Do Case
					Case &TabColCod2 = 1
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc1))
					Case &TabColCod2 = 2
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc2))
					Case &TabColCod2 = 3
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc3))
					Case &TabColCod2 = 4
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc4))
					Case &TabColCod2 = 5
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc5))
					Case &TabColCod2 = 6
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc6))
					Case &TabColCod2 = 7
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc7))
					Case &TabColCod2 = 8
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc8))
					Case &TabColCod2 = 9
						&Mensagem += ' R$ '+ trim(toFormattedString(TabPrc9))
				EndCase
			Endif
		
		EndFor
	EndFor
	
	if &TabColCod1 <> 0 and &TabColCod2 <> 0
		&coluna2 = &Mensagem
		&Coluna1 = ''
	Else
		&Coluna1 = &Mensagem
		&coluna2 = ''
	Endif

EndSub


Sub 'getTipoProduto'
	For each Order EmpCod,ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProTip = ProTip
		Exit
	EndFor
EndSub
]]></Source>
