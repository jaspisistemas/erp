      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsTodosInformados = true
//&Mensagem.SetEmpty()

For Each order EmpCod, FilCod, PrdCod, PrdItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PrdCod = &PrdCod
	Where ProSolLot = SolicitarLote.SIM_CONTROLAR
	Where PrdItmQtd <> PrdLotTot

	&IsTodosInformados = false
//	&Mensagem = 'É preciso informar todos os lotes dos produtos, ou informar no Prdido que o produto não possui lote'
	Exit
EndFor

if &IsTodosInformados = true
	For Each order EmpCod, FilCod, PrdCod, PrdItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PrdCod = &PrdCod
		Where ProSolLot = SolicitarLote.SIM_CONTROLAR		
		
		For Each order EmpCod, FilCod, PrdCod, PrdItmCod, PrdProEstLotCod
			Where PrdProEstLotCod <> '#SEM_LOTE'
			Where PrdProEstLotFab.IsEmpty() or PrdProEstLotFab.IsNull() or PrdProEstLotVct.IsEmpty() or PrdProEstLotVct.IsNull()
			&IsTodosInformados = false
//			&Mensagem = 'É preciso informar data de Fabricação e Vencimento aos Lotes'
			Exit
		EndFor		
		
		if &IsTodosInformados = false
			Exit
		EndIf
	EndFor
Endif
]]></Source>
