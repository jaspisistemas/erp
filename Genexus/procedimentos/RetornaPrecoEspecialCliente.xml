      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PedVlrUnt.SetEmpty()

For Each Order EmpCod, PesCod, EspProCod, EspProGraCod
	Where EmpCod = &EmpCod
	Where PesCod = &PedClICod
	Where EspProCod = &ProCod
	Where EspProGraCod = &ProGraCod
    
    If ((EspDtaIni <= &PedDtaEms) or EspDtaIni.IsEmpty()) and (EspDtaFin.IsEmpty() or (EspDtaFin >= &PedDtaEms))
        Do Case
			Case &TabColCod = 9
				&PedVlrUnt = EspPrc9
			Case &TabColCod = 8
				&PedVlrUnt = EspPrc8
			Case &TabColCod = 7
				&PedVlrUnt = EspPrc7
			Case &TabColCod = 6
				&PedVlrUnt = EspPrc6
	        Case &TabColCod = 5
	            &PedVlrUnt = EspPrc5
	        Case &TabColCod = 4
                &PedVlrUnt = EspPrc4
	        Case &TabColCod = 3
                &PedVlrUnt = EspPrc3
	        Case &TabColCod = 2
                &PedVlrUnt = EspPrc2
	        Otherwise
                &PedVlrUnt = EspPrc1
        EndCase
    EndIF
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
