      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do CAse
	CAse &OqueFazer = 'ADD' //ADD ALTERA
		For Each Order EmpCod, MonNcmCod
			Where EmpCod = &EmpCod
			Where MonNcmCod = &MonNcmCod
			
			MonIs = &MonIs
			&Mensagem = 'NCM: '+trim(&MonNcmCod)+' Alterado com sucesso!'
			
			Exit
			
		When none
			&Mensagem = 'NCM: '+trim(&MonNcmCod)+' inserido com sucesso!'
			New
				EmpCod = &EmpCod
				MonNcmCod = &MonNcmCod
				MonIs = &MonIs
			EndNew
		EndFor
		
		Commit
		
	CAse &OqueFazer = 'DEL' //DELETA 1
		&Mensagem = 'NCM: '+trim(&MonNcmCod)+' Eliminado com sucesso!'
		For Each Order EmpCod, MonNcmCod
			Where EmpCod = &EmpCod
			Where MonNcmCod = &MonNcmCod
			
			Delete
			
			Exit
		EndFor
		
		Commit
		
		
	CAse &OqueFazer = 'DEX' //DELETA TUDO
		For Each Order EmpCod, MonNcmCod
			Where EmpCod = &EmpCod
			
			Delete
		EndFor
		
		Commit
		
EndCase

]]></Source>
