      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[if &entrada.StartsWith('+')
	&saida = &entrada
else
	&matchs = &entrada.Matches('[0-9]+') // retorna só números
	
	For &match in &matchs
		&saida += &match.Value
	EndFor
	
	&length = &saida.Length()
	
	/*
		8  - ignora      - 3249-6601 | 9761-8592
		10 - add 55      - (44) 3249-6601 | (44) 9761-8592
		11 - add 55      - (44) 9 9761-8592
		12 - ok, sem add - +55 (44) 3249-6601 | +55 (44) 9761-8592
		13 - ok, sem add - +55 (44) 9 9761-8592
	*/
	do case
		case &length = 10
			&saida = '55' + &saida
		case &length = 11
			&saida = '55' + &saida
		case &length = 12
			// não remova
		case &length = 13
			// não remova
		otherwise
			&saida.SetEmpty()
	endcase
endif
]]></Source>
