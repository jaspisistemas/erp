      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 10
&Count = 0
&Percentual = 5
&ProgressIni = serverNow()
do 'Atualiza'

&IsContinua = true
do while  &IsContinua = true
	&PedCod = 0
	
	&SdtGravaPedido = new()
	&SdtGravaPedido.FilCod = &FilCod
	&SdtGravaPedido.EmpCod = &empCod
	&SdtGravaPedido.LctCod = &LctCod	
	&SdtGravaPedido.PedFatFilCod = &FilCodFat
	&SdtGravaPedido.PedVenCod = &PedVenCod
	&SdtGravaPedido.PedTipFrt = TipoFrete.Emitente
	
	For Each ORder EmpCod, FilCod
		Where EmpCod = &empCod
		Where FilCod = &FilCod
		
		&tabCod  = FilTabCod
		&SdtGravaPedido.TabCod = FilTabCod
		&SdtGravaPedido.TabColCod = FilTabColCod
		&SdtGravaPedido.PedCliCod = FilPesCod
		&TabColCod = FilTabColCod
		Exit
	EndFor
	
	if &tabCod.IsEmpty()
		&tabCod = '1'
		&TabColCod = 1
	Endif
	
	&SdtGravaPedido.PedDtaEms = serverdate()
	
	GravaPedidoVenda.Call(TrnMode.Insert, &empCod, &FilCod, &PedCod, &SdtGravaPedido, &PedVenCod, &WwpContextUserName)
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &empCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		PedSts = Status_Pedido.CANCELADO //JDF cancela para depois abrir em baixo
		PedStsFin = Status_Financeiro.CANCELADO
		Exit
	EndFor

 	commit
	
	&Count = 0
	
	For Each ORder EmpCod, FilCod, ProCod, ProGraCod
		where EmpCod = &empCod
		Where FilCod = &FilCod
		Where EstQtd > 0
		where ProCod > &ProCod
		
		&PedVlrUnt = 0		
		RetornaPrecoUnitarioVenda.Call(EmpCod, &tabCod, '', ProCod, ProGraCod, &TabColCod, serverdate(), &PedDtaVct, &PedVlrUnt )
		
		if &PedVlrUnt > 0
			&Count += 1
			
			&sdtAddPedidoProduto = new()			
			&sdtAddPedidoProduto.PedItmAcr = 0
			&sdtAddPedidoProduto.PedItmDsc = 0
			&sdtAddPedidoProduto.PedItmIpi = 0
			&sdtAddPedidoProduto.PedItmIcmSt = 0
			&sdtAddPedidoProduto.PedItmIcmStPob = 0
			&sdtAddPedidoProduto.PedItmIcm = 0
			&sdtAddPedidoProduto.PedQtdEmb = EstQtd
			&sdtAddPedidoProduto.PedProEmbQtd = ProEmbQtd
			&sdtAddPedidoProduto.PedItmCmp = ''
		//	&sdtAddPedidoProduto.PedItmAjuIpiBas = PedItmAjuIpiBas
		//	&sdtAddPedidoProduto.PedItmAjuIcmBas = PedItmAjuIcmBas
		//	&sdtAddPedidoProduto.PedItmAjuIcmStBas = PedItmAjuIcmStBas
		//	&sdtAddPedidoProduto.PedItmAjuPisBas = PedItmAjuPisBas
			&sdtAddPedidoProduto.PedItmPis = 0
			&sdtAddPedidoProduto.PedItmCofins = 0
			
			GravaItemPedidoCompra.Call(&empCod, &FilCod, &PedCod, 0, ProCod, ProGraCod, EstQtd, &PedVlrUnt, &sdtAddPedidoProduto, &sdtProdutoLote, &InseridoMensagem, &AlteradoMensagem, &WwpContextUserName, 'N')
			
			&ProCod = ProCod
			if &Count = 399
				Exit
			EndIf
		Endif
		
	EndFor

	//Atualiza Total pedido
	AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')
	AtualizaEstoqueGerencialCompra.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &EmpCod,  Status_Pedido.ABERTO)
	
	if &Count < 399
		&IsContinua = false
	Endif
Enddo


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub

]]></Source>
