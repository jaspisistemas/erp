      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PesCod
	where EmpCod = &EmpCod
	where PesCod = &PesCod
	&PesRaz = PesRaz
	&PesPrmEml = PesPrmEml
	&PesPrmFon = PesPrmFon
		
	Exit
EndFor

//FILHOS
For &SdtFilhosItem in &SdtFilhos
	&IsSalvo = true
	For each order EmpCod, PesCod, PesHerCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		where PesHerCod = &SdtFilhosItem.PesHerCod
		
		if &SdtFilhosItem.PesHerSts = Status_SimNao.Sim 
			PesHerNom = &SdtFilhosItem.PesHerNom
			PesHerDtaNas = &SdtFilhosItem.PesHerDtaNas			
			
			if &SdtFilhosItem.PesHerNom.IsEmpty()
				&IsSalvo = false
				Delete
			EndIf
		else 
			&IsSalvo = false
			Delete // se tiver Sts = nao - deleta
		EndIf
		
	When none
		if &SdtFilhosItem.PesHerSts = Status_SimNao.Sim
			if not &SdtFilhosItem.PesHerNom.IsEmpty()
				New
					EmpCod = &EmpCod
					PesCod = &PesCod
					PesHerCod = &SdtFilhosItem.PesHerCod
					PesHerNom = &SdtFilhosItem.PesHerNom
					PesHerDtaNas = &SdtFilhosItem.PesHerDtaNas
				EndNew
			Else
				&IsSalvo = false
			EndIf
		EndIf
	EndFor

	if &SdtFilhosItem.PesHerDtaNas.IsEmpty() or &SdtFilhosItem.PesHerNom.IsEmpty()	
		&IsSalvo = false
	Endif

	Commit
	
	&AuxPesRaz = Substr(&PesRaz, 1, 15) + ' [FILHO:'+ &SdtFilhosItem.PesHerNom+ ']'
	
	if &IsSalvo = true
		prcAtualizaAniversariantes.Call('ADD', &EmpCod, &AuxPesRaz, TipoAniversario.Filho, Status_SimNao.Sim, 0, '', &SdtFilhosItem.PesHerDtaNas, &PesCod, &SdtFilhosItem.PesHerCod, &PesPrmFon, &PesPrmEml )
	Else
		prcAtualizaAniversariantes.Call('ADD', &EmpCod, &AuxPesRaz, TipoAniversario.Filho, Status_SimNao.Sim, 0, '', &PesEmlDtaNas, &PesCod, &SdtFilhosItem.PesHerCod, &PesPrmFon, &PesPrmEml )
	Endif
EndFor

]]></Source>
