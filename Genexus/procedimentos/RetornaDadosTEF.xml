      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, TefCod
	Where EmpCod = &EmpCod
	Where TefCod = &TefCod
	
	&TefBand = TefBand.ToUpper()
	&CreditoDebitoVoucher = TefCreDebVou
	&TefBanCarCod = TefBanCarCod
	&BanCarCnpj = TefBandCnpj
	&TefBandCod = TefBandCod
	&TefAutorizacao = TefIdAut

	if not &TefBandCod.IsEmpty()
		do 'getBandeira'
	Endif

	Exit
endfor


if &BanCarCnpj.IsEmpty()
	For Each Order EmpCod, BanCarCod
		Where EmpCod = &EmpCod
		Where BanCarCod = &TefBanCarCod
		
		&BanCarCnpj = BanCarCNPJ
		Exit
	EndFor	
Endif


Sub 'getBandeira'
	Do CAse 
		Case &TefBandCod = 	1	&TefBand = 'VISA'
		Case &TefBandCod = 	2	&TefBand = 'MASTERCARD'
		Case &TefBandCod = 	3	&TefBand = 'AMERICAN EXPRESS'
		Case &TefBandCod = 	4	&TefBand = 'SOROCRED'
		Case &TefBandCod = 	5	&TefBand = 'DINERS CLUB'
		Case &TefBandCod = 	6	&TefBand = 'ELO'
		Case &TefBandCod = 	7	&TefBand = 'HIPERCARD'
		Case &TefBandCod = 	8	&TefBand = 'AURA'
		Case &TefBandCod = 	9	&TefBand = 'CABAL'
		Case &TefBandCod = 	10	&TefBand = 'ALELO'
		Case &TefBandCod = 	11	&TefBand = 'BANES CARD'
		Case &TefBandCod = 	12	&TefBand = 'CALCARD '
		Case &TefBandCod = 	13	&TefBand = 'CREDZ'
		Case &TefBandCod = 	14	&TefBand = 'DISCOVER'
		Case &TefBandCod = 	15	&TefBand = 'GOODCARD'
		Case &TefBandCod = 	16	&TefBand = 'GREENCARD'
		Case &TefBandCod = 	17	&TefBand = 'HIPER'
		Case &TefBandCod = 	18	&TefBand = 'JCB'
		Case &TefBandCod = 	19	&TefBand = 'MAIS'
		Case &TefBandCod = 	20	&TefBand = 'MAXVAN'
		Case &TefBandCod = 	21	&TefBand = 'POLICARD'
		Case &TefBandCod = 	22	&TefBand = 'REDECOMPRAS'
		Case &TefBandCod = 	23	&TefBand = 'SODEXO'
		Case &TefBandCod = 	24	&TefBand = 'VALECARD'
		Case &TefBandCod = 	25	&TefBand = 'VEROCHEQUE'
		Case &TefBandCod = 	26	&TefBand = 'VR'
		Case &TefBandCod = 	27	&TefBand = 'TICKET'
		Case &TefBandCod = 	99	&TefBand = 'OUTROS'
	EndCase
EndSub
]]></Source>
