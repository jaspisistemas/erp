      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
LoadWWPContext.Call(&Context)
&EmpCod = &Context.EmpCod

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &Context.FilCod
		&FilEan13 = FilEan13
	Exit
EndFor

&tamanho  = len(&FilEan13)

if &tamanho in (9,10)
	For &Item = 1 to 999 step 1
		Do Case
			CAse &tamanho = 9
				&AuxProBar = trim(&FilEan13) + padL(trim(str(&Item)), 3, '0')
			Case &tamanho = 10
				&AuxProBar = trim(&FilEan13) + padL(trim(str(&Item)), 2, '0')
		EndCase
		
		digitoEAN13.Call(&AuxProBar, &NewProbar)
		
		For Each Order EmpCod, ProGraBar, ProCod
			Where EmpCod = &EmpCod
			Where ProCod <> &ProCod
			Where ProGraBar = &NewProbar
			&AuxProBar = ''
			&Mensagem = 'Não Localizado EAN-13 Disponível para esse Produto, Adquira Mais uma sequência de EAN-13'
			Exit
		When none
			&Mensagem = ''
			Return
		EndFor
	EndFor
Else
	&Mensagem = 'Código Empresa para uso do EAN13 não Localizado ou inválido, Atualize o Código Empresa do EAN13 no Cadastro da Filial!'
	ValidaEan13.Call(&ProCod, '', &NewProbar, &ErroEan13Mensagem)
EndIF

]]></Source>
