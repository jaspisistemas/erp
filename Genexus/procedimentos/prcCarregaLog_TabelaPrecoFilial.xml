        <Source><![CDATA[

if &TabCod.IsEmpty() //INSERT
	//QUando insert inserido os campos no proprio processo de gravar.
Else
	For Each order EmpCod,TabCod,TabFilCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		
		&IdVarchar = trim(str(TabFilCod))
		prcLogAddSdtLevel.Call(&IdVarchar, 'TabCod', trim(TabCod), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'TabFilCod', trim(TabFilCod.ToFormattedString()), '', &sdtLogAtributosLevel)
		
	EndFor
Endif
]]></Source>
