      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
prcMercadolivreRefreshToken.Call(&EmpCod, &MrkCod, &MrkSession, &IsSucesso)

&HttpClient.AddHeader('Content-Type', 'application/json')
&HttpClient.AddHeader('Accept', 'application/json')
&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
&HttpClient.AddString(&LongVarChar)
&HttpClient.Execute('GET', 'https://api.mercadolibre.com/shipments/'+&MrkShipSku+'/billing_info')

&LongVarchar = "Status: " + &HttpClient.StatusCode.ToString()+' GUID:' +&MrkGuid
&LongVarchar += "Erro: " + &HttpClient.ErrDescription
&LongVarchar += "Retorno: " + &HttpClient.ToString()
&LongVarchar += &HttpClient.ToString()
	padraoUsuario.Call('G', 'TESTEBilling', 1, 1,&LongVarchar, &PAdDtaMod)

If &HttpClient.StatusCode = 200
	
	&sdtShipping.FromJson(&HttpClient.ToString())
	
	For Each Order EmpCod, MrkCod, MrkShipSku
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		Where MrkShipSku = &MrkShipSku
		
//		MrkShipLong = &Longvarchar
		
		if not &sdtShipping.receiver.document.value.IsEmpty()
			MrkShipCpfCnpj = &sdtShipping.receiver.document.value
		Endif
	
		if not &sdtShipping.receiver.document.id.IsEmpty()
			MrkShipPesTip = iif(&sdtShipping.receiver.document.id = 'CPF', TipoPessoa.FISICA, TipoPessoa.JURIDICA)
		Endif
	
		for &sdtShippingReceiverAditional in &sdtShipping.receiver.additional_documents.additional_documentsItemns
			If &sdtShippingReceiverAditional.id = 'IE'
				MrkShipInsEst = &sdtShippingReceiverAditional.value
			Endif
		EndFor
	

//		MrkShipBai = &sdtShipping.receiver_address.neighborhood.name
//		MrkShipLog = &sdtShipping.receiver_address.street_name
//		MrkShipNro = &sdtShipping.receiver_address.street_number
//		MrkShipCid = &sdtShipping.receiver_address.city.name
//		MrkShipPai = &sdtShipping.receiver_address.country.name
//		MrkShipUF = &sdtShipping.receiver_address.state.id
//		
//		MrkShipFrt = &sdtShipping.base_cost
		
		Exit
//	When none
//		New
//			EmpCod = &EmpCod
//			MrkCod = &MrkCod
//			MrkShipSku = &MrkShipSku
//			
//			MrkShipBai = &sdtShipping.receiver_address.neighborhood.name
//			MrkShipLog = &sdtShipping.receiver_address.street_name
//			MrkShipNro = &sdtShipping.receiver_address.street_number
//			MrkShipCid = &sdtShipping.receiver_address.city.name
//			MrkShipPai = &sdtShipping.receiver_address.country.name
//			MrkShipUF = &sdtShipping.receiver_address.state.id
//			
//			MrkShipFrt = &sdtShipping.base_cost
//			
//			MrkShipLong = &Longvarchar
//		EndNew	
	EndFor
	
	commit
Else
	msg('Falha catastrófica! ' + &HttpClient.StatusCode.ToString())
Endif

]]></Source>
