      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,AloCod,AloDtaFch
	Where EmpCod = &EmpCod
	Where AloCod = &AloCod

	If &OQUEFAZER = 'ABRIR' // 'ABRIR', 'FECHAR'
		AloDtaFch.SetEmpty()
		AloSts =Status_alojamento.Emproducao
	Else
	 	AloDtaFch = &AloDtaFch
		AloSts =Status_alojamento.Encerrado
	EndIf
EndFor
]]></Source>
