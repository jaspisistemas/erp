      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
for Each order EmpCod, PdvCod
	Where PdvRandon = &PdvRandon //PRA SABER SE É UM PDV VALIDO
	&EmpCod = EmpCod
	&FilCod = PdvFilCod
	Exit
When none
	Return
EndFor
 
&MarDtaHorUltMod = ServerNow()
&SDUltimaSync = TimestampToDateTime.Udp(&DataSyncTimesTamp)
 
// &mensagem = &DataHoraVarchar + ' ' + trim(toformattedString(&SDUltimaSync))
//padraousuario.Call('G' , 'JEANJJASNS1', 1, 1, &mensagem, &PadDtaMod)

&sdtGetProdutosExtraPDV.Sts = 'J200'
&sdtGetProdutosExtraPDV.Msg = ''
&sdtGetProdutosExtraPDV.empCod = &EmpCod

 if &inProCod = 0
	//RETORNAR DADOS PRODUTOS / MARCA / ESTOQUE
	For each order EmpCod, MarCod
		Where EmpCod = &EmpCod
		Where MarDtaHorUltMod >= &SDUltimaSync or &SDUltimaSync.IsEmpty() or MarDtaHorUltMod.IsEmpty() or MarDtaHorUltMod.IsNull()
		
		if MarDtaHorUltMod.IsEmpty() or MarDtaHorUltMod.IsNull()
			MarDtaHorUltMod = &MarDtaHorUltMod
			Commit
		Endif
		
		&sdtGetProdutosExtraPDVMarca = new()
		&sdtGetProdutosExtraPDVMarca.MarCod = MarCod
		&sdtGetProdutosExtraPDVMarca.MarNom = MarNom
		&sdtGetProdutosExtraPDV.Marca.Add(&sdtGetProdutosExtraPDVMarca)
	EndFor
	
	//EMBALAGEM
	For each order EmpCod, EmbCod
		Where EmpCod = &EmpCod
		Where EmbDtaHorUltMod >= &SDUltimaSync or &SDUltimaSync.IsEmpty() or EmbDtaHorUltMod.IsEmpty() or EmbDtaHorUltMod.IsNull()
		
		if EmbDtaHorUltMod.IsEmpty() or EmbDtaHorUltMod.IsNull()
			EmbDtaHorUltMod = &MarDtaHorUltMod
			Commit
		Endif
		
		&sdtGetProdutosExtraPDVEmbalagem = new()
		&sdtGetProdutosExtraPDVEmbalagem.EmbCod = EmbCod
		&sdtGetProdutosExtraPDVEmbalagem.EmbNom = EmbNom
		&sdtGetProdutosExtraPDVEmbalagem.EmbUnd = EmbUnd
//		&sdtGetProdutosExtraPDVEmbalagem.EmbUndTrib = EmbUndTrib
//		&sdtGetProdutosExtraPDVEmbalagem.EmbQtd = EmbQtd
//		&sdtGetProdutosExtraPDVEmbalagem.EmbEsp = EmbEsp
		&sdtGetProdutosExtraPDV.Embalagem.Add(&sdtGetProdutosExtraPDVEmbalagem)
	EndFor
Endif

//ESTOQUE
For each order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	where ProCod > &inProCod //when &SDUltimaSync.IsEmpty()
	Where EstDtaHorUltMod >= &SDUltimaSync or &SDUltimaSync.IsEmpty() or EstDtaHorUltMod.IsEmpty() or EstDtaHorUltMod.IsNull()
	Where ProSts = Status_Produto.ATIVO
	
	&Count += 1
	
	&sdtGetProdutosExtraPDVEstoque = new()
	&sdtGetProdutosExtraPDVEstoque.ProCod = ProCod
	&sdtGetProdutosExtraPDVEstoque.ProGraCod = ProGraCod
	
	&sdtGetProdutosExtraPDVEstoque.EstQtd = 0
	if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
		&sdtGetProdutosExtraPDVEstoque.EstQtd = EstQtd
	Endif

	if (&Count = 25 and &inProCod = 0) or (&inProCod > 0 and &Count = 100)
		&sdtGetProdutosExtraPDV.TemMais = 'S'	
		exit
	Else 
		if EstDtaHorUltMod.IsEmpty() or EstDtaHorUltMod.IsNull()
			EstDtaHorUltMod = &MarDtaHorUltMod
			Commit
		Endif
	
		&Count += 1
		&sdtGetProdutosExtraPDV.Estoque.Add(&sdtGetProdutosExtraPDVEstoque)
	Endif
EndFor

]]></Source>
