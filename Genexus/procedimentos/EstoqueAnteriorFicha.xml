      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&EstTipQtd = 0
For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &PRoGraCod when &PRoGraCod > 1
	&EstTipQtd += EstQtd
EndFor

For Each Order EmpCod, FilCod, ProCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedProEstProCod = &ProCod
	Where PedProEstProGraCod = &PRoGraCod when &PRoGraCod > 1
	Where PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO
	Where (PedDtaFic >= &PedDtaFat and  PedDtaFic <= &PedDtaFat_to) 
	Where LctAtuEst = Status_EntradaSaida.Entrada or LctAtuEst = Status_EntradaSaida.Saida
	
	if LctAtuEst = Status_EntradaSaida.Saida
		&EstTipQtd += PedQtd
	else
		&EstTipQtd -= PedQtd
	endif    
EndFor
]]></Source>
