      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, SimCod
	Where 	EmpCod 			= &EmpCod //Empresa
	Where 	(SimProCod 		= &ProCod) or  (SimProCodVin = &ProCod )
	
	//Vai pegar o código ao contrário do parâmetro 
	//Se o ProCod for igual ao SimProCod, ele vai pegar como similar o SimProCodVin. E vice-versa
	If SimProCod = &ProCod 
		&OUtroProCod = SimProCodVin
		&ProRef = SimProRefVin
		&ProNom = SimProNomVin
	Else
		&OUtroProCod = SimProCod
		&ProRef = SimProRef
		&ProNom = SimProNom
	EndIf
	
	&IsAchou = false
	For &sdtSimilaresItem in &sdtSimilares.Produtos
		if &sdtSimilaresItem.SimProCod = &OUtroProCod
			&IsAchou = true
			Exit
		Endif			
	EndFor

	if &IsAchou = false //ADD LISTA SIMILARES
		&sdtSimilaresItem = new()
		&sdtSimilaresItem.SimProCod = &OUtroProCod
		&sdtSimilaresItem.SimProNom = &ProNom 
		&sdtSimilaresItem.SimProRef = &ProRef
		prcEstoqueSimilar_EstQtd.Call(&EmpCod, &FilCod, &OUtroProCod, &EstLoc, &AuxSimEstQtd, &ProQtdMax, &ProQtdMin)
		&sdtSimilaresItem.EstLoc = &EstLoc
		&sdtSimilaresItem.SimQtd = &AuxSimEstQtd
		&sdtSimilaresItem.SimQtdMin = &ProQtdMin
		&sdtSimilaresItem.SimQtdMax = &ProQtdMax
		&sdtSimilares.Produtos.Add(&sdtSimilaresItem)
		
		&sdtSimilares.QtdSimilar += &AuxSimEstQtd
		
		if (&ProQtdMin < &sdtSimilares.QtdMin or &sdtSimilares.QtdMin.IsEmpty()) and &ProQtdMin > 0
			&sdtSimilares.QtdMin = &ProQtdMin
		Endif
	
		if (&ProQtdMax > &sdtSimilares.QtdMax and &ProQtdMax > 0)
			&sdtSimilares.QtdMax = &ProQtdMax
		Endif
	
		prcRetornaQuantidadeEstoqueSimilares_1.Call(&EmpCod, &FilCod, &OUtroProCod, &sdtSimilares)
	Endif	
EndFor

]]></Source>
