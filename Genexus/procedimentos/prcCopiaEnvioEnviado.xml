      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//PEGA PASTAS DE CONFIGURACAO
&sdtConfiguracoesPasta = RetornaConfiguracoesPastas.Udp(&EmpCod, &FilCod)

For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	if not NfeChv.IsEmpty()
		&NomeEmProcessamento = &sdtConfiguracoesPasta.PastaNFprocessamento + NfeChv.Trim() + '-nfe.xml'
		&NomeEnvio = &sdtConfiguracoesPasta.PastaNFerro + NfeChv.Trim() + '-nfe.xml'
		
		//GERA ARQUIVO XML NA PASTA ENVIO
		&ArquivoEnvio.Source = &NomeEnvio
		if &ArquivoEnvio.Exists()
			&ArquivoEnvio.Copy(&NomeEmProcessamento)
		endif
	Endif

	Exit
EndFor
]]></Source>
