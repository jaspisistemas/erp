      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsBaixaOk	= True
&Mensagem = ''
For each Order EmpCod,FilCod,CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	
	Do Case
		Case CreOriDup <> OrigemDuplicata.LancamentoManual and (CrePedCod <> 0 or CreFrtCod <> 0)
			&Mensagem = 'ATENÇÃO! Duplicata foi originada de um "' +trim(CreOriDup.EnumerationDescription())+ '", Não é possível Cancelar essa duplicata por aqui!'
			
		Case CreVlrSdo = CreVlrDup and CrePedCod = 0
			CreSts = Status_Duplicata.CANCELADA
			If not CreCheCod.IsEmpty() and not CreCheCod.IsNull()
				&cheCod =  CreCheCod
				Do 'CancelaCheque'
			Endif
			
			If CreCbrTipBol	= TipoBoleto.Hibrido And Not CreBloNro.IsEmpty() And CreDtaRet.IsEmpty()
				Do Case
					Case CreCbrCtaBanBanCod = '077'
						&CreCbrCod	= CreCbrCod
						Do 'GetLocalCobranca'
						
						If &IsErro	= False
							&MotivoVarChar	= 'Duplicata cancelada via Sistema JASPI.'
							prcCancelarCobranca_Inter.Call(&EmpCod, &FilCod, 0, '', CreCod, &CreCbrCod, &CbrChaTra, &contacorrente, CreCodSol, &MotivoVarChar, &Mensagem)
						EndIf
					Case CreCbrCtaBanBanCod = '748'
						prcCancelarCobranca_Sicredi.Call(&EmpCod, &FilCod, 0, '', CreCod, CreCbrCod, CreBloNro, &IsBaixaOk, &Mensagem)
						
				EndCase
			EndIf
			
			//cancelar o status de pago da folha de pagamento 
			If CreOriDup = OrigemDuplicata.PagamentoFerias or CreOriDup = OrigemDuplicata.PagamentoRescisao
				do 'updateFolhaPagamento'
			Endif
		
//		Case CreVlrSdo = CreVlrDup and (CreTipDup = TipoDuplicata.CHEQUEP or CreTipDup = TipoDuplicata.CHEQUET)
//			&cheCod =  CreCheCod
//			Do 'DeletaCheque'
//			CreSts = Status_Duplicata.CANCELADA
		OtherWise
			&Mensagem = 'ATENÇÃO! Não é possível Cancelar essa duplicata pois a mesma já possui pagamento'
	EndCase
EndFor

GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'Duplicata Cancelada',&CreMetCod,&CreResCob,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
Commit


Sub 'updateFolhaPagamento'
	For Each ORder EmpCod, FPagCod, FPagDupCod
		Where EmpCod = &EmpCod
		Where FPagDupCreCod = &CreCod
		Where FPagDupFilCod = &FilCod
		
		
		&FPagCod = FPagCod
		
		do 'updateFolha'
		
		//JDF deixa o zero 
		FPagDupCreCod = 0
		FPagDupFilCod = 0
	EndFor
		
EndSub

Sub 'UpdateFolha'
	For Each Order EmpCod, FPagCod
		Where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		
		&IsTemUm = false
		For Each ORder EmpCod, FPagCod, FPagDupCod
			if FPagDupCreCod > 0 and FPagDupCreCod <> &CreCod
				&IsTemUm = true
			Endif		
		EndFor
		For Each ORder EmpCod, FPagCod, FPagCtaCod
			If FPagCtaMovCod > 0
				&IsTemUm = true
			Endif
		EndFor
		
		if &IsTemUm = true
			FPagSts = Status_Folha.PagoParcial //fechado parcial
		Else
			FPagSts = Status_Folha.Aberto //aberto
		Endif
	
		Exit
	EndFor
EndSub


Sub 'CancelaCheque'
	For each Order EmpCod,CheCod
		Where EmpCod = &EmpCod
		Where CheCod = &cheCod
		
		CheMot = MotivoCheque.CANCELADO
		//delete 
		
		Exit
	EndFor
EndSub

Sub 'GetLocalCobranca'
	
	&IsErro 		= False
	For each Order EmpCod, CbrCod, CrbRegAut
		Where EmpCod 	= &EmpCod
		Where CbrCod 	= &CreCbrCod
		Where CrbRegAut = Status_SimNao.Sim
		
		&contacorrente	= CbrNroCon.Trim() + CbrNroConDig.Trim()
		If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow()
			&CbrChaTra 			= CbrChaTra
		Else
			prcOAuth_Inter.Call(&EmpCod, &FilCod, &PesCod, CbrCod, &CbrChaTra, &Mensagem)
			If Not &Mensagem.IsEmpty()
				&IsErro			= True
			EndIf
		EndIf
		
		Exit
	When None
		&IsErro	= True
	EndFor

EndSub
]]></Source>
