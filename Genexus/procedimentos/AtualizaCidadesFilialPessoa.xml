      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CidNom = &ppJASPI_EmpresasdtEmpresa.CliCidNom
&UfeCod = &ppJASPI_EmpresasdtEmpresa.UfeCod

For Each Order EmpCod, CidNom, UfeCod
	Where EmpCod = &EmpCod
	Where CidNom = &CidNom 
	Where UfeCod = &UfeCod
	&CidCod = CidCod
	
	Exit
EndFor


For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCidCod.IsEmpty() or FilCidCod.IsNull()
	FilCidCod = &CidCod
EndFor


For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCidCod.IsEmpty() or PesCidCod.IsNull()
	PesCidCod = &CidCod
EndFor

Commit
]]></Source>
