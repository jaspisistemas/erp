      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem = ''

For Each order EmpCod, MarNom
	Where EmpCod = &EmpCod
	Where MarNom = &MarNom
	Where MarCod <> &MarCod
	&Mensagem = 'Marca Já cadastrada Código: ' + trim(str(MarCod))
	Exit
EndFor
]]></Source>
