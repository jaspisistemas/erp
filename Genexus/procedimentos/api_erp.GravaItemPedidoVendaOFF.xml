      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&MensagemAlterada = ''
&MensagemInserida = ''
&OldPedQtd = 0
&PedQtdFat = 0

//NAO GRAVA LOG, SOMENTE USADO NO SMART

For Each Order EmpCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&ProGraRef = ProGraRef
	&GrupCom = GrupCom
	&PedVlrCus = ProVlrCus
	
	&PedVlrCusPrd = 0
	Do Case
		Case ProTipCus = TipoCusto.Receita 
			&PedVlrCusPrd    = ProVlrCusPrd
			
		Case ProTipCus = TipoCusto.CustoProdutoEstoque
			&PedVlrCusPrd    = retornaCustoProducao.Udp(EmpCod, ProEstProCod)				
	EndCase
		
	&ProTipDef = ProTipDef
	
	&PedProEstProCod	= ProEstProCod		
	&PedProEstProGraCod = &ProGraCod
	
	Exit
EndFor 


For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&PedDtaFat = PedDtaFat
	
	&LctAtuEst = LctAtuEst
	&LctAtuSal = LctAtuSal
	&LctAtuPro = LctAtuPro
	&LctTip = LctTip
	&LctGerFin = LctGerFin
	
	&PedSts = PedSts
    &IsLimite = false
	
    For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where PedItmCod = &PedItmCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&OldPedQtd = PedQtd
		&OldPedQtdSdo = PedQtdSdo
		&PedQtdFat = PedQtdFat
		
		&OldPedVlrCus = PedVlrCus
		//&PedVlrCusPrd = PedVlrCusPrd
		
		PedProEstProCod	   = &PedProEstProCod
		PedProEstProGraCod = &PedProEstProGraCod
		
		PedQtd = &PedQtd
		
		If &PedQtdCan >= 0 
			PedQtdCan = &PedQtdCan
		Else
			PedQtdCan = 0
		EndIF
		
		PedVlrCus = &PedVlrCus
		PedVlrCusPrd    = &PedVlrCusPrd
		PedItmCmp = &PedItmCmp
		PedItmVenCod = &PedItmVenCod
		PedProEmbQtd = 0
		PedQtdEmb = &PedQtd
		PedVlrTab = &PedVlrTab
		PedVlrUnt = &PedVlrUnt
		PedItmDsc = &PedItmDsc
			
		if &ProTipDef = Definicao.SERVICO
			&MensagemInserida = 'Serviço ' +trim(&ProGraRef)+ ', atualizado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		Else
			&MensagemInserida = 'Produto ' +trim(&ProGraRef)+ ', atualizado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		EndIF
        Exit
    When none
		&PedItmCod = 0
        For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
			Where EmpCod = &EmpCod
	        Where FilCod = &FilCod
	        Where PedCod = &PedCod
            &PedItmCod = PedItmCod
	        Exit
        EndFor
		
        &PedItmCod += 1
        new
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			PedItmCod = &PedItmCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
			PedProEstProCod	   = &PedProEstProCod		
			PedProEstProGraCod = &PedProEstProGraCod
			PedProEmbQtd = 0
			PedQtdEmb = &PedQtd
			PedQtd = &PedQtd
			PedQtdCan = 0
			PedVlrCus = &PedVlrCus
			PedVlrCusPrd    = &PedVlrCusPrd
			//PedItmIpi
			//PedItmIcmSt
			//PedItmAcr
			
			PedItmCmp = &PedItmCmp
			PedItmVenCod = &PedItmVenCod
			PedVlrTab = &PedVlrTab
			PedVlrUnt = &PedVlrUnt
			PedItmDsc = &PedItmDsc
			//PedItmPrm = &PedItmPrm
			//PedItmCom = &PedItmCom
			PedItmDtaAdd = ServerNow()
			PedCodOciRefItm = &PedCodOciRefItm
			
        EndNew
	
		
		if &ProTipDef = Definicao.SERVICO
			&MensagemInserida = 'Serviço ' +trim(&ProGraRef)+ ', adicionado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		Else
			&MensagemInserida = 'Produto ' +trim(&ProGraRef)+ ', adicionado com sucesso. QTD:' + trim(toformattedString(&PedQtd))
		EndIF
		
    EndFor
	Exit
EndFor

commit
]]></Source>
