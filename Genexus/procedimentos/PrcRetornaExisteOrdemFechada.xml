      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ExisteOrdCod = 0

For Each Order EmpCod, FilCod, OrdSetCod, OrdGrupHie, (OrdCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdSetCod = &SetCod
	Where OrdGrupHie like &OrdGrupHie
	Where OrdSts = Status_Producao.EmProducao or OrdSts = Status_Producao.Produzido
	Where OrdCod > &OrdCod

	&ExisteOrdCod = OrdCod
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
