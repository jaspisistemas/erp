      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//INATIVAR OU REATIVAR plano - passar como parametro Status

For each order EmpCod, SerItmCod
	where EmpCod = &EmpCod
	where SerItmCod = &SerItmCod
	
	SerItmSts = &SerItmSts
	if &SerItmSts = Status_AtivoInativo.INATIVO
		msg('Plano inativado com sucesso!')
	else
		msg('Plano reativado com sucesso!')
	EndIf

EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
