      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProBarRef_Comp = ''

For Each Order EmpCod, ProCod, ProGraCod, ProBarId
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod 
	where ProBarMarCod = &MarCod when not &MarCod.IsEmpty()
	Where ProBarTip = 'A' OR ProBarTip = 'O' 
	
	if &ProBarRef_Comp.IsEmpty()
		&ProBarRef_Comp = ProBarRef.Trim()
	Else
		&ProBarRef_Comp += ',' + ProBarRef.Trim()
	Endif

EndFor
]]></Source>
