      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Vpalavra = ''
&X = 1
&Y = 0
&Vnumero  = ''

&Vnum = str(&VnumAux, 18,2)

do while &X <=18
    &Vconverte = substr( &Vnum , &X , 1 )
//==>
    if &Vconverte <> '.'
        &Vnumero=concat( &Vnumero, &Vconverte ,'')

        if &Vconverte <> ' '
            &Y = &Y + 1
        endif
    else
        &Vnumero = concat(&Vnumero,&Vconverte,'')
        &Y = &Y + 1
    endif

    //======================================================================
    // teste de casas decimais
    // (neste modelo o separador decimal é Virgula
    //======================================================================
//==>
    if  &Vconverte = '.' .OR. &Vantcon = '.' .OR. &Vantcon1 = '.'
        &Vantcon1 = &Vantcon
        &Vantcon  = &Vconverte
        &Ponto    = &Ponto + 1
    endif

    &X = &X + 1

EndDo

if  &Ponto = 0
    &Vnumero = concat(&Vnumero,'.00','')
    &Y = &Y + 3
else
    if  &Ponto = 1
        &Vnumero = concat(&Vnumero,'00','')
        &Y = &Y + 2
    else
        if  &Ponto = 2
            &Vnumero = concat(&Vnumero ,'0','')
            &Y = &Y + 1
        endif
    endif
endif

Do while &Y < 18
    &Vnumero = concat('0',&Vnumero,'')
    &Y = &Y + 1
Enddo

// inicio extenso
&Vtri = substr( &Vnumero,1 , 3)
&Vbi  = substr( &Vnumero,4 , 3 )
&Vmi  = substr( &Vnumero,7 , 3 )
&Vmil = substr( &Vnumero,10, 3 )
&Vuni = substr( &Vnumero,13, 3 )
&Vcen = substr( &Vnumero,17, 2 )
&Sep = ''

if &Vtri <> '000'       //trilhoes
    &Vnum1 = val(substr( &Vtri, 1 , 1 ))
    &Vnum2 = val(substr( &Vtri, 2 , 1 ))
    &Vnum3 = val(substr( &Vtri, 3 , 1 ))

    if .NOT. null(&Vnum1)
        &Abc = &Vnum1
        &A   = &Vnum2
        &B   = &Vnum3
        &Centos = 100
        Do 'rot1'
        &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum2)
        &A   = &Vnum3
        &Abc = &Vnum2
        &Centos = 10
        Do 'rot1'
        &Vpalavra = concat( &Vpalavra, &Sep ,' ')
        &Vpalavra = concat( &Vpalavra, &Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum3)
        &A   = &Vnum1
        &B   = &Vnum2
        &Abc = &Vnum3
        &Centos = 0

        If &B <> 1
            do 'rot1'
            &Vpalavra = concat( &Vpalavra, &Sep ,' ')
            &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        endif
    endif

    if &Vnum3 = 1 .AND. null(&Vnum1) .AND. null(&Vnum2)
        &Vpalavra = concat( &Vpalavra,'Trilhao',' ')
    else
        &Vpalavra = concat( &Vpalavra,'Trilhoes',' ')
    endif

    &Sep = ','

endif

if &Vbi <> '000'       //======== Bilhoes ========
    &Vnum1 = val(substr( &Vbi, 1 , 1 ))
    &Vnum2 = val(substr( &Vbi, 2 , 1 ))
    &Vnum3 = val(substr( &Vbi, 3 , 1 ))

    if .NOT. null(&Vnum1)
        &Abc = &Vnum1
        &A   = &Vnum2
        &B   = &Vnum3
        &Centos = 100
        Do 'rot1'
        &Vpalavra = concat( &Vpalavra, &Sep ,' ')
        &Vpalavra = concat( &Vpalavra,&Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum2)
        &A   = &Vnum3
        &Abc = &Vnum2
        &Centos = 10
        Do 'rot1'
        &Vpalavra = concat( &Vpalavra, &Sep ,' ')
        &Vpalavra = concat( &Vpalavra, &Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum3)
        &A   = &Vnum1
        &B   = &Vnum2
        &Abc = &Vnum3
        &Centos = 0
        if &B <> 1
            do 'rot1'
            &Vpalavra = concat( &Vpalavra,&Sep,' ')
            &Vpalavra = concat( &Vpalavra,&Desnum,' ')
        endif
    endif

    if &Vnum3 = 1 .AND. &Vnum1 = 0 .AND. &Vnum2 = 0
        &Vpalavra = concat( &Vpalavra, 'Bilhao',' ')
    else
        &Vpalavra = concat( &Vpalavra, 'Bilhoes',' ')
    endif

    &Sep = ','
endif

if  &Vmi <> '000'        //========== Milhoes =========
    &Vnum1 = val(substr( &Vmi, 1 , 1 ))
    &Vnum2 = val(substr( &Vmi, 2 , 1 ))
    &Vnum3 = val(substr( &Vmi, 3 , 1 ))

    if  .NOT. null(&Vnum1)
        &Abc = &Vnum1
        &A   = &Vnum2
        &B   = &Vnum3
        &Centos = 100
        Do 'rot1'
        &Vpalavra = concat( &Vpalavra, &Sep ,'')
        &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum2)
        &A   = &Vnum3
        &Abc = &Vnum2
        &Centos = 10
        Do 'rot1'
        &Vpalavra = concat( &Vpalavra, &Sep ,' ')
        &Vpalavra = concat( &Vpalavra, &Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum3)
        &A   = &Vnum1
        &B   = &Vnum2
        &Abc = &Vnum3
        &Centos = 0

        if &B <> 1
            do 'rot1'
            &Vpalavra = concat( &Vpalavra, &Sep ,' ')
            &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        endif
    endif

    if &Vnum3 = 1 .AND. &Vnum1 = 0 .AND. &Vnum2 = 0
        &Vpalavra = concat( &Vpalavra, 'Milhao',' ')
    else
        &Vpalavra = concat( &Vpalavra, 'Milhões',' ')
    endif

    &Sep = ','
    
endif

if &Vmil <> '000'       //======= Mil =========
    &Vnum1 = val(substr( &Vmil, 1 , 1 ))
    &Vnum2 = val(substr( &Vmil, 2 , 1 ))
    &Vnum3 = val(substr( &Vmil, 3 , 1 ))

    if  .NOT. null(&Vnum1)
        &Abc = &Vnum1
        &A   = &Vnum2
        &B   = &Vnum3
        &Centos = 100
        Do 'rot1'
        &Vpalavra = concat( &Vpalavra, &Sep ,'')
        &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum2)
        &A   = &Vnum3
        &Abc = &Vnum2
        &Centos = 10
        Do 'rot1'
        &Vpalavra = concat(&Vpalavra, &Sep ,' ')
        &Vpalavra = concat( &Vpalavra, &Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum3)
        &A   = &Vnum1
        &B   = &Vnum2
        &Abc = &Vnum3
        &Centos = 0

        if &B <> 1
            do 'rot1'
            &Vpalavra = concat(&Vpalavra, &Sep,' ')
            &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        endif

    endif

    &Vpalavra = concat(&Vpalavra,'Mil',' ')
    &Sep = ','

endif

if &Vuni <> '000'       //======= Unidades ========
    &Vnum1 = val(substr( &Vuni, 1 , 1 ))
    &Vnum2 = val(substr( &Vuni, 2 , 1 ))
    &Vnum3 = val(substr( &Vuni, 3 , 1 ))

    if  .NOT. null(&Vnum1)
        &Abc = &Vnum1
        &A   = &Vnum2
        &B   = &Vnum3
        &Centos = 100

        Do 'rot1'

        &Vpalavra = concat( &Vpalavra, &Sep ,'')
        &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum2)
        &A   = &Vnum3
        &Abc = &Vnum2
        &Centos = 10
        Do 'rot1'
        &Vpalavra = concat( &Vpalavra, &Sep ,' ')
        &Vpalavra = concat( &Vpalavra, &Desnum,' ')
        &Sep = 'e'
    endif

    if .NOT. null(&Vnum3)
        &A   = &Vnum1
        &B   = &Vnum2
        &Abc = &Vnum3
        &Centos = 0

        if &B <> 1
            do 'rot1'
            &Vpalavra = concat( &Vpalavra, &Sep ,' ')
            &Vpalavra = concat(&Vpalavra,&Desnum,' ')
        endif
    endif
endif

// real ou reais
&F = val(&Vtri)
&G = val(&Vbi)
&H = val(&Vmi)
&I = val(&Vmil)
&J = val(&Vuni)

if null(&F ) .AND. null(&G ) .AND. null(&H ) .AND. null(&I ) .AND. null(&J )
    &Sep = ' '
else
    &Sep = 'de Reais'     // para trilhoes, bilhoes e milhoes
endif

// mil
if null(&F) .AND. null(&G) .AND. null(&H) .AND. .NOT. null(&I) .AND. null(&J)
    &Sep = 'Reais'
else
    if null(&F) .AND. null(&G) .AND. null(&H) .AND. null(&I) .AND. &J=1
        &Sep = 'Real'
    else
        if .NOT. null(&J)
            &Sep = 'Reais'
        endif
    endif
endif

&Vpalavra = concat(&Vpalavra,&Sep,' ')

if &Vcen <> '00'       //========  Centavos =======

    &Vpalavra = concat(&Vpalavra, 'e', ' ')

    &Vnum1 = val(substr( &Vcen, 1 , 1 ))
    &Vnum2 = val(substr( &Vcen, 2 , 1 ))

    if  .NOT. null(&Vnum1)
        &A   = &Vnum2
        &Abc = &Vnum1
        &Centos = 10

        Do 'rot1'

        if &A = 0 .OR. &Abc = 1
            &Sep = 'Centavos'
        else
            &Sep = 'e'
        endif

        &Vpalavra = concat( &Vpalavra, &Desnum,' ')
        &Vpalavra = concat( &Vpalavra, &Sep,' ')
    endif

    if .NOT. null(&Vnum2)
        &B   = &Vnum1
        &Abc = &Vnum2
        &Centos = 0

        if &B <> 1

            do 'rot1'

            if &Abc = 1

                if &B = 0
                    &Sep = 'Centavo'
                else
                    &Sep = 'Centavos'
                endif
            else
                &Sep = 'Centavos'
            endif

            &Vpalavra = concat(&Vpalavra,&Desnum,' ')
            &Vpalavra = concat(&Vpalavra,&Sep,' ')
        endif
    endif
endif

//===== concatenar asteriscos =======
&Vxxx = 1
&Vast = 0

do while &Vxxx <= 200
    &Vparte = substr( &Vpalavra , &Vxxx, 1)

    if .NOT. null(&Vparte)
        &Vast = &Vast + 1
    endif

    &Vxxx = &Vxxx + 1
enddo

&Vpalavra = concat( &Vpalavra , '','' )
&Vast = &Vast + 2

do while &Vast <= 200
    &Vpalavra = concat( &Vpalavra , '','' )
    &Vast = &Vast + 1

    If (&Vast / 10) = int(&Vast / 10)
        &Vpalavra = concat( &Vpalavra , '','' )
        &Vast = &Vast + 2
    EndIf
enddo

Sub 'rot1'
//=========================================================================
    if &Centos = 0 .AND. &B <> 1
        if &Abc = 1
            &Desnum = 'Um'
        else
            if  &Abc = 2
                &Desnum = 'Dois'
            else
                if  &Abc = 3
                    &Desnum = 'Tres'
                else
                    if  &Abc = 4
                        &Desnum = 'Quatro'
                    else
                        if  &Abc = 5
                            &Desnum = 'Cinco'
                        else
                            if  &Abc = 6
                                &Desnum = 'Seis'
                            else
                                if  &Abc = 7
                                    &Desnum = 'Sete'
                                else
                                    if  &Abc = 8
                                        &Desnum = 'Oito'
                                    else
                                        if  &Abc = 9
                                            &Desnum = 'Nove'
                                        endif
                                    endif
                                endif
                            endif
                        endif
                    endif
                endif
            endif
        endif
    else
        if  &Centos = 10
            if &Abc = 1
                if &A = 0
                    &Desnum = 'Dez'
                else
                    if &A = 1
                        &Desnum = 'Onze'
                    else
                        if &A = 2
                            &Desnum = 'Doze'
                        else
                            if &A = 3
                                &Desnum = 'Treze'
                            else
                                if &A = 4
                                    &Desnum = 'Quatorze'
                                else
                                    if &A = 5
                                        &Desnum = 'Quinze'
                                    else
                                        if &A = 6
                                            &Desnum = 'Dezesseis'
                                        else
                                            if &A = 7
                                                &Desnum = 'Dezessete'
                                            else
                                                if &A = 8
                                                    &Desnum = 'Dezoito'
                                                else
                                                    if &A = 9
                                                        &Desnum = 'Dezenove'
                                                    endif
                                                endif
                                            endif
                                        endif
                                    endif
                                endif
                            endif
                        endif
                    endif
                endif
            else
                if  &Abc = 2
                   &Desnum = 'Vinte'
                else
                    if  &Abc = 3
                       &Desnum = 'Trinta'
                    else
                        if  &Abc = 4
                            &Desnum = 'Quarenta'
                        else
                            if  &Abc = 5
                                &Desnum = 'Cinquenta'
                            else
                                if  &Abc = 6
                                    &Desnum = 'Sessenta'
                                else
                                    if  &Abc = 7
                                        &Desnum = 'Setenta'
                                    else
                                        if  &Abc = 8
                                           &Desnum = 'Oitenta'
                                        else
                                            if  &Abc = 9
                                               &Desnum = 'Noventa'
                                            endif
                                        endif
                                    endif
                                endif
                            endif
                        endif
                    endif
                endif
            endif
        else
            if  &Centos = 100
                if  &Abc = 1
                    if &A = 0 .AND. &B = 0
                        &Desnum = 'Cem'
                    else
                        &Desnum = 'Cento'
                    endif
                else
                    if  &Abc = 2
                        &Desnum = 'Duzentos'
                    else
                        if  &Abc = 3
                            &Desnum = 'Trezentos'
                        else
                            if  &Abc = 4
                                &Desnum = 'Quatrocentos'
                            else
                                if  &Abc = 5
                                    &Desnum = 'Quinhentos'
                                else
                                    if  &Abc = 6
                                        &Desnum = 'Seiscentos'
                                    else
                                        if  &Abc = 7
                                            &Desnum = 'Setecentos'
                                        else
                                            if  &Abc = 8
                                                &Desnum = 'Oitocentos'
                                            else
                                                if &Abc = 9
                                                    &Desnum = 'Novecentos'
                                                endif
                                            endif
                                        endif
                                    endif
                                endif
                            endif
                        endif
                    endif
                endif
            endif
        endif
    endif
EndSub
