      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

&mensagem = &AuxMensagem
print mensagem
print titulo

For Each Order ProgressId
	Where ProgressId = &ProgressId
	&sdtPedidosCusto.FromJson(ProgressLogXml)
	Exit
EndFor

If &sdtPedidosCusto.Count = 0
	&mensagem = 'Nada precisou ser atualizado!'
	print mensagem
Else
	For &sdtPedidosCustoItem in &sdtPedidosCusto
		
		print Pedido
	EndFor
EndIF



Header
	&titulo = UPPER('Listagem pedidos Custo Alterado')
	print Cabecalho
End


Footer
	print Rodape
End
]]></Source>
