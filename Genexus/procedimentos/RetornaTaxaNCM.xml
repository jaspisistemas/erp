      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon084_ImpostoAproximado, &TCon084_ImpostoAproximado)
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon103_AliquotaTribApro, &TCon103_AliquotaTribApro)

&UfeCod = &FilCidUfeCod
if &FilCidUfeCod.IsEmpty()
	&UfeCod = 'PR'
EndIF
&AliTaxa = 0

If &TCon084_ImpostoAproximado = 'N'
	&AliTaxa = Val(&TCon103_AliquotaTribApro)
Else	
	For Each Order NcmCod, NcmIbptUF
		Where NcmCod = &NcmCod
		Where NcmIbptUF = &UfeCod
		&AliTaxa = NcmIbptAliqTot
		Exit
	EndFor
EndIf


]]></Source>
