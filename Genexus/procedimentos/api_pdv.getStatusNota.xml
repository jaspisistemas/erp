      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
for Each order EmpCod, PdvCod	
	Where PdvRandon = &PdvRandon //PRA SABER SE É UM PDV VALIDO
	
	&EmpCod = EmpCod
	&FilCod = PdvFilCod	
	Exit
When none 	
	&sdtRetornoNota.Sts = 'E999'
	&sdtRetornoNota.msg = 'Falha catastrófica'
	Return	
EndFor 


For Each ORder EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	where FilCod = &FilCod
	Where NfeDeviceRandon = &nfeGUID
	
	&sdtRetornoNota.Sts = 'J200'
	&sdtRetornoNota.msg = 'Achou a Nota'
	
	If not NfeArqXml.IsEmpty() and NfeSts = Status_NFe.Autorizada
		GravarStatusIMpressao.Call(EmpCod, FilCod, NfeCod, 0)	
	EndIF	
	&sdtRetornoNota.NfeSts = NfeSts
	
	&sdtRetornoNota.NfeChv = NfeChv
	&sdtRetornoNota.NfeSer = NfeSer
	&sdtRetornoNota.NfeNum = NfeNum
	

	
	if NfeSts = Status_Nfe.Autorizada
		&sdtRetornoNota.NfeArqXml = NfeArqXml
		LeituraXmlDanfe.Call(NfeArqXml,&TNFeProc)
		
		If not &TNFeProc.protNFe.infProt.nProt.IsEmpty()
			&sdtRetornoNota.NfeProt = &TNFeProc.protNFe.infProt.nProt + ' ' 
			+ Substr(&TNFeProc.protNFe.infProt.dhRecbto, 9,2) + '/' + Substr(&TNFeProc.protNFe.infProt.dhRecbto, 6,2)
			+ '/' + Substr(&TNFeProc.protNFe.infProt.dhRecbto, 1,4) + ' ' + Substr(&TNFeProc.protNFe.infProt.dhRecbto, 12,8) 
		EndiF
		
		&sdtRetornoNota.NfeUrlQrCode = &TNFeProc.NFe.infNFeSupl.qrCode.Trim()
	Else
		RetornaConfiguracoesPastas.Call(EmpCod, FilCod, &SdtConfiguracoesPasta)
		&sdtRetornoNota.NfeUrlQrCode = &SdtConfiguracoesPasta.PastaDiretorioVirtual + 'sincronizacao/visualizarnfce?&EmpCod='+trim(str(EmpCod))+'&nfeGUID='+trim(NfeDeviceRandon)
	Endif
	
	Return
	
	Exit
When None
	&sdtRetornoNota.Sts = 'E609'
	&sdtRetornoNota.msg = 'Nota não localizada'
	Return
EndFor
]]></Source>
