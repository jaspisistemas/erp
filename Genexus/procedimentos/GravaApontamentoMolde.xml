      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod
	Where EmpCod = &EmpCod
	Where AptDtaLct = &AptDtaLct
	Where AptCodVin = &inAptCod
	delete
EndFor

Commit

if &AptMolCod > 0
	For Each Order EmpCod, MolCod, MolProCod
		Where EmpCod = &EmpCod
		Where MolCod = &AptMolCod
		
		&aptCod = 0
		For Each order EmpCod, AptDtaLct, (AptCod)
			where EmpCod = &EmpCod
			Where AptDtaLct = &AptDtaLct
			&AptCod = AptCod
			Exit
		EndFor
		&AptCod += 1
		if &AptCodVin.IsEmpty()
			&AptCodVin = &AptCod
		EndIF
	
		new
			EmpCod = &EmpCod
			AptDtaLct = &AptDtaLct
			AptCod = &AptCod
			AptAtiCod = &AptAtiCod
			AptFunCod = &AptFunCod
			AptHorIni = &AptHorIni
			AptHorFin = &AptHorFin
			AptProCod = MolProCod
			AptEtpCod = 1
			AptQtd = &AptMolQtd * MolQtd
			AptObs = &AptObs
			AptMolCod = &AptMolCod
			AptMolQtd = &AptMolQtd
			AptCodVin = &AptCodVin
		EndNew
		
		commit
	EndFor

EndiF
]]></Source>
