      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CreDtaVct = serverNow()
&CreCod = 0
&NotaValorMoeda = 0

Do CAse
	CAse &PadGrupTip = 'V' //3 DIAS ANTES DO VENCIMENTO
		if &PadGrupDia > 0
			&CreDtaVct = &CreDtaVct.AddDays(&PadGrupDia)
		Else
			&CreDtaVct = &CreDtaVct.AddDays(3)
		Endif
	
		
		For Each Order EmpCod, FilCod, CreCod, (CreDtaVct)
			Where EmpCod = &EmpCod
			Where CreCliCod = &PadGrupPesCod
			Where CreSts <> Status_Duplicata.CANCELADA 
			Where not CreAdmCod.IsEmpty() and not CreAdmCod.IsNull() //DUPLICATA VINDA DO ADM.
			Where CreNfeCod.IsEmpty() or CreNfeCod.IsNull() //QUE NAO POSSUA NOTA.
			Where CreDtaVct <= &CreDtaVct and CreDtaVct >= serverdate() //3 DIAS ANTES DO VENCIMENTO.
			
			&NotaValorMoeda = CreVlrDup
			&CreCod = CreCod
			
			Exit
		EndFor
		
	CAse &PadGrupTip = 'A' //APOS LIQUIDACAO
	
		&Mes = &CreDtaVct.Month()
		&ano = &CreDtaVct.Year()
		
		For Each Order EmpCod, FilCod, CreCod
			Where EmpCod = &EmpCod
			Where CreCliCod = &PadGrupPesCod
			Where CreSts <> Status_Duplicata.CANCELADA 
			Where not CreAdmCod.IsEmpty() and not CreAdmCod.IsNull() //DUPLICATA VINDA DO ADM.
			Where CreNfeCod.IsEmpty() or CreNfeCod.IsNull() //QUE NAO POSSUA NOTA.
			Where month(CreDtaVct) = &Mes and Year(CreDtaVct) = &ano //3 DIAS ANTES DO VENCIMENTO.
			Where CreVlrSdo = 0 //Paga totalmente
			
//			For Each ORder EmpCod, FiLCod, CreCod, CrePagCod
				&NotaValorMoeda = CreVlrDup
				&CreCod = CreCod
//			EndFor
		
			Exit
		EndFor
EndCAse

	
]]></Source>
