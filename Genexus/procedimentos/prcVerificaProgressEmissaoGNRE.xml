      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&Total 		= &SdtGNRE.Count*3	//## Total de segundos em que o sistema fará a verificação 
&Count 		= 0					//## Segundo inicial 										
&Percentual = 0					//## PErcentual da leitura 									

&ProgressIni 	= serverNow()	//## Data em que o progresso iniciou						
&Mensagem 		= ''				//## XMLLog do progresso 									

do 'Atualiza'				//## Verifica se há um progresso existente 					
do 'VerificaXML'

&Percentual 	= 100			//## Percentual final 										
&ProgressFin 	= serverNow()	//## Data da finalização do Progresso 						
do 'Atualiza'

//Do 'EnviaNotificacaoConcluido'

Sub 'VerificaXML'
	
	//## BUSCA TODAS AS NOTAS DO SDT	##\\

	For &SdtGNREItem In &SdtGNRE
		&NomeXML 		= &SdtConfiguracoesPasta.PastaNFretorno+&SdtGNREItem.NomeArquivo+'-ret-gnre.xml'	//## Nome de Leitura	##\\
		
		&IsExiste 			= False
		Do While &IsExiste 	= False
			&File.Source	= &NomeXML
			If &File.Exists()
				&Count 		+= 1			
				&Percentual = round((&Count / &Total) * 100, 0)
				Do 'Atualiza'
				&IsExiste 	= True
				Exit
			EndIf
			
			&Dorme = Sleep(2)
		EndDo
		
		&NumRec.SetEmpty()
		&SitRecp.SetEmpty()
		prcLerRetGNREXml.Call(&NomeXML, &NumRec, &SitRecp)
		If &SitRecp <> "100" and &SitRecp <> "101"
			&Count 		+= 1			
			&Percentual = round((&Count / &Total) * 100, 0)
			Do 'Atualiza'
			New											 
				EmpCod 		= &EmpCod					// Código da Empresa		
				FilCod 		= &FilCod					// Código da Filial	
				GNRENumRec 	= 'ERRO'					// Recibo da GNRE			
				GNREDtaEms 	= &Today					// Data de Emissão		
				GNREFunCod 	= &FunCod					// Funcionário que emitiu
			EndNew
			Commit
			
			New										
				EmpCod 		=	&EmpCod					//## Código da Empresa				
				FilCod 		= 	&FilCod					//## Código da Filial				
				GNRENumRec 	= 	'ERRO'					//## Número do Recibo 	da GNRE		
				GNREChavNot = 	&SdtGNREItem.NfeChv		//## Chave 				da Nfe		
				GNREVlrTot	= 	Trim(Str(&SdtGNREItem.ValorPrincipal,8, 2))	//## Valor	Total 		da GNRE		
				GNRETipo 	= 	&SdtGNREItem.GnreRecCod	//## Receita 			da GNRE		
				GNRELotPDF 	= 	''						//## Arquivo em PDF		da GNRE		
				GNRELotXML 	= 	''						//## Arquivo em XML		da GNRE	
				GNRESts		= 	&SitRecp
			EndNew
			Commit
			
			&Count 			+= 1			
			&Percentual 	= round((&Count / &Total) * 100, 0)
			Do 'Atualiza'
			Exit
		Else
			&IsExiste 			= False
			prcGerarXmlGNREUniNfe2.Call(&NumRec, &SdtGNREItem.NomeArquivo)
			Do While &IsExiste 	= False
				&File.Source	= &sdtConfiguracoesPasta.PastaNFretorno+&SdtGNREItem.NomeArquivo+'_guias-pro-rec.xml'
				If &File.Exists()
					&Count 		+= 1			
					&Percentual = round((&Count / &Total) * 100, 0)
					Do 'Atualiza'
					&IsExiste 	= True
					Exit
				EndIf
				&Dorme = Sleep(2)
			EndDo
			prcGravaLogGNRE_Novo.Call(&NumRec, &SdtGNREItem.NfeChv, Trim(Str(&SdtGNREItem.NfeNum)), &SdtGNREItem.NomeArquivo, &EmpCod, &FilCod, &GerarDuplicata, &PesCodFornecedor, &PlanCod, &FunCod, &SdtGNREItem.GnreRecCod)
			
			&Count 			+= 1			
			&Percentual 	= round((&Count / &Total) * 100, 0)
			Do 'Atualiza'
		EndIf
	EndFor

EndSub

Sub 'Atualiza'				//## Grava um novo progresso, ou atualiza um existente
	
	For Each Order ProgressId
		Where ProgressId = &ProgressId
		
		ProgressValue = &Percentual
		ProgressLogXml = &Mensagem
	  	ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		  
	When none
		
		New
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &Mensagem
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		EndNew
		
	EndFor
	
	Commit	
	
EndSub

