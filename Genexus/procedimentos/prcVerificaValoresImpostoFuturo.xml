      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PedFatFilCod = &ParPedFatFilCod

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon144_FreteBaseCalculoICMS, &TCon144_FreteBaseCalculoICMS) //FRETE
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon005_TipoCliente, &TipoCliente_369)

RetornaNotasPedido.Call(&EmpCod, &FilCod, &PedCod, &DadosNota)
if not &DadosNota.IsEmpty()
	Return
EndIf

&UltimoPedItmCod = 0 //&TCon144_FreteBaseCalculoICMS
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where  ProTipDef <> Definicao.SERVICO
	&UltimoPedItmCod += 1 //&TCon144_FreteBaseCalculoICMS
EndFor

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedSts <> Status_Pedido.FECHADO
	
	//&TCon144_FreteBaseCalculoICMS
	&tmpNfeVlrBrtNotDesconto = PedVlrBrt
	&tmpNfeVlrBrtNot = PedVlrBrt - (PedVlrOut + PedVlrFrt + PedVlrGnre) //- PedVlrDscGlb
	
	If &TipoCliente_369 = 'S'
		&PedTpcVlr 		= PedTpcVlr
	Else
		&PedTpcVlr 		= 0
	EndIF
	
	if &PedFatFilCod.IsEmpty()
		if PedFatFilCod.IsEmpty() or PedFatFilCod.IsNull()
			&PedFatFilCod = FilCod
		Else
			&PedFatFilCod = PedFatFilCod
		Endif
	Endif
	
	RetornaFilialBaseImposto.Call(EmpCod, &PedFatFiLCod, &FilBasImp)
	
	prcDadosEmissaoNfe.call(EmpCod, &FilBasImp, &FilAmbEms)
	
	if &FilAmbEms <> TAmb.Producao
		Return
	Else
		&DescontoUnitarioGlobal = 0 
		if PedVlrDscGlb > 0 and &tmpNfeVlrBrtNotDesconto > 0 and not &PedTpcVlr > 0
			&DescontoUnitarioGlobal = (PedVlrDscGlb/&tmpNfeVlrBrtNotDesconto ) * 100
			&tmpNfeVlrBrtNot -= PedVlrDscGlb
		Endif

		if &TCon144_FreteBaseCalculoICMS = 'S' or &TCon144_FreteBaseCalculoICMS = 'A'
			&AuxPedVlrFrt = PedVlrFrt
			
			&valorGlobalFrete = 0 
			if &AuxPedVlrFrt > 0 and &tmpNfeVlrBrtNot > 0
				&valorGlobalFrete = &AuxPedVlrFrt/&tmpNfeVlrBrtNot
			Endif
		Endif
	
		&LctBasImpCod = LctBasImpCod
		&PedCliCidUfeCod = PedCliCidUfeCod
		&PedCliGruImpCod = PedCliGruImpCod
		
		&AuxImpostosTotal = 0				
		&TotalItem = 0
		&ImpostosTotal = 0
		
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where PedQtd > 0
			
			&CalculoFretePedItmCod += 1 //&TCon144_FreteBaseCalculoICMS
			
			&PedVlrUntComDsc = PedVlrUntComDsc
			&tmpPedVlrDsc = 0
			if &DescontoUnitarioGlobal > 0 and &PedVlrUntComDsc > 0 and not &PedTpcVlr > 0
				&tmpPedVlrDsc = round(((&PedVlrUntComDsc * &DescontoUnitarioGlobal) / 100), 5)
				&PedVlrUntComDsc -= &tmpPedVlrDsc
			Endif
		
			&tmpProVlrFrt = 0 //if &TCon144_FreteBaseCalculoICMS
			&tmpProBasVlrIcm = PedVlrItm-&tmpPedVlrDsc
			if &TCon144_FreteBaseCalculoICMS = 'S' or &TCon144_FreteBaseCalculoICMS = 'A' 
				do 'CalculaFrete'
			EndIf
		
			RetornaTotalImpostoDetalhado.Call(EmpCod, FilCod, PedCod, ProCod, &FilBasImp, &LctBasImpCod, &PedCliCidUfeCod, &PedCliGruImpCod, ProCatCod, &PedVlrUntComDsc, PedQtd, &tmpProVlrFrt, &PedTpcVlr, false, &ImpAlqIcmInt,&impIPI,&ImpAlqIcmExt,&tmpProVlrIcm,&tmpProVlrIpi,&tmpProVlrIcmSt,&tmpProVlrFCPIcmsSt,&tmpProVlrCOFINS,&tmpProVlrPIS,&IsImpostoCadastrado)
			
			if &IsImpostoCadastrado = false
				&IsErroTabelaImposto = true
				&impostoNaoCalculado = format('IMPOSTO DO PRODUTO: %1 NÃO CALCULADO, PODERA SOFRER ALTERAÇÕES ATÉ O FATURAMENTO', ProGraRef)
			Endif
			//&ImpAlqIcmInt % icms
			//&impIPI       % ipi
			//&ImpAlqIcmExt % st
			
			//&tmpProVlrIcm R$ icms
			If (&tmpProVlrIpi > 0 or &tmpProVlrIcmSt > 0 or &tmpProVlrFCPIcmsSt > 0 or &tmpProVlrPIS > 0 or &tmpProVlrCOFINS > 0) and PedQtd > 0
				//soma dos impostos
				&AuxImpostosTotal = (&tmpProVlrIpi + &tmpProVlrIcmSt+ &tmpProVlrFCPIcmsSt)
				
				//calculando unitario final
				&ImpostosTotal = ( &AuxImpostosTotal / PedQtd)
				
				//Totalizando Valor IPI
				&TottmpProVlrIpi+=&tmpProVlrIpi
				
				//Totalizando Valor ST
				&TottmpProVlrIcmSt+=(&tmpProVlrIcmSt+&tmpProVlrFCPIcmsSt)
				
				//Totalizando Valor Pis
				&tottmpProVlrPIS += &tmpProVlrPIS
				
				//Totalizando Valor Cofins
				&TottmpProVlrCOFINS+=&tmpProVlrCOFINS
				
				&TottmpProVlrIcm  += &tmpProVlrIcm
			EndIF
			
//			&ImpostosTotal += &PedVlrUntDsc
			
			&TotalAcrescimoMoeda = round(PedVlrItm * &AcrescimoPercentual, 2) / PedQtd		
			&TotaDescontoMoeda = round(PedVlrItm * &DescontoPercentual, 2) / PedQtd
			
			&ImpostosTotal += &TotalAcrescimoMoeda
			&ImpostosTotal -= &TotaDescontoMoeda
			
			&TotalItem =  PedVlrItm + &AuxImpostosTotal
			&TotalImpostosPedido += &AuxImpostosTotal
			//total com imposto na config T ########
			&TotalItemcomimposto = &ImpostosTotal * PedQtd
			
		EndFor
	Endif
EndFor

Sub 'CalculaFrete' //FRETE	&TCon144_FreteBaseCalculoICMS
	if &CalculoFretePedItmCod = &UltimoPedItmCod and &UltimoPedItmCod > 0
		&tmpProVlrFrt = &AuxPedVlrFrt - &AuxNfeProVlrFrt
	Else
		&tmpProVlrFrt =  round((&tmpProBasVlrIcm * &valorGlobalFrete), 2)
		&AuxNfeProVlrFrt += &tmpProVlrFrt
	Endif
EndSub
]]></Source>
