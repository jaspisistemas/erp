      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&FilEan13 = '000'

For &Item = &FicCod to 9999 step 1
	&AuxProBar = trim(&FilEan13) + padL(trim(str(&Item)), 4, '0')
	digitoEAN8.Call(&AuxProBar, &FicBar)
	
	VerificaCodigoUnicoFicha.Call(&EmpCod, &FicCod, &FicBar, &RepetidoEanMensagem) 
	if &RepetidoEanMensagem.IsEmpty()
		For Each Order EmpCod, FicCod
			Where EmpCod = &EmpCod
			Where FicCod = &FicCod
			FicBar = &FicBar
			Exit
		EndFor
	
		Commit
		
		Return
	EndiF
EndFor


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
