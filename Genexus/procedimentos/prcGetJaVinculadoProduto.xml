      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&JaVinculadoProRefNom.SetEmpty()

For Each Order EmpCod, ProCod
	where EmpCod = &EmpCod
	where ProForCod = &ProForCod
	Where ProForProCod = &ProForProCod
	
	if not &JaVinculadoProRefNom.IsEmpty()
		&JaVinculadoProRefNom += ', '
	EndIf
	&JaVinculadoProRefNom += ProRefNom
	
EndFor
]]></Source>
