      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, NfeCod, NfeDocRefCod
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	&sdtNotasReferenciadasItem = new()
	&sdtNotasReferenciadasItem.NfeDocRefCod = NfeDocRefCod
	&sdtNotasReferenciadasItem.NfeDocRefNfe = NfeDocRefNfe
	&sdtNotasReferenciadasItem.NfeDocRefUfe = NfeDocRefUfe
	&sdtNotasReferenciadasItem.NfeDocRefDta = NfeDocRefDta
	&sdtNotasReferenciadasItem.NfeDocRefCnpj = NfeDocRefCnpj
	&sdtNotasReferenciadasItem.NfeDocRefMod = NfeDocRefMod
	&sdtNotasReferenciadasItem.NfeDocRefInsEst = NfeDocRefInsEst
	&sdtNotasReferenciadasItem.NfeDocRefSer = NfeDocRefSer
	&sdtNotasReferenciadasItem.NfeDocRefNro = NfeDocRefNro
	&sdtNotasReferenciadasItem.NfeDocRefCte	= NfeDocRefCte	
	&sdtNotasReferenciadas.Add(&sdtNotasReferenciadasItem)
	
EndFor
]]></Source>
