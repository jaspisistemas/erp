      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAchou = False

For each Order EmpCod,RcbMovCod,RcbMovItm
	Where EmpCod = &EmpCod
	Where RcbCreCod = &CreCod
	Where RcbCrePagCod = &CrePagCod
	
	&RcbCod = RcbCod
	&IsAchou = True
	
	Exit
EndFor

For each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	
	&CreCliCod = CreCliCod
	&CreCliRaz = CreCliRaz
	&CreVlrDup = CreVlrDup
	&CreRecPag = CreRecPag
	&CreDupNro = CreDupNro
	&CrePagDta = CreDtaPrmPag
	
	For Each Order EmpCod, FilCod, CreCod, CrePagCod
		Where CrePagCod = &CrePagCod //when &CrePagCod.IsEmpty()
		
		&CreVlrDup = CrePagVlr
		&CrePagDta = CrePagDta
		Exit
	EndFor

	Exit
EndFor

////##################################### GRAVA RECIBO ###############################
For Each Order EmpCod, RcbCod
	Where EmpCod = &EmpCod
	Where RcbCod = &RcbCod
	
	RcbDstCod = &CreCliCod
	RcbDstNom = &CreCliRaz
	if RcbFilCod.IsNull() or RcbFilCod.IsEmpty()
		RcbFilCod = &FilCod
	Endif

	RcbVlr = &CreVlrDup
	RcbDoc = trim(&CreDupNro)
	RcbObs = 'PAGAMENTO DA DUPLICATA ' + trim(&CreDupNro) + ' DIA ' + &CrePagDta.ToFormattedString()
	
	Exit
When none
	
	UltimoCodigoEmpresa.Call(domParCod.RECIBO, &EmpCod, 0,&RcbCod)
	New	
		EmpCod = &EmpCod
		RcbCod = &RcbCod
		RcbDoc = trim(&CreDupNro)
		RcbTip = Iif(&CreRecPag = ReceberPagar.Receber,TipoRecibo.Receber,TipoRecibo.Pagar)
		
		RcbVlr = &CreVlrDup
		
		RcbDstCod = &CreCliCod
		RcbDstNom = &CreCliRaz
		RcbObs = 'PAGAMENTO DA DUPLICATA ' + trim(&CreDupNro) + ' DIA ' + &CrePagDta.ToFormattedString()
		
		
		RcbCreCod = &CreCod
		RcbFilCod = &FilCod
		RcbCrePagCod = &CrePagCod
		RcbDta = SerVerDate()
		RcbHor = ServerNow()
		RcbCodeVR = 1000 * Random()
	EndNew
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
