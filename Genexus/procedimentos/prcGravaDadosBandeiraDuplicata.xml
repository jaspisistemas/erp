      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

VerificaLancamentoZoopDupCancelada.Call(&EmpCod, &CreCarNroAut, &CreCarNroNsu)

For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	
	&oldCreCarNroAut = CreCarNroAut
	&BanCarCod = CreCarBanCod
	
	do 'GetBandeira'	

	CreCarArqc = &CreCarArqc
	CreCarBanCod = &CreCarBanCod
	CreCarNroAut = &CreCarNroAut
	CreCarNroNsu = &CreCarNroNsu
	CreCarBanNom = &CreCarBanNom
	CreCarCardNom = &CreCarCardNom
	CreCarTax = &CreCarTax
	Exit
EndFor

Commit

if not &oldCreCarNroAut.IsEmpty()  and &BanCarConfAut = 'J' and &oldCreCarNroAut <> &CreCarNroAut//BAIXA MAQUININHA JASPI
	do 'RemoveZoopPagamento'
EndIF

Sub 'GetBandeira'
	&BanCarConfAut.SetEmpty()
	For Each Order EmpCod, BanCod
		Where EmpCod = &EmpCod
		Where BanCarCod = &BanCarCod
		
		&BanCarConfAut = BanCarConfAut
		Exit
	EndFor
EndSub


Sub 'RemoveZoopPagamento'
	For Each Order EmpCod, FilCod, ZoopId
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ZoopCreCod = &CreCod
		
		ZoopCreCod = 0
		ZoopFilCod = 0
		ZoopJaspiSts = 'P'
		&ZoopObs = ZoopObs
		&zoopEvent = new()
		&zoopEvent.fee_details.Clear()
		&zoopEvent.history.Clear()
		&zoopEvent.FromJson(ZoopObs)
		commit
		prcGravaRegistroEntradaZoop.Call(&EmpCod, &FilCod, &zoopEvent, &ZoopObs)	
	EndFor	
	
	For Each Order EmpCod, FilCod, ZoopId, ZoopHisId
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ZoopHisCreCod = &CreCod
		
		ZoopHisCreCod = 0
		ZoopHisFilCod = 0
		ZoopHisOpe = 'P' //PENDENTE
		ZoopJaspiSts = 'P'
		&AuxZoopEvent = new()
		&AuxZoopEvent.fee_details.Clear()
		&AuxZoopEvent.history.Clear()
		&AuxZoopEvent.FromJson(ZoopHisObs)
		&ZoopHisObs = ZoopHisObs
		Commit
		prcGravaRegistroEntradaZoop_Recebimento.Call(&EmpCod, &FilCod, &AuxZoopEvent, &ZoopHisObs)
	EndFor

	
EndSub
]]></Source>
