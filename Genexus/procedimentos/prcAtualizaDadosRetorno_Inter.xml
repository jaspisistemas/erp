      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,CreCod
	Where EmpCod 	= &EmpCod
	Where CreCod 	= &CreCod
	
	CreDtaRet 		= ServerDate()
	CreCodBar 		= &SdtRecuperarCobranca_Inter.boleto.codigoBarras
	CreLinDig 		= &SdtRecuperarCobranca_Inter.boleto.linhaDigitavel
	CreQrCode 		= &SdtRecuperarCobranca_Inter.pix.pixCopiaECola
	CreTxId 		= &SdtRecuperarCobranca_Inter.pix.txid
	
	if CreSts = Status_Duplicata.ATIVO
		CreSts = Status_Duplicata.EM_REMESSA
	EndIf

	If &SdtRecuperarCobranca_Inter.boleto.nossoNumero.Trim().IsEmpty()
//		CreSts = Status_Duplicata.EM_REMESSA
	Else
		CreBloNro		= &SdtRecuperarCobranca_Inter.boleto.nossoNumero
	EndIf

	CreArqRetApiEco = &SdtRecuperarCobranca_Inter.ToJson()

	Exit
EndFor
Commit
]]></Source>
