      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&SdoAtu = 0 
&ConSdoFut = 0
For Each Order EmpCod, CreCarBanCod, CreFrpPgtoTip
	Where EmpCod = &EmpCod
	Where CreFilPgt in &CollFilCod
	Where CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
	Where CreSts <> Status_Duplicata.CANCELADA
	Where CreCarBanCod = &CreCarBanCod
	Where CreVlrSdo > 0
	if CreDtaVct <= &DataBase
		&SdoAtu += CreVlrSdo
	Else
		&ConSdoFut += CreVlrSdo
	EndIF
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
