      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&sdtVencimentosProdutos.FromJson(&WebSession.Get('wwMonitoraVencimentosImprimir'))

&titulo = 'PRODUTOS COM VENCIMENTOS PROXIMOS'

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = UPPER(&Title)
	print Cabecalho
End


if  &ComoImprimri = 'S'	
	&sdtVencimentosProdutos.Sort('Ordem') 
Else	
	&sdtVencimentosProdutos.Sort('Status') 
Endif

For &sdtVencimentosProdutosItem in &sdtVencimentosProdutos
	
	if &sdtVencimentosProdutosItem.ProSetCod <> &ProSetCod and &ComoImprimri = 'S'		
		if &ProSetCod <> 0
			eject
		Endif
	
		&ProSetCod = &sdtVencimentosProdutosItem.ProSetCod
		RetornaNomeSetor.Call(&EmpCod, &sdtVencimentosProdutosItem.ProSetCod, &SetNom)
		&ProSetCodNom = trim(str(&ProSetCod)) + ' - ' + &SetNom
		
		print Setor
		&Status = ''
	Endif
	
	if &Status <> &sdtVencimentosProdutosItem.Status
		&Status = &sdtVencimentosProdutosItem.Status
		&mensagem = &sdtVencimentosProdutosItem.Mensagem
		print Categoria
	Endif

	&ProRef = &sdtVencimentosProdutosItem.ProRef
	&ProNom = &sdtVencimentosProdutosItem.ProNom
	&VarQuantidade = &sdtVencimentosProdutosItem.ProVctQtd
	&ProVctDta = &sdtVencimentosProdutosItem.ProVctDta
	&VarEstoque = &sdtVencimentosProdutosItem.EstQtd
	
	print Produtos	
EndFor




Footer
//	print Rodape
End
]]></Source>
