      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon018_TranspPadraoCidade, &CfgVlr)
&TransportadoraCidade = &CfgVlr.Trim()
	
&PedTraRedCod = 0

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PEsCod
	
	if &SaiRed = 'R'
		if &TransportadoraCidade = 'S'
			&PedTraRedCod = PesCidTraCod
		EndIF
		
		If &PedTraRedCod.IsEmpty()
			&PedTraRedCod = PesCliTraCod
		EndIF
	Else
		if &TransportadoraCidade = 'S'
			&PedTraRedCod = PesCidTraCod
		EndIF
		
		If &PedTraRedCod.IsEmpty()
			&PedTraRedCod = PesCliTraSaiCod
		EndIF
	EndIF

	Exit
EndFor
]]></Source>
