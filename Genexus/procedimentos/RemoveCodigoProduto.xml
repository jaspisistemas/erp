      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, ProCod, ProGraCod, ProBarId
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where ProBarRef = &ProbarRef
	Where ProBarTip = 'A' or  ProBarTip = 'C' Or ProBarTip = 'O'  //SOMENTE AVULSOS/CAIXAS PODE SER DELETADOS PELO USUARIO
	
	delete
	Exit 
 EndFor

commit


RetornaMaisCodigosCompleto.Call(&EmpCod, &ProCod, &ProGraCod, &ProBarRef_Comp)
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	ProRef_Comp = &ProBarRef_Comp
	
	For Each Order EmpCod, ProCod, ProGraCod
		Where ProGraCod = &ProGraCod
		
		ProBarRef_Comp = &ProBarRef_Comp
		Exit		
	EndFor
	
	Exit
EndFor

Commit
]]></Source>
