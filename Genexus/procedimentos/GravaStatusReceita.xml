      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,RctCod,RctSts
	Where EmpCod = &EmpCod
	Where RctCod = &RctCod
	Where RctSts <> Status_Receituario.Transmitido
	
	&RctNfeCod = RctNfeCod	
	RctSts = &RctSts
	
	For Each Order EmpCod,RctCod,RctProCod
		&RctProCod = RctProCod
		Do 'AtualizaStatusNaNFe'
		
	EndFor
Endfor

Sub 'AtualizaStatusNaNFe'
	
	For Each Order EmpCod,NfeCod, NfeProCod
		Where EmpCod = &EmpCod
		Where NfeCod = &RctNfeCod
		Where NfeProCod = &RctProCod
		
		Do case
			Case &RctSts = Status_Receituario.Finalizado // receituario finalizado
				NfeProRctPen = Status_SimNao.Nao //Aatualiza a Nfe para nd Pendente
			Case &RctSts = Status_Receituario.Cancelado or &RctSts = Status_Receituario.Digitando
				NfeProRctPen = Status_SimNao.Sim //Atualiza a Nfe para (Pendente) novamente pois cancelou receituario
		EndCase
	EndFor
EndSub

		
]]></Source>
