      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[ConsultaRFB(&EmpCod,&PesCnpj,&PesRaz,&PesFan,&PesCep,&PesLog,&PesNro,&PesBai,&PesCidUfeCod,&PesCidCod
,&PesEml, &PesFonNum,&HttpClient)

if &PesCnpj.Length() > 14
	&PesTip = TipoPessoa.JURIDICA
	&PesCpf = ''
Else
	&PesTip = TipoPessoa.FISICA
	&PesCpf = &PesCnpj
endif

if &PesFan.IsEmpty()
	&PesFan = &PesRaz
endif

&PesCod = 0
UltimoCodigoEspecial.Call(domParCod.PESSOA, &EmpCod, 0, &PesCod)

do 'getRamoAtividade'
do 'getGrupoImposto'
New 
	EmpCod = &EmpCod
	PesCod = &PesCod
	PesRaz = &PesRaz
	PesRaz = PesRaz.Replace('&', 'E')
	PesFan = &PesFan
	PesFan = PesFan.Replace('&', 'E')
 	
	PesIsFor = false
	PesIsCli = false
	PesIsTra = false
	PesIsVen = False
	PesIsFun = false
	
	PesSts = Status_AtivoInativo.ATIVO
	
	Do Case
		Case &OqueFazer = 'CLI' or &OqueFazer = 'CON'
			PesIsCli = true
		Case &OqueFazer = 'FOR'
			PesIsFor = true
		Case &OqueFazer = 'FUN'
			PesIsFun = true
		Case &OqueFazer = 'VEN'
			PesIsVen = true
		Case &OqueFazer = 'TRA'
			PesIsTra = true
		Case &OqueFazer = 'MOT'
			PesIsMot = true
	EndCase

	PesCidCod  = &PesCidCod
	PesInsEst  = &PesInsEst 
	PesInsMun  = &PesInsMun
	PesCadPro  = &PesCadPro
	PesDtaNas  =  &PesDtaNas
	PesRg      = &PesRg
	PesCnpj    = &PesCnpj
	PesCpf     = &PesCpf
	PesTip     = &PesTip
	PesSuf 	   = &PesSuf
	PesVenAprz = Status_SimNao.Sim
	PesCliCrd  = &PesCliCrd
	
	//Endereço
	PesLog       = &PesLog
	PesNro       = &PesNro
	PesBai       = &PesBai
	PesCep       = &PesCep
	PesCpl       = &PesCpl
	PesProAtv    = 'N' 
	PesExtVenCod = 1
	OriCod       = OrigemCadastroPessoa.ORIGEM_INTERNA
	
	
	RatCod       = &RatCod
	PesGruImpCod = &PesGruImpCod
	
	PesVenAprz   = Status_SimNao.Sim
	
	PesEmpSecCod = &PesEmpCodSec
	PesDtaVctCer = &PesDtaVctCer
	PesEscCtbCod = &PesEscCtbCod
	PesObs       = &PesObs
	
	PesDscMax    = 100
	PesDtaCad    = serverdate()
	PesDtaAlt    = serverdate()
	PesDtaHorAlt = serverNow()
	PesAltFunCod = &PesAltFunCod
Endnew

commit

if not &PesEml.IsEmpty()
	New
		EmpCod    = &EmpCod
		PesCod    = &PesCod
		PesEmlCod = 1
		PesEml    = &PesEml
		PesEmlFin = true
		PesEmlPed = true
		PesEmlFat = true
	EndNew
endif

if not &PesFonNum.IsEmpty()
	New
		EmpCod    = &EmpCod
		PesCod    = &PesCod
		PesFonCod = 1
		PesFonTpo = TipoTelefone.OUTROS
		PesFonNum = &PesFonNum
		PesFonOpe = OperadoraFone.OUTRA
	EndNew
endif

Commit

AtualizaEnderecoCliente.Call( &EmpCod, &PesCod)

sub 'getRamoAtividade'
	For Each Order EmpCod, RatCod
		where EmpCod = &EmpCod
		&RatCod = RatCod
		Exit
	EndFor
	
EndSub

sub 'getGrupoImposto'
	For Each Order EmpCod, GruImpCod
		Where EmpCod = &EmpCod
		Where GruImpSts = Status_AtivoInativo.ATIVO
		&PesGruImpCod = GruImpCod
		Exit
	endFor

EndSub

	
