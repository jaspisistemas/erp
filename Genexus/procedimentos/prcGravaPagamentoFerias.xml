      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&FPagCod = &parFPagCod

For Each Order EmpCod, PesCod, PesRecCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	where PesRecCod= &PesRecCod
	if &FerAnoBas = year(serverdate())
		&FPagMes = month(serverdate())
	Else
		&FPagMes = month(PesDtaAdm) //grava mes da admissao como mes base pagamento ferias.
	Endif

	Exit
EndFor


prcGravaPagamentoFolha.Call(&EmpCod, &FPagCod, TipoPagamentoFolha.Ferias, &PesCod, &FerAnoBas, &FPagMes, false, &FPagCod)
prcGravaPagamentoFolhaItem.call(&EmpCod, &FPagCod, &sdtItensFolha, &sdtPagamentosFolhaContas, &sdtPagamentoFolhaAdiantamentos)

//AtualizaStatus
For Each Order EmpCod, FPagCod
	Where EmpCod = &EmpCod
	Where FPagPesCod = &PesCod
	Where FPagAno = &FerAnoBas
	Where FPagTip= TipoPagamentoFolha.Ferias
		
	For Each Order EmpCod, FPagCod,FPagLcfCod		
		Do CAse
			CAse FPagLcfCod = 16 and FPagItemVlr > 0
				&IsTemPagamentoTerco = true
			Case FPagLcfCod = 16 and FPagItemVlr = 0
				&isJaPagoFerias = true 
		EndCAse
		
		Do CAse
			CAse FPagLcfCod = 15 and FPagItemCpl = 'INTEGRALMENTE'
				&IsTemPagamentoFeriasIntegralmente = true
			Case FPagLcfCod = 15 and FPagItemCpl = 'PARCIALMENTE'
				&IsTemPagamentoFeriasParcialmente = true
			Case FPagLcfCod = 15 and FPagItemCpl = 'OUTRO PERIODO'
				&IsTemPagamentoFeriasOutroPeriodo = true
		EndCAse
	EndFor
Endfor

	
For Each Order EmpCod, PesCod, PesRecCod, FerAnoBas
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	where PesRecCod= &PesRecCod
	where FerAnoBas = &FerAnoBas
	
	Do CAse
		CAse &IsTemPagamentoFeriasOutroPeriodo = true
			FerPgto = 'O' //ja pago as ferias
		CAse &IsTemPagamentoFeriasIntegralmente = true
			FerPgto = 'B' //Pagamento Integralmente
		CAse &IsTemPagamentoFeriasParcialmente = true
			FerPgto = 'A' //Pagamento parcialmente
		Otherwise
			FerPgto = 'P' //PENDENTE
	EndCase

	Do CAse
		Case &isJaPagoFerias = true 
			FerPgtoTer = 'O' //ja pago as ferias
		CAse &IsTemPagamentoTerco = true 
			FerPgtoTer = 'B' //Pago Integralmente
		Otherwise
			FerPgtoTer = 'P' //PENDENte
	EndCAse

	Exit
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
