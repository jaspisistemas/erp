      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[



For Each Order EmpCod, WaAnoMes
	Where EmpCod = &EmpCod
	Where WaAnoMes = &WaAnoMes
	
	&EmpQtdWhatsMsg = EmpQtdWhatsMsg + WaAnoMesQtdExt + EmpQtdWhatsMsg0800
	&WaAnoMesQtd = WaAnoMesQtd
	
	Exit
When None
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		&EmpQtdWhatsMsg = EmpQtdWhatsMsg + EmpQtdWhatsMsg0800
		Exit
	EndFor

	&WaAnoMesQtd = 0
	If not &EmpQtdWhatsMsg.IsEmpty()
		&Ano = str(year(serverdate()))
		&Ano = &Ano.Trim()
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '01'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '02'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '03'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '04'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '05'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '06'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '07'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '08'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '09'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '10'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '11'
			WaAnoMesQtd = 0
		EndNEw
		
		new
			EmpCod = &EmpCod
			WaAnoMes = &Ano + '12'
			WaAnoMesQtd = 0
		EndNEw
	
		Commit
	Endif

EndFor
]]></Source>
