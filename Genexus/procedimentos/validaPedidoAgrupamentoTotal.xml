      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErroPedido = true
&Mensagem = ''

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	Do Case
		Case PedCliCod <> &AgrpVlrPedCliCod and &AgrpVlrPedCliCod <> 0
			&Mensagem = 'Pedido ' + trim(str(PedCod)) + '. É preciso ter mesmo Cliente/Fornecedor para Agrupar pedidos!'
			
		Case PedStsFin <> Status_Financeiro.ABERTO or PedStsFinIsPar = true
			&Mensagem = 'Pedido ' + trim(str(PedCod)) + ' está com Financeiro diferente de Aberto!'
			
		Case PedVlrLiq.IsEmpty()
			&Mensagem = 'Pedido ' + trim(str(PedCod)) + ' com valor Líquido Zerado!'
			
		Case not PedVlrAgr.IsEmpty()
			&Mensagem = 'Pedido ' + trim(str(PedCod)) + ' já passou por um Agrupamento de Valores, não é possível agrupá-lo em outro pedido!'
			
		Case PedSts = Status_Pedido.CANCELADO or PedStsFin = Status_Financeiro.CANCELADO
			&Mensagem = 'Pedido ' + trim(str(PedCod)) + ' com Status Cancelado, não podem ser Agrupado!'
			
		Case LctGerFin <> Status_SimNao.Sim and &OqueFazer = 'A' //SOMENTE VALORES
			&Mensagem = 'Pedido ' + trim(str(PedCod)) + ' não Gera Financeiro, não é possível agrupar Valor!'
			
		CAse LctTip <> &AgrpLctTip and not &AgrpLctTip.IsEmpty()
			&Mensagem = 'Pedidos Precisam ter Mesmo tipo de Lançamento, Pedidos de Compras, Pedidos de Venda, ...'
			
		case PedSts <> Status_pedido.Aberto and &OqueFazer = 'B' //AGRUPAMENTO COMPLETO
			&Mensagem = 'Para Agrupamento Total, Pedidos devem estar com Estoque e Financeiro ABERTO'
			
		Otherwise
			&IsErroPedido = false
	EndCase
	
	Exit
When none
	&Mensagem = 'Pedido ' + trim(str(&PedCod)) + ' Não Localizado!'
	
EndFor

]]></Source>
