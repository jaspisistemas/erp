      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//&B_Curva = &B_Curva + &A_Curva

For Each Order EmpCod, CrvCod //CurvaABC ( EmpCod,  CrvCod )
	Where EmpCod = &EmpCod
//	Where CrvCod <> &CrvCod
	
	For Each Order EmpCod, CrvCod, CrvProCod //CurvaABCproduto ( EmpCod,  CrvCod )
		delete
	EndFor
	
	delete
When none
	New
		EmpCod = &EmpCod
		CrvCod = &CrvCod
	EndNew
EndFor

Commit

//contagem 

For Each Order EmpCod, ProCod, ProGraRef //PRODUTO GRADE
	Where EmpCod = &EmpCod
	Where GrupCod in &ColGrupCod when &GrupHie <> ''
	Where ProPadForCod = &ProPadForCod When &ProPadForCod <> 0
	Where ProSts = Status_Produto.ATIVO or &IncluirProdutosInativos = Status_SimNao.Sim
	where ProSts <> Status_Produto.EXCLUIDO when &IncluirProdutosInativos = Status_SimNao.Nao
	&PercentualTotal +=1
EndFor

// Inicio

&Percentual = 0
&ProgressIni = serverNow()
&PerCount = 0
do 'Atualiza'

&ValorTotalVenda = 0
&ValorTotalCusto = 0

if not &GrupHie.IsEmpty()
	retornaCollGrupoProduto.Call(&EmpCod, &GrupHie, &ColGrupCod)
EndIF

For Each 
	Order EmpCod, ProCod, ProGraRef //PRODUTO GRADE
	
	Where EmpCod = &EmpCod
	Where GrupCod in &ColGrupCod when &GrupHie <> ''
	Where ProPadForCod = &ProPadForCod When &ProPadForCod <> 0
	Where ProSts = Status_Produto.ATIVO or &IncluirProdutosInativos = Status_SimNao.Sim
	where ProSts <> Status_Produto.EXCLUIDO when &IncluirProdutosInativos = Status_SimNao.Nao
	
	&CrvPedQtd = 0
	&CrvPedQtdCan = 0
	&CrvVlrTotItm = 0
	&CrvVlrTotCus = 0
	&IsOk = false
	&CrvEstLoc.SetEmpty()
	&CrvEstQtd = 0
	
	For Each Order EmpCod, FilCod, PedSts, LctAtuEst, PedDtaFat, ProCod, ProGraCod  //PEDIDO
		Where FilCod = &FilCod
		where PedSts = Status_Pedido.FECHADO
		Where LctAtuEst = Status_EntradaSaida.Saida
		where LctAtuSal = Status_EntradaSaida.Saida
		Where PedDtaFat >= &iniPedDtaFat and PedDtaFat <= &finPedDtaFat
		Where PedQtd > 0
		Where LctGerFin = Status_SimNao.Sim or &IncluirPedidosSemFinanceiro = Status_SimNao.Sim
		Where PedCliEntUfeCod = &RecUfeCod when not &RecUfeCod.IsEmpty()
		//Where PedCidCod = &CidCod or &CidCod = 0 
		//Where PedCliUdfeCod = &UfeCod or &UfeCod = ''
		
		&IsOk = true
		&CrvPedQtd += PedQtd
		&CrvPedQtdCan += PedQtdCan
		&CrvVlrTotItm += PedVlrItm
		&CrvVlrTotCus += PedVlrItmCus
	EndFor

	For Each Order EmpCod, FilCod, ProCod, ProGraCod //estoque
		Where FilCod = &FilCod
		
		&CrvEstLoc = EstLoc
		&CrvEstQtd = EstQtd
		
        If EstQtd > 0
			&IsOk = true
		EndIF
	
		If &AtualizarCurvaCadastro = Status_SimNao.Sim	
			if &CalcularListarTipoCurva = 'R' 
				EstABC_Ren = 'D'
			Else
				EstABC_Qtd = 'D'
			EndIf
		EndIF
    EndFor
	
	&X +=1
	If &X = 250
		&PerCount += 249
		&X=0
		Do 'Percentual'
	EndIf
	
	If &IsOk = true
		For Each Order EmpCod, CrvCod, CrvProCod
			Where CrvCod = &CrvCod
			Where CrvProCod = ProCod
			
			CrvPedQtd += &CrvPedQtd
			CrvPedQtdCan += &CrvPedQtdCan
			CrvVlrTotItm += &CrvVlrTotItm
			CrvVlrTotCus += &CrvVlrTotCus
			CrvVlrTotRen = CrvVlrTotItm - CrvVlrTotCus
	    when none
	        New
				EmpCod = EmpCod
				CrvCod = &CrvCod
				CrvProCod = ProCod
				CrvProRef = ProRef
				CrvProNom = ProNom.Trim()
				CrvEstLoc = &CrvEstLoc
				CrvPedQtd = &CrvPedQtd
				CrvEstQtd = &CrvEstQtd
				CrvPedQtdCan = &CrvPedQtdCan
				CrvVlrTotItm = &CrvVlrTotItm
				CrvVlrTotCus = &CrvVlrTotCus
				CrvVlrTotRen = &CrvVlrTotItm - &CrvVlrTotCus
			EndNew
		EndFor
	EndIF
EndFor

Commit


&PerCount += &X
Do 'Percentual'

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor

	commit
EndSub

sub 'Percentual'
	&PerCount += 1
	If &PerCount > 0
		&Percentual = round((&PerCount / &PercentualTotal) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
EndSub

]]></Source>
