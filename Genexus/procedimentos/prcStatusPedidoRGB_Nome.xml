      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&R = 0
&G = 0
&B = 0

For Each Order EmpCod, StsNom
	Where EmpCod = &EmpCod
	Where StsCod = &StsCod
	
	&StsNom = StsNom
	if (not StsHex.IsEmpty()) and (Not StsHex.IsNull())
		&R = StsR
		&G = StsG
		&B = StsB
	Else
		do 'getCor'
		StsHex = &StsHex
		StsR = &R
		StsG = &G
		StsB = &B
		
		Commit
	EndIF
EndFor

sub 'getCor'
	Do Case
		Case &StsNom = 'CANCELADO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'DESPACHADO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'FATURADO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'SEPARAÇÃO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'DIGITAÇÃO'
			&StsHex = 'FF7700'
			&R = 255
			&G = 119
			&B = 0
			
		Case &StsNom = 'ORÇAMENTO'
			&StsHex = 'FF3300'
			&R = 255
			&G = 51
			&B = 0
			
		Case &StsNom = 'AUTORIZ.'	
			&StsHex = '000DFF'
			&R = 0
			&G = 13
			&B = 255
			
		Case &StsNom = 'NÃO.AUTOR.'
			&StsHex = 'FF3300'
			&R = 255
			&G = 51
			&B = 0
			
		Case &StsNom = 'ANALISADO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'ANALISE'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'ABERTO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'PRODUZIDO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		Case &StsNom = 'PRODUZINDO'
			&StsHex = '000000'
			&R = 0
			&G = 0
			&B = 0
			
		CAse &StsNom = 'MARKETPLACE' or &StsNom = 'SMART.ANALISE'
			&StsHex = '9900CC'
			&R = 153
			&G = 0
			&B = 204
			
	EndCAse
EndSub
]]></Source>
