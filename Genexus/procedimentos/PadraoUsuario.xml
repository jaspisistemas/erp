      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//LER AS CONFIGURACOES
if &OqueFazer =  'L' 
	
	&PadObs = ''
    For Each Order PadRotLin, PadPesCod, PadEmpCod
	    Where PadRotLin = &PadRotLin
	    Where PadPesCod = &PadPesCod
		Where PadEmpCod = &PadEmpCod
        &PadObs = PadObs
		&PadDtaMod = PadDtaMod
		Exit
    EndFor
else
    For Each Order PadRotLin, PadPesCod, PadEmpCod
	    Where PadRotLin = &PadRotLin
	    Where PadPesCod = &PadPesCod
		Where PadEmpCod = &PadEmpCod
        PadObs = &PadObs
		PadDtaMod = serverdate()
		PadDtaHorMod = ServerDate()
    when none
        new
            PadRotLin = &PadRotLin
            PadPesCod = &PadPesCod
			PadEmpCod = &PadEmpCod
            PadObs = &PadObs
			PadDtaMod = serverdate()
			PadDtaHorMod = ServerDate()
        EndNew    
    EndFor

	commit
EndIf
]]></Source>
