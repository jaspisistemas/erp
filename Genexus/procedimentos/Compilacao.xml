      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Compilacao = 627
&IsExecutaUpdate = false
&outEmpCmp = &Compilacao

if &IsBD = true
	For Each Order EmpCod
		
		&EmpVer = EmpVer		
		&EmpCmp = EmpCmp
		
		If EmpCmp.IsEmpty() or EmpCmp.IsNull() or EmpCmp < &Compilacao
			&IsExecutaUpdate = true
		EndIf
	
		Exit
	EndFor
Else
	&EmpCmp = &Compilacao
	&EmpCmp = &EmpCmp - 387
	&EmpVer = '2.2.'+trim(str(&EmpCmp))
Endif


]]></Source>
