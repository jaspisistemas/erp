      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&HojeData = ServerDate()
&IsExecutou = false

&sdtAgendadorFiltros.FromXml(&AgdFiltro)
For &sdtAgendadorFiltrosItem in &sdtAgendadorFiltros
	//--NOTAS PROPRIAS
	Do Case
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SINTENVDIAS'
			&Dias = val(&sdtAgendadorFiltrosItem.AgdValue)
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SINDUPTIP'
			&TipoArquivo = &sdtAgendadorFiltrosItem.AgdValue.Trim()
			
			//PROPRIA
			//		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_FILPROP'
			//			&FiltrarProprias = &sdtAgendadorFiltrosItem.AgdValue
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_AUTOR'
			if &sdtAgendadorFiltrosItem.AgdValue = 'S' or &sdtAgendadorFiltrosItem.AgdValue = ''
				&SomenteNotasAutorizadas = Status_SimNao.Sim
			Else
				&SomenteNotasAutorizadas = Status_SimNao.Nao
			Endif
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_PDF_CTE'
			if &sdtAgendadorFiltrosItem.AgdValue = 'N' or &sdtAgendadorFiltrosItem.AgdValue = ''
				&EnviaPdfCte = Status_SimNao.Nao
			Else
				&EnviaPdfCte = Status_SimNao.Sim
			Endif
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_PDF_NFE'
			if &sdtAgendadorFiltrosItem.AgdValue = 'N' or &sdtAgendadorFiltrosItem.AgdValue = ''
				&EnviaPdfNota = Status_SimNao.Nao
			Else
				&EnviaPdfNota = Status_SimNao.Sim
			Endif
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_PRODUTOS_PERIODO'
			if &sdtAgendadorFiltrosItem.AgdValue = '0' or &sdtAgendadorFiltrosItem.AgdValue = ''
				&EnviaRelatorioProdutos = False
			Else
				&EnviaRelatorioProdutos = true
			Endif		
			
		case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_NFTERCEIROS'
			//TERCEIROS
			&EnviarNotasTerceiros.FromString(&sdtAgendadorFiltrosItem.AgdValue)
			
			//		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SIN_FILTER'
			//			&FiltrarTerceiros = &sdtAgendadorFiltrosItem.AgdValue
			
			//		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'PERFILSPED'
			//			&PerFil = &sdtAgendadorFiltrosItem.AgdValue
			
			//&RegistroInventario, &FinalidadeGeracao, &Perfil
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_TIPONFTERCEIRO'
			&TipoNotaTerceiros.FromString(&sdtAgendadorFiltrosItem.AgdValue)
							
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_INVENT'
			&RegistroInventario = &sdtAgendadorFiltrosItem.AgdValue
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_FINA'	
			&FinalidadeGeracao = &sdtAgendadorFiltrosItem.AgdValue
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_PERFIL'
			&Perfil = &sdtAgendadorFiltrosItem.AgdValue
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_CONTABIPI'
			&ContabilizarIPIemOutroValores = &sdtAgendadorFiltrosItem.AgdValue
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_PISCOFINS'
			&NaoDestacarPISCOFINS = &sdtAgendadorFiltrosItem.AgdValue
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_APURACAO'
			&tipoApuracao = &sdtAgendadorFiltrosItem.AgdValue
			if &TipoApuracaoICMS.IsEmpty()
				&TipoApuracaoICMS = &tipoApuracao
			Endif
		
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'SPD_APURACAOICMS'
			&TipoApuracaoICMS = &sdtAgendadorFiltrosItem.AgdValue
	EndCase
EndFor

//&PerFil = 'A' //PERFIL A

&Ano = Year(&HojeData)
&Mes = Month(&HojeData)
&DataLimite = yMDtoD(&Ano, &Mes, 1)
&DataLimite = &DataLimite.AddDays(&Dias)

&iniNfeDtaEms = yMDtoD(&Ano, &Mes, 1)
&iniNfeDtaEms = &iniNfeDtaEms.AddMonths(-1)
&finNfeDtaEms = EOM(&iniNfeDtaEms)
	
&PropriaTerceiros = 'P'
If &EnviarNotasTerceiros = 'S'
	&PropriaTerceiros.SetEmpty()
EndIF

if &SomenteNotasAutorizadas.IsEmpty()
	&SomenteNotasAutorizadas = Status_SimNao.Sim
EndIF

msg( &AgdUltDta.ToFormattedString() + ' < ' + &DataLimite.ToFormattedString() + ' and '  + &DataLimite.ToFormattedString() + ' < ' + &HojeData.ToFormattedString(), status)

if &AgdUltDta < &DataLimite and &DataLimite < &HojeData		
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &AgdExeFilCod 
		Where not FilCtaEml.IsEmpty() and not FilCtaEml.IsNull()
		
		&FilCod = FilCod
		&FilCtaEml = FilCtaEml
		
		&FilTip = FilTip
		do 'EnviaArquivo'
		
	EndFor
EndIf

Sub 'EnviaArquivo'
		
	if &TipoArquivo = 'N' //SPED
		AtualizaDataFaturadoNotas.Call(&EmpCod, &FilCod, &iniNfeDtaEms, &FinNfeDtaEms)
		
		&ProgressId = 'Sped' + trim(Str(&EmpCod)) + trim(Str(&FilCod)) + 'Agendador'
		
		RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
		
		&random = random() * 100000
		&NomeFinalArquivo = trim(str(&random))
		&NomeFinalArquivo = RetornaSoNumeros.udp(&NomeFinalArquivo)
		
		&NomeArquivo = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim()
		&NomeArquivo += trim(str(&Ano)) + trim(str(&Mes)) + '_EFD_ICMS-IPI_'+ &NomeFinalArquivo.Trim() + '.txt'
		
		&NomeArquivo1 = ''
		if &FilTip <> 'F' //FILIAL NAO ENVIA O EFD_PIS-COF
			&NomeArquivo1 = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim()
			&NomeArquivo1 += trim(str(&Ano)) + trim(str(&Mes)) + '_EFD_PIS-COF_'+ &NomeFinalArquivo.Trim() + '.txt'
		Endif
	
		&sdtEnviaSped = new()
		&sdtEnviaSped.ArquivoIcmsIpi = &NomeArquivo
		&sdtEnviaSped.ArquivoPisCofins =  &NomeArquivo1
		&sdtEnviaSped.IniNfeDtaFat = &iniNfeDtaEms
		&sdtEnviaSped.FinNfeDtaFat = &FinNfeDtaEms
		&sdtEnviaSped.PesEml = &FilCtaEml
		&sdtEnviaSped.PesCod = -1
		&sdtEnviaSped.PesRaz = 'JASPI SISTEMAS'
		
		&sdtEnviaSped.EnviarPdfCte = &enviaPdfCte
		&sdtEnviaSped.EnviarPdfNota = &EnviaPdfNota
		&sdtEnviaSped.RegistroInventario = &RegistroInventario
		&sdtEnviaSped.FinalidadeGeracao = &FinalidadeGeracao 
		&sdtEnviaSped.PerFil = &Perfil
		&sdtEnviaSped.TipoNota = &PropriaTerceiros
		&sdtEnviaSped.TipoApuracao = &TipoApuracao
		&sdtEnviaSped.TipoApuracaoICMS = &TipoApuracaoICMS
		&sdtEnviaSped.TipoNotaTerceiros = &TipoNotaTerceiros
		&sdtEnviaSped.ContabilizarIpiOutrosValores = &ContabilizarIPIemOutroValores
		&sdtEnviaSped.NaoDestacarPisCofins = &NaoDestacarPISCOFINS
		
		EnviaSped_Web.Call(&ProgressId, &EmpCod, &FilCod, &sdtConfiguracoesPasta, &sdtEnviaSped, &IsExecutou)
	Else
		&ProgressId = 'Sintegra' + trim(Str(&EmpCod)) + trim(Str(&FilCod)) + 'Agendador'
		
		RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
		
		&NomeFinalArquivo = serverTime()
		&NomeFinalArquivo = RetornaSoNumeros.udp(&NomeFinalArquivo)
		
		EnviaSintegra_Web.Call(&ProgressId, &EmpCod, &FilCod, &sdtConfiguracoesPasta, &iniNfeDtaEms, &finNfeDtaEms, Status_SimNao.Nao, Status_SimNao.Sim, '1', &SomenteNotasAutorizadas, &PropriaTerceiros, &NomeFinalArquivo,&FilCtaEml, -1,'', &IsExecutou,&EnviaPdfCte,&EnviaPdfNota, &EnviaRelatorioProdutos)
	Endif
	
EndSub
]]></Source>
