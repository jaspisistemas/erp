      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)
&ArquivoVirtual = &SdtConfiguracoesPasta.PastaDiretorioCobVir+ 'CADTXT.txt'
&nomArq = &SdtConfiguracoesPasta.PastaDiretorioCobFis+ 'CADTXT.txt'

&File.Source = &NomArq
If  &File.Exists()
	&File.Delete()
Endif
&File.Close()


For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilTabCod = FilTabCod 
	Exit
EndFor


&ResultadoAbertura = DfwOpen(&NomArq,'','', 0, 'ISO-8859-1') 
For Each Order EmpCod, BlcCod, BlcItmCod
	Where EmpCod = &EmpCod
	Where BlcCod = &BlcCod
	
	&BlcProCod = BlcProCod
	&BlcProGraCod = BlcProGraCod
	do 'GetProduto'
	
	if not &ProGraRef.IsEmpty() and not &TabPrc1.IsEmpty()
		&Varchar = PADL(trim(STR(&TabPrc1 * 100)), 7,'0')
		
		if BlcPesUnit = 'U'
			&DadosArquivo = padL(&ProGraRef, 6, '0') +'U'+ padR(Substr(&ProNomGra, 1, 22), 22, ' ') + PADL(&Varchar, 7, '0')
		Else
			&DadosArquivo = padL(&ProGraRef, 6, '0') +'P'+ padR(Substr(&ProNomGra, 1, 22), 22, ' ') + PADL(&Varchar, 7, '0')
		Endif
	
		&Varchar = padL(trim(str(BlcQtdVal)), 3, '0')
		&DadosArquivo += &Varchar
		
		&ResultadoNext=  dfwptxt(&DadosArquivo) // Grava Linha 
		&ResultadoNext = dfwnext()
	Endif

EndFor
&ResultadoAbertura = dfwclose()


sub 'GetProduto'
	&ProGraRef.SetEmpty()
	&ProNomGra.SetEmpty()
	&TabPrc1.SetEmpty()
	
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &BlcProCod
		Where ProGraCod = &BlcProGraCod
		
		&ProGraRef = retornaSonumeros.Udp(ProGraRef)
		&ProNomGra = ProNomGra
		
		Exit
	EndFor

	For Each ORder EmpCod, TabCod, TabAltCod
		Where EmpCod = &EmpCod
		Where TabCod = &FilTabCod
		Where TabAltCod = TabUltAlt
		
		Where ProCod = &BlcProCod
		Where ProGraCod = &BlcProGraCod
		
		&TabPrc1 = TabPrc1
		
		Exit
	EndFor

EndSub
]]></Source>
