      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ProgressLogXml = ''
&Percentual = 0
&ProgressIni = serverNow()
&PerCount = 0
&PercentualTotal = 10000

do 'Atualiza'


For Each Order IpPro 
	where IpPro = &ProgressId 
	Where IpIsAchou = true
	
	&ProCod = IpProCod
	do 'GravarProduto'


	&AuxCount += 1
	if &AuxCount > 50
		&PerCount += &AuxCount
		Do 'Percentual'
		&AuxCount = 0
	Endif

EndFor

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'
	
sub 'Percentual'
	&PerCount += 1
	If &PerCount > 0
		&Percentual = round((&PerCount / &PercentualTotal) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
EndSub


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &ProgressLogXml 
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &ProgressLogXml 
		Endnew
	endfor

	commit
EndSub

Sub 'GravarProduto'
	
	&Exist = false
	For Each order EmpCod,CtlCod,ProCod
		Where EmpCod = &EmpCod
		Where CtlCod = &CtlCod
		Where ProCod = &ProCod
		&Exist = true
	EndFor
	If not &Exist
		&CatalogoProduto = new()
		&CatalogoProduto.EmpCod = &EmpCod
		&CatalogoProduto.CtlCod = &CtlCod
		&CatalogoProduto.ProCod = &ProCod
		&CatalogoProduto.Save()
		If not &CatalogoProduto.Success()
			&Success = false
		EndIf
	EndIf
EndSub
]]></Source>
