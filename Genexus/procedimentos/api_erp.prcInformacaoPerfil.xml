      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&TipoPerfil = 0
&auxPesExtCod = val(&PesExtCod)

if &auxPesExtCod > 0
	For each order PesExtCod, EmpCod, PesCod   //Pessoa
		Where PesExtCod = &auxPesExtCod
		&TipoPerfil = 1
		&sdtAuth.TipoPerfil = 1
		&sdtAuth.PesCod = PesCod
		&sdtAuth.PesRaz = PesRaz
		Exit
	EndFor
	
	If &TipoPerfil = 0
		For each order CrtCod 
			Where CrtExtId = &auxPesExtCod
			&TipoPerfil = 2
			&sdtAuth.TipoPerfil = 2
			&sdtAuth.PesCod = CrtCod
			&sdtAuth.PesRaz = CrtRaz
			exit
		EndFor
	EndIf
	
	If &TipoPerfil = 0
		For each order SupCod
			Where SupExtID = &auxPesExtCod
			&TipoPerfil = 3
			&sdtAuth.TipoPerfil = 3
			&sdtAuth.PesCod = SupCod
			&sdtAuth.PesRaz = SupNom
			exit
		EndFor
	EndIf
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
