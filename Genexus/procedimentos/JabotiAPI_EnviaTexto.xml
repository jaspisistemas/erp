      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[do case
	case &numero.IsEmpty()
		&UserMessage = criaUserMessageError('Informe um número de telefone','')
		
	case &texto.IsEmpty()
		&UserMessage = criaUserMessageError('Informe um texto','')
		
	otherwise
		&sdtJabotiPost = new()
		&sdtJabotiPost.to = &numero
		&sdtJabotiPost.type = 'text'
		&sdtJabotiPost.text.body = &texto
		
		JabotiAPIPostMessage(&EmpCod, &LogGUID, &sdtJabotiPost, &sdtJabotiResponse)
		
		if &sdtJabotiResponse.error.code.IsEmpty()
			&UserMessage = criaUserMessageSucesso('','')
		else
			&UserMessage = criaUserMessageError('#'+trim(&sdtJabotiResponse.error.code.ToString()),&sdtJabotiResponse.error.message)
		endif
endcase
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
