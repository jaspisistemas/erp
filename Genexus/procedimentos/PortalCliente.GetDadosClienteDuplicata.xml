      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	For Each Order EmpCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CreCod = &CreCod
		
		&sdtConfiguracoesPasta = RetornaConfiguracoesPastas.Udp(EmpCod, FilCod)
		
		&SdtGerarBoleto.Clear()
		&SdtGerarBoletoItem.CreEmpCod = EmpCod
		&SdtGerarBoletoItem.creFilCod = FilCod
		&SdtGerarBoletoItem.CreCod = CreCod
		&SdtGerarBoleto.Add(&SdtGerarBoletoItem)
		
		gerarBoleto.Call(&SdtGerarBoleto, false, &IsErro, &ImprimeSdtBoleto)
		
		&Random = Random() * 100000
		
		if &IsErro = false
			
			&DiretorioFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'Boleto' + trim(str(CreCod)) +'_'+ trim(str(&Random))+ '.pdf'
			&DiretorioVirtual = &sdtConfiguracoesPasta.PastaDiretoriotempVir.Trim() + 'Boleto' + trim(str(CreCod)) +'_'+ trim(str(&Random))+ '.pdf'
			&File.Source = &DiretorioFisico
			if &File.Exists()
				&File.Delete()
			EndIf
			
			RELJAS045_toFile.Call(EmpCod, FilCod, &ImprimeSdtBoleto, &DiretorioFisico)
			&isOk = true
		Else
			msg('Não foi possível gerar boleto, entre em contato com suporte! ')
		EndIF
		
		Exit
	EndFor
]]></Source>
