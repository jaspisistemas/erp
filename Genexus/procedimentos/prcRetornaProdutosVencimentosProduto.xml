<Object parentGuid="52144c8b-486d-4427-adc7-53be191a5137" user="WIN-JEAN\jean.fae" versionDate="2022-09-21T19:08:54.0000000Z" lastUpdate="2022-09-20T14:03:16.0000000Z" checksum="a401f1aa3e33a128f02ad75fb8f0d9b6" fullyQualifiedName="prcRetornaProdutosVencimentosProduto" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="56bbbb07-cfd7-4a10-b0f1-31cd4eda980e" name="prcRetornaProdutosVencimentosProduto" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Retorna Produtos Vencimentos Produto" parent="PrcVencimentos" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ProVctDta = &DataBase.AddDays(&DiasAFiltro)

For Each Order EmpCod, FilCod, ProVctDta	
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod //FILIAL
	Where ProSts = Status_Produto.ATIVO //ATIVOS
	Where EstQtd > 0 //PRODUTOS COM ESTOQUE
	Where (ProVctDta >= &DataBase or ProVctSts <> 'N') and ProVctDta < &ProVctDta //DENTRO DO PRAZO FILTRADO
	Where ProRef = &ProRef when not &ProRef.IsEmpty()
	Where ProNom like &ProRefNom when not &ProRefNom.IsEmpty()
	
	&Mensagem.SetEmpty()
	&IsOk = false
	
	if ProVctDta > &DataBase
		//if &Filtrar = 'B' //PRODUTOS ACIMA DO ESTOQUE VENCER NOS PROXIMOS X dias:B
		&Dias = ProVctDta-&DataBase //vai vencer em x dias.
		
		If ProPadForCod <> &AuxProPadForCod
			&AuxProPadForCod = ProPadForCod
			&PesForPrzTot = RetornaDiasSeguracaoFornecedor.Udp(EmpCod, ProPadForCod)
		EndIf
		
		&TotalDiasBase = &PesForPrzTot + FilPrzEst + ProMarSeg + ProSetPrzEst
		
		if EstMin > 0  and &TotalDiasBase > 0
			if (EstMin / &TotalDiasBase) * &Dias <= ProVctQtd //and &Dias < 15
				
				&Mensagem = 'VENCE ANTES DE VENDER, PROMOCAO NELES!'
				&status = '-01'
				&IsOk = true
			Endif
		Endif
		
		if &Mensagem.IsEmpty() or &Dias <= 2
			Do Case
				CAse &Dias <= 0
					&Mensagem = 'VENCE HOJE!'
					&status = '00'
				CAse &Dias <= 1
					&Mensagem = 'VENCE AMANHA!'
					&status = '01'
				CAse &Dias <= 2
					&Mensagem = 'VENCE EM 2 DIAS !'
					&status = '02'
				CAse &Dias <= 5
					&Mensagem = 'VENCE EM 5 DIAS!'
					&status = '05'
				Case &Dias <= 10
					&Mensagem = 'VENCE EM 10 DIAS!'
					&status = '10'
				Case &Dias <= 15
					&Mensagem = 'VENCE EM 15 DIAS!'
					&status = '15'				
				Case &Dias > 20
					&Mensagem = 'VENCIMENTO ACIMA DE 20 DIAS!'
					&status = '20'
				Case &Dias > 30
					&Mensagem = 'VENCIMENTO ACIMA DE 30 DIAS!'
					&status = '30'
			EndCAse
			
		Endif
	Else
		&Mensagem = 'VENCIDO!'
		&status = '-02'
	Endif

	if &Filtrar <> 'B' //PRODUTOS ACIMA DO ESTOQUE VENCER NOS PROXIMOS X dias:B			
		&IsOk = true
		//	Else //PRODUTOS A VENCER NOS PROXIMOS X dias:A,
	Endif
	
	
	if &IsOk = true
		
		&Ordem = PadL(trim(str(ProSetCod)), 9, '0') + &status
		
		&sdtVencimentosProdutosItens = new()
		
		RetiraZerosDepoisVirgulaxCasas.Call(0, toformattedString(EstMin), &Varchar)
		&sdtVencimentosProdutositens.EstMin = &Varchar
		
		&sdtVencimentosProdutositens.ProRef = ProRef
		&sdtVencimentosProdutositens.ProSetCod = ProSetCod
		&sdtVencimentosProdutositens.ProNom = ProNom
		&sdtVencimentosProdutositens.FilCod = FilCod
		&sdtVencimentosProdutositens.EmpCod = EmpCod
		
		RetiraZerosDepoisVirgulaxCasas.Call(0, toformattedString(EstQtd), &Varchar)
		&sdtVencimentosProdutositens.EstQtd = &Varchar
		
		&sdtVencimentosProdutositens.ProCod = ProCod
		&sdtVencimentosProdutositens.ProGraCod = ProGraCod
		&sdtVencimentosProdutositens.ProVctDta = ProVctDta
		&sdtVencimentosProdutositens.ProVctCod = ProVctCod
		
		RetiraZerosDepoisVirgulaxCasas.Call(0, toformattedString(ProVctQtd), &Varchar)
		&sdtVencimentosProdutositens.ProVctQtd = &Varchar
		
//		&sdtVencimentosProdutositens.ProQtdMin = ProQtdMin
		&sdtVencimentosProdutositens.Mensagem = &Mensagem
		&sdtVencimentosProdutositens.Ordem = &Ordem
		&sdtVencimentosProdutositens.Status = &Status
		&sdtVencimentosProdutos.Add(&sdtVencimentosProdutositens)
	Endif
EndFor

]]></Source>
