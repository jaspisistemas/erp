      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CountCte = 0
&Count55 = 0
&Count65 = 0
&CountServico = 0
&CountReceitas = 0

Do 'Cte'
Do 'Notas'
Do 'Servico'
do 'Receita'

Sub 'Cte'
	//CTE
	For Each Order EmpCod,CteSts,CteProTer ,FilCod, CteCod
		Where EmpCod = &EmpCod
		Where CteSts = Status_NFe.Digitando
		Where CteProTer  = Nota_ProPriaTerceira.PROPRIA
		Where CteNum > 0
		&CountCte += 1
		
	EndFor
EndSub

Sub 'Notas'
	
	//NOTAS 55 e 65
	For Each Order EmpCod,NfeProTer,NfeSts, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilAmbEms = TAmb.Producao
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_NFe.Digitando
		Where not NfeNum.IsEmpty()
		
		if ModCod = '55'
			&Count55 += 1
		Else
			&Count65 += 1
		Endif
	EndFor
EndSub

Sub 'Servico'
	//NOTA DE SERVICO
	
	For Each Order EmpCod,NfsProTer,NfsSts, NfsFilCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfsSts = Status_NFe.Digitando
		Where not NfsNumLote.IsEmpty()
		
		&CountServico += 1
	EndFor
EndSub


sUB 'Receita'
	RetornaEmpresaModulo.Call(&EmpCod, moduloSistema.AGRO_INSUMOS, &PossuiModulo)
	if &PossuiModulo = 'S'
		&NfeDtaEms  = (&Today-90)
		For Each Order EmpCod,NfeProTer,NfeSts, NfeFilCod, NfeCod
			Where EmpCod = &EmpCod
			Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
			Where NfeRctPen = Status_SimNao.Sim
			Where NfeSts = Status_NFe.Autorizada
			Where NfeDtaEms >= &NfeDtaEms
			&CountReceitas += 1
		EndFor
	EndIf
EndSub
]]></Source>
