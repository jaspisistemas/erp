      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

For Each Order EmpCod, MalTabCod 
	Where EmpCod = &EmpCod
	Where MalTabCod = &MalTabCod
	
	&PesRaz = ''
	&PesLog = ''
	&PesLog1 = ''
	&PesLog2 = ''
	&PesLog3 = ''
	
	For Each Order EmpCod, PesCod
		Where PesCod = MalPesCod
		
		&PesRaz = PesRaz
		
		&Endereco = 'END:' + trim(PesLog) 
		&Endereco += ', ' + iif(not PesNro.IsEmpty(), trim(PesNro), ' S/N') 
		&Endereco += PesCpl.Trim()
		If not PesBai.IsEmpty()
			&Endereco = &Endereco.Trim() + ' - ' + trim(PesBai)
		EndIF
	
		&PesLog = gxGetMLi(&Endereco, 1, 43)
		&PesLog1 = gxGetMLi(&Endereco, 2, 43)
		
		if not PesRef.IsEmpty()
			If &PesLog1.IsEmpty()
				&PesLog1 = '(' + gxGetMLi(PesRef, 1, 43) + ')'
			Else
				&PesLog2 = '(' + gxGetMLi(PesRef, 1, 43) + ')'
			EndIF
		EndIf
	
		&Cidade = trim(PesCep) + ' - ' + PesCidUfeCod + ' - ' + trim(PesCidNom)
		Do Case
			Case &PesLog1.IsEmpty()
				&PesLog1 = &Cidade
			Case &PesLog2.IsEmpty()
				&PesLog2 = &Cidade
			Otherwise
				&PesLog3 = &Cidade
		Endcase
		
		print EtiquetaModelo01MalaDireta
	EndFor

EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
