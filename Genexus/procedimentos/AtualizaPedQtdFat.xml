      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order tmpNFeCod
	where tmpNFeCod = &tmpNFeCod
	Where tmpNfeItmCod = &tmpNfeItmCod
	
	Do Case
		Case &TmpPedQtdFat > tmpPedQtd
			&TmpPedQtdFat = tmpPedQtd
		Case &TmpPedQtdFat < 0
			&TmpPedQtdFat = 0
	EndCase
	&OldTmpPedQtdFat = tmpPedQtdFat
	tmpPedQtdFat = &TmpPedQtdFat
	
	Exit
EndFor

commit

//ATUALIZA OS TOTAIS DO PRODUTO E IMPOSTOS
If &OldTmpPedQtdFat <> &TmpPedQtdFat
	AtualizaNotaTemporariaVenda.Call(&tmpNFeCod, &tmpNfeItmCod)
EndIF
]]></Source>
