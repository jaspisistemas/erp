      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//PRIMEIRA COMPRA
For Each Order EmpCod, FilCod, PedCliCod, PedSts,LctAtuEst,PedStsFin,LctPagCom,PedDtaFat
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCliCod = &PedCliCod
	Where PedSts = Status_Pedido.FECHADO
	Where PedStsFin = Status_Financeiro.FECHADO
	Where LctAtuEst = Status_EntradaSaida.Saida
	Where LctPagCom = Status_SimNao.Sim
	
	&PrimeiraCompraData = PedDtaFat
	&PrimeiraCompraValor = PedVlrLiq
	formataParcela.Call(PedPraParNom, &PrimeiraCompraPrazo)
	
	Exit
EndFor

//ULTIMA COMPRA
For Each Order EmpCod, FilCod, PedCliCod, PedSts,PedStsFin,LctAtuEst,LctPagCom,(PedDtaFat)
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCliCod = &PedCliCod
	Where PedSts = Status_Pedido.FECHADO
	Where PedStsFin = Status_Financeiro.FECHADO
	Where LctAtuEst = Status_EntradaSaida.Saida
	Where LctPagCom = Status_SimNao.Sim
	
	&UltimaCompraData = PedDtaFat
	&UltimaCompraValor = PedVlrLiq
	formataParcela.Call(PedPraParNom, &UltimaCompraPrazo)
	Exit
EndFor

//SOMA PEDIDOS
For Each Order EmpCod, FilCod, PedCliCod, PedSts, PedStsFin,LctAtuEst,LctPagCom
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCliCod = &PedCliCod
	Where PedSts = Status_Pedido.FECHADO
	Where PedStsFin = Status_Financeiro.FECHADO
	Where LctAtuEst = Status_EntradaSaida.Saida
	Where LctPagCom = Status_SimNao.Sim

	&Totalpedidos += PedVlrLiq
	&QtdPedidos += 1
EndFor

//VALOR MEDIO COMPRA
if &QtdPedidos > 0 and &Totalpedidos > 0
	&valorMedio = &Totalpedidos / &QtdPedidos
Endif

//PERIODO MEDIO
&Dias = &UltimaCompraData - &PrimeiraCompraData
if &Dias > 0 and &QtdPedidos > 0
	&PeriodoCompra = round(&Dias / &QtdPedidos, 0)
Endif
]]></Source>
