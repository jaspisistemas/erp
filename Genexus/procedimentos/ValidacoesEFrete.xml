      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Erro = 0

For each Order EmpCod,FilCod,MDFeCod,MDFeMotCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MdfeCod
	&MdfeMotCpf = MDFeMotCpf
	Do 'GetMotorista'
	EXIT
When none
	msg('Motorista não encontrato com este CPF')
	&Erro = 1
EndFor


Sub 'GetMotorista'
	
	For each Order EmpCod,PesCpf
		Where EmpCod = &EmpCod
		Where PesCpf = &MdfeMotCpf 
		
		If PesCnh.Trim().IsEmpty()
			Msg('CNH do motorista Vazia Verifique!')
			&Erro = 1
		EndIf
		
		If PesRaz.Trim().IsEmpty()
			Msg('Nome do mortorista Vazio Verifique!')
			&Erro = 1
		EndIf
		
		If PesLog.Trim().IsEmpty()
			Msg('Endereço do mortorista Vazio Verifique!')
			&Erro = 1
		EndIf
		
		If PesBai.Trim().IsEmpty()
			Msg('Bairro do mortorista Vazio Verifique!')
			&Erro = 1
		EndIf
		
		If PesCep.Trim().IsEmpty()
			Msg('CEP do mortorista Vazio Verifique!')
			&Erro = 1
		EndIf
		
		If PesNro.Trim().IsEmpty()
			Msg('Número do mortorista Vazio Verifique!')
			&Erro = 1
		EndIf
		
		If PesDtaNas.IsEmpty()
			Msg('Data de Nascimento do mortorista Vazio Verifique!')
			&Erro = 1
		EndIf
		
		If PesCidIBGE = 0
			Msg('Cidade do mortorista Vazio Verifique!')
			&Erro = 1
		EndIf
		
		For each Order EmpCod,PesCod
			If PesFonNum.Trim().IsEmpty()
				Msg('Número do celular do mortorista Vazio Verifique!')
				&Erro = 1
			EndIf
			Exit
		EndFor
		exit
	EndFor
EndSub
]]></Source>
