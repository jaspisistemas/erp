      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

//	padraousuario.Call('G', '%testeEnviaEmail%', 1, 1, &EnviaWhats, &PadDtaMod)

if &EnviaWhats.IsEmpty()
	&sdtRetornowbs.Sts = 'E003'
	&sdtRetornowbs.Obs = 'Nada para enviar whats'
	
	return
Endif

if &IsAcessoConcedido = true //Acesso conced
	
	&sdtEnviaEmail.FromJson(&EnviaWhats)
	//	padraousuario.Call('G', '%testeEnviaEmail%', 1, 1, &EnviaWhats, &PadDtaMod)
	//	padraousuario.Call('G', '%testeEnviaEmail1%', 1, 1, &sdtEnviaEmail.ToJson(), &PadDtaMod)
	
	FormataFone.Call(&sdtEnviaEmail.Eml1, &PesFonNum1)
	FormataFone.Call(&sdtEnviaEmail.Eml2, &PesFonNum2)
	FormataFone.Call(&sdtEnviaEmail.Eml3, &PesFonNum3)
		
//		&EnviarFaltasPDFWhats = Status_SIMNAO.Sim And &IsFaltas >= 1
//		&EnviarNotasWhats = Status_SimNao.Sim
//		&EnviarBoletosWhats = Status_SimNao.Sim

	//		&PadObs = '1' //iif(&EnviarEmailPDF = true, '1', '0')
	//		&PadObs += '0' //iif(&EnviarEmailExcell = true, '1', '0')
	//		&PadObs += iif(&waDestacarImpostos = Status_SimNao.Sim, 'S', 'N')
	//		&PadObs += trim(&waTipoPedido)
	//		&PadObs += iif(&EnviarBoletosWhats = Status_SimNao.Sim, 'S', 'N')
	//		PadraoUsuarioHora.call('G', &LoadPadrao+'_wa', &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	
	&WaDtaEms = serverdate()
	&Ano = year(&WaDtaEms)
	&Mes = month(&WaDtaEms)
	&WaAnoMes = trim(str(&Ano)) + padL(trim(str(&mes)),2,'0')
	&IsGerouPDF = false
	
	&IsPodeEnviar = true
	if not &PesFonNum1.IsEmpty()
		&WaFonDest = &PesFonNum1
		do 'GravaEnvio'
	Endif
	
	if &IsPodeEnviar = true
		if not &PesFonNum2.IsEmpty()
			&WaFonDest = &PesFonNum2
			do 'GravaEnvio'
		Endif
	Endif
	if &IsPodeEnviar = true
		if not &PesFonNum3.IsEmpty()
			&WaFonDest = &PesFonNum3
			do 'GravaEnvio'
		Endif
	Endif
	
	if &IsPodeEnviar = true
		&sdtRetornowbs.Sts = 'J200'
		&sdtRetornowbs.Obs = 'Whats enviados com sucesso'
	Else
		&sdtRetornowbs.Sts = 'E009'
		&sdtRetornowbs.Obs = 'Não foi possivel enviar todas as mensagens, pacote mensagens exedido!'
	Endif
Else
	&sdtRetornowbs.Sts = 'E002'
	&sdtRetornowbs.Obs = 'Nao autorizado Device'
EndiF


Sub 'GravaEnvio'

	&IsPodeEnviar = false
	&IsJaEnviado = false
	&IsPrimeiraVez = false
	//Verificar se o numero ja foi enviado hoje
	prcWhatsApp_VerificaJaEnviado.Call(&wwpContext.EmpCod, &WaAnoMes, &WaDtaEms, &WaFonDest, &IsJaEnviado)
	If &IsJaEnviado = false
		//se nao foi enviado verificar se pode enviar
		prcWhatsApp_verificaQtdEnviadaAnoMes.Call(&wwpContext.EmpCod, &WaAnoMes, &WaAnoMesQtd, &EmpQtdWhatsMsg)
		if &EmpQtdWhatsMsg > &WaAnoMesQtd
			&IsPodeEnviar = true
			&IsPrimeiraVez = true
		Endif
	Else
		&IsPodeEnviar = true
	Endif
	
	if &IsPodeEnviar = true
		//grava envio
		
		&WaMensagem = 'Envio de Pedido: ' + trim(Str(&sdtEnviaEmail.EmlPedCod)) //PREENCHER MENSAGEM
		prcWhatsApp_GravaEnvio.Call(&wwpContext.EmpCod, &WaAnoMes, &WaDtaEms, &WaFonDest, &IsPrimeiraVez, &WaMensagem, &sdtEnviaEmail.EmlPedCod, &FilCod, 0, 0, &wwpContext.PesCod, &WaGUID)
		
		if &IsGerouPDF = false
			//GERA O PDF DO PEDIDO
			RetornaCaminhoPedido.call(trim(str(&wwpContext.PesExtCod)), &wwpContext.EmpCod, &wwpContext.FilCod, &sdtEnviaEmail.EmlPedCod, &URLDESTINO, &UrlVirtual)
			
			Do Case //&TipoPedido mesmo codigo do envia email.
				Case &waTipoPedido = '3' //PEDIDO VENDA COM LOGOMARCA
					RELJAS078_toFile.Call('SR', &wwpContext.EmpCod, &wwpContext.FilCod, &sdtEnviaEmail.EmlPedCod, &wwpContext.PesCod, &URLDESTINO, 'N', false)
				Case  &waTipoPedido = '2' //PEDIDO VENDA COM LOGOMARCA
					RELJAS078_toFile.Call('', &wwpContext.EmpCod, &wwpContext.FilCod, &sdtEnviaEmail.EmlPedCod, &wwpContext.PesCod, &URLDESTINO, 'N', false)
				Case  &waTipoPedido = '4' //PEDIDO VENDA COM LOGOMARCA - IMG PRODUTO
					RELJAS137_toFile.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtEnviaEmail.EmlPedCod, &wwpContext.PesCod, &URLDESTINO, 'N', false)
				Otherwise //PEDIDO SEM LOGO			 
					RELJAS002_toFile.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtEnviaEmail.EmlPedCod, &URLDESTINO, 'N', false)
			EndCase
		Endif
		&IsGerouPDF = true
		
		&IsFaltasPDF = iIf( &EnviarFaltasPDFWhats = Status_SIMNAO.Sim And &IsFaltas >= 1, true, false)
		&IsEnviarNota = iif( &EnviarNotasWhats = Status_SimNao.Sim, true, false)
		&IsEnviarBoletos = iif(&EnviarBoletosWhats = Status_SimNao.Sim, true, false)
	
		//GRAVA FILA DE ENVIO
		prcFilaEnvioWhats_EnviaPedidoVenda.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtEnviaEmail.EmlPedCod, &wwpContext.PesCod, &URLDESTINO, &UrlVirtual, 0, &WaFonDest, &WaGUID, &IsFaltasPDF, &IsEnviarNota, &IsEnviarBoletos)
	//Else
	//	&sdtRetornoWbs.Sts = 'E001'
	//	&sdtRetornoWbs.Obs = 'Pacote de Mensagens WhatsApp atingido, para envio de Mais mensagens entre em contato com o suporte.'
	Endif

EndSub
]]></Source>
