      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&PedidosMEnsagem = ''
&OrdPedCod() = 0
&CollOrdPedCod.Clear()

For Each Order EmpCod, FilCod, OrdCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdCod = &OrdCod
	
	&CollOrdPedCod.add(OrdPedCod)
EndFor


For Each Order EmpCod, FilCod, PedDtaHorSelPrd
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod in &CollOrdPedCod
	Where ProTipDef = definicao.FABRICADO
	Where ProSetCod = &ProSetCod
	
	if &OrdPedCod(PedCod) = 0
		If not &PedidosMEnsagem.IsEmpty()
			&PedidosMEnsagem += ' / '
		EndIF

		&PedidosMEnsagem += padL(trim(str(PedCod)), 9, '0')	
			
		&OrdPedCod(PedCod) = 1
	EndIf
	
EndFor
]]></Source>
