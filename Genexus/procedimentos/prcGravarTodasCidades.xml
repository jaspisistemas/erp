      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
padraoUsuarioHora.Call('L', '#CONFIGUFS_OFF#', &PesCod, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
&sdtUF.FromJson(&PadObs)

if &sdtUF.Count = 0
	&UfeCodColl.Add('PR')
Else
	for &sdtUFItem in &sdtUF
		&UfeCodColl.Add(&sdtUFItem.UfeCod)
	Endfor
Endif


&PadObs.SetEmpty()
padraoUsuarioHora.Call('L', '#CONFIGCIDADES_OFF#', &PesCod, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
&sdtCidade.FromJson(&PadObs)

For Each Order EmpCod, UfeCod, CidCod
	Where EmpCod = &EmpCod
	Where UfeCod in &UfeCodColl	
	
	&IsJaAdicionado = false
	
	For &sdtCidadeItem in &sdtCidade
		If &sdtCidadeItem.CidCod = &CidCod
			&IsJaAdicionado = true
			Exit
		Endif
	EndFor
	
	if &IsJaAdicionado = false
		&sdtCidadeItem = new()
		&sdtCidadeItem.CidCod = CidCod
		&sdtCidadeItem.CidNom = CidNom
		&sdtCidadeItem.CidSel = true
		&sdtCidade.Add(&sdtCidadeItem)
	Endif
EndFor

&PadObs = &sdtCidade.ToJson()
padraoUsuarioHora.Call('G', '#CONFIGCIDADES_OFF#', &PesCod, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
SetDeviceAtualizaS.Call(&EmpCod, &PesCod)
]]></Source>
