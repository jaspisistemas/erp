      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod, FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	CteCfop = formataCfop.udp(&CteCfop)
	CteImpCst = &CteImpCst
	CteDtaSai = &CteDtaSai
	Do Case
		Case CteAutMsg.Trim() = '100'
			CteSts = Status_nFe.Autorizada
		Case CteAutMsg.Trim() = '101'
			CteSts = Status_nFe.Cancelada
		Case CteAutMsg.Trim() = '102'
			CteSts = Status_nFe.Inutilizada
		Case CteAutMsg.Trim() = '110'
			CteSts = Status_nFe.Denegada
		Otherwise
			CteSts = Status_nFe.Digitando
	EndCase
EndFor

			
	
Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
