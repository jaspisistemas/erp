      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[LoadWWpContext.Call(&WWpContext)
&Mensagem			= ''
&IsPossuiRegistro	= False

&LongVarChar		= '[{ "codigoSolicitacao": "' + Trim(&CodigoSolicitacao) + '" }]'
&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
&HttpClient.AddHeader('Connection', 'keep-alive')
&HttpClient.AddHeader('Content-Type', 'application/json')
&HttpClient.AddString(&LongVarChar)

PadraoUsuario.Call('G', 'ENVIA_INTER_WEBHOOK', 0, 0, &LongVarChar, &PadDtaMod)
&HttpClient.Execute('POST', 'https://adm.jaspi.com.br/retorno/prcWebhookADMERP_Inter')
If &HttpClient.StatusCode = 200
	
	&SdtRecebimentoWebhook.FromJson(&HttpClient.ToString())
	For &payload In &SdtRecebimentoWebhook.Payload
		&IsPossuiRegistro			= True
		Do Case
			Case &payload.situacao	= !"CANCELADO"
				prcCancelaDuplicata_Webhook.Call(&payload.codigoSolicitacao, &CreDupNro)
				PadraoUsuario.Call('G', 'BOLETO_CANCELADO_INTER', &WWpContext.PesCod, &WWpContext.EmpCod, &SdtRecebimentoWebhook.ToJson(), &PadDtaMod)
				&Mensagem			= 'REGISTRO ONLINE DO BOLETO: ' +  &CreDupNro + ' - CANCELADO!'
				
			Case &payload.situacao	= !"RECEBIDO"
				//prcPagaDuplicata_Webhook
				PadraoUsuario.Call('G', 'BOLETO_PAGO_INTER', &WWpContext.PesCod, &WWpContext.EmpCod, &SdtRecebimentoWebhook.ToJson(), &PadDtaMod)
				&Mensagem			= 'REGISTRO ONLINE DO BOLETO: ' +  &CreDupNro + ' - PAGO!'
			
			Case &payload.situacao	= !"A_RECEBER"
			
			OtherWise
				&IsPossuiRegistro	= False
				&Mensagem			= &payload.situacao + ' Código de Solicitação: ' + &payload.codigoSolicitacao
				PadraoUsuario.Call('G', 'ERRO_INTER_WEBHOOK', 0, 0, &Mensagem, &PadDtaMod)	

		EndCase
	EndFor

	If 	&IsPossuiRegistro	= True
		PadraoUsuario.Call('G', 'SUCESSO_INTER_WEBHOOK', 0, 0, &HttpClient.ToString(), &PadDtaMod)	
	Else
		PadraoUsuario.Call('G', 'ERRO_INTER_WEBHOOK', 0, 0, &HttpClient.ToString(), &PadDtaMod)	
	EndIf
EndIf
]]></Source>
