        <Source><![CDATA[

// &OQUEFAZER
//P = lancar e baixar duplicata
//NP= Nao paga somente lancar o vlor deo saldo

//**** GRAVA FINANCEIRO DUPLICATAS DESCONTADAS ****\\

Do 'loadDesconto' //carrega tabela desconto e ja altera status pra fechado
Do 'loadLclCobranca' //carega CtaBanCod
Do 'NewMovCre' //New Movimento para os Creditos
Do 'NewMovTxa' //New Movimento para os debitos/tarifas
&TotalMoeda = 0
For each order EmpCod, DesCod, DesDupItmCod //DESCONTO ITEM
	where EmpCod = &EmpCod
	where DesCod = &DesCod		
	
	&CountCre = DesDupItmCod
	&DesFilCod = DesFilCod
	&DesCreCod = DesCreCod
	do 'Duplicata'
EndFor


Do 'NewMovTxaItem'

AtualizaSaldoConta.Call(TrnMode.Insert, &EmpCod, &CtaBanCod, &DesDta, 'C', &TotalMoeda, &data, 0, 'C')

AtualizaSaldoConta.Call(TrnMode.Insert, &EmpCod, &CtaBanCod, &DesDta, 'D', &DesVlr, &data, 0, 'D')


sub 'Duplicata'
	For each order EmpCod, FilCod, CreCod //DUPLICATA
		where EmpCod = &EmpCod
		where FilCod = &DesFilCod
		where CreCod = &DesCreCod
		
		//CreSts = Status_Duplicata.DESCONTADA
		&MovItmCpl = 'DESCONTO DUP:' + trim(CreDupNro) + ' CLI:'+ trim(str(CreCliCod)) + '-' + trim(CreCliRaz)
		
		&CreMaxPagCod = CreMaxPagCod
		
		&CreVlrDup =  CreVlrDup	
		&TotalMoeda += CreVlrDup
		
		
		//###################################### GRAVA ITEM DO CAIXA #################################
		
		&CreMaxPagCod += 1 //soma item do Rcbto da Duplicata
		Do 'NewMovCreItem'
		GravaCobranca.call(EmpCod,FilCod ,CreCod,('DUPLICATA DESCONTADA - Cód. Desc.: ' + &DesCod.ToFormattedString()) ,0,0, ServerDate(), '00:00:00', TipoObservacaoDuplicata.INTERNA)
		If &OQUEFAZER = 'P'  //pagar (baixar) duplicata	
			Do 'GravaPgtoDup'
		EndIf
		Exit
	EndFor
	Commit
EndSub


Sub 'GravaPgtoDup'
	
	New
		EmpCod       = &EmpCod
		FilCod       = &DesFilCod
		CreCod       = &DesCreCod		    
		CrePagCod    = &CreMaxPagCod
		CrePagDta    = &DesDta		
		CrePagVlr    = &CreVlrDup
		CrePagTip    = TipoDuplicataBaixa.Total
		CrePagVlrJur = 0
		CrePagVlrDsc = 0
		CreMovCod    = &DesMovCodCre
		CreMovItmCod = &CountCre
	EndNew
	
	commit
	AtualizaSaldoDuplicata.Call(&EmpCod,&DesCreCod,&DesFilCod)
EndSub


sub 'NewMovCre'
	New
		EmpCod = &EmpCod
		MovCod = &DesMovCodCre
		MovTip = TipoMovimento.DescontoDuplicataCheque
		MovDta = ServerDate()
		MovHor = ServerNow()
		MovDtaPgt = &DesDta
		MovCtaBanCod = &CtaBanCod
		MovDoc = trim(Str(&MovCod))
		MovCreDeb = 'C'
		MovDtaCon = &DesDta
		MovSts = Status_Caixa.Lancado
	EndNew
	Commit
EndSub

Sub 'NewMovCreItem'
	New
		EmpCod = &EmpCod
		MovCod = &DesMovCodCre
		MovItmCod = &CountCre
		MovItmCpl = &MovItmCpl
		MovItmVlr = &CreVlrDup
		PlanCod = &DesPlanCodDesc
		
		MovCreFilCod = &DesFilCod
		MovCreCod    = &DesCreCod
		MovCrePagCod = &CreMaxPagCod
	EndNew
	
	Commit
EndSub


Sub 'NewMovTxa'
	New
		EmpCod = &EmpCod
		MovCod = &DesMovCodTxa
		MovTip = TipoMovimento.DescontoDuplicataCheque
		MovDta = ServerDate()
		MovHor = ServerNow()
		MovDtaPgt = &DesDta
		MovCtaBanCod = &CtaBanCod
		MovDoc = trim(Str(&MovCod))
		MovCreDeb = 'D'
		MovDtaCon = &DesDta
		MovSts = Status_Caixa.Lancado
	EndNew
	Commit
EndSub

Sub 'NewMovTxaItem'
	New
		EmpCod = &EmpCod
		MovCod = &DesMovCodTxa
		MovItmCod = 1
		MovItmVlr = &DesVlr
		PlanCod = 	&DesPlanCodTrf
	EndNew
Commit
EndSub

Sub 'loadLclCobranca'

	For each order EmpCod, CbrCod
		where EmpCod = &EmpCod
		where CbrCod = &CbrCod
		&CtaBanCod = CbrCtaBanCod
		exit
	EndFor

EndSub

Sub 'loadDesconto'
	
	For each order EmpCod, DesCod
		where EmpCod = &EmpCod
		where DesCod = &DesCod
		&DesDta = DesDta
		&DesTip = DesTip
		&CbrCod = CbrCod
		&DesVlr = DesVlr
		&DesSts = DesSts
		&DesPlanCodDesc = DesPlanCodDesc
		&DesPlanCodTrf = DesPlanCodTrf
		&DesMovCodTxa = DesMovCodTxa
		&DesMovCodCre = DesMovCodCre
		
		DesSts = Status_AbertoFechado.Fechado
		
		if DesMovCodCre.IsEmpty()
			UltimoCodigoEmpresa.Call(domParCod.MOVIMENTO, &EmpCod, 0, &DesMovCodCre)
			DesMovCodCre = &DesMovCodCre
			UltimoCodigoEmpresa.Call(domParCod.MOVIMENTO, &EmpCod, 0, &DesMovCodTxa)
			DesMovCodTxa = &DesMovCodTxa
		EndIf
		exit
	EndFor
	Commit
EndSub

]]></Source>
