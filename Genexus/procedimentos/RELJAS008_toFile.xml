        <Source><![CDATA[//
//loadWWPContext.Call(&Context)
//If &Context.PesCod = 0
//	Return
//EndIf

For Each Order ProgressId
	Where ProgressId = &ProgressId
	&sdtEstoque.FromXml(ProgressLogXml)
	Exit
EndFor


For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	print Cabecalho
End


//ESTOQUE EMPRESA
&IsImprimeTitulo = true
For &sdtEstoqueItem in &sdtEstoque
	If &sdtEstoqueItem.EstTipCod = 1
		If &IsImprimeTitulo = true
			&IsImprimeTitulo = false
			&TipoEstoque = 'ESTOQUE EMPRESA'
			
			print TituloProduto
		Endif
		
		&ProCod = &sdtEstoqueItem.ProCod
		&ProRef = &sdtEstoqueItem.ProRef
		&ProNom = &sdtEstoqueItem.ProNom
		&EstQtd = &sdtEstoqueItem.EstQtd
		&AntEstQtd = &sdtEstoqueItem.AntEstQtd
		
		&Diferenca = (&sdtEstoqueItem.AntEstQtd - &sdtEstoqueItem.EstQtd)
		print ItemProduto
	EndIF
EndFor

If &IsImprimeTitulo = false
	Eject
EndIF

//ESTOQUE PRODUCAO
&IsImprimeTitulo = true
For &sdtEstoqueItem in &sdtEstoque
	If &sdtEstoqueItem.EstTipCod = 2
		If &IsImprimeTitulo = true
			&IsImprimeTitulo = false
			&TipoEstoque = 'ESTOQUE PRODUCAO'
			
			print TituloProduto
		Endif
	
		&ProCod = &sdtEstoqueItem.ProCod
		&ProRef = &sdtEstoqueItem.ProRef
		&ProNom = &sdtEstoqueItem.ProNom
		&EstQtd = &sdtEstoqueItem.EstQtd
		&AntEstQtd = &sdtEstoqueItem.AntEstQtd
		
		&Diferenca = (&sdtEstoqueItem.AntEstQtd - &sdtEstoqueItem.EstQtd)
		print ItemProduto
	EndIF
EndFor


If &IsImprimeTitulo = false
	Eject
EndIF

//ESTOQUE PRODUCAO
&IsImprimeTitulo = true
For &sdtEstoqueItem in &sdtEstoque
	If &sdtEstoqueItem.EstTipCod = 3
		If &IsImprimeTitulo = true
			&IsImprimeTitulo = false
			&TipoEstoque = 'ESTOQUE FISCAL'
			
			print TituloProduto
		Endif
	
		&ProCod = &sdtEstoqueItem.ProCod
		&ProRef = &sdtEstoqueItem.ProRef
		&ProNom = &sdtEstoqueItem.ProNom
		&EstQtd = &sdtEstoqueItem.EstQtd
		&AntEstQtd = &sdtEstoqueItem.AntEstQtd
		
		&Diferenca = (&sdtEstoqueItem.AntEstQtd - &sdtEstoqueItem.EstQtd)
		print ItemProduto
	EndIF
EndFor

Footer
	print Rodape
End
]]></Source>
