      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf
RetornaEmpresaModulo.Call(&Context.EmpCod, modulosistema.INDAGRIL, &INDAGRIL)
&PesRaz = &Context.PesRaz

For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	&FilTabCod = FilTabCod
	Exit
EndFor

MB 4
MT 2

if &INDAGRIL = 'S'
	&tituloReferencia = 'Referencia'
Endif

if &PrecoVEnda = 'S'
	&tituloVarchar = 'R$ Venda'
EndIf

Header
	&titulo = 'NCMs INVÁLIDOS'
	print Cabecalho

End

&auxGrupHie = &GrupHie.Trim() + '.'

For Each Order EmpCod, NcmCod, ProNom 
	Where EmpCod = &EmpCod
	Where NcmCod = &NcmCod when not &NcmCod.IsEmpty()
	Where NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()
	
	where ProSts <> Status_Produto.EXCLUIDO	
	Where (ProIsGra <> true) or (ProIsGra.IsNull() or ProIsGra.IsEmpty()) or ProGraCod > 1
	
	if &OldNcmCod <> NcmCod
		&OldNcmCod = NcmCod
		print prinNCM
		print Titulo
	Endif

	//Where MarCod = &MarCod when not &MarCod.IsEmpty()
	&ProBarRef_Comp = ''
	&MarNom = MarNom
	
	&ProCod =  ProCod
	&ProGracod = ProGraCod
	
	If ProPesLiq > 0
		&PropesLiq = ProPesLiq
	Else
		&PropesLiq = ProPesLiqCal
	Endif
		
	&ProBarRef = ProGraRef 
	&ProNomGra = gxGetMLi(ProNomGra, 1, 45)
	&Mensagem = ProNomGra
	
	print Produto
	
	//DescricaoAdicional
	&Final = &ProNomGra.Length()
	&Final += 1
	
	&Mensagem = Substr(&Mensagem, &Final, 500)
	&Mensagem = &Mensagem.Trim()
	if not &Mensagem.IsEmpty()
		&ProNomGra =  gxGetMLi(&Mensagem, 1, 120)
		if not &ProNomGra.IsEmpty()
			Print descricaoAdicional
		EndIF			
		&ProNomGra =  gxGetMLi(&Mensagem, 2, 120)
		if not &ProNomGra.IsEmpty()
			Print descricaoAdicional
		EndIF
		&ProNomGra =  gxGetMLi(&Mensagem, 3, 120)
		if not &ProNomGra.IsEmpty()
			Print descricaoAdicional
		EndIF
	Endif
	print Tracejado
EndFor


Footer
	print Rodape
End
]]></Source>
