      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	&CteImpTriVlrInss = CteImpTriVlrInss
	
	Do case			
		Case &CteImpCst = ClassificacaoCst.Outros or &CteImpCst = ClassificacaoCst.OutraUF
			&CteImpAli    = CteImpAli
			&CteImpVlr    = CteImpVlr
			&CteImpVbc = CteImpVbc 
			&CteImpVlrCre = CteImpVlrCre
			&CteImpPerRed = CteImpPerRed
			
		Case &CteImpCst = ClassificacaoCst.Normal
			&CteImpAli = CteImpAli
			&CteImpVlr = CteImpVlr
			&CteImpVbc = CteImpVbc 
			
		Case &CteImpCst = ClassificacaoCst.Reduzida
			&CteImpAli    = CteImpAli
			&CteImpVlr    = CteImpVlr
			&CteImpVbc    = CteImpVbc 
			&CteImpPerRed = CteImpPerRed
			
		Case &CteImpCst = ClassificacaoCst.Substituicao
			&CteImpVstRet = CteImpVstRet
			&CteImpVbcRet = CteImpVbcRet
			&CteImpAliRet = CteImpAliRet
			&CteImpVlrCre = CteImpVlrCre
			
		Case &CteImpCst = ClassificacaoCst.Isento or &CteImpCst = ClassificacaoCst.NaoTributada or &CteImpCst = ClassificacaoCst.Deferido	
			&CteImpAli    = 0
			&CteImpVlr    = 0
			&CteImpVlrCre = 0
			&CteImpPerRed = 0
			&CteImpVbc    = 0 
			
	EndCase
	
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
