      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'APONTAMENTOS DO FUNCIONÁRIO'
	print Cabecalho
	if &AptDtaLctIni = &AptDtaLctFin and (not &AptDtaLctFin.IsEmpty())
		&Periodo = 'DIA: ' + trim(toformattedString(&AptDtaLctIni))
	Else
		&Periodo = 'PERÍODO: ' + trim(toformattedString(&AptDtaLctIni)) + ' À ' + trim(toformattedString(&AptDtaLctFin))
	EndIf

End

&AuxPesCod = 0 
For Each Order EmpCod, AptFunCod, AptDtaLct, AptHorIni
Where EmpCod = &EmpCod
Where AptFunCod = &PesCod when not &PesCod.IsEmpty()
Where (AptDtaLct >= &AptDtaLctIni or &AptDtaLctIni.IsEmpty()) and (AptDtaLct <= &AptDtaLctFin or &AptDtaLctFin.IsEmpty())
	
	&AptQtd = AptQtd
	RetornaDiferencaEntreHoras.Call(AptHorIni, AptHorFin, &AptTotHor, &Segundosfinais)
	&SegundosTotais += &Segundosfinais
	
	if &AuxPesCod <> AptFunCod		
		&FunPesRaz = AptFunNom
		if not &AuxPesCod.IsEmpty()
			
			&DataDiferenca = serverDate()
			&DataDiferenca = &DataDiferenca.AddSeconds(&SegundosTotais)
			//99/99/9999 99:99:99
			&mensagem = trim(toformattedString(&DataDiferenca))
			&TotalHora = Substr(&mensagem,12,8)
	
			print Total
			
			&QtdPecas = 0
			&SegundosTotais = 0
			eject
		EndIf
		
		print Funcionario
	EndIf
	
	RetornaNomeEtapaGrupo.Call(EmpCod, AptProCod, AptEtpCod, &CTrNom)
	&Etapa = trim(str(AptEtpCod)) + ' - ' + trim(&CTrNom)
	
	&QtdPecas += AptQtd
	print lancamento
	&AuxPesCod = AptFunCod
EndFor

if &QtdPecas > 0
	&DataDiferenca = serverDate()
	&DataDiferenca = &DataDiferenca.AddSeconds(&SegundosTotais)
	//99/99/9999 99:99:99
	&mensagem = trim(toformattedString(&DataDiferenca))
	&TotalHora = trim(Substr(&mensagem,12,8))
	
	print Total
Endif

Footer
	print Rodape
End
]]></Source>
