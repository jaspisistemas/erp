      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//obtem empresa atraves usuario
For each Order MonRandon
	Where MonRandon = &ApiToken //localiza monitor
	where MonSts = Status_Pdv.INSTALADO
	Where MonTip = TipoApp.BI
	
	&EmpCod = EmpCod
	
	MonUltSync = serverNow()
	
	Exit 
When none
	return
EndFor

&PedDtaFat = serverdate()
&PedDtaFat = &PedDtaFAt.AddDays(-90)

&FilCod = &inFilCod

//Filial
if &FilCod.IsEmpty()
	&FilCod = 1
EndIf

&auxGrupHie = &GrupHie.Trim() + '.'

For Each order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	
	&sdtInventarioItem = new()
	&sdtInventarioItem.ProRef = ProRef
	&sdtInventarioItem.FilCod = FilCod
	&sdtInventarioItem.GrupHie = GrupHie
	&sdtInventarioItem.ProNom = ProNom
	&sdtInventarioItem.EstQtd = RetirazerosDepoisVirgulaxCasas.Udp(0, EstQtd.ToFormattedString())
	&sdtInventarioItem.EstSdo = RetirazerosDepoisVirgulaxCasas.Udp(0, EstSdo.ToFormattedString())
	
	//tabela preco
	For Each Order EmpCod,TabCod,ProCod,ProGraCod, TabAltCod
		Where TabCod = FilTabCod
		Where TabAltCod = TabUltAlt
		&sdtInventarioItem.TabPrc1 = RetirazerosDepoisVirgulaxCasas.Udp(2, TabPrc1.ToFormattedString())
		exit
	When none
		&sdtInventarioItem.TabPrc1 = '0,00'
	EndFor

	&sdtInventarioItem.ProForVlrCus = '0,00'
	
	For Each Order EmpCod, ProCod, ProForCod
		Where ProForCod = ProPadForCod
		&sdtInventarioItem.ProForVlrCus = RetirazerosDepoisVirgulaxCasas.Udp(2, ProForVlrCus.ToFormattedString())
		Exit
	EndFor
	
	&Media3MesesPedQtd = 0
	&PedQtd = 0
	For Each ORder EmpCod, FilCod, PedCod, PedItmCod
		Where PedDtaFat >= &PedDtaFAt 
		Where PedSts = 'F'
		Where LctAtuEst = Status_EntradaSaida.Saida
		&PedQtd += PedQtd
	EndFor
	if &Media3MesesPedQtd > 0
		&Media3MesesPedQtd = &PedQtd / 3
	Endif

	&sdtInventarioItem.Media3Meses = RetiraZerosDepoisVirgulaxCasas.Udp(0, &Media3MesesPedQtd.ToFormattedString())
	&sdtInventarioItem.ProForCod = ProPadForCod
	&sdtInventarioItem.ProForRaz = ProPadForRaz
	&sdtInventarioItem.ProVlrCus = RetirazerosDepoisVirgulaxCasas.Udp(2, ProVlrCus.ToFormattedString())
	&sdtInventarioItem.EstABC_Ren = EstABC_Ren
	&sdtInventarioItem.ProSts = ProSts
	&sdtInventario.Add(&sdtInventarioItem)
EndFor
]]></Source>
