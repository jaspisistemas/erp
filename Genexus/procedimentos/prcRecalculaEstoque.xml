      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&finNfeDtaEms = serverdate()
AtualizaDataFaturadoNotas.Call(&EmpCod, &FilCod, &iniNfeDtaEms, &finNfeDtaEms)

retornaCodigoCategoriaProduto.Call(&EmpCod, &GrupHie, &GrupCod, &GrupNom, &AuxGrupHie)

&DataInicial = CtoD(&CfgVlr)

if &ProgressId = 'cmdRecalculo'
	msg('Data Inicial:' + &DataInicial.ToFormattedString(), status)
EndIF

&sdtEstoque.Clear()

&Total = 0
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&HojeData = serverdate()
&limiteData = &HojeData.AddDays(-30)

msg(toformattedString(&limiteData), status)

For Each Order EmpCod,ProCod, ProGraCod
	Where EmpCod = &EmpCod or &EmpCod = 0
	Where ProRef >= &iniProRef when not &iniProRef.IsEmpty()
	Where ProRef <= &FinProRef when not &FinProRef.IsEmpty()
	Where ProSetCod = &SetCod when &SetCod <> 0
	Where GrupCod = &GrupCod when &GrupCod <> 0
	Where ProUltAtuEst <= (&limiteData) or ProUltAtuEst.IsEmpty() or ProUltAtuEst.IsNull() when &ProgressId = 'cmdRecalculo'
	Where ProSts = Status_Produto.ATIVO
	Where ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
	Where ProTipDef <> Definicao.SERVICO
	&Total += 1
EndFor

msg(trim(str(&Total)), status)

For Each Order EmpCod, ProGraRefPadL
	Where EmpCod = &EmpCod or &EmpCod = 0
	Where ProRef >= &iniProRef when not &iniProRef.IsEmpty()
	Where ProRef <= &FinProRef when not &FinProRef.IsEmpty()
	Where ProSetCod = &SetCod when &SetCod <> 0
	Where GrupCod = &GrupCod when &GrupCod <> 0
	Where ProUltAtuEst <= (&limiteData) or ProUltAtuEst.IsEmpty() or ProUltAtuEst.IsNull() when &ProgressId = 'cmdRecalculo'
	Where ProSts = Status_Produto.ATIVO
	Where ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
	Where ProTipDef <> Definicao.SERVICO
	
	&AuxProCod = ProCod
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'

	RetornaQuantidadeEstoque.Call(EmpCod, &FilCod, ProCod, ProGraCod, &EstCom, &EstVen, &AntEstPrd, &AntEstQtd, &EstSdo, &EstSug, &AntEstQtdFis)
	RecalculaEstoque.Call(EmpCod, &FilCod, ProCod, ProGraCod, &SomenteProducao, &SomenteNotas, &DataInicial)
	RetornaQuantidadeEstoque.Call(EmpCod, &FilCod, ProCod, ProGraCod, &EstCom, &EstVen, &AtuEstPrd, &AtuEstQtd,  &EstSdo, &EstSug, &AtuEstQtdFis)
	
	If &AntEstQtdFis <> &AtuEstQtdFis
		&sdtEstoqueItem = new()
		&sdtEstoqueItem.ProCod = ProCod
		&sdtEstoqueItem.ProRef = ProGraRef
		&sdtEstoqueItem.ProGraCod = ProGraCod
		&sdtEstoqueItem.EstTipCod = 3
		&sdtEstoqueItem.EstQtd = &AtuEstQtdFis
		&sdtEstoqueItem.ProNom = ProNomGra
		&sdtEstoqueItem.AntEstQtd = &AntEstQtdFis
		&sdtEstoque.Add(&sdtEstoqueItem)

	EndIF
	If &AntEstPrd <> &AtuEstPrd
		&sdtEstoqueItem = new()
		&sdtEstoqueItem.ProCod = ProCod
		&sdtEstoqueItem.ProRef = ProGraRef
		&sdtEstoqueItem.ProGraCod = ProGraCod
		&sdtEstoqueItem.EstTipCod = 2
		&sdtEstoqueItem.EstQtd = &AtuEstPrd
		&sdtEstoqueItem.ProNom = ProNomGra
		&sdtEstoqueItem.AntEstQtd = &AntEstPrd
		&sdtEstoque.Add(&sdtEstoqueItem)
	EndIF
	
	If &AntEstQtd <> &AtuEstQtd
		&sdtEstoqueItem = new()
		&sdtEstoqueItem.ProRef = ProGraRef
		&sdtEstoqueItem.ProCod = ProCod
		&sdtEstoqueItem.ProGraCod = ProGraCod
		&sdtEstoqueItem.EstTipCod = 1
		&sdtEstoqueItem.EstQtd = &AtuEstQtd
		&sdtEstoqueItem.ProNom = ProNomGra
		&sdtEstoqueItem.AntEstQtd = &AntEstQtd
		&sdtEstoque.Add(&sdtEstoqueItem)
	EndIF

	if  &AntEstPrd <> &AtuEstPrd or &AntEstQtd <> &AtuEstQtd
		ProUltAtuEst = &HojeData
	Else
		ProUltAtuEst = &HojeData.AddDays(45)
	Endif

	
	Commit
EndFor

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
		for each Order ProgressId
			where ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &sdtEstoque.ToXml()
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		When none
			new
				ProgressId = &ProgressId
				ProgressValue = &Percentual
				ProgressLogXml = &sdtEstoque.ToXml()
				ProgressFin = &ProgressFin
				ProgressIni = &Progressini
			Endnew
		endfor
		
		commit
		
	if &ProgressId = 'cmdRecalculo'
		msg('Produto:' + trim(str(&AuxProCod)) + ' Percentual: ' + trim(str(&Percentual)), status)
	EndIF
EndSub
]]></Source>
