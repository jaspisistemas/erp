      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PedSts, PedBlq, LctGerFin, LctAtuSal, PedDtaFat
	Where EmpCod = &EmpCod
	where FilCod in &collFilCod
	Where PedVenCod = &PedVenCod when not &PedVenCod = 0
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where LctGerFin = Status_SimNao.Sim
	Where LctAtuSal = Status_EntradaSaida.Saida
	Where PedSts = Status_Pedido.FECHADO
	Where PedDtaFat >= &PedDtaFat and PedDtaFat <= &PedDtaFat_Go
	Where LctAtuGra = Status_SimNao.Sim Or LctAtuGra.IsNull()
	Where PedBlq = Status_SimNao.Nao
	
	&TotalPedVlrLiq += PedVlrLiq
	&Count += 1
EndFor


If &Count > 0 and &TotalPedVlrLiq > 0
	&MediaMensalMoeda = &TotalPedVlrLiq/&Count
EndIf
]]></Source>
