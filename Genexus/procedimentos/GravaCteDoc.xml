      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &CteDocCod = 0 
	For each Order EmpCod,FilCod,CteCod,(CteDocCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&ForCteDocCod = CteDocCod
		exit
	EndFor
	&auxCteDocCod = &ForCteDocCod+1
	
	
	If  &CteDocTip = TipoDocumentoCte.NFe
		&IsChaveok = True
		If not &CteDocChvNfe.Trim().IsEmpty()
			Do 'ValidaSeJaEstaLancado'
		Else
			&IsChaveok = False
		EndIf
	Else
		&IsAdicionada = False
	EndIf 	
	
	If &IsAdicionada = False or (&IsChaveok = True and &IsAdicionada = False and &CteDocTip = TipoDocumentoCte.NFe and not &CteDocChvNfe.IsEmpty())
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CteCod = &CteCod
			CteDocTip = &CteDocTip
			CteDocCod = &auxCteDocCod
			CteDocNroRom = trim(&CteDocNroRom)
			CteDocNroPed = trim(&CteDocNroPed)
			CteDocMod = &CteDocMod
			CteDocSer = &CteDocSer
			If &CteDocTip = TipoDocumentoCte.NFe
				CteDocNro = substr(trim(&CteDocChvNfe),26,9)
			Else
				CteDocNro = &CteDocNro
			EndIF
			CteDocTipOri = &CteDocTipOri
			CteDocDes = trim(&CteDocDes)
			CteDocDta = &CteDocDta
			CteDocVbc = &CteDocVbc
			CteDocVlrIcm = &CteDocVlrIcm
			CteDocVstIcm = &CteDocVstIcm
			CteDocVst = &CteDocVst
			CteDocVlrTotPro = &CteDocVlrTotPro
			CteDocTotPso = &CteDocTotPso
			If &CteDocTip = TipoDocumentoCte.NFe
				CteDocVlrTotNtf = &CteDocVlrNtf
			Else
				CteDocVlrTotNtf = &CteDocVlrTotNtf
			EndIF
			
			CteDocCfoPre = &CteDocCfoPre
			CteDocPes = &CteDocPes
			CteDocChvNfe = trim(&CteDocChvNfe)
			CteDocPinSuf = &CteDocPinSuf
			CteDocDtaPre = &CteDocDtaPre
			CteDocNcmPre = &CteDocNcmPre
			Msg('Nota Adicionada com sucesso!')
		Endnew
		Commit
	EndIf
Else
	For each Order EmpCod,FilCod,CteCod,CteDocCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocCod = &CteDocCod
		
		CteDocTip = &CteDocTip
		CteDocNroRom = trim(&CteDocNroRom)
		CteDocNroPed = trim(&CteDocNroPed)
		CteDocMod = &CteDocMod
		CteDocSer = &CteDocSer
		If &CteDocTip = TipoDocumentoCte.NFe
			CteDocNro = substr(trim(&CteDocChvNfe),26,9)
		Else
			CteDocNro = &CteDocNro
		EndIF
		
		CteDocTipOri = &CteDocTipOri
		CteDocDes = trim(&CteDocDes)
		CteDocDta = &CteDocDta
		CteDocVbc = &CteDocVbc
		CteDocVlrIcm = &CteDocVlrIcm
		CteDocVstIcm = &CteDocVstIcm
		CteDocVst = &CteDocVst
		CteDocVlrTotPro = &CteDocVlrTotPro
		CteDocTotPso = &CteDocTotPso
		If &CteDocTip = TipoDocumentoCte.NFe
			CteDocVlrTotNtf = &CteDocVlrNtf
		Else
			CteDocVlrTotNtf = &CteDocVlrTotNtf
		EndIF
		CteDocCfoPre = &CteDocCfoPre
		CteDocPes = &CteDocPes
		CteDocChvNfe = trim(&CteDocChvNfe)
		CteDocPinSuf = &CteDocPinSuf
		CteDocDtaPre = &CteDocDtaPre
		CteDocNcmPre = &CteDocNcmPre
		Msg('Nota alterada com sucesso!')
	EndFor
EndIf

Sub 'ValidaSeJaEstaLancado'
	&IsAdicionada =  false
	For each Order EmpCod,FilCod,CteCod,(CteDocCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocChvNfe = trim(&CteDocChvNfe)
		&RefCteDocCod = CteDocCod
		&IsAdicionada =  True
		Msg('ATENÇÃO! Esta chave de Nota Fiscal nro: '+trim(CteDocChvNfe)+' já está adicionada no item '+ trim(str(&RefCteDocCod)))
	EndFor
EndSub


]]></Source>
