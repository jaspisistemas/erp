      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod, PedCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &novoPedCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	&PedQtd = PedQtd - &NfeProQtd
	
	if &PedQtd < 0
		&PedQtd = 0
	Endif
	
	PedQtd = &PedQtd
	PedQtdEmb = &PedQtd
	
	Exit
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
