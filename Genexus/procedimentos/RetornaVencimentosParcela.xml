      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, CidCod
	Where EmpCod = &EmpCod
	Where CidCod = &CidCod
	&UfeCod = UfeCod
	&paiCod = PaiCod
	Exit
EndFor
	
&Posicao = 0 
&sdtVencimentos.Clear()
&VencimentosExtenso = ''

Do While &Posicao <= 300
    &PosIni  = ((&Posicao * 4) + 1)
    &Dias = val(substr(&PedPraParNom,&PosIni,3))
    if &Dias > 0
        &CreDtaVct = (&PedDtaFat + &Dias)
        &Dias = 0
		
        &Feriado = '' //Testa Sabados/Domingos/Feriados
		if &CreRecPag = ReceberPagar.Receber
	        Do While (&Feriado = 'S' OR &Feriado = '')
				Do Case
					Case dow(&CreDtaVct) = 7  //Se Vencimento For Sabado, Muda Vencimento para Segunda;
						&Dias = 2
						
					Case dow(&CreDtaVct) = 1  //Se Vencimento For Domingo, Muda Vencimento para Segunda;
						&Dias = 1
				EndCase
				
				&CreDtaVct += &Dias
				
	            &Feriado = 'N'
				&EmpFrdDia = Substr(trim(toformattedString(&CreDtaVct)), 1, 5)
				For Each Order EmpCod, EmpFrdDta
					Where EmpCod = &EmpCod
				  	Where (EmpFrdDta = &CreDtaVct and EmpFrdFix = Status_SimNao.Nao)
					or (EmpFrdDia = &EmpFrdDia and EmpFrdFix = Status_SimNao.Sim)
					
					&Feriado = 'S'
					
					Do Case
						Case EmpFrdNac = TipoRegiao.Nacional
							If EmpFrdPaiCod = &paiCod or EmpFrdPaiCod.IsEmpty()
								&CreDtaVct += 1
								Exit
							EndIF
							
						Case EmpFrdNac = TipoRegiao.Estadual
							If EmpFrdUfeCod = &UfeCod and EmpFrdPaiCod = &paiCod
								&CreDtaVct += 1
								Exit
							EndIF
							
						Case EmpFrdNac = TipoRegiao.Municipal
							If EmpFrdCidCod = &CidCod
								&CreDtaVct += 1
								Exit
							EndIF
					EndCAse
					
					&Feriado = 'N'
				EndFor	
	        EndDo
		Endif
           
		do 'AddSdtVencimento'
    endif

    &Posicao += 1
EndDo

if &sdtVencimentos.Count = 0 //Se Nenhuma Parcela Informada
    &CreDtaVct = &PedDtaFat
	do 'AddSdtVencimento'
endif


Sub 'AddSdtVencimento'
	If &VencimentosExtenso.IsEmpty()
		&VencimentosExtenso = trim(toformattedString(&CreDtaVct))
	Else
		&VencimentosExtenso = &VencimentosExtenso.Trim() + ' - ' + trim(toformattedString(&CreDtaVct))
	EndIF
	
	&sdtVencimentosItem = new()
	&sdtVencimentosItem.CreDtaVct = &CreDtaVct
	&sdtVencimentosItem.CreDupDias = &CreDtaVct - &PedDtaFat
	&sdtVencimentos.Add(&sdtVencimentosItem)
EndSub
]]></Source>
