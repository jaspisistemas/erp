        <Source><![CDATA[
&LogGUID = GUID.NewGuid()

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)

if &RespPesCod <> 0
	&Dias = 1
	&DataLimite = &Today.AddDays(&Dias)
	do 'Init'
	

	// Pesquisa boletos próximo ao vencimento ainda não enviados, ou marcados como pendente
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&FilRaz = RetornaNomeCadFilial.Udp(EmpCod, FilCod)
		if &RespPesRaz.IsEmpty()
			&RespPesRaz = &FilRaz
		Endif
	
		&PedCliCod = PedCliCod
		&PedVlrLiq = PedVlrLiq
		
		
	
		do 'Match'
		msg('Pedido ' + &PedCod+ ': feito!', status)
	EndFor
endif

Sub 'Init'
	RetornaTemplatePadraoWhatsPorTipo(&EmpCod,TipoTemplateWhatsapp.PEDIDO,&tempatePedido)
	RetornaTemplatePadraoWhatsPorTipo(&EmpCod,TipoTemplateWhatsapp.NAO_RESPONDA,&tempateNaoResponda)
	
	do 'BuscaInformacoesResponsavel'
EndSub

// Match!
Sub 'Match'
	// tudo certo para continuar			
	if not &tempatePedido.IsEmpty()
		&txtFomatado = &tempatePedido
		do 'Mustache'
		&tempatePedido = &txtFomatado
		
		&txtFomatado = &tempateNaoResponda
		do 'Mustache'
		&tempateNaoResponda = &txtFomatado
		
		do 'New'
	endif
EndSub

Sub 'BuscaInformacoesResponsavel'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&RespPesFonNum = FilFonNum.Trim()
		
		&FilArt = FilArt
		Exit
	EndFor

	// NOME E TELEFONE
	For each Order EmpCod,PesCod
		where EmpCod = &EmpCod
		where PesCod = &RespPesCod
		
		&RespPesRaz = PesRaz
		if &RespPesFonNum.IsEmpty()
			For Each Order EmpCod, PesCod, PesFonCod
				&RespPesFonNum = PesFonNum
				exit
			EndFor
		EndIf
	
		exit		
	EndFor
EndSub

Sub 'Mustache'
	msg('Pedido ' + &PedCod + ': fazendo match!', status)
	mustache(&txtFomatado,'Artigo',&FilArt,&txtFomatado)
	mustache(&txtFomatado,'NomeFilial',&FilRaz,&txtFomatado)
	mustache(&txtFomatado,'NumeroPedido',&PedCod.ToString().Trim(),&txtFomatado)
	mustache(&txtFomatado,'ValorPedido',&PedVlrLiq.ToString().Trim(),&txtFomatado)
	mustache(&txtFomatado,'FoneContato',&RespPesFonNum,&txtFomatado)
	mustache(&txtFomatado,'NomeContato',&RespPesRaz,&txtFomatado)
EndSub

Sub 'New'
	msg('Pedido ' + &PedCod + ': gravando', status)
	&FilaWhatsMsgOrd = 0
	New
		EmpCod                 = &EmpCod
		FilaWhatsGUID          = GUID.NewGuid()
		FilaWhatsFilCod        = &FilCod
		FilaWhatsRespPesCod    = &RespPesCod
		FilaWhatsDestPesCod    = &PedCliCod
		FilaWhatsDestPesFonCod = &DestPesFonCod
		FilaWhatsDtaEms        = now()
		FilaWhatsDtaLim        = &DataLimite
		FilaWhatsSts           = Status_FilaWhats.PENDENTE
		FilaWhatsTip           = TipoFilaEnvioWhats.PEDIDO
		FilaWaGuid			   = &WaGUID
		
		if Substr(&FilaWhatsDestPesFonNum,1,1) <> '+'
			FilaWhatsDestPesFonNum = '55' + retornasoNumeros.Udp(&FilaWhatsDestPesFonNum)
		Else	
			FilaWhatsDestPesFonNum = retornasoNumeros.Udp(&FilaWhatsDestPesFonNum)
		Endif	
		
		// TEXTO DO TEMPLATE ENVIO PEDIDO
		&FilaWhatsMsgOrd        += 1
		New
			FilaWhatsMsgGUID         = GUID.NewGuid()
			FilaWhatsMsgTxt          = &tempatePedido
			FilaWhatsMsgOrd          = &FilaWhatsMsgOrd
			FilaWhatsMsgTip          = TipoMensagemWhats.Texto
			FilaWhatsMsgSts          = Status_FilaWhats.PENDENTE
			FilaWhatsMsgPedCod = &PedCod
		EndNew
		
		// PDF DO PEDIDO
		&FilaWhatsMsgOrd        += 1
		New
			FilaWhatsMsgGUID         = GUID.NewGuid()
			//FilaWhatsMsgCreCod       = &sdtMensalAtrasoItem.FilaWhatsMsgCreCod
			FilaWhatsMsgArqNom       = 'Pedido_'+trim(Str(&PedCod))+'.pdf'
			FilaWhatsMsgTxt          = ''
			FilaWhatsMsgTip          = TipoMensagemWhats.Documento
			FilaWhatsMsgarqDirFis    = &DirFisPDF
			FilaWhatsMsgArqDirFisVir = &UrlVirtual
			FilaWhatsMsgOrd          = &FilaWhatsMsgOrd
			FilaWhatsMsgSts          = Status_FilaWhats.PENDENTE
			FilaWhatsMsgPedCod = &PedCod
		EndNew
		
		//PDF DAS FALTAS
		if &IsEnviarFaltas = true
			&Data = serverdate()
			&Hora = serverTime()
			&mensagem = trim(toformattedString(&Data)) + trim(&Hora)
			&mensagem = RetornaSoNumeros.Udp(&mensagem)
			
			&UrlFisicoFaltas = &SdtConfiguracoesPasta.PastaDiretorioTempFis + trim(str(&EmpCod)) + trim(str(&FilCod)) + trim(str(&PedCod)) + &mensagem + '_faltas.PDF'
			&UrlVirtuaFaltas = &SdtConfiguracoesPasta.PastaDiretorioTempVir + trim(str(&EmpCod)) + trim(str(&FilCod)) + trim(str(&PedCod)) + &mensagem + '_faltas.PDF'
			
			do 'verificaDeletaArquivoFaltas'
			RELJAS037_toFile.Call(&EmpCod, &FIlCod, &PedCod, &UrlFisicoFaltas)
			
			// PDF FALTAS
			&FilaWhatsMsgOrd        += 1
			New
				FilaWhatsMsgGUID         = GUID.NewGuid()
				//FilaWhatsMsgCreCod       = &sdtMensalAtrasoItem.FilaWhatsMsgCreCod
				FilaWhatsMsgArqNom       = 'Faltas_'+trim(Str(&PedCod))+'.pdf'
				FilaWhatsMsgTxt          = ''
				FilaWhatsMsgTip          = TipoMensagemWhats.Documento
				FilaWhatsMsgarqDirFis    = &UrlFisicoFaltas
				FilaWhatsMsgArqDirFisVir = &UrlVirtuaFaltas
				FilaWhatsMsgOrd          = &FilaWhatsMsgOrd
				FilaWhatsMsgSts          = Status_FilaWhats.PENDENTE
				FilaWhatsMsgPedCod 			= &PedCod
			EndNew
		Endif
	
		//NOTAS FISCAIS
		if &IsEnviarNotas = true
			For each order EmpCod,NfeFilCod,NfePedCod,NfeSts
				Where EmpCod = &EmpCod
				Where NfeFilCod = &FilCod
				Where NfePedCod = &PedCod
				Where NfeSts = Status_NFe.Autorizada
				
				GeraPdfDanfe_EnviaEmail.Call(EmpCod, FilCod, NfeCod, &AuxUrlVirtual, &URlFisico)
				
			    //ADICIONA ARQUIVO
				&File.Source = &URlFisico //PDF
				If &File.Exists()
					&FilaWhatsMsgOrd        += 1
					New
						FilaWhatsMsgGUID         = GUID.NewGuid()
						//FilaWhatsMsgCreCod       = &sdtMensalAtrasoItem.FilaWhatsMsgCreCod
						FilaWhatsMsgArqNom       = NfeChv.Trim() + '.pdf'
						FilaWhatsMsgTxt          = ''
						FilaWhatsMsgTip          = TipoMensagemWhats.Documento
						FilaWhatsMsgarqDirFis    = &URlFisico
						FilaWhatsMsgArqDirFisVir = &AuxUrlVirtual
						FilaWhatsMsgOrd          = &FilaWhatsMsgOrd
						FilaWhatsMsgSts          = Status_FilaWhats.PENDENTE
						FilaWhatsMsgPedCod 			= &PedCod
					EndNew
				EndIF
				
			When none
				
			EndFor
		Endif
	
		//BOLETOS 
		if &IsEnviarBoletos = true
			RetornaSDTboletosPedido.Call(&EmpCod, &FilCod, &PedCod, &sdtBoleto)
			For &SdtBoletoItem in &SdtBoleto
				if &sdtBoletoItem.IsBoleto = 1
					&auxsdtBoletoItem = new()
					&auxsdtBoletoItem.CreEmpCod = &SdtBoletoItem.CreEmpCod
					&auxsdtBoletoItem.CreFilCod = &SdtBoletoItem.CreFilCod
					&auxsdtBoletoItem.CreCod = &SdtBoletoItem.CreCod
		
					&auxsdtBoleto.Add(&auxsdtBoletoItem)
				Endif
			EndFor
				
			if &auxsdtBoleto.Count > 0
				&AuxUrlVirtual= &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + 'envBoletoPedido' + trim(str(&PedCod)) + '.pdf'
				&URlFisico = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'envBoletoPedido' + trim(str(&PedCod)) + '.pdf'
				&File.Source = &URlFisico
				if &File.Exists()
					&File.Delete()
				EndIf
				
				GerarBoleto.Call(&auxsdtBoleto, false, &IsErro, &ImprimeSdtBoleto)
				
				RELJAS045_toFile.Call(&EmpCod, &FilCod, &ImprimeSdtBoleto, &URlFisico)
				
				&FilaWhatsMsgOrd        += 1
				New
					FilaWhatsMsgGUID         = GUID.NewGuid()
					//FilaWhatsMsgCreCod       = &sdtMensalAtrasoItem.FilaWhatsMsgCreCod
					if &auxsdtBoleto.Count > 1
						FilaWhatsMsgArqNom       = 'BoletosPedido'+trim(str(&PedCod))+'.pdf'
					Else
						FilaWhatsMsgArqNom       = 'BoletoPedido'+trim(str(&PedCod))+'.pdf'
					Endif
				
					FilaWhatsMsgTxt          = ''
					FilaWhatsMsgTip          = TipoMensagemWhats.Documento
					FilaWhatsMsgarqDirFis    = &URlFisico
					FilaWhatsMsgArqDirFisVir = &AuxUrlVirtual
					FilaWhatsMsgOrd          = &FilaWhatsMsgOrd
					FilaWhatsMsgSts          = Status_FilaWhats.PENDENTE
					FilaWhatsMsgPedCod 			= &PedCod
				EndNew
			Endif
		Endif
	
	EndNew

	Commit
EndSub

Sub 'verificaDeletaArquivoFaltas'
	&File.Source = &UrlFisicoFaltas
	If &File.Exists()
		&File.Delete()
	EndIf
EndSub

Sub 'subException_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subException_handler','subException_handler')
	
EndSub

Sub 'subError_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subError_handler','subError_handler')
	
EndSub

