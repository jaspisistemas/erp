      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem = ''

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
    
	UltimoCodigoEmpresa.Call(domParCod.PEDIDO, EmpCod, FilCod, &NovoPedCod)
	
    New
		EmpCod = EmpCod
        FilCod = FilCod
        PedCod = &NovoPedCod
        LctCod = &NovLctCod
        PedCliCod = &NovPedCliCod
        PedDtaEms = &NovPedDtaEms
		PedVenCod = &NovPedVenCod
		TabCod = &NovTabCod
		TabPrmCod = &NovTabPrmCod
		TabColCod = &NovTabColCod
		PedHorEms = ServerTime()
		PedDtaFat = nullvalue(PedDtaFat)
		PedDtaFic = nullvalue(PedDtaFic)
        PedSts = Status_Pedido.ABERTO
        PedStsFin = Status_Financeiro.ABERTO
		PedDtaCrd.SetEmpty()
		PedStsAna.SetEmpty()
		PedVlrAgr = 0
		PedCodAgr = 0
		PedCnhEms.SetEmpty()
		PedCnhTraCod.SetEmpty()
		PedCnhFrt.SetEmpty()
		PedCnhVlr = 0
		PedStsCrd = Status_Autorizado.NAO_AUTORIZADO
		PedStsPrd.SetEmpty()
		PedDtaPrv.SetEmpty()
		PedBlq = Status_SimNao.Nao
		PedStsDigBlk = &PedStsDigBlk
    EndNew
EndFor

Commit


for &sdtPedidoProdutoItem in &sdtPedidoProduto
//For Each Order EmpCod, FilCod, PedCod, PedItmCod
//	Where EmpCod = &EmpCod
//	Where FilCod = &FilCod
//	Where PedCod = &PedCod
	&PedItmCod += 1
    new
		EmpCod = &EmpCod
        FilCod = &FilCod
        PedCod = &NovoPedCod
        PedItmCod = &PedItmCod
        PedQtdCan = 0

		ProCod = &sdtPedidoProdutoItem.ProCod
		ProGraCod = &sdtPedidoProdutoItem.ProGraCod
		PedProEstProCod = &sdtPedidoProdutoItem.ProEstProCod
		PedProEstProGraCod = &sdtPedidoProdutoItem.ProGraCod
		PedProEmbQtd = 0
		PedQtdEmb = &sdtPedidoProdutoItem.PedQtd
		PedQtd = &sdtPedidoProdutoItem.PedQtd
			
		//PedVlrCus = &sdtPedidoProdutoItem.PedVlrCus
		
		RetornaPrecoEspecialCliente.Call(&EmpCod, &NovPedCliCod, &sdtPedidoProdutoItem.ProCod, &sdtPedidoProdutoItem.ProGraCod, &NovTabColCod, &NovPedDtaEms, &EspPedVlrUnt)
		RetornaPrecoUnitarioTipo.Call(&EmpCod, &NovTabPrmCod, &sdtPedidoProdutoItem.ProCod, &sdtPedidoProdutoItem.ProGraCod, &NovTabColCod, &NovPedDtaEms, 0, &PedItmPrm)		
		&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &NovTabCod, &NovTabPrmCod, &sdtPedidoProdutoItem.ProCod, &sdtPedidoProdutoItem.ProGraCod, &NovTabColCod, &NovPedDtaEms, &PedDtaVct)
		&PedVlrUnt = &PedVlrTab
		
		if &EspPedVlrUnt < &PedVlrUnt and &EspPedVlrUnt > 0
			&PedItmDsc = 100 - ((&EspPedVlrUnt / &PedVlrUnt) * 100)
			&NoPedItmDsc = &PedItmDsc
		EndIF
	
		PedItmCmp = &PedItmPrm
		PedItmVenCod = 0
		PedVlrTab = &PedVlrTab
		PedVlrUnt = &PedVlrUnt
		PedItmDsc = &PedItmDsc
		
    EndNew
EndFor

commit

CriticasPedido.Call(&EmpCod, &FilCod, &NovoPedCod, TipoCriticaPedido.Digitado, &FunPesCod)

//GRAVA PREÇOS UNITARIOS CONFORME ALTERACAO NOS CAMPOS /COLUNA / TABELA
AtualizaPrecosPedidoVenda.Call(&EmpCod, &FilCod, &NovoPedCod, false)
	
//AtualizaEstoqueGerencialVenda.Call(&EmpCod, &FilCod, &NovoPedCod, &NovPedDtaEms, &FunPesCod, Status_Pedido.ABERTO)
AtualizaPedidoEstoqueVendidoComprado.Call(&EmpCod, &FilCod, &NovoPedCod)

&Mensagem = 'Gerado Pedido Número: ' + trim(str(&NovoPedCod))
]]></Source>
