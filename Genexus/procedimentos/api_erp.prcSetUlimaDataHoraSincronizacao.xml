      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso conced
	
	Do cAse
		CAse &DevTabCod = 'TUDOOFF'
			prcSetUlimaDataHoraSincronizacao2.Call(&DevRandon, 'CLIENTEOFF', &sdtRetornowbs)
			if &sdtRetornowbs.Sts = 'J200'
				prcSetUlimaDataHoraSincronizacao2.Call(&DevRandon, 'PEDIDOOFF', &sdtRetornowbs)
				if &sdtRetornowbs.Sts = 'J200'
					prcSetUlimaDataHoraSincronizacao2.Call(&DevRandon, 'PRODUTOOFF', &sdtRetornowbs)
					if &sdtRetornowbs.Sts = 'J200'
						prcSetUlimaDataHoraSincronizacao2.Call(&DevRandon, 'MARCAOFF', &sdtRetornowbs)
						if &sdtRetornowbs.Sts = 'J200'
							prcSetUlimaDataHoraSincronizacao2.Call(&DevRandon, 'ESTOQUEOFF', &sdtRetornowbs)
							if &sdtRetornowbs.Sts = 'J200'
								prcSetUlimaDataHoraSincronizacao2.Call(&DevRandon, 'FORMAPAGAMENTOOFF', &sdtRetornowbs)
								if &sdtRetornowbs.Sts = 'J200'
									For Each Order DeviceId, DevRandon
										Where DevRandon = &DevRandon
										
										DevAtu = false
										Exit
									EndFor
									
									Commit
								Endif
							EndIf
						Endif
					Endif
				Endif
			Endif
		
		CAse &DevTabCod = 'APAGA'
			//verifica id da sessao.
			For Each Order DeviceId, DevRandon, DevTabCod
				Where DevRandon = &DevRandon
				//	DeviceId
				//	DevRandon
				//	DevTabCod
				DevTabDtaUltSync = now()
				DevTabAtu = true
				&sdtRetornowbs.Sts = 'J200'
				&sdtRetornowbs.Obs = 'Sucesso na comunicacao'
			When none
				&sdtRetornowbs.Sts = 'E001'
				&sdtRetornowbs.Obs = 'Nao localizado Device'
			EndFor
			
			Commit
			
		Otherwise
			prcSetUlimaDataHoraSincronizacao2.Call(&DevRandon, &DevTabCod, &sdtRetornowbs)	
	EndCAse

Else
	&sdtRetornowbs.Sts = 'E002'
	&sdtRetornowbs.Obs = 'Nao autorizado Device'
EndiF
]]></Source>
