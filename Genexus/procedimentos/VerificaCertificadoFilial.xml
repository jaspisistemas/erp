      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


		
For each Order EmpCod, FilCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	
	&FilCerPsw = FilCerPsw
	&CaminhoCertificadoVarChar = &PastaDiretorioCertificado + FilCerNom.Trim()
	
	&File.Source = &CaminhoCertificadoVarChar
	If &File.Exists()
		Exit
	Else
		&FilCert = FilCert
		
		&LongVarchar = &FilCert.ToBase64String()
		
		&Directory.Source = &PastaDiretorioCertificado
		If not &Directory.Exists()
			&Directory.Create()
		EndIF
		
		&File.Source = &CaminhoCertificadoVarChar
		&File.Create()
		&File.FromBase64String(&LongVarchar) 
		&File.Close()
	Endif

	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
