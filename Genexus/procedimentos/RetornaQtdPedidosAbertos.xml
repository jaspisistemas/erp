      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem.SetEmpty()
&PedDtaEms = serverdate()
&PedDtaEms = &PedDtaEms.AddDays(-15)

For Each ORder EmpCod, FilCod,PedSts,LctAtuEst,LctTip,LctGerFin,LctAtuSal, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedSts = Status_Pedido.ABERTO
	Where PedDtaEms <= &PedDtaEms
	Where LctAtuEst = Status_EntradaSaida.Saida //SAIDA
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where LctGerFin = Status_SimNao.Sim //GERA FINANCEIRO
	Where PedVenCod = &PedVenCod when not &PedVenCod.IsEmpty()
	
	&Count += 1
	if &Count = 50
		Exit
	Endif
EndFor


Do case
	case &Count = 50
		&Mensagem = 'ALERTA: Existem +' + trim(str(&Count)) + ' pedidos c/ status ABERTO, emitidos à mais de 15 dias.'
	case &Count > 0
		&Mensagem = 'ALERTA: Existem ' + trim(str(&Count)) +  ' pedidos c/ status ABERTO, emitidos à mais de 15 dias.'
EndCase

]]></Source>
