      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem = ''

For Each order EmpCod, CatNom
	Where EmpCod = &EmpCod
	Where CatNom = &CatNom or CatCodImp = &CatNom
	Where CatCod <> &CatCod
	&Mensagem = 'Categoria Produto Já cadastrada Código: ' + trim(str(CatCod))
	Exit
EndFor
]]></Source>
