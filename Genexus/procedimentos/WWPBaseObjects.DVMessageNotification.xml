	in:&ButtonStickerHoverEnable, in:&ButtonsShowOnNonBlock, in:&ButtonCloseLabel,
	in:&ButtonStickerLabel, in:&NonBlockEnable, in:&NonBlockOpacity,
	in:&DesktopNotificationEnable,in:&DesktopNotificationFallBackEnable,
	in:&DesktopNotificationIconUrl, in:&DesktopNotificationTag,
