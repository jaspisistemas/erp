//&sdtProdutoPrecoItem.RepItm =  'N'
//Do CAse
//	CAse ProRepItm = true
//		&sdtProdutoPrecoItem.RepItm =  'S'
//	Case &TCon052_ServicoDuplicadoVenda and ProTIpDef = 'S' //SERVICO
//		&sdtProdutoPrecoItem.RepItm =  'S'
//	case &TCon053_ProdutoDuplicadoVenda = 'S'  and ProTIpDef <> 'S' //PRODUTO
//		&sdtProdutoPrecoItem.RepItm =  'S'//iif(ProRepItm = true or &TCon053_ProdutoDuplicadoVenda = 'S', 'S', 'N')
//EndCase

if not &inProGraRef.IsEmpty()	
	If &IsAumentar = false
		&PedQtd = -1
	Else
		&PedQtd = 1
	EndIF

	&auxPedQtd = &PedQtd
	
	&IsAchouProduto = false
	&ProCod = 0
	RetornaProdutoReferencia.Call(&EmpCod, &inProGraRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)
	if not &Mensagem.IsEmpty()
		&sdtRetornoWbsEtc.Sts = 'E999'
		&sdtRetornoWbsEtc.Obs = &Mensagem
		Return
	EndIF
	
	if &IsAchouProduto = true 
		do 'GetDadosProdutoGrade'
		&PedQtd += &AuxPedQtd
		if &PedQtd < 0
			&PedQtd = 0
		EndIF
		
		If &PedQtd <> &OLDPedQtd
			&PedQtdCan = &PedQtdCan + (&OLDPedQtd - &PedQtd)
		EndIF
	
		If &PedVlrUnt > 0				
			If (&ProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &ProGraCod = 1)
				do 'GravaItemPDV'				
			Else
				&sdtRetornoWbsEtc.Sts = 'E999'
				&sdtRetornoWbsEtc.Obs = 'Produto com Variação, é preciso inserir o Código da Variação!'
				return
			Endif
		Else				
			&sdtRetornoWbsEtc.Sts = 'E999'
			&sdtRetornoWbsEtc.Obs = 'Produto não cadastrado na tabela de Preço!'
			return
		EndIf
	EndIF
EndiF


Sub 'GravaItemPDV'
	
	if &PedQtd <= 0 and &PedItmCod > 0
		DeletaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &pedItmCod)
	Else
		GravaItemPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &ProCod, &ProGraCod, &PedQtd, &PedQtdCan, 0, &PedVlrUnt, &PedVlrTab, &PedItmDsc, &PedItmCmp, 0, &PedCodOciRefItm, &MensagemInserida, &MensagemAlterado, &wwpContextUserName)
	Endif
	get_qtditemcatalogo.Call(&DevRandon, &FilCod, &PedCod, &ProCod, &ProGraCod, &sdtRetornoWbsEtc)	
EndSub

Sub 'GetDadosProdutoGrade'	
    Do 'GetProduto'
	&PedQtd = 0
	Do 'GetProdutoPedido'
EndSub


Sub 'GetProdutoPedido'
	&PedItmCod = 0	
	
	If &ErroProduto <> 1
		For Each Order EmpCod, FilCod, PedCod, ProCod, ProGraCod, (PedItmCod) //TEM QUE SER ASSIM JDF.
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			
			&PedItmCod = PedItmCod
			&PedQtd = PedQtd
			&OldPedQtd = PedQtd
			&PedQtdCan = PedQtdCan
			&PedVlrUnt = PedVlrUnt
			&PedVlrTab = PedVlrTab
			&PedItmDsc = PedItmDsc
			&PedItmCmp = PedItmCmp
			Exit
		EndFor
		
		do 'GetPreco'
		Do 'GetDesconto'	
	EndIF

EndSub

Sub 'GetProduto'
	
	&ErroProduto = 0
	&ErroInativo = 0
	
    For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
	    Where ProCod = &ProCod
		where ProSts <> Status_Produto.EXCLUIDO
		
		&ProIsGra = ProIsGra
		&ProVlrCus = ProVlrCus
		
		RetornaEstoquePedido.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &PedSts, &EstLoc, &EstQtd, &EstSdo, &Mensagem)
		if not &Mensagem.IsEmpty()
			&sdtRetornoWbsEtc.Sts = 'E999'
			&sdtRetornoWbsEtc.Obs = 'Produto em Balanço, não pode ser Alterado! '	
			Return
		EndIF
		
		If ProSts = Status_Produto.INATIVO and &EstQtd <= 0
			&sdtRetornoWbsEtc.Sts = 'E999'
			&sdtRetornoWbsEtc.Obs = 'Produto Inativo com Estoque Zero! Produto:' + trim(ProRef)
			Return
		EndIf
		
	    Exit
	When none
		&sdtRetornoWbsEtc.Sts = 'E999'
		&sdtRetornoWbsEtc.Obs = 'Produto código: ' +trim(&inProGraRef) + ' não localizado!'
		Return
    EndFor
EndSub

Sub 'GetPreco'
	Do Case
		Case &LctRetCus = Status_SimNao.Sim and &PedVlrUnt <= 0
			&PedVlrUnt = &ProVlrCus
			&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
			
		Case (&LctInfPrc = Status_SimNao.Nao and &ProReqVlr <> true) or &PedVlrUnt <= 0
			&PedVlrUnt = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
			&PedVlrTab = &PedVlrUnt
	EndCase
EndSub

Sub 'GetDesconto'
	&PedItmPrm = RetornaPrecoUnitarioTipo.Udp(&EmpCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedItmDsc)
EndSub
]]></Source>
