      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PesInsEst = ''
For each Order EmpCod,PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	
	If PesTip = TipoPessoa.JURIDICA
		If not PesInsEst.IsEmpty()
			&PesInsEst = PesInsEst
		Else
			&PesInsEst = 'ISENTO'
		EndIF
	Else		
		//Pessoa Física e produtor rural
		Do 'Propriedade'
		If &PesInsEst.IsEmpty()
			If not PesCadPro.IsEmpty()
				&PesInsEst = PesCadPro
			Else
				&PesInsEst = 'ISENTO'
			EndIF
		EndIf
	EndIF
EndFor

Sub 'Propriedade'
	For each Order EmpCod,PesCod,PesPrpCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&PesInsEst = PesPrpIns
		exit
	EndFor
EndSub
]]></Source>
