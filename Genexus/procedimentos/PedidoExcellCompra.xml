        <Source><![CDATA[
&IsErro = false
&NomArq = &NomeArquivo.trim() + '.xlsx'
&Planilha.Open(&NomArq)
 
 
if &Planilha.ErrCode <> 0
	&IsErro = true
    Return
EndIf

for each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	where PedCod = &PedCod
	where FilCod = &Filcod
	&PedClicod = PedCliCod	 
	exit
endfor

&Planilha.AutoFit = 1
&Linha = 1
&Planilha.Cells(&Linha,01,2,2)
&Planilha.Cells(&Linha,03).Size = 19
&Planilha.Cells(&Linha,03).Text = 'PLANILHA DO PEDIDO : ' + &PedCod.ToString().Trim()
&Linha += 2
   
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon005_TipoCliente, &TipoCliente_369)

   // EMITENTE 
 for each Order EmpCod, FilCod
	 Where EmpCod = &EmpCod
		where FilCod = &filcod
		&FilBasImp = FilBasImp
		
	&Planilha.Cells(&Linha,02).Text = 'EMITENTE'	
	&Planilha.Cells(&Linha,03).Size = 13
	&Planilha.AutoFit = 1
	&Planilha.Cells(&Linha,03).Text = FilRaz.ToString().Trim()
    &Linha+= 1
	
    &Planilha.Cells(&Linha,02).Text = 'ENDEREÇO'
    &Planilha.Cells(&Linha,03).Text = FilLog
    &Planilha.Cells(&Linha,04).Text = 'Nº  ' + FilNro.ToString().Trim()
    &Planilha.Cells(&Linha,05).Text = 'CIDADE'	
    &Planilha.Cells(&Linha,06).text = FilCidNom.Trim()
	&Linha+= 1
	
    &Planilha.Cells(&Linha,02).Text = 'CNPJ'
    &Planilha.Cells(&Linha,03).Text = FilCpj
    &Planilha.Cells(&Linha,04).Text = 'IE'	
    &Planilha.Cells(&Linha,05).text = FilInsEst
	&Linha+= 1
	 
    &Planilha.Cells(&Linha,02).Text = 'TEL'
    &Planilha.Cells(&Linha,03).Text = FilFonNum
	&Linha+= 1	
	exit
endfor

// DESTINATARIO
For each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	where PesCod = &PedClicod
	&Linha+= 1
	&Planilha.Cells(&Linha,03).Size = 13
//	&Planilha.AutoFit = 1
	&Planilha.Cells(&Linha,02).Text = 'FORNECEDOR'
	&Planilha.Cells(&Linha,03).Text = PesRaz
	exit
endfor

// PRODUTOS
for each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &filcod
	where PedCod = &PedCod
	
	&LctBasImpCod = LctBasImpCod
	&PedCliCidUfeCod = PedCliCidUfeCod
	&PedCliGruImpCod = PedCliGruImpCod
	If &TipoCliente_369 = 'S'
		&PedTpcVlr = PedTpcVlr
	Else
		&PedTpcVlr = 0
	EndIF

	&LctAtuSal = LctAtuSal
	
	&Linha+= 1 
	&Planilha.Cells(&Linha,05).Text = 'EMISSÃO'
	&Planilha.Cells(&Linha,06).Text = PedDtaEms.ToString()
	&Linha+= 1
	&Planilha.Cells(&Linha,05).Text = 'FATURAMENTO'
	&Planilha.Cells(&Linha,06).Text = PedDtaFat.ToString()
	&Linha+= 1
	
	&Planilha.AutoFit = 1
	
	if &LctAtuSal = 'C'
		&Planilha.Cells(&Linha,01).Text = 'COD.FORN.'
	endif
	&Planilha.Cells(&Linha,02).Text = 'PRODUTO'
	
	&Planilha.Cells(&Linha,03).Text = 'DESCRIÇÃO'
    &Planilha.Cells(&Linha,04).Text = 'QTDE'
	&Planilha.Cells(&Linha,05).Text = 'MARCA'
	&Planilha.Cells(&Linha,06).Text = 'NCM'
	
	&Planilha.Cells(&Linha,07).Text = 'VLR.UNITÁRIO'
	&Planilha.Cells(&Linha,08).Text = 'TOT.LÍQUIDO'
	&Planilha.Cells(&Linha,09).Text = 'CÓD.BARRAS'
	if &EmlPedImp = true
		RetornaPercentualUnitario.Call(EmpCod, FilCod, PedCod, &AcrescimoPercentual, &DescontoPercentual)
		&Planilha.Cells(&Linha,10).Text = 'UNT.FINAL'
		&Planilha.Cells(&Linha,11).Text = 'TOT.FINAL'
		&Planilha.Cells(&Linha,12).Text = '(IMPOSTOS)'
	EndIF

	&Linha+= 1
	
	&IsNotas = false
	RetornaNotasPedido.Call(EmpCod, FilCod, PedCod, &DadosNota)
	if not &DadosNota.IsEmpty()
		&IsNotas = true
	EndIf
	
	for each Order EmpCod, FilCod, PedCod, ProNom
		Where PedQtd > 0
		&ProCod = ProCod		
		
		if &LctAtuSal = 'C'
			Do 'getCodFornecedor'
			&Planilha.Cells(&Linha,01).Size = 9
			&Planilha.Cells(&Linha,01).Text = &ProForProCod
		endif
		
			
		&Planilha.Cells(&Linha,02).Size = 9
		&Planilha.Cells(&Linha,02).Text = ProGraRef
	    &Planilha.Cells(&Linha,03).Size = 9
		&Planilha.Cells(&Linha,03).Text = ProNomGra
		&Planilha.Cells(&Linha,04).Size = 9
		&Planilha.Cells(&Linha,04).Number = PedQtd
		
		&Planilha.Cells(&Linha,05).Size = 9
		&Planilha.Cells(&Linha,05).Text = MarNom
		
		&Planilha.Cells(&Linha,06).Size = 9
		&Planilha.Cells(&Linha,06).Text = NcmCod.ToString()
		
		&Planilha.Cells(&Linha,07).Size = 9
	    &Planilha.Cells(&Linha,07).Number = PedVlrUntComDsc	
		
		&Planilha.Cells(&Linha,08).Size = 9
	    &Planilha.Cells(&Linha,08).Number = PedVlrItmComDsc
		
		&Planilha.Cells(&Linha,09).Size = 9
	    &Planilha.Cells(&Linha,09).Text = trim(toformattedString(ProGraBar))
		
		If &EmlPedImp = true
			&AuxImpostosTotal = 0
			&TotalItem = 0
			&ImpostosTotal = 0
			RetornaTotalImposto.Call(EmpCod, FilCod, PedCod, ProCod, &FilBasImp, &LctBasImpCod, &PedCliCidUfeCod, &PedCliGruImpCod, ProCatCod, PedVlrUntComDsc, PedQtd, &PedTpcVlr, &IsNotas, &AuxImpostosTotal, &IsImpostoCadastrado)
			if &AuxImpostosTotal > 0 and PedQtd > 0
				&ImpostosTotal = &AuxImpostosTotal / PedQtd
				&ItemImpostosTotal = &AuxImpostosTotal / PedQtd
			EndIF
			
			&ImpostosTotal += PedVlrUntComDsc
			
			&TotalAcrescimoMoeda = round(PedVlrItm * &AcrescimoPercentual, 2) / PedQtd		
			&TotaDescontoMoeda = round(PedVlrItm * &DescontoPercentual, 2) / PedQtd
			
			&ImpostosTotal += &TotalAcrescimoMoeda
			&ImpostosTotal -= &TotaDescontoMoeda
			
			&TotalItem =  PedVlrItm + &AuxImpostosTotal
			
			&TotalImpostosPedido += &AuxImpostosTotal
			&ImpostosTotal = round(&ImpostosTotal, 4)
			
			&Planilha.Cells(&Linha,10).Size = 9
	    	&Planilha.Cells(&Linha,10).Number = &ImpostosTotal	
			
			&Planilha.Cells(&Linha,11).Size = 9
	    	&Planilha.Cells(&Linha,11).Number = &ImpostosTotal*PedQtd
			
			&Planilha.Cells(&Linha,12).Size = 9
	    	&Planilha.Cells(&Linha,12).Number = &ItemImpostosTotal
			
			
//			&Planilha.Cells(&Linha,09).Size = 9
//	    	&Planilha.Cells(&Linha,09).Number = &TotalItem
			
		EndIF
		
		&Linha+= 1
	endfor


	&PedVlrLiq = PedVlrLiq 
	
	//If PedVlrLiq <> PedVlrBrt		
		if (PedVlrGnre.IsEmpty() or PedVlrGnre.IsNull()) and &EmlPedImp = true and &TotalImpostosPedido > 0
			&PedVlrLIq += &TotalImpostosPedido
		EndIF
		
	//Else
		//if &EmlPedImp = true and &TotalImpostosPedido > 0
		//	&PedVlrLIq += &TotalImpostosPedido
		//EndIF
	//EndIF
endfor

&Linha+= 1
&Planilha.Cells(&Linha,03).Size = 13
&Planilha.Cells(&Linha,03).Text = 'VALOR TOTAL: ' + &PedVlrLiq.ToString().Trim()

&Planilha.Save()
&Planilha.Close()
//return

Sub 'getCodFornecedor'
	&ProForProCod = ''
	For each Order EmpCod, ProCod, ProForCod
		where ProForCod = &PedClicod
		where ProCod = &ProCod
		&ProForProCod = ProForProCod	    
	endfor
endsub
]]></Source>
