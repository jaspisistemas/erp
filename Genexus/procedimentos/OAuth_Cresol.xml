      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[/*
ENDPOINT com funcionalidade de gerar um token necessário para consumir APIs do CRESOL.
	° O tempo de vida de um token gerado é de cinco minutos. Com isso, é possível realizar
	um número determinado de requisições, de acordo com o rate limit de cada api.
		Rate Limit: 5 chamadas por minuto, ou uma chamada a cada 12 segundos.
		
Neste ENDPOINT, o sistema irá definir alguns valores padrões e montar o body da requisição
em formato x-ww-form-urlencoded. Posteriormente, montará o header da requisição e adicionar
o certificado referente a conta bancária na requisição. Após a adição, o sistema irá executar
um POST na URL referente ao ambiente de produção do banco CRESOL.

Responses:
	Sucesso:
		Code 200 = Sucesso. Token Emitido.
		
	Erros:
		Code 400 = Requisição com formato inválido, por exemplo erro de semântica.
		Code 403 = Requisição de participante autenticado que viola alguma regra de autorização. Verifique com o suporte do banco.
		Code 404 = Recurso solicitado não foi encontrado.
		Code 503 = Serviço não disponível no momento. O endpoint neste caso não funciona mais, ou está em manutenção.	
*/

Do 'GetLocalCobranca'

//Define valores padrões
&DataHora	= ServerNow()
&Mensagem.SetEmpty()

//Adiciona em uma variavel o body da requisição
//em formato x-ww-form-urlencoded
&xwwformurlencoded	= 'grant_type=password'
&xwwformurlencoded += '&client_id=cresolApi'
&xwwformurlencoded += '&client_secret=cr3s0l4p1' 
&xwwformurlencoded += '&scope=' + &scope
&xwwformurlencoded += '&username=' + &client_id
&xwwformurlencoded += '&password=' + &client_secret

//Configura os Headers e adiciona o body
&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
&HttpClient.AddHeader('Connection', 'keep-alive')
&HttpClient.AddHeader('Content-Type', 'application/x-www-form-urlencoded')
&HttpClient.AddString(&xwwformurlencoded)

//HOMOLOGAÇÃO &HttpClient.Execute(HttpMethod.Post, 'https://auth-dev.governarti.com.br/auth/realms/cresol/protocol/openid-connect/token')
&HttpClient.Execute(HttpMethod.Post, 'https://cresolauth.governarti.com.br/auth/realms/cresol/protocol/openid-connect/token')
If &HttpClient.ErrCode = 0
	PadraoUsuarioHora.Call('G', 'CRESOL_TOKENOAUTH', &ContextPesCod, &EmpCod, &HttpClient.ToString(), ServerDate(), ServerNow(), 'T')
	&OAuthCresol_Response.FromJson(&HttpClient.ToString())
	Do 'GravaAccessToken'
Else
	PadraoUsuarioHora.Call('G', 'CRESOL_TOKENOAUTH_ERRO', &ContextPesCod, &EmpCod, &HttpClient.ToString(), ServerDate(), ServerNow(), 'T')
	&OAuthCresol_Erro.FromJson(&HttpClient.ToString())
	&Mensagem	= &OAuthCresol_Erro.error + IIf(&OAuthCresol_Erro.error_description.IsEmpty(), '', ' - ' + &OAuthCresol_Erro.error_description)
EndIf

Sub 'GetLocalCobranca'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&client_id	= CtaBanPixCliId
		&client_secret	= CtaBanPixCliSec
		&scope	= CtaBanPixEsc
		
		Exit
	EndFor

EndSub

Sub 'GravaAccessToken'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&CbrChaTra	= &OAuthCresol_Response.access_token
		CbrChaTra	= &OAuthCresol_Response.access_token
		CbrChaTraVct	= &DataHora.AddSeconds(&OAuthCresol_Response.expires_in)
		
		Exit
	EndFor
	
EndSub
]]></Source>
