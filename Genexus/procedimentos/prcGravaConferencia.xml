      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, PedCod, PedConProCod, PedConProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedConProCod = &PedConProCod
	Where PedConProGraCod = &PedConProGraCod
	
	PedConQtd += &PedConQtd
	PedConDtaHor = serverNow()
	
	if PedConQtd <= 0
		delete 
	Endif
	
	Exit
	
When None
	if &PedConQtd > 0
		For Each Order EmpCod, FilCod, PedCod, (PedConItm)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			&PedConItm = PedConItm
			Exit
		EndFor
		&PedConItm += 1
		
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			PedConItm = &PedConItm
			
			PedConProCod = &PedConProCod
			PedConProGraCod = &PedConProGraCod
			
			PedConQtd = &PedConQtd
			PedConDtaHor = serverNow()
		Endnew
	Endif
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
