      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	if &sdtImpressoras.idImpressao.IsEmpty()
		&EtqCod = 'API_'+trim(str(&wwpContext.EmpCod)) + trim(str(&wwpContext.FilCod)) + trim(Str(&wwpContext.PesCod))
		GravaProdutoEtiqueta.Call('DEL', &EtqCod, 0, '', 0, '', 0, '', '', 0,'',0, '') //DELETA TUDO
	Else
		&EtqCod = &sdtImpressoras.idImpressao
	EndIf
	&sdtRetornowbs.Detalhes = &EtqCod
	
	Do CAse
		CAse &sdtImpressoras.oQueFazer = 'DEL' and not &sdtImpressoras.idImpressao.IsEmpty()
			GravaProdutoEtiqueta.Call('DEL', &sdtImpressoras.idImpressao, &sdtImpressoras.empImpCod, '', 0, '', 0, '', '', 0,'',0, '') //DELETA TUDO
			&sdtRetornowbs.sts = 'J200'
			if &sdtImpressoras.idImpressao.IsEmpty()
				&sdtRetornowbs.Obs = 'Fila de impressão limpa!'
			else
				&sdtRetornowbs.Obs = 'Item removido com sucesso!'
			Endif
		
		Case &sdtImpressoras.oQueFazer = 'ADD' //ADD ou IMP
			//GRAVA ETIQUETA
			if not &sdtImpressoras.ProRef.IsEmpty()
				&sdtRetornowbs.sts = 'J200'
				&sdtRetornowbs.Obs = 'Produto adiciona na fila de impressão!'
				For Each Order EtqCod, (EtqItmCod)
					Where EtqCod = &EtqCod
					&EtqItmCod = EtqItmCod
					Exit
				EndFor
				&EtqItmCod += 1
				GravaProdutoEtiqueta.Call('ADD', &EtqCod, 0, &sdtImpressoras.ProRef, &sdtImpressoras.ProCod, &sdtImpressoras.ProNom, &sdtImpressoras.ProGraCod, &sdtImpressoras.ProBar, &sdtImpressoras.ProGraNom, &sdtImpressoras.ProQtdEmb,&sdtImpressoras.EstLotCod, &sdtImpressoras.QtdEtq, '')
				&sdtRetornowbs.qtdPed = &EtqItmCod
			Endif
		
		Case &sdtImpressoras.oQueFazer = 'IMP'
			&Random = (Random() * 10000000)
			&ArquivoFisico  =  'api_EtiqPro' + trim(&EtqCod) + trim(str(&Random)) + '.pdf'	
			
			Do CAse
				CAse &sdtImpressoras.TipEtiqueta = 'R10'
					RELJAS048_R10_Direta.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &EtqCod, &sdtImpressoras.TipEtiqueta, &sdtImpressoras.EmpImpCod, &wwpContext.PesCod)
					&sdtRetornowbs.sts = 'J200'
					&sdtRetornowbs.Obs = 'Impressão solicitada, aguarde início da impressão!'
				CAse &sdtImpressoras.TipEtiqueta = 'R05' //DIRETA GONDOLA 
					RELJAS048_R05_Direta.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &EtqCod, &sdtImpressoras.TipEtiqueta, &sdtImpressoras.EmpImpCod, &wwpContext.PesCod)
					&sdtRetornowbs.sts = 'J200'
					&sdtRetornowbs.Obs = 'Impressão solicitada, aguarde início da impressão!'
				Otherwise
					&sdtRetornowbs.sts = 'E999'
					&sdtRetornowbs.Obs = 'Modelo de etiqueta não disponivel para a impressao direta!'
			EndCase
		
			if &sdtImpressoras.proNom = 'DEL'
				GravaProdutoEtiqueta.Call('DEL', &sdtImpressoras.idImpressao, 0, '', 0, '', 0, '', '', 0,'',0, '') //DELETA TUDO
			Endif
	EndCase

Endif
]]></Source>
