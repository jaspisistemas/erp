      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &MrkItmCod.IsEmpty()
	return
endif


&sdtDadosProduto.FromJson(&LongVarchar)

For Each Order EmpCod, MrkCod
	Where EmpCod = &EmPCod
	Where MrkCod = &MrkCod
	Where MrkItmCod = &MrkItmCod
	
//		MrkProCod
//		MrkProGraCod
		MrkProNom = &sdtDadosProduto.title
		MrkProQtd = &sdtDadosProduto.available_quantity
		MrkProVlr = &sdtDadosProduto.price
		MrkUrlImgPri = &sdtDadosProduto.thumbnail
		MrkProSts = iif(&sdtDadosProduto.status = 'paused', Status_AtivoInativo.INATIVO, Status_AtivoInativo.ATIVO)
		MrkItmLogVarchar = &LongVarchar
		
		MrkItmLink = &sdtDadosProduto.permalink
		MrkItmStsInt = StatusMarketplace.Integrada
	Exit
When none
	New
		EmpCod = &EmPCod
		MrkCod = &MrkCod
		MrkItmCod = &MrkItmCod
		MrkItmStsInt = StatusMarketplace.Pendente
//		MrkItmSku
//		MrkProCod
//		MrkProGraCod
		MrkProNom = &sdtDadosProduto.title
		MrkUrlImgPri = &sdtDadosProduto.thumbnail
		MrkProQtd = &sdtDadosProduto.available_quantity
		MrkProVlr = &sdtDadosProduto.price
		MrkItmLink = &sdtDadosProduto.permalink
//		MrkProSts
	EndNew
EndFor

Commit


For &sdtDadosProdutoAttributos in &sdtDadosProduto.attributes
	For Each Order EmpCod, MrkCod, MrkItmCod, MrkAttCod
		Where EmpCod = &EmPCod
		Where MrkCod = &MrkCod
		Where MrkItmCod = &MrkItmCod
		Where MrkAttCod = &sdtDadosProdutoAttributos.id
		MrkAttNom = &sdtDadosProdutoAttributos.name
		MrkAttValCod = iif(&sdtDadosProdutoAttributos.value_id.ToUpper() = 'NULL', '', &sdtDadosProdutoAttributos.value_id)
		MrkAttVal = &sdtDadosProdutoAttributos.value_name
	When none
		
		new
			EmpCod = &EmPCod
			MrkCod = &MrkCod
			MrkItmCod = &MrkItmCod
			MrkAttCod = &sdtDadosProdutoAttributos.id
			MrkAttNom = &sdtDadosProdutoAttributos.name
			MrkAttValCod = iif(&sdtDadosProdutoAttributos.value_id.ToUpper() = 'NULL', '', &sdtDadosProdutoAttributos.value_id)
			MrkAttVal = &sdtDadosProdutoAttributos.value_name
		ENdNew
	EndFor
EndFor
]]></Source>
