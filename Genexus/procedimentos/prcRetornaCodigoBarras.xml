      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&OrigemProBar.SetEmpty()

For Each Order EmpCod, ProCod
	Where EmpCod = &OrigemEmpCod 
	Where ProCod = &OrigemProCod
	
	if Substr(ProBar,1, 3) <> '333'
		validaEAN13.Call(ProCod, ProBar, &NEwProBar, &Mensagem)
	
		&OrigemProBar = ProBar		
	Endif
	
	Exit
EndFor
]]></Source>
