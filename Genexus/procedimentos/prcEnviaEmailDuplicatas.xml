      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&HojeData = serverdate()

&sdtAgendadorFiltros.FromXml(&AgdFiltro)
For &sdtAgendadorFiltrosItem in &sdtAgendadorFiltros
	Do Case
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDDUPDIAS'
			&Dias = val(&sdtAgendadorFiltrosItem.AgdValue)
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDDUPTIP'
			&TipoDuplicatas = &sdtAgendadorFiltrosItem.AgdValue.Trim()
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'AGDDUPPESCOD'
			&PEsCod = val(&sdtAgendadorFiltrosItem.AgdValue.Trim())
	EndCase
EndFor

&DataLimite =  &HojeData + &Dias

For Each Order EmpCod, CreRecPag,CreVlrDup,FilCod, CreCliCod
	Where EmpCod = &EmpCod
	Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
	Where CreDtaVct >= &HojeData and CreDtaVct <= &DataLimite
	Where CreRecPag = ReceberPagar.Receber
	Where CreSts <> Status_Duplicata.CANCELADA
	Where CreCbrAvsVct.IsEmpty() or CreCbrAvsVct.IsNull() or CreCbrAvsVct = Status_SimNao_PS.SIM
	Where (CreCbrImp = TipoImpressao.GerarBoleto) or (CreCbrImp = TipoImpressao.ImprimirBoleto and CreBloNro <> '')
	Where CreVlrDup = CreVlrSdo
	
	RetornaEnvioEmail.call(EmpCod, FilCod, CreCod, &IsJaEnviada)
	
	if &IsJaEnviada = false
		msg('Duplicata Sequencia: ' + trim(str(CreCod)), Status)
		&EmlAss = 'Boleto da ' + trim(FilRaz)
		&sdtBoleto.Clear()
		&AuxCreCliCod = CreCliCod
		&FilCod = FilCod
		&sdtBoletoItem = new()
		&sdtBoletoItem.CreEmpCod = EmpCod
		&sdtBoletoItem.CreFilCod = FilCod
		&sdtBoletoItem.CreCod = CreCod
		&sdtBoleto.Add(&sdtBoletoItem)
		
		do 'EmailCliente'
		do 'GravaEnvio'
	Endif
EndFor


Sub 'GravaEnvio'
	If &SdtEmail.Count > 0 and &sdtBoleto.Count > 0
		GravaEnvioEmail.Call(&EmpCod, &FilCod, 0, 0, TipoContaEmail.Email_Financeiro, &EmlAss, TipoSolicitacao.EnviaAvisoVencimento, &PesCod, &Mensagem, &SdtEmail, &sdtBoleto)
	EndIF
	
	&SdtEmail.Clear()
EndSub

sub 'EmailCliente'
	&SdtEmail.Clear()	
	RetornaEmailFinanceiro.call(EmpCod, &AuxCreCliCod, &SdtEmail)	
EndSub
]]></Source>
