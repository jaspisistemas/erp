      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf
&PesRaz = &Context.PesRaz


For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 0
MT 0
padraoUsuario.Call('L', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
&sdtTipEtq.FromJson(&PadObs)

&OcsItm = 0

for Each Order EmpCod, OcsCod
	Where EmpCod = &EmpCod
	Where OcsCod = &OcsCod
	
	&MensagemCorte = 'ORDEM: ' + trim(str(&OcsCod))
	if not OcsNfeNum.IsEmpty()
		&MensagemCorte += ' NF.ENTR: ' + trim(toformattedString(OcsNfeNum))
	Endif
	
	if not &OcsProNroCor.IsEmpty()
		for Each Order EmpCod, OcsCod, OcsItm
			Where OcsProNroCor = &OcsProNroCor
			&OcsItm = OcsItm
			
			Exit
		EndFor
	EndIf
	Exit
Endfor

For &sdtTipEtqitem in &sdtTipEtq
	&auxPesRaz = &sdtTipEtqitem.CD.Trim() + ' - ' + &sdtTipEtqitem.DES.Trim()
	
	for Each Order EmpCod, OcsCod, OcsItm
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		Where OcsItm = &OcsItm when not &OcsItm.IsEmpty()
		
		&AuxOcsProNroCor = trim(OcsProNroCor) + ' - ' + trim(OcsProGraNom)
		
		&Count += 1
		if &Count = 1
			print Espaco
		Endif
	
		print Menu
		&i = 0
		&AuxOcsEtpItm = 21	
		
		for Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
			Where OcsEtpItm <= 20
			
			&i += 1
			&OcsEtpGrupNom2.SetEmpty()
			&OcsEtpGrupNom = padL(trim(str(OcsEtpItm)), 2, '0') + ' - '+ trim(OcsEtpGrupNom)
			
			RetornaNomeEtapaOrdem.Call(EmpCod, OcsCod, OcsItm, &AuxOcsEtpItm, &OcsEtpGrupNom2)
			
			&AuxOcsEtpItm += 1
			
			Print Detalhe1
		EndFor
		
		&OcsEtpGrupNom2.SetEmpty()
		&OcsEtpGrupNom.SetEmpty()
		
		Do while &i <= 19
			Print Detalhe1
			&i += 1
		EndDo
		print Total
		
		if &Count = 3
			&Count = 0
			eject
		Else
			print Tesoura
		Endif
	EndFor

EndFor
]]></Source>
