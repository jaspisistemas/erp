      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GetDados
For each order EmpCod,FilCod,CreCod
	where EmpCod = &EmpCod
	where FilCod = &FilCod
	where CreCod = &CreCod
	where CreSts <> Status_Duplicata.CANCELADA
	where CreVlrSdo > 0
	&CreCliCod = CreCliCod
	&CreBloNro = CreBloNro
	&OldCreDtaVct = CreDtaVct
	&CreCbrCtaBanBanCod = CreCbrCtaBanBanCod
	Do 'GravaObs'
	&Mensagem.SetEmpty()
	Do case
		case CreCbrCtaBanBanCod = '748' //Sicredi
			InstrucaoBoletoApiECommerce.call(&EmpCod,&FilCod,&CreCod,ComandoInstrucao.ALTERACAO_VENCIMENTO,complementoInstrucao.DESCONTO,&NovCreDtaVct,'',&Mensagem,&MsgSucesso)
			if not &Mensagem.isEmpty()
				&IsErro = true
			EndIf
			
		case CreCbrCtaBanBanCod = '999' //JASPI PAGAMENTOS ZOOP
			
			CreDtaVct = &NovCreDtaVct
			CreBloNro.SetEmpty()
			CreDtaRet.SetEmpty()
			
		otherwise
			&IsErro = true
			&Mensagem = 'Não implementado atualização de vencimento para o banco ' + CreCbrCtaBanBanCod + '. Contate o suporte JASPI!'
	EndCase
	exit
when none
	&IsErro = true
	&Mensagem = 'Não foi possível atualizar este boleto. Contate o suporte JASPI!' //ja ta pago?
EndFor


if &CreCbrCtaBanBanCod = '999' //zoop
	commit
	Do 'RegistraZoop'
EndIf


Sub 'GravaObs'
	
	&CreCobObs = 'Bloqueto anterior: ' + &CreBloNro + ', Vencimento anterior: ' + &OldCreDtaVct.ToFormattedString() + '. ATUALIZADO PELA "AREACLIENTE"'
	GravaCobranca.Call(&EmpCod,&FilCod,&CreCod,&CreCobObs,0,0,&NovCreDtaVct,'00:00:00', TipoObservacaoDuplicata.INTERNA)
	
EndSub

Sub 'RegistraZoop'
	
	ValidaCliente.call(&EmpCod, &FilCod, &CreCliCod, &IsErro, &Mensagem)
	if &IsErro = false
		GeraBoletoApi_ZoopCliente.Call(&EmpCod, &FilCod, &CreCliCod, &IsErro, &Mensagem)
	Endif
	if &IsErro = false
		GeraBoletoApi_ZoopDuplicata.Call(&EmpCod, &FilCod, &CreCod, &IsErro, &Mensagem)
	Endif

	if &IsErro = false
		&Mensagem.SetEmpty() //volta msg 201 registrado com sucesso
	EndIf
	
EndSub
]]></Source>
