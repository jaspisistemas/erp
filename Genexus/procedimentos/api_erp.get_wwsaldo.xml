<Object parentGuid="2029c88d-bc03-4d0a-89d8-cf9907782d43" user="WINJEAN\jeanfae" versionDate="2025-03-03T21:12:34.0000000Z" lastUpdate="2025-02-28T20:25:24.0000000Z" checksum="8e6b6a4c9b2e1cfa6cdf0ca8454dce35" fullyQualifiedName="api_erp.get_wwsaldo" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="e979c53e-a868-4d54-bd8f-d1ff5b87db8a" name="get_wwsaldo" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_wwsaldo" parent="api_erp.Financeiro" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)


if &IsAcessoConcedido = true //Acesso concedido
		
	&wwSaldo.qtd = 0
	
	if &inDataBase <= 0
		&DataBase = serverdate()
	Else
		TimestampToDate.Call(&inDataBase, &DataBase)
	Endif

	//PRECISA VERIFICAR QUAL FILIAL USUARIO TEM ACESSO, POR HORA ASIM PARA TESTE
	For Each Order EmpCod, FilCod
		Where EmpCod = &wwpContext.EmpCod
		&CollFilCod.Add(FilCod)
	EndFor
	//PRECISA VERIFICAR QUAL FILIAL USUARIO TEM ACESSO
	
	
	SaldoTotaisMonitoraSaldo.Call(&wwpContext.EmpCod, &CollFilCod, &wwpContext.PesCod, &DataBase, &TotSdoEnt,&TotSdoSai,&TotSdoDia,&TotSdoAtu)
	&wwSaldo.tot = trim(&TotSdoAtu.ToFormattedString())
	&wwSaldo.totEntrada = trim(&TotSdoEnt.ToFormattedString())
	&wwSaldo.totSaida = trim(&TotSdoSai.ToFormattedString())
	
	For each Order EmpCod, CtaBanSts, CtaBanOrd, CtabanCod
		Where EmpCod = &wwpContext.EmpCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO

		&CtabanCod = CtabanCod
		
////		&CtaBanFilCod = CtaBanFilCod
////		Do 'GetFilial'
////		&CtaFecDta = CtaFecDta
////		&ConSdoEnt = 0
////		&ConSdoSai = 0
////		&ConSdoFut = 0

		If &wwpContext.PesCod > 0
			Do 'ValidaPermisaoConta'
		Else
			&IsAutorizado = True
		EndIf

		If &IsAutorizado = True
					
			For each Order EmpCod,CtabanCod,(SdoDta)
				Where SdoDta <= &DataBase
				
				//							&SdoDta = SdoDta
				//							&SdoAnt = SdoAnt
				//							&SdoEnt = SdoEnt
				//							&SdoSai = SdoSai
				//							&SdoDia = SdoDia
				&SdoAtu = SdoAtu
				
				Exit
			When none
				//							&SdoDta = &DataBase
				//							&SdoAnt = 0
				//							&SdoEnt = 0
				//							&SdoSai = 0
				//							&SdoDia = 0
				&SdoAtu = 0			
			EndFor
			////			&SdoEnt.ForeColor = rgb(0,0,255)
			////			&SdoSai.ForeColor = rgb(255,0,0)
			////			&ConSdoFut = (&SdoAtu+&ConSdoEnt) - &ConSdoSai			
			
			If (&ComSaldo = True and &SdoAtu <> 0) or &ComSaldo = false
				&wwSaldo.qtd += 1
				
				&wwSaldoConta = new()
				&wwSaldoConta.Cod = CtabanCod
				if not CtaBanNomExib.IsEmpty() and not CtaBanNomExib.IsNull()
					&wwSaldoConta.Nom = CtaBanNomExib
				Else
					&wwSaldoConta.Nom = CtaBanNom
				Endif
				////			SaldoAConferir.call(EmpCod,CtabanCod,&ConSdoEnt,&ConSdoSai)
				
				
				&wwSaldoConta.vlr = trim(&SdoAtu.ToFormattedString())
				&wwSaldoConta.tip = CtaBanTip.ToFormattedString()
				
				////	&Extrato = !'<i class="far fa-file-pdf"></i>'
				////	&Transferencia = !'<i class="fas fa-sync"></i>'
				////	&FechaAbreCaixa = !'<i class="fas fa-euro-sign"></i>'
				////	If (&CtaBanTip <> 'PDV' AND &CtaBanTip <> 'Motorista')
				////		&FechaAbreCaixa.Class = !'Attribute'
				////	Else
				////		&FechaAbreCaixa.Class = !'Invisible'
				////	Endif
				
				////			If &ConSdoFut <> &SdoAtu
				////				&ConSdoFut.ForeColor = rgb(255,0,0)
				////			Else
				////				&ConSdoFut.ForeColor = rgb(0,0,0)
				////			EndIf
				
				&wwSaldo.contas.Add(&wwSaldoConta)
			EndIf		
		EndIf
	EndFor
Endif


Sub 'ValidaPermisaoConta'

	&IsAutorizado = False
	For each Order EmpCod, CtabanCod, CtaFunCod
		Where EmpCod = &wwpContext.EmpCod
		Where CtabanCod = &CtaBanCod
		Where CtaFunCod = &wwpContext.PesCod
		Where CtaFunIsCx <> Status_SimNao.Nao
		&IsAutorizado = True
		exit
	EndFor

EndSub
]]></Source>
