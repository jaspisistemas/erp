      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVAR OS LOTES
For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstLotCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod 
	Where ProGraCod = &ProGraCod
	Where EstLotQtd <> 0
	
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		BalCod = &BalCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		BalLotCod = EstLotCod
		BalLotQtd = 0
		BalLotQtdAnt = EstLotQtd
		BalLotVct = EstLotVct
		BalLotFab = EstLotFab
		BalLotVctAnt = EstLotVct
	When Duplicate
		BalLotQtdAnt = EstLotQtd
		BalLotVctAnt = EstLotVct
		BalLotFabAnt = EstLotFab
	EndNew
	
EndFor

Commit
]]></Source>
