        <Source><![CDATA[
//&isErro = false
//&LogGUID = GUID.NewGuid()

//Tirei pois é para retornar o total do desconto independente se é autorizado ou nao.
//if &Context.TipoPerfil <> 3 //ADM
//	RetornaAutorizacaoDescontoMaximo.Call(&EmpCod, &Context.PesCod, &IsAutorizadoDescontoMaximo)
//	if &IsAutorizadoDescontoMaximo = true
//		return
//	Endif
//Else
//	Return
//Endif

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&PedVlrDscGlb = PedVlrDscGlb
	&PedVlrLiq = PedVlrBrt //Total Produtos
	&PedPerSpm1 = PedPerSpm1
	&PedPerSpm2 = PedPerSpm2
	&PedPerPrm1 = PedPerPrm1
	&PedPerPrm2 = PedPerPrm2
	
	if &PedItmCod > 0
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where PedItmCod = &PedItmCod
			
			&PedVlrLiq -= PedVlrItm //-TotalItem
			Exit
		EndFor
	Endif
EndFor

&PedVlrLiq += &PedVlrItm
if &PedVlrLiq < 0
	&PedVlrLiq = 0
Endif

if &PedVlrDscGlb > 0 //% desconto Valor Informado
	if &PedVlrLiq > 0
		&DescontoTotalValorInformado = (&PedVlrDscGlb / &PedVlrLiq) * 100
		
		if &DescontoTotalValorInformado > 100
			&DescontoTotalValorInformado = 100
		Endif
	else
		&DescontoTotalValorInformado = 100
	EndIf
ENdif

&Total = 100
&desconto1 = 0
&desconto2 = 0
&TotalDescontoNormal = 0
if &PedPerSpm1 > 0 and &PedPerSpm2 > 0 //%descontos Tabela Normal
	&desconto1 = round(&Total * (&PedPerSpm1/100), 2) //ValorDesconto 1
	&Total = &Total - &desconto1
	
	&desconto2 = &Total * (&PedPerSpm2/100) //valor 
	&Total = &Total - &desconto2
	
	&TotalDescontoNormal = 100-&Total //% desconto dos descontos normal	
Else
	Do CAse
		Case &PedPerSpm1 > 0
			&TotalDescontoNormal = &PedPerSpm1
		Case &PedPerSpm2 > 0
			&TotalDescontoNormal = &PedPerSpm2
	EndCase
Endif

&Total = 100
&desconto1 = 0
&desconto2 = 0
&TotalDescontoPromocao = 0
if &PedPerPrm1 > 0 and &PedPerPrm2 > 0 //%descontos Tabela Promocao
	&desconto1 = round(&Total * (&PedPerPrm1/100), 2) //ValorDesconto 1
	&Total = &Total - &desconto1
	
	&desconto2 = &Total * (&PedPerPrm2/100) //valor 
	&Total = &Total - &desconto2
	
	&TotalDescontoPromocao = 100-&Total //% desconto dos descontos Promocao	
Else
	Do CAse
		Case &PedPerPrm1 > 0
			&TotalDescontoPromocao = &PedPerPrm1
		Case &PedPerPrm2 > 0
			&TotalDescontoPromocao = &PedPerPrm2
	EndCase
Endif

&TotalNormal = &DescontoTotalValorInformado+&TotalDescontoNormal
&TotalPromocao = &DescontoTotalValorInformado+&TotalDescontoPromocao

&TotalDescontos = &PedItmDsc				
if &PedItmPrm = domPedItmPrm.PROMOCAO or &PedItmPrm = domPedItmPrm.DESCONTO
	&TotalDescontos += &TotalPromocao
Else
	&TotalDescontos += &TotalNormal
Endif


]]></Source>
