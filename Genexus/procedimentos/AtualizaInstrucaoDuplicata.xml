      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FilCod,CreCod,CreRecPag,CreCrbRegAut
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	Where CreRecPag = ReceberPagar.Receber
	Where CreCrbRegAut = Status_SimNao.Sim
		Do Case
			Case &CreCmdIns = ComandoInstrucao.PEDIDO_BAIXA
				&CreCobObs = 'PEDIDO BAIXA'
					//if CreRenDstCod > 0
						CreDtaRet.SetEmpty()
						&CreCobObs += IIf(Not CreCodSol.IsEmpty() Or Not CreCodSol.IsNull(), 'Código de solicitação: ' + CreCodSol, '')
						&CreCobObs += IIf(Not CreCodBar.IsEmpty() Or Not CreCodBar.IsNull(), 'Código de Barras: ' + CreCodBar, '')
						&CreCobObs += IIf(Not CreLinDig.IsEmpty() Or Not CreLinDig.IsNull(), 'Linha Digitavel: ' + CreLinDig, '')
						&CreCobObs += IIf(Not CreQrCode.IsEmpty() Or Not CreQrCode.IsNull(), 'Código QR: ' + CreQrCode, '')
						&CreCobObs += IIf(Not CreTxId.IsEmpty() Or Not CreTxId.IsNull(), 'Transaction ID (txid): ' + CreTxId, '')
						&CreCobObs += IIf(Not CreBloNro.IsEmpty() Or Not CreBloNro.IsNull(), 'Nosso número: ' + CreBloNro, '')
						
						CreCodSol	= ''
						CreCodBar 	= ''
						CreLinDig 	= ''
						CreQrCode 	= ''
						CreTxId 	= ''
						CreBloNro	= ''

//					CreSts = Status_Duplicata.CANCELADA
//					//JDF estou querendo so cancelar o boleto e nao a duplicata.
//					
//				endif
			
				//CreSts = Status_Duplicata.CANCELADA
				////		Case &CreCmdIns = ComandoInstrucao.PEDIDO_PROTESTO
				////			&CreCobObs = 'PEDIDO PROTESTO'
				////			//				CreDtaPrt = &Today
				////		Case &CreCmdIns = ComandoInstrucao.ALTERACAO_OUTROS_DADOS
				////			&CreCobObs = 'ALTERACAO OUTROS DADOS'
			Case &CreCmdIns = ComandoInstrucao.ALTERACAO_VENCIMENTO
				CreDtaVct = &CampoData
				////			&CreCobObs = 'ALTERAÇÃO DE VENCIMENTO PARA NOVO VENCIMENTO EM: '+ DTOC(&CampoData)
				////		Case &CreCmdIns = ComandoInstrucao.CANCELAMENTO_ABATIMENTO_CONCEDIDO
				////			&CreCobObs = 'CANCELAMENTO ABATIMENTO CONCEDIDO'
				////		Case &CreCmdIns = ComandoInstrucao.CONCESSAO_ABATIMENTO
				////			&CreCobObs = 'CONCESSAO ABATIMENTO'
				////		Case &CreCmdIns = ComandoInstrucao.SUSTAR_PROTESTO_BAIXAR_TITULO
				////			&CreCobObs = 'SUSTAR PROTESTO BAIXAR TITULO'
				////		Case &CreCmdIns = ComandoInstrucao.SUSTAR_PROTESTO_MANTER_CARTEIRA
				////			&CreCobObs = 'SUSTAR PROTESTO MANTER CARTEIRA'
		EndCase
	
	&IsComandoExecutado = True
	&CreMaxCobCod = CreMaxCobCod
	Exit
EndFor

If &IsComandoExecutado = True
	&CreMaxCobCod+=1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CreCod = &CreCod
		CreCobCod = &CreMaxCobCod
		CreCobObs = &CreCobObs
		CreObsTip = TipoObservacaoDuplicata.INTERNA
		If &CreCmdIns = ComandoInstrucao.ALTERACAO_VENCIMENTO
			CrePrmPag = &CampoData
			CrePrmPagHor = &Time
		EndIf
		CreHorLig = serverNow()
		
		CreFunCod = &PesCod
		CreFunNom = &PesRaz
		
		CreCmdIns = &CreCmdIns
		CreCmdCpl = &CreCmdCpl
	EndNew
EndIf
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
