      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do case
	case &OQueFazer = 'NEW'
		if &pWinAppInsGUID.IsEmpty()
			&WinAppInsGUID = GUID.NewGuid()
		else
			&WinAppInsGUID = &pWinAppInsGUID
		endif
		New
			WinAppGUID         = &WinAppGUID
			WinAppInsGUID      = &WinAppInsGUID
			WinAppInsDtaUltExe = now()
			WinAppInsSts       = iif(&WinAppInsPID > 0, Status_Instancia.ATIVO, Status_Instancia.INATIVO)
			WinAppInsLog       = &WinAppLog
			WinAppInsPID       = &WinAppInsPID
		EndNew
		commit
		
	case &OQueFazer = 'STP' // para a instância
		for each order WinAppGUID,WinAppInsGUID
			where WinAppGUID    = &WinAppGUID
			where WinAppInsGUID = &pWinAppInsGUID
			WinAppInsLog        = &WinAppLog
			WinAppInsPID        = 0
			WinAppInsSts        = Status_Instancia.INATIVO
			WinAppInsDtaUltExe  = now()
			exit
		endfor
		commit
EndCase
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
