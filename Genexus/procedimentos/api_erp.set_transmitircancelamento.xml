      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	//&PadObs = format('nfe:%1,fil:%2', trim(toformattedString(&NfeCod)), trim(toformattedString(&FilCod)))
	//padraousuario.Call('G', 'set_cliente', 1, 1, &PadObs, &PadDtaMod)
	//padraousuario.Call('G', 'set_cliente1', 1, 1, &sdtItemNfeLongVarchar, &PadDtaMod)
	
	&tmpNfeEnvEml = false 
	&tmpCancelarDuplicatas = false
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&NfeChv = NfeChv
		&NfeAutNumPro = NfeAutNumPro
//		&ModCod = ModCod
		
		Exit
	EndFor
	
	
	&xJust = retiraCaracteresEspeciais.Udp(&motivocancelamento)
	Do 'Verifica_especial'
	
	Do Case
		Case &NfeChv.IsEmpty()
			&sdtCapaNfe.sts = 'E001'
			&sdtCapaNfe.obs = 'NFe não possui a chave da NFe, só pode cancelar uma Nota se a Mesma Estiver Autorizada!'
			
		Case &NfeAutNumPro.IsEmpty()
			&sdtCapaNfe.sts = 'E002'
			&sdtCapaNfe.obs = 'NFe não possui número do Protocolo, Consulte a Nota no SEFAZ!'
			
		Case &erro = 0
			GeraXmlCancelamento.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &xJust, &wwpContext.PesCod, &tmpNfeEnvEml, &tmpCancelarDuplicatas, &SolCod)
			
			&GUID = GUID.NewGuid()
			&ProgressId = format('canceNFe%1', &GUID.ToString())
			&ProgressId = &ProgressId.trim()
				
			RecepcaoNFe.Submit(&ProgressId, &ProgressId, &wwpContext.EmpCod, &FilCod, &NfeCod, &SolCod)
			
			&sdtCapaNfe.ProgressId = &ProgressId
			&sdtCapaNfe.SolCod = &SolCod
			&sdtCapaNfe.sts = 'J200'
			&sdtCapaNfe.obs = 'sucesso'
	EndCase
Endif


Sub 'Verifica_especial'
	
    &erro = 0 
    &Tamanho = len(&xJust)
    if &tamanho < 15 or &tamanho > 255
		&sdtCapaNfe.sts = 'E003'
		&sdtCapaNfe.obs = 'Tamanho da justificativa tem que ficar entre 15 e 255'
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&xJust,&Posicao,1) < ' '  or (substr(&xJust,&Posicao,1) > 'z'  ))
                &sdtCapaNfe.sts = 'E004'
				&sdtCapaNfe.obs = 'Caracter especial "'+  substr(&xJust,&Posicao,1) + '" Não é permitido' 
                &erro = 1
            Endif
        EndFor
    EndIf
	
EndSub
]]></Source>
