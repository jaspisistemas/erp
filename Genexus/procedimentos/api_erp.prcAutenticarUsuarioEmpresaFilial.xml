        <Source><![CDATA[

//TRATAR A VERSAO DO APPP
//vApi
//vApiNew
//linkBaixaApp


// 'J100' //recebido parametros
// 'J101' //erro usuario adm
// 'J102' //redefinir senha
// 'J103' //Erro do GAM
// 'J200' // SUCESSO
// 'J999 ou J998' //'log in my eggs'

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizarTabelas, &wwpContext)

if &IsAcessoConcedido = true
	//inicializa	
	&sdtAuth.EmpCod = &wwpContext.EmpCod
	&sdtAuth.EmpRaz = &wwpContext.EmpRaz
	&sdtAuth.FilCod = &wwpContext.FilCod
	&sdtAuth.FilRaz = &wwpContext.FilRaz
	//&wwpContext.FilTime //NAO PRECISA
	&sdtAuth.PesCod = &wwpContext.PesCod
	&sdtAuth.PesRaz = &wwpContext.PesRaz 
	&sdtAuth.PesIsVen = &wwpContext.PesIsVen
	&sdtAuth.PesIsFun = &wwpContext.PesIsFun
	//&wwpContext.CtaBanCod //NAO PRECISA
	//&wwpContext.CtaBanNom //NAO PRECISA
	&sdtAuth.UserName = &wwpContext.UserName
	&sdtAuth.PesExtCod = &wwpContext.PesExtCod
	&sdtAuth.DevRandon = &wwpContext.DeviceRandon
	//&wwpContext.BrowserVersion //NAO PRECISA
	&sdtAuth.TipoPerfil = &wwpContext.TipoPerfil
	&sdtAuth.Old_Perfil = &wwpContext.Old_Perfil
	
	ProcLoadInicio_smart.Call(&EmpCod, &FiLCod, &sdtAuth)			
	
	//inicializa
	&wwpContext.EmpCod = &sdtAuth.EmpCod
	&wwpContext.EmpRaz = &sdtAuth.EmpRaz
	&wwpContext.FilCod = &sdtAuth.FilCod
	&wwpContext.FilRaz = &sdtAuth.FilRaz
	//&wwpContext.FilTime //NAO PRECISA
	&wwpContext.PesCod = &sdtAuth.PesCod
	&wwpContext.PesRaz = &sdtAuth.PesRaz
	&wwpContext.PesIsVen = &sdtAuth.PesIsVen
	&wwpContext.PesIsFun = &sdtAuth.PesIsFun
	//&wwpContext.CtaBanCod //NAO PRECISA
	//&wwpContext.CtaBanNom //NAO PRECISA
	&wwpContext.UserName = &sdtAuth.UserName
	&wwpContext.PesExtCod = &sdtAuth.PesExtCod
	//&wwpContext.DeviceRandon = &sdtAuth.DevRandon
	//&wwpContext.BrowserVersion
	&wwpContext.TipoPerfil = &sdtAuth.TipoPerfil
	&wwpContext.Old_Perfil = &sdtAuth.Old_Perfil
	
	prcDeviceConexao.Call(&wwpContext.DeviceRandon, &wwpContext)
	
Else
	&sdtAuth.status = 'J999'
	&sdtAuth.msg = 'Não autorizado'
Endif
]]></Source>
