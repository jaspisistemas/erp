      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TabelaVarchar = 'PRODUTOGRADE'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	If &ProGraCod = 1
		//Imagens
		For Each Order EmpCod, ProCod, ProImgCod
			delete
		EndFor
		
		//Receita
		For Each Order EmpCod, ProCod, PreItmCod
			Delete
		EndFor
		
		//receita
		For Each Order EmpCod, ProCod, RecItmCod
			Delete
		EndFor
		
		//PrecoFornecedor
		For Each Order EmpCod, ProCod, ProForCod
			Delete 
		EndFor		
	EndIF
	
	//GradeCodigos
	For Each Order EmpCod, ProCod, ProGraCod, ProBarId
		Where ProGraCod = &ProGracod when &ProGraCod <> 1
			
		delete
	EndFor
	//Grade
	For Each Order EmpCod, ProCod, ProGraCod
		Where ProGraCod = &ProGracod when &ProGraCod <> 1
		
		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(ProRef)
			&LogErpRegCod2 = trim(ProGraRef)
			&LogErpRegTip = TrnMode.Delete
			&LogErpRegGUID.SetEmpty()
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			//GERAL
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProGraBar', ProGraBar.Trim(), '', &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProGraNom', ProGraNom.Trim(), '', &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProGraSts', ProGraSts.ToString(), '', &LogErpRegGUID )				
		Endif
	
		delete
	EndFor	
	//tabela Preco
	For Each Order EmpCod, TabCod, ProCod, ProGraCod, TabAltCod
		Where ProGraCod = &ProGracod when &ProGraCod <> 1
		Delete 
	EndFor	
	
	if &IsPossuiPedidos = false //NAO TEM PEDIDO NEM NFE.
		//Estoque
		For Each Order EmpCod, FilCod,ProCod,ProGraCod,EstTipCod,EstTipAno,EstTipMes
			Where ProGraCod = &ProGracod when &ProGraCod <> 1
			Delete 
		EndFor
		
		//Estoque
		For Each Order EmpCod, FilCod,ProCod,ProGraCod
			Where ProGraCod = &ProGracod when &ProGraCod <> 1
			Delete 
		EndFor
	EndIf
	
	&ProNom = '[EXCLUIDO] - ' + ProNom 
//	&ProDeviceRandon = ProDeviceRandon
	
	delete //Mas insere denovo embaixo
EndFor

Commit

new //Mas insere denovo embaixo
	EmpCod = &EmpCod
	ProCod = &ProCod
	ProNom = &PRoNom
	ProSts = Status_Produto.EXCLUIDO
	ProDtaHorUltMod = serverNow()
//	ProDeviceRandon = &ProDeviceRandon 
EndNew

Commit

For Each Order EmpCod, TabCod, ProCod, ProGraCod, TabPrcCmpItmCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod or TabPrcRecProCod = &ProCod
	Where ProGraCod = &ProGracod or TabPrcRecProGraCod = &ProGracod when &ProGraCod <> 1
	Delete 
EndFor


if &ProGracod > 0
	GravaAtualizaGrade.Call(&EmpCod, &ProCod)
EndiF

Commit
]]></Source>
