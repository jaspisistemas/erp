      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &EnviaEmail.IsEmpty()	
	&sdtRetornowbs.Sts = 'E003'
	&sdtRetornowbs.Obs = 'Nada para enviar email'
	
	return
Endif

if &IsAcessoConcedido = true //Acesso conced
	
	&sdtEnviaEmail.FromJson(&EnviaEmail)
//	padraousuario.Call('G', '%testeEnviaEmail%', 1, 1, &EnviaEmail, &PadDtaMod)
//	padraousuario.Call('G', '%testeEnviaEmail1%', 1, 1, &sdtEnviaEmail.ToJson(), &PadDtaMod)
	
	&SdtEmail.Clear()
	&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
   
	If not &sdtEnviaEmail.Eml1.IsEmpty() and (&sdtEnviaEmail.Eml1.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEnviaEmail.Eml1
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtEnviaEmail.Eml2.IsEmpty()  and (&sdtEnviaEmail.Eml2.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEnviaEmail.Eml2
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtEnviaEmail.Eml3.IsEmpty()  and (&sdtEnviaEmail.Eml3.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEnviaEmail.Eml3
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf

	Do Case
		CAse &sdtEnviaEmail.EmlAss.IsEmpty()
			&sdtRetornowbs.Sts = 'E005'
			&sdtRetornowbs.Obs = 'Informe um assunto para o Email'
			
		Case &SdtEmail.Count > 0
			GravaEnvioEmailPedido.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtEnviaEmail.EmlPedCod, 0, TipoContaEmail.Email_Comercial, &sdtEnviaEmail.EmlAss, TipoSolicitacao.Envia_Pedido, &WwpContext.PesCod, &sdtEnviaEmail.EmlObs, &SdtEmail, &sdtBoleto, Status_SimNao.Nao, true, true, &sdtEnviaEmail.EmlTipPed, false, false)
			
			&sdtRetornowbs.Sts = 'J200'
			&sdtRetornowbs.Obs = 'Email enviado com sucesso'
		Otherwise
			&sdtRetornowbs.Sts = 'E004'
			&sdtRetornowbs.Obs = 'Nenhum email válido informado'
	Endcase
Else
	&sdtRetornowbs.Sts = 'E002'
	&sdtRetornowbs.Obs = 'Nao autorizado Device'
EndiF
]]></Source>
