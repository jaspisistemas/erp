<Object parentGuid="49ada6f0-9d08-45f9-81d5-460ce1ff5dd5" user="WINJEAN\jeanfae" versionDate="2025-06-30T11:45:07.0000000Z" lastUpdate="2025-06-23T20:42:30.0000000Z" checksum="2e0142d182a6d4c43f5cbdbda7ea5325" fullyQualifiedName="api_erp.gravaInicioMdfe" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="ae5c8d1b-38f0-4da3-8d5a-9430962078eb" name="gravaInicioMdfe" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="grava Inicio Mdfe" parent="api_erp.mdfe" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do Case
	Case &OqueFazer = 'PERCURSO'
	//GRAVA MDFE
		For Each ORder EmpCod, FilCod, MDFeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FiLCod
			Where MDFeCod = &MdfeCod
					
			MDFeDesCidCod = &SdtMdfe.DestCidCod
						
			Exit
		EndFor
		
		commit
		
		if &SdtMdfe.MdfeSegRef = 0
			For Each Order EmpCod, FilCod
				Where EmpCod = &EmpCod
				Where FilCod = &FiLCod
				&MdfeSegResCnpj = FilCpj
				&MdfeSegNom = FilRaz
				Exit
			EndFor		
		Else
			
			For Each ORder EmpCod, SegCod
				Where EmpCod = &EmpCod
				Where SegCod = &SdtMdfe.MdfeSegRef
				&MdfeSegResCnpj = SegCnpj
				&MdfeSegNom = SegNom
				Exit
			EndFor
		Endif
			
		//GRAVA DADOS SEGURO
		For Each Order EmpCod, FilCod, MDFeCod,MdfeSegCod
			Where EmpCod = &EmpCod
			WHere FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			Where MdfeSegCod = 1
			MdfeSegRes = &SdtMdfe.MdfeSegRes
			
			MdfeSegRef = &SdtMdfe.MdfeSegRef
			MdfeSegResCnpj = &MdfeSegResCnpj
			MdfeSegNom = &MdfeSegNom
			MdfeSegCnpj = &MdfeSegResCnpj
			MdfeSegNroApo = &SdtMdfe.MdfeSegNroApo
			
		When none
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				MDFeCod = &MDFeCod
				MdfeSegCod = 1
				MdfeSegRes = &SdtMdfe.MdfeSegRes
				MdfeSegRef = &SdtMdfe.MdfeSegRef
				MdfeSegResCnpj = &MdfeSegResCnpj
				MdfeSegNom = &MdfeSegNom
				MdfeSegCnpj = &MdfeSegResCnpj
				MdfeSegNroApo = &SdtMdfe.MdfeSegNroApo
			EndNew		
		EndFor
	
		commit	
	
	CAse &OqueFazer = 'DOCUMENTOS'
		//GRAVA MDFE
		For Each ORder EmpCod, FilCod, MDFeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FiLCod
			Where MDFeCod = &MdfeCod
			
			MDFeTipCar = &SdtMdfe.MDFeTipCar
			MDFeProPre = &SdtMdfe.MDFeProPre
			MDfeUnd = &SdtMdfe.MDFeUnd
			
			
			Exit
		EndFor
		
		commit
		
		MDFe_TotalizarNotas.Call(&EmpCod, &FiLCod, &MdfeCod, &countCteNumeric, &countNfeNumeric, &totalNumeric, &PesoBrutoMoeda, &TotalMoeda)
		
	Case &OqueFazer = 'INICIO'
		//GRAVA MDFE
		For Each ORder EmpCod, FilCod, MDFeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FiLCod
			Where MDFeCod = &MdfeCod
			
			if not &sdtMdfe.MDFeTipTra.IsEmpty()
				MDFeTipTra = &sdtMdfe.MDFeTipTra
			Endif
			
			MDFeOriUfeCod = &SdtMdfe.OriUfeCod
			//		MDFeCarCidCod = &SdtMdfe.OriCidCod
			MDFeLotCarCep = &SdtMdfe.OriCep
			
			MDFeDstUfeCod = &SdtMdfe.DestUfeCod
			MDFeDesCidCod = &SdtMdfe.DestCidCod
			MDFeLotDesCep = &SdtMdfe.DestCep
			MDFeAdc = &sdtMdfe.MDFeAdc
			
			Exit
		EndFor
		
		commit		
		
		//GRAVA DESCARREGAMENTO
		For Each Order EmpCod, FilCod, MDFeCod,MDFeCarCod
			Where EmpCod = &EmpCod
			WHere FilCod = &FiLCod
			Where MDFeCod = &MdfeCod
			Where MDFeCarCod = 1
			MDFeCarCidCod = &SdtMdfe.OriCidCod
			Exit
		When none
			New 
				EmpCod = &EmpCod
				FilCod = &FilCod
				MDFeCod = &MdfeCod
				MDFeCarCod    = 1
				MDFeCarCidCod = &SdtMdfe.OriCidCod
			EndNew
		EndFor
		
		commit
EndCAse
]]></Source>
