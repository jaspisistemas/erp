      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &OqueFazer = 'ADD'
	if &PesDebCod.IsEmpty()
		&newPesDebCod = 0
		For Each Order EmpCod, PesCod, (PesDebCod)
			Where EmpCod = &EmpCod
			Where PesCod = &PEsCod
			&newPesDebCod = PesDebCod
			Exit
		EndFor
		&newPesDebCod += 1
		
		New
			EmpCod = &EmpCod
			PesCod = &PesCod
			PesDebCod = &newPesDebCod
			PesDebDta = &PesDebDta
			PesDebTip = &PesDebTip
			PesDebVlr = &PesDebVlr 
			PesDebQtd = &PesDebQtd
			PesDebObs = &PesDebObs
		endNew
		
		Commit
		
	else
		
		for Each Order EmpCod, PesCod, PesDebCod
			Where EmpCod = &EmpCod
			Where PesCod = &PEsCod
			Where PesDebCod = &PesDebCod
			PesDebDta = &PesDebDta
			PesDebTip = &PesDebTip
			PesDebVlr = &PesDebVlr
			PesDebQtd = &PesDebQtd
			PesDebObs = &PesDebObs
			Exit
		EndFor
		Commit
	EndIf
Else
	for Each Order EmpCod, PesCod, PesDebCod
		Where EmpCod = &EmpCod
		Where PesCod = &PEsCod
		Where PesDebCod = &PesDebCod
		delete
	EndFor
	Commit
EndIF

]]></Source>
