      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NfeDtaEms = serverdate() - 30

If &AlterarDataNota = Status_SimNao.Sim
	For Each Order EmpCod, NfeProTer, NfeSts, NfeCod
		Where EmpCod = &EmpCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_NFe.Digitando
		where not NfeNum.IsEmpty()
		
		NfeDtaEms = &Data
		NfeDtaDsp = &Data
		NfeDtaFat = &Data
		NfeDtaFat_Ano = &Data.Year()
		NfeDtaFat_Mes = &Data.Month()
		NfeChv = ''
	EndFor
EndIf

if &EnviarAutorizacao = Status_SimNao.Sim
	For Each Order EmpCod, NfeProTer, NfeSts, NfeCod
		Where EmpCod = &EmpCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_NFe.Digitando
		Where NfeDtaEms >= &NfeDtaEms
		where not NfeNum.IsEmpty()
		
		&sdtSolicitacaoItem = new()
		&sdtSolicitacaoItem.SolCod = &SolCod
		&sdtSolicitacaoItem.NfeCod = NfeCod
		&sdtSolicitacaoItem.EmpCod = EmpCod
		&sdtSolicitacaoItem.FilCod = FilCod
		&SdtSolicitacaoItem.ModCod = ModCod
		&sdtSolicitacaoItem.Tipo = 'A'
		&SdtSolicitacao.Add(&SdtSolicitacaoItem)
	EndFor
EndIF

if &EnviarConsulta = Status_SimNao.Sim
	For Each Order EmpCod, NfeProTer, NfeSts, NfeCod
		Where EmpCod = &EmpCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_NFe.Digitando
		where not NfeNum.IsEmpty()
		
		&sdtSolicitacaoItem = new()
		&sdtSolicitacaoItem.SolCod = &SolCod
		&sdtSolicitacaoItem.NfeCod = NfeCod
		&sdtSolicitacaoItem.EmpCod = EmpCod
		&sdtSolicitacaoItem.FilCod = FilCod
		&SdtSolicitacaoItem.ModCod = ModCod
		&sdtSolicitacaoItem.Tipo = 'B'
		&SdtSolicitacao.Add(&SdtSolicitacaoItem)
	EndFor
EndIF

if &SdtSolicitacao.Count > 0
	
	&Total = &SdtSolicitacao.Count
	&Count = 0
	&Percentual = 0
	&ProgressIni = serverNow()
	&ProgressLogXml = ''
	do 'Atualiza'
	
	
	
	For &SdtSolicitacaoItem in &SdtSolicitacao
		
		&Count += 1
		If &Count > 0
			&Percentual = round((&Count / &Total) * 100, 0)
		EndIF
		If &Percentual >= 100
			&Percentual = 99
		EndIf
		do 'Atualiza'
		
		ValidaSchemaNFe.Call(&EmpCod, &FilCod, &NfeCod,&ContextFilCod, &Mensagem)			
		if &Mensagem.IsEmpty()
			If &SdtSolicitacaoItem.Tipo = 'A'
				
				If &SdtSolicitacaoItem.ModCod = '65'
					GeraXmlNFeModelo65_4.Call(&SdtSolicitacaoItem.EmpCod, &SdtSolicitacaoItem.FilCod, &SdtSolicitacaoItem.NfeCod, 'S', &PesCod, 'E', &SolCod)
				Else
					GeraXmlNFeModelo55_4.Call(&SdtSolicitacaoItem.EmpCod, &SdtSolicitacaoItem.FilCod, &SdtSolicitacaoItem.NfeCod, 'S', &PesCod, 'E', &SolCod)
				EndIF
			Else
				GravaConsultaSEFAZ.call('', &SdtSolicitacaoItem.EmpCod, &SdtSolicitacaoItem.FilCod, &SdtSolicitacaoItem.NfeCod, &PesCod, &SolCod)
			EndIF
		EndiF
	
	
		&Dorme = sleep(2)
	EndFor
	
Else
	&ProgressLogXml = 'Nenhuma Nota pendente para retransmissão!'
EndIF

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml =  &ProgressLogXml  
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml =  &ProgressLogXml  
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub
]]></Source>
