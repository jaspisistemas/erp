      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&HojeData = serverdate()
&Mensagem.SetEmpty()

PadraoUsuario.Call('L', '#VENCIMENTODUPLICATAJASPI#', 1, &EmpCod, &PadObs, &PadDtaMod)

&VencimentoData.FromString(Substr(&PadObs,1,10))

&AuxVencimentoData = &VencimentoData.AddDays(10)

&Nivel = 0
Do Case
	Case (&AuxVencimentoData < &HojeData ) and not &VencimentoData.IsEmpty() //VENCIDO A MAIS DE 10 DIAS
		&AuxData = &VencimentoData.AddDays(10)
		&Mensagem = 'ATENÇÃO! Seu sistema poderá ser bloqueado a qualquer momento, efetue a quitação da mensalidade para evitar transtornos'
		&Nivel = 3
	
	Case &VencimentoData <= &HojeData and not &VencimentoData.IsEmpty() //VENCIDO 
		&AuxData = &VencimentoData.AddDays(10)
		&Mensagem = 'ATENÇÃO! Evite o bloqueio do seu sistema efetuando a quitação da mensalidade até o dia: '	+ trim(&AuxData.ToFormattedString())
		&Nivel = 3
		
	Case &VencimentoData <= (&HojeData+3)  and not &VencimentoData.IsEmpty()  //A VENCER MENOR QUE 3 DIAS
		&AuxData = &VencimentoData
		&Mensagem = 'Boleto já disponivel para pagamento com vencimento em: ' + trim(&AuxData.ToFormattedString())
		&Nivel = 2
		
	Case &VencimentoData <= (&HojeData+6)  and not &VencimentoData.IsEmpty()  //A VENCER MENOR QUE 10 DIAS
		&AuxData = &VencimentoData
		&Mensagem = 'Boleto já disponivel para pagamento com vencimento em: ' + trim(&AuxData.ToFormattedString())
		&Nivel = 1
EndCase
]]></Source>
