      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsJaEnviado = false

For Each Order EmpCod,WaAnoMes,WaDtaEms,WaFonDest
	Where EmpCod = &EmpCod
	Where WaAnoMes = &WaAnoMes
	Where WaDtaEms = &WaDtaEms
	Where WaFonDest = &WaFonDest
	Where WaSts = 'P' or WaSts = 'S' or WaSts.IsEmpty() or WaSts.IsNull()
	
	&IsJaEnviado = true
	Exit
EndFor
]]></Source>
