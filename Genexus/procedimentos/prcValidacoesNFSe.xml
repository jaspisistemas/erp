      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErro = false
&erroMensagem = ''

For Each Order EmpCod, NfsCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NfsCod
	
	&FilCod = NfsFilCod
	do 'validaFilial'
	
	//Validar Dados do Cliente
	//DADOS CLIENTE
	if NfsCliCidIbge = 0		
	     &erroMensagem = 'Cidade do cliente não tem o código do IBGE, atualize o cadastro da Cidade:' + trim(STR(NfsCliCidIbge)) + ' - ' + trim(NfsCliCidNom) + newLine()
		 &IsErro = true
		 Return
	EndIF
	
	if NfsCliTipPes = TipoPessoa.JURIDICA
		if NfsCliCidUfCod <> 'EX'
			ValidaCpfCnpj.Call(NfsCliCnpj, &ErroCnpj, 'S') 
			IF &ErroCnpj = 1 
				&erroMensagem = &erroMensagem.Trim() + newLine() + ' CNPJ Inválido! Obrigatório CNPJ' 
				&IsErro = true
				Return
			Endif
		Endif
		
		prcValidaInscricaoEstadual.Call(NfsCliInsEst, NfsCliCidUfCod, &ComErro, &PedCliInsEst)
		If &ComErro = 'N'
		    &erroMensagem = &erroMensagem.Trim() + newLine() + ' Inscrição Estadual do cliente Inválida!'
			&IsErro = true
			Return
		EndIf  
	Else
		If NfsCliCidUfCod <> 'EX'
			ValidaCpfCnpj.Call(NfsCliCPF, &ErroCpf, 'S') 
			IF &ErroCpf = 1	
				&erroMensagem = &erroMensagem.Trim() + newLine() + ' CPF Inválido! Obrigatório CPF'
				&IsErro = true
				Return
			Endif
		Endif
	EndiF
	
	If NfsCliLog.IsEmpty() or len(trim(NfsCliLog)) < 5
	    &erroMensagem = &erroMensagem.Trim() + newLine() + ' Cliente sem Endereço no Cadastro, Endereço precisa ter no minimo 5 caracteres!'
		&IsErro = true
		Return
	EndIf	
	If NfsCliBai.IsEmpty() 
	    &erroMensagem = &erroMensagem.Trim() + newLine() + ' Cliente sem o Bairro no Cadastro. Verifique!'
		&IsErro = true
		Return
	endif	
	if NfsCliNro.IsEmpty()
	    &erroMensagem = &erroMensagem.Trim() + newLine() + ' Cliente sem o número do Endereço no Cadastro!'
		&IsErro = true
		Return
	endif
	
	&SoNumeros = RetornaSoNumeros.Udp(NfsCliCep)
	&qtdDigitos = len(&SoNumeros)
	If &qtdDigitos < 8 and NfsCliCidUfCod <> 'EX'
	    &erroMensagem = &erroMensagem.Trim() + newLine() + ' CEP do cliente é inválido!'
		&IsErro = true
		Return
	Endif

	
	//Validar Dados intermediario
	
	
	
	//Validar Dados CNAe, Aliquotas
	
	
	
	//Validar Dados Servico
	For Each Order EmpCod, NfsCod, NfsItmCod
		
	EndFor

	
	if NfsVlrTot.IsEmpty()
		&erroMensagem = &erroMensagem.Trim() + newLine() + ' Total da NFSe não pode ser zero!'
		&IsErro = true
		Return
	Endif

	
	Exit
EndFor

Sub 'validaFilial'
	For Each ORder EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &NfsFilCod
		
		&FilBasImp = FilBasImp
		do 'baseImposto'
		
		//inscricao Municipal vazia.
		
	EndFor
EndSub

Sub 'baseImposto'
	For Each Order EmpCod, TbImpFilCod
		Where EmpCod = &EmpCod
		Where TbImpFilCod = &FilBasImp
		
		Do CAse
			CAse TbFilRegTribMun.IsEmpty() or TbFilRegTribMun.IsNull() or TbFilRegTribMun = '0'
				&erroMensagem = &erroMensagem.Trim() + newLine() + ' Configuração Grupo Filial Imposto: Situação perante Simples Nacional não Selecionado!'
				&IsErro = true
		EndCase
	
		Exit
	EndFor
EndSub
]]></Source>
