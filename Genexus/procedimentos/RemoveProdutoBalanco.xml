      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&mensagemRemovido = ''
For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where BalCod = &BalCod
	
	&BalSts = BalSts
	&PedCod = BalPedCod
	
	For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		&mensagemRemovido = 'Produto '+trim(str(ProCod))+', removido com sucesso.'
		delete
		Exit
	EndFor

	Exit
EndFor

commit


For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	EstProStsBal = RetornaProdutoBalanco.Udp(EmpCod, FilCod, ProCod, ProGraCod)
	Exit
EndFor

commit


if &BalSts = Status_Pedido.FECHADO
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where PedCod = &PedCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		GravaItemPedidoVenda.Call(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod, 0, 0,0,0, 0, 0, '', 0,0, &mensagem, &mensagem, &Pgmname)
		
		delete
		Exit
	EndFor

	Commit
EndIF
]]></Source>
