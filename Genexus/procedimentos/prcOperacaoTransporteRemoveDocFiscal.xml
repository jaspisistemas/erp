      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//PROCEDIMENTO PARA EXCLUIR NFE DA OPERAÇÃO\\

For Each Order EmpCod, FilCod, OpeCod, OpeNfeCod
	Where EmpCod 	= &parmEmpCod
	Where FilCod 	= &parmFilCod
	Where OpeCod 	= &parmOpeCod
	Where OpeNfeCod	= &parmOpeNfeCod
	
	Msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", "Nota Fiscal removida com sucesso!" ,DVMessageType.success, "", DVMessageBoolean.True,"") )
	
	Delete
	Exit
EndFor

Commit
]]></Source>
