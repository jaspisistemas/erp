<Object parentGuid="3adcb0ab-846f-4614-8229-06f294967876" user="" versionDate="2022-06-28T23:50:51.0000000Z" lastUpdate="2019-08-19T11:25:55.0000000Z" checksum="0e84f68cf062ef6bcaa22a2ed5c28a6e" fullyQualifiedName="AtualizaEnderecoCliente" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="dde0a49e-e9b6-4f2e-9e3c-31c723485a2d" name="AtualizaEnderecoCliente" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Atualiza Endereco Cliente" parent="PesRot" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	
	PesDtaAdm = PesDtaAdm_FORMULA
	PesDtaReg = PesDtaReg_FORMULA
	PesDtaDem = PesDtaDem_FORMULA
	
	PesCodRazSugg = PesCodRazSugg_FORMULA
	
	if PesVenAprz.IsEmpty() or PesVenAprz.IsNull()
		PesVenAprz = Status_SimNao.Sim
	EndIF
	
	if PesVinCod = 0 or PesVinCod.IsNull()
		PesVinCod = PesCod
	EndIF
	
	if PesIntVenCod = 0 or PesIntVenCod.IsNull()
		PesIntVenCod = 1
	EndIF
	
	if PesExtVenCod = 0 or PesExtVenCod.IsNull()
		PesExtVenCod = 1
	EndIF

	if TpcCod.IsNull()
		TpcCod = ' '
	EndIf

	if PesTip = TipoPessoa.JURIDICA
		PesNumCpfCpnj = retornasoNumeros.Udp(PesCnpj)
	Else
		PesNumCpfCpnj = retornasoNumeros.Udp(PesCpf)
	EndiF

	If PesIsEndCob = false // Cobranca
		PesCobBai = PesBai
		PesCobCep = FormataCEP.Udp(PesCep)
		PesCobCidCod = PesCidCod
		PesCobCpl = PesCpl
		PesCobLog = PesLog
		PesCobNro = PesNro
	EndIf

	If PesIsEndEnt = false //Entrega
		PesEntBai = PesBai
		PesEntCep = FormataCEP.Udp(PesCep)
		PesEntCidCod = PesCidCod
		PesEntCpl = PesCpl
		PesEntLog = PesLog
		PesEntNro = PesNro
	EndIF
EndFor

commit


AtualizaClienteNFPendente.Call(&EmpCod, &PesCod)
]]></Source>
