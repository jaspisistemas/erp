      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Domingo = 1
//Sabado = 7

&DataFinal = &DataInicial
Do Case
	Case DoW(&DataFinal) = 1 //domingo
		&DataFinal = &DataFinal.AddDays(1)
	Case DoW(&DataFinal) = 7 //sabado
		&DataFinal = &DataFinal.AddDays(2)
EndCase

if &AddDias > 0
	For &Count = 1 to &AddDias
		&DataFinal = &DataFinal.AddDays(1)
		
		Do Case
			Case DoW(&DataFinal) = 1 //domingo
				&DataFinal = &DataFinal.AddDays(1)
			Case DoW(&DataFinal) = 7 //sabado
				&DataFinal = &DataFinal.AddDays(2)
		EndCase
	EndFor
EndIF
]]></Source>
