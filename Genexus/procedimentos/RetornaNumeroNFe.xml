      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NfePedItmCod = 0
&NfeNum = 0
For Each ORder EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where NfeFilCod = &FilCod
	Where NfePedCod = &PedCod
	
//	&NfeCod = NfeCod
	&NfeNum = NfeNum

	For Each Order EmpCod, FilCod, NfeCod
		Where NfePedItmCod = &PedItmCod
		&NfeItmCod = NfeItmCod
		&NfeProNom = NfeProNom
		Exit
	EndFor

	Exit
EndFor
]]></Source>
