      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//ATUALIZA STATUS CHEQUE 
For Each Order EmpCod, CheCod
	where EmpCod = &EmpCod
	Where CheCod = &CheCod
	
	CheMot = &CheMot
	
	&CheCreCod = CheCreCod
	&CheCreFilCod = CheCreFilCod
	
	Exit
EndFor

Commit

//DELETA PAGAMENTOS
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &CheCreFilCod
	Where CreCod = &CheCreCod
	
	&MovCod = 0
	&SdtMovimento.Clear()
	&SdtMovimentoItem = new()
	&SdtMovimentoItem.PlanCod = &PlanCod
	&SdtMovimentoItem.MovItmVlr = CreVlrSdo
	&SdtMovimentoItem.MovItmCpl = 'REAPRESENTACAO CHEQUE: CLIENTE ' + trim(CreCliRaz)
	&SdtMovimentoItem.MovCreCod = 0
	&SdtMovimentoItem.MovCreFilCod = 0
	&SdtMovimentoItem.MovCrePagCod = 1
	&SdtMovimento.Add(&SdtMovimentoItem)
	
	GravaMovimento.Call(&EmpCod, TrnMode.Insert, &MovCod,serverdate(),serverdate(),&MovCtaBanCod,'C', CreDupNro, &SdtMovimento, TipoMovimento.RecebimentoCheque, '', &Erro)
	
	GravaPagamentoAntecipado.Call(&EmpCod,&MovCod,1,CreCod,FilCod,CreVlrSdo,0,0)
	
	&Mensagem = 'REAPRESENTADO CHEQUE: INSERIDO REAPRESENTACAO CAIXA SEQ.:' + trim(str(&MovCod))
	
	GravaCobranca.Call(&EmpCod, &CheCreFilCod, &CheCreCod, &Mensagem, 0, 0, &Data, &Hora, TipoObservacaoDuplicata.INTERNA)
EndFor

Commit

//AtualizaSaldoDuplicata.Call(&EmpCod, &CheCreCod, &CheCreFilCod)
]]></Source>
