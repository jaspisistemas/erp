      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	//CÓDIGO REFEITO GRAZADEUS
	
	For Each Order EmpCod, AgeCod, AgeTip	//## Faz uma busca na Agenda 
		Where EmpCod = &EmpCod 				
		Where AgeDta = ServerDate()			
		Where AgeSts = Status_AtivoInativo.ATIVO
		
		&AgeCod = AgeCod
		Do 'BuscaCodigoPessoasAgendador'
		
	EndFor

	Sub 'BuscaCodigoPessoasAgendador'
		
		For Each Order EmpCod, AgeCod, AgePesCod //## Faz uma busca na AgendaUsuario
			Where EmpCod = &EmpCod
			Where AgeCod = &AgeCod
			
			&AgePesCod = AgePesCod
			Do 'BuscaCodigoExterno'
			
		EndFor
	
	EndSub
	
	Sub 'BuscaCodigoExterno'
		
		For Each Order EmpCod, PesCod //## Faz uma busca na Pessoa
			Where EmpCod = &EmpCod
			Where PesCod = &AgePesCod
			
			&PesExtCod = PesExtCod
			Do 'EnviaNotificacao'
			
			Exit
		EndFor
		
	EndSub

	Sub 'EnviaNotificacao'
		
		&TodayDia = trim(str(day(&Today)))  //## Define o Dia de Hoje
		&TodayMes = trim(Str(Month(&Today)))//##  Define o Mês Atual  
		&TodayAno = trim(Str(Year(&Today))) //##  Define o Ano Atual
		&QuantNotif = 0						//## Zera a quantidade de notificações 
		
		&Filter.ExternalId = trim(str(&PesExtCod)) //## Define o filtro que será usado no GetUser 
		
		For &User in GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors) //## Procura o GAMGUID do usuário e envia a notificação para o mesmo 
			&IDUsuario = &User.GUID //## Define IDUsuario como o código do GAMGUID
			
			For Each Order WWPNotificationId, (WWPNotificationDefinitionId) //## Procura se há alguma notificação, de Compromisso, no dia de Hoje
				Where WWPNotificationDefinitionId = 4                       //## Código da Notificação de Compromisso
				Where WWPUserExtendedId = &IDUsuario                        //## Código GAMGUID, do usuário
				Where trim(str(day(WWPNotificationCreated))) = &TodayDia	//## Onde o Dia da última notificação é = ao Dia de Hoje
				Where trim(Str(Month(WWPNotificationCreated))) = &TodayMes	//## Onde o Mês da última notificação é = ao Mês de Hoje
				Where trim(Str(Year(WWPNotificationCreated))) = &TodayAno	//## Onde o Ano da última notificação é = ao Ano de Hoje 
				
				&QuantNotif = Count(WWPNotificationId)						//## Conta quantas notificações tem 
				
				Exit
			EndFor
			
			//===### Se houver uma notificação, no dia de HOJE, envia um lembrete que há Compromisso(os) ###===\\
			If &QuantNotif = 0
				&NotificationLink = dashboard.Link()
				WWP_SendNotification(!'Compromisso', !"Compromissos", '', "fas fa-exclamation FontColorIconWarning", "Você tem Compromisso!", Format("Passando para lembrar que você tem um compromisso, Hoje! %2 %3", "Confira em: DASHBOARD!"), Format("Passando para lembrar que você tem um compromisso, Hoje! %2 %3", "Confira em: DASHBOARD!"), &NotificationLink, '', '', True, &IDUsuario)
			endif
			//===###################################################################################################===\\
			
			Exit
		EndFor
		
	EndSub	
]]></Source>
