      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AntPlanCatTip.SetEmpty()

&Caractere = &PlanHie //Retorna Numero e pontos Ex: 10.1.2

do 'soNumeros'

&NewPlanHie = &PlanHie

&indexFinal = 1
&IsContinua = true
//&IsPrimeiraCategoria = true
&IsErroHierarquia = false
&PlanPaiCod.SetEmpty()
&planPaiHie.SetEmpty()


do while &IsContinua = true //Separa os Nó
	&indexFinal = &Numeros.IndexOf('.', &indexFinal)
	&indexFinal -= 1
	&Codigo = Substr(&Numeros, 1, &indexFinal)
	
	&indexFinal += 2
	&QtdLevel += 1
	
	if &indexFinal.IsEmpty()
		//msg('Vazio')
		&IsContinua = false
	Else		
		If &Codigo.IsEmpty()
			&IsContinua = false
		Else
			//		&AuxIndexInicial = &indexFinal
			//		&AuxIndexFinal = &Numeros.Length()
			
			//		&IsPrimeiraCategoria = false
			
			do 'getPai'
			If &IsErroHierarquia = true
				&IsContinua = false
				return
			EndIf		
		EndIF
	Endif

	if &PlanHie = &Codigo
		&IsContinua = false
	EndIf

EndDo

if &QtdLevel > 5
	&IsErroHierarquia = true
	&NomePaizao = 'No máximo Permitido 5 Hierarquias'
	Return
ENdiF

//if (&IsPrimeiraCategoria = true and &Numeros.Length() > 5)
//	&IsErroHierarquia = true
//	&NomePaizao = '.Tamanho máximo de 5 Digitos, informado: ' + trim(&Numeros)
//	Return
//Else
//	&AuxNumeros = Substr(&Numeros, &AuxIndexInicial, &AuxIndexFinal)
//	if &AuxNumeros.Length() > 5
//		&IsErroHierarquia = true
//		&NomePaizao = ',Tamanho máximo de 5 Digitos, informado: ' + trim(&AuxNumeros)
//		Return
//	EndIF
//EndiF

&NewPlanHie = &Numeros

For Each Order EmpCod, PlanHie //Verifica se ja tem codigo cadastrado
	Where EmpCod = &EmpCod
	Where PlanHie = &NewPlanHie
	Where PlanCod <> &PlanCod
	&NomePaizao = 'Já Existe Categoria Cadastrada com o nome de ' + trim(PlanNom)
	&IsErroHierarquia = true
	
	Return
	Exit
EndFor


Sub 'getPai' //Verifica Existe Pai
	
	&paiPlanHie = &Codigo.Trim()
	
	if &PlanHie <> &paiPlanHie
		For Each Order EmpCod, PlanHie
			Where EmpCod = &EmpCod
			Where PlanHie = &paiPlanHie
			
			If not &NomePaizao.IsEmpty()
				&NomePaizao += ' | '
			EndIF
			
			&NomePaizao = trim(&NomePaizao) + ' ' + trim(PlanNom)
			
			If PlanAnaSin = 'A' //GRUPO ANALITICO
				&NomePaizao = 'Hierarquia não Disponível. Pai Hierárquico ' + trim(PlanNom) + ' é preciso ser Tipo:Sintético'
				&IsErroHierarquia = true
			EndIf
			
			&AntPlanCatTip = PlanCatTip
			
			&PlanPaiCod = PlanCod
			&planPaiHie = PlanHie
			
			Exit
		When none
			if &PlanHie <> &paiPlanHie
				&NomePaizao = 'Hierarquia não Disponível. Primeiramente Cadastre o Pai Hierárquico ' + trim(&paiPlanHie)
				&IsErroHierarquia = true
			Endif
		EndFor
	Endif
EndSub


Sub 'soNumeros'
	&Pos = 1
	&Numeros = ''
	
	Do While &Pos <= 100
		if (substr(&Caractere,&Pos,1) >= '0' and substr(&Caractere,&Pos,1) <= '9') or (substr(&Caractere,&Pos,1) = '.' and not &Numeros.IsEmpty())
			If substr(&Caractere,&Pos,1) = '.'
				&temDepois = Substr(&Caractere, &Pos, 100)
				&temDepois = RetornaSoNumeros.Udp(&temDepois)
				
				if &temDepois <> ''
					&Numeros += substr(TRIM(&Caractere),&Pos,1)
				EndIF
			else
		        &Numeros += substr(TRIM(&Caractere),&Pos,1)
			EndIF
	    Endif
	
	    &Pos += 1
	EndDo
EndSub
]]></Source>
