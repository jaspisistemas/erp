      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &MarCod = 0 //INSERT
	prcLogAddSdt.Call('MarNom', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('MarLojVirIntId', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('MarLojVirIntUrl', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('MarLojVirIntSeo', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('MarLojVirIntUri', '', '', &sdtLogAtributos)	
Else
	For Each order EmpCod, MarCod
		Where EmpCod = &EmpCod
		Where MarCod = &MarCod
		
		prcLogAddSdt.Call('MarNom', trim(MarNom), '', &sdtLogAtributos)
		prcLogAddSdt.Call('MarLojVirIntId', trim(toformattedString(MarLojVirIntId)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('MarLojVirIntUrl', trim(toformattedString(MarLojVirIntUrl)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('MarLojVirIntSeo', trim(toformattedString(MarLojVirIntSeo)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('MarLojVirIntUri', trim(toformattedString(MarLojVirIntUri)), '', &sdtLogAtributos)
		
		Exit
	EndFor
Endif
]]></Source>
