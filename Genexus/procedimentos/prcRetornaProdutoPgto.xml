      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtpgtoItem.Clear()

For Each order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCodRef.IsEmpty() or PedItmCodRef.IsNull() or PedItmCodRef = PedItmCod
	
	
	&ProGraNom = PedProNom
	&DescontoPedVlrItm = round(PedVlrItm + (PedVlrItm * PedProTaxAcrGerItm* 0.01) - (PedVlrItm * PedProTaxDscGerItm * 0.01),2) //aqui da o valor do item com todos os acescimeo sou descontos da capa
	
	&PedVlrItm = (&DescontoPedVlrItm) - (PedItmPagVlrTot)  //aqui pega o total do item - o que ja foi pago
	&PeQtd = (PedQtd - PedItmPagQtdTot)
	
	&PedItmPagVlrTot = PedItmPagVlrTot   // Valor que ja foi pago
	&PedItmPagQtdTot = PedItmPagQtdTot   // Qtde que ja foi paga
	
	&PedItmPagVlrSel = PedItmPagVlrSel   // Valor selecionado para pagar
	&PedItmPagQtdSel = PedItmPagQtdSel   // Qtde  Selecionado para Pagar
	
	&PedItmPagQtdTotCreOrd = PedItmPagQtdTotCreOrd 
	&PedItmPagVlrTotCreOrd = PedItmPagVlrTotCreOrd 
	
	
	if &PedItmPagVlrSel < 0 or &PedVlrItm < 0
		&PedVlrItm = 0
		&PedItmPagVlrSel = 0
	Endif
	
	//SELECIONAD
	if PedItmPagIsSel = true and &PedItmPagVlrSel > 0
		&IsMarcadoBol = True
	Else
		&IsMarcadoBol = false
	Endif
	If &PedItmPagQtdTot > 0 or  &PeQtd > 0
		if &MostrarItens = 'T' or (&MostrarItens = 'P'  and &PedVlrItm > 0)   	//PENDENTES PAGAMENTO:P,TODOS OS ITENS:T
			&sdtpgtoItemItem = new()
			&sdtpgtoItemItem.PedItmCod = PedItmCod
			&sdtpgtoItemItem.ProGraRef = ProGraRef
			&sdtpgtoItemItem.ProGraNomCompleto = &ProGraNom
			&sdtpgtoItemItem.PedVlrItm = &PedVlrItm
			&sdtpgtoItemItem.PedQtd = &PeQtd
			
			&sdtpgtoItemItem.PedItmPagVlrSel = &PedItmPagVlrSel
			&sdtpgtoItemItem.PedItmPagQtdSel = &PedItmPagQtdSel
			&sdtpgtoItemItem.PedItmPagIsSel = &IsMarcadoBol
			
			&sdtpgtoItemItem.PedItmPagVlrTot = &PedItmPagVlrTot
			&sdtpgtoItemItem.PedItmPagQtdTot = &PedItmPagQtdTot
			
			//################ aqui carrega so pra questão de informaçao no fecha financeiro da ordem de carregamento.
			&sdtpgtoItemItem.PedItmPagQtdTotCreOrd = &PedItmPagQtdTotCreOrd 
			&sdtpgtoItemItem.PedItmPagVlrTotCreOrd = &PedItmPagVlrTotCreOrd 
			//################
			&sdtpgtoItem.Add(&sdtpgtoItemItem)
		Endif
	EndiF

	
EndFor
//PedItmPagQtdTot
//PedItmPagVlrTot
//PedItmPagVlrSel
//PedItmPagIsSel
