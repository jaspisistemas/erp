      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//FUTURAMENTE VAI GERAR UM DEBITO COM O VALOR

For each order EmpCod, FilCod, CreCod
	where EmpCod = &EmpCod
	where FilCod = &FilCod
	where CreCod = &CreCod
		
	if not CreDtaRet.IsEmpty() and not CreDtaRet.IsNull()
		CreSts = Status_Duplicata.EM_REMESSA
	else
		CreSts = Status_Duplicata.ATIVO
	EndIf	
	GravaCobranca.Call(&EmpCod,&FilCod,&CreCod, ('EXTORNADO DESCONTO DUPLICATA - Cód. Desc.: ' + &DesCod.ToFormattedString()),0,0, ServerDate(), '00:00:00', TipoObservacaoDuplicata.INTERNA)
	Exit
EndFor
Commit
]]></Source>
