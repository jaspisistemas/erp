      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For &SdtDuplicatasItem in &SdtDuplicatas
	Do 'GetUltCodItm'
	new
		EmpCod = &EmpCod
		DesCod = &DesCod
		DesDupItmCod = &DesDupItmCod
		DesCreCod = &SdtDuplicatasItem.CreCod
		DesFilCod = &SdtDuplicatasItem.FilCod
	EndNew
	Commit
	
	//sts duplicata = descontada
	AlteraStatusDuplicataDescontada.Call(&EmpCod,&SdtDuplicatasItem.FilCod ,&SdtDuplicatasItem.CreCod, Status_Duplicata.DESCONTADA)
	
	
EndFor
Commit



Sub 'GetUltCodItm'
	//	&DesDupItmCod = 0
	For each order EmpCod, DesCod, (DesDupItmCod)
		where EmpCod = &EmpCod
		where DesCod = &DesCod
		&DesDupItmCod = DesDupItmCod
		exit
	EndFor
	&DesDupItmCod += 1
EndSub
]]></Source>
