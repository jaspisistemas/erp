      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsDeletou = false
For Each Order EmpCod, CreFrtFilCod, CreFrtCod, CreCod //DUPLICATA
	Where EmpCod = &EmpCod
	Where CreFrtFilCod = &FilCod
	Where CreFrtCod = &FrtCod
	where CreOriDup = OrigemDuplicata.ConhecimentoFrete
	
	if CreVlrSdo = CreVlrDup
		&IsDeletou = true
		For Each Order EmpCod, FilCod, CreCod, CreCobCod //COBRANCA
			delete
		EndFor		
		
		If not CreCheCod.IsEmpty() and not CreCheCod.IsNull()
			&cheCod =  CreCheCod
			Do 'CancelaCheque'
		Endif
	
		delete
	else
		&Mensagem = 'Duplicata não pode ser eliminada, possui pagamentos!'
	EndIF
	
	Exit
EndFor


if &IsDeletou = true
	For Each ORder EmpCod, FilCod, FrtCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where FrtCod = &FrtCod
		if FrtStsFin <> Status_Financeiro.FECHADO
			&Mensagem = 'Nenhuma duplicata localizada!'
		EndIF
		
		&FrtStsFin = FrtStsFin
		
		//GRAVA LOG
		&TabelaVarchar = 'FRETE'
		&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(Str(FrtCod))
			&LogErpRegTip = TrnMode.Update
			&LogErpRegGUID.SetEmpty()
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'FrtStsFin', trim(FrtStsFin), trim(&FrtStsFin), &LogErpRegGUID )
		Endif
		//GRAVA LOG
		
		FrtStsFin = Status_Financeiro.ABERTO
		
		Exit
	EndFor
Else
	&Mensagem = 'Nenhuma duplicata localizada!'
EndiF


Commit



Sub 'CancelaCheque'
	For each Order EmpCod,CheCod
		Where EmpCod = &EmpCod
		Where CheCod = &cheCod
		
		CheMot = MotivoCheque.CANCELADO
		//delete 
		
		Exit
	EndFor
EndSub
]]></Source>
