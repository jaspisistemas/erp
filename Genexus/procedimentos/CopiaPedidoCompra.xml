      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
&Mensagem = ''

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
    
	UltimoCodigoEmpresa.Call(domParCod.PEDIDO, EmpCod, FilCod, &NovoPedCod)
	
    New
		EmpCod = EmpCod
        FilCod = FilCod
        PedCod = &NovoPedCod
        LctCod = &NovLctCod
        PedCliCod = &NovPedCliCod
        PedDtaEms = serverdate()
		PedHorEms = ServerTime()
		PedDtaFat = nullvalue(PedDtaFat)
		PedDtaFic = nullvalue(PedDtaFic)
		PedDtaDsp = nullvalue(PedDtaDsp)
		PedHorDsp.SetEmpty()
		PedHorFat.SetEmpty()
		PedHorEmb.SetEmpty()
        PedSts = Status_Pedido.CANCELADO
        PedStsFin = Status_Financeiro.ABERTO
		PedVlrAgr = 0
		PedCodAgr = 0
		PedCnhEms.SetEmpty()
		PedCnhTraCod.SetEmpty()
		PedCnhFrt = ''
		PedCnhVlr = 0
		PedDtaPrv.SetEmpty()
    EndNew
EndFor

Commit


For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
    new
		EmpCod = EmpCod
        FilCod = FilCod
        PedCod = &NovoPedCod
        PedItmCod = PedItmCod
        PedQtdCan = 0
    EndNew
EndFor

commit

CriticasPedido.Call(&EmpCod, &FilCod, &NovoPedCod, TipoCriticaPedido.Digitado, &Context.PesCod)

AtualizaEstoqueGerencialCompra.Call(&EmpCod, &FilCod, &NovoPedCod, serverdate(),&PesCod,  Status_Pedido.ABERTO)


&Mensagem = 'Copia de Pedido concluído. Gerado Pedido Número: ' + trim(str(&NovoPedCod))
]]></Source>
