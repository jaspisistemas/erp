      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&count = 0
&auxcount = 0

For each Order EmpCod,MovCod
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	
	&MovCplMan = MovCplMan
	
	For Each Order EmpCod, MovCod, MovItmCod
		where MovItmSts <> Status_Caixa.Cancelado
		
		&count +=1
		&MovCreFilCod = MovCreFilCod
		&MovCreCod = MovCreCod
		Do 'ValidaDuplicata'
		
		Do Case
			Case (MovTip = TipoMovimento.Manual) and &count > 1
				&MovItmCpl = 'LANÇAMENTOS DIVERSOS'
				
			Case MovTip = TipoMovimento.FolhaPgto
				If &MovFunCod <> MovFunCod
					&auxcount +=1
				EndIf
				&MovFunCod = MovFunCod
				If &auxcount > 1
					&MovItmCpl = 'PGTO FUNCIONARIO: FOLHAS DIVERSAS'
				Else
					&MovItmCpl = SubStr(Trim(MovItmCpl),1,100)
				EndIf
			
			Case not (MovTip = TipoMovimento.Manual) and &count > 1
				If &auxcount > 1
					&MovItmCpl = 'CL: CLIENTES DIVERSOS'
				Else
					&MovItmCpl = SubStr(Trim(MovItmCpl),1,100)
				EndIf			

			Otherwise
				&MovItmCpl = SubStr(Trim(MovItmCpl),1,100)
//				Exit
		EndCase
	EndFor

	If NOT &MovCplMan.Trim().IsEmpty()
		&MovItmCpl += ', ' + &MovCplMan.Trim()
	EndIf
EndFor


Sub 'ValidaDuplicata'
	if &MovCreCod <> 0
		&CreCliCod.SetEmpty()
		For Each Order EmpCod, FilCod, CreCod
			Where EmpCod = &EmpCod
			Where FilCod = &MovCreFilCod
			Where CreCod = &MovCreCod
			&CreCliCod = CreCliCod
			Exit
		EndFor
		
		if &OldCreCliCod.IsEmpty() or &OldCreCliCod <> &CreCliCod
			&auxcount +=1
		Endif
		&OldCreCliCod = &CreCliCod
	Endif
EndSub
]]></Source>
