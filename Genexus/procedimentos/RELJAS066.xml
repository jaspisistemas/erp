Sub 'Tabela'
	For each Order EmpCod TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		
		If not TabColNom.trim().IsEmpty()
			&nome = TabColNom
		Else
			&nome = 'Col.' + trim(str(TabColCod))
		EndiF
		
		Do Case
			Case  TabColCod = 1
				Do 'AddTitle'
			Case TabColCod = 2
				Do 'AddTitle'
			Case TabColCod = 3
				Do 'AddTitle'
			Case TabColCod = 4
				Do 'AddTitle'
			Case TabColCod = 5
				Do 'AddTitle'
		EndCase
	EndFor
EndSub

sub 'AddTitle'
	Do Case
		Case &Col1.IsEmpty()
			&Col1 = &nome
		Case &Col2.IsEmpty()
			&Col2 = &nome
		Case &Col3.IsEmpty()
			&Col3 = &nome
		Case &Col4.IsEmpty()
			&Col4 = &nome
		Case &Col5.IsEmpty()
			&Col5 = &nome
	EndCase
	
EndSub

Sub 'Confirmado'
	&mensagem = ''
	&mensagem = 'Confirmada a alteração de acréscimo/Desconto nas seguintes colunas da tabela de preço '
	
	If &IsColuna1 = true and &TabPrc1 <> 0
		&mensagem += Newline() + 'COLUNA 1:  '+ trim(toformattedString(&TabPrc1)) + '%'
	EndIF
	If &IsColuna2 = true and &TabPrc2 <> 0
		&mensagem += Newline() + 'COLUNA 2:  '+ trim(toformattedString(&TabPrc2)) + '%'
	EndIF
	If &IsColuna3 = true and &TabPrc3 <> 0
		&mensagem += Newline() + 'COLUNA 3:  '+ trim(toformattedString(&TabPrc3)) + '%'
	EndIF
	If &IsColuna4 = true and &TabPrc4 <> 0
		&mensagem += Newline() + 'COLUNA 4:  '+ trim(toformattedString(&TabPrc4)) + '%'
	EndIF
	If &IsColuna5 = true and &TabPrc5 <> 0
		&mensagem += Newline() + 'COLUNA 5:  '+ trim(toformattedString(&TabPrc5)) + '%'
	EndIF
&mensagem = &mensagem.ToUpper()
EndSub

