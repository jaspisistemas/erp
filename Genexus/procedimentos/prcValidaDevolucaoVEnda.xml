        <Source><![CDATA[
&IsErro = false
For Each ORder EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	prcRetornaQtdVendido.Call(EmpCod, FilCod, PedCodOciRef, PedCodOciRefItm, ProCod, ProGraCod, &PedVlrUnt, &PedQtdVend, &PedItmCmp, &PedItmCmpInt, &PedItmVenCod)
	&PedQtdDev_FORMULA = prcPedQtdDevItem_FORMULA.udp(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod)
	&DisponivelPedQtd = &PedQtdVend - &PedQtdDev_FORMULA
	
//	if &DisponivelPedQtd < PedQtd
