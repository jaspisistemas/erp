      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[RetornaConfSistema.Call(&EmpCod, 1, domConfSistema.TCon054_TrabalharGrades, &ValorConfiguracao)
For Each Order EmpCod, RotCod
	Where EmpCod = &EmpCod
	Where RotAutCod = 'WWMODALIDADE'

		if &ValorConfiguracao <> 'S' //GRADE PRODUTOS
			RotSts = Status_AtivoInativo.INATIVO
		Else
			RotSts = Status_AtivoInativo.ATIVO
		EndiF
		
	Exit
EndFor

