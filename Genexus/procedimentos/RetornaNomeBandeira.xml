      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&BanCarNom = ''
For Each ORder EmpCod, BanCarCod
	Where EmpCod = &EmpCod
	Where BanCarCod = &BanCarCod 
	if BanCarNom.Length() > 10
		&BanCarNom  = Substr(BanCarNom,1,10) + '...'
	Else
		&BanCarNom  = Substr(BanCarNom,1,10) 
	Endif

	Exit
EndFor

]]></Source>
