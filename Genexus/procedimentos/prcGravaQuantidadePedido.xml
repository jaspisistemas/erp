      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, PedCod //PEDIDO
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&TabDtaVct = TabDtaVct 
	&TabPerAcr = TabPerAcr
	&TabPerAnt = TabPerAnt
	&LctRetCus = LctRetCus
	&TabCod = TabCod
	&TabPrmCod = TabPrmCod
	&TabColCod = TabColCod
	&PedDtaEms = PedDtaEms
	&PedDtaVct = PedDtaVct
	&LctInfPrc = LctInfPrc
	&PedCliCod = PedCliCod
	&TabIsAntAcr = TabIsAntAcr
	
	//, &inFilCod, &inPedCod, ProCod, ProGraCod, &PedQtd
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&PedQtdCan = PedQtdCan
		If &PedQtd <> PedQtd
			&PedQtdCan = PedQtdCan + (PedQtd - &PedQtd)
		EndIF
		
		if &PedQtd > 0
			GravaItempedidoVenda_Precificacao.Call(&EmpCod, &FilCod, &PedCod, PedItmCod, ProCod, ProGraCod, &PedQtd, &PedQtdCan, PedVlrUnt, PedVlrTab, PedItmDsc, PedItmCmp, PedItmVenCod, PedCodOciRefItm, &TabDtaVct, &TabPerAcr, &TabPerAnt, PedItmProRefDig, PedNItmPed, &MensagemInserido, &MensagemAlterado)
		Else
			DeletaItemPedidoCompra.Call(EmpCod, FilCod, PedCod, PedItmCod)
		Endif
		
		Exit
	When none
		if &PedQtd > 0
			do 'addNew'
		Endif
	EndFor
	
	Exit
EndFor


Sub 'addNew'
	For Each Order EmpCod, ProCod
		Where EmpCod  = &EmpCod
		Where ProCod = &ProCod
		&ProVlrCus = ProVlrCus
		&ProReqVlr = ProReqVlr
		Exit
	EndFor
	
	Do Case
		Case (&LctRetCus = Status_SimNao.Sim)
			&PedVlrUnt = &ProVlrCus
			&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaEms)
			
		Case (&LctInfPrc = Status_SimNao.Nao and &ProReqVlr <> true) or &PedVlrUnt <= 0
			
			&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaEms)
			&EspPedVlrUnt = RetornaPrecoEspecialCliente.UDP(&EmpCod, &PedCliCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms)
					
			if &TabIsAntAcr = true
				RetornaPrecoUnitarioVendaPrecificado.Call(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct, &PedVlrUnt, &TabPerAcr, &TabPerAnt, &TabDtaVct)
			Else
				&PedVlrUnt = &PedVlrTab
				&TabPerAcr.SetEmpty()
				&TabPerAnt.SetEmpty()
				&TabDtaVct.SetEmpty()
			EndIf
				
			if &EspPedVlrUnt < &PedVlrUnt and &EspPedVlrUnt > 0
				&PedItmDsc = 100 - ((&EspPedVlrUnt / &PedVlrUnt) * 100)
			EndIF
	EndCase
	
	If &PedVlrUnt > 0
		GravaItempedidoVenda_Precificacao.Call(&EmpCod, &FilCod, &PedCod, 0, &ProCod, &ProGraCod, &PedQtd, 0, &PedVlrUnt, &PedVlrTab, 0, '', 0, 0, &TabDtaVct, &TabPerAcr, &TabPerAnt, &PedItmProRefDig, &PedNItmPed, &MensagemInserido, &MensagemAlterado)
	Endif

EndSub

]]></Source>
