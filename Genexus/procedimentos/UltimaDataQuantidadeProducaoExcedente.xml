      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&AuxOrdGrupHie = &OrdGrupHie.Trim() + '.'

&AntOrdProQtd = 0 
&AntPedDtaFat.SetEmpty()
&IsAlgumaCoisa = false
For Each Order EmpCod, FilCod, OrdProCod, OrdProGraCod, (OrdDta)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdCod < &OrdCod when &OrdCod <> 0
	Where OrdDta < &OrdDta
	Where OrdSts = Status_Producao.EmProducao or OrdSts = Status_Producao.Produzido
	Where OrdProCod = &ProCod
	Where OrdProGraCod = &ProGraCod
	//Where OrdProQtd > 0
	Where OrdTip = TipoOrdem.OrdemProducao //Ordem Producao
	//Where OrdSetCod = &OrdSetCod
	//Where OrdGrupHie = &OrdGrupHie or OrdGrupHie like &AuxOrdGrupHie
	Where OrdProQtd >= 0 and OrdProEstPrd >= 0
	
	&IsAlgumaCoisa = true
	
	Do Case			
		Case not OrdProQtd.IsEmpty() and &AntPedDtaFat.IsEmpty()
			&AntPedDtaFat = OrdDta
			
			if &AntOrdProQtd.IsEmpty()
		    	&AntOrdProQtd = OrdProQtd
			EndIF
		
		Case OrdProQtd.IsEmpty() and &AntOrdProQtd.IsEmpty()
			&AntOrdProQtd = OrdProEstPrd
			if not &AntOrdProQtd.IsEmpty()
				&AntPedDtaFat = OrdDta
			EndIF
		
	EndCase

//	If not &AntPedDtaFat.IsEmpty()
	    exit
//	EndIF
EndFor


if &AntPedDtaFat.IsEmpty() or &AntOrdProQtd.IsEmpty() and &IsAlgumaCoisa = false
//	For Each Order EmpCod, FilCod, OrdSts, OrdProCod, OrdProGraCod, (OrdDta)
//		Where EmpCod = &EmpCod
//		Where FilCod = &FilCod
//		Where OrdCod < &OrdCod when &OrdCod <> 0
//		Where OrdDta < &OrdDta
//		Where OrdSts = Status_Pedido.FECHADO
//		Where OrdProCod = &ProCod
//		Where OrdProGraCod = &ProGraCod
//		//Where OrdProQtd > 0
//		Where OrdTip = 'O' //Ordem Producao
//		//Where OrdSetCod = &OrdSetCod
//		//Where OrdGrupHie = &OrdGrupHie or OrdGrupHie like &AuxOrdGrupHie
//		Where OrdProEstPrd > 0 or OrdProQtd > 0 
//		
//		if OrdProQtd.IsEmpty()
//			&AntOrdProQtd = OrdProEstPrd
//		Else		
//		    &AntOrdProQtd = OrdProQtd
//		EndIF
//		
//		if &AntPedDtaFat.IsEmpty()
//		    &AntPedDtaFat = OrdDta
//		EndIF
//		
//	    exit
//	EndFor

	&dataSIC = CtoD('15/02/2016')
	For Each Order EmpCod, FilCod, ProCod, ProGraCod, PedSts, LctAtuPro, (PedDtaEms)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where PedSts = Status_Pedido.FECHADO
		Where LctAtuPro = Status_EntradaSaida.Entrada
		//Where PedQtd > 0
		Where PedDtaEms < &OrdDta and PedDtaEms < &dataSIC
	
		if PedQtd > 0 or EstPrd > 0
			if &AntOrdProQtd.IsEmpty()
				if PedQtd > 0
		    		&AntOrdProQtd = PedQtd
				Else
					&AntOrdProQtd = EstPrd
				EndiF
			EndIF
	
			if &AntPedDtaFat.IsEmpty()
	    		&AntPedDtaFat = PedDtaEms
			EndIf
		EndIF
	
		Exit
	EndFor

EndIf
]]></Source>
