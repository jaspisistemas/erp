      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//[(Salário Bruto – Dependentes – INSS) • Alíquota – Dedução] = IRRF
&IrrfTax = 0
&IrrfDed = 0
&PesDepVlr = 0
For each Order EmpCod,IrrfVlrIni,IrrfVlrFin
	Where EmpCod = &EmpCod
	Where IrrfVlrIni <= &PesVlrSalCat and  IrrfVlrFin >= &PesVlrSalCat 
	&IrrfTax = IrrfTax       // Alíquota
	&IrrfDed = IrrfDed       // Valor Dedução
	&IrrfDedDep = IrrfDedDep // Valor por Dependente
	Exit
EndFor

If &PesFunQtdDep > 0 //Qtd * Valor
	&PesDepVlr = (&PesFunQtdDep * &IrrfDedDep)
EndIf

If &IrrfTax > 0 
	&IrrfTax = (&IrrfTax / 100)
	&IrrfPesVlrSalCat = ((&PesVlrSalCat - &PesDepVlr - &PesVlrIns) * &IrrfTax) - &IrrfDed
	&IrrfPesVlrSalCat = iif(&IrrfPesVlrSalCat < 0,0,&IrrfPesVlrSalCat)
	&IrrfTax = (&IrrfTax * 100)
EndIf
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
