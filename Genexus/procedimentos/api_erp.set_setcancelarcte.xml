      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&xJust = &Justificativa

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	For Each ORder EmpCod, FilCod, CteCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&CteAutNumPro = CteAutNumPro
		&CteChv = CteChv
		Exit
	When none
		&sdtCte.sts = 'E998'
		&sdtCte.obs = 'CTe não localizado!'
		return
	Endfor

 	&erro = 0 
    &Tamanho = len(&xJust)
    if &tamanho < 15 or &tamanho > 255
        &sdtCte.sts = 'E993'
		&sdtCte.obs = 'Tamanho da justificativa tem que ficar entre 15 e 255'
		return
        &erro = 1
    else
        For &Posicao = 1 to &Tamanho
            if (substr(&xJust,&Posicao,1) < ' '  or (substr(&xJust,&Posicao,1) > 'z'  ))
                &sdtCte.sts = 'E994'
				&sdtCte.obs = 'Caracter especial '+  substr(&xJust,&Posicao,1) + 'Não é permitido' 
				return
                &erro = 1
				Exit
            Endif
        EndFor
    EndIf
	
	Do Case
		Case &CteChv.IsEmpty()
			&sdtCte.sts = 'E998'
			&sdtCte.obs = 'CTe não possui a chave do CTe, só pode cancelar um CTe se a mesma estiver autorizada!'
			return
			
		Case &CteAutNumPro.IsEmpty()
			&sdtCte.sts = 'E997'
			&sdtCte.obs = 'CTe não possui número do protocolo, consulte o CTe no SEFAZ!'
			return
			
		Case &erro = 0
			GeraXmlCancelamentoCte.Call(&wwpContext.EmpCod, &FilCod, &CteCod, &xJust, &wwpContext.PesCod, &tmpNfeEnvEml,&tmpCancelarDuplicatas, &SolCod)
			
	EndCase
	
	&guid = GUID.NewGuid()
	&ProgressId = 'autCTe' + trim(&guid.ToString())
	&ProgressId = &ProgressId.trim()
	
	RecepcaoCte.Submit(&ProgressId, &ProgressId, &wwpContext.EmpCod, &FilCod, &CteCod, &SolCod)
	
	&sdtCte.sts = 'J200'
	&sdtCte.SolCod = &SolCod
	&sdtCte.obs = 'Iniciado transmissão!'
	&sdtCte.arq = &ProgressId
	return
Else
	&sdtCte.sts = 'E999'
	&sdtCte.obs = 'Nada mais aqui!'
	return
Endif
]]></Source>
