      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NfeArqXml = ''
&xmlNFe.Open(&ArquivoPronto)    
Do While  not &xmlNFe.EOF
    &NfeArqXml += &xmlNFe.ReadRawXML()
    &xmlNFe.Read()
Enddo
&xmlNFe.Close()

If &NfeArqXml <> ''
	LeituraXmlNFSeNacional.Call('', &ArquivoPronto, &NFSeLongVarchar, &sdtNFSeNacional)
	&sdtNFSeNacional.Fromxml(&NFSeLongVarchar)
//	&dhEmi = substr(&TNFeProc.NFe.infNFe.ide.dhEmi ,9,2) +'/'+ Substr(&TNFeProc.NFe.infNFe.ide.dhEmi,6,2) +'/'+ Substr(&TNFeProc.NFe.infNFe.ide.dhEmi,1,4)
//	&NfeDtaEms = CtoD(&dhEmi)
	
	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod
//		Where FilCod = &FilCod
		Where NfsCod = &NfsCod
		
		if (NfsNum.IsEmpty() or NfsNum.IsNull())
			NfsNum = val(&sdtNFSeNacional.infNFSe.nNFSe)
		Endif
		
		if (NfsChv.IsEmpty() or NfsChv.IsNull())
			NfsChv = retornaSONUmeros.Udp(&sdtNFSeNacional.infNFSe.Id)
		Endif
	
//		NfeDtaEms = &NfeDtaEms
//		NfeDtaDsp = &NfeDtaEms
		NfsArqXml = &NfeArqXml
		
		NfsTotISS = val(&sdtNFSeNacional.infNFSe.valores.vISSQN)
		NfsPerISS = val(&sdtNFSeNacional.infNFSe.valores.pAliqAplic)
		
		NfsVlrTot = val(&sdtNFSeNacional.infNFSe.valores.vLiq)
//		if NfeProTer = Nota_ProPriaTerceira.PROPRIA or NfePedCod = 0
//			NfeDtaFat = &NfeDtaEms
//			NfeDtaFat_Ano = &NfeDtaEms.Year()
//			NfeDtaFat_Mes = &NfeDtaEms.Month()
//		Endif	
	
		Exit
	EndFor
EndIF

commit

]]></Source>
