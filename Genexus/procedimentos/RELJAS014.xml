      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'MOVIMENTO FINANCEIRO'
	print Cabecalho
	Print Titulo
End

Do 'Conta'
Do 'Saldo'
&Deb2MovVlr = 0
&DebMovVlr  = 0
&Cre2MovVlr = 0
&CreMovVlr  = 0
&Tot2MovVlr = 0
For each Order EmpCod,MovCtaBanCod,MovDtaCon,MovCod
	Where EmpCod = &EmpCod
	Where MovCtaBanCod = &CtaBanCod
	Where MovDtaPgt >= &DtaIni when not &DtaIni.IsEmpty() AND &ExtFil = 2
	Where MovDtaPgt <= &DtaFin when not &DtaFin.IsEmpty() AND &ExtFil = 2
	Where MovDtaCon >= &DtaIni when not &DtaIni.IsEmpty() AND &ExtFil = 1
	Where MovDtaCon <= &DtaFin when not &DtaFin.IsEmpty() AND &ExtFil = 1
	Where MovSts.IsEmpty() or MovSts.IsNull() or MovSts <> Status_Caixa.Cancelado
		
	&MovCpl = MovCplTot
	For each Order EmpCod,MovCod
		Where MovItmSts.IsEmpty() or MovItmSts.IsNull() or MovItmSts <> Status_Caixa.Cancelado
		&MovItmCpl = ''
		&MovItmCpl = trim(PlanNom)+' | '+trim(&MovCpl)
		If MovCreCod <> 0
			&MovItmCpl +=' DUP: '+padl(trim(str(MovCreCod)),8,'0')
		EndIf
		Exit
	EndFor

	&MovCod = MovCod
	&MovDoc = trim(MovDoc)
	&MovDta = MovDtaPgt
	&MovDtaCon = MovDtaCon
	&MovVlr = MovVlr
	
	If MovCreDeb = 'C'   //Crédito
		If not MovDtaCon.IsEmpty()
			&SdoMovVlr += &MovVlr
			&CreMovVlr += &MovVlr //Total Crédito
		Else
			&Cre2MovVlr += &MovVlr //Total Crédito Não Conferido
		EndIf
		
		Print Receita
	Else
		If not MovDtaCon.IsEmpty()
			&SdoMovVlr -= &MovVlr
			&DebMovVlr -= &MovVlr //Total Débito
		Else
			&Deb2MovVlr -= &MovVlr //Total Débito Não Conferido
		EndIf
		&MovVlr = (&MovVlr * -1)
		Print Saida
	EndIf

	If &IsMostraDetalhe = 'S' and MovMaxItm > 1	
		For each Order EmpCod,MovCod
			
			 MovItmCod
			&MovItmVlr = MovItmVlr
			&MovItmCpl = 'ITEM:'+trim(Str(MovItmCod))+' '+trim(PlanNom)+' | '+trim(MovItmCpl)
			&auxMovItmCpl = 'FUN: '+padl(trim(str(MovFunCod)),8,' ') + ' DUP: '+padl(trim(str(MovCreCod)),8,' ')+ ' TRAN. Ori.: '+padl(trim(str(MovTrnOriCod)),8,' ')
			Print Detalhe
		EndFor
	EndIf
EndFor
&Tot2MovVlr = &Cre2MovVlr + &Deb2MovVlr  //Total não conferido
Print Total

Footer
	print Rodape
End

Sub 'Conta'
	&CtaBanCodNom = ''
	For each Order EmpCod,CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		&CtaBanCodNom = CtaBanCodNom
		exit
	Endfor
EndSub
	
Sub 'Saldo'
	For each Order EmpCod,CtabanCod,(SdoDta)
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		Where SdoDta < &DtaIni		
		&MovDta = SdoDta
		&MovVlr = 0
		&SdoMovVlr = SdoAtu
		Exit
	EndFor
	Print Conta
	noskip
	Print Conta
EndSub
]]></Source>
