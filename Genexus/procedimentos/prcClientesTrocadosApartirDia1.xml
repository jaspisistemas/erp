      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

MB 4
MT 2

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	&Filtro = format('VENDEDOR ANTERIOR: %1 - %2', trim(Str(PesCod)), PesRaz.Trim())
	Exit
EndFor


Header
	&titulo = 'CLIENTES TROCADOS DE TELEVENDAS'
	
	print Cabecalho
	print Titulo
End

padraoUsuario.Call('L', 'PRCCLIENTESTROCADOSAPARTIRDIA', &EmpCod, 1, &PadObs, &PaddtaMod)
&sdtPessoa.FromJson(&PadObs)

For &sdtPessoaItem in &sdtPessoa
	for Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &sdtPessoaItem.PesCod
		
		&PesCod = &sdtPessoaItem.PesCod
		&PesRaz = &sdtPessoaItem.pesRaz 
		&PesIntVenCod = &sdtPessoaItem.PesIntVenCod
		&PesIntVenNom = PesIntVenNom

		RetornaVinculos.Call(EmpCod, PesCod, &sdtVinculos)
		do 'GetObs'
		print Cliente
		print Dialogo
		
		for &sdtVinculosItem in &sdtVinculos
			if &sdtVinculosItem.PesCod <> PesCod
				&PesCod = &sdtVinculosItem.PesCod
				&PesRaz = &sdtVinculosItem.PesRaz
				print Vinculo
			Endif
		EndFor
		
		print Traco
	EndFor

EndFor

Footer
//	print Rodape
End


Sub 'GetObs'
	RetornaObs.Call(&EmpCod, &sdtVinculos, &OldPesVenCod, &NewPesCod, &DataBase, &Obs)
EndSub

]]></Source>
