      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each ORder EmpCod, PesCod, ComLctCod, ComDscItm //when &PedItmPrm = domPedItmPrm.NORMAL
	Where EmpCod = &EmPCod
	Where PesCod = &PedVenCod
	Where ComLctCod = &LctCod
	Where ComDscTabCod.IsEmpty() or ComDscTabCod.IsNull() or ComDscTabCod = &TabCod
	Where ComDscTabColCod = &TabColCod or ComDscTabColCod = 0
	
	&sdtComissaoItem = new()
	if &PedItmPrm = domPedItmPrm.NORMAL
		&sdtComissaoItem.ComPer = ComDscNor
		&sdtComissaoItem.comvlrCom = Round(&PedVlrTab * (ComDscNor*0.01), 2)
	Else
		&sdtComissaoItem.ComPer = ComDscPrm
		&sdtComissaoItem.comvlrCom = Round(&PedVlrTab * (ComDscPrm*0.01), 2)
	Endif
	
	&sdtComissaoItem.ComVlr = Round(&PedVlrTab - (&PedVlrTab * (ComDscTax*0.01)), 2)
	
	Do case
		Case not ComDscTabColCod.IsEmpty() and not ComDscTabColCod.IsNull()
			&sdtComissaoItem.Mensagem = 'Exclusivo Coluna: '+trim(str(ComDscTabColCod))
			
		CAse not ComDscTabCod.IsEmpty() and not ComDscTabCod.IsNull()
			&sdtComissaoItem.Mensagem = 'Exclusivo Tabela: '+trim(ComDscTabCod)
	EndCase
	
	&sdtComissao.Add(&sdtComissaoItem)
EndFor
]]></Source>
