<Object parentGuid="afa47377-41d5-4ae8-9755-6f53150aa361" user="WIN-JEAN\jean.fae" versionDate="2024-08-22T13:53:50.0000000Z" lastUpdate="2024-08-21T17:05:38.0000000Z" checksum="8730c1a28be094b2516110162b6b72cd" fullyQualifiedName="prcAlteraDescontoPedidoProduto" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="647459e1-1771-413c-b13c-29e252a0a75d" name="prcAlteraDescontoPedidoProduto" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Altera Desconto Pedido Produto">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon017_DescMax, &Varchar)
	&TCon017_DescMax = val(&Varchar) //Tabela Normal

	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon131_DescMaxTabPromocao, &Varchar)
	&TCon131_DescMaxTabPromocao = val(&Varchar) //Tabela Normal
	
	If &wwpContext.TipoPerfil <> 3 																		//## Se o perfil do usuário for diferente de ADM ##\\
		RetornaAutorizacaoDescontoMaximo.Call(&EmpCod, &wwpContext.PesCod, &IsAutorizadoDescontoMaximo)	//## Verifica se ele está autorizado a dar o desconto máximo ##\\
	Else																								
		&IsAutorizadoDescontoMaximo = True																//## Se o perfil for ADM, ele estará autorizado a dar o desconto máximo ##\\
	EndIf
	
	do 'CarregaPedido'	

	For Each Order EmpCod, FilCod, PedCod	//## Faz uma pesquisa na Tabela PedidoProduto ##\\
		Where EmpCod = &EmpCod				//## Código da Empresa passada por parâmetro ##\\
		Where FilCod = &FilCod				//## Código da Filial passada por parâmetro ##\\
		Where PedCod = &PedCod				//## Código do pedido passado por parâmetro ##\\
	
		&PedVlrUnt = PedVlrUnt				//## Define o Valor Unitário do Item ##\\
		&PedVlrTab = PedVlrTab				//## Define o Valor do Item referente a sua tabela de preço ##\\
		
		
		&ProCod = ProCod					//## Código do Produto (Item) ##\\
		&ProRef = ProRef
		&ProNom = ProNom
		&ProDesMax = ProDesMax			//## Desconto máximo do PRODUTO (Item) ##\\
		&GrupDscMax = GrupDscMax		//## Desconto máximo do GRUPO do Produto ##\\
		
		&ProGraCod = ProGraCod					//## Código da Grade do Produto ##\\
		&ProGraRef = ProGraRef					//## Código de Barras do Produto ##\\
		
		
		RetornaTotalAutorizado.Call(&EmpCod, &FilCod, &PedCod, &ProCod, &ProGraCod, &PedLibAutPedQtd, &PedLIbAutPedVlr, &PedLibAutPedDesc)	//## Verifica as autorizações do pedido ##\\
		
		
		If &IsAutorizadoDescontoMaximo <> true	//## Se o usuário não estiver autorizado à dar o desconto máximo ##\\
					
			&TotalDescontos = 0
			IF (&PedVlrUnt <> &PedVlrTab) AND (&PedVlrUnt > 0) AND (&PedVlrTab > 0)
				&TotalDescontos = (100 - ((&PedVlrUnt / &PedVlrTab) * 100))
			EndIF
			
			//if &PedItmDsc > 0
			&TotalDescontos += &PedItmDsc
			//EndIF
			if &PedItmDsc < 0
				&TotalDescontos = 0
			Endif
		
			&PedItmPrm = PedItmPrm
			if PedItmPrm = domPedItmPrm.NORMAL and &TotalDescontos > 0
				&PedItmPrm = domPedItmPrm.DESCONTO
			Endif		
			
			&PedVlrItm = round((PedVlrUntDsc*PedQtd)/(1+&TotalDescontos/100),2)	//## Calcula o novo valor total com base no novo desconto ##\\
			
			VerificaDescontoMaximoPedidoItem.Call(EmpCod, FilCod, PedCod, &wwpContext, PedItmCod, &PedItmPrm, &PedVlrItm, &TotalDescontos, PedVlrUnt, &TCon017_DescMax, &TCon131_DescMaxTabPromocao, &PesDscMax, &ProDesMax, &GrupDscMax, &PedLibAutPedQtd, &PedLibAutPedVlr, &PedLibAutPedDesc, &ProRef, &ProNom, &Mensagem, &IsErro)
			&ErroDescontoMaximo = iif(&IsErro = true, 1, 0)
			if &IsErro = true
				&IsTensComErro = true
				&TotalMensagem += &Mensagem
			Endif
		
		EndIf
		
		If &ErroDescontoMaximo = 0											//## Se não houver NENHUM erro de desconto ##\\
			
			&PedVlrItm = round((PedVlrUntDsc*PedQtd)/(1+&PedItmDsc/100),2)	//## Calcula o novo valor total com base no novo desconto ##\\
			PedItmDsc = &PedItmDsc											//## Define o novo valor de desconto ##\\
			PedVlrItm = &PedVlrItm											//## Define o novo valor total ##\\
			PedVlrItmComDsc = &PedVlrItm									//## Define o novo valor total ##\\
			Commit
			
		EndIf
	
	EndFor


Sub 'CarregaPedido'
	
	For Each Order EmpCod, FilCod, PedCod	//## Faz uma busca na Tabela Pedido ##\\
		Where EmpCod = &EmpCod				//## Código da Empresa passada por parâmetro ##\\
		Where FilCod = &FilCod				//## Código da Filial passada por parâmetro ##\\
		Where PedCod = &PedCod				//## Código do Pedido passado por parâmetro ##\\
		
		&PesDscMax = PedCliDscMax			//## Desconto máximo do CLIENTE ##\\
		
		Exit
	EndFor
	
EndSub

]]></Source>
