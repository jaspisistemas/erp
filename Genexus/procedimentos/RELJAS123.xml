      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf


prcVendasVendedor.Call(&EmpCod, &FilCod, &PedVenCod, &PesVenIntExt, &RegistradoTodos, false, &AnoBase, &MesBase, &sdtPedidosVendedor, &sdtPedidosTotais)

if &MesBase.IsEmpty()
	&titulo = 'VENDAS X FATURADO MENSAL ANO BASE: ' + trim(str(&AnoBase))
	&TituloMesDia = 'MÊS'
Else
	&Varchar = cMonth(&Data, 'por')
	&titulo = 'VENDAS X FATURADO DIARIO MÊS/ANO BASE: ' + trim(UPPER(&Varchar)) +'/'+ trim(str(&AnoBase))
	&TituloMesDia = 'DIA'
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	
	print Cabecalho
End

RetornaNomevendedor.Call(&EmpCod, &PedVenCod, &PesISVen, &PesRaz)

print DadosVendedor

For &sdtPedidosTotalItem in &sdtPedidosTotais
	Do Case
		Case &sdtPedidosTotalItem.Descricao = 'VENDIDO'
			&TotalVendido = &sdtPedidosTotalItem.FaturadoMoeda
		Case &sdtPedidosTotalItem.Descricao = 'FATURADO'
			&TotalFaturado  = &sdtPedidosTotalItem.FaturadoMoeda
	EndCase
EndFor

prcRetornaMetaVendedor.call(&EmpCod, &PedVenCod, &PesVenIntExt, &RegistradoTodos, &AnoBase, &MetaAnualMOeda, &MetaMensalMoeda, &MetaDiariaMoeda)

print PrintTotais
Noskip
print Titulo

for &sdtPedidosVendedorItem in &sdtPedidosVendedor
	
	if &MesBase.IsEmpty() // MENSAL
		do Case
			CAse &sdtPedidosVendedorItem.Mes = 1
				&DiaMesVarchar = '1 - Janeiro'
			CAse &sdtPedidosVendedorItem.Mes = 2
				&DiaMesVarchar = '2 - Fevereiro'
			CAse &sdtPedidosVendedorItem.Mes = 3
				&DiaMesVarchar = '3 - Março'
			CAse &sdtPedidosVendedorItem.Mes = 4
				&DiaMesVarchar = '4 - Abril'
			CAse &sdtPedidosVendedorItem.Mes = 5
				&DiaMesVarchar = '5 - Maio'
			CAse &sdtPedidosVendedorItem.Mes = 6
				&DiaMesVarchar = '6 - Junho'
			CAse &sdtPedidosVendedorItem.Mes = 7
				&DiaMesVarchar = '7 - Julho'
			CAse &sdtPedidosVendedorItem.Mes = 8
				&DiaMesVarchar = '8 - Agosto'
			CAse &sdtPedidosVendedorItem.Mes = 9
				&DiaMesVarchar = '9 - Setembro'
			CAse &sdtPedidosVendedorItem.Mes = 10
				&DiaMesVarchar = '10 - Outubro'
			CAse &sdtPedidosVendedorItem.Mes = 11
				&DiaMesVarchar = '11 - Novembro'
			CAse &sdtPedidosVendedorItem.Mes = 12
				&DiaMesVarchar = '12 - Dezembro'
		EndCase
	Else
		&DiaMesVarchar = trim(Str(&sdtPedidosVendedorItem.Dia))
	Endif
	
	&FaturadoMoeda = &sdtPedidosVendedorItem.FaturadoMoeda
	&VendidoMoeda = &sdtPedidosVendedorItem.VendidoMoeda
	print Dados
	
EndFor



Footer
	print Rodape
End
]]></Source>
