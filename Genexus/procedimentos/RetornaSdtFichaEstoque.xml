      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AuxFim = serverdate()
&AuxFim = &AuxFim.AddDays(1)
EstoqueAnteriorFicha.Call(&EmpCod, &FilCod, &ProCod, &ProGracod, 1, &PedDtaFat, &AuxFim, &AntEstQtd)

&sdtFichaEstoque.Clear()
&TotPedQtd = &AntEstQtd

For Each Order EmpCod, FilCod, PedDtaFic, PedHorFat
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedProEstProCod = &ProCod or ProCod = &ProCod
	Where PedProEstProGraCod = &ProGracod or ProGraCod = &ProGracod When &ProGracod > 1
	Where PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO
	Where PedDtaFic >= &PedDtaFat and PedDtaFic <= &PedDtaFat_to
	Where LctAtuEst = Status_EntradaSaida.Saida or LctAtuEst = Status_EntradaSaida.Entrada
	Where PedCliCod = &PedCliCod or &PedCliCod = 0
	Where PedVenCod = &PedVenCod or &PedVenCod = 0
	Where PedQtd <> 0
	
	&Mensagem = ''
	&IsAchou = true
	if ProSolLot = SolicitarLote.SIM_CONTROLAR 
		PedItmCmpLotes_PedidoProduto.Call(EmpCod, FilCod, PedCod, PedItmCod, &Mensagem)
		if not &PedProEstLotCod.IsEmpty()
			&IsAchou = false
			if &Mensagem like '%LT: '+trim(&PedProEstLotCod)+'%'
				&IsAchou = true
			Endif
		Endif
	Endif

	if &IsAchou = true
		&Count += 1		
		&sdtFichaEstoqueItem = new()
		&sdtFichaEstoqueItem.Count = &Count
		&sdtFichaEstoqueItem.ProCod = ProCod		

		&sdtFichaEstoqueItem.ProRef = ''
		&sdtFichaEstoqueItem.ProRef = PedItmProRefDig
		if &sdtFichaEstoqueItem.ProRef.IsEmpty()
			&sdtFichaEstoqueItem.ProRef = ProRef
		Endif
	
		&sdtFichaEstoqueItem.DtaFat = PedDtaFic
		
		if PedSts = Status_Pedido.FECHADO	
			&sdtFichaEstoqueItem.PedSts = Status_Pedido.fechADO
		Else
			&sdtFichaEstoqueItem.PedSts = Status_Pedido.SEPARANDO
		EndIF
		
		&sdtFichaEstoqueItem.AtuEst = LctAtuEst
		&sdtFichaEstoqueItem.PedCod = PedCod
		&sdtFichaEstoqueItem.LctCod = LctCod
		&sdtFichaEstoqueItem.VenCod = PedVenCod
		
		If LctTip = TipoLancamento.MovimentacaoValores
			&sdtFichaEstoqueItem.CliCRaz = LctCodNom
		Else
			&sdtFichaEstoqueItem.CliCRaz = PedCliCodRaz_Nov
		Endif
		
		&sdtFichaEstoqueItem.EmpCod = EmpCod
		&sdtFichaEstoqueItem.FilCod = FilCod
				
		if LctAtuEst = Status_EntradaSaida.Entrada
			&PedQtd = PedQtd
			RetiraZerosDepoisVirgulaxCasas.Call(0, &PedQtd.ToFormattedString(), &sdtFichaEstoqueItem.QtdEnt)
			&sdtFichaEstoqueItem.QtdSai = ''
			&qtdEntPed += 1
			&EntPedQtd += PedQtd
			&TotPedQtd += PedQtd
		Else
			&PedQtd = (PedQtd * -1)
			
			RetiraZerosDepoisVirgulaxCasas.Call(0, &PedQtd.ToFormattedString(), &sdtFichaEstoqueItem.QtdSai)
			&sdtFichaEstoqueItem.QtdEnt = ''
			&qtdSaiPed += 1
			&SaiPedQtd += PedQtd
			&TotPedQtd += &PedQtd
		EndIF
		
		RetiraZerosDepoisVirgulaxCasas.Call(2, PedVlrCus.ToFormattedString(), &sdtFichaEstoqueItem.VlrCus)
		RetiraZerosDepoisVirgulaxCasas.Call(2, PedVlrUntComDsc.ToFormattedString(), &sdtFichaEstoqueItem.VlrUnt)
		
		RetiraZerosDepoisVirgulaxCasas.Call(0, &TotPedQtd.ToFormattedString(), &sdtFichaEstoqueItem.QtdEst)
		
		&sdtFichaEstoqueItem.Lotes = &Mensagem
		
		&sdtFichaEstoque.Add(&sdtFichaEstoqueItem)
	Endif
EndFor
]]></Source>
