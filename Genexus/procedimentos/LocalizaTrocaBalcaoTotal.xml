      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCodOciRef = &PedCodOciRef
	Where PedStsGer = Pedido_Gerado.TrocaMercadorias
	Where LctTip = TipoLancamento.DevolucaoVenda
	Where PedSts = Status_Pedido.ABERTO
	
	&DevPedCod = PedCod
	&DevPedVlrLiq = PedVlrLiq
	
	Exit
EndFor
]]></Source>
