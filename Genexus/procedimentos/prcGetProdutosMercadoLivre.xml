      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErro = true

for Each Order EmpCod, MrkCod
	where EmpCod = &EmPCod
	where MrkCod = &MrkCod
	
	prcMercadolivreRefreshToken.Call(EmpCod, MrkCod, &MrkSession, &IsSucesso)
	&MrkSellID = MrkSellID
	Exit
EndFor

if &IsSucesso = true
	&Pagina = 0
	
	&IsContinua = true
	Do while (&IsContinua = true)
		&HttpClient.AddHeader('Content-Type', 'application/json')
		&HttpClient.AddHeader('Accept', 'application/json')
		&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
		&HttpClient.Execute('GET', 'https://api.mercadolibre.com/users/'+&MrkSellID+'/items/search?&offset='+trim(str(&Pagina))+'&limit=50')
		
		If &HttpClient.StatusCode = 200
			&sdtListaProdutos.FromJson(&HttpClient.ToString())
			For &sdtListaProdutosResults  in &sdtListaProdutos.results
				prcGravaProdutosImportados.Call(&EmPCod, &MrkCod, &sdtListaProdutosResults)
			Endfor
			
			&PaginaTotal = &sdtListaProdutos.paging.total		
			&Pagina += 1
			
			if &Pagina = &PaginaTotal
				&IsContinua = false
			Endif		
		Else
			&IsErro = false
			msg('Falha catastrófica! ' + &HttpClient.StatusCode.ToString())
			&IsContinua = false
		Endif
	EndDo
	
	//se nao deu o erro
	if &IsErro = true
		
		//busca produtos do ml
		For Each Order EmpCod, MrkCod, MrkItmCod
			Where EmpCod = &EmPCod
			Where MrkCod = &MrkCod
			Where MrkItmStsInt = StatusMarketplace.Pendente
			
			&HttpClient.AddHeader('Content-Type', 'application/json')
			&HttpClient.AddHeader('Accept', 'application/json')
			&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
			&HttpClient.Execute('GET', 'https://api.mercadolibre.com/items/'+MrkItmCod.Trim())
			
			If &HttpClient.StatusCode = 200
				prcGravaProdutosImportadosCompleto.Call(&EmPCod, &MrkCod, &sdtListaProdutosResults, &HttpClient.ToString())
			Else
				&IsErro = false
				msg('Falha catastrófica! ' + &HttpClient.StatusCode.ToString())
				&IsContinua = false
			Endif
			
		EndFor
		
		Commit
	Endif
Endif


]]></Source>
