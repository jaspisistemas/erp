      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod,FilCod,CreCod,CrePagCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	Where CrePagCod = &CrePagCod
	CrePagSts = Status_Caixa.Cancelado
	Exit
EndFor

commit

AtualizaSaldoDuplicata.Call(&EmpCod,&CreCod,&FilCod)


]]></Source>
