      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Captura Filtros
//&wwClientesFiltros.FromJson(&Filtros)

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif

	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwClientes.qtdcli = 0

	&wwClientes.pA = '0'
	&wwClientes.pT = '0'
	&wwClientes.p1 = '0'
	&wwClientes.p2 = '0'
	&wwClientes.p3 = '0'
	&wwClientes.p4 = '0'
	&wwClientes.p5 = '0'
	&IsPaginaOk = false

	retornaConfiguracoesPastas.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &SdtConfiguracoesPasta )
	RetornaTipoAnexo.Call(&wwpContext.EmpCod, '#IMAGEM_PESSOA#', &PesAnxTipCod)
	&imagem.FromImage(sem_imagem)
	
	For Each Order EmpCod, PesRaz
		Where EmpCod = &wwpContext.empCod
		Where PesSts = &PesSts When not &PesSts.IsEmpty() and not &PesSts = 'T'
		Where PesRaz like &PesRaz or PesFan like &PesRaz when not &PesRaz.IsEmpty()
		Where PesCod = &PesCod when not &PesCod.IsEmpty()
		Where PesCidUfeCod = &UfeCod when not &UfeCod.IsEmpty() and not &UfeCod = 'TD'
		Where PesIsTra = true when &SomenteCliente = 'S'
		
		if &IsPaginaOk = false
			if &TestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwClientes.qtdcli = 0
					&wwClientes.Item.Clear()
					&TestaPagina = false
				Endif
			Endif
		
			if &IsPaginaOk = false
				&wwClientes.qtdcli += 1
		
			&wwClientesItem = New()
			&wwClientesItem.Cod = PesCod
			&wwClientesItem.Raz = PesRaz
			&wwClientesItem.Fon = PesPrmFon
			&wwClientesItem.Eml = PesPrmEml
			&wwClientesItem.end = PesLog + ', ' + PesNro
			
			&wwClientesItem.Tip = PesTip
			&wwClientesItem.Cpf = iif(PesTip = TipoPessoa.JURIDICA, PesCnpj, PesCpf)
			&wwClientesItem.Sts = PesSts.ToString()
			
			&auxPesCod = PesCod
			
			&wwClientes.Item.Add(&wwClientesItem)
			
			Endif
		Endif
	
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&TestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	When none
		&wwClientes.qtdcli = 0
		&Pagina = 0
	EndFor


	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwClientes.pA = trim(str(&Pagina))
		&wwClientes.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwClientes.p1, &wwClientes.p2, &wwClientes.p3, &wwClientes.p4, &wwClientes.p5)
		
		for &wwClientesItem in &wwClientes.Item
			&auxPesCod = &wwClientesItem.Cod
			do 'GETIMAGEM'
			&wwClientesItem.UrlImg = &link
		EndFOr
	Endif
Endif



Sub 'GETiMAGEM'
	&link = ''
	For Each Order EmpCod, PesAnxCod
		Where EmpCod = &wwpContext.EmpCod
		Where PesCod = &auxPesCod
		where PesAnxTipCod = &PesAnxTipCod
		
		&link = &SdtConfiguracoesPasta.PastaDiretoriovirtual.Trim() +'appjaspi\anexos\'+ trim(str(EmpCod)) + '\' + trim(PesAnxGuidNom)+'_'+trim(PesAnxGuid.ToString()) +'.'+ trim(PesAnxGuidExt)
		
		Exit
	When none
		&link = &imagem.ImageURI
	EndFor
EndSub

]]></Source>
