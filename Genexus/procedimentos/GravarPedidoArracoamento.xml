<Object parentGuid="3621c430-313f-479b-8239-2a4a4b55223a" user="WIN-JEAN\jean.fae" versionDate="2024-08-22T13:53:50.0000000Z" lastUpdate="2024-08-21T14:46:02.0000000Z" checksum="c9890f86957be4be27211aa8b0c6c557" fullyQualifiedName="GravarPedidoArracoamento" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="164c76c0-39c7-4571-98d5-805ca35791b4" name="GravarPedidoArracoamento" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Gravar Pedido Arracoamento" parent="Piscicultura" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[LoadWWPContext.Call(&Context)
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon136_TipoLctoArracoamento, &CfgVlr)
&LctCod = iif(&CfgVlr.IsEmpty(), 0, Val(&CfgVlr))
&PesCod = &Context.PesCod
&PedItmCod = 0

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	&PedCliCod = 1
	if FilPesCod > 0 
		&PedCliCod = FilPesCod
	EndiF
	&FilTabCod = FilTabCod
	
	UltimoCodigoEmpresa.Call(domParCod.PEDIDO, &EmpCod, &FilCod, &PedCod)
	
    do 'addCapaPedido'
	
	&PedItmCod = 0
	
	do 'InsereItem'
EndFor

commit
 
//AtualizaTotaisPedido
AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')

AtualizaEstoqueEntradaSaida.Call( &EmpCod, &FilCod, &PedCod, Status_Pedido.FECHADO)

commit

do 'AtualizaArracoamento'

Sub 'InsereItem'
	&PedItmCod += 1
	Do 'GetProduto'
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedItmCod = &PedItmCod
		ProCod = &ArrProCod
		ProGraCod = &ProGraCod
		
		PedQtdCan = 0
		PedQtdEmb = &PedQtdEmb
		PedQtd    = &ArrQtdRac
		PedVlrUnt = &ProVlrCus
		
		PedProEstProCod = &ArrProCod
		PedProEstProGraCod = &ProGraCod
	EndNew
EndSub


Sub 'GetProduto'
	
    For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
	    Where ProCod = &ArrProCod
		where ProSts <> Status_Produto.EXCLUIDO
		&ProGraCod = ProGraCod
		
		&ProVlrCus = ProVlrCus
		&ProQtdEmb = ProQtdEmb
		&ProEmbUnd = ProEmbUnd
		&ProQtdVol = ProQtdVol
		&ProIsGra = ProIsGra
				
		RetornaEstoquePedido.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &PedSts, &EstLoc, &EstQtd, &EstSdo, &Mensagem)
		
	    Exit
    EndFor
EndSub

Sub 'addCapaPedido'
	for Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
			
			PedDtaEms = &ArrDta
			PedHorEms = &ArrHor.toformattedString()
			
			PedBlq = Status_SimNao.Sim
			PedStsGer = Pedido_Gerado.Interno
			PedStsFin = Status_Financeiro.FECHADO
			
			PedCliCod = &PedCliCod
			LctCod = &LctCod
			
			PedSts = Status_Pedido.FECHADO
			PedDtaFat = &ArrDta
			PedHorFat = &ArrHor
			PedDtaFic = &ArrDta //DATA FATURAMENTO
			TabCod = &FilTabCod
			TabColCod = 1
			
			PedTipFrt = TipoFrete.SemFrete
			PedPraCod = 1
			
			for Each Order EmpCod, FilCod, PedCod, PedItmCod
				Delete
			EndFor
		Exit
	When none
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			PedNum = &ArrCod
		    PedDtaEms = &ArrDta
			PedHorEms = &ArrHor.toformattedString()
			PedVenCod = &PesCod
			PedBlq = Status_SimNao.Sim
			PedStsGer = Pedido_Gerado.Interno
			PedStsFin = Status_Financeiro.FECHADO
			
			PedCliCod = &PedCliCod
			LctCod = &LctCod
			
			PedSts = Status_Pedido.FECHADO
			PedDtaFat = &ArrDta
			PedHorFat = &ArrHor
			PedDtaFic = &ArrDta //DATA FATURAMENTO
			TabCod = &FilTabCod
			TabColCod = 1
			
			PedTipFrt = TipoFrete.SemFrete
			PedPraCod = 1
		EndNew	
		
		commit
	EndFor
EndSub

Sub 'AtualizaArracoamento'
	For each Order EmpCod,ArrCod
		Where EmpCod = &EmpCod
		Where ArrCod = &ArrCod
		
		ArrPedCod = &PedCod
		Exit
	EndFor
EndSub
]]></Source>
