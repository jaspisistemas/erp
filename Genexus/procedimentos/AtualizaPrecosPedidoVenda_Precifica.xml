      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//&alterou = 'N'

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	If LctTip =  TipoLancamento.OrcamentoVenda and PedSts = Status_Pedido.ABERTO
		&IsAtualizaCusto = true
	Else
		&IsAtualizaCusto = false
	EndIf
	
	&PedDtaVct = PedDtaVct
	
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		if (LctInfPrc = Status_SimNao.Nao or &IsAtualiza = true) and (ProReqVlr <> true or &IsAtualiza = true)//NAO DIGITAR VALOR PEDIDO
			&AuxTabColCod = TabColCod
			
			If LctRetCus = Status_SimNao.Sim //and &PedVlrUnt <= 0
				&PedVlrUnt = ProVlrCus
			Else				
				&PedVlrUnt = PedVlrUnt
				if TabIsAntAcr = true
					if (PedItmTabPerAcr > 0 and PedItmTabPerAnt > 0) and &PedVlrUnt > 0 and (not &PedDtaVct.IsEmpty() and not PedItmTabDtaVct.IsEmpty() and not PedItmTabDtaVct.IsNull() )
						
						&PedVlrUnt = PedVlrTab
						
						if &PedDtaVct <> PedItmTabDtaVct
							retornaUnitarioLiquidoAntecipado.Call(PedItmTabPerAcr, PedItmTabPerAnt,  PedItmTabDtaVct,PedDtaEms, &PedDtaVct, &PedVlrUnt)
						Endif
					Endif
				Endif
			EndIF
		
			//STATUS ITEM. PROMOCAO. NORMAL. DESCONTO -- mandei para AtualizaTotaisPedido
			//PedItmPrm = RetornaPrecoUnitarioTipo.Udp(EmpCod, TabPrmCod, ProCod, ProGraCod, &AuxTabColCod, PedDtaEms, PedItmDsc)
			
			If (round(PedVlrUnt,2) <> round(&PedVlrUnt,2))
				//&alterou = 'S'
				PedVlrUnt = &PedVlrUnt
			EndIf
		EndIf
		
		If PedQtdCan < 0 
			PedQtdCan = 0
		EndIf
	
		//COMISSAO VENDEDOR  -- mandei para AtualizaTotaisPedido
		//PedItmCom = RetornaComissaoVendedor.Udp(EmpCod, PedVenCod, LctPagCom, LctCod, GrupCom, PedItmPrm)
		//		if PedItmVenCod > 0
		//			&PedItmCom = retornaComissaoVendedor.Udp(EmpCod, PedItmVenCod, LctPagCom, LctCod, GrupCom, &PedItmPrm)
		//		Else
		//			&PedItmCom = retornaComissaoVendedor.Udp(EmpCod, PedVenCod, LctPagCom, LctCod, GrupCom, &PedItmPrm)
		//		EndIF
		//PedPrfPrcCal = ProPreRec
		
		if &IsAtualizaCusto = true
			
			PedVlrCus = ProVlrCus
			PedVlrCusPrd = 0
			
			Do Case
				Case ProTipCus = TipoCusto.Receita 
					PedVlrCusPrd    = ProVlrCusPrd
					
				Case ProTipCus = TipoCusto.CustoProdutoEstoque
					PedVlrCusPrd    = retornaCustoProducao.Udp(EmpCod, ProEstProCod)				
			EndCase
		EndIF
	EndFor
	
	Exit
EndFor

commit

AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')
]]></Source>
