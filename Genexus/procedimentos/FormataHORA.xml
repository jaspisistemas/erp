      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&ValorSaida = RetornaSoNumeros.Udp(&Entrada)

If not &ValorSaida.IsEmpty()
	
	&TesteNumeric = val(padR(Substr(&ValorSaida,1,2), 2, '0'))
	if &TesteNumeric >= 24
		&NovoValorSaida = '00'
	Else
		&NovoValorSaida = padR(Substr(&ValorSaida,1,2), 2, '0')
	EndIF
	
	
	&NovoValorSaida += ':' 
	&TesteNumeric = val(padR(Substr(trim(&ValorSaida),3,2), 2, '0'))
	if &TesteNumeric >= 60
		&NovoValorSaida += '00'
	else
		&NovoValorSaida += padR(Substr(trim(&ValorSaida),3,2), 2, '0')
	EndIF

	&NovoValorSaida += ':' 
	&TesteNumeric = val(padR(Substr(trim(&ValorSaida), 5, 2), 2, '0'))
	if &TesteNumeric >= 60
		&NovoValorSaida += '00'
	else
		&NovoValorSaida += padR(Substr(trim(&ValorSaida), 5, 2), 2, '0')
	EndIF
EndIF

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
