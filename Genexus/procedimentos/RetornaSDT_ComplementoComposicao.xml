      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtObservacaoGrupo.Clear()

For Each Order EmpCod, GrupCod, GrupComItmCod
	Where EmpCod = &EmpCod
	Where GrupCod = &GrupCod
	Where GrupObsComp = 'P'
	
	&sdtObservacaoGrupoItem = new()	
	&sdtObservacaoGrupoItem.OGrupCod = GrupProCod
	&ProCod = GrupProCod
	do 'RetornaNomeProduto'
	
	if not &ProNom.IsEmpty()
		&sdtObservacaoGrupoItem.OGrupNom = &ProNom
		&sdtObservacaoGrupoItem.OGrupCodRef = &ProRef	
		&sdtObservacaoGrupo.Add(&sdtObservacaoGrupoItem)
	Endif
EndFor

&sdtObservacaoGrupo.Sort('OGrupNom')

sub 'RetornaNomeProduto'
	&ProNom.SetEmpty()
	&ProRef.SetEmpty()
	For Each Order EmpCod, ProCod
		Where EmpCod = &empCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		&ProRef = ProGraRef
		&ProNom = iif(ProDet.IsEmpty() or ProDet.IsNull(), ProNom, ProDet)
		Exit
	EndFor
EndSub
]]></Source>
