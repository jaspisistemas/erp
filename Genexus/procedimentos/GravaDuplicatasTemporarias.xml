      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do Case
	Case  &TipoParcela = 'C' //Coletiva
		For each Order DupTmpPesCod
			Where DupTmpPesCod = &PesCod
			Delete
		EndFor
		Commit
		
		For &SdtAdiantamentoItem in &SdtAdiantamento
			&Count +=1
			&CreDupNro = &SdtAdiantamentoItem.Nro
			&CreDtaVct = &SdtAdiantamentoItem.Data
			&CreVlrDup = &SdtAdiantamentoItem.Valor
			Do 'NewTmp'			
		EndFor
	
	Case &TipoParcela = 'A' //Avulsa
		For &SdtAdiantamentoItem in &SdtAdiantamento
			UltimoCodigoEmpresa.Call(domParCod.DUPLICATA,&EmpCod, &FilCod,&CreCod)
			&CreDupNro = &SdtAdiantamentoItem.Nro
			&CreDtaVct = &SdtAdiantamentoItem.Data
			&CreVlrDup = &SdtAdiantamentoItem.Valor
			Do 'Duplicata'
		EndFor
EndCase

Sub 'Duplicata'
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CreCod = &CreCod
		if &CreFilPgt.IsEmpty()
			CreFilPgt = 1
		Else
			CreFilPgt = &CreFilPgt
		Endif
		CreNovCliRaz = &CreNovCliRaz
		CreDupNro = &CreDupNro
		CreDtaEms = &CreDtaEms 
		CreDtaVct = &CreDtaVct
		CreFrpPgtoCod = 1// duplicata
		CreVlrDup = &CreVlrDup
		CreVlrSdo = &CreVlrDup
		CreCliCod = &CreCliCod
		CreVenCod = &CreVenCod
		CreRecPag = &CreRecPag
		CreCbrCod = &CreCbrCod
		CreBloNro = trim(&CreBloNro)
		CreCodBar = &CreCodBar
		CreSts    = Status_Duplicata.ATIVO
		CreOriDup = OrigemDuplicata.LancamentoManual
		CrePlanCod = &PlanCod
		CrePerComCbr = &CrePerComCbr
		
	EndNew

	Commit
	
	if not &CreCobObs.IsEmpty()
		GravaCobranca.call(&EmpCod,&FilCod,&CreCod,&CreCobObs,0,0,&CrePrmPag, '00:00:00', TipoObservacaoDuplicata.USUARIO)
	Else
		AtualizaSaldoDuplicata.call(&EmpCod, &CreCod, &FilCod)
	EndiF
	
EndSub

Sub 'NewTmp'
	New
		DupTmpEmpCod = &EmpCod
		DupTmpFilCod = &FilCod
		
		if &CreFilPgt.IsEmpty()
			DupTmpCreFilPgt = 1
		Else
			DupTmpCreFilPgt = &CreFilPgt
		Endif
		DupTmpCreNovCliRaz = &CreNovCliRaz
		DupTmpCreCod = &Count
		DupTmpPesCod = &PesCod
		DupTmpCreDupNro = &CreDupNro
		DupTmpCreDtaEms = &CreDtaEms
		DupTmpCreDtaVct = &CreDtaVct
		DupTmpCreVlrDup = &CreVlrDup
		DupTmpCreVlrSdo = &CreVlrDup
		DupTmpCreCliCod = &CreCliCod
		DupTmpCreVenCod = &CreVenCod
		DupTmpCreRecPag = &CreRecPag
		DupTmpCreCbrCod = &CreCbrCod
		DupTmpCreBloNro	= &CreBloNro
		DupTmpCreCbrJurCod = &CreCbrJurCod
		DupTmpCreCodBar = &CreCodBar
		DupTmpCrePlanCod = &PlanCod
		DupTmpCrePerComCbr = &CrePerComCbr
	EndNew

	Commit
EndSub
]]></Source>
