      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//GRAVA LOG
&TabelaVarchar = 'PESSOASOCIOS'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)

	
//QUADRO SOCIAL
For Each Order EmpCod, PesCod, PesSocCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod

	&PesSocConf = serverdate()
	
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(PesCod))
		&LogErpRegCod2 = trim(str(PesSocCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocConf', trim(toformattedString(PesSocConf)), trim(toformattedString(&PesSocConf)), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	PesSocConf = &PesSocConf 
	Exit
EndFor

Commit
]]></Source>
