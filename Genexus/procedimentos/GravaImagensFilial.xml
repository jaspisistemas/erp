      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	If not &FilImg146_50.IsEmpty()
		FilImg_LogNFeCmp = &FilImg146_50
	EndiF
	if not &FilImg350_120.IsEmpty()
		FilImg_LogRel = &FilImg350_120
	EndIF

	if not &FilImg_LogNfeSup.IsEmpty()
		FilImg_LogNfeSup = &FilImg_LogNfeSup
	Endif
	
	if not &FilImg_LogNfeEsq.IsEmpty()
		FilImg_LogNfeEsq = &FilImg_LogNfeEsq
	Endif

	if not &FilImg_LogERP.IsEmpty()
		FilImg_LogERP = &FilImg_LogERP
	Endif

	Exit
EndFor

Commit
]]></Source>
