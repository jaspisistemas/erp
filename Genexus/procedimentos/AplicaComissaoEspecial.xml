      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//COD.LCT P/ COMISSAO ESPECIAL PARA VENDEDORES EXTERNOS, PEDIDOS VENDIDOS EM SUA AREA
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon026_TipoLctoComissaoEspecial, &CfgVlr)

&LctCod = val(&CfgVlr)

If &LctCod = 0 //Se nao tem cai fora
    Return
Else
	For Each Order EmpCod, FilCod, PedSts, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod or &PedCod = 0
		Where (PedDtaFat >= &iniPedDtaEms and PedDtaFat <= &fimPedDtaEms) or &PedCod = 0
		where PedSts = Status_Pedido.FECHADO // PEDIDOS FECHADOS
		Where LctPagCom = Status_SimNao.Sim	//GERA COMISSAO
		Where LctAtuEst = Status_EntradaSaida.Saida //SAIDA
		Where PedVenIntExt = Status_InternoExterno.INTERNO //SOMENTE VENDEDORES INTERNOS
		Where PedCliCidAreCod <> 1 //IGNORA CLIENTES DA AREA 1
		&Total += 1
	EndFor
	
	For Each Order EmpCod, FilCod, PedSts, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod or &PedCod = 0
		Where (PedDtaFat >= &iniPedDtaEms and PedDtaFat <= &fimPedDtaEms) or &PedCod = 0
		where PedSts = Status_Pedido.FECHADO // PEDIDOS FECHADOS
		Where LctPagCom = Status_SimNao.Sim	//GERA COMISSAO
		Where LctAtuEst = Status_EntradaSaida.Saida //SAIDA
		Where PedVenIntExt = Status_InternoExterno.INTERNO //SOMENTE VENDEDORES INTERNOS
		Where PedCliCidAreCod <> 1 //IGNORA CLIENTES DA AREA 1
		
		if not &ProgressId.IsEmpty()
			&Count += 1
			If &Count > 0
				&Percentual = round((&Count / &Total) * 100, 0)
				If &Percentual = 0
					&Percentual = 5
				EndIF
				
			EndIF
			If &Percentual >= 100
				&Percentual = 99
			EndIf
			
			do 'Atualiza'
		Endif
	
		&PedCliCidAreCod = PedCliCidAreCod
		&PedVenCod = PedVenCod
		&NewFilCod = FilCod
		&NewPedCod = PedCod
	    do 'GetVendedor'
	EndFor
	
	commit
EndIF

Sub 'GetVendedor'
    &PesCod = 0
    For Each Order EmpCod,PesCod
	Where EmpCod = &EmpCod
	Where PesCod <> &PedVenCod
    Where PesCod = &parPedVenCod or &parPedVenCod = 0
    Where PesVenIntExt = Status_InternoExterno.EXTERNO //VENDEDORES EXTERNOS
	Where PesDtaDem.IsEmpty() //VENDEDORES ATIVOS
    Where PesVenAreCod = &PedCliCidAreCod
	Where ComLctCod = &LctCod
        &PesCod = PesCod
        &ComTabNor = ComTabNor
        do 'SetComissaoNoPedido'
    EndFor
EndSub

Sub 'SetComissaoNoPedido'
    For Each Order EmpCod, FilCod, PedCod, PedComEspVenCod
		Where EmpCod = &EmpCod
	    Where FilCod    = &NewFilCod
	    Where PedCod    = &NewPedCod
	    Where PedComEspVenCod = &PesCod
        If PedComAut = Status_SimNao.Sim
            PedComEsp = &ComTabNor
        EndIF
        Exit
    When none
        New
			EmpCod = &EmpCod
            FilCod = &NewFilCod
            PedCod = &NewPedCod
            PedComEspVenCod = &PesCod
            PedComEsp = &ComTabNor
            PedComAut = Status_SimNao.Sim //GERADO AUTOMATICO
        EndNew
    EndFor
EndSub

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &sdtEstoque.ToXml()
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor

	commit
EndSub
	
]]></Source>
