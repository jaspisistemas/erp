      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&iniPedDtaFat = yMDtoD(&PesMetAno, &PEsMetMes, 1)
&FinPedDtaFat = eoM(&iniPedDtaFat)

&Total = 100
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&sdtPessoa.Clear()

//adiciona os Vendedores
For Each Order EmpCod, PesRaz
	Where EmpCod = &EmpCod
	//Where PesSts = Status_AtivoInativo.ATIVO
	Where PesIsVen = true
	Where PesDtaDem.IsEmpty() or PesDtaDem.IsNull()
	Where PesVenIntExt = Status_InternoExterno.INTERNO
	
	&sdtPessoaItem = new()
	&sdtPessoaItem.PesCod = PesCod
	RetiraCaracteresEspeciais.Call(PesRaz, &PesRaz)
	&sdtPessoaItem.PesRaz = gxGetMLi(&PesRaz, 1, 20)
	
	&sdtPessoaItem.PesMeta = 0
	For Each Order EmpCod, PesCod, PesMetAno, PesMetMes //Pega A meta para o Ano/MEs
		Where PesMetAno = &PesMetAno
		Where PesMetMes = &PEsMetMes
		&sdtPessoaItem.PesMeta= PesMetVlr
		Exit
	EndFor

	&sdtPessoa.Add(&sdtPessoaItem)
EndFor

//soma as vendas FECHADAS
For each Order EmpCod, FilCod, PedVenCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedDtaFat >= &iniPedDtaFat and PedDtaFat <= &FinPedDtaFat
	Where PedVenIs = true
	Where PedVenIntExt = Status_InternoExterno.INTERNO
	Where pedVenIntDem.IsEmpty() or pedVenIntDem.IsNull()
	Where PedSts = Status_Pedido.FECHADO
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where LctPagCom = Status_SimNao.Sim
	
	if &OldPedVencod <> PedVenCod AND &OldPedVencod <> 0
		do 'AddTotalRealizado'
		&PesRealizadoMoeda = 0
	EndIF
	
	&PesRealizadoMoeda += PedTotProLiq 
	&PedVenCod = PedVenCod
	&OldPedVencod = PedVenCod 
EndFor

if &PesRealizadoMoeda > 0
	do 'AddTotalAberto'
EndiF

&Count += 50
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

&OldPedVencod = 0
//soma as vendas ABERTAS
For each Order EmpCod, FilCod, PedVenCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedDtaEms >= &iniPedDtaFat and PedDtaEms <= &FinPedDtaFat
	Where PedVenIs = true
	Where PedVenIntExt = Status_InternoExterno.INTERNO
	Where pedVenIntDem.IsEmpty() or pedVenIntDem.IsNull()
	Where PedSts = Status_Pedido.ABERTO
	Where LctTip = TipoLancamento.SaidaMercadoria or LctTip = TipoLancamento.OrcamentoVenda
	
	if &OldPedVencod <> PedVenCod AND &OldPedVencod <> 0		
		do 'AddTotalAberto'
		&PesRealizadoMoeda = 0
	EndIF
	
	&PesRealizadoMoeda += PedTotProLiq 
	&PedVenCod = PedVenCod
	&OldPedVencod = PedVenCod 
EndFor

if &PesRealizadoMoeda > 0
	do 'AddTotalAberto'
EndiF

&Percentual = 100
&ProgressFin = serverNow()
&ProgressLogXml = &sdtPessoa.ToJson()
do 'Atualiza'

sub 'AddTotalAberto'
	For &sdtPessoaItem in &sdtPessoa
		If &sdtPessoaItem.PesCod = &PedVenCod 
			&sdtPessoaItem.PesAber = &PesRealizadoMoeda
			Exit
		EndIF	
	EndFor
EndSub

sub 'AddTotalRealizado'
	For &sdtPessoaItem in &sdtPessoa
		If &sdtPessoaItem.PesCod = &PedVenCod 
			&sdtPessoaItem.PesRea = &PesRealizadoMoeda
			Exit
		EndIF	
	EndFor
EndSub

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = ''
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub
]]></Source>
