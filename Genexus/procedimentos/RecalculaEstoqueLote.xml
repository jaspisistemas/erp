      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if not &DataInicial.IsEmpty()
	&MesInicial = Month(&DataInicial)
	&AnoInicial = Year(&DataInicial)
EndIf

If &ProCod <> 0 //and &ProGraCod > 1
	
	//DELETA LEVEL ANO MES
	For Each Order EmpCod,FilCod,ProCod,ProGraCod,EstLotCod
		where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
				
		For Each Order EmpCod,FilCod,ProCod,ProGraCod,EstLotCod,EstLotAno,EstLotMes
			//Where EstLotAno >= &AnoInicial when not &DataInicial.IsEmpty()
			//Where EstLotMes >= &MesInicial or EstLotAno > &AnoInicial when not &DataInicial.IsEmpty()
			
			delete
		EndFor
	
		delete
	EndFor
	
	commit
	
	//VERIFICA PEDIDOS
	For Each order EmpCod, FilCod, PedProEstProCod, PedProEstProGraCod, PedDtaFic, PedProEstLotCod
		where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedProEstProCod = &ProCod
		Where PedProEstProGraCod = &ProGraCod
		Where PedSts = Status_Pedido.FECHADO
		//Where Year(PedDtaFic) >= &AnoInicial when not &DataInicial.IsEmpty()
		//Where Month(PedDtaFic) >= &MesInicial or Year(PedDtaFic) > &AnoInicial when not &DataInicial.IsEmpty()
		
		&LctCod = LctCod
		&PedDtaFat = PedDtaFat
		//&PedCod = PedCod
		&PedProEstLotCod = PedProEstLotCod
		&PedProEstLotQtd = PedProEstLotQtd
		&PedProEstLotVct = PedProEstLotVct
		&PedProEstLotFab = PedProEstLotFab
		//&EstLotVct, &PedDtaFat
		
		do 'FechaEstoque'

		commit
	EndFor
EndIF


Sub 'FechaEstoque'
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmPCod
		Where LctCod = &LctCod
		
		Do Case
			Case LctAtuEst =  Status_EntradaSaida.Entrada
				RecalculaEstoquelote1.Call(&EmPCod, &FilCod, &PedProEstLotCod, &ProCod, &ProGraCod, '+', &PedProEstLotQtd, 0, &PedProEstLotVct, &PedProEstLotFab,&PedDtaFat)
				
			Case LctAtuEst =  Status_EntradaSaida.Saida
				RecalculaEstoquelote1.Call(&EmPCod, &FilCod, &PedProEstLotCod, &ProCod, &ProGraCod, '-', &PedProEstLotQtd, 0, &PedProEstLotVct, &PedProEstLotFab,&PedDtaFat)
				
		EndCase
	EndFor
EndSub

]]></Source>
