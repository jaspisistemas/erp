      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAchou = False
For Each Order EmpCod,CreBloNro,CreRecPag,CreCbrCtaBanCrt
    Where EmpCod    = &EmpCod  // Empresa
	Where CreBloNro = &RemCreBloNro    // Nosso Número
	Where CreRecPag = ReceberPagar.Receber              // Duplicata a Receber
	where CreSts <> Status_Duplicata.CANCELADA
	
	
	&CreCbrCtaBanCrt = Str(Val(trim(CreCbrCtaBanCrt))) //converto pra tirar zeros inicio
	&CreCbrNroCon = Str(Val(trim(CreCbrNroCon)))
	if ((&CreCbrCtaBanCrt.Trim() = &CtaBanCrt.Trim()) or (&CreCbrNroCon.Trim() = &CtaBanCrt.Trim()))// Convenio(codigo beneficiario) do Local de Cobrança
		&IsAchou = True
		&FilCod = FilCod
		&CreCod = CreCod
		Exit
	Endif
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
