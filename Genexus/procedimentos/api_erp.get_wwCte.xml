<Object parentGuid="187a4a7f-bd09-43ed-b6cc-bb45b7f907fc" user="WINJEAN\jeanfae" versionDate="2025-07-04T16:39:54.0000000Z" lastUpdate="2025-06-30T13:24:40.0000000Z" checksum="047b935954a6b050eea4980e16e6f53c" fullyQualifiedName="api_erp.get_wwCte" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="2c19423a-2a8f-496e-8b14-760ed5013cd2" name="get_wwCte" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_ww Cte" parent="api_erp.cte" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	//, in:&CteDtaEmsIniTmpSec, in:&CteDtaEmsFinTmpSec, in:&CtePlc, in:&CteSts, in:&CteModCod, out:&wwCte);
	
//	&count += 1
//	padraousuario.Call('G', 'get_wwCte'+trim(str(&count)), 1, 1, '&IsAcessoConcedido', &PadDtaMod)
	
//	&count += 1
//	padraousuario.Call('G', 'get_wwCte'+trim(str(&count)), 1, 1, &CteDtaEmsIniTmpSec.ToFormattedString(), &PadDtaMod)
	
//	&count += 1
//	padraousuario.Call('G', 'get_wwCte'+trim(str(&count)), 1, 1, &CteDtaEmsFinTmpSec.ToFormattedString(), &PadDtaMod)
	
//	&count += 1
//	padraousuario.Call('G', 'get_wwCte'+trim(str(&count)), 1, 1, &Status, &PadDtaMod)
	
	
	if not &Status.IsEmpty() and not &Status = 'T'
		&CteSts.FromString(&Status)
	Endif
	
	&Pagina = &parPagina
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	
	&wwCte.pA = '0'
	&wwCte.pT = '0'
	&wwCte.p1 = '0'
	&wwCte.p2 = '0'
	&wwCte.p3 = '0'
	&wwCte.p4 = '0'
	&wwCte.p5 = '0'
	&IsPaginaOk = false
	
	TimestampToDate.Call(&CteDtaEmsIniTmpSec, &iniCteDtaEms)
	TimestampToDate.Call(&CteDtaEmsFinTmpSec, &finCteDtaEms)
	
	
	if &filCod <= 0 
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAceNiv > 0
				&collFilCod.add(PesFilAce)
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif
	Else
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAce = &filCod
				Where PesFilAceNiv > 0
				&collFilCod.add(PesFilAce)			
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &filCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif	
	EndIf
	
	&PesRaz = &nome.ToUpper()
	&Varchar = RetornaSoNumeros.Udp(&PesRaz)
	&PesRazCteNum = val(&Varchar)
	For Each 
		Order EmpCod, (CteDtaEms), (CteCod) when &Ordem.IsEmpty() or &Ordem = 'DD'
		Order EmpCod, CteDtaEms, CteCod when &Ordem.IsEmpty() or &Ordem = 'DC'
		
		Where EmpCod = &wwpContext.empCod
		Where FilCod in &collFilCod
		Where CteCod = &CteCod when not &CteCod.IsEmpty()
		where CteNum = &CteNum when not &CteNum.IsEmpty()
		Where CteMod = &CteModCod when not &CteModCod.IsEmpty()
		Where CteSts = &CteSts  when not &CteSts.IsEmpty()
		Where CteSts <> Status_NFe.Importada when &CteSts.IsEmpty()
		Where (CteDtaEms >= &iniCteDtaEms and CteDtaEms <= &finCteDtaEms)
		Where (CteTomRaz like &PesRaz or CteTomFan like &PesRaz)
		or (CteRemRaz like &PesRaz or CteRemFan like &PesRaz)
		or (CteDesRaz like &PesRaz)
		or (CtePlc like &PesRaz or CtePlcTra like &PesRaz)
		or (CteNum = &PesRazCteNum)
		
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwCte.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false				
				&wwCteItem = New()
				&wwCteItem.FilCod = FilCod
				&wwCteItem.CteCod = CteCod
				&wwCteItem.CteNum = CteNum
				&wwCteItem.CteSer = CteSer
				&wwCteItem.CteDtaEmsTmp = DateToTimestamp.Udp(CteDtaEms)
				&wwCteItem.CteSts = CteSts
				if CteModCod = '67' //servico
					&wwCteItem.Tom = CteTomRaz
				Else
					&wwCteItem.Rem = CteRemRaz
					&wwCteItem.Dest = CteDesRaz
				Endif
			
				&wwCteItem.VlrCte = trim(toformattedString(CteVlrRecSer))
				&wwCteItem.Placa = CtePlcTra
				&wwCteItem.UFDes = CteTerUfe
				&wwCteItem.CidDes = CteTerCidNom
				&wwCteItem.ModCod = CteModCod				
				
				
				&wwCte.Item.Add(&wwCteItem)
			Endif
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	When none
		&Pagina = 0
	EndFor
	
	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwCte.pA = trim(str(&Pagina))
		&wwCte.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwCte.p1, &wwCte.p2, &wwCte.p3, &wwCte.p4, &wwCte.p5)
	Endif

	&wwCte.sts = 'J200'
	&wwCte.obs = ''
	return
else
	&wwCte.sts = 'E999'
	&wwCte.obs = 'Nada mais aqui!'
	return
	
Endif
]]></Source>
