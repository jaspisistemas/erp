      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each ORder EmpCod
	
	&PrimeiraEmpCod = EmpCod
	
	&EmpDirFis = EmpDirFis
	&EmpDirVir = EmpDirVir
	&EmpDirVirExt = EmpDirVirExt
	&EmpDirVirMon = EmpDirVirMon
	&EmpDirVirPdv = EmpDirVirPdv
	&EmpDirVirSmart = EmpDirVirSmart 
	
	Exit
EndFor

if &PrimeiraEmpCod = &EmpCod
	
	For Each Order EmpCod
		Where EmpCod <> &EmpCod
		
		EmpDirFis = &EmpDirFis
		EmpDirVir = &EmpDirVir
		EmpDirVirExt = &EmpDirVirExt
		EmpDirVirMon = &EmpDirVirMon
		EmpDirVirPdv = &EmpDirVirPdv
		EmpDirVirSmart = &EmpDirVirSmart 
		
	EndFor
	
	Commit
Endif

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
