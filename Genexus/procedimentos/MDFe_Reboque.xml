      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &OqueFAzer = 'ADD'
	For Each Order EmpCod, FilCod, MDFeCod, MDFeRebCod
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeRebPla = &MDFeRebPla
		msg('Reboque já adicionado ao MDFe!')
		Exit
	When none
		For Each Order EmpCod, VeiCod
			Where EmpCod = &EmpCod
			Where VeiPla = &MDFeRebPla
			Where VeiTip = VeiculoTipo.Reboque
			&MDFeRebUF		= VeiUfeCod
			&MDFeRebTar		= VeiTar
			&MDFeRebCap		= VeiCap
			&MDFeRebCapM3	= VeiCapM3
			&MDFeRebTipCar   = VeiTipCarr
			&MDFeRebTipRod   = VeiTipRod
			&MDFeRebRen		= VeiRen
			If VeiPro <> PropriedadeVeiculo.Proprio
				&MDFeRebRNTRC    = VeiProRNTRC.Trim()
				&MDFeRebProCnpj = VeiProCnpj.Trim()
				&MDFeRebProIe = VeiProIe.Trim()
				&MDFeRebProRaz = VeiProRaz.Trim()
				&MdfeRebProTip = VeiPro
				&MDFeRebProUf = VeiProUf
			Else
				&MDFeRebRNTRC = ''
				&MDFeRebProCnpj = ''
				&MDFeRebProIe = ''
				&MDFeRebProRaz = ''
				&MdfeRebProTip = PropriedadeVeiculo.Proprio
				&MDFeRebProUf = ''
			EndIf
			Exit
		When None
			msg('Reboque não localizado!')
			Return
		EndFor
		
		For Each Order EmpCod, FilCod, MDFeCod, (MDFeRebCod)
			Where EmpCod = &EmpCod
			WHere FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			&NewMdfeRebCod = MDFeRebCod
			Exit
		EndFor
		&NewMdfeRebCod += 1
		
		NEw
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MDFeCod
			MDFeRebCod = &NewMdfeRebCod
			MDFeRebPla = &MDFeRebPla
			MDFeRebUF = &MDFeRebUF
			MDFeRebTar = &MDFeRebTar
			MDFeRebCap = &MDFeRebCap
			MDFeRebCapM3 = &MDFeRebCapM3
			MDFeRebTipCar = &MDFeRebTipCar
			MDFERebTipRod = &MDFeRebTipRod
			MDfeRebRen = &MDFeRebRen
				///dados do proprietario do veiculo
			MDFeRebRNTRC = &MDFeRebRNTRC
			MDFeRebProCnpj = &MDFeRebProCnpj
			MDFeRebProIe = &MDFeRebProIe 
			MDFeRebProRaz = &MDFeRebProRaz
			MdfeRebProTip = &MdfeRebProTip
			MDFeRebProUf = &MDFeRebProUf
		EndNEw
	EndFor
Else //DELETAR
	For Each Order EmpCod, FilCod, MDFeCod, MDFeRebCod
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeRebCod = &MdfeRebCod
		delete
	EndFor	
EndIF

Commit

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
