//&ResultadoNext =  dfwptxt(&XmlIMprimirLongVarchar, 5000)
//	&ResultadoNext = DFWNext()
//	&ResultadoAbertura = dfwclose()
	
////padraousuario.Call('G', serverTime(), 1, 1, &XmlIMprimirLongVarchar, &PadDtaMod)
//&sdtCappta.FromJson(&XmlIMprimirLongVarchar)

//&XmlWriter.Open('teste2.xml')
//&XmlWriter.WriteRawText(&sdtCappta.ToXml())
//&XmlWriter.Close()

MT 0
MB 0

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod > 0
	
	&UmFilRaz = FilFan
	print tituloA
	
	&CnpjIeIm = FilCpj
	print Cabecalho
	
	&CnpjIeIm = FilCep.Trim() + ' - ' + FilCidNom.Trim() + ' - ' + FilCidUfeCod.Trim()
	print Cabecalho
	
	&CnpjIeIm = FilLog.Trim() + ', ' + FilNro.Trim() + ' - ' + FilBai.Trim()
	print Cabecalho
	
	Exit
EndFor

print traco
print ViaCliente

&XmlMensagem = &XmlIMprimir.ToUpper()

//&XmlMensagem = &XmlMensagem.Replace('  :', ':')
//&XmlMensagem = &XmlMensagem.Replace('CARTAO:', '  CARTAO:')
//&XmlMensagem = &XmlMensagem.Replace('TERM:', '  TERM:')
//&XmlMensagem = &XmlMensagem.Replace('(', '')
//&XmlMensagem = &XmlMensagem.Replace(')', '')

&isImprimeTitulo = true
&Count = 0

For &Mensagem in &XmlMensagem.SplitRegEx(';:;')
	&Mensagem = &Mensagem.Trim()
	&Mensagem = &Mensagem.ToUpper()
	
	if not &Mensagem.IsEmpty()		
		
		if &Count > 0
			&Count += 1
		Endif
	
		Do Case
			Case &Count = 0 and &Mensagem.ToUpper() like '%ESTABELECIMENTO%'
				&Count = 1
			Case &Count = 2 //bandeira
				
			Case &Count = 3 //bandeira + modo
				print Centralizado				
			Case &Count > 3 and &cartao.IsEmpty()
				&cartao = &Mensagem
			Case &Count > 3 and &terminal.IsEmpty()
				&terminal = &Mensagem
			Case &Count > 3 and &Mensagem1.IsEmpty()
				&Mensagem1 = &Mensagem
			Case &Count > 3 and &Mensagem2.IsEmpty()
				&Mensagem2 = &Mensagem
			Case &Count > 3 and &Mensagem3.IsEmpty()
				&Mensagem3 = &Mensagem
			Case &Count > 3 and &Mensagem4.IsEmpty()
				&Mensagem4 = &Mensagem
			Case &Count > 3 and &Mensagem5.IsEmpty()
				&Mensagem5 = &Mensagem				
			Case &Mensagem like '%TOTAL%'
				&Mensagem = trim(&Mensagem.Replace('TOTAL:', ''))
				&Mensagem = trim(&Mensagem.Replace('TOTAL', ''))
				&Mensagem = trim(&Mensagem.Replace(':', ''))
				&Mensagem = trim(&Mensagem.Replace('.', ','))
				&varPedVlrBrt = trim(&Mensagem)			
			Case &Mensagem like '%SALDO%'
				&VarPedvlrSld = trim(&Mensagem)				
			cASE &Count > 3 and &FormaAutorizada.IsEmpty()
				&FormaAutorizada = &Mensagem				
			cASE &Count > 3 and &FormaAutorizada1.IsEmpty()
				&FormaAutorizada1 = &Mensagem
		EndCase
			
	Endif
EndFor

print traco
print dadosvalores

if not &VarPedvlrSld.IsEmpty()
	&Mensagem = &VarPedvlrSld
	print Autorizacao
Endif

&Mensagem = 'Obrigado pela preferência!'
print traco
print DadosCliente
&Mensagem = ''
print DadosCliente

&IsImprimiu = true
