      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each
	Where EmpCod = &EmPCod
	Where BanCarCod = &BanCarCod
	Where BanItemNom = &BanItemNom
	Where BanItemCredDeb = &BanItemCredDeb
	Where BanItemPar = &BanItemPar
	
	
	BanItemTax = &BanItemTax
	
	Exit
When none
	New
		EmpCod = &EmPCod
		BanCarCod = &BanCarCod
		BanItemNom = &BanItemNom.ToUpper()
		BanItemCredDeb = &BanItemCredDeb
		BanItemPar = &BanItemPar
		BanItemTax = &BanItemTax
	EndNew
EndFor

Commit
]]></Source>
