      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, LctCod
	Where EmpCod = &EmpCod
	Where LctCod = &LctCod
	&LctAtuSal = LctAtuSal
	&LctAtuEst = LctAtuEst
	Exit
endfor

if &OriUfeCod.IsEmpty()
	RetornaRegimeTributarioFilial.Call(&EmpCod, &FilBasImp, &tbFilRegTrib, &FilCidUfeCod)
Else
	&FilCidUfeCod = &OriUfeCod
EndIf

&CfopPrimeiro = SUBSTR(&CfoCod,1,1)
&Mensagem = ''

if not &FilCidUfeCod.IsEmpty() 
	// ENTRADAS
	if &LctAtuSal = Status_EntradaSaida.Entrada or &LctAtuEst = Status_EntradaSaida.Entrada
		Do case
			case &FilCidUfeCod = &UfeCod  //Dentro do Estado
				if &CfopPrimeiro <> '1'
					&Mensagem = 'Para Entradas estaduais. CFOP deve começar com 1!'
				endif
				
			Case &UfeCod = 'EX' //IMPORTACAO
				if &CfopPrimeiro <> '3'	
					&Mensagem = 'Para Notas de Importações. CFOP deve começar com 3!'
				endif
				
			case &FilCidUfeCod <> &UfeCod   //Outro Estado
				if &CfopPrimeiro <> '2'
					&Mensagem = 'Para Entradas Interestaduais. CFOP deve começar com 2!'
				endif
		EndCase
		
	Else //SAIDAS
		if &LctAtuSal = Status_EntradaSaida.Saida or &LctAtuEst = Status_EntradaSaida.Saida
			
			Do Case
				case &FilCidUfeCod = &UfeCod  //Dentro do Estado
					If &CfopPrimeiro <> '5'
						&Mensagem = 'Para Vendas estaduais. CFOP deve começar com 5!'
					Endif	
					
				Case &UfeCod = 'EX' //EXPORTACAO
					If not &CfopPrimeiro in ('5', '7')
						&Mensagem = 'Para Notas de Exportações. CFOP deve começar com 7 ou 5!'
					Endif
					
				Case &FilCidUfeCod <> &UfeCod  //Outro Estado
					If &CfopPrimeiro <> '6'
						&Mensagem = 'Para Vendas Interestaduais. CFOP deve começar com 6!'
					EndiF			
			EndCase
			
		Else //NENHUM
			&Mensagem = 'Tipo de Lançamento não Atualiza Saldos, é preciso atualizar Saldos Entrada/Saída para Configuração de CFOP.'
		EndIf
	EndIF
Endif


]]></Source>
