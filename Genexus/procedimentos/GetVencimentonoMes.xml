      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CrePagTotItm = 0
&CrePagVlrJur = 0
&CrePagVlrDsc = 0

&CreDtaVct = yMDtoD(&ano,&mes,1)
&FimCreDtaVct = eom(&CreDtaVct)
For each order EmpCod,FilCod,CreRecPag,CrePagDta,CrePagCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreRecPag = &CreRecPag
	Where CreSts <> Status_Duplicata.CANCELADA
	Where CreDtaVct >= &CreDtaVct and CreDtaVct <= &FimCreDtaVct
	Where CrePagDta <= &FimCreDtaVct
	Where CrePagSts <> Status_Caixa.Cancelado or CrePagSts.IsEmpty() or CrePagSts.IsNull()
	
	&CrePagTotItm += CrePagTotItm
	&CrePagVlrJur += CrePagVlrJur
	&CrePagVlrDsc += CrePagVlrDsc
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
