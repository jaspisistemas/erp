      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&TipoPerfil = 0
&auxPesExtCod = val(&PesExtCod)

if &auxPesExtCod > 0
	For each order PesExtCod, EmpCod, PesCod   //Pessoa
		Where PesExtCod = &auxPesExtCod
		&TipoPerfil = 1
		Exit
	EndFor
	
	If &TipoPerfil = 0
		For each order CrtCod //contador
			Where CrtExtId = &auxPesExtCod
			&TipoPerfil = 2
			exit
		EndFor
	EndIf
	
	If &TipoPerfil = 0
		For each order SupCod  //suporte
			Where SupExtID = &auxPesExtCod
			&TipoPerfil = 3
			exit
		EndFor
	EndIf
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
