      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, PlanCod, FinAno, FinMes
	Where EmpCod = &EmpCod
	Where PlanCod = &PlanCod when not &PlanCod.IsEmpty()
	Where FinAno = &FinAno
	Where FinMes = &FinMes
	
	if FinForCod1.IsEmpty()
		FinForPer1 = 0
	EndIF
	
	if FinForCod2.IsEmpty()
		FinForPer2 = 0
	EndIF
	
	if FinForCod3.IsEmpty()
		FinForPer3 = 0
	EndIF
	if FinForCod4.IsEmpty()
		FinForPer4 = 0
	EndIF
EndFor

commit


]]></Source>
