      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&SoNumero = RetornaSoNumeros.Udp(&PesCnpj)

&HttpClient.host = "www.receitaws.com.br/v1/cnpj/" + &SoNumero.Trim()
&HttpClient.Timeout = 5
&HttpClient.Execute('GET','')
&HttpClient.Secure = 1

If &httpClient.ErrCode = 0
	&response = &HttpClient.ToString()
	&SDTRFB.FromJson(&response)
	
	&PesRaz = &SDTRFB.nome
	&PesFan = &SDTRFB.fantasia
	&PesCEP = RetornaSoNumeros.Udp(&SDTRFB.cep)
	&PesCEP = FormataCEP.Udp(&PesCEP)
	&PesLog = &SDTRFB.logradouro
	&PesNro = &SDTRFB.numero
	&PesBai = &SDTRFB.bairro
	&PesEml = &SDTRFB.email
	&CidNom = &SDTRFB.municipio.Trim()
	&UfeCod  = &SDTRFB.uf
	&PesFonNum = Substr(&SDTRFB.telefone,1, 15)
	Do 'getCidade'
Else 
	&PesRaz = ''
	&PesFan = ''
	&PesCEP = ''
	&PesLog = ''
	&PesNro = ''
	&PesBai = ''
	&UfeCod  = ''
	&CidNom = ''
	&PesEml = ''
EndIF

sub 'getCidade'
	For Each Order EmpCod, CidNom, UfeCod
		Where EmpCod = &EmpCod
		Where CidNom = &CidNom
		Where UfeCod = &UfeCod
		&CidCod = CidCod
		Exit
	EndFor
EndSub
]]></Source>
