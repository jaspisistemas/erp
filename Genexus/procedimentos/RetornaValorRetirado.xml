      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&OciPedQtd = 0
If &ProCod > 0
	For each Order EmpCod,FilCod,ProCod,PedCodOciRef,PedSts
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where PedCodOciRef = &PedCodOciRef
		Where PedSts = Status_Pedido.FECHADO
		Where PedStsGer = Pedido_gerado.OrdemCarregamento
		
		&PedVlrItm += PedVlrItmComDsc
	EndFor
Else
	Do 'Pedido'
	
EndIf

Sub 'Pedido'
	For each Order EmpCod,FilCod,PedSts,PedCodOciRef
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCodOciRef = &PedCodOciRef
		Where PedSts = Status_Pedido.FECHADO
		Where PedStsGer = Pedido_gerado.OrdemCarregamento
		
		&PedVlrItm += PedVlrItmComDsc
	EndFor
EndSub
]]></Source>
