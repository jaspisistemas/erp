      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SDT_MovimentoTransferencia.Clear()

//Origem
For each order EmpCod,MovCod, MovTip
	where EmpCod = &EmpCod
	where MovTip = TipoMovimento.Transferencia
	where MovCreDeb = 'D' //Origem é Débito
	where MovCtaBanCod = &OrigemCtaBanCod when not &OrigemCtaBanCod.IsEmpty()
	where MovDtaCon >= &MovDtaCon when not &MovDtaCon.IsEmpty()
	where MovDtaCon <= &MovDtaCon_To when not &MovDtaCon_To.IsEmpty()
	where MovVlr = &MovVlr when not &MovVlr.IsEmpty()
	&SDT_MovimentoTransferenciaItem = new()
	&SDT_MovimentoTransferenciaItem.DebMovCod = MovCod
	&SDT_MovimentoTransferenciaItem.DebMovDoc = MovDoc
	&SDT_MovimentoTransferenciaItem.DebMovVlr = MovVlr
	&SDT_MovimentoTransferenciaItem.DebMovCtaBanCod = MovCtaBanCod
	&SDT_MovimentoTransferenciaItem.DebMovCtaBanNom = substr(MovCtaBanNom,1,23)
	&OriMovTrnOriCod = MovTrnOriCod
	Do 'Destino'
	&SDT_MovimentoTransferenciaItem.MovDtaCon = MovDtaCon
	if &SDT_MovimentoTransferenciaItem.CreMovVlr <> 0 or &SDT_MovimentoTransferenciaItem.CreMovCtaBanCod <> 0
		&SDT_MovimentoTransferencia.Add(&SDT_MovimentoTransferenciaItem)
	EndIf
EndFor


//Destino
Sub 'Destino'
	
	For each order EmpCod,MovCod
		where EmpCod = &EmpCod
		where MovCod = &OriMovTrnOriCod 
		where MovCtaBanCod = &DestinoCtaBanCod when not &DestinoCtaBanCod.IsEmpty()
		&SDT_MovimentoTransferenciaItem.CreMovCod = MovCod
		&SDT_MovimentoTransferenciaItem.CreMovVlr = MovVlr
		&SDT_MovimentoTransferenciaItem.CreMovDoc = MovDoc
		&SDT_MovimentoTransferenciaItem.CreMovCtaBanCod = MovCtaBanCod
		&SDT_MovimentoTransferenciaItem.CreMovCtaBanNom = substr(MovCtaBanNom,1,23)
		exit
	when none
		&SDT_MovimentoTransferenciaItem.CreMovCtaBanCod = 0
		&SDT_MovimentoTransferenciaItem.CreMovVlr = 0
	EndFor
	
EndSub

]]></Source>
