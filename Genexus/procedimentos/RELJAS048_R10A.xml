      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
RetornaTabelaFilial.Call(&EmpCod, &FilCod, &FiltabCod)
&TipoCodigoBarras = TipoCodigoBarras.Code128

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&IsColuna1 = true
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	&EtqQtd = EtqQtd
	&ProCod = EtqProCod
	&ProGraCod = EtqProGraCod

	

	&Coluna1.SetEmpty()
	&EtqProQtdEmb.SetEmpty()
	&Coluna3.SetEmpty()
	
	&sdtDadosAdicionaisEtiqueta = new()
	if not EtqProObsAdi.IsEmpty()
		&sdtDadosAdicionaisEtiqueta.FromJson(EtqProObsAdi)
	Endif
	
	&Coluna4 = ''
	if not &sdtDadosAdicionaisEtiqueta.ProDesEtq4.IsEmpty()
		&Coluna4 = Format('LOC: %1', trim(&sdtDadosAdicionaisEtiqueta.ProDesEtq4))
	EndIf

	&NomeEmpresa = trim(&FilFan)
	&EtqProQtdEmb = EtqProQtdEmb
	If not EtqProNroLot.Trim().IsEmpty()
		&Coluna3 = 'Lote: '+trim(EtqProNroLot)
	EndIf

	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto += ': ' + trim(str(EtqProCod))
		&Codigo = trim(str(EtqProCod))
	Else
		&CodigoProduto += ': ' + trim(EtqNovProCod)
		&Codigo = trim(EtqNovProCod)
	EndIF
	
	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF
	
	if &ImprimirLocacao =  true
		do 'GetLocacao'
//		&EtqProNom += ' | ' + trim(&EstLoc) ///aqui a locação fica no nome do produto
	EndiF

	&NomeProduto  = GxGetMLi(&EtqProNom, 1, 37)
	&NomeProduto1 = GxGetMLi(&EtqProNom, 2, 37)
	
	&NewProBar = format('%1 %2 %3 %4', substr(EtqProBar, 1, 2), substr(EtqProBar, 3, 7), substr(EtqProBar, 10, 3), substr(EtqProBar, 13, 1))
	
	//MAIS CODIGOS
	&Referencias = ''
	&Referencias2 = ''
	&Referencias3 = ''
	&MensagemReferencias = ''
	if &ImprimirLocacao =  true ///aqui a locação fica no codigos adicionais
		&MensagemReferencias = trim(&EstLoc)
	EndIf	
	if not &sdtDadosAdicionaisEtiqueta.CodigosExtrasImpressaoEtiqueta.IsEmpty()
		&MensagemReferencias += ' REF: '+&sdtDadosAdicionaisEtiqueta.CodigosExtrasImpressaoEtiqueta.Trim()
	Endif

	&MensagemReferencias = trim(&MensagemReferencias)
	&Referencias = GxGetMLi(&MensagemReferencias, 1, 40)
	&Referencias2 = GxGetMLi(&MensagemReferencias, 2, 40)
	&Referencias3 = GxGetMLi(&MensagemReferencias, 3, 40)
	
	&CodBarrasImage.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqProBar) + '.jpg'
	If not EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqProBar, EtqProBar)
		EndIF
		If &File.Exists()
			&CodBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf
	if &MensagemReferencias.IsEmpty()
		do 'printEtiquetasSemRef'
	Else
		do 'printEtiquetas'
	Endif
EndFor

sub 'printEtiquetasSemRef'
	For &i = 1 to &EtqQtd step 1
		print EtiquetaModelo001Col2
	EndFor
EndSub

sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		print EtiquetaModelo001Col1
	EndFor
EndSub


Sub 'GetLocacao'
	For each order EmpCod, FilCod, ProCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		Where ProCod = &ProCod
		&EstLoc = 'Loc.: '+trim(EstLoc)
		Exit
	EndFor
EndSub
]]></Source>
