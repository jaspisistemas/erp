      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&iniPedDtaFat = ymdtoD(&Ano, 1, 1)
&finPedDtaFat = ymdtoD(&Ano, 12, 31)
 
For &Count = 1 to 12
	&SdtGraficoVendasMensalItem = new()
	&SdtGraficoVendasMensalItem.CreDtaMes = YmDtoD(&Ano, &Count, 1)
	&SdtGraficoVendasMensalItem.CreMes = Substr(CMonth(&SdtGraficoVendasMensalItem.CreDtaMes), 1, 3)
	&SdtGraficoVendasMensal.Add(&SdtGraficoVendasMensalItem)
EndFor

For Each Order EmpCod, PedSts, FilCod, PedDtaFat
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod when not &FilCod.IsEmpty()
	Where PedDtaFat >= &iniPedDtaFat and PedDtaFat <= &finPedDtaFat
	
	Where LctTip = TipoLancamento.SaidaMercadoria when not &PedVenCod.IsEmpty()
	Where LctTip = TipoLancamento.SaidaMercadoria or LctTip = TipoLancamento.EntradaMercadoria when &PedVenCod.IsEmpty()
	
	Where PedSts = Status_Pedido.FECHADO
	
	Where LctAtuSal = Status_EntradaSaida.Saida when not &PedVenCod.IsEmpty()
	Where LctAtuSal = Status_EntradaSaida.Saida or LctAtuSal = Status_EntradaSaida.Entrada when &PedVenCod.IsEmpty()
	
	Where PedVenCod = &PedVenCod when not &PedVenCod = 0
	Where LctAtuGra <> Status_SimNao_PS.NAO or LctAtuGra.IsNull()
	
	If (&LctTip <> LctTip or PedDtaFat <> &PedDtaFat or LctAtuSal <> &LctAtuSal) and not &PedDtaFat.IsEmpty()
		do 'addSdt'
	Endif	
	
	&PedVlrLIq += PedVlrLiq
	
	&LctTip = LctTip
	&PedDtaFat = PedDtaFat 
	&LctAtuSal = LctAtuSal 
EndFor

if &PedVlrLIq > 0
	do 'addSdt'
Endif

padraoUsuarioHora.Call('G', '#WidGet_GraficoVendas#', &PesCod, &EmpCod, &SdtGraficoVendasMensal.ToXml(), &PadDtaMod, &PadDtaHorMod, 'T')

Sub 'addSdt'
	
	For &SdtGraficoVendasMensalItem in &SdtGraficoVendasMensal
		if month(&SdtGraficoVendasMensalItem.CreDtaMes) = month(&PedDtaFat)
			if &LctTip = TipoLancamento.SaidaMercadoria
				&SdtGraficoVendasMensalItem.CreVlrVen += &PedVlrLIq
			Else
				&SdtGraficoVendasMensalItem.CreVlrCom += &PedVlrLIq
			endif
		EndIf
	EndFor

	&PedVlrLIq = 0
EndSub
]]></Source>
