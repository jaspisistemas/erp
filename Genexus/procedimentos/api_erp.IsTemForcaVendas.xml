      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsTemForcaVendas = false

CarregaSdtPerfil_api.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &AutGrpCod, &AutGrpNom)

For Each Order EmpCod, RotSts, MenOrd, MenNom, SubMenOrd, SubMenNom, RotOrd, RotNom
	Where EmpCod = &wwpContext.EmpCod
	Where RotSts = Status_AtivoInativo.ATIVO
	Where not RotLinSmart.IsEmpty()	//not RotLin.IsEmpty() or 
	Where MenNom.ToUpper() like 'FORÇA DE VENDAS'
	 
	if &wwpContext.tipoPerfil <> 3
		If not RotAutCod.IsEmpty()
			RetornaAutorizacaoApi.Call(RotAutCod.Trim(), &wwpContext, &AutGrpCod, &AutNiv)
		Else
			&AutNiv = 1
		EndIF
	Else
		&AutNiv = 4
	Endif
	
	If (&AutNiv > 0 and &AutNiv >= RotNivReq and RotNivReq < 4) or &AutNiv = 4
		&IsTemForcaVendas = true
	EndIF
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
