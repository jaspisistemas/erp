      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &CreSts <> Status_Duplicata.DESCONTADA
	&CrePagVlr = &RemCrePagVlr 
Endif

For Each Order EmpCod, PlanCod
	Where EmpCod = &EmpCod
	Where PlanCod = &RetPlanCod
	
	&RetPlanCatTip = PlanCatTip
	Do CAse
//		CAse &RemRetBanCod = '28' and &BanCod = '748'
//			&MovItmVlr = &RemCreVlrTar
		
		CAse &RemRetBanCod = 'TAXA'
			&MovItmVlr = &RemCreVlrTar
			&CrePagVlr = &RemCreVlrTar
			
		Otherwise
			&MovItmVlr = &CrePagVlr
	EndCAse

	
	Do case
		Case PlanCatTip = 'D'
			&MovTip = TipoMovimento.DespesaRemessa
			Do 'ValidaCapadoLcto'
		Case PlanCatTip = 'C'
		    &MovTip = TipoMovimento.ReceitaRemessa
			Do 'ValidaCapadoLcto'
	EndCase
	Exit
EndFor

if &MovCod > 0
	PrcAtualizaMovimentoFinanceiro.Call(&EmpCod, &MovCod)
Endif

//#############################################################################################################################
Sub 'ValidaCapadoLcto'
	&IsExiste = False
	For each Order EmpCod,MovDtaPgt,MovTip,MovCtaBanCod
		Where EmpCod = &EmpCod
		Where MovDtaPgt = &RemDtaCreDta
		Where MovTip = &MovTip 
		Where MovCtaBanCod = &CreCbrCtaBanCod
		Where MovCrePagDta = &DtaOco// adicionado 01/07/16 TTS
		Where MovSts = Status_Caixa.Lancado or MovSts.IsEmpty() or MovSts.IsNull()
				
		&MovCod    = MovCod
		&MovMaxItm = MovMaxItm
		Do 'InsereItensLcto'
		Exit
	When none
		Do 'CapadoLcto'
	EndFor
EndSub
//#############################################################################################################################
Sub 'CapadoLcto'
	UltimoCodigoEmpresa.Call(domParCod.MOVIMENTO, &EmpCod, 0, &MovCod)
	New
		EmpCod = &EmpCod
		MovCod = &MovCod
		MovDta = SErverDate()
		MovDtaPgt = &RemDtaCreDta
		MovHor = ServerNow()
		MovCtaBanCod = &CreCbrCtaBanCod
		MovCreDeb = &RetPlanCatTip
		if &RemCreDupNro.IsEmpty()
			MovDoc = trim(str(&MovCod))
		Else		
			MovDoc    = &RemCreDupNro
		Endif
	
	    MovTip    = &MovTip
		MovDtaCon = &RemDtaCreDta
		MovCrePagDta = &DtaOco
		MovSts = Status_Caixa.Lancado
	EndNew
	commit
	Do 'InsereItensLcto'

EndSub

Sub 'InsereItensLcto'
	
	&MovItmCpl = 'CL: '+Trim(str(&CreCliCod))+'-'+trim(&CreCliRaz)
	
//	if &RemRetBanCod <> '28'
		For each Order EmpCod,FilCod,CreCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CreCod = &CreCod
			&CreMaxPagCod = CreMaxPagCod
			
			Exit
		EndFor
		&AuxCreMaxPagCod = &CreMaxPagCod +1
		&AuxMovMaxItm  = &MovMaxItm + 1
		
		New //MOVIMENTO ITEM
			EmpCod       = &EmpCod
			MovCod       = &MovCod
			MovItmCod    = &AuxMovMaxItm
			MovItmVlr    = &MovItmVlr
			PlanCod      = &RetPlanCod
			MovCreFilCod = &FilCod
			MovCreCod    = &CreCod
			MovItmCpl    = &MovItmCpl
			MovCrePagCod = &AuxCreMaxPagCod
		EndNew
		Commit
		
		New
		    EmpCod       = &EmpCod
			FilCod       = &FilCod
			CreCod       = &CreCod
			CrePagCod    = &AuxCreMaxPagCod
			CrePagDta    = &DtaOco //#########################################
			CrePagVlr    = &RemCrePagVlr
			CrePagVlrJur = &RemCrePagVlrJur
			CrePagVlrDsc = &RemCrePagVlrDsc
			if &RemRetBanCod = 'TAXA'
				CrePagVlr    = 0
				CrePagVlrTar = &MovItmVlr
				CrePagVlr    = 0
				CrePagVlrJur = 0
				CrePagVlrDsc = 0
			Endif
		
			
			CrePagTip    = TipoDuplicataBaixa.Total
			CreIsRet     = true
			CreMovCod    = &MovCod
			CreMovItmCod = &AuxMovMaxItm
		Endnew
	
		Commit
		
		AtualizaSaldoDuplicata.Call(&EmpCod,&CreCod,&FilCod)
		
//	Else //SO GRAVA TARIFA NA CONTA SE AINDA NAO FOI GRAVADA.
//		For Each Order EmpCod, MovCod, MovCreFilCod, MovCreCod
//			Where EmpCod       = &EmpCod
//			Where MovCod       = &MovCod
//			Where MovCreFilCod = &FilCod
//			Where MovCreCod    = &CreCod
//			MovItmVlr    = &MovItmVlr
//			PlanCod      = &RetPlanCod
//			MovItmCpl    = &MovItmCpl
//			Exit
//		When none
//			&AuxMovMaxItm  = &MovMaxItm + 1
//			New
//				EmpCod       = &EmpCod
//				MovCod       = &MovCod
//				MovItmCod    = &AuxMovMaxItm
//				MovItmVlr    = &MovItmVlr
//				PlanCod      = &RetPlanCod
//				MovCreFilCod = &FilCod
//				MovCreCod    = &CreCod
//				MovItmCpl    = &MovItmCpl
//				MovCrePagCod = 1
//			EndNew
//		EndFor
//	
//		Commit
//	EndIf

	&Mode = TrnMode.update
	AtualizaSaldoConta.Call(&Mode,&EmpCod,&CreCbrCtaBanCod,&RemDtaCreDta,&RetPlanCatTip,&CrePagVlr,&DtaVazia,0, '')
	
EndSub

]]></Source>
