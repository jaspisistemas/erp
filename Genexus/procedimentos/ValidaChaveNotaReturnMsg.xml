      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CteDocChvNfe = trim(RetornaSoNumeros.Udp(&CteDocChvNfe))

If &CteDocChvNfe.Trim().Length() <> 44
	&Mensagem = 'A chave de nota não é válida pois não possui os 44 dígitos!'
	return
Else
	&aux = SubStr(trim(&CteDocChvNfe),1,43)
	&Dg  = SubStr(trim(&CteDocChvNfe),44,1)
	&cDV = RetornaModulo11.Udp(&aux)
	If  &Dg <> &cDV
		&Mensagem = 'A chave de nota não é válida.Verifique!'
		return
	Else
		
		&serie = val(SubStr(trim(&CteDocChvNfe),23,3))   //chave cpf tiago ex: 41181000005041624976559200000000011000000019
		If &serie >= 920 and &serie <= 969
			&Cpf = SubStr(trim(&CteDocChvNfe),10,11)
			ValidaCpfCnpj.Call(&Cpf,&ErroCpf, &ObrigatorioCpfCnpj)//cpf tiago 050.416.249.76
			If  &ErroCpf = 1
				&Mensagem = 'O CPF da chave está inválido! CHAVE INVÁLIDA!'
				return
			EndIf
		Else
			&Cnpj = SubStr(trim(&CteDocChvNfe),7,14)
			ValidaCpfCnpj.Call(&Cnpj,&ErroCpf, &ObrigatorioCpfCnpj)
			If &ErroCpf = 1
				&Mensagem = 'O CNPJ da chave está inválido! CHAVE INVÁLIDA!'
				return
			EndIf
		EndiF
	EndIf
EndIf


]]></Source>
