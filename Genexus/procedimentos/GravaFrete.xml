      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//&FrtNot.FromString(&auxFrtNot)

//GRAVAR LOG
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'FRETE')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
	&LogErpRegTip =  iif(&FrtCod = 0, Trnmode.Insert, Trnmode.Update)
	prcCarregaLog_Frete.Call(&EmpCod, &FilCod, &FrtCod, &SdtLogAtributos)
Endif


For Each Order EmpCod, FilCod, FrtCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where FrtCod = &FrtCod
	FrtDoc = &FrtDoc
	//ModCod = &ModCod
	FrtTraCod = &FrtTraCod
	//FrtNot = &FrtNot
	//FrtOri = &FrtOri
	//FrtSer = &FrtSer
	FrtDtaEms = &FrtDtaEms
	FrtDtaVct = &FrtDtaVct
	FrtDtaEnt = &FrtDtaEnt
	FrtObs = &FrtObs
	//CfoCod = &CfoCod
	FrtVlrCtb = &FrtVlrCtb
//	FrtBasCal = &FrtBasCal
//	FrtVlrImp = &FrtVlrImp
	//FrtChv = &FrtChv
//	FrtVlrIse = &FrtVlrIse
//	FrtAliImp = &FrtAliImp
	FrtDscVlr = &FrtDscVlr
	FrtAcrVlr = &FrtAcrVlr
	FrtPlanCod = &FrtPlanCod
	Exit
When none
	UltimoCodigoEmpresa.Call(domParCod.FRETE, &EmpCod, &FilCod, &FrtCod)
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		FrtCod = &FrtCod
		FrtDoc = &FrtDoc
		//ModCod = &ModCod
		FrtTraCod = &FrtTraCod
		//FrtNot = &FrtNot
		//FrtOri = &FrtOri
		//FrtSer = &FrtSer
		FrtStsFin = Status_Financeiro.ABERTO
		FrtDtaEms = &FrtDtaEms
		FrtDtaVct = &FrtDtaVct
		FrtDtaEnt = &FrtDtaEnt
		FrtDtaLct = serverdate()
		FrtObs = &FrtObs
		//CfoCod = &CfoCod
		FrtVlrCtb = &FrtVlrCtb
		//FrtBasCal = &FrtBasCal
		//FrtVlrImp = &FrtVlrImp
		//FrtChv = &FrtChv
		//FrtVlrIse = &FrtVlrIse
		//FrtAliImp = &FrtAliImp
		FrtDscVlr = &FrtDscVlr
		FrtAcrVlr = &FrtAcrVlr
		FrtPlanCod = &FrtPlanCod
	EndNEw
EndFor

Commit

if &LogErpTabIsLog = true //GRAVA LOG
	prcGravaLog_frete.Call(&LogErpRegTip, &EmpCod, &FilCod, &FrtCod, &Pgmname, &wwpContextUserName, &SdtLogAtributos)
Endif
]]></Source>
