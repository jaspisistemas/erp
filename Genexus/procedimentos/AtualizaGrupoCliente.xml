      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//

//GRAVA LOG
&TabelaVarchar = 'PESSOA'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)

					
for &SdtClienteXlsItem in &SdtClienteXls
	
	For each order EmpCod, PesCod
		where EmpCod = &EmpCod
		where PesCod = &SdtClienteXlsItem.PesCod

		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(Str(PesCod))
			&LogErpRegTip = TrnMode.Update
			&LogErpRegGUID.SetEmpty()
		Endif
		
		if &IsAlterarCidade = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesCidCod', trim(PesCidCod.ToFormattedString()), trim(&PesCidCod.ToFormattedString()), &LogErpRegGUID )
			EndIf
			PesCidCod = &PesCidCod
		EndIf
		
		if &IsAlterarCep = true 
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesCep', trim(PesCep.ToFormattedString()), trim(&PesCep.ToFormattedString()), &LogErpRegGUID )
			EndIf
			PesCep = &PesCep
		EndIf	
		
		if &IsAlterarRamoAtividade = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'RatCod', trim(RatCod.ToFormattedString()), trim(&RatCod.ToFormattedString()), &LogErpRegGUID )
			EndIf
			RatCod = &RatCod
		EndIf
		
		if &IsAlterarGrupoImposto = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesGruImpCod', trim(PesGruImpCod.ToFormattedString()), trim(&GruImpCod.ToFormattedString()), &LogErpRegGUID )
			EndIf
			PesGruImpCod = &GruImpCod
		EndIf
	
		If &IsAlteraTranspRedesVenda = True
			If &LogErpTabIsLog = True
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesCliTraCod', Trim(PesCliTraCod.ToFormattedString()), trim(&PesCliTraCod.ToFormattedString()), &LogErpRegGUID )
			EndIf
			PesCliTraCod	= &PesCliTraCod
		EndIf
		
		If &IsAlteraTranspRedesCompra = True
			If &LogErpTabIsLog = True
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesCliTraSaiCod', Trim(PesCliTraSaiCod.ToFormattedString()), trim(&PesCliTraSaiCod.ToFormattedString()), &LogErpRegGUID )
			EndIf
			PesCliTraSaiCod	= &PesCliTraSaiCod
		EndIf
						
		if &WPALTERAVENDEDORCLIENTE_AutNiv > 0
			if &IsAlterarVendedorInterno = true
				&PesSacDlg = '#JASPI# Transferido do Televendas:' + trim(str(PesIntVenCod)) + ' Para Televendas:' + trim(Str(&PesIntVenCod))
				GravaLigacaoTelevendas.Call(&EmpCod, PesCod, &PesIntVenCod, true, Status_InternoExterno.INTERNO, &PesSacDlg,  serverdate(), 'I', &ContextPesCod)
				If &LogErpTabIsLog = True
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesIntVenCod', Trim(PesIntVenCod.ToFormattedString()), trim(&PesIntVenCod.ToFormattedString()), &LogErpRegGUID )
				EndIf
			Endif
			if &IsAlterarVendedorExterno = true
				&PesSacDlg = '#JASPI# Transferido do Vendedor:' + trim(str(PesExtVenCod)) + ' Para Vendedor:' + trim(Str(&PesExtVenCod))
				GravaLigacaoTelevendas.Call(&EmpCod, PesCod, &PesExtVenCod, true, Status_InternoExterno.ExTERNO, &PesSacDlg, serverdate(), 'E', &ContextPesCod)
				If &LogErpTabIsLog = True
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesExtVenCod', Trim(PesExtVenCod.ToFormattedString()), trim(&PesExtVenCod.ToFormattedString()), &LogErpRegGUID )
				EndIf
			EndIF	
			if (&IsAlterarVendedorInterno = true or &IsAlterarVendedorExterno = true)
				SubstituiVendedorVinculos.Call(&EmpCod, PesCod, &PesExtVenCod, &PesIntVenCod, &Count)
			Endif
		Endif
		
		Commit
	EndFor
	
	AtualizaEnderecoCliente.Call(&EmpCod, &SdtClienteXlsItem.PesCod) //este atualiza os outros campos conforme PesCidCod, ex: PesCidNom
	commit
	
EndFor

Commit
]]></Source>
