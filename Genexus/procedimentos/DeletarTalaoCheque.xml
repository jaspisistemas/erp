      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsNaoPodeDeletar = False

For Each Order EmpCod,TalCtabanCod,TalCod
	Where EmpCod = &EmpCod
	Where TalCtabanCod = &TalCtaBanCod
	Where TalCod = &TalCod
	Where not CheMot in ('00', '98')
	&IsNaoPodeDeletar = true
	Exit
EndFor

If &IsNaoPodeDeletar = false
	For Each Order EmpCod,TalCtabanCod,TalCod
		Where EmpCod = &EmpCod
		Where TalCtabanCod = &TalCtaBanCod
		Where TalCod = &TalCod
		
//		&LgObs = 'TALAO DELETADO:' + trim(str(TalPNum)) + '; FILIAL:' + trim(str(ChPFilCod)) + '; CONTA:' + trim(ChPConNum) + 
//		'; SEQ.INICIAL:' + trim(str(TalPChqIni)) + '; SEQ.FINAL:' + trim(str(TalPChqFin)) + '; DTA.ENTRADA:' + TalPDatEnt.ToFormattedString()
		Delete
		Exit
	EndFor
	
	For Each Order EmpCod,TalCod,CheCod
		Where EmpCod = &EmpCod
		Where TalCod = &TalCod
		Delete
	EndFor
Else
	msg('Atenção Somente pode ser Excluido Talões com Cheques Cancelados e não Emitidos')
EndIF

commit
]]></Source>
