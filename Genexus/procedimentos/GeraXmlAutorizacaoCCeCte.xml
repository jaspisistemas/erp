      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
LoadWWPContext.Call(&Context)
&PesCod = &Context.PesCod

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
RetornaVersaoNotas.Call(VersaoNota.VersaoCTe,&VersaoNF)
&Hoje = serverdate()

GravaSolicitacao.Call(&EmpCod, &FilCod, &CteCod, &CteCceCod, TipoSolicitacao.Autoriza_CCe_CTE, &PesCod, &SolCod)

	
//dados da Cte
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	&cUF = substr(str(FilCidUfeIbge,7,0),1,2)
	&FilFusHor = FilFusHor
	&FilAmbEms = FilAmbEms
	&FilCpj = RetornaSoNumeros.Udp(FilCpj)
	&CteChv = CteChv	
    Exit
EndFor

&nomeArquivo 	= &CteChv.Trim() + '-' + padL(trim(str(&CteCceCod)),2,'0') 
&ID 			= 'ID110110' + &CteChv + padL(trim(str(&CteCceCod)),2,'0')
&IdLote 		= trim(str(&FilCod)) + trim(str(&CteCod)) + trim(str(&CteCceCod))

&ano = str(YEAR(&hoje))
&mes = str(MONTH(&hoje))
&dia = str(DAY(&hoje))
&hojeHora = TAdd(servernow(), -100)

&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hojeHora))),2, '0') + ':00'

&CondicoesUso = 'A Carta de Correcao e disciplinada pelo Art. 58-B do CONVENIO/SINIEF 06/89: Fica permitida a utilizacao de carta de correcao, para regularizacao de erro ocorrido na emissao de documentos fiscais relativos a prestacao de servico de transporte, desde que o erro nao esteja relacionado com: I - as variaveis que determinam o valor do imposto tais como: base de calculo, aliquota, diferenca de preco, quantidade, valor da prestacao;II - a correcao de dados cadastrais que implique mudanca do emitente, tomador, remetente ou do destinatario;III - a data de emissao ou de saida.'

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + trim(&nomeArquivo) + '-env-cce.xml'

&ArqNota.Open(&Nome_enviar)

// START DOC xml
&ArqNota.WriteStartDocument(Encoding.UTF_8)
&ArqNota.WriteStartElement('eventoCTe')
&ArqNota.WriteAttribute('versao', &VersaoNF)
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/cte')

&ArqNota.WriteStartElement('infEvento')
&ArqNota.WriteAttribute('Id', &ID)
&ArqNota.WriteElement('cOrgao', &cUF)
&ArqNota.WriteElement('tpAmb',&FilAmbEms)
If &FilCpj.Trim().Length() > 11
	&ArqNota.WriteElement('CNPJ', &FilCpj)
Else
	&ArqNota.WriteElement('CPF', &FilCpj)
EndIf
&ArqNota.WriteElement('chCTe', &CteChv)

&ArqNota.WriteElement('dhEvento',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' + &hora + '-' + trim(&FilFusHor))
&ArqNota.WriteElement('tpEvento', '110110')
&ArqNota.WriteElement('nSeqEvento',trim(str(&CteCceCod)))
&ArqNota.WriteStartElement('detEvento')
&ArqNota.WriteAttribute('versaoEvento', &VersaoNF)
&ArqNota.WriteStartElement('evCCeCTe')
&ArqNota.WriteElement('descEvento','Carta de Correcao')

For each Order EmpCod, FilCod, CteCod, CteCCeCod,CteCCeInfCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteCCeCod = &CteCceCod
	&ArqNota.WriteStartElement('infCorrecao')
	&ArqNota.WriteElement('grupoAlterado',trim(CteCCeGrp))
    &ArqNota.WriteElement('campoAlterado',trim(CteCCeCam))
    &ArqNota.WriteElement('valorAlterado',trim(CteCCeVlr))
	&ArqNota.WriteEndElement()
EndFor
&ArqNota.WriteElement('xCondUso', &CondicoesUso.Trim())
&ArqNota.WriteEndElement()
&ArqNota.WriteEndElement()
&ArqNota.WriteEndElement()
&ArqNota.Close()

wpAutorizaCCeRecepcaoCte.Link(&EmpCod, &FilCod, &CteCod, &CteCceCod, &SolCod)
]]></Source>
