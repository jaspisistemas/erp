      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TabPrc1 = 0

For Each Order EmpCod, TabCod, ProCod, ProGraCod, TabAltCod	
	Where EmpCod = &EmpCod
	WHere TabCod = &TabCod
	Where ProCod = &ProCod
	Where TabAltCod = TabUltAlt
	Where ProGraCod = &ProGraCod
		&TabPrc1 = TabPrc1
	Exit
EndFor
]]></Source>
