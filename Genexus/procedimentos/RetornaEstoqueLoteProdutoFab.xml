        <Source><![CDATA[&EstlotFab.SetEmpty()
For each Order EmpCod, FilCod, ProCod, ProGraCod, EstLotCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &PrOGraCod
	Where EstLotCod = &EstLotCod	
	&EstLotFab = EstLotFab
	Exit
Endfor
]]></Source>
