      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&sdtFichaEstoque.Clear()

&DtaRef = serverdate()
&QtdAux = &Qtd
	
&TotPedQtdCan = 0
&TotPedQtd = 0

do 'monta_descricao_inicio'

&Mostrou = 'N'    
For Each Order EmpCod, FilCod, LctAtuEst, PedSts, PedDtaFat
Where EmpCod = &EmpCod
Where FilCod = &FilCod
Where PedProEstProCod = &ProCod or ProCod = &proCod
Where LctAtuEst = Status_EntradaSaida.Saida
Where PedSts = Status_Pedido.FECHADO
Where PedDtaFat >= &IniPedDtaFat
Where LctGerFin = &LctGerFin when &LctGerFin = Status_SimNao.Sim
	
    if PedDtaFat >= &IniPedDtaFat and PedDtaFat <= &FinPedDtaFat
        &PedQtd += PedQtd
        &PedQtdCan += PedQtdCan
        &Mostrou = 'N'
		
		&TotPedQtd += PedQtd
		&TotPedQtdCan += PedQtdCan
    else
        do 'AddSdt'
		
        &DtaRef = PedDtaFat
        &QtdAux = 0 
        do 'monta_descricao_inicio'
        &PedQtd += PedQtd
        &PedQtdCan += PedQtdCan			
        &Mostrou  = 'S'
		
		&TotPedQtd += PedQtd
		&TotPedQtdCan += PedQtdCan
    endif
EndFor

do 'AddSdt'

Sub 'AddSdt'
	&sdtFichaEstoqueItem = new()
	&sdtFichaEstoqueItem.Desc = &Descricao
	RetiraZerosDepoisVirgulaxCasas.Call(0, &PedQtd.ToFormattedString(), &sdtFichaEstoqueItem.QtdSai)
	
	&sdtFichaEstoqueItem.QtdCan = &PedQtdCan
	
	&sdtFichaEstoque.Add(&sdtFichaEstoqueItem)
	
EndSub

Sub 'Monta_descricao_inicio'

    Do Case
		Case &Tipo =  'D'
	        &IniPedDtaFat = &DtaRef - &QtdAux
	        &FinPedDtaFat = &IniPedDtaFat 
			&Descricao = 'Dias, Período:'
			
	    Case &Tipo = 'S'         
            &IniPedDtaFat = &DtaRef - (&QtdAux * 7)
            if dow(&IniPedDtaFat) <> 1
                &IniPedDtaFat = (&IniPedDtaFat - dow(&IniPedDtaFat)) + 1
            endif
            &FinPedDtaFat = &IniPedDtaFat + 6
			
			&Descricao = 'Semana, Período:'
        Otherwise
            &IniPedDtaFat = &DtaRef - (&QtdAux * 30)
            if day(&IniPedDtaFat) <> 1
                &IniPedDtaFat = (&IniPedDtaFat - day(&IniPedDtaFat))  + 1
            endif
            &FinPedDtaFat = eom(&IniPedDtaFat)
			&Descricao = 'ANO/MÊS ' + trim(str(year(&FinPedDtaFat))) + '/' + trim(str(month(&FinPedDtaFat))) + ':'
    EndCase

    &Descricao += ' ' + dtoc(&IniPedDtaFat) + ' a '+ dtoc(&FinPedDtaFat)
    &PedQtd = 0 
    &PedQtdCan = 0
EndSub
]]></Source>
