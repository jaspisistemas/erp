      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For &sdtDadosRecebidosCotacaoItem in &sdtDadosRecebidosCotacao.Valor
	
	if &AuxCotComProForCod <> &sdtDadosRecebidosCotacaoItem.ForCod 
		&AuxCotComProForCod = &sdtDadosRecebidosCotacaoItem.ForCod 
		do 'podesincronizar'
	Endif

	if &IsPOde = true 
		For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
			
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComItmCod = &sdtDadosRecebidosCotacaoItem.ItmCod
			Where CotComProForCod = &sdtDadosRecebidosCotacaoItem.ForCod
			
			CotComProForVlr = &sdtDadosRecebidosCotacaoItem.Vlr
			CotComProForVlrIpi = &sdtDadosRecebidosCotacaoItem.VlrIpi
			CotComProForVlrIcms = &sdtDadosRecebidosCotacaoItem.VlrIcms
			CotComProForVlrIcmsSt = &sdtDadosRecebidosCotacaoItem.VlrIcmsSt
			CotComProForVlrFin = &sdtDadosRecebidosCotacaoItem.VlrFin
			CotComProForObs = &sdtDadosRecebidosCotacaoItem.Obs
			
			CotComProForSts.FromString(&sdtDadosRecebidosCotacaoItem.sts)
			CotComProForIsImp = &sdtDadosRecebidosCotacaoItem.isImp
			
			Exit
		EndFor
	Endif
	
EndFor

Commit


if &sdtDadosRecebidosCotacao.Fornecedor.Count > 0
	For &sdtDadosRecebidosCotacaoFornecedor in &sdtDadosRecebidosCotacao.Fornecedor
		
		For Each Order EmpCod, CotComCod, CotComForCod
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComForCod = &sdtDadosRecebidosCotacaoFornecedor.ForCod
			
			CotComForObs = &sdtDadosRecebidosCotacaoFornecedor.Obs
			CotComForTipFrt = &sdtDadosRecebidosCotacaoFornecedor.TipFrt
			CotComForFrtVlr = &sdtDadosRecebidosCotacaoFornecedor.FrtVlr
			CotComForPrzEnt = &sdtDadosRecebidosCotacaoFornecedor.PrzEnt
			CotComForPrzPgtParc = &sdtDadosRecebidosCotacaoFornecedor.PrzPag
			Exit
		EndFor
		
	EndFor

	Commit
Endif

Sub 'podesincronizar'
	&IsPOde = true
	For Each Order EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComForCod = &AuxCotComProForCod
		Where CotComForSts = statusCotacaoFornecedor.FINALIZADA
		&IsPOde = false
		Exit
	EndFor
EndSUb

]]></Source>
