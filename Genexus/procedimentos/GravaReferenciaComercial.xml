        <Source><![CDATA[
prcCarregaLog_ClienteReferencias.Call(&EmpCod, &PesCod, &PesRefCod, &SdtLogAtributos)

For Each Order EmpCod, PesCod, PesRefCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesRefCod = &PesRefCod
	
	&newPesRefCod = &PesRefCod
	&LogErpRegTip = trnMode.Update
	
	PesRefObs 		= &PesRefObs
	PesMedAtz 		= &PesMedAtz
	PesRefClaTip 	= &PesRefClaTip
	PesRefPrz		= &PesRefPrz
	PesRefTipPgto 	= &PesRefTipPgto
	PesRefMaiorCmp 	= &PesRefMaiorCmp
	PesRefVlrUltDta = &PesRefVlrUltDta
	PesRefMaiorDta = &PesRefMaiorDta
	PesRefVlrUltCmp	= &PesRefVlrUltCmp
	PesRefDta 		= &PesRefDta
	PesRefDtaCli 	= &PesRefDtaCli
	PesRefFon		= &PesRefFon
	PesRefCon 		= &PesRefCon
	PesRefEml 		= &PesRefEml
	PesRefEmpCod 	= &PesRefEmpCod
	PesRefEmpRaz 	= &PesRefEmpRaz
	PesRefEmpFan 	= &PesRefEmpFan
	PesRefEmpCnpj 	= &PesRefEmpCnpj
	PesRefFon2 		= &PesRefFon2
	PesRefFon3 		= &PesRefFon3
	PesRefSit 		= &PesRefSit
	PesRefUfCod 	= &PesRefUfCod
	PesRefObt		= &PesRefObt
	
	PesRefLim 		= &PesRefLim
	PesRefFreCmp 	= &PesRefFreCmp
	PesRefMaiorAtrz = &PesRefMaiorAtrz
	PesRefMedCmp 	= &PesRefMedCmp
	PesRefObs2		= &PesRefObs2
	PesRefSts       = &PesRefSts
	Exit
When none
	For Each Order EmpCod, PesCod, (PesRefCod)
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&newPesRefCod = PesRefCod
		Exit
	EndFor
	&newPesRefCod += 1
	&LogErpRegTip = trnMode.Insert
	New
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesRefCod = &newPesRefCod
		PesRefObs 		= &PesRefObs
		PesMedAtz 		= &PesMedAtz
		PesRefClaTip 	= &PesRefClaTip
		PesRefPrz		= &PesRefPrz
		PesRefTipPgto 	= &PesRefTipPgto
		PesRefMaiorCmp 	= &PesRefMaiorCmp
		PesRefVlrUltDta = &PesRefVlrUltDta
		PesRefMaiorDta = &PesRefMaiorDta
		PesRefVlrUltCmp	= &PesRefVlrUltCmp
		PesRefDta 		= &PesRefDta
		PesRefDtaCli 	= &PesRefDtaCli
		PesRefFon		= &PesRefFon
		PesRefCon 		= &PesRefCon
		PesRefEml 		= &PesRefEml
		PesRefEmpCod 	= &PesRefEmpCod
		PesRefEmpRaz 	= &PesRefEmpRaz
		PesRefEmpFan 	= &PesRefEmpFan
		PesRefEmpCnpj 	= &PesRefEmpCnpj
		PesRefFon2 		= &PesRefFon2
		PesRefFon3 		= &PesRefFon3
		PesRefSit 		= &PesRefSit
		PesRefUfCod 	= &PesRefUfCod
		PesRefObt		= &PesRefObt
		PesRefLim 		= &PesRefLim
		PesRefFreCmp 	= &PesRefFreCmp
		PesRefMaiorAtrz = &PesRefMaiorAtrz
		PesRefMedCmp 	= &PesRefMedCmp
		PesRefObs2		= &PesRefObs2
		PesRefSts       = &PesRefSts
	EndNew
EndFor

Commit


prcGravaLog_ClienteReferencias.Call(&LogErpRegTip, &EmpCod, &FilCod, &PesCod, &newPesRefCod, &Pgmname, &wwpContextUserName, &SdtLogAtributos)
]]></Source>
