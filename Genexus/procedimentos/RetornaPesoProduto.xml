      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProPesLiq.SetEmpty()

For Each Order EmpCod, ProCod
	Where EmpCod = &empCod
	Where ProCod = &ProCod
	
	if ProPesLiq > 0
		&ProPesLiq = ProPesLiq
	Else
		&ProPesLiq = ProPesLiqCal
	EndIf

	exit
EndFor
]]></Source>
