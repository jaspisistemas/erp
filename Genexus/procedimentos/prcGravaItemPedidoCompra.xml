      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order tmpNFeCod
	Where tmpNFeCod = &tmpNfeCod

	&PedCliCod = tmpEmixCod	
	
	Exit
EndFor

For Each Order tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNfeCod
	
	&ProCod = tmpProCod
	&ProGraCod = tmpProGraCod
	if tmpProQtdCmpEmb <> 0
		&ProForQtdEmb = tmpProQtdCmpEmb
	Else
		&ProForQtdEmb = RetornaQtdEmbalagem.Udp(&EmpCod, &PedCliCod, &ProCod)
	EndIF
	
	//	//fazer buscar somente para quem nao quer repetido
	//    If &DuplicadoCompra <> 'S' //NAO ACEITA DUPLICADOS
	//		RetornaProdutoPedido.Call('N', &EmpCod, &FilCod, &PedCod, &ProCod, &ProGraCod, &PedItmCod, &PedItmIpi, &PedItmIcmSt, &PedItmIcm, &PedItmAcr, &PedItmDsc, &PedQtd, &PedVlrUnt, &PedVlrItm, &PedItmCmp)
	//    Else //ACEITA DUPLICADOS
	//		RetornaProdutoPedido.Call('S', &EmpCod, &FilCod, &PedCod, &ProCod, &ProGraCod, &PedItmCod, &PedItmIpi, &PedItmIcmSt, &PedItmIcm, &PedItmAcr, &PedItmDsc, &PedQtd, &PedVlrUnt, &PedVlrItm, &PedItmCmp)
	//    EndIF
	
	&PedQtdEmb = tmpPedQtd	
	 Do case
        Case &ProForQtdEmb > 0
            &PedQtd = ((&PedQtdEmb * &ProForQtdEmb)) 
        Case &ProForQtdEmb < 0 and &PedQtdEmb > 0
            &PedQtd = (&PedQtdEmb / (&ProForQtdEmb*-1))  
        Otherwise
            &PedQtd = &PedQtdEmb
    EndCase
	
	&PedVlrUnt = tmpPedVlrUnt
	&PedVlrItm = tmpPedVlrTot
	&PedItmVlrDsc = tmpPedVlrDsc
	&PedItmVlrAcr = tmpProVlrFrt + tmpProVlrOut
	
	&PedItmIcm = 0
	&PedItmIcmSt = 0
	&PedItmIcmStPob = 0
	&PedItmDsc = 0
	&PedItmAcr = 0
	&PedItmIpi = 0
	&PedItmVlrIcm = tmpProVlrIcm
	&PedItmVlrIcmSt = tmpProVlrIcmSt
	&PedItmVlrIcmStPob = tmpProVlrFCPIcmsSt
	&PedItmVlrIpi = tmpProVlrIpi
	
	&PedItmPis = tmpProPerPIS
	&PedItmCofins = tmpProPerCOFINS
	
	//PIS e COFINS
	&PedItmAjuPisBas = 0
	&PedItmAjuPisVlr = 0
	&PedItmAjuCofinsVlr = 0
	IF tmpProBasPIS > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasPIS
		&PedItmAjuPisBas = 100 - (tmpProBasPIS/tmpPedVlrTot) * 100
		&PedItmAjuPisBas = &PedItmAjuPisBas *-1
		
		&Moeda = round(tmpProBasPIS * tmpProPerPIS * 0.01, 2)	
		
		if &Moeda <> tmpProVlrPIS
			&PedItmAjuPisVlr = 100 - (tmpProVlrPIS/&Moeda ) * 100
			&PedItmAjuPisVlr = &PedItmAjuPisVlr*-1
		Endif
	
		&Moeda = round(tmpProBasPIS * tmpProPerCOFINS * 0.01, 2)	
		
		if &Moeda <> tmpProVlrCOFINS
			&PedItmAjuCofinsVlr = 100 - (tmpProVlrCOFINS/&Moeda ) * 100
			&PedItmAjuCofinsVlr = &PedItmAjuCofinsVlr*-1
		Endif		
	Endif
	
	//IPI
	&PedItmAjuIpiBas = 0
	&PedItmIpi = tmpProPerIpi
	IF tmpProBasVlrIpi > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasVlrIpi
		&PedItmAjuIpiBas = 100 - (tmpProBasVlrIpi/tmpPedVlrTot) * 100
		&PedItmAjuIpiBas = &PedItmAjuIpiBas*-1
		
		&Moeda = round(tmpProBasVlrIpi * tmpProPerIpi * 0.01, 2)	
		
		if &Moeda <> tmpProVlrIpi
			&PedItmAjuIpiVlr = 100 - (tmpProVlrIpi/&Moeda ) * 100
			&PedItmAjuIpiVlr = &PedItmAjuIpiVlr*-1
		Endif
	Endif		
	
	//ICMS
	&PedItmAjuIcmBas = 0	
	&PedItmAjuIcmVlr = 0
	&PedItmIcm = tmpProPerIcm
	IF tmpProBasVlrIcm > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasVlrIcm
		&PedItmAjuIcmBas = 100 - (tmpProBasVlrIcm/tmpPedVlrTot ) * 100
		&PedItmAjuIcmBas = &PedItmAjuIcmBas*-1
		
		&Moeda = round(tmpProBasVlrIcm * tmpProPerIcm * 0.01, 2)	
		
		if &Moeda <> tmpProVlrIcm
			&PedItmAjuIcmVlr = 100 - (tmpProVlrIcm/&Moeda ) * 100
			&PedItmAjuIcmVlr = &PedItmAjuIcmVlr*-1
		Endif
	Endif

	//ICMS ST
	&PedItmAjuIcmStBas = 0	
	&PedItmAjuIcmStVlr = 0
	&PedItmIcmSt = tmpProPerIcmSt
	IF tmpProBasVlrIcmSt > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasVlrIcmSt
		&PedItmAjuIcmStBas = 100 - (tmpProBasVlrIcmSt/tmpPedVlrTot ) * 100
		&PedItmAjuIcmStBas = &PedItmAjuIcmStBas*-1
		
		&Moeda = round(tmpProBasVlrIcmSt * tmpProPerIcmSt * 0.01, 2)	
		
		if &Moeda <> tmpProVlrIcmSt
			&PedItmAjuIcmStVlr = 100 - (tmpProVlrIcmSt/&Moeda ) * 100
			&PedItmAjuIcmStVlr = &PedItmAjuIcmStVlr*-1
		Endif
	Endif

	if not &PedItmVlrAcr.IsEmpty()
		&PedItmAcr = round((&PedItmVlrAcr * 100) / &PedVlrItm, 4)
	EndiF
	
	If not &PedItmVlrDsc.IsEmpty()
		&PedItmDsc = round((&PedItmVlrDsc * 100) / &PedVlrItm, 4)
	EndIF
	
	If not &PedItmVlrIcmStPob.IsEmpty()
		&PedItmIcmStPob = round((&PedItmVlrIcmStPob * 100) / &PedVlrItm, 4)
	EndiF

	&PedItmCod = 0
	
	&sdtAddPedidoProduto = new()			
	&sdtAddPedidoProduto.PedItmAcr = &PedItmAcr
	&sdtAddPedidoProduto.PedItmDsc = &PedItmDsc
	&sdtAddPedidoProduto.PedItmIpi = &PedItmIpi
	&sdtAddPedidoProduto.PedItmIcmSt = &PedItmIcmSt
	&sdtAddPedidoProduto.PedItmIcmStPob = &PedItmIcmStPob
	&sdtAddPedidoProduto.PedItmIcm = &PedItmIcm
	&sdtAddPedidoProduto.PedQtdEmb = &PedQtdEmb
	&sdtAddPedidoProduto.PedProEmbQtd = &ProForQtdEmb
	&sdtAddPedidoProduto.PedItmCmp = &PedItmCmp
	&sdtAddPedidoProduto.PedItmAjuIpiBas = &PedItmAjuIpiBas
	&sdtAddPedidoProduto.PedItmAjuIcmBas = &PedItmAjuIcmBas
	&sdtAddPedidoProduto.PedItmAjuIcmStBas = &PedItmAjuIcmStBas
	&sdtAddPedidoProduto.PedItmAjuPisBas = &PedItmAjuPisBas
	&sdtAddPedidoProduto.PedItmPis = &PedItmPis
	&sdtAddPedidoProduto.PedItmCofins = &PedItmCofins
	
	&sdtAddPedidoProduto.PedItmAjuIcmVlr = &PedItmAjuIcmVlr
	&sdtAddPedidoProduto.PedItmAjuCofinsVlr  = &PedItmAjuCofinsVlr
	&sdtAddPedidoProduto.PedItmAjuIcmsStPobVlr  = &PedItmAjuIcmsStPobVlr
	&sdtAddPedidoProduto.PedItmAjuIcmStVlr  = &PedItmAjuIcmStVlr
	&sdtAddPedidoProduto.PedItmAjuIpiVlr  = &PedItmAjuIpiVlr 
	&sdtAddPedidoProduto.PedItmAjuPisVlr  = &PedItmAjuPisVlr
	
	GravaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &ProCod, &ProGraCod, &PedQtd, &PedVlrUnt, &sdtAddPedidoProduto, &sdtProdutoLote, &inseridoMensagem, &AlteradoMensagem, &wwpContextUserName, 'S')
	GravaItemPedidoCompra_Cfop.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, tmpEntCFOP, tmpNfeSitCod, false, &wwpContextUserName)
EndFor

commit
]]></Source>
