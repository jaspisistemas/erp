<Object parentGuid="b7dac21c-4d23-49e0-921e-0f5f9f1389c5" user="WINJEAN\jeanfae" versionDate="2025-01-28T20:44:04.0000000Z" lastUpdate="2025-01-27T20:38:26.0000000Z" checksum="202f932fcdf4b5a17e872e24beffc14d" fullyQualifiedName="api_erp.get_capaBalanco" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="a901bf15-f83b-4391-8d76-9d1be184304b" name="get_capaBalanco" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_capa Balanco" parent="api_erp.Balanco" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//parm(in:&DevRandon, in:&OqueFazer, in:&parProCod, in:&parFilCod, in:&parBalCod, out:&sdtBalancoCapa);

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	Do CAse
		Case &OqueFazer = 'ITEM'
			&HojeData = serverdate()
			RetornaProdutoReferencia.Call(&wwpContext.EmpCod, &parProRef, &Procod, &PrograCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &erroMensagem )
			
			For Each ORder EmpCod, BalCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &parFilCod
				Where BalCod = &parBalCod
				
				&BalDta = BalDta
				&AuxFim = &HojeData.AddDays(1)
				&DataBaseBalDta = BalDta.AddDays(1)
				
				&sdtBalancoCapa.sts = 'J200'
				&sdtBalancoCapa.obs = 'Sucesso'
				&sdtBalancoCapa.balCod = BalCod
				&sdtBalancoCapa.filcod = FilCod
				//&sdtBalancoCapa.balObs = BalObs
				&sdtBalancoCapa.balSts = BalSts
				//&sdtBalancoCapa.balDta = BalDta.ToFormattedString()
				//&sdtBalancoCapa.balDtaTmp = DateToTimestamp.Udp(BalDta)
				//&sdtBalancoCapa.balPedcod = BalPedCod
				
				For Each Order EmpCod, BalCod, ProCod, ProGraCod
					Where ProCod = &Procod
					Where ProGraCod = &PrograCod
					
					&sdtBalancoCapa.proRef = ProGraRef
					&sdtBalancoCapa.proCod = ProCod
					&sdtBalancoCapa.proGraCod = ProGraCod
					&sdtBalancoCapa.proNom = ProNomGra
					&sdtBalancoCapa.balQtd = BalQtd
					&BalQtd = BalQtd
					&sdtBalancoCapa.balQtdv = RetiraZerosDepoisVirgulaxCasas.Udp(0,&BalQtd.ToFormattedString())
					&sdtBalancoCapa.SolLot = ProSolLot
					&sdtBalancoCapa.sLancado = 'S'
					do 'getEstoque'					
					&sdtBalancoCapa.estLoc = &EstLoc
					&sdtBalancoCapa.estQtdHje = &EstQtd
					&sdtBalancoCapa.estQtdDia = &EstData
					//&sdtBalancoCapa.EstSdo = &EstSdo
					
					Exit
				When none
					&sdtBalancoCapa.sLancado = 'N'
					do 'getPRoduto'
				EndFor
				
				Exit
			EndFor
			
		Case &OqueFazer = 'CAPA'
			For Each ORder EmpCod, BalCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &parFilCod
				Where BalCod = &parBalCod
				
				&sdtBalancoCapa.sts = 'J200'
				&sdtBalancoCapa.obs = 'Sucesso'
				&sdtBalancoCapa.balCod = BalCod
				&sdtBalancoCapa.filcod = FilCod
				&sdtBalancoCapa.balObs = BalObs
				&sdtBalancoCapa.balSts = BalSts
				&sdtBalancoCapa.balDta = BalDta.ToFormattedString()
				&sdtBalancoCapa.balDtaTmp = DateToTimestamp.Udp(BalDta)
				&sdtBalancoCapa.balPedcod = BalPedCod
				
				&qtd = 0
				For Each Order EmpCod, FilCod, BalCod, (BalOrd)
					&qtd += 1
					&sdtBalancoCapaitem = new()
					
					&sdtBalancoCapaitem.cod = ProCod
					&sdtBalancoCapaitem.ref = ProGraRef
					&sdtBalancoCapaitem.graCod = ProGraCod
					&sdtBalancoCapaitem.nom = ProNom
					&sdtBalancoCapaitem.ord = BalOrd
					&sdtBalancoCapaitem.qtd = BalQtd
					&sdtBalancoCapaitem.bar = ProBar
					&sdtBalancoCapaitem.mNom = MarNom
					
					&sdtBalancoCapa.filcod = FilCod
					&sdtBalancoCapa.filNom  = FilRaz
					&sdtBalancoCapa.pesCod = BalFunCod
					&sdtBalancoCapa.pesRaz = retornaNomepessoa.Udp(EmpCod,BalFunCod)
					
					&BalQtd = BalQtd
					&sdtBalancoCapaitem.qtdV = RetiraZerosDepoisVirgulaxCasas.Udp(0,&BalQtd.ToFormattedString())
					
					&sdtBalancoCapaitem.qtdAnt = BalQtdAnt
					
					&sdtBalancoCapa.produtos.Add(&sdtBalancoCapaitem)
					if &qtd = 5
						exit
					endif
				EndFor
				
				Exit
			when none
				if &parBalCod = 0
					&balDta = serverdate()
					&sdtBalancoCapa.sts = 'J200'
					&sdtBalancoCapa.obs = 'Sucesso'
					&sdtBalancoCapa.balCod = 0
					&sdtBalancoCapa.filcod = &wwpContext.FilCod
					&sdtBalancoCapa.balObs = 'NOVO BALANCO'
					&sdtBalancoCapa.balSts = Status_Pedido.ABERTO
					
					&sdtBalancoCapa.balDta = &balDta.ToFormattedString()
					&sdtBalancoCapa.balDtaTmp = DateToTimestamp.Udp(&balDta)
					
					&sdtBalancoCapa.balPedcod = 0
					
					&sdtBalancoCapa.filNom  = &wwpContext.FilRaz
					&sdtBalancoCapa.pesCod = &wwpContext.PesCod
					&sdtBalancoCapa.pesRaz = &wwpContext.pesRaz
				Else
					&sdtBalancoCapa.sts = 'E998'
					&sdtBalancoCapa.obs = 'Balanço de estoque não localizado!'
				Endif
				
			EndFor
		
		Otherwise
			&sdtBalancoCapa.sts = 'E997'
			&sdtBalancoCapa.obs = 'O que você está fazendo?'
	EndCAse
Else
	&sdtBalancoCapa.sts = 'E999'
	&sdtBalancoCapa.obs = 'O que você está fazendo?'
Endif

sub 'getProduto'
	For each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &wwpContext.EmpCod
		Where ProCod = &Procod
		Where ProGraCod = &PrograCod
		
		&sdtBalancoCapa.proRef = ProGraRef
		&sdtBalancoCapa.proCod = ProCod
		&sdtBalancoCapa.proGraCod = ProGraCod
		&sdtBalancoCapa.proNom = ProNomGra
		&sdtBalancoCapa.balQtd = 0
		&sdtBalancoCapa.SolLot = ProSolLot
		
		do 'getEstoque'					
		&sdtBalancoCapa.estLoc = &EstLoc
		&sdtBalancoCapa.estQtdHje = &EstQtd
		&sdtBalancoCapa.estQtdDia = &EstData
		//&sdtBalancoCapa.EstSdo = &EstSdo
		
		Exit
	When none
		&sdtBalancoCapa.sts = 'E998'
		&sdtBalancoCapa.obs = 'Não localizado produto!'
	EndFor
endSub


sub 'getEstoque'
	RetornaEstoquePedido.Call(&wwpContext.EmpCod, &parFilCod, &ProCod, &ProGraCod, Status_Pedido.ABERTO, &EstLoc, &EstQtd, &EstSdo, &Mensagem)
	
	if &BalDta <> &HojeData
		EstoqueAnteriorFicha.Call(&wwpContext.EmpCod, &parFilCod, &ProCod, &ProGracod, 1, &DataBaseBalDta, &AuxFim, &EstData)
	Else
		&EstData = &EstQtd
	Endif
	
EndSub
]]></Source>
