      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
dO CASE
	case &mode = TrnMode.Insert
		
		if &DesCod.IsEmpty()
				UltimoCodigoEmpresa.Call(domParCod.DESCONTO, &EmpCod, 0, &DesCod)
		EndIf
			
		New
			EmpCod = &EmpCod
			DesCod = &DesCod
			DesDta = &DesDta
			DesTip = &DesTip
			CbrCod = &CbrCod
			DesVlr = &DesVlr
			DesSts = &DesSts
			DesOpe = &DesOpe
			DesPlanCodDesc = &DesPlanCodDesc
			DesPlanCodTrf = &DesPlanCodTrf
			DesMovCodCre = &DesMovCodCre
			DesMovCodTxa = &DesMovCodTxa
		EndNew
		Commit
		
	case &mode = TrnMode.Update
		For each order EmpCod, DesCod
			where EmpCod = &EmpCod
			where DesCod = &DesCod
			DesDta = &DesDta
			DesTip = &DesTip
			CbrCod = &CbrCod
			DesVlr = &DesVlr
			DesSts = &DesSts
			DesOpe = &DesOpe
			DesPlanCodDesc = &DesPlanCodDesc
			DesPlanCodTrf = &DesPlanCodTrf
			DesMovCodCre = &DesMovCodCre
			DesMovCodTxa = &DesMovCodTxa
			exit
		EndFor
		Commit
EndCase
Commit
]]></Source>
