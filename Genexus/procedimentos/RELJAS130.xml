      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadwwpContext.Call(&wwpContext)
&EmpCod = &wwpContext.EmpCod
&FilCod = &wwpContext.FilCod

padraoUsuario.Call('L', 'IMPRIMIRCARREGASDTPEDIDOS', &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod)

&AuxSdtPedidos.Fromxml(&PadObs)


For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	&FiLFonNum = 'FONE: ' + trim(FilFonNum)
	Print DadosEmpresa
	Print Traco
	Exit
EndFor

MT 0
MB 0

For &AuxSdtPedidosItem in &AuxSdtPedidos
	&NomeEntregador = &AuxSdtPedidosItem.PedTraRedCodRaz
	print DadosEntregador
	print Traco	
	Exit
EndFor

Print TituloPedidos
Print Tracejado

if &PedFrpPgtoTip.IsEmpty()
	&AuxSdtPedidos.Sort('PedFrpPgtoTip')
Endif

For &AuxSdtPedidosItem in &AuxSdtPedidos
	if &AuxSdtPedidosItem.PedFrpPgtoTip = &PedFrpPgtoTip or &PedFrpPgtoTip.IsEmpty()
		
		if &PedFrpPgtoTip.IsEmpty() and &AuxSdtPedidosItem.PedFrpPgtoTip <> &AuxPedFrpPgtoTip
			&AuxPedFrpPgtoTip = &AuxSdtPedidosItem.PedFrpPgtoTip
			
			&PedFrpPgtoTipVarchar = &AuxPedFrpPgtoTip.EnumerationDescription()
			print GrupoPagamentos
		Endif	
		
		&PedCod = &AuxSdtPedidosItem.PedCod
		&PedCliCodRaz = &AuxSdtPedidosItem.PedCliCodRaz
		&PedVlrLiq = &AuxSdtPedidosItem.PedVlrLiq
		
		Do case
			Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.DUPLICATA
				&TotatTipoPagamentoMoeda(1) += &AuxSdtPedidosItem.PedVlrLiq
			Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.DINHEIRO
				&TotatTipoPagamentoMoeda(2) += &AuxSdtPedidosItem.PedVlrLiq	
			Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CHEQUEP or &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CHEQUET
				&TotatTipoPagamentoMoeda(3) += &AuxSdtPedidosItem.PedVlrLiq	
			Case &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CARTAOD or &AuxSdtPedidosItem.PedFrpPgtoTip = TipoDuplicata.CARTAOC
				&TotatTipoPagamentoMoeda(4) += &AuxSdtPedidosItem.PedVlrLiq
			Otherwise
				&TotatTipoPagamentoMoeda(5) += &AuxSdtPedidosItem.PedVlrLiq	
		EndCAse
	
		print Pedido
	Endif
	
EndFor

print traco
for &Count = 1 to 5
	&TotMoeda = &TotatTipoPagamentoMoeda(&Count)
	
	if &TotatTipoPagamentoMoeda(&Count) > 0
		&TotalGeralMoeda += &TotMoeda 
		Do Case
			Case &Count = 1
				&PedFrpTipVarchar = 'DUPLICATA'
			Case &Count = 2
				&PedFrpTipVarchar = 'DINHEIRO'
			Case &Count = 3
				&PedFrpTipVarchar = 'CHEQUE'
			Case &Count = 4
				&PedFrpTipVarchar = 'CARTÃO CRÉD./DÉB'
			Otherwise
				&PedFrpTipVarchar = 'OUTRAS FORMAS'
		EndCAse	
		
		print TotalFormaPagamento
	Endif	
Endfor

print traco
&PedFrpTipVarchar = 'TOTAL A RECEBER'
&TotMoeda = &TotalGeralMoeda
print TotalFormaPagamento
]]></Source>
