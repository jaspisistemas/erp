      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&CteDupCod = &parCteDupCod
if &CteDupCod > 0
	For Each Order EmpCod,FilCod,CteCod, CteDupCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDupCod = &CteDupCod
		
		if &CteDupVlr <= 0
			&CtePosDup = Status_SimNao.Nao
			delete
		Else
			&CtePosDup = Status_SimNao.Sim
			CteDupVlr = &CteDupVlr
			CteDupDtaVct = &CteDupDtaVct
			CteDupFrpPgtoCod = &CteDupFrpPgtoCod
		Endif
		
		Exit
	EndFor
	
	Commit
Else
	&CtePosDup = Status_SimNao.Sim
	
	For Each Order EmpCod,FilCod,CteCod,(CteDupCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&CteDupCod = CteDupCod
		Exit
	EndFor
	&CteDupCod+=1
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteDupCod = &CteDupCod
		CteDupNro = &CteDupNro
		CteDupDtaVct = &CteDupDtaVct
		CteDupFrpPgtoCod = &CteDupFrpPgtoCod
		CteDupVlr = &CteDupVlr
	EndNew

	Commit
EndIf

if &CtePosDup = Status_SimNao.Nao
	For Each Order EmpCod,FilCod,CteCod,CteDupCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CtePosDup = Status_SimNao.Sim
		Exit
	EndFor
Endif

For Each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	CtePosDup = &CtePosDup
	Exit
EndFor

Commit
]]></Source>
