      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do CAse
	CAse &sdtSyncAll.SyncOque = 'GRAVARINF_CLIENTE'
		if not &sdtSyncAll.SyncKey.IsEmpty()
			For Each Order EmpCod
				Where EmpCod = 1 //JASPI SISTEMAS
				Where PesEmpSecCod = &sdtSyncAll.SyncKey
				
				For &sdtSyncAllItem in &sdtSyncAll.Sync
					Do CAse
						CAse &sdtSyncAllItem.SyncCod = 'CliVctCer' and not &sdtSyncAllItem.SyncValue.IsEmpty()
							&PesDtaVctcer.FromString(&sdtSyncAllItem.SyncValue)
							if not &PesDtaVctcer.IsEmpty()
								PesDtaVctCer = &PesDtaVctcer
							Endif
							//Case &sdtSyncAllItem.SyncCod = 'CliVer' and not &sdtSyncAllItem.SynValue.IsEmpty()
							//	CliVer = &sdtSyncAllItem.SynValue.Trim()
					EndCAse
					
				EndFor
				
				Exit	
			EndFor
			
			Commit
		Endif
EndCAse
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
