      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
&EmpCod = &Context.EmpCod
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'RECEITA DE PRODUTOS'
	print Cabecalho
End


For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&ProNom = ProRef.Trim() + ' - ' + trim(ProNom)
	&ProEmbCodNom = trim(Str(ProEmbCod)) + ' - ' + trim(ProEmbNom)
	&ProQtdPro = ProQtdPro
	
	&TotalProducao = round(ProVlrCusRec, 2)
	&ValorMateriaPrima = round(ProVlrCusMat, 2)
	&ValorCustoUnit = round(ProVlrCusUnt, 2)
	print ProdutoProduzido
	
	if &IsComCusto = true
		Print ProdutoProduzidoCusto
	EndIF
	
	&IsImprime = true
	&Itens = 0
	&Qtde = 0
	For Each 
		Order EmpCod, RecProCod, RecItmCod when &Ordem = 'C'
		Order EmpCod, RecProNom ,RecItmCod when &Ordem = 'N'
		if &IsImprime = true
			if &IsComCusto = true
				print tituloMateriaPrimaCusto
			Else
				print tituloMateriaPrima
			EndIF
			
			&IsImprime = false
		EndIf
		
		&RecProRef = RecProRef
		if &IsComCusto = true
			print ItemMateriaPrimaComCusto
		Else
			print ItemMateriaPrima
		EndIF
		&Itens += 1
		&Qtde += RecProQtd
	EndFor

	Print Itens
	
	&IsImprime = true
	For Each Order EmpCod, ProCod, PreItmCod
		If &IsImprime = true
			print TituloPreparo
			&IsImprime = false
		EndIf
		
		&Mensagem = PreObs
		print ItemPreParo
	EndFor
	
EndFor


Footer
	print Rodape
End
]]></Source>
