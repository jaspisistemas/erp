      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsExisteXML = false
&Arquivo_Nota = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&ManCha+'-procNFe.xml'
&Arquivo_Nota2 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&ManCha+'-'+padL(trim(&NroNSU),15,'0')+'-procNFe.xml'
&Arquivo_Nota3 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&FilCpj+'-'+padL(trim(&NroNSU),15,'0')+'-procNFe.xml'
&Arquivo_Nota_210200 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&ManCha+'_210200_01-procEventoNFe.xml'
&Arquivo_Nota_210210 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&ManCha+'_210210_01-procEventoNFe.xml'
&Arquivo_Nota_210220 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&ManCha+'_210220_01-procEventoNFe.xml'
&Arquivo_Nota_210240 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&ManCha+'_210240_01-procEventoNFe.xml'
&Arquivo_Nota_110111 = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +'DFe\' +&ManCha+'_110111_01-procEventoNFe.xml'

&mensagem = 'Pega o XML NF-e no arquivo: '
&mensagem += &Arquivo_Nota
do 'Mensagem'

&File.Source = &Arquivo_Nota
If &File.Exists()
	GravaXmlNotaManifestacao.call(&EmpCod,&ManCha,&Arquivo_Nota)
	msg('Arquivo XML gravado com sucesso!',status)
	&IsExisteXML = true
Else
	&File.Source = &Arquivo_Nota2
	If &File.Exists()
		GravaXmlNotaManifestacao.call(&EmpCod,&ManCha,&Arquivo_Nota2)
		msg('Arquivo XML gravado com sucesso!',status)
		&IsExisteXML = true
	Else
		
		msg('Arquivo procNFe.Xml não encontrado',status)
		&File.Source = &Arquivo_Nota_210200
		If &File.Exists()
			&mensagem = &Arquivo_Nota_210200
			GravaXmlEvento.call(&EmpCod,&ManCha,210200,&Arquivo_Nota_210200)
		Else
			msg('Arquivo _210200_01-procEventoNFe.xml não encontrado',status)
			&File.Source = &Arquivo_Nota_210210
			If &File.Exists()
				&mensagem = &Arquivo_Nota_210210
				GravaXmlEvento.call(&EmpCod,&ManCha,210210,&Arquivo_Nota_210210)
			Else
				msg('Arquivo  _210210_01-procEventoNFe.xml não encontrado',status)
				&File.Source = &Arquivo_Nota_210220
				If &File.Exists()
					&mensagem = &Arquivo_Nota_210220
					GravaXmlEvento.call(&EmpCod,&ManCha,210220,&Arquivo_Nota_210220)
				Else
					msg('Arquivo _210220_01-procEventoNFe.xml não encontrado',status)
					&File.Source = &Arquivo_Nota_210240
					If &File.Exists()
						&mensagem = &Arquivo_Nota_210240
						GravaXmlEvento.call(&EmpCod,&ManCha,210240,&Arquivo_Nota_210240)
					Else
						msg('Arquivo _210240_01-procEventoNFe.xml não encontrado',status)
						&File.Source = &Arquivo_Nota_110111
						If &File.Exists()
							&mensagem = &Arquivo_Nota_110111
							GravaXmlEvento.call(&EmpCod,&ManCha,110111,&Arquivo_Nota_110111)
						Else
							msg('Arquivo _110111_01-procEventoNFe.xml não encontrado',status)
						EndIf
					EndIf
				EndIf
			EndIf
		EndIf
	Endif
EndIf

do 'Mensagem'


Sub 'Mensagem'
	msg(&mensagem  + ' Hora: ' + serverTime(),status)
EndSub
]]></Source>
