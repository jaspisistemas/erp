      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensg = ''
&Erro = 0
LoadWWPContext.Call(&Context)

	//###############################################################   Parametros Para Gravar
	
	//Parametros Para Gravar
	&VeiculosServiceGravarRequest.Integrador = Trim(&FilFrtHash)
	&VeiculosServiceGravarRequest.Token = trim(&Token)
	&VeiculosServiceGravarRequest.Versao = 1
	Do 'GetVeiculo'
	//#######################################################################################
	IF &IsHomologado = True
		Do 'GravarVeiculo'
	Else
		&Erro = 1
		&Mensg += 'Proprietério do Veículo não homologado, não é possível cadastrar veículo antes de homologar Proprietário'
	EndIf

Sub 'GravarVeiculo' 
	csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.SecurityProtocolType.Tls11 | System.Net.SecurityProtocolType.Tls;
//	HostWebServiceEfrete.Call(&EmpWebHost, &EmpWebBaseUrl, &EmpWebPor, &IsSecure)
	&Location = GetLocation('VeiculosService') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost 	     //servidor 
	&Location.Port = &EmpWebPor 	//porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	
	If &IsSecure = true
		&Location.Secure = 1
	ELSE
		&Location.Secure = 0 //false 
	EndIf		       //false 
	&Location.CancelOnError = 2 	   //tratar exceção do WS 	
	
	&VeiculosServiceGravarResponse = &VeiculosService.Gravar(&VeiculosServiceGravarRequest)
	
	padraoUsuario.Call('G', '#EFRETEVEICULO', &Context.PesCod, &Context.EmpCod, &VeiculosServiceGravarRequest.ToXml(), &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
	padraoUsuario.Call('G', '#EFRETEVEICULORESPOSTA', &Context.PesCod, &Context.EmpCod, &VeiculosServiceGravarResponse.ToXml(), &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
		
	If GetSOAPErr() = 0 // Resposta do Obter Veiculo
		If &VeiculosServiceGravarResponse.Sucesso = True
			&Mensg = 'Gravado com Sucesso '+ &VeiculosServiceGravarResponse.Excecao.Mensagem
			do 'AtualizaVeiculo'
		Else
			&Mensg = &VeiculosServiceGravarResponse.Excecao.Mensagem
		EndIf
	Else 
		&Erro = val(str(GetSOAPErr()))
		&Mensg += 'DESC. ERRO:'+GetSOAPErrMsg() 
	EndIf
EndSub

Sub 'GetVeiculo'
	For Each Order EmpCod, VeiCod
		Where EmpCod = &EmpCod
		Where VeiCod = &VeiCod
		
		&VeiculosServiceGravarRequest.Veiculo.Placa   = substr(VeiPla,1,3)+substr(VeiPla,5,4)
		&VeiculosServiceGravarRequest.Veiculo.RNTRC   = val(VeiProRNTRC)
		&VeiculosServiceGravarRequest.Veiculo.AnoFabricacao = VeiAnoFab
		&VeiculosServiceGravarRequest.Veiculo.AnoModelo     = VeiAnoMod
		&VeiculosServiceGravarRequest.Veiculo.CapacidadeKg  = VeiCap
		&VeiculosServiceGravarRequest.Veiculo.CapacidadeM3  = VeiCapM3
		&VeiculosServiceGravarRequest.Veiculo.Chassi = VeiCha
		&VeiculosServiceGravarRequest.Veiculo.CodigoMunicipio =  VeiCidIbge
		&VeiculosServiceGravarRequest.Veiculo.Cor   = CorNom		
		&VeiculosServiceGravarRequest.Veiculo.Marca = VeiMarNom
		&VeiculosServiceGravarRequest.Veiculo.modelo = VeiMod
		&VeiculosServiceGravarRequest.Veiculo.NumeroDeEixos = VeiNroEixo		
		&VeiculosServiceGravarRequest.Veiculo.Renavam = val(Retornasonumeros.Udp(VeiRen))
		&VeiculosServiceGravarRequest.Veiculo.Tara    = VeiTar	
		Do case
			Case VeiTipCarr = VeiculoTipoCarroceria.Aberta
			 &VeiculosServiceGravarRequest.Veiculo.TipoCarroceria = VeiculosServiceTipoCarroceria.Aberta
			 Case VeiTipCarr = VeiculoTipoCarroceria.FechadaBau
			 &VeiculosServiceGravarRequest.Veiculo.TipoCarroceria = VeiculosServiceTipoCarroceria.FechadaOuBau
				
			Case VeiTipCarr = VeiculoTipoCarroceria.Graneleira
			 &VeiculosServiceGravarRequest.Veiculo.TipoCarroceria = VeiculosServiceTipoCarroceria.Granelera
				
			Case VeiTipCarr = VeiculoTipoCarroceria.NaoAplicavel
			 &VeiculosServiceGravarRequest.Veiculo.TipoCarroceria = VeiculosServiceTipoCarroceria.NaoAplicavel
				
			Case VeiTipCarr = VeiculoTipoCarroceria.PortaConteiner
			 &VeiculosServiceGravarRequest.Veiculo.TipoCarroceria = VeiculosServiceTipoCarroceria.PortaContainer
			Case VeiTipCarr = VeiculoTipoCarroceria.Sider
			 &VeiculosServiceGravarRequest.Veiculo.TipoCarroceria = VeiculosServiceTipoCarroceria.Sider
		EndCase
		
		
		//################################################################################################
		&VeiPesCod  = VeiProCod
		Do 'GetProprietario'
		exit
	EndFor
EndSub

Sub 'GetProprietario'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &VeiPesCod
		
		If PesStsEfr = Status_EFrete.Homologado
			&IsHomologado = True
		Else
			&IsHomologado = FALSE
		EndIF
		Exit
	When none
		&IsHomologado = FALSE
	EndFor
EndSub

Sub 'AtualizaVeiculo'
	For each Order EmpCod,VeiCod
		Where EmpCod = &EmpCod
		Where VeiCod = &VeiCod
		VeiStsEfr = Status_EFrete.Homologado
	Endfor
EndSub
]]></Source>
