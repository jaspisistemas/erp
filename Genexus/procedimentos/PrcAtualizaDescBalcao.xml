      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PEdCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpRegGUID.SetEmpty()
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	&LogErpRegCod1 = trim(Str(PedCod))
	&LogErpRegTip = TrnMode.Update
	if &LogErpTabIsLog = true
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVlrOut', trim(toformattedString(PedVlrOut)), trim(toformattedString(&PedVlrOut)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVlrDscGlb', trim(toformattedString(PedVlrDscGlb)), trim(toformattedString(&PedVlrDscGlb)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPerSpm1', trim(toformattedString(PedPerSpm1)), trim(toformattedString(&PedPerSpm1)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPerSpm2', trim(toformattedString(PedPerSpm2)), trim(toformattedString(&PedPerSpm2)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPerPrm1', trim(toformattedString(PedPerPrm1)), trim(toformattedString(&PedPerPrm1)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPerPrm2', trim(toformattedString(PedPerPrm2)), trim(toformattedString(&PedPerPrm2)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPerSrv1', trim(toformattedString(PedPerSrv1)), trim(toformattedString(&PedPerSrv1)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPerSrv2', trim(toformattedString(PedPerSrv2)), trim(toformattedString(&PedPerSrv2)), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	PedVlrOut = &PedVlrOut
	PedVlrDscGlb = &PedVlrDscGlb
	
	PedPerSpm1 = &PedPerSpm1
	PedPerSpm2 = &PedPerSpm2
	
	PedPerPrm1 = &PedPerPrm1
	PedPerPrm2 = &PedPerPrm2
	
	PedPerSrv1 = &PedPerSrv1
	PedPerSrv2 = &PedPerSrv2
	
	Exit
EndFor

Commit
AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')
]]></Source>
