      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SaidaLongVarchar = &SdtRetornoPDV.ToJson()
&LogGUID = GUID.NewGuid()

for Each order EmpCod, PdvCod
	Where EmpCod = &EmpCod
	Where PdvRandon = &PdvRandon //PRA SABER SE É UM PDV VALIDO
	
	Exit
When none
	Return
EndFor



Do CAse
	CAse &PesFonNum.IsEmpty()
		&SdtRetornoPDV.Codigo = 401
		&SdtRetornoPDV.Mensagem = 'TELEFONE NAO INFORMADO'
	Case &LinkCopiaCola.IsEmpty()
		&SdtRetornoPDV.Codigo = 400
		&SdtRetornoPDV.Mensagem = 'LINK INVALIDO'
		
	Otherwise
		//NAO PASSEI RESPONSAVEL, FALAR DIRETO COM A EMPRESA
		prcFilaEnvioWhats_EnviaCopiaCola.Call(&EmpCod, &FilCod, 0, &LinkCopiaCola, &PedVlrLiq, &PesFonNum, &WaGUID)
		
		&SdtRetornoPDV.Codigo = 1
		&SdtRetornoPDV.Mensagem = 'COPIA E COLA ENVIADO'
EndCase

&SaidaLongVarchar = &SdtRetornoPDV.ToJson()

Sub 'subException_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subException_handler','subException_handler')
	
EndSub

Sub 'subError_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subError_handler','subError_handler')
	
EndSub
]]></Source>
