      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TrsDtaEms = serverdate()

//Valida Existe Capa.
For Each Order EmpCod, (TrsCod)
	Where EmpCod = &EmpCod
	Where TrsSaiFilCod = &OriFilCod
	Where TrsEntFiLCod = &DestFilCod
	Where TrsDtaEms = &TrsDtaEms 
	Where TrsSts = Status_Pedido.FECHADO
	
	&OrigemPedCod = TrsSaiPedCod 
	&DestinoPedCod = TrsEntPedCod			
	&TrsCod = TrsCod
	
	Exit
When none
	
	RetornaConfSistema.Call(&EmpCod, &OriFilCod, domConfSistema.TCon048_TransDestinoProduto, &ValorConfiguracao)
	&DestinoLctCod = val(&ValorConfiguracao)
	
	RetornaConfSistema.Call(&EmpCod, &OriFilCod, domConfSistema.TCon047_TransOrigemProduto, &ValorConfiguracao)
	&OrigemLctCod = val(&ValorConfiguracao)
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &OriFilCod //CLIENTE DA FILIAL SAIDA
		&FilPesCod = FilPesCod
		&FilTabCod = FilTabCod
	EndFor

	UltimoCodigoEmpresa.Call(domParCod.TRANSPEDIDO, &EmpCod, 0, &TrsCod)
	New
		EmpCod = &EmpCod
		TrsCod = &TrsCod
		TrsDtaEms = &TrsDtaEms
		TrsSaiFilCod = &OriFilCod
		
		prcInsereCapaTransferencia.Call(&EmpCod, &OriFilCod, &TrsDtaEms, &OrigemLctCod, &FilPesCod, &FilTabCod, &OrigemPedCod)	
		TrsSaiPedCod = &OrigemPedCod
		
		TrsEntFiLCod = &DestFilCod
		
		prcInsereCapaTransferencia.Call(&EmpCod, &DestFilCod, &TrsDtaEms, &DestinoLctCod, &FilPesCod, &FilTabCod, &DestinoPedCod)	
		TrsEntPedCod = &DestinoPedCod
		
		TrsSts = Status_Pedido.FECHADO
	EndNew
	
	Commit
EndFor

//ja temos o codigo transferencia.
//Gravamos o Item
GravaTransfProduto.Call(&EmpCod, &TrsCod, 0, &OriProcod, &OriProGraCod, &PedQtd, &DestProCod, &DestProGraCod, &PedQtd, &newTrsItmCod)


//ja existe os pedidos. status: Fechado, 
//Gravamos Item no pedido Origem
&ProVlrCus = 0
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &OriProcod
	
	&ProVlrCus = ProVlrCus
	
	Exit
EndFor
PrcGravaItemTransferenciaPedido.Call(&EmpCod, &DestFilCod, &DestinoPedCod, &newTrsItmCod, &OriProcod, &OriProGraCod, &PedQtd, &ProVlrCus)
AtualizaTotaisPedido.Call(&EmpCod, &DestFilCod, &DestinoPedCod, &newTrsItmCod, 'I')

FechaEstoqueTransferenciaPorItem.Call(&EmpCod, &DestFilCod, &DestinoPedCod, Status_Pedido.FECHADO, &newTrsItmCod)

//ja existe os pedidos. status: Fechado, 
//Gravamos Item no pedido Destino
&ProVlrCus = 0
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &DestProCod
	
	&ProVlrCus = ProVlrCus
	
	Exit
EndFor
PrcGravaItemTransferenciaPedido.Call(&EmpCod, &OriFilCod, &OrigemPedCod, &newTrsItmCod, &DestProCod, &DestProGraCod, &PedQtd, &ProVlrCus)
AtualizaTotaisPedido.Call(&EmpCod, &OriFilCod, &OrigemPedCod, &newTrsItmCod, 'I')

FechaEstoqueTransferenciaPorItem.Call(&EmpCod, &OriFilCod, &OrigemPedCod, Status_Pedido.FECHADO, &newTrsItmCod)
//FechaTransferenciaProduto.Submit('wpFechaTrans', &ProgressId, &EmpCod, &FilCod, &Context.PesCod, &trsCod)



]]></Source>
