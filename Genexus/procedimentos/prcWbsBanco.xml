        <Source><![CDATA[
//&XMlWriter.Open('ppJASPI_BancossdtEstruturaBanco.xml')
//&XMlWriter.WriteRawText(&ppJASPI_BancossdtEstruturaBanco.ToXml())
//&XMlWriter.Close()

if &ppJASPI_BancossdtEstruturaBanco.Banco.BancoItems.Count > 0
	For &sdtBancos in &ppJASPI_BancossdtEstruturaBanco.Banco.BancoItems
		For Each Order BanCod 
			Where BanCod = &sdtBancos.BanCod
			BanNom = &sdtBancos.BanNom
			BanImg.FromURL(&sdtBancos.ImgBan_GXI)
			Exit
		When none
			new
				BanCod = &sdtBancos.BanCod
				BanNom = &sdtBancos.BanNom
				BanImg.FromURL(&sdtBancos.ImgBan_GXI)
				BanSts = Status_AtivoInativo.ATIVO
			EndNew
		EndFor
		
		Commit
	EndFor
	
EndIF

 
if &ppJASPI_BancossdtEstruturaBanco.Carteira.CarteiraItems.Count > 0
	For Each Order BanCod, BanCarNro
		Delete
	EndFor
	Commit 
	
	For &sdtCarteiras in  &ppJASPI_BancossdtEstruturaBanco.Carteira.CarteiraItems
		For Each Order BanCod, BanCarNro
			Where BanCod = &sdtCarteiras.BanCod
			Where BanCarNro = &sdtCarteiras.BanCarNro
			Exit
		When none
			new
				BanCod = &sdtCarteiras.BanCod
				BanCarNro = &sdtCarteiras.BanCarNro
			EndNew
		EndFor
	
		Commit
	EndFor
EndIF


if &ppJASPI_BancossdtEstruturaBanco.Retorno.RetornoItems.Count > 0
	For &sdtRetornos in  &ppJASPI_BancossdtEstruturaBanco.Retorno.RetornoItems
		For Each Order BanCod, EmpCod, RetBanCod
			Where EmpCod = &EmpCod
			Where BanCod = &sdtRetornos.BanCod
			Where RetBanCod = &sdtRetornos.RetBanCod
			Exit
		When none
			new
				BanCod = &sdtRetornos.BanCod
				EmpCod = &EmpCod
				RetBanCod = &sdtRetornos.RetBanCod
				RetBanNom = &sdtRetornos.RetBanNom
			EndNew
		EndFor
	
		Commit
		
		for &ppJASPI_BancossdtEstruturaRetornoItem in  &sdtRetornos.Ocorrencia.OcorrenciaItems
			For Each Order BanCod, EmpCod, RetBanCod
				Where BanCod = &sdtRetornos.BanCod
				Where EmpCod = &EmpCod
				Where RetBanCod = &sdtRetornos.RetBanCod
				Where RetMotCod = &ppJASPI_BancossdtEstruturaRetornoItem.RetBanOcoCod
				Exit
			When none
				new
					BanCod = &sdtRetornos.BanCod
					EmpCod = &EmpCod
					RetBanCod = &sdtRetornos.RetBanCod
					RetMotCod = &ppJASPI_BancossdtEstruturaRetornoItem.RetBanOcoCod
					RetMotNom = &ppJASPI_BancossdtEstruturaRetornoItem.RetBanOcoNom
				EndNew
			EndFor
			
			Commit
		EndFor
	EndFor
EndIF
]]></Source>
