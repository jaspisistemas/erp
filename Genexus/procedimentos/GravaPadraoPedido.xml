      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&padGrupItmCod = &ParpadGrupItmCod
if &OqueFAzer = 'DEL'
	For Each Order EmpCod, PadGrupCod, padGrupItmCod
		Where EmpCod = &EmpCod
		Where PadGrupCod = &PadGrupCod
		Where padGrupItmCod = &padGrupItmCod
		
		Delete
		
		Exit
	EndFor

	Commit
Else
	For Each Order EmpCod, PadGrupCod, padGrupItmCod
		Where EmpCod = &EmpCod
		Where PadGrupCod = &PadGrupCod
		Where padGrupItmCod = &padGrupItmCod
		
		PadGrupIsSel = &PadGrupIsSel
		PadGrupFilCod = &PadGrupFilCod
		PadGrupNfePesCod = &PadGrupNfePesCod
		PadGrupNfePesCpl = &PadGrupNfePesCpl
		PadGrupNfeVlr = &PadGrupNfeVlr
		Exit
	When none
		&padGrupItmCod = 0
		For Each Order EmpCod, PadGrupCod, (padGrupItmCod)
			Where EmpCod = &EmpCod
			Where PadGrupCod = &PadGrupCod
			&PadGrupItmCod = padGrupItmCod
			Exit
		EndFor
		&padGrupItmCod += 1
		
		NEw	
			EmpCod = &EmpCod
			PadGrupCod = &PadGruPCod
			padGrupItmCod = &padGrupItmCod
			PadGrupPesCod = &PadGrupPesCod
			PadGrupFilCod = &PadGrupFilCod
			PadGrupIsSel = &PadGrupIsSel
			PadGrupNfePesCod = &PadGrupNfePesCod
			PadGrupNfePesCpl = &PadGrupNfePesCpl
			PadGrupNfeVlr = &PadGrupNfeVlr
		EndNew
	EndFor
	
	Commit
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
