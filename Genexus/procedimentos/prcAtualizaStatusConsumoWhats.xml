      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, WaAnoMes, WaGuid
	where EmpCod = &EmpCod
	Where WaGuid = &WaGuid
	
	
	if &IsSucesso = true
		WaSts = 'S'
	Else
		WaSts = 'F'
		If WaIsConPlano = true
			&WaAnoMes = WaAnoMes
			do 'atualiza'
		EndIf
	EndIf	
EndFor

Commit


sub 'atualiza'
	For Each ORder EmpCod, WaAnoMes
		Where EmpCod = &EmpCod
		Where WaAnoMes = &WaAnoMes
		WaAnoMesQtd -= 1
		exit
	EndFor
EndSUb

]]></Source>
