      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//LOG da Tabela Completa TabelaPrecoAreas

&LogErpRegCod1 = trim(str(&PraCod))
&Tabela = 'PRAZOPARCELA'

For Each Order EmpCod, PraCod, PraParCod
	Where EmpCod = &EmpCod
	Where PraCod = &PraCod
	
	&LogErpRegCod2 = trim(str(PraParCod))
	
	&IsAchou = false
	For &sdtLogAtributosLevelItem in &sdtLogAtributosLevel
		if &sdtLogAtributosLevelItem.LvID = &LogErpRegCod2 and &sdtLogAtributosLevelItem.IsSts = 'N'
			&sdtLogAtributosLevelItem.IsSts = 'S'
			
			&LogErpRegTip = TrnMode.Update
			
			For &sdtLogAtributosLevelItemAtributo in &sdtLogAtributosLevelItem.Atributos
				Do Case
					Case &sdtLogAtributosLevelItemAtributo.Att = 'PraParCod'
						&LogErpRegItmNew = trim(PraParCod.ToFormattedString())
						prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1,&LogErpRegCod2,'', &Tabela, &ObjetoGeradorLog, &wwpContextUserName, &sdtLogAtributosLevelItemAtributo.Att, &sdtLogAtributosLevelItemAtributo.Old, &LogErpRegItmNew, &LogErpRegGUID )
					Case &sdtLogAtributosLevelItemAtributo.Att = 'PraParNom'
						&LogErpRegItmNew = trim(PraParNom)
						prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1,&LogErpRegCod2,'', &Tabela, &ObjetoGeradorLog, &wwpContextUserName, &sdtLogAtributosLevelItemAtributo.Att, &sdtLogAtributosLevelItemAtributo.Old, &LogErpRegItmNew, &LogErpRegGUID )
				EndCase
			EndFor
			
			&IsAchou = true
			Exit
		Endif
	EndFor
	
	if &IsAchou = false
		&LogErpRegTip = TrnMode.Insert
		
		&LogErpRegItmNew = trim(toformattedString(PraParCod))
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1,&LogErpRegCod2,'', &Tabela, &ObjetoGeradorLog, &wwpContextUserName, 'PraParCod', '', &LogErpRegItmNew, &LogErpRegGUID )
		
		&LogErpRegItmNew = trim(toformattedString(PraParNom))
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1,&LogErpRegCod2,'', &Tabela, &ObjetoGeradorLog, &wwpContextUserName, 'PraParNom', '', &LogErpRegItmNew, &LogErpRegGUID )
	Endif
	
	&IsAchou = false
	&LogErpRegGUID.SetEmpty()	
EndFor

&LogErpRegItmNew = ''
//DELETA
For &sdtLogAtributosLevelItem in &sdtLogAtributosLevel
	if &sdtLogAtributosLevelItem.LvID <> '0' and &sdtLogAtributosLevelItem.IsSts = 'N'
		&LogErpRegCod2 = &sdtLogAtributosLevelItem.LvID
		&LogErpRegTip = TrnMode.Delete
		&LogErpRegItmNew = ''
		For &sdtLogAtributosLevelItemAtributo in &sdtLogAtributosLevelItem.Atributos
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1,&LogErpRegCod2,'', &Tabela, &ObjetoGeradorLog, &wwpContextUserName, &sdtLogAtributosLevelItemAtributo.Att, &sdtLogAtributosLevelItemAtributo.Old, &LogErpRegItmNew, &LogErpRegGUID )
		EndFor		
		&LogErpRegGUID.SetEmpty()
	Endif
EndFor
]]></Source>
