      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[




Do Case
	cAse &OqueFazer = 'A' //REMOVE TUDO
		
		//remove Apontamentos
		For Each Order EmpCod,AptDtaLct,AptCod,AptEtpCod
			Where EmpCod = &EmpCod
			Where AptEtpCod = &GrupCTrOrd
			Where AptProGrupCod = &GrupCod
			delete
		EndFor
		
		commit
		
		//removeetapa
		For each Order EmpCod,GrupCod,GrupCTrOrd
			Where EmpCod = &EmpCod
			Where GrupCod = &GrupCod
			Where GrupCTrOrd = &GrupCTrOrd
			delete
		EndFor
		
		commit
		
	Case &OqueFazer = 'B' //Altera apontamentos
		//Alterar Apontamentos
		For Each Order EmpCod,AptDtaLct,AptCod,AptEtpCod
			Where EmpCod = &EmpCod
			Where AptEtpCod = &GrupCTrOrd
			Where AptProGrupCod = &GrupCod
			AptEtpCod = &NovoGrupCTrOrd
		EndFor
		
		commit
		
		//removeetapa
		For each Order EmpCod,GrupCod,GrupCTrOrd
			Where EmpCod = &EmpCod
			Where GrupCod = &GrupCod
			Where GrupCTrOrd = &GrupCTrOrd
			delete
		EndFor
		
		commit
EndCase

	
]]></Source>
