      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For &sdtMovimentoItem in &sdtMovimento
	For each Order EmpCod,MovCod,MovCtaBanCod
		Where EmpCod = &sdtMovimentoItem.EmpCod
		Where MovCod = &sdtMovimentoItem.MovCod
		Where MovCtaBanCod = &sdtMovimentoItem.MovCtaBanCod
		
		MovDtaCon = &MovDtaCon 
		AtualizaSaldoConta.Call(TrnMode.Insert,EmpCod,MovCtaBanCod,&MovDtaCon,MovCreDeb,MovVlr,&DataVazia,0,'')
		exit
	EndFor

EndFor
]]></Source>
