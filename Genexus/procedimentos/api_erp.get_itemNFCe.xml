      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

//&PadObs = format('nfe:%1,fil:%2,Ref:%3, itm:%4', trim(toformattedString(&NfeCod)), trim(toformattedString(&FilCod)), &ProRef, trim(toformattedString(&NfeItmCod)))
//padraousuario.Call('G', 'set_cliente', 1, 1, &PadObs, &PadDtaMod)
//padraousuario.Call('G', 'set_cliente1', 1, 1, &sdtItemNfeLongVarchar, &PadDtaMod)
	
if &IsAcessoConcedido = true
	&ProRef = &parProRef
	
	if &NfeItmCod > 0
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &wwpContext.EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeItmCod = &NfeItmCod
			&ProRef = NfeProGraRef
			Exit
		When none
			&sdtItemNfe.sts = 'E001'
			&sdtItemNfe.obs = 'Item da Nota não localizado!'
			Return
		EndFor		
	Endif

	&sdtItemNfe.NfeCod = &NfeCod
	&sdtItemNfe.FilCod = &FilCod
	&sdtItemNfe.nfeItmCod = &NfeItmCod
		
	RetornaProdutoReferencia.Call(&wwpContext.EmpCod, &ProRef, &NfeProCod, &NfeProGraCod, &NfeProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &erroMensagem)
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod	
		
		&FilTabCod = FilTabCod
		if FilBasImp = 0
			&FilBasImp = FilCod
		Else
			&FilBasImp = FilBasImp
		EndIF
		
		&NfeSts = NfeSts
		RetornaRegimeTributarioFilial.Call(EmpCod, &FilBasImp, &FilRegTrib, &CImpOriUfeCod)
		
		&PedCliCidUfeCod = NfeCliCidUF
		&LctBasImpCod = NfeLctBasImp
		&NfeCliCod = NfeCliCod
		
		Exit
	When none
		&sdtItemNfe.sts = 'E001'
		&sdtItemNfe.obs = 'Nota não localizada!'
		Return
	EndFor

	&DataHoje = serverdate()
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &wwpContext.EmpCod
		Where ProCod = &NfeProCod
		Where ProGraCod = &NfeProGraCod
		
		//CODIGO DE BARRAS
		&NfeProBar = ''
		&AuxMensagem = ''
		&Varchar = Substr(trim(ProGraBar), 1, 3)
		if &Varchar <> '333' and not &Varchar.IsEmpty()
			ValidaEAN13.Call(ProCod, ProGraBar, &NfeProBar, &AuxMensagem)
		Else
			&AuxMensagem = 'invalido'
		EndiF
		
		if not &AuxMensagem.IsEmpty()
			&sdtItemNfe.ProBar = &NfeProBar
		Else
			if not ProBarTrib.IsEmpty() and not ProBarTrib.IsNull()
				&sdtItemNfe.ProBar = &NfeProBar
				&sdtItemNfe.ProBarTrib = ProBarTrib
			Else
				&sdtItemNfe.ProBar = &NfeProBar
				&sdtItemNfe.ProBarTrib = &NfeProBar				
			Endif		
		EndIF
	
		&sdtItemNfe.ProCod = ProCod
		
		&sdtItemNfe.ProRef = ProGraRef
		
		if ProNomNF.IsEmpty() or ProNomNF.IsNull()
			&sdtItemNfe.ProNom = ProNomGra
		Else
			&sdtItemNfe.ProNom = ProNomNF
			IF ProGraCod > 1
				&sdtItemNfe.ProNom += ' | ' +trim(ProGraNom)
			Endif
		Endif
	
		&sdtItemNfe.NfeProDadAdi = ProDetNfe
		&sdtItemNfe.NfeEmbUnd = ProEmbUnd
		If not ProUndTrib.IsEmpty() and not ProUndTrib.IsNull()
			&sdtItemNfe.NfeEmbUndTrib = ProUndTrib
		Else
			&sdtItemNfe.NfeEmbUndTrib = ProEmbUndTrib
		Endif
	
		&sdtItemNfe.NfeNcmCod = NcmCod
		&sdtItemNfe.NfeNcmCest = trim(Str(ProNcmCest))
		&sdtItemNfe.ProCatCod = ProCatCod
		&sdtItemNfe.ProOriTriCod = ProOriTriCod
		
		&sdtItemNfe.ProObrAnp = Status_simNao.Sim
			
		RetornaPrecoUnitarioVenda.Call(EmpCod, &FilTabCod, '', ProCod,  ProGraCod, 1, &DataHoje, &PedDtaVct, &NfeProVlrUnt)
		&sdtItemNfe.NfeProVlrUnt = &NfeProVlrUnt
		&Moeda5 = &NfeProVlrUnt
		&sdtItemNfe.NfeProVlrUntVar = RetiraZerosDepoisVirgulaxCasas.Udp(2, &Moeda5.ToFormattedString())
		&sdtItemNfe.NfeProVlrUntVar = &sdtItemNfe.NfeProVlrUntVar.Replace(',','.')
		
		&ProCatCod = ProCatCod
				
		Exit
	When none
		If not &ProRef.IsEmpty()
			&sdtItemNfe.sts = 'E002'
			&sdtItemNfe.obs = 'Produto não localizado!'
			Return
		Endif	
	EndFor
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &wwpContext.EmpCod
		Where PesCod = &NfeCliCod
		&PedCliGruImpCod = PesGruImpCod
		Exit
	When none
		&PedCliGruImpCod = 1
	EndFor

	do 'tabImposto'
	
	if &NfeItmCod <> 0
		do 'loadItemNFe'
	EndiF	
	
	&sdtItemNfe.sts = 'J200'
	&sdtItemNfe.obs = 'sucesso'
Endif



Sub 'tabImposto'

	&sdtItemNfe.NfeCfoCod = ''
	&sdtItemNfe.NfeSitCod = ''
	&sdtItemNfe.NfeProCBenef = ''
	
	For Each Order EmpCod,CImpTbFilCod,CImpLctCod,CImpOriUfeCod,CImpDstUfeCod,CImpGruImpCod,CImpCatCod,(CImpDtaIni)
		Where EmpCod = &wwpContext.EmpCod
		Where CImpTbFilCod = &FilBasImp
		Where CImpLctCod = &LctBasImpCod
		Where CImpOriUfeCod = &CImpOriUfeCod
		Where CImpDstUfeCod = &PedCliCidUfeCod
		Where CImpGruImpCod = &PedCliGruImpCod
		Where CImpCatCod = &ProCatCod
		Where CImpDtaIni <= serverdate()
		
		&sdtItemNfe.NfeSitCod = trim(CImpCstCod.ToFormattedString())
		&sdtItemNfe.NfeCfoCod = CImpCfoCod
		&sdtItemNfe.NfeProCBenef = CImpCBenef
		
		Exit
	EndFor

EndSub


Sub 'loadItemNFe'

	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeItmCod = &NfeItmCod
		
		&sdtItemNfe.NfeProDadAdi = NfeProDadAdi
		&sdtItemNfe.ProNom = NfeProNom
		
		&sdtItemNfe.NfeProQtd = NfeProQtd
		
		&Moeda6 = NfeProQtd
		&sdtItemNfe.NfeProQtdVar = RetiraZerosDepoisVirgulaxCasas.Udp(0, &Moeda6.ToFormattedString())
		&sdtItemNfe.NfeProQtdVar = &sdtItemNfe.NfeProQtdVar.Replace(',','.')
		
		&sdtItemNfe.NfeProVlrUnt = NfeProVlrUnt
		&Moeda5 = NfeProVlrUnt
		&sdtItemNfe.NfeProVlrUntVar = RetiraZerosDepoisVirgulaxCasas.Udp(2, &Moeda5.ToFormattedString())
		&sdtItemNfe.NfeProVlrUntVar = &sdtItemNfe.NfeProVlrUntVar.Replace(',','.')
		
		&sdtItemNfe.NfeProVlrTot = NfeProVlrTot
		&Moeda2 = NfeProVlrTot
		&sdtItemNfe.NfeProVlrTotVar = RetiraZerosDepoisVirgulaxCasas.Udp(2, &Moeda2.ToFormattedString())
		&sdtItemNfe.NfeProVlrTotVar = &sdtItemNfe.NfeProVlrTotVar.Replace(',','.')
		
		&sdtItemNfe.NfeNcmCod = NfeNcmCod
		&sdtItemNfe.NfeCfoCod = NfeCfoCod
		&sdtItemNfe.NfeSitCod = NfeSitCod
		 
		
		&sdtItemNfe.NfeEmbUnd = NfeEmbUnd
		&sdtItemNfe.NfeEmbUndTrib = NfeEmbUndTrib
	
//		&NfeProTaxIcmsSt = NfeProTaxIcmsSt
//		&NfeProTaxIpi = NfeProTaxIpi
//		&NfeProTaxIcms = NfeProTaxIcms
//		&NfeProTaxPIS = NfeProTaxPIS
//		&NfeProTaxCofins = NfeProTaxCofins
		
		&sdtItemNfe.NfeProCBenef = NfeProCBenef
	
		&sdtItemNfe.ProBar = NfeProBar
		&sdtItemNfe.ProBarTrib = NfeProBarTrib
				
		
		Exit
	EndFor

EndSub
]]></Source>
