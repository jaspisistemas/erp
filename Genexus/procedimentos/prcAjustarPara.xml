      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each ORder EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&Diferenca = 0
	if &AjustarPara > 0
		&Diferenca = (PedVlrLiq + PedVlrDscGlb) - &AjustarPara
		if &Diferenca <= 0
			&Diferenca = 0		
		Endif
	Endif
	
	prcAtualizaDescBalcao.Call(&EmpCod, &FilCod, &PedCod, &Diferenca,PedPerSpm1,PedPerSpm2,PedPerPrm1,PedPerPrm2,PedVlrOut,PedPerSrv1,PedPerSrv2, &wwpContextUserName)
	Exit
EndFor
]]></Source>
