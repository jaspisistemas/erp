<Object parentGuid="2029c88d-bc03-4d0a-89d8-cf9907782d43" user="WINJEAN\jeanfae" versionDate="2025-04-15T20:14:23.0000000Z" lastUpdate="2025-04-15T16:38:21.0000000Z" checksum="451d25abada06a93a72a8cb5786fbe4b" fullyQualifiedName="api_erp.set_transferencia" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="017cd662-3e60-4492-b332-c670f07a3830" name="set_transferencia" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="set_transferencia" parent="api_erp.Financeiro" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	&LogGUID = GUID.NewGuid()
	
	timestampToDate.Call(&sdtMovimento.movDtaPgtTmp, &movDtaPgt)
		
	PrcValidaCaixaAberto.Call(&wwpContext.EmpCod, &sdtMovimento.movCtaBanCod, &movDtaPgt, &IsCaixaFechado, &Mensagem)
	if &IsCaixaFechado = false
		PrcValidaCaixaAberto.Call(&wwpContext.EmpCod, &sdtMovimento.destCtaBanCod, &movDtaPgt, &IsCaixaFechado, &Mensagem)
	Endif

	&MovVlr.FromString(&sdtMovimento.movVlr)
	Do Case
		Case &IsCaixaFechado = true
			&sdtRetornoWbsEtc.sts = 'E997'
			&sdtRetornoWbsEtc.obs = &Mensagem
			return
		Case &sdtMovimento.MovCtaBanCod.IsEmpty()
			&sdtRetornoWbsEtc.sts = 'E996'
			&sdtRetornoWbsEtc.obs = 'Conta bancária ORIGEM não informada!'
			return
		Case &sdtMovimento.destCtaBanCod.IsEmpty()
			&sdtRetornoWbsEtc.sts = 'E996'
			&sdtRetornoWbsEtc.obs = 'Conta bancária DESTINO não informada!'
			return
		case &movDtaPgt.IsEmpty()
			&sdtRetornoWbsEtc.sts = 'E995'
			&sdtRetornoWbsEtc.obs = 'Data de Pagamento não informado!'
			return
		case &movVlr = 0
			&sdtRetornoWbsEtc.sts = 'E994'
			&sdtRetornoWbsEtc.obs = 'Lançamento zerado!'
			return
		Otherwise
		
			
			Transferencia.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtMovimento.movCtaBanCod, &SdtMovimento.destCtaBanCod, &sdtMovimento.movDoc, &MovVlr, &movDtaPgt, &sdtMovimento.movDoc, &SdtMovimento.movCplMan, '', &erro)
			If &erro = 1
				&sdtRetornoWbsEtc.sts = 'E992'
				&sdtRetornoWbsEtc.obs = 'ATENÇÃO, A  chave do lançamento já existe, não possível gravar o lançamento! verifique os parâmetros, ou contate a equipe jaspi!'
				return
			Else
			
				&sdtRetornoWbsEtc.sts = 'J200'
				&sdtRetornoWbsEtc.obs = 'Transferência realizada'
				return
			EndIf
	EndCase
	
EndIf


Sub 'Exception_handler'
	&sdtRetornowbs.Sts = 'XX99'
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXexceptionType',&GXexceptionType)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionDetails',&GXExceptionDetails)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionStack',&GXExceptionStack)
	
Endsub

Sub 'Error_handler'
	&sdtRetornowbs.Sts = 'XX99'
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &Err',&Err.ToFormattedString())
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBErr',&gxDBErr.ToFormattedString())
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &GxDbSqlState',&GxDbSqlState)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBTxt',&gxDBTxt)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxOper',&gxOper)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrTbl',&gxErrTbl)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrOpt',&gxErrOpt.ToFormattedString())
Endsub
]]></Source>
