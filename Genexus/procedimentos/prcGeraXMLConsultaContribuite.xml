      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)					//## Retorna o caminho dos diretórios da Empresa/Filial informada ##\\

&SoNumeroCNPJ = RetornaSoNumeros.Udp(&PesCnpj)
&SoNumeroCPF = RetornaSoNumeros.Udp(&PesCPF)

&NomeRetArquivo = &SdtConfiguracoesPasta.PastaNFretorno+&SoNumeroCNPJ+'-ret-cons-cad.xml'
&File.Source = &NomeRetArquivo
If &File.Exists()																			//## Se o arquivo existir, o mesmo é excluido ##\\
    &File.Delete()
EndIf

&NomeArquivo = &SdtConfiguracoesPasta.PastaNFenvio+Trim(&SoNumeroCNPJ)+'-cons-cad.xml'

&XMLWriter.Open(&NomeArquivo)																//## Abre o arquivo ##\\
&XMLWriter.WriteStartDocument('utf-8')														//## Define o encoding do arquivo ##\\

&XMLWriter.WriteStartElement('ConsCad')

	&XMLWriter.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')					//## Define um atributo ao elemento composto acima ##\\
	&XMLWriter.WriteAttribute('versao','2.00')												//## Define um atributo ao elemento composto acima ##\\

		&XMLWriter.WriteStartElement('infCons')
		
			&XMLWriter.WriteElement('xServ','CONS-CAD') 
			
			&XMLWriter.WriteElement('UF',&PesCidUfeCod)
			&XMLWriter.WriteElement('CNPJ',&SoNumeroCNPJ)
			&XMLWriter.WriteEndElement()
			&XMLWriter.WriteEndElement()
			&XMLWriter.WriteEndElement()
		
		&XMLWriter.WriteEndElement()

&XMLWriter.WriteEndElement()
&XMLWriter.Close()																			//## Fecha o arquivo ##\\
]]></Source>
