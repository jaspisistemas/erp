      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&GrupCod.SetEmpty()
&GrupCodNom.SetEmpty()

For Each Order EmpCod, GrupAnaSin, GrupHiePadL
	Where EmpCod = &EmpCod
	Where GrupAnaSin = 'A' when &AuxGrupCod.IsEmpty()
	where GrupCod = &AuxGrupCod when not &AuxGrupCod.IsEmpty()
	&GrupCod = GrupCod
	&GrupCodNom = GrupCodNom
	Exit
EndFor
]]></Source>
