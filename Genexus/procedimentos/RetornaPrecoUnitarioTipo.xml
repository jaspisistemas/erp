      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedItmPrm = domPedItmPrm.DESCONTO


	
For Each Order EmpCod, TabCod, TabColCod, ProCod, ProGraCod, (TabAltCod)
	Where EmpCod = &EmpCod
	Where TabCod = &TabPrmCod //TABELA PROMOCAO
	 //Where TabSts = StatusTabela.Promocao
	Where ProCod = &ProCod
	Where TabColCod = &TabColCod
	Where ProGraCod = &ProGraCod
	Where (TabDtaIni <= &PedDtaEms or TabDtaIni.IsEmpty()) and (TabDtaFin >= &PedDtaEms or TabDtaFin.IsEmpty())
	Where (TabProDtaIni <= &PedDtaEms or TabProDtaIni.IsEmpty()) and (TabProDtaFin >= &PedDtaEms or TabProDtaFin.IsEmpty())
	Where TabPrc1 > 0 when &TabColCod = 1
	Where TabPrc2 > 0 when &TabColCod = 2
	Where TabPrc3 > 0 when &TabColCod = 3
	Where TabPrc4 > 0 when &TabColCod = 4
	Where TabPrc5 > 0 when &TabColCod = 5
	Where TabPrc6 > 0 when &TabColCod = 6
	Where TabPrc7 > 0 when &TabColCod = 7
	Where TabPrc8 > 0 when &TabColCod = 8
	Where TabPrc9 > 0 when &TabColCod = 9
	
	&PedItmPrm = domPedItmPrm.PROMOCAO
	Exit	
When None
	If &PedItmDsc.IsEmpty()	//SE NAO TEM DESCONTO FAZ ISSO
		&PedItmPrm = domPedItmPrm.NORMAL 
	Endif
	//POR MAIS QUE TENHA DESCONTO MAS É PROMOCAO< MANTER COMO PROMOCAO --JDF
EndFor
	
//Else //COMENTEI PORQUE NAO EH PARA SOMAR NO TOTAL NORMAL
	//	If &PedItmDsc < 0
	//		&PedItmPrm = PedItmPrm.NORMAL
	//	EndIF
//EndIf
]]></Source>
