        <Source><![CDATA[
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	if FilTConCod.IsEmpty() or FilTConCod.IsNull()
		FilTConCod = 1
		&TConCod = 1
		commit
	Else
		&TConCod = FilTConCod
	EndIF	
	
	Exit
EndFor

&sdtConfig_wwpVendas_3 = new()

For Each Order EmpCod, TConCod
	Where EmpCod = &EmpCod
	Where TConCod = &TConCod
	
	&sdtConfSistema_CadastroProduto.TCon032_MargemPadraoProduto = TCon032.ToString()
	&sdtConfSistema_CadastroProduto.TCon065_BloquearAlteracaoCodigo = TCon065.ToString()
	&sdtConfSistema_CadastroProduto.TCon078_UtilizarCodOrigem = TCon078.ToString()
	&sdtConfSistema_CadastroProduto.TCon083_Markup = TCon083.ToString()
	&sdtConfSistema_CadastroProduto.TCon097_ExibeTipoProduto = TCon097.ToString()
	
	if TCon108.IsEmpty() or TCon108.IsNull()
		&sdtConfSistema_CadastroProduto.TCon108_CasasDecimais = 2
	Else
		&sdtConfSistema_CadastroProduto.TCon108_CasasDecimais = val(TCon108)
	Endif

	
	&sdtConfSistema_CadastroProduto.TCon119_DestacaObrigacaoNFPe = TCon119.ToString()
	&sdtConfSistema_CadastroProduto.TCon125_AddComplementoProduto = TCon125.ToString()
	&sdtConfSistema_CadastroProduto.TCon130_MostrarTabelaPreco = TCon130.ToString()
	&sdtConfSistema_CadastroProduto.TCon148_ControleLote = TCon148.ToString()
	&sdtConfSistema_CadastroProduto.TCon157_SolicitaTecnicoResponsavel = TCon157.ToString()
	
	&sdtConfSistema_CadastroProduto.TCon164_DescricaoExtras = TCon164.ToString()
	
	Exit
EndFor

]]></Source>
