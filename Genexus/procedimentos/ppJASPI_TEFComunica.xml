      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Versao 	= 1 //VERSAO IDEAL DO APLICATIVO

&AuxLongVarchar = &ParamentroEntrada
//&AuxLongVarchar = &AuxLongVarchar.Replace('&lt;', '<')
//&AuxLongVarchar = &AuxLongVarchar.Replace('&gt;', '>')

&SdtJaspiComunicador.FromJson(&AuxLongVarchar)
&OutsdtJaspiImpressao_out = &SdtJaspiComunicador

&EmpCodSec 	= &SdtJaspiComunicador.EmpCodSec

if &SdtJaspiComunicador.EmpImpVer <> &Versao
	&OutsdtJaspiImpressao_out.EmpStsMsg = 'ERRO DE VERSAO, NECESSARIO UTILIZACAO VERSAO: ' + trim(str(&Versao))
	&OutsdtJaspiImpressao_out.EmpImpVer = &Versao
	
	For each Order EmpCodSec
		Where EmpCodSec = &EmpCodSec
		&EmpCod = EmpCod
		&OutsdtJaspiImpressao_out.EmpWebBaseUrl = EmpDirVir + 'appjaspi/app/JASPI_TEF'+trim(str(&Versao)) + '.rar'
		Exit 
	When none
		&OutsdtJaspiImpressao_out.EmpStsMsg = 'ERRO DE EMPRESA, NAO LOCALIZADA'
	EndFor
	
	return
Else
	For each Order EmpCodSec
		Where EmpCodSec = &EmpCodSec
		&EmpCod = EmpCod
		&OutsdtJaspiImpressao_out.EmpStsMsg = EmpRaz
		Exit 
	When none
		&OutsdtJaspiImpressao_out.EmpStsMsg = 'ERRO DE EMPRESA, NAO LOCALIZADA'
		return
	EndFor
Endif

&OutsdtJaspiImpressao_out.EmpImpVer = &Versao

Do CAse
	Case &OqueFazer = 'VERSAO'
		
	Case &OqueFazer = 'PENDENTE'
		
		&OutsdtJaspiImpressao_out.BanCarTefCOM = ''
		&OutsdtJaspiImpressao_out.FilZoopKey = ''
		
		For Each ORder EmpCod, (TefCod)
			Where EmpCod = &EmpCod
			
			&TefCod = TefCod
			&FilCod = TefFilCod
			do 'getFilial'
			
			&TefBanCarCod = TefBanCarCod
			do 'getbandeira'
			
			if TefSts = 'P' //PENDENTE
				&IsJaSolicitado = false
				For Each Order EmpCod, TefCod, TefItmID
					&IsJaSolicitado = true
					Exit
				EndFor
				
				if &IsJaSolicitado = false
					&OutsdtJaspiImpressao_out.TefVlr = TefVlr
					&OutsdtJaspiImpressao_out.TefSolID = padl(trim(str(EmpCod)), 9, '0') + padl(trim(str(TefCod)), 9, '0')
					&OutsdtJaspiImpressao_out.TefCreDebVou = TefCreDebVou
					&TefMsg = 'ATENDENDO SOLICITACAO'
					do 'GravaItemObs'
				Endif
			Else
				&OutsdtJaspiImpressao_out.EmpStsMsg = 'NADA A FAZER, VAI DORMIR'
			Endif
			
			Exit
		EndFor	
EndCase

&ParamentroSaida = &OutsdtJaspiImpressao_out.ToJson()

Sub 'getbandeira'
	For Each Order EmpCod, BanCarCod
		Where EmpCod = &EmpCod
		Where BanCarCod = &TefBanCarCod
		&OutsdtJaspiImpressao_out.BanCarTefCOM = BanCarTefCOM
		Exit
	EndFor
EndSub

Sub 'GetFilial'
	//TABELA FILIAL
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		&OutsdtJaspiImpressao_out.FilZoopKey = FilZoopKey
		Exit
	EndFor
EndSub

sub 'GravaItemObs'
	&TefItmID = 0
	For Each Order EmpCod, TefCod, (TefItmID)
		Where EmpCod = &EmPCod
		Where TefCod = &TefCod
		&TefItmID = TefItmID
		Exit
	EndFor
	&TefItmID  += 1
	
	new
		EmpCod = &EmPCod
		TefCod = &TefCod
		TefItmID = &TefItmID
		TefMsg = &TefMsg
		TefItmSts = &TEfSts
		TefItmDtaHor = serverNow()
		TefItmStsSyncServ = 'N'
	endnew
	Commit
EndSub
]]></Source>
