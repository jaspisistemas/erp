      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedItmCod.SetEmpty()

For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where PedQtd > 0
	Where PedItmCodRef.IsEmpty() or PedItmCodRef.IsNull() or PedItmCodRef = PedItmCod
	
	&PedItmCod = PedItmCod
	
	Exit
EndFor
]]></Source>
