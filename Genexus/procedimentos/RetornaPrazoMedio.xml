      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PrzMed = 0
&TotDia = 0

Do While &Posicao <= 300
    &PosIni  = ((&Posicao * 4) + 1)
    &Dias = val(substr(&PrzPar,&PosIni,3))
	
    if &Dias > 0
        &Parcela += 1
        &TotDia += &Dias
    endif

    &Posicao+= 1
EndDo

if &Parcela <> 0 and &TotDia <> 0 
    &PrzMed = &TotDia / &Parcela
Endif
]]></Source>
