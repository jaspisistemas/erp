      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PEsCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PESSOA'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(PesCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesEnvSpc', trim(toformattedString(PesEnvSpc)), trim(toformattedString(&PesEnvSpc)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesResSpc', trim(toformattedString(PesResSpc)), trim(toformattedString(&PesResSpc)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesResChe', trim(PesResChe.ToString()), trim(&PesResChe.ToString()), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesDtaCon', trim(PesDtaCon.toformattedString()), trim(&PesDtaCon.toformattedString()), &LogErpRegGUID )
		
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesProAtv', trim(PesProAtv.ToString()), trim(&PesProAtv.ToString()), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesPrtQtd', trim(PesPrtQtd.ToString()), trim(&PesPrtQtd.ToString()), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesPrtVlr', trim(PesPrtVlr.toformattedString()), trim(&PesPrtVlr.toformattedString()), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	PesEnvSpc = &PesEnvSpc
	PesResSpc = &PesResSpc
	PesResChe = &PesResChe
	PesDtaCon  = &PesDtaCon 
	
	//PROTESTO
	PesProAtv = &PesProAtv
	PesPrtQtd = &PesPrtQtd
	PesPrtVlr = &PesPrtVlr
	
	Exit
EndFor

Commit
	
]]></Source>
