      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, TabCod, ProCod, ProGraCod, (TabAltCod)
    Where EmpCod = &EmpCod
	Where TabCod = &TabNum
    Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGraCod > 1
	Where TabAltCod = &TabAltCod
	
	TabDtaVct = &TabDtaVct
	Exit
EndFor

commit
]]></Source>
