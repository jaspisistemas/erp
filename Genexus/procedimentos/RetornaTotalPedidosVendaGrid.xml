      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&FinMedioMoeda = 0
&medioMoeda = 0
&PedidoMoeda = 0
&QtdPedidos = 0
&FinQtdPedido = 0
&FinPedidoMoeda = 0
For Each 
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod or &PedCod = 0
	Where (PedSts = &PedSts or (&PedSts.IsEmpty() and PedSts <> Status_Pedido.CANCELADO))
	Where (PedStsFin = &PedStsFin or &PedStsFin.IsEmpty())
	Where (PedCliCod = &PedCliCod or &PedCliCod.IsEmpty()) 
	Where (PedStsCrd = &PedStsCrd or &PedStsCrd.IsEmpty()) 
	Where (PedDtaEms >= &PedDtaEms or &PedDtaEms.IsEmpty())
	Where (PedDtaEms <= &PedDtaEms_To or &PedDtaEms_To.IsEmpty()) 
	Where LctTip = TipoLancamento.OrcamentoVenda or LctTip = TipoLancamento.SaidaMercadoria when &CompraVenda = 'V'
	Where LctTip = TipoLancamento.OrcamentoCompra or LctTip = TipoLancamento.EntradaMercadoria when &CompraVenda = 'C'
	Where LctAtuSal = Status_EntradaSaida.Saida when &CompraVenda = 'V'
	Where LctAtuSal = Status_EntradaSaida.Entrada when &CompraVenda = 'C'
	Where PedBlq = Status_SimNao.Nao
	Where (PedDtaFat >= &PedDtaFat or &PedDtaFat.IsEmpty()) 
	Where (PedDtaFat <= &PedDtaFat_To or &PedDtaFat_To.IsEmpty()) 
	Where (LctCod =&LctCod or &LctCod.IsEmpty()) 
	Where PedVenCod = &PedVenCod or &PedVenCod.IsEmpty()
	
	&QtdPedidos += 1
	&PedidoMoeda += PedVlrLiq
	if LctGerFin = Status_SimNao.Sim
		&FinQtdPedido += 1
		&FinPedidoMoeda += PedVlrLiq
	EndIF
	
	if PedFatFilCod.IsEmpty() or PedFatFilCod.IsNull()
		&CollQtdPedidos(FilCod) += 1
		&CollPedidoMoeda(FilCod) += PedVlrLiq
	
		if LctGerFin = Status_SimNao.Sim
			&FinCollQtdPedido(FilCod) += 1
			&FinCollPedidoMoeda(FilCod) += PedVlrLiq
		EndIF
	
	Else
		&CollQtdPedidos(PedFatFilCod) += 1
		&CollPedidoMoeda(PedFatFilCod) += PedVlrLiq
	
		if LctGerFin = Status_SimNao.Sim
			&FinCollQtdPedido(PedFatFilCod) += 1
			&FinCollPedidoMoeda(PedFatFilCod) += PedVlrLiq
		EndIF
	Endif
			
EndFor

if &PedidoMoeda > 0 and &QtdPedidos > 0
	&medioMoeda = (&PedidoMoeda / &QtdPedidos)
EndIF

if &FinQtdPedido > 0 and &FinPedidoMoeda > 0
	&FinMedioMoeda = (&FinPedidoMoeda / &FinQtdPedido)
EndIF


For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	
	&Count += 1
	
	&sdtTotalPedidosItem = new()
	&sdtTotalPedidosItem.FilCod = FilCod
	&sdtTotalPedidosItem.FilCodNom = FilCodNom
	
	&sdtTotalPedidosItem.PedVlrFinMed = 0
	if &FinCollQtdPedido(FilCod) > 0 and &FinCollPedidoMoeda(FilCod) > 0
		&sdtTotalPedidosItem.PedVlrFinMed = (&FinCollPedidoMoeda(FilCod) / &FinCollQtdPedido(FilCod))
	EndIF
	&sdtTotalPedidosItem.PedVlrFinQtd = &FinCollQtdPedido(FilCod)
	&sdtTotalPedidosItem.PedVlrFinTot = &FinCollPedidoMoeda(FilCod)
	
	&sdtTotalPedidosItem.PedVlrTotMed = 0
	if &CollQtdPedidos(FilCod) > 0 and &CollPedidoMoeda(FilCod) > 0
		&sdtTotalPedidosItem.PedVlrTotMed = (&CollPedidoMoeda(FilCod) / &CollQtdPedidos(FilCod))
	EndIF
	&sdtTotalPedidosItem.PedVlrTotQtd = &CollQtdPedidos(FilCod)
	&sdtTotalPedidosItem.PedVlrTot = &CollPedidoMoeda(FilCod)
	
	&sdtTotalPedidos.Add(&sdtTotalPedidosItem)
EndFor

If &Count > 1
	&sdtTotalPedidosItem = new()
	&sdtTotalPedidosItem.FilCod = 99999999
	&sdtTotalPedidosItem.FilCodNom = 'TOTAL FILIAIS'
	
	&sdtTotalPedidosItem.PedVlrFinMed = &FinMedioMoeda
	&sdtTotalPedidosItem.PedVlrFinQtd = &FinQtdPedido
	&sdtTotalPedidosItem.PedVlrFinTot = &FinPedidoMoeda
	
	&sdtTotalPedidosItem.PedVlrTotMed = &medioMoeda
	&sdtTotalPedidosItem.PedVlrTotQtd = &QtdPedidos
	&sdtTotalPedidosItem.PedVlrTot = &PedidoMoeda
	
	&sdtTotalPedidos.Add(&sdtTotalPedidosItem)
Endif


padraoUsuarioHora.Call('G', '#retornatotalpedidosporfilial#', 1, &EmpCod, &sdtTotalPedidos.ToJson(), &PadDtaMod, &PadDtaHorMod, 'T')
]]></Source>
