        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	&Status_SimNao = iif(&IgnoraTabelaImposto = 'S' or &IgnoraTabelaImposto = '1', Status_SimNao.Sim, Status_SimNao.Nao)
		
	prcClonarNfe.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &FilCodFat, &NfeFin,&NfeEntSai,&NfeLctCod, Nota_ProPriaTerceira.PROPRIA, &Status_SimNao, &NewNfeCod)
	
	&sdtRetornowbs.Sts = 'J200'
	&sdtRetornowbs.Obs = 'SUCESSO'
	&sdtRetornowbs.qtdPed = &NewNfeCod
Endif
]]></Source>
