      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &NfeCidNom.Trim().IsEmpty()
	Do 'getCidade'	
EndIf

If &OqueFazer = 'ADD'
	For Each Order EmpCod, FilCod, MDFeCod, MDFeNFeFilCod, MDFeNfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeNFeFilCod = &NfeFilCod
		Where MDFeNfeCod = &NfeCod
		Where MDFeNfeChv = &NfeChv
		
		msg('ATENÇÃO, A nota de Sequência '+trim(str(&NfeCod))+' e valor ' +&NfeVlrTot.ToFormattedString()+ ' já foi adicionado!')
		MDFeNfeVlrTot = &NfeVlrTot
		MDfeNfePso = &NfePso
		
		Exit
	When none
		
		For Each Order EmpCod, FilCod, MDFeCod, (MDFeNFeItm)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			&MDFeNfeItm = MDFeNFeItm
			Exit
		EndFor
		&MDFeNfeItm += 1
		
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MdfeCod
			MDFeNFeItm =  &MDFeNfeItm
			MDFeNFeFilCod = &NfeFilCod
			MDFeNfeCod = &NfeCod
			MDFeNfeChv = &NfeChv
			MDfeNfeCidCod = &NfeCidCod
			MDFeNfeCidNom = &NfeCidNom
			MdfeNfeUfeCod = &NfeUfeCod
			MDFeNfeVlrTot = &NfeVlrTot
			MDfeNfePso = &NfePesBrt
			MDFeNfeChv2 = &MDFeNfeChv2
			msg('Nota '+trim(str(&NfeCod))+' e valor ' +&NfeVlrTot.ToFormattedString()+ ' foi adicionado com sucesso!')
		EndNEw
		COMMIT		
	EndFor
Else
	For Each Order EmpCod, FilCod, MDFeCod, MDFeNFeItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeNFeItm = &ParMDFeNfeItm
		Delete
		Exit
	EndFor
EndIF

Commit
	
Sub 'getCidade'
	For each Order EmpCod,CidIBGE, CidCod
		Where EmpCod = &EmpCod
		Where CidIBGE = &NfeCidCod		
		&NfeCidNom = CidNom
		exit
	EndFor
EndSub
]]></Source>
