      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVAR LOG
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'FRETENOTAS')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVO	
	prcCarregaLog_FreteNotas.Call(&EmpCod, &FilCod, &FrtCod, &SdtLogAtributosLevel)
Endif


For Each Order EmpCod, FilCod, FrtCod, (FrtItmCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where FrtCod = &FrtCod
	&FrtItmCod = FrtItmCod
	Exit
EndFor

&FrtItmCod += 1

New
	EmpCod = &EmpCod
	FilCod = &FilCod
	FrtCod = &FrtCod
	FrtItmCod = &FrtItmCod
	FrtNfeFilCod = &FrtNfeFilCod
	FrtNfeCod = &FrtNfeCod
	FrtNfeNum = &FrtNfeNum
	FrtPedFiLCod = &FrtPedFiLCod
	FrtPedCod = &FrtPedCod
	FrtItmVlr = &FrtItmVlr
	FrtItmNot = &FrtItmNot
	FrtItmTip = &FrtItmTip
	FrtItmCte = &FrtItmCte	
EndNew

Commit

if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVO	
	prcGravaLog_FreteNotas.Call(&EmpCod, &FilCod, &FrtCod, &Pgmname, &WwpContextUserName, &SdtLogAtributosLevel)
Endif

RateiaFreteItens.Call(&EmpCod, &FilCod, &FrtCod)
]]></Source>
