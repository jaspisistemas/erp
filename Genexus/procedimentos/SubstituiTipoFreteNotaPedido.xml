      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where NfeCod = &NfeCod
	
	If &FrtOri = 'E' //EMITENTE
		NfeTipFrt = TipoFrete.Emitente
	Else
		NfeTipFrt = TipoFrete.Destinatario
	EndIF
	Exit
EndFor


commit
]]></Source>
