      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//TRATAR A VERSAO DO APPP
//vApi
//vApiNew
//linkBaixaApp


// 'J100' //erro servidor
// 'J101' //erro codigo acesso

&Pass = prcCode.Udp()

if &CodigoAtivacao like '%'+&Pass
	For each Order EmpCod
		&Dados = 'J200'
		Exit
	When none
		&Dados = 'J100'
	EndFor
Else
	&Dados = 'J101'
Endif
]]></Source>
