      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAchou = False

For each Order EmpCod,RcbMovCod,RcbMovItm
	Where EmpCod = &EmpCod
	Where RcbMovCod = &MovCod
	&IsAchou = True
	
	Exit
EndFor

If &IsAchou = False
	For each Order EmpCod,MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		&MovCreDeb = MovCreDeb
		&MovTip   = MovTip
		Exit
	EndFor
	
	For each Order EmpCod,MovCod,MovItmCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		
		////##################################### GRAVA RECIBO ###############################
		UltimoCodigoEmpresa.Call(domParCod.RECIBO, &EmpCod, 0,&RcbCod)
		New	
			EmpCod = &EmpCod
			RcbCod = &RcbCod
			RcbDoc = trim(str(&MovCod))
			RcbTip = Iif(&MovCreDeb = 'C',TipoRecibo.Receber,TipoRecibo.Pagar)
			
			RcbVlr = MovItmVlr
			
			If not MovCreFilCod.IsEmpty() and not MovCreFilCod.IsNull()
				&MovCreFilCod = MovCreFilCod
			Else
				&MovCreFilCod = MovCtaBanFilCod
			Endif
			
			&MovCreCod    = MovCreCod
			&MovFunCod    = MovFunCod
			Do 'Duplicata'
			
			If &MovTip = TipoMovimento.Adiantamento
				Do 'Funcionario'
				RcbDstCod = MovFunCod
				RcbDstNom = &PesRaz
				&MovCreFilCod = &PesFunFilCod
				RcbObs = MovItmCpl+' COM VENCIMENTO NO MÊS '+Str(MovFunMes)+' ANO '+ Str(MovFunAno)
			Else
				RcbDstCod = &CreCliCod
				RcbDstNom = &CreCliRaz
				RcbObs = MovItmCpl
			EndIf
			
		
			RcbMovCod = &MovCod
			RcbMovItm = MovItmCod
			RcbFilCod = &MovCreFilCod
			RcbCreCod = MovCreCod
			RcbCrePagCod = MovCrePagCod
			RcbDta = SerVerDate()
			RcbHor = ServerNow()
			RcbCodeVR = 1000 * Random()
		EndNew
	EndFor

	Commit
EndIf

Sub 'Duplicata'
	For each order EmpCod,FilCod,CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &MovCreFilCod
		Where CreCod = &MovCreCod
		&CreCliCod = CreCliCod
		&CreCliRaz = CreCliRaz
//		&CrePedCod = CrePedCod
		Exit
	EndFor
EndSub

Sub 'Funcionario'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &MovFunCod
		&PesFunFilCod = PesFunFilCod
		&PesRaz = PesRaz
		Exit
	EndFor
EndSub
]]></Source>
