      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, NfsCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NfsCod
	&NFsTipNf = NfsTipNF
	Exit
EndFor

For Each Order EmpCod, NfsCod, NfsItmCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NfsCod
	Where NfsItmCod = &WizardData.Itens.NfsItmCod
	
	NfsItmValTot = round(&WizardData.Itens.NfsItmQtd * &WizardData.Itens.NfsItmValUnt, 2)
	
	NfsItmEmbUnd = &WizardData.Itens.NfsItmEmbUnd
	NfsItmValUnt = &WizardData.Itens.NfsItmValUnt
	NfsItmQtd = &WizardData.Itens.NfsItmQtd
	NfsItmProNom = &WizardData.Itens.NfsItmProNom
	
	//ProRef = &WizardData.Itens.ProRef
	//NfsItmCod = &WizardData.Itens.NfsItmCod
	
	Exit
When none
	&NfsItmCod = 0	
	For Each Order EmpCod, NfsCod, (NfsItmCod)
		Where EmpCod = &EmpCod
		Where NfsCod = &NfsCod
		&NfsItmCod = NfsItmCod
		Exit
	EndFor
	&NfsItmCod += 1
	if &NfsItmCod = 1 and &NFsTipNf = 'S'
		&NfsItmCod += 1
	Endif
	
	New //ADD ITEM
		EmpCod = &EmpCod
		NfsCod = &NfsCod 
		NfsItmCod = &NfsItmCod
		NfsItmProCod = &WizardData.Itens.NfsItmProCod
		NfsItmProGraCod = &WizardData.Itens.NfsItmProGraCod
		NfsItmProNom = &WizardData.Itens.NfsItmProNom
		NfsItmEmbUnd = &WizardData.Itens.NfsItmEmbUnd
		
		NfsItmValUnt = &WizardData.Itens.NfsItmValUnt
		NfsItmQtd = &WizardData.Itens.NfsItmQtd
		
		NfsItmValTot = round(&WizardData.Itens.NfsItmQtd * &WizardData.Itens.NfsItmValUnt, 2)		
	EndNew

EndFor

Commit

if &NFsTipNf <> 'S'
	prcTotalizaNFSe.Call(&EmpCod, &NfsCod)
Endif
]]></Source>
