      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&LctAtuSal = LctAtuSal
EndFor

If &PedTmpDupCod <> 0
	For Each Order EmpCod, FilCod, PedCod, PedTmpDupCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedTmpDupCod = &PedTmpDupCod
		
		PedTmpDupNro = &PedTmpDupNro
		PedTmpDupVct = &PedTmpDupVct
		&PedTmpSem = substr(cdow(&PedTmpDupVct), 1, 3)
		PedTmpSem = &PedTmpSem
		
		if PedTmpDupDtaFat.IsEmpty()
			&PedDtaFat = PedDtaFat
		Else
			&PedDtaFat = PedTmpDupDtaFat
		Endif	
		
		&PedTmpPrz = 0
		IF (not &PedDtaFat.IsEmpty()) and (not &PedTmpDupVct.IsEmpty())
			&PedTmpPrz = (&PedTmpDupVct - &PedDtaFat) 
		EndIF
		
		PedTmpPrz          = &PedTmpPrz
		PedTmpDupBanCarCod = &BanCarCod
		PedTmpDupCreDeb    = &PedTmpDupCreDeb
		PedTmpDupVlr       = &PedTmpDupVlr
		PedTmpDupCbrCod    = &PedTmpDupCbrCod
		PedTmpCtaBanCod    = &PedTmpDupCbrCod
		PedTmpPlanCod      = &PedTmpPlanCod
		PedTmpDtaPag       = &CrePagDta
		PedTmpFrpPgtoCod       = &PedTmpFrpPgtoCod
		PedTmpDupCarNroAut = &PedTmpDupCarNroAut
		PedTmpPesCod = &PedTmpPesCod
		Exit
	EndFor
Else	
	if &PedTmpPlanCod.IsEmpty()
		if &LctAtuSal = Status_EntradaSaida.Entrada
			RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon027_PlanoContasFornecedor, &CfgVlr)
		Else
			RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &CfgVlr)
		EndiF
		
		RetornaCodigoPlanoContas.Call(&EmpCod, &CfgVlr, &PlanCod)
	Else
		&PlanCod = &PedTmpPlanCod
	EndiF	
	
	&AuxPedTmpDupCod = 0
	For Each Order EmpCod, FilCod, PedCod, (PedTmpDupCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&AuxPedTmpDupCod = PedTmpDupCod
		Exit
	EndFor
	&AuxPedTmpDupCod += 1
	
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedTmpDupCod = &AuxPedTmpDupCod
		
		PedTmpDupNro = trim(str(&PedCod)) + '-' + trim(str(&AuxPedTmpDupCod))
		
		PedTmpCreCod = 0
		
		PedTmpFrpPgtoCod = &PedTmpFrpPgtoCod
		
		PedTmpPlanCod = &PlanCod
		PedTmpSts = Status_SimNao.Nao
		PedTmpDtaPag = &CrePagDta
		PedTmpDupCarNroAut = &PedTmpDupCarNroAut
	EndNew
EndIf

commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
