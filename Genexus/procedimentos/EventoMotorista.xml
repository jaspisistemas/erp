      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &oquefazer = 'ADD'
	For each Order EmpCod,FilCod,MDFeCod,(MdfeEveCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		
		&MdfeEveCod = MdfeEveCod
		Exit
	EndFor

	do 'SequencialEvento'
	
	&MdfeEveCod +=1
	
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDFeCod
		MdfeEveCod = &MdfeEveCod
		MdfeDta = Serverdate()
		MdfeEveNro = '110114'  //incusao MOtorista	
		MdfeEveMotCod = &MdfeEveMotCod + 1
		MdfeEveMotCpf = &MDFeMotCpf
		MdfeEveMotNom = &MDFeMotNom
		MdfeEveSts = Status_Mdfe.Digitando
	EndNew
	
Else
	For each Order EmpCod,FilCod,MDFeCod,MdfeEveCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeEveCod = &MdfeEveCod
		Delete
	EndFor
EndIf


Sub 'SequencialEvento'	
	For each Order EmpCod,FilCod,MDFeCod,MdfeEveNro,(MdfeEveMotCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeEveNro = '110114'// ultimo sequencial desse evento pois a tabela serve pra outros eentos.
		
		&MdfeEveMotCod = MdfeEveMotCod
		Exit
	EndFor
EndSub
]]></Source>
