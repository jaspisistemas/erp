      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//CIDADES
if &ppJASPI_CidadessdtEstruturaLocalizacao.sdtCidades.Cidadess.Count > 0
	For &sdtCidadess in &ppJASPI_CidadessdtEstruturaLocalizacao.sdtCidades.Cidadess		
		UltimoCodigoEmpresa.Call(domParCod.CIDADE, &EmpCod, 0, &CidCod)
		
		new
			EmpCod = &EmpCod
			CidCod = &CidCod
			CidNom = &sdtCidadess.CidNom
			CidIBGE = &sdtCidadess.CidIBGE
			UfeCod = &sdtCidadess.UfeCod
			PaiCod = &sdtCidadess.PaiCod
			CidPop = &sdtCidadess.CidPop
			CidWs = Status_WsUsu.WebService
			CidDtaMod = serverNow()
			CidAreCod = 1
			CidTraCod = 0
			CidCodSync = &sdtCidadess.CidCodSync
		EndNew
		Commit
		
		AtualizaCidadeFormula.Call(&EmpCod,&CidCod)
	EndFor

	
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		EmpSyncCid = serverdate() - 1
		Exit
	EndFor
EndIf

For Each Order EmpCod, CidCodSync, CidCod
	Where EmpCod = &EmpCod
	Where CidWs = Status_WsUsu.WebService
	Where CidCodSync.IsEmpty() or CidCodSync.IsNull()
	CidWs = Status_WsUsu.Usuario
	CidDtaMod = serverNow()
EndFor
Commit
	

//ESTADOS
if &ppJASPI_CidadessdtEstruturaLocalizacao.sdtEstados.Estadoss.Count > 0
	For &sdtEstadoss in &ppJASPI_CidadessdtEstruturaLocalizacao.sdtEstados.Estadoss

		For Each Order EmpCod, UfeCod
			where EmpCod = &EmpCod
			where UfeCod = &sdtEstadoss.UfeCod
			UfeNom = &sdtEstadoss.UfeNom
			Exit
		When none
			new
				EmpCod = &EmpCod
				UfeCod = &sdtEstadoss.UfeCod
				UfeNom = &sdtEstadoss.UfeNom
				if &sdtEstadoss.UfeCod in ('SP', 'ES')
					UfeGNRE = Status_SimNao.Nao
				Else
					UfeGNRE = Status_SimNao.Sim
				EndIf
	
			EndNew
		EndFor
		Commit
	EndFor

EndIF

//PAISES
if &ppJASPI_CidadessdtEstruturaLocalizacao.sdtPais.Paiss.Count > 0
	For &sdtPaiss in &ppJASPI_CidadessdtEstruturaLocalizacao.sdtPais.Paiss		
		For Each Order EmpCod, PaiCod
			Where EmpCod = &EmpCod
			Where PaiCod = &sdtPaiss.PaiCod
			PaiNom = &sdtPaiss.PaiNom
			PaiIso = &sdtPaiss.PaiIso
			Exit
		When none
			new
				EmpCod = &EmpCod
				PaiCod = &sdtPaiss.PaiCod
				PaiNom = &sdtPaiss.PaiNom
				PaiIso = &sdtPaiss.PaiIso
			EndNew
		EndFor
		Commit
	EndFor
EndIF
]]></Source>
