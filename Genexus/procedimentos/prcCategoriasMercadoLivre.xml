      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&HttpClient.AddHeader('Content-Type', 'application/json')
&HttpClient.AddHeader('Accept', 'application/json')
&HttpClient.Execute('GET', 'https://api.mercadolibre.com/sites/MLB/categories/all')

If &HttpClient.StatusCode = 200
	
	&longvarchar = &HttpClient.ToString()
	
&properties.FromJson(&longvarchar)
for &Property in &properties
	
	&MrkCatCod = &Property.Key
	&MrkCatPaiCod = ''
	
	&sdtcategoriasMLItem.FromJson(&Property.Value)
	
	padraoUsuario.Call('G', &Property.Key, 1, 1,&sdtcategoriasMLItem.ToJson(), &PAdDtaMod)
	
	For &path_from_root in &sdtcategoriasMLItem.path_from_root
		if &path_from_root.id <> &MrkCatCod
			&MrkCatPaiCod = &path_from_root.id
		Endif
	EndFor
	
	if &MrkCatPaiCod.IsEmpty() 
		&MrkCatPaiCod = &MrkCatCod
	Endif
	
	
	For Each Order MrkCatApp, MrkCatCod
		Where MrkCatApp = TipoMarketplace.MercadoLivre
		Where MrkCatCod = &MrkCatCod
		MrkCatNom = &sdtcategoriasMLItem.name
		MrkCatPaiCod = &MrkCatPaiCod
		//		MrkCatQtdFil.FromString(&sdtcategoriasMLItem.children_categories)
		MrkCatImgUrl = &sdtcategoriasMLItem.picture
		MrkCatJson = &Property.Value
	When None
		new
			MrkCatApp = TipoMarketplace.MercadoLivre
			MrkCatCod = &MrkCatCod
			MrkCatNom = &sdtcategoriasMLItem.name
			MrkCatPaiCod = &MrkCatPaiCod
			//			MrkCatQtdFil.FromString(&sdtcategoriasMLItem.children_categories)
			MrkCatImgUrl = &sdtcategoriasMLItem.picture
			MrkCatJson = &Property.Value
		EndNew
	EndFor
	
	Commit
	
endfor




	

	
Else
	msg('Falha catastrófica! ' + &HttpClient.StatusCode.ToString())
Endif
]]></Source>
