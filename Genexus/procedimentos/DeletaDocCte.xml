      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,CteCod,CteDocCod //Deleta documento
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteDocCod = &CteDocCod when not &CteDocCod.IsEmpty()
	
	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip  //Deleta Transporte
		
		For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip,CteInfUndTraCarTip //Deleta Carga	
			
			For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip,CteInfUndTraCarTip,CteUniTraCarLac //Deleta Lacres
				Delete
			EndFor
			Delete
		EndFor	
		
		For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndTraTip,CteUniTraLac //Deleta Transporte Lacre
			Delete
		EndFor
		
		Delete
	EndFor

	For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndCarTip  //Deleta Carga documento
		For Each Order EmpCod,FilCod,CteCod,CteDocCod,CteInfUndCarTip,CteUniCarLac  //Deleta lacre da carga do documento
			delete
		EndFor
		delete
	EndFor
	delete
EndFor

Commit
]]></Source>
