      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, OcsCod, OcsItm, (OcsEtpItm)
	where EmpCod = &EmpCod
	Where OcsCod = &OcsCOd
	where OcsItm = &OcsItm
	&UltOcsEtpItm = OcsEtpItm
	exit
EndFor

If &UltOcsEtpItm > 0
	For &OcsEtpItm = 1 to &UltOcsEtpItm
		
		//RetornaExisteEtapaCodigo	
		do 'LocalizaExisteEtapaCodigo'
		
		//SE NAO EXISTE, LOCALIZA PROXIMO CODIGO
		if &IsExiste = false
			do 'localizaProximaEtapa'

			//ALTERA ORDEM ETAPA E APONTAMENTOS
			if &PrxOcsEtpItm > 0
				AlteraordemEtapaCostura.Call(&EmpCod, &OcsCOd, &OcsItm, &PrxOcsEtpItm, &OcsEtpItm)
			Endif
		Endif
	EndFor
Endif


sub  'localizaProximaEtapa'
	&PrxOcsEtpItm = 0
	For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
		where EmpCod = &EmpCod
		Where OcsCod = &OcsCOd
		Where OcsItm = &OcsItm
		Where OcsEtpItm > &OcsEtpItm 
		&PrxOcsEtpItm = OcsEtpItm
		exit
	EndFor
EndSub

sub  'LocalizaExisteEtapaCodigo'
	&IsExiste = false
	For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
		where EmpCod = &EmpCod
		Where OcsCod = &OcsCOd
		Where OcsItm = &OcsItm
		Where OcsEtpItm = &OcsEtpItm
		&IsExiste = true
		exit
	EndFor
EndSub
]]></Source>
