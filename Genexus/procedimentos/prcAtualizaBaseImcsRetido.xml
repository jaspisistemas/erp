      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAtualizaRedito = false
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where PedCod = &PedCod
	
	if (LctIcmsRet.IsEmpty() or LctIcmsRet.IsNull() or LctIcmsRet = Status_SimNao_PS.SIM) and (LctTip = TipoLancamento.EntradaMercadoria) and (LctGerFin = Status_SimNao.Sim)
		&IsAtualizaRedito = true
	Endif

	Exit
EndFor


if &IsAtualizaRedito = true
	For Each Order tmpNFeCod, tmpNfeItmCod
		WHere tmpNFeCod = &tmpNFeCod
		
		Do case
	        Case tmpProQtdCmpEmb > 0
	            &PedQtd = ((tmpPedQtd * tmpProQtdCmpEmb))
			Case tmpProQtdCmpEmb < 0 //and &QtdMultiplicada > 0
				&PedQtd = ((tmpPedQtd / (tmpProQtdCmpEmb*-1)))
	        Otherwise
	            &PedQtd = tmpPedQtd
	    EndCase
	
	
		if &PedQtd > 0 and ((not tmpProVlrIcmSt.IsEmpty() and not tmpProVlrIcmSt.IsNull()) or (not tmpNfeProVlrIcmsRet.IsEmpty() and not tmpNfeProVlrIcmsRet.IsNull()))
			
			&ProCod = tmpProCod
			
			if not tmpProVlrIcmSt.IsEmpty() and not tmpProVlrIcmSt.IsNull() 
				if not tmpProBasVlrIcmSt.IsEmpty() and not tmpProBasVlrIcmSt.IsNull()
					&ProBasIcmsRet = tmpProBasVlrIcmSt/&PedQtd
				Endif

				&ProTaxIcmsRet = tmpProPerIcmSt
				if not tmpProVlrIcmSt.IsEmpty() and not tmpProVlrIcmSt.IsNull()
					&ProVlrIcmsRet = tmpProVlrIcmSt/&PedQtd
				Endif			
			Else
				if not tmpNfeProBasIcmsRet.IsEmpty() and not tmpNfeProBasIcmsRet.IsNull()
					&ProBasIcmsRet = tmpNfeProBasIcmsRet/&PedQtd
				Endif
				if not tmpNfeProVlrIcmsRet.IsEmpty() and not tmpNfeProVlrIcmsRet.IsNull()
					&ProVlrIcmsRet = tmpNfeProVlrIcmsRet/&PedQtd
				Endif
				&ProTaxIcmsRet = tmpNfeProTaxIcmsRet
			endIf
			
			if not &ProTaxIcmsRet.IsEmpty() and not &ProVlrIcmsRet.IsEmpty() and not &ProBasIcmsRet.IsEmpty()
				do 'AtualizaProduto'
			Endif
			
		Endif

	EndFor
Endif

Sub 'AtualizaProduto'
	//ICMS RETIDO
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		ProBasIcmsRet = &ProBasIcmsRet
		ProTaxIcmsRet = &ProTaxIcmsRet
		ProVlrIcmsRet = &ProVlrIcmsRet
		
		Exit
	EndFor
	
	Commit
EndSub
]]></Source>
