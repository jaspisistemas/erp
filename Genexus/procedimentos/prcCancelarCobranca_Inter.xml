      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do 'GetContaBancaria'

&Mensagem.SetEmpty()
&LongVarChar			= '{    "motivoCancelamento": "'+ &MotivoVarChar + '"}'//&SdtCancelaCobranca_Inter.ToJson()
&Password				= '1234'
&VerificaMensagemToken	= 0
&VerificaMensagemScopo	= 0
&CampoData	= &Today.AddDays(1)

If Not &contaCorrente.IsEmpty()
	&HttpClient.AddHeader('x-conta-corrente', &contaCorrente)
EndIf
&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
&HttpClient.AddHeader('Connection', 'keep-alive')
&HTTPClient.AddHeader('Authorization', 'Bearer ' + &CbrChaTra.Trim())
&HttpClient.AddHeader('Content-Type', 'application/json')
&HttpClient.AddString(&LongVarChar)

PadraoUsuario.Call('G', 'INTER_CANCELARCOBRANCA_JSON', &PesCod, &EmpCod, &LongVarChar, &PadDtaMod)

//Carrega o Certificado ao Handler
CSHARP try
CSHARP { [!&HttpClient!].AddCertificate([!&PathCert!],[!&Password!]); }
CSHARP catch (Exception ex)
CSHARP { [!&ErrorDescription!] = ex.ToString();
CSHARP }

&HttpClient.Execute('POST', 'https://cdpj.partners.bancointer.com.br/cobranca/v3/cobrancas/' + &codigoSolicitacao + '/cancelar')
If &HttpClient.StatusCode > 202
	
	&SdtErroAPI_Inter.FromJson(&HttpClient.ToString())
	&Mensagem		= &SdtErroAPI_Inter.title + ' ' + &SdtErroAPI_Inter.detail
	
	If &SdtErroAPI_Inter.violacoes.Count >= 1
		For &violacoes In &SdtErroAPI_Inter.violacoes
			&Mensagem  += ' ' + &violacoes.razao.Trim() + ' Propriedade: ' + &violacoes.propriedade.Trim()
		EndFor
	EndIf
	
	&Mensagem	   += IIf(&ErrorDescription.IsEmpty(), '', ' - Erro CSHARP:' + &ErrorDescription.Trim())
	
	//Verifica se é erro de Token
	If &Mensagem.IsEmpty()
		&Mensagem				= &HttpClient.ToString()
		&VerificaMensagemToken	= StrSearch(&Mensagem, 'Token inválido.', 1)
	EndIf
	
	//Se for erro de token, realiza a autenticação automaticamente
	If &VerificaMensagemToken > 0
		prcOAuth_Inter.Call(&EmpCod, &FilCod, &PesCod, &CreCbrCod, &AuxCbrChaTra, &Mensagem)
		If &Mensagem.IsEmpty()
			prcCancelarCobranca_Inter.Call(&EmpCod, &FilCod, &PesCod, &PesRaz, &CreCod, &CreCbrCod, &AuxCbrChaTra, &contaCorrente, &codigoSolicitacao, &MotivoVarChar, &Mensagem)
		Else
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &Mensagem, DVMessageType.error, "", DVMessageBoolean.True, ""))
		EndIf
	Else
		//Se for erro de escopo, sinaliza o escopo
		&VerificaMensagemScopo	= StrSearch(&Mensagem, 'escopos', 1)
		If &VerificaMensagemScopo > 0
			&Mensagem			= 'Faltando escopos necessários. Verifique na Conta Bancária se há os seguintes escopos: boleto-cobranca.write boleto-cobranca.read'
		EndIf
		PadraoUsuario.Call('G', 'INTER_CANCELARCOBRANCA_ERRO', &PesCod, &EmpCod, &Mensagem, &PadDtaMod)
	EndIf
Else
	Do 'AtualizaDuplicata'
EndIf

Sub 'AtualizaDuplicata'
	
	&IsComandoExecutado = False
	If &PesRaz.IsEmpty()
		&PesRaz	= 'PROCEDIMENTOS JASPI'
	EndIf
	
	AtualizaInstrucaoDuplicata.call(&EmpCod, &FilCod, &CreCod, ComandoInstrucao.PEDIDO_BAIXA, &CampoData, &PesCod, &PesRaz, &SdtBoletoInstrucaoSicrediRetorno)
	
EndSub

Sub 'GetContaBancaria'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CreCbrCod
				
		//Faz o genexus criar um arquivo temporario do certificado
		//Pega o caminho da web dele
		&Path			= PathToUrl(CtaBanPixCer)
		&InicioPath		= StrSearch(&Path, 'PublicTempStorage', 1)
		&Path			= SubStr(&Path, &InicioPath, &Path.Length())
		
		//Pesquisa o caminho fisico temporario do certificado
		&File.Source	= CtaBanPixCerNom
		&PathCert		= &File.GetPath() + !"\" + &Path
		&PathCert		= StrReplace(&PathCert, '/', '\')
		&File.Close()		
		
		Exit
	EndFor
	
EndSub
]]></Source>
