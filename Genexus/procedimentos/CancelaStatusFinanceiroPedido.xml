      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAchou = false

if &PedCod <> 0
	//	&PedTmpCreCod = 0
	//	For each Order EmpCod, FilCod, PedCod,PedTmpDupCod
	//		Where EmpCod = &EmpCod
	//		Where FilCod = &FilCod
	//		Where PedCod = &PedCod	
	//		&PedTmpCreCod = PedTmpCreCod
	//		do 'deletaduplicata'
	//		delete
	//	When none
	//		&PedTmpCreCod = 0
	//		Do 'deletaduplicata'
	//	EndFor
	//
	//EndIf
	//
	//Sub 'deletaduplicata'
	//DUPLICATAS
  
	For Each Order EmpCod, FilCod, CrePedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CrePedCod = &PedCod
		Where CreSts <> Status_Duplicata.CANCELADA
		&IsAchou = True
		//PAGAMENTOS normais 
		For Each Order EmpCod, FilCod, CreCod, CrePagCod
			Where CrePagSts <> Status_Caixa.Cancelado or CrePagSts.IsNull()
			
			RemoveFinanceiroDuplicata.Call(EmpCod, FilCod, CreCod, CreMovCod, CreMovItmCod, CrePagCod, &IsAchouPagamentos)
			
			CrePagSts = Status_Caixa.Cancelado
		EndFor
		
		//RENEGOCIACOES
		For Each Order EmpCod, FilCod, CreCod, CreRenCod
			delete
		EndFor

		prcDeletaDuplicatareferenciada.Call(EmpCod, FilCod, CreCod)
		
		//OBSERVACOES //JDF NAO DELETAR AS OBS.
		//	For Each Order EmpCod, FilCod, CreCobCod
		//		delete
		//	EndFor
		
		If Not CreFunCodVal.IsEmpty()
			prcCancelaAdiantamentoPedido.Call(EmpCod, FilCod, CreCod)
		EndIf
		
		if CreRecPag = ReceberPagar.Receber //TERCEIROS
			if not CreCheCod.IsEmpty() //DELETA CHEQUE LANCADO
				RemoveChequeTerceiros.Call(EmpCod, CreCheCod)
			Endif
		Else //PROPRIO
			Do CAse
				CAse CreFrpPgtoTip = TipoDuplicata.CHEQUEP and CreCheCod > 0 //REMOVE O CHEQUE PROPRIO
					RemoveChequeProprio.Call(EmpCod, CreCheCod)
					
				Case CreFrpPgtoTip = TipoDuplicata.CHEQUET //REMOVE O CHEQUE REPASSADO.
					
					&CreCod = CreCod
					do 'AtualizaCheque'
			EndCase
			
		EndiF
		
		//CANCELA BOLETO HIBRIDO
		If CreCbrTipBol = TipoBoleto.Hibrido And Not CreBloNro.IsEmpty() And Not CreDtaRet.IsEmpty()
			&PesRaz	= 'USUÁRIO: ' + Trim(Str(&ContextPesCod))
			Do Case
				Case CreCbrCtaBanBanCod = '748'
					prcCancelarCobranca_Sicredi.Call(EmpCod, FilCod, &ContextPesCod, &PesRaz, CreCod, CreCbrCod, CreBloNro, &IsBaixaOk, &BaixaMensagem)
					
				Case CreCbrCtaBanBanCod = '077'
					&CreCbrCod	= CreCbrCod
					Do 'GetLocalCobranca'
					
					If &IsErro	= False
						prcCancelarCobranca_Inter.Call(EmpCod, FilCod, &ContextPesCod, &PesRaz, CreCod, CreCbrCod, &CbrChaTra, &contacorrente, CreCodSol, &Mensagem, &BaixaMensagem)
					EndIf
			EndCase
		EndIf
		
		CreSts = Status_Duplicata.CANCELADA
	EndFor
	
	Commit
	
	//Remove as pgto de creditos utilizados no pedido.
	DeletaPgtodeCredito.call(&EmpCod,&FilCod,&PedCod)
	
	
	//altera Financeiro pedido
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod //when not &PedCod = 0
		
		PedStsFin 		= Status_Financeiro.ABERTO
		PedStsFinIsPar 	= false
		
		DeletaPgtoItenPedido.Call(EmpCod,FilCod,PedCod)
	EndFor
	
	commit
	
	If &IsAchou = True
		
		//GRAVA HISTORICO
		CriticasPedido.Call(&EmpCod, &FilCod, &PedCod, TipoCriticaPedido.CanceladoFinanceiro, &ContextPesCod)
		For Each Order EmpCod, FilCod, PedCod, (HisItmCod)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod //when not &PedCod = 0
			&HisItmCod = HisItmCod
			Exit
		EndFor
		
		if not &Mensagem.IsEmpty()
			&PedStsCod = RetornaCodigoStatusPedido.Udp(&EmpCod, 'CANCELADO')
			//GRAVA HISTORICO
			&HisItmCod += 1
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				PedCod = &PedCod
				HisItmCod = &HisItmCod
				HisStsCod = &PedStsCod
				HisStsObs = format('Financeiro usuario %1: %2', trim(str(&ContextPesCod)), &Mensagem)
			EndNew
			
			Commit
		Endif
	EndIf
EndIf

sub 'AtualizaCheque'
	For Each Order EmpCod, CheRepFilCreCod, CheRepCreCod
		Where EmpCod 			= &EmpCod
		Where CheRepFilCreCod 	= &FilCod
		Where CheRepCreCod 		= &CreCod
		
		CheRepIs 		= false
		CheRepFilCreCod = 0
		CheRepCreCod 	= 0
		
		ChequeTerceiros_AlteraStatus.Call(EmpCod, CheCod, MotivoCheque.EMITIDO)
	EndFor

	Commit
EndSub	

Sub 'GetLocalCobranca'
	
	&IsErro 		= False
	For each Order EmpCod, CbrCod, CrbRegAut
		Where EmpCod 	= &EmpCod
		Where CbrCod 	= &CreCbrCod
		Where CrbRegAut = Status_SimNao.Sim
		
		&contacorrente	= CbrNroCon.Trim() + CbrNroConDig.Trim()
		If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow()
			&CbrChaTra 			= CbrChaTra
		Else
			prcOAuth_Inter.Call(&EmpCod, &FilCod, &PesCod, CbrCod, &CbrChaTra, &Mensagem)
			If Not &Mensagem.IsEmpty()
				&IsErro			= True
			EndIf
		EndIf
		
		Exit
	When None
		&IsErro	= True
	EndFor

EndSub
]]></Source>
