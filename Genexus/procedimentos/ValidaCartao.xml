      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
 
&IsAchouParcela = false
	
For each Order EmpCod, BanCarCod 
	Where EmpCod = &EmpCod
	Where BanCarCod = &BanCarCod
	
	&BanCarConfAut = BanCarConfAut  
	
	if &CarParQtd > 1
		For each Order EmpCod, BanCarCod, BanCarCrePar
			&BanCarVlrMinPar = &CarMovVlr / BanCarCrePar
			If  &BanCarVlrMinPar >= BanCarVlrMinPar and &CarParQtd = BanCarCrePar
				&IsAchouParcela = true
				Exit
			EndIf
		EndFor
	Else
		&CarParQtd = 1
		&IsAchouParcela = true
	Endif
EndFor
]]></Source>
