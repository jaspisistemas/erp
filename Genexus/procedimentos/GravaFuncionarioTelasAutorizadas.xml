      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVAR LOG
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'FUNCIONARIOSENHA')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
	prcCarregaLog_FuncionarioSenha.Call(&EmpCod, &PesCod, &SdtLogAtributosLevel)
Endif

if &IsAutorizar = true
	For Each Order EmpCod, PesCod, PesSenLoc
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesSenLoc = &PesSenLoc
		Exit
	When none
		For Each Order EmpCod, PesCod, (PesSenItm)
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			&PesSenItm = PesSenItm
			Exit
		EndFor
		&PesSenItm += 1
		
		new
			EmpCod = &EmpCod
			PesCod = &PesCod 
			PesSenItm = &PesSenItm
			PesSenLoc = &PesSenLoc			
		EndNew
	Endfor

	Commit

Else
	For Each Order EmpCod, PesCod, PesSenLoc
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesSenLoc = &PesSenLoc
		delete
	endFor

	commit
Endif


if &LogErpTabIsLog = true //GRAVA LOG
	prcGravaLog_FuncionarioSenha.Call(&EmpCod, &FilCod, &PesCod, &Pgmname, &WwpContextUserName, &SdtLogAtributosLevel)
Endif



For Each Order EmpCod, PesCod //JDF para atualizar os PDV
	where EmpCod = &EmpCod
	Where PesCod = &PesCod
	PesDtaHorAlt = serverNow()
	Exit
EndFor

Commit
]]></Source>
