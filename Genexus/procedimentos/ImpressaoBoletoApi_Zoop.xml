      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod,FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod	
	&CreBloNro = CreBloNro
	if CrePdf64ApiEco.IsEmpty() or CrePdf64ApiEco.IsNull()
		&sdtZoop_Duplicata.FromJson(CreArqRetApiEco)
		do 'RetornaHtml'
		CrePdf64ApiEco = &CrePdf64ApiEco
		Commit
	Else
		&CrePdf64ApiEco = CrePdf64ApiEco
	Endif
	exit
EndFor	

if not &CrePdf64ApiEco.isEmpty()
	RetornaConfiguracoesPastas.Call(&EmpCod,&FilCod,&SdtConfiguracoesPasta)
	&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempFis+trim(&CreBloNro)+'.html'
	&File.Source = &NomeArquivo
	If &File.Exists()
		&File.Delete()
	EndIf			
	
	&File2.Source = &NomeArquivo
	If not &File2.Exists()
		&File2.Create()
		&File2.WriteAllText(&CrePdf64ApiEco) 
		&File2.Close()
		
		&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempVir+trim(&CreBloNro)+'.html'
//		Link(&NomeArquivo)
	EndIf		
Endif

			
Sub 'RetornaHtml'
	&sdtZoop_Duplicata.payment_method.url = &sdtZoop_Duplicata.payment_method.url.Replace('\', '')
	&sdtZoop_Duplicata.payment_method.url = &sdtZoop_Duplicata.payment_method.url.Replace('http://', '')
	&sdtZoop_Duplicata.payment_method.url = &sdtZoop_Duplicata.payment_method.url.Replace('https://', '')
	
	&Index = &sdtZoop_Duplicata.payment_method.url.IndexOf('/', 1)
	&Host = Substr(&sdtZoop_Duplicata.payment_method.url, 1, &index)
	&String = &sdtZoop_Duplicata.payment_method.url.Replace(&Host, '')
	&Host = &Host.Replace('/', '')
	
	&HttpClient.Host = &Host //servidor
	&HttpClient.Secure = 1
	//&httpclient.AddHeader(!'Content-type',!'application/json')
//	&httpclient.AddHeader('Content-type', 'text/html')
	csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.SecurityProtocolType.Tls11 | System.Net.SecurityProtocolType.Tls;
	&HttpClient.Execute('GET',&String)
	
	//padraoUsuario.Call('G', '#BOLETOAPI_ZOOP', &PesCod, &EmpCod, &HttpClient.toString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
 	//################################# sem erro de comunicação ################################################################################
	Do Case
		Case &HttpClient.ErrCode = 0
			&CrePdf64ApiEco = &HttpClient.toString()
			
		Otherwise
			msg('ERRO - '+trim(str(&HttpClient.ErrCode)) +': '+&HttpClient.ErrDescription)
	EndCase
	
EndSub


]]></Source>
