      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod //Empresa
	Where FilCod = &FilCod //Filial
	Where NfeSer = &NfeSer //Serie
	Where ModCod = &ModCod //Modelo
    Where NfeNum >= &FilInuNroIni and NfeNum <= &FilInuNroFin //Intervalo Emissao
	Where NfeSts = Status_Nfe.Digitando
	
    NfeSts = Status_Nfe.Inutilizada
	NfeAutMsg = &NfeAutMsg
	NfeAutSts = '102'
EndFor

commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
