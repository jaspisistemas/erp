      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmPCod
	Where FilCod = &FiLCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	EstCom = 0
	EstVen = 0
	if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
		EstCom = EstCom_FORMULA
		EstVen = EstVen_FORMULA
	Endif
		
	&EstQTd = EstQtd
	&EstQtdCus = EstQtdCus
	Exit
EndFOr

commit

//&IsAtualizaCusto = false

//SEPARADO POR CAUSA DA FORMULA //JDF
For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
 
	if 1=2 //JDF Rever processo muito lento
//		if ProTipCus = TipoCusto.CustoMedio
			AtualizaCustomedio_estoque.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &EstQTd, &EstQtdCus)
//			if EstQtdCus <> &EstQtdCus
//				&IsAtualizaCusto = true
//			Endif
//		Endif
	Endif
	EstSug = 0
	if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
		EstSug = EstSug_FORMULA
	Endif

	EstQtdCus = &EstQtdCus
EndFor

Commit

//if &IsAtualizaCusto = true
//	ProVlrCus_Produto.Call(&EmpCod, &ProCod)
//Endif
]]></Source>
