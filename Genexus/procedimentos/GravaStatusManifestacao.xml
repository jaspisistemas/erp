      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each order EmpCod,ManCod
	Where EmpCod = &EmpCod
	Where ManCod = &ManCod
	
	Do case
		Case &tpEvento = 210200 //Confirmacao da Operacao
			ManSts = Status_DFe.Confirmacao
			
		Case &tpEvento = 210210 //Ciencia da Operacao
			ManSts = Status_DFe.Ciencia
			
		Case &tpEvento = 210220 //Desconhecimento da Operacao
			ManSts = Status_DFe.Desconhecido
			
		Case &tpEvento = 210240 //Operacao nao Realizada
			ManSts = Status_DFe.NaoRealizada
	EndCase
	Exit
EndFor

Commit

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
