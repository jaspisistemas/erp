      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&EstQtd = 0
&EstSdo = 0
&EstLoc = ''
&Mensagem.SetEmpty()

For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGraCod > 1
	Where ProGraCod > 0
	
	if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
		
		&EstQtd = EstQtd
		&EstLoc = EstLoc
		&EstSdo = EstSdo
		if (&PedSts = Status_Pedido.FECHADO or &PedSts = Status_Pedido.SEPARANDO) and EstProStsBal = Status_SimNao.Sim
			&Mensagem = 'Produto em Balanço, não pode ser Alterado!'
		EndIF
	EndIF	
	Exit
When None
	IniciaEstoque.call(&EmpCod, &FilCod, &ProCod, &ProGraCod)
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
