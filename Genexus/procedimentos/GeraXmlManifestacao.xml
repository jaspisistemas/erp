      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
&Hoje = serverDate()
&versao = RetornaVersaoNotas.Udp(VersaoNota.VersaoDFeEvento)

For each order EmpCod,FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	If &Transmitir = 'S'
		//GERA ARQUIVO XML NA PASTA ENVIO
		&ArquivoEnvio.Source = &sdtConfiguracoesPasta.PastaNFenvio +trim(str(&Evento))+ TRIM(&ManCha) + '-ped-eve.xml'
		If &ArquivoEnvio.Exists()
			&ArquivoEnvio.Delete()
		EndIf	
		&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() +trim(str(&Evento))+ TRIM(&ManCha) +  '-ped-eve.xml'
	EndIf
	&ID = 'ID'+trim(str(&Evento))+TRIM(&ManCha)+'01'
	
	//http://www.flexdocs.com.br/guianfe/WS.evento.ManDest.html
	Do case
		Case &Evento = 210200 //Confirmacao da Operacao
			&descEvento = 'Confirmacao da Operacao'
			
		Case &Evento = 210210 //Ciencia da Operacao
			&descEvento = 'Ciencia da Operacao'
			
		Case &Evento = 210220 //Desconhecimento da Operacao
			&descEvento = 'Desconhecimento da Operacao'
			
		Case &Evento = 210240 //Operacao nao Realizada
			&descEvento = 'Operacao nao Realizada'
	EndCase

	AtualizaEventoManifestacao.call(&EmpCod,&ManCod,&Evento)

	&lote = Val(&ManNsu)
	&ArqDFe.Open(&Nome_enviar) // Abrir o arquivo XML
	&ArqDFe.WriteStartDocument('UTF-8')
	&ArqDFe.WriteStartElement('envEvento')
	&ArqDFe.WriteAttribute('versao',&versao)
	&ArqDFe.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')
	&ArqDFe.WriteElement('idLote',&lote)
	
	&ArqDFe.WriteStartElement('evento')
	&ArqDFe.WriteAttribute('versao',&versao)
	&ArqDFe.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')
	
	&ArqDFe.WriteStartElement('infEvento')
	&ArqDFe.WriteAttribute('Id',trim(&ID))
	&ArqDFe.WriteElement('cOrgao','91')
	&ArqDFe.WriteElement('tpAmb',FilAmbEms)
	
	retornaJuridicaFisica.call(FilCpj, &PesTip)
	
	If &PesTip = TipoPessoa.JURIDICA
		&ArqDFe.WriteElement('CNPJ',retornasoNumeros.Udp(FilCpj))
	Else
		&ArqDFe.WriteElement('CPF',retornasoNumeros.Udp(FilCpj))
	Endif

	&ArqDFe.WriteElement('chNFe',&ManCha)
	&soNumero = str(year(&Hoje),4,0) +'-'+padl(trim(str(month(&Hoje),2,0)),2,'0') +'-'+padl(trim(str(day(&Hoje),2,0)),2,'0') +'T'+trim(serverTime()) +'-'+ trim(FilFusHor)
	&ArqDFe.WriteElement('dhEvento',&soNumero)
	&ArqDFe.WriteElement('tpEvento',&Evento)
	&ArqDFe.WriteElement('nSeqEvento','1')
	&ArqDFe.WriteElement('verEvento',&versao)
	&ArqDFe.WriteStartElement('detEvento')
	&ArqDFe.WriteAttribute('versao',&versao)
	&ArqDFe.WriteElement('descEvento',trim(&descEvento))
	If not &xJust.Trim().IsEmpty()
		&ArqDFe.WriteElement('xJust',trim(&xJust))
	EndIf
	&ArqDFe.WriteEndElement()//dettEvento	
	&ArqDFe.WriteEndElement()//infEvento
	&ArqDFe.WriteEndElement()//evento
	&ArqDFe.WriteEndElement()//envEvento
	&ArqDFe.Close()
	exit
EndFor

If &Transmitir = 'S'	
	GravaSolicitacaoProgramada.Call(&EmpCod, &FilCod, &ManCod, 0, TipoSolicitacao.Manifestar_DFe, &PesCod, &SolCod, 5)
EndIF

