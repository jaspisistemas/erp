      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Total = 30
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
&Mensagem = ''
do 'Atualiza'
&NfeTenRet = 0

&IsContinua = true
do while &IsContinua = true
	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	&NfeTenRet += 1
	
	do 'VerificaRetorno'
	If not &Mensagem.IsEmpty()
		&IsContinua = false
		Exit
	EndIF
	
	If &NfeTenRet >= 30
		&IsContinua = false
		&Mensagem = 'Não foi possível a Obtenção do Retorno.'
		Exit
	Else
		&Dorme = sleep(2)
	EndIF
EndDo

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

sub 'VerificaRetorno'
	For Each Order SolEmpCod, SolCod
		Where SolEmpCod = &EmpCod
		Where SolCod = &SolCod
		Where SolMsg <> ''
		&Mensagem = SolMsg
		&Count += 30
		Exit
	EndFor	
EndSub

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &Mensagem
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &Mensagem
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub
]]></Source>
