      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if not &tmpNFeCod.IsEmpty()
	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNFeCod
		tmpNfeDI = &tmpNfeDI
		Exit
	EndFor
Else
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		NfeDI = &tmpNfeDI
		Exit
	EndFor
EndIF

Commit
]]></Source>
