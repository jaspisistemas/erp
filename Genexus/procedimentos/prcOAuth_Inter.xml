      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[/*
ENDPOINT com funcionalidade de gerar um token necessário para consumir APIs do INTER.
	° O tempo de vida de um token gerado é de uma hora. Com isso, é possível realizar
	um número determinado de requisições, de acordo com o rate limit de cada api.
		Rate Limit: 5 chamadas por minuto, ou uma chamada a cada 12 segundos.
		
Neste ENDPOINT, o sistema irá definir alguns valores padrões e montar o body da requisição
em formato x-ww-form-urlencoded. Posteriormente, montará o header da requisição e adicionar
o certificado referente a conta bancária na requisição. Após a adição, o sistema irá executar
um POST na URL referente ao ambiente de produção do banco INTER.

Responses:
	Sucesso:
		Code 200 = Sucesso. Token Emitido.
		
	Erros:
		Code 400 = Requisição com formato inválido, por exemplo erro de semântica.
		Code 403 = Requisição de participante autenticado que viola alguma regra de autorização. Verifique com o suporte do banco.
		Code 404 = Recurso solicitado não foi encontrado.
		Code 503 = Serviço não disponível no momento. O endpoint neste caso não funciona mais, ou está em manutenção.	
*/


Do 'GetContaBancaria'

//Define valores padrões
&DataHora			= ServerNow()
&Password			= '1234'
&Mensagem.SetEmpty()
&ErrorDescription.SetEmpty()

//Adiciona em uma variavel o body da requisição
//em formato x-ww-form-urlencoded
&xwwformurlencoded	= 'grant_type=client_credentials'
&xwwformurlencoded += '&client_id=' + &client_id
&xwwformurlencoded += '&client_secret=' + &client_secret
&xwwformurlencoded += '&scope=' + &scope

csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.SecurityProtocolType.Tls11 | System.Net.SecurityProtocolType.Tls;

//Configura os Headers e adiciona o body
&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
&HttpClient.AddHeader('Connection', 'keep-alive')
&HttpClient.AddHeader('Content-Type', 'application/x-www-form-urlencoded')
&HttpClient.AddString(&xwwformurlencoded)

PadraoUsuarioHora.Call('G', 'INTER_TOKENOAUTH_HTTPCLIENTantes', &PesCod, &EmpCod, &HttpClient.ToString(), &PadDtaMod,ServerNow(),'T')

//Carrega o Certificado ao Handler
CSHARP try
CSHARP { [!&HttpClient!].AddCertificate([!&PathCert!],[!&Password!]); }
CSHARP catch (Exception ex)
CSHARP { [!&ErrorDescription!] = ex.ToString();
CSHARP }

PadraoUsuarioHora.Call('G', 'INTER_TOKENOAUTH_HTTPCLIENT', &PesCod, &EmpCod, &HttpClient.ToString(), &PadDtaMod,ServerNow(),'T')

//Executa o post para adquirir o token de acesso.
&HttpClient.Execute('POST', 'https://cdpj.partners.bancointer.com.br/oauth/v2/token')
PadraoUsuarioHora.Call('G', 'INTER_TOKENOAUTH_HTTPCLIENTdepois', &PesCod, &EmpCod, &HttpClient.ToString(), &PadDtaMod,ServerNow(),'T')
PadraoUsuarioHora.Call('G', 'INTER_TOKENOAUTH_HTTPRequest', &PesCod, &EmpCod, &httpRequest.ToString(), &PadDtaMod,ServerNow(),'T')

If &HttpClient.StatusCode	= 200
	
	PadraoUsuarioHora.Call('G', 'INTER_TOKENOAUTH_SS', &PesCod, &EmpCod, 'SS', &PadDtaMod,ServerNow(),'T')
	
	&SdtOAuth_Inter.FromJson(&HttpClient.ToString())
	If Not &SdtOAuth_Inter.access_token.IsEmpty()
		Do 'GravaAutenticacaoLocalCobranca'
	EndIf
	
Else
	
	&SdtErroAPI_Inter.FromJson(&HttpClient.ToString())
	&Mensagem		= &SdtErroAPI_Inter.title + ' ' + &SdtErroAPI_Inter.detail
	
	If &SdtErroAPI_Inter.violacoes.Count >= 1
		For &violacoes In &SdtErroAPI_Inter.violacoes
			&Mensagem  += NewLine() + &violacoes.razao.Trim() + ' Propriedade: ' + &violacoes.propriedade.Trim()
		EndFor
	EndIf
	
	&Mensagem	   += IIf(&ErrorDescription.IsEmpty(), '', NewLine() + 'Erro CSHARP:' + &ErrorDescription.Trim())
	PadraoUsuarioHora.Call('G', 'INTER_TOKENOAUTH_ERRO', &PesCod, &EmpCod, &Mensagem, &PadDtaMod,ServerNow(),'T')
	
	if &Mensagem.IsEmpty() 
		&Mensagem = 'ERRO ' + trim(str(&HttpClient.StatusCode)) + ' - ' + &HttpClient.ToString() 
	Endif

EndIf



Sub 'GravaAutenticacaoLocalCobranca'
	
	For Each Order EmpCod, CbrCod, CbrTipImp
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&CbrChaTra		= &SdtOAuth_Inter.access_token.Trim()
		CbrChaTra		= &SdtOAuth_Inter.access_token.Trim()
		CbrChaTraVct	= &DataHora.AddSeconds(&SdtOAuth_Inter.expires_in)
		
		Exit
	EndFor
	Commit
	
EndSub

Sub 'GetContaBancaria'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&client_id		= CtaBanPixCliId
		&client_secret	= CtaBanPixCliSec
		&scope			= CtaBanPixEsc
		
		//Faz o genexus criar um arquivo temporario do certificado
		//Pega o caminho da web dele
		&Path			= PathToUrl(CtaBanPixCer)
		&InicioPath		= StrSearch(&Path, 'PublicTempStorage', 1)
		&Path			= SubStr(&Path, &InicioPath, &Path.Length())
		
		//Pesquisa o caminho fisico temporario do certificado
		&File.Source	= &Path
		&PathCert		= &File.GetAbsoluteName() // GetPath() + !"\" + &Path
		&PathCert		= StrReplace(&PathCert, '/', '\')
		&File.Close()		
		
		Exit
	EndFor
	
EndSub
]]></Source>
