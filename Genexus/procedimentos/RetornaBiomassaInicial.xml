      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&AloUniProBioMasIni = 0
For each Order EmpCod,LotCod
	Where EmpCod = &EmpCod
	Where LotCod = &AloLotCod
	&LotIniKgs = LotIniKgs
	Exit
EndFor

&AloUniProBioMasIni = &AloQtdUni * &LotIniKgs
]]></Source>
