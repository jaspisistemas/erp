      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&sdtLancamentos = dpLancamentosMaquininha(&EmpCod, &BanCarCod, &dataDia, &dataMes, &dataAno, &qtdItensMovimentacao, &statusConciliacao)
	
for &sdtLancamentoItem in &sdtLancamentos
	for each
		order EmpCod
		where EmpCod        =  &EmpCod
		where FilCod        =  &FilCod
		where CreFrpPgtoTip =  TipoDuplicata.CARTAOC or CreFrpPgtoTip = TipoDuplicata.CARTAOD
		where CreCarNroAut  =  &sdtLancamentoItem.LanMaqNroAut when not &sdtLancamentoItem.LanMaqNroAut.IsEmpty()
		where CreCarNroNsu  =  &sdtLancamentoItem.LanMaqNSU    when not &sdtLancamentoItem.LanMaqNSU.IsEmpty()
		where CreSts        <> Status_Duplicata.CANCELADA
		where CrePagSts     <> Status_Caixa.Cancelado
		where CreDtaVct     =  &sdtLancamentoItem.LanMaqDtaPgto
		where CreCarBanCod  =  &BanCarCod
		where CreVlrSdo     =  0
		
		for each Movimento
			where MovCod = CreMovCod
			where MovTip = TipoMovimento.RecebimentoCartao
			
			&sdtDuplicataItemConciliacao               = new()
			&sdtDuplicataItemConciliacao.CreCod        = CreCod
			&sdtDuplicataItemConciliacao.CreCliCod     = CreCliCod
			&sdtDuplicataItemConciliacao.CreCliRaz     = CreCliRaz
			&sdtDuplicataItemConciliacao.CreCliCodRaz  = CreCliCodRaz
			&sdtDuplicataItemConciliacao.CreDtaVct     = CreDtaVct
			&sdtDuplicataItemConciliacao.CreDtaEms     = CreDtaEms
			&sdtDuplicataItemConciliacao.CrePlanCod    = CrePlanCod
			&sdtDuplicataItemConciliacao.CreCarCreDeb  = CreCarCreDeb
			&sdtDuplicataItemConciliacao.CreCarBanNom  = CreCarBanNom
			&sdtDuplicataItemConciliacao.CreCarCardNom = CreCarCardNom
			&sdtDuplicataItemConciliacao.CreDupNro     = CreDupNro
			&sdtDuplicataItemConciliacao.CreVlrDup     = CreVlrDup
			&sdtDuplicataItemConciliacao.CreCarNroAut  = CreCarNroAut
			&sdtDuplicataItemConciliacao.CreCarNroNsu  = CreCarNroNsu
			&sdtDuplicataItemConciliacao.MovCpl        = 'CONCILIACAO:' + trim(str(CreCliCod)) + ' - ' + trim(CreCliRaz)
			&sdtDuplicataItemConciliacao.CrePagDta     = CrePagDta
			&sdtDuplicataItemConciliacao.CrePagVlrJur  = CrePagVlrJur
			&sdtDuplicataItemConciliacao.CrePagVlrDsc  = CrePagVlrDsc
			&sdtDuplicataItemConciliacao.CrePagVlrTar  = CrePagVlrTar
			&sdtLancamentoItem.duplicatas.Add(&sdtDuplicataItemConciliacao)
		endfor
	endfor
endfor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
