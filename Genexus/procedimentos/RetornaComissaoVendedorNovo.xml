      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedItmCom = 0 

        For Each Order EmpCod, PesCod, ComLctCod
			Where EmpCod = &EmpCod
	        Where PesCod = &PedVenCod
	        Where ComLctCod = &ComLctCod
			
			Do CAse
				CAse PesTipCom = 'N' // FIXA
					If &PedItmPrm = domPedItmPrm.PROMOCAO //TABELA PROMOCAO
		                &PedItmCom = ComTabPrm
		            Else //TABELA NORMAL
		                &PedItmCom = ComTabNor
		            EndIf
					
				Case PesTipCom = 'S' //FATURAMENTO
					For Each Order EmpCod, PesCod, ComLctCod, (ComFatVlr)
						Where ComFatVlr <= &TotalFaturadoMoeda
						
			            If &PedItmPrm = domPedItmPrm.PROMOCAO //TABELA PROMOCAO
			                &PedItmCom = ComFatTabPrm
			            Else //TABELA NORMAL
			                &PedItmCom = ComFatTabNor
			            EndIf						
						Exit
					EndFor
					
				Case PesTipCom = 'D' //DESCONTO
					For Each 
						Order EmpCod, PesCod, ComLctCod, (ComDscTax) when &TaxaDescontoItem >= 0
						Order EmpCod, PesCod, ComLctCod, ComDscTax when &TaxaDescontoItem < 0
						
						Where ComDscTax <= &TaxaDescontoItem  when &TaxaDescontoItem >= 0
						Where ComDscTax >= &TaxaDescontoItem  when &TaxaDescontoItem < 0
						
						Where ComDscTabCod = &tabCod or ComDscTabCod.IsEmpty() or ComDscTabCod.IsNull()
						Where ComDscTabColCod = &tabColCod or ComDscTabColCod.IsEmpty() or ComDscTabColCod.IsNull()
						
						If &PedItmPrm = domPedItmPrm.PROMOCAO //TABELA PROMOCAO
			                &PedItmCom = ComDscPrm
			            Else //TABELA NORMAL
			                &PedItmCom = ComDscNor
			            EndIf
						Exit
					EndFor
			EndCase
			
			Exit
        EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
      </Part>
