      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, EmlTip, EmlCod
	where EmpCod = &EmpCod
	where EmlTip = &EmlTip
	where EmlCod = &EmlCod	
	
	If &EmlSts <> Status_Solicitacao.Pendente //or &tentativa >= 10
		EmlMsg = &EmlMsg
		EmlDtaEnv = serverdate()
		EmlHorEnv = serverTime()
		EmlSts = &EmlSts
	Else
		EmlQtdTen += 1
		
		If EmlQtdTen > 1
			EmlMsg = 'Atingido Tempo limite de Resposta!'
			EmlDtaEnv = serverdate()
			EmlHorEnv = serverTime()
			EmlSts = Status_Solicitacao.Falha
		EndIF
	EndIF
	
	Exit
EndFor

commit
]]></Source>
