      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem = ''

RetornaRegimeTributarioFilial.Call(&EmpCod, &FilBasImp, &FilRegTrib, &TbImpUfeCod)
//For Each Order EmpCod, TbImpFilCod
//	Where EmpCod = &EmpCod
//	Wheore TbImpFilCod = &FilCod
//	&FilRegTrib = TbFilRegTrib
//endfor

//if not &FilRegTrib.IsEmpty() //PEGA DA FILIAL PELA COMPATIBILIDADE, DEPOIS NAO VAI MAIS TER. JDF
//	For Each Order EmpCod, FilCod
//		Where EmpCod = &EmpCod
//		Where FilCod = &FilCod
//		&FilRegTrib = FilRegTrib
//	endfor
//Endif


if not &SitCod in (2,15,53,61)
	if &FilRegTrib <> RegimeTributario.SimplesNacional and &FilRegTrib <> RegimeTributario.MEI 
		if not &SitCod in (0,2,10,15,20,30,40,41,50,51,53,60,61,70,90)
			&Mensagem = format('A CST para Regime "%1" devem ser uma das opções (0,10,20,30,40,41,50,51,60,70,90), CST: %2 inválida!', &FilRegTrib.EnumerationDescription(), trim(str(&SitCod)))
		EndIf
	else
		if not &SitCod in (101,102,103,201,202,203,300,400,500,900)
			&Mensagem = format('A CSOSN para Regime "%1" devem ser uma das opções (101,102,103,201,202,203,300,400,500,900), CSOSN: %2 inválida!', &FilRegTrib.EnumerationDescription(), trim(str(&SitCod)))
		EndIf
	EndIF
EndIf
]]></Source>
