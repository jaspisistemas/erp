      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//DELETA NOVA FOLHA PAGAMENTO
For each Order EmpCod,FPagAno,FPagMes,FPagPesCod, FPagCtaMovCod, FPagCtaMovItmCod
	Where EmpCod = &EmpCod
	Where FPagAno = &FPagAno
	Where FPagMes = &FPagMes
	Where FPagPesCod = &FPagPesCod
	Where FPagCtaMovCod = &MovCod When not &MovCod.IsEmpty()
	Where FPagCtaMovItmCod = &MovItmCod When not &MovItmCod.IsEmpty()
	
	FPagCtaMovCod.SetEmpty()
	FPagCtaMovItmCod.SetEmpty()
EndFor

Commit

AtualizaStatusPagamentoFolha.Call(&EmpcOD,&FPagAno,&FPagMes)
]]></Source>
