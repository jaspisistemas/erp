      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	For each Order EmpCod, FilCod, NfeCod, NfeItmCod //Itens		
		For each Order EmpCod, FilCod, NfeCod, NfeItmCod, NfeProLotCod //Lotes
			Delete
		EndFor
	
		Delete
	EndFor
	
	For Each Order EmpCod, FilCod, NfeCod, NfeSelPedCod //NotasPedidos
		Delete
	EndFor
	
	For each Order EmpCod,FilCod,NfeCod,NfeDupItmCod //DUPLICATAS
		Delete 
	EndFor
	
	For Each Order EmpCod,FilCod,NfeCod,NfeCCeCod //CCE
		Delete
	EndFor	
	
	For Each Order EmpCod, FilCod, NfeCod, NfeDocRefCod //NotasDocumentosReferenciados
		delete
	EndFor
	
	Delete	
EndFor

commit



]]></Source>
