      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	CtePosDocAnt = Status_SimNao.Sim
	Exit
EndFor


For Each Order EmpCod,FilCod,CteCod,CteDocAntChv //se achar atualiza
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteDocAntChv = &CteDocAntChv
	
	If &CteDocAntCnpj.Length() > 14
		CteDocAntCnpj = &CteDocAntCnpj
	Else
		CteDocAntCpf = &CteDocAntCnpj
	EndIf
	CteDocAntIns = &CteDocAntIns
	CteDocAntUf = &CteDocAntUf
	CteDocAntRaz = trim(&CteDocAntRaz)
	
	Exit
When none	//senao insere
	&CteDocAntCod = 0
	For Each Order EmpCod,FilCod,CteCod,(CteDocAntCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&CteDocAntCod = CteDocAntCod
		exit
	EndFor
	&CteDocAntCod += 1
	
	New 
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteDocAntCod = &CteDocAntCod
		If &CteDocAntCnpj.Length() > 14
			CteDocAntCnpj = &CteDocAntCnpj
		Else
			CteDocAntCpf = &CteDocAntCnpj
		EndIf
		CteDocAntIns = &CteDocAntIns
		CteDocAntUf = &CteDocAntUf
		CteDocAntRaz = trim(&CteDocAntRaz)
		CteDocAntChv = &CteDocAntChv
		
	EndNew
EndFor


]]></Source>
