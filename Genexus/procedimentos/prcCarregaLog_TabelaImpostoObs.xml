      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each order EmpCod, ImpLctCod, ImpFilCod, ImpUfeCod, ImpGruImpCod, ImpCatCod, ObsCod
	Where EmpCod = &EmpCod
	Where ImpLctCod = &ImpLctCod
	Where ImpFilCod = &ImpFilCod
	Where ImpUfeCod = &ImpUfeCod
	Where ImpGruImpCod = &ImpGruImpCod
	Where ImpCatCod = &ImpCatCod
	
	&IdVarchar = trim(str(ObsCod))
	prcLogAddSdtLevel.Call(&IdVarchar, 'ObsCod', trim(str(ObsCod)), '', &sdtLogAtributosLevel)
	
EndFor
]]></Source>
