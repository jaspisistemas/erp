      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
&versao = '1.01'//RetornaVersaoNotas.Udp(VersaoNota.VersaoDFe)
For each order EmpCod,FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	If &Transmitir = 'S'
		//GERA ARQUIVO XML NA PASTA ENVIO
		&ArquivoEnvio.Source = &sdtConfiguracoesPasta.PastaNFenvio + &ManCha.Trim() + '-con-dist-dfe.xml'
		If &ArquivoEnvio.Exists()
			&ArquivoEnvio.Delete()
		EndIf	
		&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + &ManCha.Trim() + '-con-dist-dfe.xml'
	EndIf

	&FilAmbEms = FilAmbEms
	&FilCidUfeIbge = FilCidUfeIbge
	&FilCpj = FilCpj
	
	retornaJuridicaFisica.call(FilCpj, &PesTip)
	
	exit
EndFor

&ArqDFe.Open(&Nome_enviar) // Abrir o arquivo XML
&ArqDFe.WriteStartDocument('UTF-8')
&ArqDFe.WriteStartElement('distDFeInt')
&ArqDFe.WriteAttribute('versao',&versao)
&ArqDFe.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')
&ArqDFe.WriteElement('tpAmb',&FilAmbEms)
&ArqDFe.WriteElement('cUFAutor',SubStr(trim(str(&FilCidUfeIbge)),1,2))

if &PesTip = TipoPessoa.JURIDICA
	&ArqDFe.WriteElement('CNPJ',retornasoNumeros.Udp(&FilCpj))
Else
	&ArqDFe.WriteElement('CPF',retornasoNumeros.Udp(&FilCpj))
Endif

&ArqDFe.WriteStartElement('consChNFe')
&ArqDFe.WriteElement('chNFe',&ManCha)
&ArqDFe.WriteEndElement()//InfCte	
&ArqDFe.WriteEndElement()//CTe	
&ArqDFe.Close()

If &Transmitir = 'S'	
	RetornaexisteSolicitacaoPendente.Call(&EmpCod, &FilCod, &ManCod, 0, TipoSolicitacao.DownloadXML_DFe, &IsPendente, &SolCod)
	if &SolCod.IsEmpty()
		GravaSolicitacaoProgramada.Call(&EmpCod, &FilCod, &ManCod, 0, TipoSolicitacao.DownloadXML_DFe, &PesCod, 0, &SolCod)
	Endif

EndIF

]]></Source>
