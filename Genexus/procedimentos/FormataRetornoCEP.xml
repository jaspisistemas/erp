      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&SaidaVarchar = ''
&PesLog.SetEmpty()
&PesCPL.setEmpty()
&PesBai.SetEmpty()

&XmlReader.OpenFromString(&EntradaVarchar)
&ret = &XmlReader.ReadType(1, 'webservicecep') 
if &ret <> 0
	&XmlReader.Read()
	Do While &XmlReader.Name <> 'webservicecep'
		Do CAse
			Case &XmlReader.Name = 'resultado_txt'
				&SaidaVarchar = 'STATUS: ' + trim(&XmlReader.Value)
			CAse &XmlReader.Name = 'uf'
				&SaidaVarchar += newLine() + 'UF : ' +  trim(&XmlReader.Value)
			Case &XmlReader.Name = 'cidade'
				&SaidaVarchar += newLine() + 'CIDADE: ' + trim(&XmlReader.Value)
			Case &XmlReader.Name = 'bairro'
				&PesBai = trim(&XmlReader.Value)
			Case &XmlReader.Name = 'tipo_logradouro'
				&PesCPL = trim(&XmlReader.Value)
			Case &XmlReader.Name = 'logradouro'
				&PesLog = trim(&XmlReader.Value)
		EndCase
		&XmlReader.Read()
	EndDo
endif
&XmlReader.Close()

&SaidaVarchar += NewLine()
If &PesBai <> ''
	&SaidaVarchar += NewLine() + 'BAIRRO: ' + trim(&PesBai)
EndIF

If &PesLog <> ''
	&SaidaVarchar += NewLine() + 'LOGRADOURO: '
	if &PesCPL <> ''
		&SaidaVarchar +=  trim(&PesCPL) 
	EndIF
 	&SaidaVarchar += ' ' + trim(&PesLog)
EndIF
]]></Source>
