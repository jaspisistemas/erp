      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsDisponivel = false
&Mensagem = ''
For Each Order EmpCod, CheTip, CheNro, TalCtabanCod, CheCod
	Where EmpCod = &EmpCod
	Where CheTip = TipoCheque.Proprio
	Where TalCtabanCod = &ProCheCtaBanCod
	Where CheNro = &ProCheNro
	
	&ProCheAgeCod = CheAgeCod
	&ProCheBanCod = CheBanCod
	&ProCheCon = CheCon
	
	if not CheCreCod.IsEmpty() or not CheCreCod.IsNull() or CheMot <> MotivoCheque.NAOEMITIDO
		&IsDisponivel = true
		&Mensagem = 'Cheque já utilizado!'
	Endif
	
	Exit
when none 
	&Mensagem = 'Cheque não Localizado!'
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
