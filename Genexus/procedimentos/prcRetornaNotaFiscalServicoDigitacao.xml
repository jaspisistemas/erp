      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, NfsPedFilCod, NfsPedCod, NfsSts, NfsProTer, NfsCod
	Where EmpCod = &EmpCod
	Where NfsPedFilCod = &FilCod
	Where NfsPedCod = &PedCod
	Where NfsSts = Status_Nfe.Digitando
	Where NfsProTer = Nota_ProPriaTerceira.PROPRIA
	Where NfsIsEnv = false //NOTA AINDA NAO TRANSMITIDA
	
		&NfsCod = NfsCod		
	Exit
EndFor
]]></Source>
