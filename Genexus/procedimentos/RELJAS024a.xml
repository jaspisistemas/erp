      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

if &TipoCurva = 'V' and  &ListarEstoque <> Status_SimNao.Sim
	&TituloCurva = 'ABC Rent.'
Else
	&TituloCurva = 'ABC Qtd.'
EndiF

Header
	&titulo = 'LISTAGEM DE PRODUTOS POR CURVA ABC'
	print Cabecalho
	
	If &ListarEstoque <> Status_SimNao.Sim
		print tituloSemEstoque
	Else
		print TituloProduto
	EndIF
End

&TotalQtdCurvaD.SetEmpty()
&TotalQtdCurvaB.SetEmpty()
&TotalQtdCurvaC.SetEmpty()
&TotalQtdCurvaA.SetEmpty()
&IsImprime = false

&AuxLisGrupHie = trim(&LisGrupHie) + '.'

For Each
	Order  EmpCod, FilCod, ProCod When &Ordem = 'C'
	Order  EmpCod, FilCod, ProNom When &Ordem = 'N'
	Order  EmpCod, FilCod, EstLoc When &Ordem = 'L'
	Order EmpCod, FilCod, EstABC_Ren When &Ordem = 'A' and &TipoCurva = 'V'
	Order EmpCod, FilCod, EstABC_Qtd When &Ordem = 'A' and &TipoCurva = 'Q'
	Where ProSts = &LisProSts when not &LisProSts.IsEmpty()
	where ProSts <> Status_Produto.EXCLUIDO when &LisProSts.IsEmpty()
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where EstABC_Ren = &QualCurva When &QualCurva <> '0' and &TipoCurva = 'V'
	Where EstABC_Qtd = &QualCurva When &QualCurva <> '0' and &TipoCurva = 'Q'
	Where ProPadForCod = &ProPadForCod when not &ProPadForCod.IsEmpty()
	Where EstQtd > 0 when &SomenteComEstoque = Status_SimNao.Sim
	Where GrupHie = &LisGrupHie or GrupHie like &AuxLisGrupHie when not &LisGrupHie.IsEmpty()
	if &TipoCurva = 'V'
		&Curva = EstABC_Ren
	Else
		&Curva = EstABC_Qtd
	EndIF

	if not &Curva in ('A', 'B', 'C')
		&Curva = 'D'
	EndIF
	
	if &Ordem = 'A' and &OldCurva <> &Curva and &OldCurva <> '' and &ListarEstoque = Status_SimNao.Sim
		
		Do CAse
			Case &OldCurva = 'A'
				&TotalQtdCurva = &TotalQtdCurvaA
				&NomeTotalCurva = 'TOTAL CURVA A:'
			Case &OldCurva = 'B'
				&TotalQtdCurva = &TotalQtdCurvaB
				&NomeTotalCurva = 'TOTAL CURVA B:'
			Case &OldCurva = 'C'
				&TotalQtdCurva = &TotalQtdCurvaC
				&NomeTotalCurva = 'TOTAL CURVA C:'
			Otherwise
				&TotalQtdCurva = &TotalQtdCurvaD
				&NomeTotalCurva = 'TOTAL CURVA D:'
		EndCAse
		&IsImprime = true
		print TotalCurva
	EndIF
	
	&EstABC_Qtd = EstABC_Qtd
	if not EstABC_Qtd in ('A', 'B', 'C')
		&EstABC_Qtd = 'D'
	EndIF
	
	&EstABC_Ren = EstABC_Ren
	if not EstABC_Ren in ('A', 'B', 'C')
		&EstABC_Ren = 'D'
	EndIF
	
	&EstQtd = EstQtd
	
	if &ListarEstoque <> Status_SimNao.Sim
		print printSemEstoque
	Else
		print ProdutoDescricao
		
		If EstQtd > 0 
			Do CAse
				Case &Curva = 'A'
					&TotalQtdCurvaA += EstQtd
				Case &Curva = 'B'
					&TotalQtdCurvaB += EstQtd
				Case &Curva = 'C'
					&TotalQtdCurvaC += EstQtd
				Otherwise
					&TotalQtdCurvaD += EstQtd
			EndCAse
		EndIF
	EndIF

	&OldCurva = &Curva
	&IsImprime = false
	
EndFor

if &IsImprime = false and &Ordem = 'A'  and &ListarEstoque = Status_SimNao.Sim
	Do CAse
		Case &Curva = 'A'
			&TotalQtdCurva = &TotalQtdCurvaA
			&NomeTotalCurva = 'TOTAL CURVA A:'
		Case &Curva = 'B'
			&TotalQtdCurva = &TotalQtdCurvaB
			&NomeTotalCurva = 'TOTAL CURVA B:'
		Case &Curva = 'C'
			&TotalQtdCurva = &TotalQtdCurvaC
			&NomeTotalCurva = 'TOTAL CURVA C:'
		Otherwise
			&TotalQtdCurva = &TotalQtdCurvaD
			&NomeTotalCurva = 'TOTAL CURVA D:'
	EndCAse
	
	print TotalCurva
Else
	If &QualCurva <> '0'  and &ListarEstoque = Status_SimNao.Sim
		Do CAse
			Case &Curva = 'A'
				&TotalQtdCurva = &TotalQtdCurvaA
				&NomeTotalCurva = 'TOTAL CURVA A:'
			Case &Curva = 'B'
				&TotalQtdCurva = &TotalQtdCurvaB
				&NomeTotalCurva = 'TOTAL CURVA B:'
			Case &Curva = 'C'
				&TotalQtdCurva = &TotalQtdCurvaC
				&NomeTotalCurva = 'TOTAL CURVA C:'
			Otherwise
				&TotalQtdCurva = &TotalQtdCurvaD
				&NomeTotalCurva = 'TOTAL CURVA D:'
		EndCAse
		
		print TotalCurva
	EndIF
EndIF

If &QualCurva = '0'  and &ListarEstoque = Status_SimNao.Sim
	&TotalQtdCurva = &TotalQtdCurvaA + &TotalQtdCurvaB + &TotalQtdCurvaC + &TotalQtdCurvaD
	&NomeTotalCurva = 'TOTAL CURVAS:'
	
	print TotalCurva
EndiF



Footer
	print Rodape
End
]]></Source>
