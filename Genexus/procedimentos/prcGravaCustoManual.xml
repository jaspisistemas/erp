      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[if &ProTipCus = TipoCusto.CustoFixo
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		ProVlrCusFix = &ProCusVlr
		Exit
	EndFor
	
	Commit
Else
	
	&ProCusCod = 0
	For Each Order EmpCod, ProCod, (ProCusCod)
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&ProCusCod = ProCusCod
		Exit
	EndFor
	&ProCusCod += 1
	
	new
		EmpCod = &EmpCod
		ProCod = &ProCod
		ProCusCod = &ProCusCod
		ProCusDta = serverdate()
		ProCusHor = ServerTime()
		ProCusVlr = &ProCusVlr
		ProCusFunCod = &PesCod
	EndNEw
	
	Commit
Endif

ProVlrCus_Produto.Call(&EmpCod, &ProCod)
]]></Source>
