      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsSemEstoque = false

For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &Filcod
	Where PedCod = &PedCod
	Where ProEstTip <> TipoEstoque.NAO_ATUALIZA
	Where PedQtd > 0
	
	Do Case
		Case ProCod = PedProEstProCod and PedQtd > EstQtd and (ProAtuEst.IsEmpty() or ProAtuEst.IsNull() or ProAtuEst = false)
	 	   //Obs não valida os itens da receita
		   	&IsSemEstoque = true
			
		Case  ProCod <> PedProEstProCod and ProEstTip = TipoEstoque.ATUALIZAR_OUTRO_PRODUTO // vai verificar o estoque do outro produto
			VerificaProdutoSemEstoqueOutro.call(EmpCod,FilCod,PedProEstProCod,PedProEstProGraCod,PedQtd,&IsSemEstoque)
		 	//Se caiu aqui é que atualiza estoque de outro produto e a quatidade é maior.
	EndCase
	
	If &IsSemEstoque = true
		Exit
	EndIf   
EndFor


]]></Source>
