      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&QtdBolSemReg = 0
For each order EmpCod,CreCod
	where EmpCod = &EmpCod
	where CreSts <> Status_Duplicata.CANCELADA
	where CreVlrSdo = CreVlrDup
	Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
	where CreDtaRet.IsEmpty() or CreDtaRet.IsNull()
	where CreRecPag = ReceberPagar.Receber
	where CreCrbRegAut = Status_SimNao.Sim
	Where CreDtaVct >= serverdate()
	&QtdBolSemReg += 1
EndFor
]]></Source>
