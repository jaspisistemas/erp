        <Source><![CDATA[
&PesRaz = ''
&PesIsVen = false
For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	&PesRaz = PesRaz
	&PesIsVen = PesIsVen
	if (not PesDtaDem.IsEmpty()) and (not PesDtaDem.IsNull())
		&PesIsVen = false
	EndIF

	Exit
EndFor

	
]]></Source>
