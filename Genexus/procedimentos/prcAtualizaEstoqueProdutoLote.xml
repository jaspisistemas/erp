      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedQtd = &EstLotQtdEnt + &EstLotQtdSai

If &Sinal = '+' //SOMAR
	&EstLotQtd = &PedQtd
	&AuxEstLotQtdEnt = &EstLotQtdEnt
	&AuxEstLotQtdSai = &EstLotQtdSai

Else //DIMINUIR
	&EstLotQtd = &PedQtd * -1
	&AuxEstLotQtdEnt = &EstLotQtdEnt * -1
	&AuxEstLotQtdSai = &EstLotQtdSai * -1
EndIF	


If not &PedDtaFat.IsEmpty()
	&EstLotAno = year(&PedDtaFat)
	&EstLotMes = month(&PedDtaFat)
Else
	&EstLotAno = year(Serverdate())
	&EstLotMes = month(Serverdate())
EndIF

//UltimasDatasEstoqueCliente.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &EstLotCod, &EstCliUltSai)

For Each Order EmpCod, FilCod ProCod, ProGraCod,EstLotCod //ESTOQUE LOTE
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstLotCod = &EstLotCod
	
	
	//Atençao só atualiza os dados do lote se ele não existir por exemplo VCTO
	if (EstLotVct.IsEmpty() and not &EstLotVct.IsEmpty() and EstLotVct < &EstLotVct) or (not &EstLotVct.IsEmpty() and EstLotQtd = 0) 
		EstLotVct = &EstLotVct
	Endif
	
	If (EstLotFab.IsEmpty() and not &EstLotFab.IsEmpty()) or (not &EstLotFab.IsEmpty() and EstLotQtd = 0) 
		EstLotFab = &EstLotfab
	EndIf
	
	If EstLotGer.IsEmpty() and not &EstLotGer.IsEmpty()
		EstLotGer = &EstLotGer
	Endif

	If EstLotPen.IsEmpty() and not &EstLotPen.isEmpty()
		EstLotPen = &EstLotPen
	EndIf
	
	If EstLotPms.IsEmpty() and not &EstLotPms.IsEmpty()
		EstLotPms = &EstLotPms
	EndIf
	
	If EstLotPur.IsEmpty() and not &EstLotPur.IsEmpty()
		EstLotPur = &EstLotPur
	EndIf
	
	If EstLotRen.Trim().IsEmpty() and not &EstLotRen.Trim().IsEmpty()
		EstLotRen = &EstLotRen
	EndIf

	
	EstLotQtd += &EstLotQtd
	
	Exit
When None
    New   //ESTOQUE
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstLotCod = &EstLotCod
		EstLotVct = &EstLotVct
		EstLotFab = &EstLotFab
		EstLotQtd = &EstLotQtd
		EstLotGer = &EstLotGer
		EstLotPen = &EstLotPen
		EstLotPms = &EstLotPms
		EstLotPur = &EstLotPur
		EstLotRen = &EstLotRen
    EndNew
EndFor


commit


//ESTOQUE LOTE MES
For Each Order EmpCod, FilCod ProCod, ProGraCod,EstLotCod,EstLotAno,EstLotMes
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstLotCod = &EstLotCod
	Where EstLotAno = &EstLotAno
	Where EstLotMes = &EstLotMes
	
	EstLotQtdEnt += &AuxEstLotQtdEnt
	EstLotQtdSai += &AuxEstLotQtdSai
	
	EstLotQtdSdo = (EstLotQtdAnt + EstLotQtdEnt) - EstLotQtdSai
	
	//VERIFICA MESES PARA FRENTE
	Do 'MesesFrente'
	
	Exit
When None
	
	//VERIFICAR MESES ANTERIORES
	do 'MES_ANTERIOR'
	
	New
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstLotCod = &EstLotCod
		EstLotAno = &EstLotAno
		EstLotMes = &EstLotMes
				
		EstLotQtdAnt = &AntEstLotQtdAnt
		EstLotQtdEnt += &AuxEstLotQtdEnt
		EstLotQtdSai += &AuxEstLotQtdSai
		EstLotQtdSdo = (&AntEstLotQtdAnt + EstLotQtdEnt) - EstLotQtdSai
	EndNew

	//VERIFICA MESES PARA FRENTE
	Do 'MesesFrente'
EndFor

commit


Sub 'MES_ANTERIOR'
    &AntEstLotQtdAnt = 0
	
	For Each Order EmpCod, FilCod ProCod, ProGraCod,EstLotCod,(EstLotAno),(EstLotMes)
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
    Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstLotCod = &EstLotCod
	Where (EstLotAno = &EstLotAno and EstLotMes < &EstLotMes) or EstLotAno < &EstLotAno 
		&AntEstLotQtdAnt = EstLotQtdSdo
        exit
    EndFor
EndSub


Sub 'MesesFrente'
	For Each Order EmpCod, FilCod ProCod, ProGraCod,EstLotCod,EstLotAno,EstLotMes
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where EstLotCod = &EstLotCod
		Where (EstLotAno = &EstLotAno and EstLotMes > &EstLotMes) or EstLotAno > &EstLotAno 
		
		EstLotQtdAnt += &EstLotQtd		
		EstLotQtdSdo += &EstLotQtd	
    EndFor
EndSub
]]></Source>
