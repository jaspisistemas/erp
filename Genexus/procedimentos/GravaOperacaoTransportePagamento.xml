      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

iF &OQUEFAZER = 'ADD'
	
	For Each Order EmpCod,FilCod,OpeCod
		Where EmpCod 	= &EmpCod
		Where FilCod	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&OpePgtDoc		= OpeNroDoc
		
		If OpeEmiGra = True
			&OpePgtTip	= PefServiceTipoPagamento.TransferenciaBancaria
		Else
			&OpePgtTip	= PefServiceTipoPagamento.eFRETE
		EndIf

//		For Each Order EmpCod, FilCod, OpeCod, OpeViaCod
//			Where OpeViaCod = 1
//			
//			&OpePgtTip	= OpePgtTip
//			
//			Exit
//		EndFor
		
		For each order EmpCod,FilCod,OpeCod,(OpePgtCod)
			&auxOpePgtCod 	= OpePgtCod
			exit
		EndFor
	
		Exit
	EndFor
	
	&auxOpePgtCod 	+=1
	&OpePgtNro 		= Padl(Str(&EmpCod),6,'0') + Padl(Str(&FilCod),6,'0')+ Padl(Str(&auxOpePgtCod),6,'0')	
	
	New
		EmpCod 			= &EmpCod
		FilCod 			= &FilCod
		OpeCod 			= &OpeCod
		OpePgtCod 		= &auxOpePgtCod
		OpePgtNro		= &OpePgtNro
		OpeDtaLib 		= &OpeDtaLib
		OpePgtBan 		= &OpePgtBan
		OpePgtConTip 	= &OpePgtConTip
		OpePgtAge		= &OpePgtAge
		OpePgtCon 		= &OpePgtCon
		OpePgtVal 		= &OpePgtVal
		OpePgtTip 		= &OpePgtTip
		OpePgtCat 		= &OpePgtCat
		OpePgtDoc 		= &OpePgtDoc
		OpePgtSts		= Status_AtivoInativo.ATIVO
		OpePgtSit		= Status_AbertoFechado.Aberto
	EndNew
	
	COMMIT
Else
	For each order EmpCod,FilCod,OpeCod,OpePgtCod
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		Where OpePgtCod = &OpePgtCod
		Delete
	EndFor
EndIF

]]></Source>
