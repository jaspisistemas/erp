      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TpaCod.SetEmpty()
For Each ORder EmpCod, TpaCod
	Where EmpCod = &EmpCod
	Where TpaNom = 'OUTROS TIPOS'
	&TpaCod = TpaCod
	Exit
	
When none
	UltimoCodigoEmpresa.Call(domParCod.TIPOANEXOS, &EmpCod, 0, &TpaCod)
	
	new
		EmpCod = &EmpCod
		TpaCod = &TpaCod
		TpaNom = 'OUTROS TIPOS'
		TpaOrd = 999999
		TpaPed = 1
		TpaPes = 1
	EndNew

	Commit
EndFor

	
]]></Source>
