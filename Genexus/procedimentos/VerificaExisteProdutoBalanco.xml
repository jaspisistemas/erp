      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&BalQtd = 0
For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where BalCod = &BalCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
    &BalQtd = BalQtd
	
	Exit
EndFor
]]></Source>
