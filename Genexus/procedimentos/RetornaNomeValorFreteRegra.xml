      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&mensagem = ''
For Each Order EmpCod, RFrtCod
	Where EmpCod = &EmpCod
	Where RFrtCod = &RFrtCod
	
	 Do CAse
		 CAse &RetornaValor = 'S' and  RFrtVlr > 0
			Do CAse
				Case RFrtSinVlr = MaiorMenor.Maior
					&mensagem = 'MAIOR: R$ ' + trim(toformattedString(RFrtVlr))
					
				Case RFrtSinVlr = MaiorMenor.Menor
					&mensagem = 'MENOR: R$ ' + trim(toformattedString(RFrtVlr))  + NewLine()
			EndCase
			
		CAse &RetornaValor = 'N' and  RFrtPer > 0
			Do CAse
				Case RFrtSinPer = MaiorMenor.Maior
					&mensagem = 'MAIOR: ' + trim(toformattedString(RFrtPer)) + '%' + NewLine()
					
				Case RFrtSinPer = MaiorMenor.Menor
					&mensagem = 'MENOR: ' + trim(toformattedString(RFrtPer)) + '%' + NewLine()
			EndCase
			
		CAse &RetornaValor = 'U'
			if RFrtIsAllUF = true
				&mensagem = 'TODAS AS UFs'
			Else
				For Each Order EmpCod, RFrtCod, RFrtUfeCod
					if not &mensagem.IsEmpty()
						&mensagem += ', '
					EndIF
					&mensagem += RFrtUfeCod
				EndFor
			EndIF	
			
		CAse &RetornaValor = 'T'
			if RFrtIsAllTab = true
				&mensagem = 'TODAS AS TABELAS'
			Else
				For Each Order EmpCod, RFrtCod, RFrtTabCod
					if not &mensagem.IsEmpty()
						&mensagem += ', '
					EndIF
					&mensagem += RFrtTabCod
				EndFor
			EndIF	
	EndCase
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
