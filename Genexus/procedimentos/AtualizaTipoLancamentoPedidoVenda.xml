      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAtualizaValoresUnitarios = false

For each Order EmpCod,FilCod,PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&PedCod))
		&LogErpRegTip = TrnMode.Update
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'LctCod', trim(toformattedString(LctCod)), trim(toformattedString(&LctCod)), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	if LctRetCus = Status_SimNao.Sim or LctInfPrc = Status_SimNao.Nao
		&IsAtualizaValoresUnitarios = true
	Else		
		prcRetornaDadosTipoLancamentoDados.call(EmpCod, &LctCod, &LctRetCus, &LctInfPrc, &LctTabColCod)
		if &LctRetCus = Status_SimNao.Sim or &LctInfPrc = Status_SimNao.Nao or (&LctTabColCod <> TabColCod and &LctTabColCod > 0)
			&IsAtualizaValoresUnitarios = true
			
			if &LogErpTabIsLog = true //GRAVA LOG
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TabColCod', trim(toformattedString(TabColCod)), trim(toformattedString(&LctTabColCod)), &LogErpRegGUID )
			Endif
		
			if &LctTabColCod > 0
				TabColCod = &LctTabColCod //TEM QUE FICAR DENTRO. POR CAUSA DA COLUNA	
			Endif
		EndIf
	EndIf

	LctCod = &LctCod
	
	Exit
EndFor

commit

AtualizaPrecosPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, &IsAtualizaValoresUnitarios)

If &OldLctCod <> &LctCod
	AtualizaPedidoEstoqueVendidoComprado.Call(&EmpCod, &FilCod, &PedCod)
EndIF
]]></Source>
