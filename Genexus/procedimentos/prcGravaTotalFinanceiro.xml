      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


if &OqueFazer = 'ADD'
	For Each Order EmpCod, PlanCod, FinAno, FinMes
		Where EmpCod = &EmpCod
		Where PlanCod = &PlanCod
		Where FinAno = &FinAno
		Where FinMes = &FinMes
		
		FinVlr = &FinVlr
		Exit
	When none
		new
			EmpCod = &EmpCod
			PlanCod = &PlanCod
			FinAno = &FinAno
			FinMes = &FinMes
			FinVlr = &FinVlr
		EndNew
	EndFor
Else
	For Each Order EmpCod, PlanCod, FinAno, FinMes
		Where EmpCod = &EmpCod
		Where PlanCod = &PlanCod
		Where FinAno = &FinAno
		Where FinMes = &FinMes
	
		Delete
	EndFor
EndIf

Commit
]]></Source>
