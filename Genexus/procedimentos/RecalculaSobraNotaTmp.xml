      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For each Order EmpCod, FilCod, PedCod  //pega o item do pedido a quantidade, valor total e unitario
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod		
	&PedItmCod = PedItmCod		
	&PedQtd = PedQtd
	&PedVlrUntDsc = PedVlrUnt
	&PedVlrItm = PedVlrItm
	
	Do 'GetItemNotaQtd' //verifica a quantidade da nota
	Do 'AtualizaNovoValor'
	Do 'GetItemNotaValor'
EndFor

Sub 'GetItemNotaQtd'
	&TmpPedQtd = 0
	&TmpPedVlrtot = 0
	&auxPedQtd = 0
	do 'Soma'
	
	If  &PedQtd <> &TmpPedQtd //Calcula a diferença de quantidade do pedido para nota 
		&auxPedQtd = &PedQtd - &TmpPedQtd
	EndIf

	//############### Atualiza somando a diferença, da quantidade ################################################################
	For each Order tmpEmpCod,tmpFilCod,tmpPedCod,tmpNfeItmCod 
		Where tmpEmpCod = &EmpCod
		Where tmpFilCod = &FilCod
		Where tmpPedCod = &PedCod
		Where tmpNfeItmCod = &PedItmCod
		tmpPedQtd += &auxPedQtd
		tmpPedQtdFat += &auxPedQtd
		exit
	EndFor
commit
EndSub

Sub 'Soma'
	// ##################################### pega todas a notas com mesmo pedido e produto e soma #######################################
	For each Order tmpEmpCod,tmpFilCod,tmpPedCod,tmpNfeItmCod 
		Where tmpEmpCod = &EmpCod
		Where tmpFilCod = &FilCod
		Where tmpPedCod = &PedCod
		Where tmpNfeItmCod = &PedItmCod
		&TmpPedQtd += tmpPedQtd 
		&TmpPedVlrtot += tmpPedVlrTot
	EndFor
EndSub

Sub 'AtualizaNovoValor'
	For each Order tmpEmpCod,tmpFilCod,tmpPedCod,tmpNfeItmCod 
		Where tmpEmpCod = &EmpCod
		Where tmpFilCod = &FilCod
		Where tmpPedCod = &PedCod
		Where tmpNfeItmCod = &PedItmCod
		tmpPedVlrTot = tmpPedQtd * tmpPedVlrUnt
		tmpPedVlrTotNov = ROUND(tmpPedQtdFat * tmpPedVlrUnt, 2)
	EndFor
	commit
EndSub

Sub 'GetItemNotaValor'
	
	&TmpPedQtd = 0
	&TmpPedVlrtot = 0
	&auxPedVlrItm = 0
	do 'Soma'
	If  &PedVlrItm <> &TmpPedVlrtot //Calcula a diferença de quantidade do pedido para nota 
		&auxPedVlrItm = &PedVlrItm - &TmpPedVlrtot
	EndIf
	
	//############### Atualiza somando a diferença, da quantidade ################################################################
	For each Order tmpEmpCod,tmpFilCod,tmpPedCod,tmpNfeItmCod 
		Where tmpEmpCod = &EmpCod
		Where tmpFilCod = &FilCod
		Where tmpPedCod = &PedCod
		Where tmpNfeItmCod = &PedItmCod
		tmpPedVlrUnt = ((tmpPedVlrTot + &auxPedVlrItm) / tmpPedQtd)
		tmpPedVlrUntNov = ((tmpPedVlrTot + &auxPedVlrItm) / tmpPedQtd)
		tmpPedVlrTot = (tmpPedVlrTot + &auxPedVlrItm)
		tmpPedVlrTotNov = (tmpPedVlrTot + &auxPedVlrItm)
		exit
	EndFor
	commit
EndSub

]]></Source>
