      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,TempUsr,TempRent
	Where EmpCod = &EmpCod
	Where TempUsr = &usrCod

	delete
EndFor

&linha = 1

&File.Source = &LinkFisico //apaga arquivo gerado com mesmo nome.
if &File.Exists()
	&File.Delete()
Endif
&File.Close()

&ExcelDocument.Open(&LinkFisico)

&titulo = upper('Produtos Vendidos/Comprados no período')
&ExcelDocument.Cells(&linha, 1).Text = &titulo
&linha += 1

&Primeira_area = 'S'
&primeiro_vendedor = 'S'
&primeiro_Grupo = 'S'
&TotPedQtd = 0
&TotPedVlrItm = 0
&TotPedVlrItmComDsc = 0 
&AuxTotPedVlrItmCus = 0
&auxGrupHie = &GrupHie.Trim() + '.'
//##################################################################### CÁLCULO
	
For each Order EmpCod,FilCod,LctAtuEst,GrupHiePadL    
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where LctAtuEst = &LctAtuEst
	Where LctCod = &LctCod  when not &LctCod.IsEmpty()
	Where LctGerFin = &LctGerFin when not &LctGerFin.IsEmpty()
	Where ProCod = &ProCod when not &ProCod.IsEmpty()
	Where ProVarNcm = &ProVarNcm when not &ProVarNcm.IsEmpty()
	Where MarCod = &MarCod when not &MarCod.IsEmpty()
	Where ProPadForCod = &ProPadForCod when not &ProPadForCod.IsEmpty()
	Where PedCliCod = &PesCliCod when not &PesCliCod.IsEmpty()
	Where (PedDtaFat >= &PedDtaEms and PedDtaFat <= &PedDtaEms_Go) when &PedSts = Status_Pedido.FECHADO and &TCon096_HoraProdutoVendido <> Status_simNao.Sim
	Where (PedDtaFic >= &PedDtaEms and PedDtaFic <= &PedDtaEms_Go) when &PedSts <> Status_Pedido.FECHADO and &TCon096_HoraProdutoVendido <> Status_simNao.Sim
	Where (PedHorFat >= &PedHorFat and PedHorFat <= &PedHorFat_Go) When &PedSts = Status_Pedido.FECHADO and &TCon096_HoraProdutoVendido = Status_simNao.Sim
	Where PedSts = &PedSts when not &PedSts.IsEmpty()
	Where PedSts <> Status_Pedido.CANCELADO when &PedSts.IsEmpty()
	Where PedVenCod = &PesVenCod when not &PesVenCod.IsEmpty()
	Where PedVenAreCod = &AreCod when not &AreCod.IsEmpty()		
	Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	where ProTipDef = Definicao.SERVICO when &TipoProduto = 'S' 
	where ProTipDef <> Definicao.SERVICO when &TipoProduto = 'P' 
	Where ProClsPrdCod =  &ProClsPrdCod when not &ProClsPrdCod.IsEmpty()
	
	If &auxProGraRef <> ProGraRef and &auxProGraRef <> ''
		If &PedQtd > 0
			Do 'AddProduto'			
			&PedQtd = 0
			&PedVlrItm = 0
			&PedVlrItmComDsc = 0
			&PedVlrItmCus = 0
		EndIf
	EndIf
	
	&auxProNom 		= ProNomGra	
	&auxProGraRef = ProGraRef
	&TempProCod = ProCod
	&TempGrupCod = GrupCod
	&TempGrupNom = GrupNom
	&tempGrupCodNom = GrupCodNom
	&TempGrupHie = GrupHie
	&TempGrupPaiCod = GrupPaiCod
	&TempGrupPaiHie = GrupPaiHie
	&TempProGraRef = ProGraRefPadL
	&AddProGraRef = ProGraRef
		
	Do Case
		Case &QtdTipo = 1//somente Vendidos
			&PedQtd += PedQtd
			&PedVlrItm += PedVlrItm
			&PedVlrItmComDsc += PedVlrItmComDsc
			&PedVlrItmCus += PedVlrItmCus
		Case &QtdTipo = 2// Somente Canceladas
			&PedQtd += PedQtdCan
			&PedVlrItm += PedVlrItm
			&PedVlrItmComDsc += PedVlrItmComDsc
			&PedVlrItmCus += (PedVlrCus *PedQtdCan)
		Case &QtdTipo = 3//Vendidas + Canceladas
			&PedQtd += PedQtd + PedQtdCan
			&PedVlrItm += PedVlrItm
			&PedVlrItmComDsc += PedVlrItmComDsc
			&PedVlrItmCus += (PedVlrItmCus + (PedVlrCus *PedQtdCan))
	EndCase
	
EndFor

If &PedQtd > 0
	Do 'AddProduto'
EndIf
//##########################################################################################

//###################################################### impressao #########################
For each Order EmpCod,TempUsr,TempGruphie,TempProGraRefPadL
	Where EmpCod 	= &EmpCod
	Where TempUsr 	= &usrCod
	
	Do Case
		Case TempGrupPaiHie.Trim().IsEmpty() and TempProCod = 0
			IF &GruPedQtd > 0
				do 'printtotalGrupo'
				&GruPedVlrItmCus = 0
				&GruPedQtd       = 0
				&GruPedVlrItmComDsc = 0
				&GruPedVlrItm    = 0
				&GruauxPedVlrCus = 0
			EndIf	
			&ExcelDocument.Cells(&linha, 1).Text = 'Grupo: '+ TempGrupCodNom
			&linha += 1
			
			&isImprimiTitleProduto = true
		Case not TempGrupPaiHie.Trim().IsEmpty() and TempProCod = 0
			&ExcelDocument.Cells(&linha, 1).Text = 'SubGrupo: '+ TempGrupCodNom
			&linha += 1
			
			&isImprimiTitleProduto = true
			
		Case TempProCod <> 0
			If &isImprimiTitleProduto = true
				If &MostrarEstoque = Status_SimNao.Sim
					&TxtQtdeEst = 'Qtd.Est'
				Else
					&TxtQtdeEst = ''
				EndiF
				
				If &MostrarCusto = Status_SimNao.Sim
					&Coluna = 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Ref.Código'		
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Produto'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Custo Uni'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Quantidade'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = &TxtQtdeEst
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Total Custo'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Valo Liq.'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Valor Bruto'
					&linha += 1
				Else
					&Coluna = 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Ref.Código'		
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Produto'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Quantidade'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = &TxtQtdeEst
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Valo Liq.'
					&Coluna += 1
					&ExcelDocument.Cells(&linha, &Coluna).Text = 'Valor Bruto'
					&linha += 1
				EndIf
				
				&isImprimiTitleProduto = false
			EndIf
			
			&AuxProCod		= TempProCod
			If &MostrarEstoque = Status_SimNao.Sim or &MostrarLocacao = Status_SimNao.Sim
				Do 'BuscaEstoque'
			Else
				&EstQtdVarChar = ''
				&Locacaoextra = ''
				&Estloc = ''
			EndIF
			
			&auxProGraRef = trim(TempProGraRef)
			&auxProNom    = TempProNom
			
			If &Estloc <> '' or &Locacaoextra <> ''
				If &Estloc <> ''
					&auxProNom   += ' Locação:' + trim(&Estloc)
				EndIf
				
				If &Locacaoextra <> ''
					&auxProNom  += ' Loc. Extra: '+ trim(&Locacaoextra)
				EndIf			 
			EndIf		
		
			&PedVlrItmCus = TempPedVlrItmCus
			&PedQtd       = TempQuantidade
			&PedVlrItmComDsc = TempPedVlrLIq
			&PedVlrItm    = TempPedVlrBrt
			&auxPedVlrCus = (TempPedVlrItmCus / TempQuantidade)
			
			&TotPedVlrItmCus += TempPedVlrItmCus
			&TotPedQtd       += TempQuantidade
			&TotPedVlrItmComDsc += TempPedVlrLIq
			&TotPedVlrItm    += TempPedVlrBrt
			&TotauxPedVlrCus += (TempPedVlrItmCus / TempQuantidade)
			
			&GruPedVlrItmCus += TempPedVlrItmCus
			&GruPedQtd       += TempQuantidade
			&GruPedVlrItmComDsc += TempPedVlrLIq
			&GruPedVlrItm    += TempPedVlrBrt
			&GruauxPedVlrCus += (TempPedVlrItmCus / TempQuantidade)
			
			
			If &MostrarCusto = Status_SimNao.Sim
				&Coluna = 1
				&ExcelDocument.Cells(&linha, &Coluna).Text = &auxProGraRef	
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Text = &auxProNom
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &auxPedVlrCus
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &PedQtd
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Text = &EstQtdVarChar
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmCus
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmComDsc
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItm
				&linha += 1
			Else
				&Coluna = 1
				&ExcelDocument.Cells(&linha, &Coluna).Text = &auxProGraRef	
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Text = &auxProNom
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &PedQtd
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Text = &EstQtdVarChar
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmComDsc
				&Coluna += 1
				&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItm
				&linha += 1
			Endif			
	EndCase
EndFor
//###################################################################

If &MostrarCusto = Status_SimNao.Sim
	do 'printtotalGrupo'	
	&Coluna = 3
	&ExcelDocument.Cells(&linha, &Coluna).Text = 'Total:'
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedQtd
	&Coluna += 1
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItmCus
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItmComDsc
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItm
	&linha += 1
Else
	do 'printtotalGrupo'
	&Coluna = 2
	&ExcelDocument.Cells(&linha, &Coluna).Text = 'Total:'
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedQtd
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItmComDsc
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItm
	&linha += 1
EndIf




&ExcelDocument.Save() //Salva e fecha
&ExcelDocument.Close()

sub 'printtotalGrupo'
	If &MostrarCusto = Status_SimNao.Sim
		&Coluna = 3
		&ExcelDocument.Cells(&linha, &Coluna).Text = 'Total Grupo:'
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &GruPedQtd
		&Coluna += 1
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &GruPedVlrItmCus
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &GruPedVlrItmComDsc
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &GruPedVlrItm
		&linha += 1
	Else
		&Coluna = 2
		&ExcelDocument.Cells(&linha, &Coluna).Text = 'Total Grupo:'
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &GruPedQtd
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &GruPedVlrItmComDsc
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &GruPedVlrItm
		&linha += 1
	Endif
EndSub


Sub 'BuscaEstoque'
	&Locacaoextra = ''
	For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstLoc
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where ProCod 	= &AuxProCod
		
		If &MostrarEstoque = Status_SimNao.Sim 
			&EstQtdVarChar 	= Trim(ToFormattedString(EstQtd))
			RetiraZerosDepoisVirgula.Call(&EstQtdVarChar, &EstQtdVarChar)
		EndIf
		
		If &MostrarLocacao = Status_SimNao.Sim
			&Estloc = EstLoc 
			
			For each Order EmpCod, FilCod, ProCod, ProGraCod, EstLoc,EstLocExt
				&Locacaoextra += ' '+ EstLocExt
			EndFor
		EndIf
	
		Exit
	EndFor
	
EndSub

Sub 'AddProduto'
	If &auxProNom.Trim().IsEmpty()
		&auxProNom = 'Produto vendido mais não encontrado no cadastro.'
	EndIf
	&TempRent = 0
	For each Order EmpCod,TempUsr,(TempRent)
		Where EmpCod = &EmpCod
		Where TempUsr = &usrCod
		&TempRent = TempRent
		Exit
	EndFor
	&TempRent+=1
	
	New		
		EmpCod = &EmpCod
		TempUsr = &usrCod
		TempRent = &TempRent
		tempProQtd = 0
		TempProCod = &TempProCod
		TempProGraRef = &AddProGraRef
		TempProGraRefPadL = &TempProGraRef
		TempProNom = &auxProNom			
		TempProVlrCus = 0
		TempProVlrRet = 0
		TempProPerRet = 0
		TempQuantidade = &PedQtd
		TempPedVlrLIq = &PedVlrItmComDsc  // VALOR LIQUIDO
		TempPedVlrBrt = &PedVlrItm        // VALOR BRUTO
        TempPedVlrItmCus = &PedVlrItmCus  // CUSTO TOTAL = QTD * CUSTO
		TempGrupCod = &TempGrupCod
		TempGrupNom = &TempGrupNom	
		TempGruphie = &TempGrupHie
		TempGrupCodNom = &TempGrupCodNom
		TempGrupPaiHie = &TempGrupPaiHie
	EndNew
	
	Commit
	//depois de adicionador o produto usa recursividade para adicionar e calcular os totais do sub grupo e grupo passando o grupo do produto &TempGrupCod
	CarregaSdtCategorias.Call(&EmpCod, &TempGrupCod,&PedVlrItmComDsc,&PedQtd,&CountPro,0, &usrCod,&TempRent,&PedVlrItm,&PedVlrItmCus)
EndSub


]]></Source>
