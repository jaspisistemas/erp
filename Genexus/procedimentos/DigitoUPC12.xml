      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[    
	&Peso(01)=3
    &Peso(02)=1 
    &Peso(03)=3 
    &Peso(04)=1 
    &Peso(05)=3 
    &Peso(06)=1 
    &Peso(07)=3 
    &Peso(08)=1 
    &Peso(09)=3 
    &Peso(10)=1 
    &Peso(11)=3 
    &Soma=0 
	
    for &posicao =1 to 11 
        &numero = Val(substr( &ProBar , &posicao , 1 ))
        &soma += ( &Numero * &Peso( &posicao  ))
    EndFor

    //verifica o final da soma
    //se for 0 o dv = 0
    //caso contrario o dv = 10 - final
    &CodigoSoma = trim(str(&Soma))
    &Tamanho = len(&CodigoSoma)        

    &Final = val(  substr(&CodigoSoma, &Tamanho  ,1 )    )

    if &Final = 0 
        &Digito = 0 
    else
        &Digito = 10 - &Final
    Endif
    &NewProBar = trim(&ProBar)+ padL(str(&Digito,1,0),1,'0')
]]></Source>
