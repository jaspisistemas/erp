        <Source><![CDATA[

PadraoUsuarioHora.Call('L', 'IMPORTACAOCLIENTEXLS', 1, &EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'T')
&ColPesCod = val(Substr(&PadObs, 1, 8))
&ColPesRaz = val(Substr(&PadObs, 9, 8))
&ColPesGrpImp = val(Substr(&PadObs, 17, 8))
&ColPesCnpj = val(Substr(&PadObs, 25, 8))
&ColPesIns = val(Substr(&PadObs,33, 8))
&ColPesRg = val(Substr(&PadObs, 41, 8))
&ColPesCEP = val(Substr(&PadObs, 49, 8))
&ColPesLog = val(Substr(&PadObs, 57, 8))
&ColPesNro = val(Substr(&PadObs, 65, 8))
&ColPesBai = val(Substr(&PadObs, 73, 8))
&ColPesCpl = val(Substr(&PadObs, 81, 8))
&ColPesCidCod = val(Substr(&PadObs, 89, 8))
&ColPesEml = val(Substr(&PadObs, 97, 8))
&ColPesFon = val(Substr(&PadObs, 105, 8))
&ColPesCel = val(Substr(&PadObs, 113, 8))
&ColPesDtaNas = val(Substr(&PadObs, 121, 8))
&ColPesSuf = val(Substr(&PadObs, 129, 8))
&ColPesObs = val(Substr(&PadObs, 137, 8))
&ColPesUfeCod = val(Substr(&PadObs, 145, 8))
&ColIsCli = val(Substr(&PadObs, 153, 8))
&ColIsFor = val(Substr(&PadObs, 161, 8))
&ColIsTra = val(Substr(&PadObs, 169, 8))
&MostrarSomenteNaoCadastrado= Substr(&PadObs, 177, 1)
&SemCpfSemCnpj 				= Substr(&PadObs, 178, 1)
&ColCidIBGE = val(Substr(&PadObs, 179, 8))

&ColPesEml2 = val(Substr(&PadObs, 187, 8))
&ColPesEml3 = val(Substr(&PadObs, 195, 8))


&Total = &sdtClienteXls.Count
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'
	
	
For &sdtClienteXlsItem in &sdtClienteXls
	if &sdtClienteXlsItem.StsCadastro <> 'S'
		
		&AuxCount += 1
		
		if &AuxCount = 100
			&AuxCount = 0
			&Count += 10
			If &Count > 0
				&Percentual = round((&Count / &Total) * 100, 0)
			EndIF
			If &Percentual >= 100
				&Percentual = 99
			EndIf
			do 'Atualiza'
		Endif
	
		If &sdtClienteXlsItem.PesCnpj.Length() > 14
			&PesTip = TipoPessoa.JURIDICA
			&PesCnpj = &sdtClienteXlsItem.PesCnpj
		Else
			&PesTip = TipoPessoa.FISICA
			&PesCpf = &sdtClienteXlsItem.PesCnpj
		EndIf
			
		&SdtGravaPessoa = new()
		if &sdtClienteXlsItem.PesCod > 0
			carregaCadastroPessoa.Call(&EmpCod, &sdtClienteXlsItem.PesCod, &SdtGravaPessoa)	
		Endif
	
//		&ColPesGrpImp = val(Substr(&PadObs, 17, 8))
//		&ColPesCnpj = val(Substr(&PadObs, 25, 8))
//		&ColPesEml = val(Substr(&PadObs, 97, 8))
//		&ColPesFon = val(Substr(&PadObs, 105, 8))
//		&ColPesCel = val(Substr(&PadObs, 113, 8))
//		&ColPesDtaNas = val(Substr(&PadObs, 121, 8))
//		&ColPesObs = val(Substr(&PadObs, 137, 8))
//		&ColPesUfeCod = val(Substr(&PadObs, 145, 8))
//		&ColIsCli = val(Substr(&PadObs, 153, 8))
//		&ColIsFor = val(Substr(&PadObs, 161, 8))
//		&ColIsTra = val(Substr(&PadObs, 169, 8))
		
		if &ColPesRaz > 0
			&SdtGravaPessoa.PesRaz = &sdtClienteXlsItem.PesRaz	
		Endif
	
		if (&ColPesCidCod > 0 and &ColPesUfeCod > 0) or &ColCidIBGE >0
			&SdtGravaPessoa.PesCidCod 	= &sdtClienteXlsItem.PesCIdCod
		Endif
		
		if &ColPesIns > 0
			&SdtGravaPessoa.PesInsEst 	= &sdtClienteXlsItem.PesInsEst
			&SdtGravaPessoa.PesCadPro 	= &sdtClienteXlsItem.PesCadPro
		Endif		
		
		if &ColPesRg > 0
			&SdtGravaPessoa.PesRg 		= &sdtClienteXlsItem.PesRg
		Endif
		if &PesTip = TipoPessoa.JURIDICA 
			&SdtGravaPessoa.PesCnpj 	= &PesCnpj
		Else
			&SdtGravaPessoa.PesCpf 		= &PesCpf
		Endif		
		&SdtGravaPessoa.PesTip 		= &PesTip
		
		if &ColPesSuf > 0
			&SdtGravaPessoa.PesSuf 		= &sdtClienteXlsItem.PesSuf
		Endif	
		//Endereço
		if &ColPesLog > 0
			&SdtGravaPessoa.PesLog = &sdtClienteXlsItem.PesLog
		Endif
		If &ColPesNro > 0
			&SdtGravaPessoa.PesNro = &sdtClienteXlsItem.PesNro
		EndIf
		if &ColPesBai > 0
			&SdtGravaPessoa.PesBai = &sdtClienteXlsItem.PesBai
		Endif
		if &ColPesCEP > 0
			&SdtGravaPessoa.PesCep = &sdtClienteXlsItem.Pescep
		Endif
		if &ColPesCpl > 0
			&SdtGravaPessoa.PesCpl = &sdtClienteXlsItem.pesCpl
		Endif

		//Contato
		&SdtGravaPessoa.Fone.Clear()
		&SdtGravaPessoa.Email.Clear()
		
		if not &sdtClienteXlsItem.PesFonNum.IsEmpty()
			&SdtGravaPessoaFone = new()
			&SdtGravaPessoaFone.PesFonNums = &sdtClienteXlsItem.PesFonNum
			&SdtGravaPessoa.Fone.Add(&SdtGravaPessoaFone)
		Endif
		if not &sdtClienteXlsItem.PesCelNum.IsEmpty()
			&SdtGravaPessoaFone = new()
			&SdtGravaPessoaFone.PesFonNums = &sdtClienteXlsItem.PesCelNum
			&SdtGravaPessoa.Fone.Add(&SdtGravaPessoaFone)
		Endif

		if not &sdtClienteXlsItem.PesEmail.IsEmpty()
			&SdtGravaPessoaEmail = new()
			&SdtGravaPessoaEmail.PesEmls = &sdtClienteXlsItem.PesEmail
			&SdtGravaPessoa.Email.Add(&SdtGravaPessoaEmail)
		Endif
	
		if not &sdtClienteXlsItem.PesEmail2.IsEmpty()
			&SdtGravaPessoaEmail = new()
			&SdtGravaPessoaEmail.PesEmls = &sdtClienteXlsItem.PesEmail2
			&SdtGravaPessoa.Email.Add(&SdtGravaPessoaEmail)
		Endif
		
		if not &sdtClienteXlsItem.PesEmail3.IsEmpty()
			&SdtGravaPessoaEmail = new()
			&SdtGravaPessoaEmail.PesEmls = &sdtClienteXlsItem.PesEmail3
			&SdtGravaPessoa.Email.Add(&SdtGravaPessoaEmail)
		Endif
	
		if &sdtClienteXlsItem.PesCod.IsEmpty()
			&SdtGravaPessoa.PesFan = &PesFan	
			&SdtGravaPessoa.PesRazNF = &PesRazNF
			
			&SdtGravaPessoa.OriCod = OrigemCadastroPessoa.IMPORTACAO_EXTERNA
			
			&SdtGravaPessoa.PesIsCli = 1
			&SdtGravaPessoa.PesIsFor = false
			&SdtGravaPessoa.PesIsFun = false
			&SdtGravaPessoa.PesIsVen = false
			&SdtGravaPessoa.PesIsTra  = false
			
			&SdtGravaPessoa.RatCod = 1
			&SdtGravaPessoa.PesGruImpCod = 1
			
			&SdtGravaPessoa.PesEmpCodSec = &PesEmpCodSec
			&SdtGravaPessoa.PesDtaVctCer = &PesDtaVctCer
			&SdtGravaPessoa.PesEscCtbCod = &PesEscCtbCod
			
			&SdtGravaPessoa.PesCliCrd = &PesCliCrd
			
			GravaCadastroPessoa.Call('ADD',&EmpCod, 0, &SdtGravaPessoa,  &FunPesCod, &AuxPesCod)
			&sdtClienteXlsItem.PesCod = &AuxPesCod
		Else //ATUALIZA
			GravaCadastroPessoa.Call('UPD',&EmpCod, &sdtClienteXlsItem.PesCod, &SdtGravaPessoa,  &FunPesCod, &AuxPesCod)
		Endif
	Endif
EndFor


&Percentual = 100
&ProgressFin = serverNow()
&ProgressLogXml = &sdtClienteXls.ToJson()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &ProgressLogXml
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub
