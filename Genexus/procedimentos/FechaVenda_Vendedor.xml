      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErroVendedor = false
&editPesCodRazSugg = ''

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesIsVen = true
	
	&PesCodRazSugg = PesCodRazSugg
	
	If not PesDtaDem.IsEmpty() and not PesDtaDem.IsNull()
		&Mensagem = 'ATENÇÃO! Vendedor está demitido. Verifique!'
		&IsErroVendedor = true
	Endif
	
	Exit
When None
	&IsErroVendedor = true
	&Mensagem = 'Vendedor não Localizado!'
EndFor
]]></Source>
