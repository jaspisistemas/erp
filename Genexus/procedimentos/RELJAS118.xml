        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

&titulo = 'LISTAGEM FICHA DO CLIENTE'

&PeriodoMensagem = trim(toformattedString(&iniPedDtaFat)) + ' À ' + trim(toformattedString(&FinPedDtaFat))

RetornaCodigoStatusPedido.Call(&EmpCod, 'ENTR.FUTURA', &stsCod)
RetornaCodigoStatusPedido.Call(&EmpCod, 'VF.ENTREGUE', &EntregueStsCod)
MB 4
MT 2

Header
	print Cabecalho
	
	print Titu
End


For Each order EmpCod, FilCod, PedDtaFic
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCliCod = &PedCliCod
	//Where PedSts <> Status_pedido.CANCELADO
	Where (PedSts = Status_Pedido.FECHADO) or PedNovStsCod = &stsCod or PedNovStsCod = &EntreguestsCod or (PedSts = Status_Pedido.ABERTO and &ConsiderarPedidosAbertos = true) //= 'ENTR.FUTURA'// and PedStsFin = Status_Financeiro.FECHADO) or PedSts = Status_Pedido.ABERTO
	Where PedDtaFic >= &iniPedDtaFat and PedDtaFic <= &finPedDtaFat
	where LctTip <> TipoLancamento.EntradaMercadoria and LctTip <> TipoLancamento.OrcamentoCompra
	
	if &PedCliCodRaz.IsEmpty()
		&PedCliCodRaz = PedCliCodRaz
	Endif	
	&PedCod = PedCod	
	
	&PedDtaFat.SetEmpty()
	&NfeNumVar.SetEmpty()
	&TipoPedido.SetEmpty()
	&NfeNum.setEmpty()
	
	&NfeFilCod = FilCod
	&NfePedCod = PedCod
	do 'localizaNfe'
	
	if &PedDtaFat.IsEmpty()
		&PedDtaFat = PedDtaFic
	Endif

	Do Case
//		Case LctTip = TipoLancamento.DevolucaoCompra or LctTip = TipoLancamento.Devolucaovenda
//			&TipoPedido = 'DV '
		Case PedStsGer = Pedido_Gerado.OrdemCarregamento // LctTip = TipoLancamento.OrdemCarregamento
			&TipoPedido = 'OC '
		Case PedNovStsCod =  &stsCod or  PedNovStsCod = &EntregueStsCod
			&TipoPedido = 'VF '
		otherwise				
			&TipoPedido = 'PD '
	EndCAse
	&TipoPedido += trim(str(PedCod))
		
	&CreDtaVct = PedDtaVct
	if &CreDtaVct.IsEmpty()
		do 'getVencimentos'
	Endif

	
	For Each order EmpCod, FilCod, PedDtaFic, PedItmCod
		Where PedQtd > 0
		
		&SaldoMoeda.SetEmpty()
		&CreditoMoeda.SetEmpty()
		&DebitoMoeda.SetEmpty()

		&ProNom = Substr(ProNom,1,55)
		
		Do Case
			Case LctTip = TipoLancamento.Devolucaovenda
				If LctAtuEst = Status_EntradaSaida.Nenhum
					//&DebitoMoeda = (PedVlrItmComDsc * -1)
					&CreditoMoeda = (PedVlrItmComDsc * -1)
				Else
					&DebitoMoeda = (PedVlrItmComDsc * -1)
					&CreditoMoeda = (PedVlrItmComDsc * -1)
				Endif
			
			Case LctTip = TipoLancamento.DevolucaoCompra
				&DebitoMoeda = (PedVlrItmComDsc * -1)
				
			Case LctAtuEst = Status_EntradaSaida.Saida
				
				if PedSts = Status_Pedido.FECHADO
					&DebitoMoeda = PedVlrItmComDsc
				Endif
			
				if  PedStsGer <> Pedido_Gerado.OrdemCarregamento //
					&CreditoMoeda = PedVlrItmComDsc
				Endif
			
//			Case LctAtuEst = Status_EntradaSaida.Saida and Pedsts = Status_Pedido.ABERTO
//				&DebitoMoeda = PedVlrItmComDsc
//				if LctTip <> TipoLancamento.OrdemCarregamento
//					&CreditoMoeda = PedVlrItmComDsc
//				Endif
			
			Case LctGerFin = Status_SimNao.Sim
				&CreditoMoeda = PedVlrItmComDsc
				
			Otherwise
				&CreditoMoeda = PedVlrItmComDsc
				&DebitoMoeda = PedVlrItmComDsc
		EndCase
		
		if &DebitoMoeda > 0
			&SaldoMoeda = (&AnteriorMoeda + &CreditoMoeda) - &DebitoMoeda
		Else
			&SaldoMoeda = (&AnteriorMoeda + &CreditoMoeda) + &DebitoMoeda
		Endif
		
		&TOTALCREDITODEBIDO(1) += &CreditoMoeda
		&TOTALCREDITODEBIDO(2) += &DebitoMoeda
		&TOTALCREDITODEBIDO(3) = &SaldoMoeda
		
		if &OldPedCod = PedCod
			print PedidoProdutos1
		Else
			print PedidoProdutos
		Endif
		
		&AnteriorMoeda = &SaldoMoeda
		
		&OldPedCod = PedCod
	EndFor	
EndFor

print SaldoTotal
Footer
	print Rodape
End


Sub 'GetVencimentos'
	
	For Each order EmpCod, FilCod, PedCod, (PedVctCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&CreDtaVct = PedVctDta
		Exit
	EndFor
EndSub

Sub 'localizaNfe'
	For Each Order EmpCod, NfeFilCod, NfePedCod, NfeSts, NfeCod
		Where EmpCod = &EmpCod
		Where NfeFilCod = &NfeFilCod
		Where NfePedCod = &NfePedCod
		where NfeSts = Status_NFe.Autorizada
		
		&PedDtaFat = NfeDtaEms
		
		&SoNumeros = padL(trim(str(NfeNum)), 9, '0')
		&NfeNumVar = substr(&SoNumeros, 1, 3) +'.' + substr(&SoNumeros, 4, 3) + '.' + substr(&SoNumeros, 7, 3)
		
		
	EndFor	
EndSub

