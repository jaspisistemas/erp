      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[MT 0
MB 0

padraoUsuario.Call('L', &CodigoTemporario, &PesCod, &EmpCod, &PadObs, &PadDtaMod)

&sdtEtiquetaLote.FromJson(&PadObs)

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

for &sdtEtiquetaLoteItem in &sdtEtiquetaLote
	
	&EstQtd = &sdtEtiquetaLoteItem.Quantidade	
	
	if not &sdtEtiquetaLoteItem.Lote.IsEmpty()
		&Fabricado = 'Lote: '+ trim(&sdtEtiquetaLoteItem.Lote)
	Endif
	if not &sdtEtiquetaLoteItem.PedDtaFat.IsEmpty()
		&Fabricado += ' FAB.: ' + trim(toformattedString(&sdtEtiquetaLoteItem.PedDtaFat))
		&PedDtaFat = &sdtEtiquetaLoteItem.PedDtaFat
		&PedDtaFat = &PedDtaFat.AddMonths(12)
		&Validade = 'VAL.: ' + trim(toformattedString(&PedDtaFat))
	Endif	
	
	RetornaProdutoReferencia.Call(&EmpCod, &sdtEtiquetaLoteItem.ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
	&IsAchouProduto = false
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		where ProImgNom = '#CREAM_SORVETE#'
		
		&IsAchouProduto = true
		&CodBarrasImage = ProImg1024
	
		Exit
	EndFor
	
	if &IsAchouProduto = true
		do 'imprime'
	Endif
EndFor

sub 'Imprime'
	for &count = 1 to &EstQtd		
		print EtiquetaModelo1opcaoA
	EndFor
EndSub
]]></Source>
