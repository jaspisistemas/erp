      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TabPrcCmpItmCod = &ParTabPrcCmpItmCod
For Each Order EmpCod, TabCod, ProCod, ProGraCod, TabPrcCmpItmCod
	Where EmpCod 			= &Empcod
	Where TabCod 			= &TabCod
	Where ProCod 			= &ProCod
	Where ProGraCod 		= &ProGraCod
	Where TabPrcCmpItmCod 	= &TabPrcCmpItmCod
	
	TabPrcRecProCod 	= &TabPrcRecProCod
	TabPrcRecProGraCod 	= &TabPrcRecProGraCod
	TabPrcRecProQtd 	= &TabPrcRecProQtd
	
	Exit
When none
	&TabPrcCmpItmCod = 0
	For Each Order EmpCod, TabCod, ProCod, ProGraCod, (TabPrcCmpItmCod)
		Where EmpCod 			= &Empcod
		Where TabCod 			= &TabCod
		Where ProCod 			= &ProCod
		Where ProGraCod 		= &ProGraCod
		&TabPrcCmpItmCod  = TabPrcCmpItmCod 
		Exit
	EndFor
	&TabPrcCmpItmCod += 1
	NEw
		EmpCod 			= &Empcod
		TabCod 			= &TabCod
		ProCod 			= &ProCod
		ProGraCod 		= &ProGraCod
		TabPrcCmpItmCod 	= &TabPrcCmpItmCod
		TabPrcRecProCod 	= &TabPrcRecProCod
		TabPrcRecProGraCod 	= &TabPrcRecProGraCod
		TabPrcRecProQtd 	= &TabPrcRecProQtd
	EndNEw
EndFor

Commit


PrcAtualizaPrecoVenda_Composicao1.Call(&Empcod, &TabCod, &TabPrcRecProCod, &TabPrcRecProGraCod, &WwpContextUserName)
]]></Source>
