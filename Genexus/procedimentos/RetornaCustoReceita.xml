      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ProVlrCusUnt = 0

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	&ProVlrCusUnt = ProVlrCusUnt
	Exit
EndFor

if &ProVlrCusUnt <= 0
	&ProVlrCusUnt = RetornaCustoFixo.Udp(&EmpCod, &ProCod)
EndIF
]]></Source>
