      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	&Pagina = &parpagina
	&QtdRegistros = &parQtdRegistros
	
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwGridGenericoPequeno.sts = 'J200'
	&wwGridGenericoPequeno.pA = '0'
	&wwGridGenericoPequeno.pT = '0'
	&wwGridGenericoPequeno.p1 = '0'
	&wwGridGenericoPequeno.p2 = '0'
	&wwGridGenericoPequeno.p3 = '0'
	&wwGridGenericoPequeno.p4 = '0'
	&wwGridGenericoPequeno.p5 = '0'
	&IsPaginaOk = false
	
	if not (&FiltroPlanCatTip.IsEmpty() or &FiltroPlanCatTip = 'T')
		&PlanCatTip.FromString(&FiltroPlanCatTip)
	Endif
	&SoNumerosVarchar = RetornaSoNumeros.Udp(&PlanNom)
	&FiltroCtaBanCod.FromString(&SoNumerosVarchar)
	
	For Each Order EmpCod, PlanHiePadL
		Where EmpCod = &wwpContext.EmpCod
		Where PlanCatTip = &PlanCatTip when not (&FiltroPlanCatTip.IsEmpty() or &FiltroPlanCatTip = 'T')
		Where PlanHie = &PLanHie when not &PLanHie.IsEmpty()
		Where PlanAnaSin = &analiticosintetico when not &analiticosintetico.IsEmpty()
//		Where PL = &CtabanCod when not &CtabanCod.IsEmpty()
//		Where CatSts = &CatSts when not (&VarCatSts.IsEmpty() or &VarCatSts = 'T')
		Where PlanNomCmp like &PlanNom or (PlanHie like &PlanNom) when not &PlanNom.IsEmpty()
		Where PlanUtiTra <> true when &incluirtransferencia = 'N' or &incluirtransferencia.IsEmpty()
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwGridGenericoPequeno.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				
				&wwGridGenericoPequenoItem = New()
				&wwGridGenericoPequenoItem.Cod = PlanCod
				&wwGridGenericoPequenoItem.Ob1 = PlanHie
				&wwGridGenericoPequenoItem.Nom = PlanNomCmp.Trim()
				
				&wwGridGenericoPequeno.Item.Add(&wwGridGenericoPequenoItem)
			Endif		
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	When none
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwGridGenericoPequeno.pA = trim(str(&Pagina))
		&wwGridGenericoPequeno.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwGridGenericoPequeno.p1, &wwGridGenericoPequeno.p2, &wwGridGenericoPequeno.p3, &wwGridGenericoPequeno.p4, &wwGridGenericoPequeno.p5)
		
	Endif
Endif

]]></Source>
