      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each ORder EmpCod, NcmCod
	Where EmpCod = &EmpCod
	Where (NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()) or ProNcmIsErro = 'E'
	
	&ProNcmIsErro = ''	
	if (NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()) 
		&ProNcmIsErro = 'E' //FIM VIGENCIA
	Endif
	
	ProNcmIsErro = &ProNcmIsErro
	if &ProNcmIsErro = 'E' //FIM VIGENCIA
		if &NCmCod <> NcmCod and not &NCmCod.IsEmpty()
			do 'addSDT'
		Endif
		&QtdItens += 1
		
		&NcmFinVig = NcmFinVig
		&NCmCod = NcmCod
	Endif	
EndFor

Commit	

if &QtdItens > 0
	do 'addSDT'
Endif

padraoUsuarioHora.Call('G', '#WPCORRIGENCM#', 1, &EmpCod, &SdtNCM.ToJson(), &paddtaMod, &PadDtaHorMod, 'T')


Sub 'addSDT'
	&SdtNCMItem = new()
	&SdtNCMItem.NcmCod = &NCmCod
	&SdtNCMItem.Msg = format('VIGENCIA: %1, TOTAL DE %2 PRODUTOS INVÁLIDOS', trim(toformattedString(&NcmFinVig)) , trim(toformattedString(&QTdItens)) )
	&SdtNCM.Add(&SdtNCMItem)
	&QtdItens = 0
EndSub

]]></Source>
