      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	print Cabecalho
End

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&OqueE = upper(LctTip.EnumerationDescription())
	
	&txtData = ''
	Do case
		CAse not PedDtaFat.IsEmpty()
			&txtData = 'Faturado:'
			&PrevisaoFaturadoData = PedDtaFat.ToFormattedString()
		Case Not PedDtaPrv.IsEmpty()
			&txtData = 'Previsão:'
			&PrevisaoFaturadoData = PedDtaPrv.ToFormattedString()
	EndCase
	
	print CapaPedido
		
	For Each Order EmpCod, FilCod, PedCod, PedCriCod //DIGITADOR
		Where PedCriTip = TipoCriticaPedido.Digitado
		&PedCriFunRaz = trim(str(PedCriFunCod)) + ' - ' + trim(PedCriFunRaz)
		Exit		
	EndFor
		
	&AuxVolume = trim(str(PedQtdVol)) + ' ' + trim(PedEspVol)
	
	&PedPesTot = PedPesTot
	If &PedPesTot.IsEmpty()
		&PedPesTot = PedPesTotPro
	EndIF
	
	print TituloProdutos_1	
	
	&QtdItens = 0
	&QtdPecas = 0
	For Each 
		Order EmpCod, FilCod, PedCod, ProCod when &Ordem = 'C' //CODIGO PRODUTO
		Order EmpCod, FilCod, PedCod, PedItmCod when &Ordem = 'S' //SEQUENCIA LANCAMENTO
		Order EmpCod, FilCod, PedCod, ProNom when &Ordem = 'N' //NOME PRODUTO
		Where PedQtd > 0
				
		&QtdItens += 1
		&QtdPecas += PedQtd
		
		&PedQtd = PedQtd
		&PedVlrUnt = PedVlrUnt
		&PedVlrUntDsc = PedVlrUntComDsc
		Print Produto_1
	EndFor
	
	&PedVlrBrt = PedVlrBrt
	print TotalPecas
	
EndFor
		
]]></Source>
