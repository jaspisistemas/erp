      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//deleta Fornecedores
if &OqueFazer = 'A' //ELIMINAR TODOS
	For Each Order EmpCod, FinAno, FinMes//, PlanCod
		Where EmpCod = &EmpCod
		Where FinAno = &FinAno
		Where FinMes = &FinMes
		
		FinForCod1 = 0
		FinForPer1 = 0
		FinForCod2 = 0
		FinForPer2 = 0
		FinForCod3 = 0
		FinForPer3 = 0
		FinForCod4 = 0
		FinForPer4 = 0
	EndFor
	
	Commit
	
	
	For Each ORder EmpCod, FinAno, FinMes//, PlanCod
		Where EmpCod = &EmpCod
		Where FinAno = &FinAno
		Where FinMes = &FinMes
		//	where PlanCatTip = 'D'
		
		FinForCod1 = &PesCod1
		FinForPer1 = &Percentual1
		FinForCod2 = &PesCod2
		FinForPer2 = &Percentual2
		FinForCod3 = &PesCod3
		FinForPer3 = &Percentual3
		FinForCod4 = &PesCod4
		FinForPer4 = &Percentual4
		
	EndFor
	
	Commit
Else
	For Each ORder EmpCod, FinAno, FinMes //, PlanCod
		Where EmpCod = &EmpCod
		Where FinAno = &FinAno
		Where FinMes = &FinMes
		//	where PlanCatTip = 'D'
		
		if FinForCod1.IsEmpty() and FinForCod2.IsEmpty() and FinForCod3.IsEmpty() and FinForCod4.IsEmpty()
			FinForCod1 = &PesCod1
			FinForPer1 = &Percentual1
			FinForCod2 = &PesCod2
			FinForPer2 = &Percentual2
			FinForCod3 = &PesCod3
			FinForPer3 = &Percentual3
			FinForCod4 = &PesCod4
			FinForPer4 = &Percentual4
		EndIF
	EndFor
	
	Commit
EndIF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
