      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsCadastrado = false

For Each Order EmpCod, GrupCod, GrupComItmCod
	Where EmpCod = &EmpCod
	where GrupCod = &GrupCod
	Where GrupObsCod = &GrupObsCod when &GrupObsComp = 'O'
	Where GrupProCod = &GrupProCod when &GrupObsComp = 'P'
	&IsCadastrado = true
	Exit
EndFor
]]></Source>
