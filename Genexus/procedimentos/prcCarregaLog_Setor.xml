      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &SetCod = 0 //INSERT
	prcLogAddSdt.Call('SetNom', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('SetTaxMo', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('SetPrzEst', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('SetPrdMax', '', '', &sdtLogAtributos)
Else
	For Each order EmpCod, SetCod
		Where EmpCod = &EmpCod
		Where SetCod = &SetCod
		
		prcLogAddSdt.Call('SetNom', trim(SetNom), '', &sdtLogAtributos)
		prcLogAddSdt.Call('SetTaxMo', trim(toformattedString(SetTaxMo)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('SetPrzEst', trim(toformattedString(SetPrzEst)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('SetPrdMax', trim(toformattedString(SetPrdMax)), '', &sdtLogAtributos)
		
		Exit
	EndFor
Endif
]]></Source>
