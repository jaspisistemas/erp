      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NfeArqXml = ''
&xmlNFe.Open(&ArquivoPronto)    
Do While  not &xmlNFe.EOF
    &NfeArqXml += &xmlNFe.ReadRawXML()
    &xmlNFe.Read()
Enddo
&xmlNFe.Close()

If &NfeArqXml <> ''
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeCCeCod = &NfeCCeCod
		NfeCCeArqXml = &NfeArqXml
		Exit
	EndFor
EndIF


commit
]]></Source>
