      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//deleta itens  maior que 1 pois nf nacional so precisa de 1 item
For Each ORder EmpCod, NfsCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NFsCod
	
	if NfsTipNF = 'S' //Nacional
		For Each ORder EmpCod, NfsCod, NfsItmCod			
			Where NfsItmCod > 1
			delete
		EndFor
	Endif

EndFor

Commit
	
]]></Source>
