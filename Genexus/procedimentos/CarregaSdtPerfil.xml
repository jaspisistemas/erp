      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AutGrpCod.Clear()
&AutGrpNom.Clear()

Do Case		
	Case &PesCod <= -10000
		For Each Order EmpCod,AutGrpSts,AutIsCon, AutGrpNom
			Where EmpCod = &EmpCod //PESSOA
			Where AutGrpSts = Status_AtivoInativo.ATIVO //ATIVO
			Where AutIsCon = true
			&AutGrpCod.Add(AutGrpCod)
			&AutGrpNom.Add(AutGrpNom)
		when none
			NaoAutorizado.Link()
		EndFor
	
	Case &PesCod < 0
		&AutGrpCod.Add(-1)
		&AutGrpNom.Add('[RESTRITO] ACESSO MASTER')
		
	Otherwise
		For Each Order EmpCod, PesCod, AutGrpSts, AutGrpNom
			Where EmpCod = &EmpCod //EMPRESA
			Where PesCod = &PesCod //PESSOA
			Where AutGrpSts = Status_AtivoInativo.ATIVO //ATIVO
			
			&AutGrpCod.Add(AutGrpCod)
			&AutGrpNom.Add(AutGrpNom)
		when none
			NaoAutorizado.Link()
		EndFor
EndCase


&WebSession.Set('PERFILUSUARIO', &AutGrpCod.ToXml())
]]></Source>
