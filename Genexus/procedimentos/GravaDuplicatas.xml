      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order DupTmpEmpCod,DupTmpPesCod
	Where DupTmpEmpCod = &EmpCod
	Where DupTmpPesCod = &PesCod
	
	UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, DupTmpFilCod,&CreCod)
	New
		EmpCod = DupTmpEmpCod
		FilCod = DupTmpFilCod
		CreCod = &CreCod
		CreDupNro = DupTmpCreDupNro		
		CreDtaVct = DupTmpCreDtaVct
		CreVlrDup = DupTmpCreVlrDup
		CreCbrCod = DupTmpCreCbrCod
		CreDtaEms = DupTmpCreDtaEms
		CreVlrSdo = DupTmpCreVlrSdo
		CreCliCod = DupTmpCreCliCod
		CreVenCod = DupTmpCreVenCod
		CreRecPag = DupTmpCreRecPag 
		CreBloNro = DupTmpCreBloNro
		CreSts = Status_Duplicata.ATIVO
		
		CreFrpPgtoCod = 1 //TipoDuplicata.DUPLICATA
		
		CreOriDup = OrigemDuplicata.LancamentoManual
		CrePlanCod = DupTmpCrePlanCod
		CrePerComCbr = DupTmpCrePerComCbr
		if DupTmpCreFilPgt.IsEmpty()
			CreFilPgt = 1
		Else
			CreFilPgt = DupTmpCreFilPgt
		Endif
		//CreAbvDup = RetornaTipoOrigemDuplicata.udp(EmpCod, FilCod, CrePedCod, CreRenDstCod, CreFrtCod, CreNfeCod)
		CreNovCliRaz = DupTmpCreNovCliRaz
	EndNew
	Commit

	GravaCobranca.call(DupTmpEmpCod,DupTmpFilCod,&CreCod,&CreCobObs,0,0,&CrePrmPag, '00:00:00', TipoObservacaoDuplicata.USUARIO)
	
EndFor
]]></Source>
