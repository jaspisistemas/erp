      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAutorizado = true
RetornaAutorizacao.Call('VENDAALTERARPEDIDOSEPARANDO', Status_SimNao.Nao, 1, &SeparandoAutNiv)

RetornaAutorizacao.Call('VENDAALTERARPEDIDOFECHADO', Status_SimNao.Nao, 1, &FechadoAutNiv)

loadwwPContext.Call(&Context)
&AutNivTel = 1
if &Context.PesIsVen = true
	retornaAutorizacao.Call('TELEVENDATROCARVENDEDOR', Status_SimNao.Nao, 1, &AutNivTel)
EndIf

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon058_DigitandoPedido, &TCon058_DigitandoPedido)

RetornaUmItemPago.Call(&EmpCod, &FilCod, &pedCod, &IsPagto)
RetornaUmPedidoReferencia.call(&EmpCod, &FilCod, &pedCod, &IsUmReferenciado)

For Each Order EmpCod, FilCod, PedCod 
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	Do Case
		Case &IsPagto = true //pedido ja tem pgto então não pode alterar.
			&IsAutorizado = false
			
		Case &IsUmReferenciado = true
			&IsAutorizado = false
			
		Case &FechadoAutNiv > 0 //Editar Pedido Fechado
			&IsAutorizado = true
			
		Case &SeparandoAutNiv > 0 and (PedSts = Status_Pedido.SEPARANDO or PedSts = Status_Pedido.ABERTO)
			//Pedido em Separacao/Aberto
			&IsAutorizado = true
			
		CAse &AutNivTel = 0 and PedVenCod <> &Context.PesCod and &Context.PesIsVen = true
			//Pedido Somente do Vendedor
			&IsAutorizado = false
			
		Case (PedSts = Status_Pedido.ABERTO and PedStsCrd <> Status_Autorizado.AUTORIZADO)
			//Pedido Aberto nao Autorizado
			&IsAutorizado = true
			if (&TCon058_DigitandoPedido = 'S') 
				Do Case
					CAse (PedStsDigBlk = true) and PedVenCod <> &Context.PesCod and &AutNivTel = 0
						//Pedido em Digitacao de Outro Vendedor
						&IsAutorizado = false
					Case (PedStsDigBlk = false) and PedVenCod = &Context.PesCod and &AutNivTel = 0
						&IsAutorizado = false
				EndCase
			EndIF
			
		Case PedSts <> Status_Pedido.ABERTO
			//Pedido Aberto já autorizado
			&IsAutorizado = false
			
		Case PedStsCrd = Status_Autorizado.AUTORIZADO and &AutNivTel = 0 
			//Pedido Aberto já autorizado
			&IsAutorizado = false
	EndCase

	Exit
EndFor


if &IsAutorizado = false and not &ProgramaOrigem.IsEmpty()	
	&Link = &ProgramaOrigem.Trim() + '.aspx'
	 link(&link)	
EndIF
]]></Source>
