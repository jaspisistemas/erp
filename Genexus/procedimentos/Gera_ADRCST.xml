      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&iniNfeDtaEms = &sdtEnviaSped.IniNfeDtaFat
&finNfeDtaEms = &sdtEnviaSped.FinNfeDtaFat
&OriginalSubstituto = &sdtEnviaSped.FinalidadeGeracao

&dia = day(&iniNfeDtaEms)
&mes = month(&iniNfeDtaEms)
&Ano = year(&iniNfeDtaEms)

//## INICIO ARQUIVO Registro 0000 – Abertura do arquivo e identificação docontribuinte
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	&FilCtaAna = FilCtaAna
	
	&ArquivoTXT = '|0000'  //01 REG Texto fixo contendo “0000”. N 004
	&ArquivoTXT += '|' + '110' // Versão atual desse Manual é 110 N 003
	&ArquivoTXT += '|' + Trim(Str(&mes))+TRIM(Str(&Ano)) // Mês e Ano de referência do arquivo Formato: MMAAAA
	&ArquivoTXT += '|' + trim(retornaSoNumeros.Udp(FilCpj)) // Informar os 14 dígitos do CNPJ sem traço e barra
	&ArquivoTXT += '|' + trim(FilInsEst) // IE- Informar os 10 dígitos do CAD/ICMS sem traço e barra
	&ArquivoTXT += '|' + trim(FilRaz)
	&ArquivoTXT += '|' + &OriginalSubstituto // 0 – Arquivo original   1 – Arquivo substituto
	&ArquivoTXT += '|' + '' // Se possuir regime especial, informar o número.
	&ArquivoTXT += '|' + '' // Informar o CNPJ do estabelecimento que centraliza as aquisições dos produtos sujeitos à substituição tributária
 	&ArquivoTXT += '|' + '' // Informar a Inscrição Estadual do estabelecimento que centraliza as aquisições dos produtos sujeitos à substituição 
	
	
//	&ArquivoTXT += '|0'//04 IND_SIT_ESP Indicador de situação especial: 0 - Abertura 1 - Cisão 2 - Fusão 3 - Incorporação 4 – Encerramento
//	&ArquivoTXT += '|' //05 NUM_REC_ANTERI OR Número do Recibo da Escrituração anterior aser retificada, utilizado quando TIPO_ESCRIT for igual a 1
//	&ArquivoTXT += '|' + trim(&InicialData) //06 DT_INI Data inicial das informações contidas no arquivo.
//	
EndFor

]]></Source>
