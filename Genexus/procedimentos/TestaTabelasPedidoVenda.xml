      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem.SetEmpty()

//PODE TER PEDIDO SEM TABELA PROMOCAO
if &TabCod = '' and &TabSts = StatusTabela.Promocao
    &Mensagem.SetEmpty()
else
	For Each Order TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		
		Do Case
			Case &PedDtaEms < TabDtaIni or &PedDtaEms > TabDtaFin
				&Mensagem = 'Período de vigência da tabela ' +trim(&TabCod)+ ' expirou! Vigência: ' + trim(TabDtaIni.ToFormattedString()) + ' à ' + trim(TabDtaFin.ToFormattedString())
				
			Case TabSts <> &TabSts
				&Mensagem = 'Tabela: ' +trim(TabCod.ToString())+ ' possuí Status ' + TabSts.EnumerationDescription() +  ' Deveria ser ' + &Tabsts.EnumerationDescription()
				
			Case TabIsAllUfe = false //SOMENTE SE NAO FOR TODOS OS ESTADOS
				For Each Order TabCod, TabUfeCod
					Where TabUfeCod = &UfeCod
					Exit
				When none
					&Mensagem = 'Tabela: ' +trim(&TabCod.ToString())+ ' não autorizada para o estado ' + &UfeCod.Trim() + '!'
				EndFor
				
			Case TabIsAllAre = false //SOMENTE SE NAO FOR TODAS AS AREAS
				For Each Order TabCod, TabAreCod
			        Where TabAreCod = &TabAreCod
					Exit
		        When none
		            &Mensagem = 'Tabela não autorizada para a ÁREA: ' + trim(&TabAreCod.ToString()) + '!'
		        EndFor
				
			Case TabIsAllFil = false //SOMENTE SE NAO FOR TODAS FILIAIS
				For Each Order TabCod, TabFilCod
			        Where TabFilCod = &TabFilCod
					Exit
		        When none
		            &Mensagem = 'Tabela não autorizada para a Filial: ' + trim(&TabFilCod.ToString()) + '!'
		        EndFor
		EndCase
	When none
		if not &TabCod.IsEmpty()
			&Mensagem = 'Tabela não localizada!'
		EndiF
	
	EndFor
EndIF
]]></Source>
