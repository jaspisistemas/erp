      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 100
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
&Mensagem = ''
do 'Atualiza'

For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	&BalDta = BalDta
	&FilTabCod = FilTabCod
	
	if BalSts <> Status_Pedido.FECHADO or BalStsPrc <> AtualizandoEstoquePedido.Fechado
		Return
	EndIF
	BalStsPrc = AtualizandoEstoquePedido.Abrindo
	
	&PedCod = BalPedCod
	do 'atualizaPedido'
    BalSts = Status_Pedido.ABERTO
EndFor

commit

For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	EstProStsBal = retornaProdutoBalanco.Udp(EmpCod, FilCod, ProCod, ProGraCod)
EndFor

commit

For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	BalStsPrc = AtualizandoEstoquePedido.Aberto
	
	Exit
EndFor
commit


&Percentual = 100
&ProgressFin = serverNow()
//&Mensagem = &SdtProdutos.ToJson()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &Mensagem
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &Mensagem
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub

Sub 'atualizaPedido'
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
				
		PedBlq = Status_SimNao.Sim
		PedStsGer = Pedido_Gerado.Interno
		PedStsFin = Status_Financeiro.ABERTO
		
		PedSts = Status_Pedido.ABERTO
		Exit
	EndFor
	
	commit
	
	PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &PedCod)
	
	AtualizaEstoqueEntradaSaida.call(&EmpCod, &FilCod, &PedCod, Status_Pedido.ABERTO)
EndSub
]]></Source>
