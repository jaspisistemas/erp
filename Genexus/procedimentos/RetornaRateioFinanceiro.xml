&RetornaMensagem = ''
For Each order EmpCod, FinAno, FinMes, PlanCod
	Where EmpCod = &EmpCod
	Where FinAno = &FinAno
	Where FinMes = &FinMes
	Where PlanCod = &PlanCod
	
	if not FinForCod1.IsEmpty()
		&Percentual = FinForPer1
		&RetornaMensagem += trim(Str(FinForCod1)) + ': ' + trim(ToformattedString(&Percentual)) + '%'
	EndiF

	if not FinForCod2.IsEmpty()
		if not &RetornaMensagem.IsEmpty()
			&RetornaMensagem += ' | ' 
		EndIF
		
		&Percentual = FinForPer2
		&RetornaMensagem += trim(Str(FinForCod2)) + ': ' + trim(ToformattedString(&Percentual)) + '%'
	EndIF

	if not FinForCod3.IsEmpty()
		if not &RetornaMensagem.IsEmpty()
			&RetornaMensagem += ' | ' 
		EndIF
		
		&Percentual = FinForPer3
		&RetornaMensagem += trim(Str(FinForCod3)) + ': ' + trim(ToformattedString(&Percentual)) + '%'
	EndIF

	if not FinForCod4.IsEmpty()
		if not &RetornaMensagem.IsEmpty()
			&RetornaMensagem += ' | ' 
		EndIF
	
		&Percentual = FinForPer4
		&RetornaMensagem += trim(Str(FinForCod4)) + ': ' + trim(ToformattedString(&Percentual)) + '%'
	EndIF
EndFor
]]></Source>
