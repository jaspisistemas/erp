loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&sdtPedidoProduto.fromXml(&WebSession.Get('ITENS_FALTAS'))

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'IMPRESSÃO FALTAS DO PEDIDO'
	
	print Cabecalho
End

For &sdtPedidoProdutoItem in &sdtPedidoProduto
	if &IsSomenteComfaltas <> true or (&sdtPedidoProdutoItem.EstQtd < (&sdtPedidoProdutoItem.PedQtd-&sdtPedidoProdutoItem.PedQtdFec))
		if &PedCliCodRaz.IsEmpty()
			&PedCliCodRaz = &sdtPedidoProdutoItem.PedCliCodRaz
			print DadosPedido
			print SupostaTitulo
		EndIF
		
		&PedQtd = &sdtPedidoProdutoItem.PedQtd
		&EstQtd = &sdtPedidoProdutoItem.EstQtd
		
		&PedqtdCan = &sdtPedidoProdutoItem.PedQtdCan
		&PedVlrItm = &sdtPedidoProdutoItem.PedVlrItm
		
		&TotPedVlrItm += &PedVlrItm
		
		&ProNom = trim(substr(&sdtPedidoProdutoItem.ProNom,1,55))
		&ProGraref = &sdtPedidoProdutoItem.ProGraRef
		&ProCod = &sdtPedidoProdutoItem.ProCod
		&Estloc = &sdtPedidoProdutoItem.EstLoc
		print SupostaProduto
		If &PedqtdCan > 0
			Do 'Similar'
		EndIf
	Endif
EndFor

print ValorTotalFaltas

Footer
	print Rodape
End

