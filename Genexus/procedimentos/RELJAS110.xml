      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[MT 0
MB 0

padraoUsuario.Call('L', &EtqCod, &PesCod, &EmpCod, &PadObs, &PadDtaMod)

&sdtLocacao.FromJson(&PadObs)


for &sdtLocacaoItem in &sdtLocacao
	&PedidoNota = &sdtLocacaoItem.EstLoc
	&EstQtd = &sdtLocacaoItem.EstQtd
	do 'imprime'
EndFor

sub 'Imprime'
	for &count = 1 to &EstQtd		
		print EtiquetaVolume
	EndFor
EndSub
]]></Source>
