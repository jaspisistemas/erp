      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CotComCod = &parCotComCod

If &CotComCod > 0
	For Each Order EmpCod, CotComCod
		Where EmpCod = &EmpCod
		Where CotComCod= &CotComCod
		
		CotComFilCod = &CotComFilCod
		CotComNom = &CotComNom
		CotComLctCod = &CotComLctCod
		CotComFunCod = &CotComFunCod
		CotComDtaLim = &CotComDtaLim
		CotComObs = &CotComObs
	EndFor
	
	Commit
Else
	UltimoCodigoEmpresa.Call(domParCod.COTACAoCOMPRA, &EmpCod, 0, &CotComCod)
	
	New
		EmpCod = &EmpCod
		CotComCod = &CotComCod
		CotComFilCod = &CotComFilCod
		CotComNom = &CotComNom
		CotComSts = StatusCotacao.Pendente
		CotComDtaEms = serverdate()
		CotComLctCod = &CotComLctCod
		CotComFunCod = &CotComFunCod
		CotComDtaLim = &CotComDtaLim
		CotComObs = &CotComObs
	EndNew

	Commit
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
