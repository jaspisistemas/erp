      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


Do CAse
	CAse &OqueFazer = 'UPD'
		For Each Order SupCod
			Where SupCod = &SupCod
			SupNom = &SupNom
			SupEmail = &SupEmail
			
			Exit
		When none
			
			&NewSupCod = 0
			For Each Order SupCod
				&NewSupCod = SupCod
				Exit
			EndFor
			&NewSupCod -= 1
			
			NEw
				SupCod = &NewSupCod
				SupNom = &SupNom
				SupEmail = &SupEmail
			EndNew
			
			AtualizaSuporteEmpresa.Call(&NewSupCod)
		EndFor
		
		Commit
	CAse &OqueFazer = 'INS'
		NEw
			SupCod = &SupCod
			SupNom = &SupNom
			SupEmail = &SupEmail
		EndNew
		Commit
EndCase

]]></Source>
