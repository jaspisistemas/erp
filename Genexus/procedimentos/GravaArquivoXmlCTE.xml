      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CteArqXml = ''
&xmlNFe.Open(&ArquivoPronto)    
Do While  not &xmlNFe.EOF
    &CteArqXml += &xmlNFe.ReadRawXML()
    &xmlNFe.Read()
Enddo
&xmlNFe.Close()

If &CteArqXml <> ''
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		CteArqXml = &CteArqXml
		Exit
	EndFor
EndIF


commit
]]></Source>
