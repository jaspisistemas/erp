      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&EstQtdCus = 0
//parm(in:&EmpCod, in:&FilCod, in:&ProCod, in:&ProGraCod, in:&EstQTd , out:&EstQtdCus);
if &EstQTd > 0
	&Count = &EstQTd
Else
	&Count = 1
Endif

//PEDIDO
For Each order EmpCod, FilCod, PedProEstProCod, PedProEstProGraCod,LctTip,LctAtuEst, (PedHorFat)
	where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedProEstProCod = &ProCod
	Where PedProEstProGraCod = &ProGraCod
	Where LctTip = TipoLancamento.EntradaMercadoria
	Where LctAtuEst = Status_EntradaSaida.Entrada
	Where PedSts in (Status_Pedido.FECHADO, Status_Pedido.SEPARANDO)
	Where PedQtd > 0
	Where PedVlrUntComDsc > 0
	
	Do Case
		Case PedQtd <= &Count
			&Count -= PedQtd
			&PedVlrUntDsc += PedVlrUntComDsc*PedQtd
		Case PedQtd > &Count
			&PedVlrUntDsc += PedVlrUntComDsc*&Count
			&Count = 0
	EndCAse
	
	if &Count = 0
		exit
	EndIf
EndFor

if &PedVlrUntDsc > 0 and &EstQTd > 0
	&EstQtdCus = &PedVlrUntDsc / &EstQTd
Endif
]]></Source>
