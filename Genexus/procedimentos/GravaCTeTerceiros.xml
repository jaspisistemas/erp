	Endif
EndIf


Sub 'GetPessoa'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&CteTomFan = Trim(SubStr(retiraCaracteresEspeciais.Udp(PesFan),1,60))
		If PesTip = TipoPessoa.JURIDICA
			&CteTomCnpj = RetornaSoNumeros.Udp(PesCnpj)
		Else
			&CteTomCpf = RetornaSoNumeros.Udp(PesCpf)
		EndIf
		&CteTomRaz = PesRaz
		&CteTomLog = Trim(SubStr(retiraCaracteresEspeciais.Udp(PesLog),1,60))
		&CteTomNro = PesNro
		&CteTomBai = trim(retiraCaracteresEspeciais.Udp(PesBai))
		&CteTomCpl = trim(retiraCaracteresEspeciais.Udp(PesCpl))
		&CteTomCep = RetornaSoNumeros.Udp(PesCep) 				
		&CteTomCidCod = PesCidIBGE
		&CteTomCidNom = trim(retiraCaracteresEspeciais.Udp(PesCidNom))
		&CteTomUfe = PesCidUfeCod
		&CteTomPaiCod = PesCidPaiCod
		&CteTomPaiNom = PesCidPaiNom
		&CteTomInsEst = trim(RetornaSoNumeros.Udp(PesInsEst))
		&PesGruImpFin = PesGruImpFin
		For each Order PesEmlCod
			&CteTomEml = PesEml
			exit
		EndFor
		
		For Each Order PesFonCod
			&CteTomFon = trim(RetornaSoNumeros.Udp(PesFonNum))
			exit
		EndFor
		exit
	EndFor
EndSub


Sub 'GetDestinatario'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CteDesCod
		If PesTip = TipoPessoa.JURIDICA
			&CteDesCnpj = trim(RetornaSoNumeros.Udp(PesCnpj))
		Else
			&CteDesCpf = trim(RetornaSoNumeros.Udp(PesCpf))
		EndIf
		&CteDesRaz = Trim(SubStr(retiraCaracteresEspeciais.Udp(PesRaz),1,60))
		&CteDesLog = Trim(SubStr(retiraCaracteresEspeciais.Udp(PesLog),1,60))
		&CteDesNro = PesNro
		&CteDesBai = trim(retiraCaracteresEspeciais.Udp(PesBai))
		&CteDesCpl = trim(retiraCaracteresEspeciais.Udp(PesCpl))
		&CteDesCep = trim(RetornaSoNumeros.Udp(PesCep))
		&CteDesCidCod = PesCidIBGE
		&CteDesCidNom = trim(retiraCaracteresEspeciais.Udp(PesCidNom))
		&CteDesUfe = PesCidUfeCod
		&CteDesPaiCod = PesCidPaiCod
		&CteDesPaiNom = PesCidPaiNom
		If PesInsEst.Trim() <> 'ISENTO'
			&CteDesIns = trim(RetornaSoNumeros.Udp(PesInsEst))
		Else
			&CteDesIns = 'ISENTO'
		EndIf
		&ImpGruImpCod = PesGruImpCod
		&CteDesSuf = PesSuf
		For each Order PesEmlCod
			&CteDesEml = PesEml
			exit
		EndFor
		
		For Each Order PesFonCod
			&CteDesFon = trim(RetornaSoNumeros.Udp(PesFonNum))
			exit
		EndFor
		exit
	EndFor
EndSub
