			CteTomRaz    = &CteTomRaz
			CteTomFan    = &CteTomFan
			CteTomCnpj   = &CteTomCnpj 
			CteTomCpf    = &CteTomCpf 
			CteTomEml    = &CteTomEml
			CteTomLog    = &CteTomLog
			CteTomNro    = &CteTomNro 
			CteTomBai    = &CteTomBai
			CteTomCpl    = &CteTomCpl
			CteTomCep    = &CteTomCep 				
			CteTomCidCod = &CteTomCidCod 
			CteTomCidNom = &CteTomCidNom
			CteTomInsEst = &CteTomInsEst
			CteTomFon    = &CteTomFon
			CteTomUfe    = &CteTomUfe
			CteTomPaiCod = &CteTomPaiCod
			CteTomPaiNom = &CteTomPaiNom
				
			if &CteEntSai = Status_EntradaSaida.Entrada 
				CteIniCidCod 	= &CteDesCidCod
				CteIniCidNom 	= &CteDesCidNom
				CteIniUfe 		= &CteDesUfe
				
				CteTerCidCod 	= &FilCidCod
				CteTerCidNom 	= &FilCidNom
				CteTerUfe 		= &FilCidUfeCod
			Else //SAIDA
				CteIniCidCod 	= &FilCidCod
				CteIniCidNom 	= &FilCidNom
				CteIniUfe 		= &FilCidUfeCod
				
				CteTerCidCod 	= &CteDesCidCod
				CteTerCidNom 	= &CteDesCidNom
				CteTerUfe 		= &CteDesUfe
			Endif
		
			CteNum 			= &CteNum
			CteSer 			= &CteSer
			CteModCod 		= &CteModCod
			CteDtaEms 		= &CteDtaEms
			CteDtaSai 		= &CteDtaSai
			CteChv 			= &CteChv
			CteCfop 		= &CteCfop
			CteImpCst 		= &CteImpCst
			CteImpVbc 		= &CteImpVbc
			CteImpAli 		= &CteImpAli
			CteImpVlr 		= &CteImpVlr
			CteVlrRecSer 	= &CteVlrRecSer
			CteVlrTotPreSer = &CteVlrTotPreSer	
			CteSts 			= Status_NFe.Autorizada	
			CteStsFin 		= Status_Financeiro.Aberto
		EndNEw
		
		Commit
	Else
		For Each Order EmpCod, FilCod, CteCod
