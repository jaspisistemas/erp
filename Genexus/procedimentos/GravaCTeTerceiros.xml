				CteIniCidNom = &FilCidNom
				CteIniUfe = &FilCidUfeCod
				
				CteTerCidCod = &CteDesCidCod
				CteTerCidNom = &CteDesCidNom
				CteTerUfe = &CteDesUfe
			Endif
		
			CteTomCod = &CteTomCod 
			&PesCod = &CteTomCod
			do 'GetPessoa'

			CteTomRaz    = &CteTomRaz
			CteTomFan    = &CteTomFan
			CteTomCnpj   = &CteTomCnpj 
