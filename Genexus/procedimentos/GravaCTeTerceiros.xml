	Where FilCod = &FilCod
	
	&FilCidCod = FilCidCod
	&FilCidNom = FilCidNom
	&FilCidUfeCod = FilCidUfeCod
	
	Exit
EndFor

if &OqueFazer = 'ADD'
	if &CteCod = 0
