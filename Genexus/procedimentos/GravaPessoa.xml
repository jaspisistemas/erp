      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PesCod=0
UltimoCodigoEspecial.Call(domParCod.PESSOA, &EmpCod, 0, &PesCod)

New 
	EmpCod = &EmpCod
	PesCod = &PesCod
	PesRaz = &PesRaz
	PesRaz = PesRaz.Replace('&', 'E')
	PesFan = &PesFan
	PesFan = PesFan.Replace('&', 'E')
 	PesRazNf = &PesRazNF
	PesRazNf = PesRazNf.Replace('&', 'E')
	
	PesIsFor = false
	PesIsCli = false
	PesIsTra = false
	PesIsVen = False
	PesIsFun = false
	
	PesSts = Status_AtivoInativo.ATIVO
	
	Do CAse
		Case &OqueFazer = 'CLI' or &OqueFazer = 'CON'
			PesIsCli = true
		Case &OqueFazer = 'FOR'
			PesIsFor = true
		Case &OqueFazer = 'FUN'
			PesIsFun = true
		Case &OqueFazer = 'VEN'
			PesIsVen = true
		Case &OqueFazer = 'TRA'
			PesIsTra = true
		Case &OqueFazer = 'MOT'
			PesIsMot = true
	EndCase

	PesCidCod = &PesCidCod
	PesInsEst = &PesInsEst 
	PesInsMun = &PesInsMun
	PesCadPro = &PesCadPro
	PesDtaNas =  &PesDtaNas
	PesRg     = &PesRg
	PesCnpj   = &PesCnpj
	PesCpf    = &PesCpf
	PesTip    = &PesTip
	PesSuf 	  = &PesSuf
	PesVenAprz = Status_SimNao.Sim
	PesCliCrd = &PesCliCrd
	
	//Endereço
	PesLog = &PesLog
	PesNro = &PesNro
	PesBai = &PesBai
	PesCep = &PesCep
	PesCpl = &PesCpl
	PesProAtv = 'N'
	PesExtVenCod = 1
	OriCod = &OriCod
	RatCod = &RatCod
	PesGruImpCod = &PesGruImpCod
	PesVenAprz = Status_SimNao.Sim
	
	PesEmpSecCod = &PesEmpCodSec
	PesDtaVctCer = &PesDtaVctCer
	PesEscCtbCod = &PesEscCtbCod
	PesObs = &PesObs
	
	PesDscMax = 100
	PesDtaCad = serverdate()
	PesDtaAlt = serverdate()
	PesDtaHorAlt = serverNow()
	PesAltFunCod = &PesAltFunCod
Endnew

commit

if not &PesEml.IsEmpty()
	New
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesEmlCod = 1
		PesEml = &PesEml
		PesEmlFin = true
		PesEmlPed = true
		PesEmlFat = true
	EndNew
EndiF

if not &PesFonNum.IsEmpty()
	New
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesFonCod = 1
		PesFonTpo = TipoTelefone.OUTROS
		PesFonNum = &PesFonNum
		PesFonOpe = OperadoraFone.OUTRA
	EndNew
EndiF

Commit

AtualizaEnderecoCliente.Call( &EmpCod, &PesCod)
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
