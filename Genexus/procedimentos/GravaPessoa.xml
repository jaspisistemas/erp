	in:&PesLog,in:&PesNro,in:&PesBai,in:&PesCep,
	in:&PesCpl,in:&PesEml,in:&PesFonNum, in:&PesCnpj, 
	in:&PesCpf, in:&PesTip, in:&PesAltFunCod, in:&RatCod, 
	in:&OriCod, in:&PesSuf, in:&PesGruImpCod, 
	in:&PesEmpCodSec, in:&PesDtaVctCer, in:&PesEscCtbCod, 
