      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each ORder EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	
	&mensagem = format('BLOQUETO ANTERIOR: %1, RETORNO: %2', trim(CreBloNro), trim(toformattedString(CreDtaRet)))
	&OldCreBloNro	= CreBloNro
	
	CreBloNro = &CreBloNro
	CreDtaRet = &CreDtaRet
	
	Do Case
		Case CreCbrCtaBanBanCod 	= '077'
			If (Not CreCodSol.IsEmpty() Or Not CreCodSol.IsNull())
				&CreCbrCod		= CreCbrCod
				Do 'GetLocalCobranca'
				
				If &IsErro	= False And (Not CreCodSol.IsEmpty() Or Not CreCodSol.IsNull())
					&MotivoVarChar	= 'Data de vencimento alterada.'
					prcCancelarCobranca_Inter.Call(&EmpCod, &FilCod, 0, '', CreCod, &CreCbrCod, &CbrChaTra, &contacorrente, CreCodSol, &MotivoVarChar, &Mensagem)
				EndIf
			EndIf
		Case CreCbrCtaBanBanCod 	= '748'
			If (Not CreBloNro.IsEmpty() Or Not CreBloNro.IsNull() And Not CreDtaRet.IsEmpty() Or Not CreDtaRet.IsNull())
				prcCancelarCobranca_Sicredi.Call(&EmpCod, &FilCod, 0, '', CreCod, &CreCbrCod, &OldCreBloNro, &IsBaixaOk, &mensagem)
			EndIf
	EndCase
	
	If &CreBloNro.IsEmpty()
		CreCodBar 	= ''
		CreLinDig 	= ''
		CreQrCode 	= ''
		CreTxId 	= ''
		CreBloNro	= ''
		CreCodSol	= ''
	EndIf
	
	Exit
endFor

Commit
GravaCobranca.call(&EmpCod,&FilCod,&CreCod,&mensagem,0,0,&CrePrmPag, '00:00:00', TipoObservacaoDuplicata.INTERNA)

Sub 'GetLocalCobranca'
	
	&IsErro 		= False
	For each Order EmpCod, CbrCod, CrbRegAut
		Where EmpCod 	= &EmpCod
		Where CbrCod 	= &CreCbrCod
		Where CrbRegAut = Status_SimNao.Sim
		
		Do Case
			Case CbrCtaBanBanCod	= '077'
				&contacorrente	= CbrNroCon.Trim() + CbrNroConDig.Trim()
				If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow()
					&CbrChaTra 			= CbrChaTra
				Else
					prcOAuth_Inter.Call(&EmpCod, &FilCod, &PesCod, CbrCod, &CbrChaTra, &Mensagem)
					If Not &Mensagem.IsEmpty()
						&IsErro			= True
					EndIf
				EndIf			
		EndCase
	
		Exit
	When None
		&IsErro	= True
	EndFor

EndSub
]]></Source>
