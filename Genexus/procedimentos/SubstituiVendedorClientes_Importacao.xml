      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Total =  &SdtImportaClienteVendedor.SdtImportaClienteVendedorSucess.Count
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

For &ClienteSucesso In &SdtImportaClienteVendedor.SdtImportaClienteVendedorSucess
	if &ClienteSucesso.PesIntVenCod > 0 And &ClienteSucesso.PesIntVenCod <> &ClienteSucesso.OldPesIntVenCod
		&PesSacDlg = '#JASPI# Transferido do Televendas:' + trim(str(&ClienteSucesso.OldPesIntVenCod)) + ' Para Televendas:' + trim(Str(&ClienteSucesso.PesIntVenCod))
		GravaLigacaoTelevendas.Call(&EmpCOd, &ClienteSucesso.PesCod, &ClienteSucesso.PesIntVenCod, true, Status_InternoExterno.INTERNO, &PesSacDlg,  serverdate(), 'I', &ContextPesCod)
	EndIF
	
	if &ClienteSucesso.PesExtVenCod > 0 And &ClienteSucesso.PesExtVenCod <> &ClienteSucesso.OldPesExtVenCod
		&PesSacDlg = '#JASPI# Transferido do Vendedor:' + trim(str(&ClienteSucesso.OldPesExtVenCod)) + ' Para Vendedor:' + trim(Str(&ClienteSucesso.PesExtVenCod))
		GravaLigacaoTelevendas.Call(&EmpCOd, &ClienteSucesso.PesCod, &ClienteSucesso.PesExtVenCod, true, Status_InternoExterno.ExTERNO, &PesSacDlg, serverdate(), 'E', &ContextPesCod)
	EndIF
	
	SubstituiVendedorVinculos.Call(&EmpCod, &ClienteSucesso.PesCod, &ClienteSucesso.PesExtVenCod, &ClienteSucesso.PesIntVenCod, &Count)				
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
EndFor
Commit


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub
]]></Source>
