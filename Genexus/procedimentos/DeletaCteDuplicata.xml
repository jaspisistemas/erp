      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FilCod,CteCod,CteDupCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteDupCod = &CteDupCod when not &CteDupCod = 0
	
	&CteDupCreSeq = CteDupCreSeq
	&CteDupFilCod = CteDupFilCod
	Do 'CancelaDuplicata'
	Delete
EndFor

commit

Sub 'CancelaDuplicata'
	For Each Order EmpCod,FilCod,CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &CteDupFilCod
		Where CreCod = &CteDupCreSeq
		
		CreSts = Status_Duplicata.CANCELADA
		
		GravaCobranca.call(EmpCod,FilCod,CreCod,'Duplicata Cancelada via CT-e',&CreMetCod,&CreResCob,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
		exit
	EndFor		
EndSub

	
]]></Source>
