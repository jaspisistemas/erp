      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	
	//aqui vai excluir o pagto da duplicata, que foi utilizada como crédito no pedido e voltar a duplicata par aberto restaurando assim o crédito do cliente.
	For Each Order EmpCod, FilCod, CreCod, CrePagCod
		Where EmpCod = &EmpCod 
		Where FilCod = &FilCod
		Where CrePagVinPedCod = &PedCod 
		Where CrePagSts <> Status_Caixa.Cancelado or CrePagSts.IsNull()
		
		&SdoCreCod = CreCod 
		RemoveFinanceiroDuplicata.Call(EmpCod, FilCod, CreCod, CreMovCod, CreMovItmCod,CrePagCod, &IsAchouPagamentos)
		CrePagSts = Status_Caixa.Cancelado
		
	EndFor

	commit
	AtualizaSaldoDuplicata.Call(&EmpCod, &SdoCreCod,&FilCod)
	
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
