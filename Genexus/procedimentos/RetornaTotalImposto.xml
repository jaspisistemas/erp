      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon144_FreteBaseCalculoICMS, &TCon144_FreteBaseCalculoICMS)
//RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon145_IpiBaseCalculoICMS, &TCon145_IpiBaseCalculoICMS)
//RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon147_ExcluirIcmsPisCofins, &TCon147_ExcluirIcmsPisCofins)

&ImpostoCadastrado = false

if &IsNotas = false
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProPesLiq = ProPesLiq		
		Exit
	EndFor

	do 'CalculaValorUnitarioTotal'

	&tmpProCod = &ProCod
	do 'tabImposto'
	do 'CalculaImpostos' 
	
	&TotalImpostoItem = &sdtImpostoProduto.ProVlrIpi + &sdtImpostoProduto.ProVlrIcmSt
Else
	&ImpostoCadastrado = true
	For Each Order EmpCod, NfeFilCod, NfePedCod,NfeProCod,NfeProTer
		Where EmpCod = &EmpCod
		Where NfeFilCod = &FilCod
		Where NfePedCod = &PedCod
		Where NfeProCod = &ProCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts in (Status_NFe.Autorizada,Status_NFe.Digitando)
	
		&TotalImpostoItem += (NfeProVlrImcsSt  + NfeProVlrIpi + NfeProVlrFCPIcmsSt)
	EndFor
EndIF


Sub 'CalculaValorUnitarioTotal'
	&tmpPedVlrUntNov = &PedVlrUnt
	
	If &PedTpcVlr > 0
		&tmpPedVlrUntNov = &tmpPedVlrUntNov - round(((&tmpPedVlrUntNov * &PedTpcVlr) / 100), 5)
	EndIF
	
	&PedVlrItm = Round(&tmpPedVlrUntNov * &Pedqtd, 2)
EndSub
	
Sub 'CalculaImpostos'
	
	if &sdtCadastrotabelaImpostoCbs.CImpCstCod in (domSituacaoTributariaVarchar.CST02,domSituacaoTributariaVarchar.CST15, domSituacaoTributariaVarchar.CST53, domSituacaoTributariaVarchar.cst61)		
		&ProBasVlrIcm = &Pedqtd * &ProPesLiq
	Else
		&ProBasVlrIcm  = &PedVlrItm
	EndIf

	&sdtImpostoProduto = new()
	&sdtImpostoProduto.ProBasVlrIcm = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasVlrIcmSt = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasVlrIpi = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasPis = &ProBasVlrIcm
	&sdtImpostoProduto.ProBasCofins = &ProBasVlrIcm
	&sdtImpostoProduto.ValorTotalProduto = &ProBasVlrIcm // TOTAL PRODUTO 

	CalculaImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs, &sdtImpostoProduto) //Calcula impostos
	
EndSub

sub 'tabImposto'
	RetornaRegimeTributarioFilial.Call(&EmpCod, &FilBasImp, &FIlRegTrib, &CImpOriUfeCod)
	&sdtCadastroTabelaImpostoCbs = new()
	&sdtCadastroTabelaImpostoCbs.EmpCod = &EmpCod
	&sdtCadastroTabelaImpostoCbs.CImpTbFilCod = &FilBasImp
	&sdtCadastroTabelaImpostoCbs.CImpLctCod = &LctBasImpCod
	&sdtCadastroTabelaImpostoCbs.CImpOriUfeCod = &CImpOriUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpDstUfeCod = &PedCliCidUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpGruImpCod = &PedCliGruImpCod
	&sdtCadastroTabelaImpostoCbs.CImpCatCod = &ImpCatCod
	&sdtCadastroTabelaImpostoCbs.ProCod = &tmpProCod
	&sdtCadastroTabelaImpostoCbs.CImpDtaIni = serverdate()
	prcRetornaConfiguracaoImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs)
	
	if &sdtCadastrotabelaImpostoCbs.sts = 'S' //cadastrado
		&ImpostoCadastrado = true
	Endif
EndSub
]]></Source>
