      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &OqueFazer = 'ADD'
	For Each Order EmpCod, FilCod, OpeCod,OpeNfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where OpeCod = &OpeCod
		Where OpeNfeCod = &OpeNfeCod
		
		msg('ATENÇÃO, A nota fiscal Nro'+trim(str(&OpeNfeNro))+' de valor ' +&OpeNfeVlrTot.ToFormattedString()+ ' já foi adicionado!')
		OpeNfeChv 		= &OpeNfeChv
		OpeNfeNro 		= &OpeNfeNro
        OpeNfeSer 		= &OpeNfeSer
		OpeNfeDta		= &OpeNfeDta
		OpeNfeVlrTot 	= &OpeNfeVlrTot		
		OpeNfeVlrUni 	= &OpeNfeVlrUni		
		OpeNfeNcm 		= &OpeNfeNcm
		OpeNfeUndMed	= &OpeNfeUndMed
		OpeNfeTipCal 	= &OpeNfeTipCal
		OpeNfeQtdMerEmb = &OpeNfeQtdMerEmb
		OpeNfeTolPerTip = &OpeNfeTolPerTip
		OpeNfeTolPerVlr = &OpeNfeTolPerVlr
		
		Exit		
	When none		
		For Each Order EmpCod, FilCod, OpeCod, (OpeNfeCod)
			Where EmpCod 	= &EmpCod
			Where FilCod 	= &FilCod
			Where OpeCod 	= &OpeCod
			&auxOpeNfeCod 	= OpeNfeCod
			Exit
		EndFor
		&auxOpeNfeCod += 1
		
		new
			EmpCod 			= &EmpCod
			FilCod 			= &FilCod
			OpeCod 			= &OpeCod
			OpeNfeCod		= &auxOpeNfeCod
			OpeNfeChv		= &OpeNfeChv
			OpeNfeNro 		= &OpeNfeNro
	        OpeNfeSer 		= &OpeNfeSer
			OpeNfeDta		= &OpeNfeDta
			OpeNfeVlrTot 	= &OpeNfeVlrTot		
			OpeNfeVlrUni 	= &OpeNfeVlrUni		
			OpeNfeNcm 		= &OpeNfeNcm
			OpeNfeUndMed 	= &OpeNfeUndMed
			OpeNfeTipCal 	= &OpeNfeTipCal
			OpeNfeQtdMerEmb	= &OpeNfeQtdMerEmb
			OpeNfeTolPerTip = &OpeNfeTolPerTip
			OpeNfeTolPerVlr = &OpeNfeTolPerVlr
			msg('Nota fiscal de Nro '+trim(str(&OpeNfeNro))+' e valor ' +&OpeNfeVlrTot.ToFormattedString()+ ' foi adicionado com sucesso!')
		EndNEw
	EndFor
Else
	For Each Order EmpCod, FilCod, OpeCod, OpeNfeCod
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		Where OpeNfeCod = &OpeNfeCod
		Delete
		Exit
	EndFor
EndIF

prcOperacaoTransporteAtualizaPeso.Call(&EmpCod, &FilCod, &OpeCod)

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
