      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Codigo Barras
prcRetornaCodigoBarras.call(&OrigemEmpCod, &OrigemProCod, &OrigemProBar)

//Pessoas Empresa
prcRetornaDadosEmpresaVinculo.Call(&DestinoEmPCod, &OrigemEmpCod, &OrigemPesCod, &OrigemPesRaz)
prcRetornaDadosEmpresaVinculo.Call(&OrigemEmpCod, &DestinoEmPCod, &DestinoPesCod,&DestinoPesRaz)


//Localiza Produto
if not &OrigemProBar.IsEmpty()
	For Each Order EmpCod, ProCod
		Where EmpCod = &DestinoEmPCod
		Where ProSts = Status_Produto.ATIVO
		Where ProBar = &OrigemProBar
		
		&DestinoProCod = ProCod
		&DestinoProRef = ProRef
		
		Exit
	EndFor
Endif

//Vincula
if not &DestinoProCod.IsEmpty()	
	if not &OrigemPesCod.IsEmpty() and not &DestinoPesCod.IsEmpty()
		prcatualizaVinculoEmpresa.Call(&DestinoEmPCod, &DestinoProCod, &DestinoPesCod, &OrigemProRef)
		prcatualizaVinculoEmpresa.Call(&OrigemEmpCod , &OrigemProCod , &OrigemPesCod, &DestinoProRef)
	Endif
EndIf
]]></Source>
