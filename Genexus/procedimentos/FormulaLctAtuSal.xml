      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[ 

For Each Order EmpCod, LctCod
	Where EmpCod = &EmpCod
	Where LctCod = &LctCod
	
	Do Case 
		Case LctTip = TipoLancamento.EntradaMercadoria or LctTip = TipoLancamento.DevolucaoVenda or LctTip = TipoLancamento.OrcamentoCompra or LctTip = TipoLancamento.RemessaEntrada
			&LctAtuSal = Status_EntradaSaida.Entrada 
			
		Case LctTip = TipoLancamento.SaidaMercadoria or LctTip = TipoLancamento.DevolucaoCompra or LctTip = TipoLancamento.OrcamentoVenda or LctTip = TipoLancamento.remessaSaida or LctTip = TipoLancamento.AmostraGratis or LctTip = TipoLancamento.LocacaoPecas
			&LctAtuSal = Status_EntradaSaida.Saida
			
		Otherwise
			&LctAtuSal = Status_EntradaSaida.Nenhum
	EndCase

	Exit
EndFor
 
]]></Source>
