      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if not &InsdtConfDuplicataWbs.EmpCodSec.IsEmpty()
	For Each Order EmpCod, PesEmpSecCod, PesCod
		Where EmpCod = 1 //JASPI
		Where PesEmpSecCod = &InsdtConfDuplicataWbs.EmpCodSec
		
		&CreCliCod = PesCod
		
		Exit
	EndFor
	
	if &CreCliCod > 0
		For Each Order EmpCod, FilCod, CreCliCod, CreRecPag, CreDtaVct
			Where EmpCod = 1
			Where CreCliCod = &CreCliCod
			Where CreRecPag = ReceberPagar.Receber
			Where CreSts <> Status_Duplicata.CANCELADA and CreSts <> Status_Duplicata.PERDA
			Where CreVlrSdo > 0
			Where CreCbrImp = TipoImpressao.GerarBoleto or CreCbrImp = TipoImpressao.ImprimirBoleto
			
			&outsdtConfDuplicataWbs.EmpCod = EmpCod
			&outsdtConfDuplicataWbs.FilCod = FilCod
			&outsdtConfDuplicataWbs.CreCod = CreCod
			&outsdtConfDuplicataWbs.CreCliCod = CreCliCod
			&outsdtConfDuplicataWbs.CreDtaVct = CreDtaVct
			
			&outsdtConfDuplicataWbs.Mensagem = 'DUPLICATA DISPONIVEL PARA PAGAMENTO'
			&outsdtConfDuplicataWbs.Codigo = 1
			
			Exit
		When none
			&outsdtConfDuplicataWbs.Mensagem = 'NENHUMA DUPLICATA PENDENTE'
			&outsdtConfDuplicataWbs.Codigo = 0
		EndFor
	Else
		&outsdtConfDuplicataWbs.Mensagem = 'NÃO LOCALIZADO O CLIENTE'
		&outsdtConfDuplicataWbs.Codigo = 3
	Endif
Else
	&outsdtConfDuplicataWbs.Mensagem = 'SABE DE NADA: ' + trim(&InsdtConfDuplicataWbs.EmpCodSec)
	&outsdtConfDuplicataWbs.Codigo = 2
Endif
]]></Source>
