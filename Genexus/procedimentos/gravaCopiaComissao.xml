      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, LctCod
	Where EmpCod = &parEmpcod
	Where LctCod = &DstLctCod when not &DstLctCod = 0
	Where LctPagCom = Status_SimNao.Sim when &DstLctCod = 0
	
	prcGravaComissoes.Call(&WwpContext, EmpCod, &DstPesCod, LctCod, &ComTabNor, &ComTabPrm, &sdtComissaoVendedor)
EndFor


Commit
]]></Source>
