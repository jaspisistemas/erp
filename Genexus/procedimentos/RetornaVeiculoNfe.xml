      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProRef.SetEmpty()

For Each Order EmpCod, VeiPla
	Where EmpCod = &EmpCod
	Where VeiPla = &PedVeiPla
	
	&CorNom = CorNom	
	&NfeProVeiAnoFab = VeiAnoFab
	&NfeProVeiAnoMod =  VeiAnoMod
	&NfeProCod = VeiNfeProCod
	&NfeProNom = VeiMod
	&NfeProVeiCha = VeiCha
	&NfeProVeiRen = VeiRen 
	&NfeProVeiCom = VeiComb
	&NfeProVeiKm = VeiUltKm
	
	Exit
EndFor


For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &NfeProCod
	
	&ProRef = ProRef
	
	Exit
EndFor
]]></Source>
