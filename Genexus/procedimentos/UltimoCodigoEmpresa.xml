      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ParUltCod = 0

For Each Order EmpCod, ParCod, ParFiLCod
	Where EmpCod = &EmpCod
	Where ParCod = &ParCod
	Where ParFiLCod = &FiLCod
	ParUltCod += 1
	commit //JDF COLOQUEI AQUI DENTRO PARA VER SE DIMINUI O PROBLEMA DE DOIS REGISTROS COM MESMO CODIGO.
	&ParUltCod = ParUltCod	
	Exit
When none
	&ParSeq = 0
	For Each Order EmpCod, (ParSeq)
		Where EmpCod = &EmpCod
		&ParSeq  = ParSeq
		Exit
	EndFor
	&ParSeq += 1
	
	new
		EmpCod = &EmpCod
		ParSeq = &ParSeq
		ParCod = &ParCod
		ParChv = trim(&ParCod.tostring())
		ParFiLCod = &FiLCod
		ParNom = &ParCod.EnumerationDescription()
		ParUltCod = 1
		&ParUltCod = 1
	EndNEw

	commit
EndFor


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
