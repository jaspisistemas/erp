      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AuxVeiPla = &parmVeiPla

if Substr(&parmVeiPla, 1, 1) <> '-'
	FormataPLACA.call(&EmpCod, &AuxVeiPla, &parmVeiPla)
Endif

//&IsLocalizou = false
&VeiculoMensagem = ''

For Each Order EmpCod, VeiPla
	Where EmpCod = &EmpCod
	Where VeiPla = &parmVeiPla
	
	&VeiculoMensagem = trim(VeiMod) + ' , ' + trim(VeiMarNom)
	If not VeiAnoFab.IsEmpty()
		&VeiculoMensagem += ' ' + trim(str(VeiAnoFab)) + '/' + trim(str(VeiAnoMod))
	EndiF

//	&IsLocalizou = true
	
//	For Each Order EmpCod, VeiPla, PesCod
