      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&WinAppGUID = GUID.FromString('f239a0a4-5bff-4b18-b330-3aa0762ab6d2')
&IsContinuar = true

if &ProcessManager.IsCurrentProcessAdmin()
	msg('Bem-vindo, adm', status)
else
	msg('Permissão insuficiente. Inicie como administrador.', status)
	do 'EncerrandoEm5s'
endif

SyncronizaInstanciaAtual(&LogGUID,'NFeComunicador',&WinAppGUID,&Pgmname,&WinAppInsGUID,&IsContinuar)

if not &IsContinuar
	do 'EncerrandoEm5s'
endif

&File.Source = 'ICSharpCode_SharpZipLib_dll'
&APlicativo = trim(&File.GetPath()) + '/appJASPI_NFe_solicitacao.exe' 
&File.Close()

&mensagem = 'Inicializando Comunicador Jaspi-Uninfe'
do 'Mensagem'
&dorme = sleep(1)

Do while &IsContinuar = true
	&SolCod = 0
	&SolDtaHorIni = serverNow()
	
	For Each Order SolEmpCod, SolCod
		Where SolA1A3 <> 'A3'
		Where SolSts = Status_Solicitacao.PENDENTE //PROCURA PENDENTES		
		Where SolDtaHorIni <= &SolDtaHorIni or SolDtaHorIni.IsEmpty() or SolDtaHorIni.IsNull()
		
		if &SolCod <> 0
//			&Comando = format('%1 %2 %3' , trim(&APlicativo), trim(str(&SolEmpCod)), trim(str(&SolCod)))
			&Argumento = format('%1 %2' , trim(str(&SolEmpCod)), trim(str(&SolCod)))
			&ProcessManager.StartProcess(trim(&APlicativo),&Argumento)
			
			&dorme = sleep(1) //JDF - deixar senao da problema no envia email. grava mesma solicitacao para clientes diferentes, tem que fazer nao pegar ultima seq de email e sim um parametro por empresa.
//			&Res     = shell(&Comando, 0) //0=NAO MODAL 1=MODAL
		Endif
		
		&SolCod = SolCod
		&SolEmpCod = SolEmpCod
		
		SolSts = Status_Solicitacao.Executando
		Commit
		
		&mensagem = 'INICIADO ATENDENTE SOLICITACAO....:' + trim(str(SolCod))
		do 'Mensagem'
		
	EndFor
	
	if &SolCod <> 0
//		&Comando = format('%1 %2 %3' , trim(&APlicativo), trim(str(&SolEmpCod)), trim(str(&SolCod)))
		&Argumento = format('%1 %2' , trim(str(&SolEmpCod)), trim(str(&SolCod)))
		&ProcessManager.StartProcess(trim(&APlicativo),&Argumento)
		
//		&Res     = shell(&Comando, 0) //0=NAO MODAL 1=MODAL
	Endif
	
	do 'DoAppContinuaAtivo'
	
	&mensagem = 'Nada a fazer dormindo 1 seg... COUNT.:' + trim(str(&Count))
	do 'Mensagem'
	&dorme = sleep(1)
EndDo

Sub 'DoAppContinuaAtivo'
	AppContinuaAtivo(&WinAppGUID,&WinAppInsGUID,&IsContinuar)
	
	if not &IsContinuar
		msg('Instância não mais ativa', status)
		do 'EncerrandoEm5s'
	endif
Endsub

Sub 'Mensagem'
	msg(&mensagem  + ' Hora: ' + serverTime(), status)
EndSub

Sub 'EncerrandoEm5s'
	msg('Encerrando em 5s', status)
	&dorme = sleep(5)
	return
EndSub
]]></Source>
