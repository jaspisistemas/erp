      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//GRAVA LOG
&TabelaVarchar = 'PEDIDOPRODUTO'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
&LogErpRegCod1 = trim(Str(&PedCod))


For Each ORder EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCod = &PedItmCod
	
	if &LogErpTabIsLog = true
		&LogErpRegCod2 = trim(toformattedString(&PedItmCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmCfoCod', trim(toformattedString(PedItmCfoCod)), trim(toformattedString(&PedItmCfoCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmCstCod', trim(toformattedString(PedItmCstCod)), trim(toformattedString(&PedItmCstCod)), &LogErpRegGUID )
	Endif
	
	PedItmCfoCod = &PedItmCfoCod
	PedItmCstCod = &PedItmCstCod	
	
	Exit
EndFor

Commit


if not &PedItmCfoCod.IsEmpty() and &PedItmCfoCod.Length() >= 4 and not &PedItmCstCod.IsEmpty() and &IsAtualizarNf = true
	For Each ORder EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &EmPCod
		Where NfeFilCod = &FilCod
		Where NfePedCod = &PedCod
		Where NfePedItmCod = &PedItmCod
		
		NfeCfoCod = &PedItmCfoCod
		NfeSitCod = &PedItmCstCod
		Exit
	EndFor

	Commit
Endif
]]></Source>
