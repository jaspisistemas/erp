      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod,FilCod,CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	&CreMaxCobCod = CreMaxCobCod
	exit
EndFor

New
	EmpCod = &EmpCod
	FilCod = &FilCod
	CreCod = &CreCod
	CreObsTip = &CreObsTip
	CreCobCod = &CreMaxCobCod +1
	CreCobObs = &CreCobObs 
	CreMetCod = &CreMetCod
	CreResCob = &CreResCob
	CrePrmPag = &CrePrmPag
	CrePrmPagHor = &CrePrmPagHor
	CreFunCod = &Context.PesCod
	CreFunNom = &Context.PesRaz
	CreDtaLig = ServerDate()
	CreHorLig = ServerNow()
Endnew

Commit

AtualizaSaldoDuplicata.call(&EmpCod, &CreCod, &FilCod)
]]></Source>
