      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Linha = &PrimeiraLinha
&Excel.Open(&selectedURL)
If &Excel.ErrCode <> 0
	msg(&Excel.ErrDescription)
Else
	Do While &Fim < 500
		
		Do 'LimpaCampos'
		
		&ProCod    = val(&Excel.Cells(&Linha,&ColunaProduto).Text)
		&ConForCod = &Excel.Cells(&Linha,&CodConcorrente).text
		&ProVlr    = &Excel.Cells(&Linha,&ColunaVlr).Number
		
		If &ProCod.IsEmpty()
			&Fim += 1
		Else
			If &ProVlr > 0	
				Do 'GetProduto'
				Do 'GravaSdt'
			Else
				&IsErro = 'S'	
				msg('Preço do produto: '+trim(str(&ProCod))+ ' não pode ser zero!')
			EndIf
			
			&Fim = 0
		EndIF
		&Linha += 1
	EndDo
EndIf

sub 'GravaSdt'
	For &SdtProdutoConcorrenteItem in &SdtProdutoConcorrente
		if &SdtProdutoConcorrenteItem.ProCod = &ProCod
			&IsErro = 'S'	
			&Mensagem = 'DUPLICIDADE: Produto já Adicionado!'
			Exit
		EndIF	
	EndFor

	If &ConForCod.Trim().IsEmpty()
		&IsErro = 'S'	
		&Mensagem = 'CÓDIGO FORNECEDOR: Vazio!'
	EndIf

	&SdtProdutoConcorrenteItem = new()		
	&SdtProdutoConcorrenteItem.EmpCod    = &EmpCod
	&SdtProdutoConcorrenteItem.ProCod    = &ProCod
	&SdtProdutoConcorrenteItem.ProNom    = &ProNom
	&SdtProdutoConcorrenteItem.ConForCod = &ConForCod
	&SdtProdutoConcorrenteItem.ProVlr    = &ProVlr
	&SdtProdutoConcorrenteItem.Mensagem  = &Mensagem
	&SdtProdutoConcorrenteItem.Erro      = &IsErro
	&SdtProdutoConcorrente.Add(&SdtProdutoConcorrenteItem)
	
EndSub

Sub 'LimpaCampos'
	&Mensagem = ''
	&IsErro = 'N'
EndSub

Sub 'GetProduto'
	
    For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
	    Where ProCod = &ProCod
		where ProSts <> Status_Produto.EXCLUIDO
		&ProNom = ProNom 		
		If ProSts = Status_Produto.INATIVO
			&Mensagem = 'Produto código: '+trim(str(ProCod))+' Inativo!'
			&IsErro = 'S'
		EndIf
		
	    Exit
	When none
		&ProNom = 'PRODUTO NÃO LOCALIZADO'
		&IsErro = 'S'
		
		If not &ProCod.IsEmpty()
           &Mensagem = 'Produto código: ' +trim(str(&ProCod)) + ' não localizado!'
        EndIF
    EndFor
EndSub
]]></Source>
