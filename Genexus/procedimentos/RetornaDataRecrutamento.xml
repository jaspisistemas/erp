      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PesRecDta.SetEmpty()
//TTS tava CERTO tabela recrutamento. Mudo pro errado, ai alterei dinovo
For each Order EmpCod,PesCod,(PesRecCod)
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsEmpty() or PesRecSts.IsNull()
	
	if PesRecSts.IsEmpty() or PesRecSts.IsNull()
		PesRecSts = status_AtivoInativo.ATIVO
	EndIf
	
	Do Case
		Case &Tipo = 'A'  // Admissão
			&PesRecDta = PesRecDtaAdm
		Case &Tipo = 'R'  // Registro
			&PesRecDta = PesRecDtaReg
		Case &Tipo = 'D'  // Demissão
			&PesRecDta = PesRecDtaDem
	EndCase
	Exit
EndFor
]]></Source>
