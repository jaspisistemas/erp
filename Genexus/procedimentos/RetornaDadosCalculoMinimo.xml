      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilPrzEst = FilPrzEst
	Exit
EndFor

prcSelecionaPedidos_MinimoReceita.Call(&EmpCod, &FilCod, &ProCod, &sdtPedidoProduto, &UtilizadaProducao)

//PRODUTOS VENDIDO NO PERIODO
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	where ProCod = &ProCod
	
	&PesForPrzTot = RetornaDiasSeguracaoFornecedor.Udp(EmpCod, ProPadForCod)
	
	&TotalDiasBase = &PesForPrzTot + &FilPrzEst + ProMarSeg + ProSetPrzEst
	
	&TotalVendido = 0
	&TotalCancelado = 0
	
	&MaiorVendidaCancelada = 0
	&MenorVendidaCancelada = 0
	&MaiorVendida = 0
	&MenorVendida = 0
	
	&InicialCalculo = RetornaDataPrimeiraSaida.Udp(EmpCod, &FilCod, ProCod, 1)
	&PrimeiroLancamento = &InicialCalculo
	If (&InicialCalculo < &iniPedDtaEms)
		&InicialCalculo = &iniPedDtaEms
	EndiF
	
	For Each Order EmpCod, FilCod, ProCod
		Where FilCod = &FilCod
		Where PedDtaFic >= &InicialCalculo and PedDtaFic <= &finPedDtaEms
		Where LctCalMin = Status_SimNao.Sim
		Where LctAtuEst = Status_EntradaSaida.Saida
		Where (PedSts = Status_Pedido.FECHADO) or (PedSts in (Status_Pedido.FECHADO,Status_Pedido.SEPARANDO,Status_Pedido.ABERTO) and &IncluirVendasAbertas = Status_SimNao.Sim)
		
		If &MenorVendidaCancelada = 0
			&MenorVendidaCancelada = PedQtdCan
		EndIF
		If &MenorVendida = 0
			&MenorVendida = PedQtd
		EndIF
		
		&TotalVendido += PedQtd
		&TotalCancelado += PedQtdCan
		
		If PedQtd > &MaiorVendida
			&MaiorVendida = PedQtd
		EndIF	
		
		If PedQtdCan > &MaiorVendidaCancelada
			&MaiorVendidaCancelada = PedQtdCan
		EndIF
		
		If &MenorVendida > PedQtd and PedQtd > 0
			&MenorVendida = PedQtd
		EndIF
		
		if &MenorVendidaCancelada > PedQtdCan and PedQtdCan > 0
			&MenorVendidaCancelada = PedQtdCan
		EndIF
	EndFor
	
	&TotalCancelado -= (&MenorVendidaCancelada + &MaiorVendidaCancelada)
	If &TotalCancelado < 0
		&TotalCancelado = 0
	EndIF
	
	&TotalVendido -= (&MaiorVendida + &MenorVendida)
	If &TotalVendido < 0
		&TotalVendido = 0
	EndIF
	
//	&QuantidadeCancelada = &TotalCancelado	
//	&QuantidadeVendida = &TotalVendido
	
	if &IncluirVendasPerdidas = Status_SimNao.Sim
		&TotalVendido += &TotalCancelado
	EndIF
	
	&DiasApuracao = (&finPedDtaEms - &InicialCalculo)
		
	if &DiasApuracao = 0
		&EstMin = &TotalVendido
	else
		&EstMin = (&TotalVendido / &DiasApuracao) 
		If &TotalDiasBase <> 0
			&EstMin = &EstMin * &TotalDiasBase
		EndiF
	endif
	&EstMin += &UtilizadaProducao
EndFor
]]></Source>
