      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	If (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
		&titulo = 'IMPRESSÃO FALTAS DO PEDIDO'
	Else
		&titulo = 'SUPOSTAS FALTAS DO PEDIDO'
	EndIF
	
	Exit
EndFor

MB 4
MT 2

Header
	print Cabecalho
End

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	print DadosPedido
	
	print SupostaTitulo
	
	
	For Each Order EmpCod, FilCod, EstLoc, ProGraRefPadL
		Where PedQtdCan > 0 when (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
		Where PedQtd > 0 and EstQtd < PedQtd when (PedSts <> Status_Pedido.FECHADO and PedSts <> Status_Pedido.SEPARANDO)
		
		&PedQtd = PedQtd
		&EstQtd = EstQtd
		
		If (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
			&PedqtdCan = PedQtdCan
		Else			
			if EstQtd < 0
				&PedqtdCan = PedQtd
			Else
				&PedqtdCan = PedQtd - EstQtd
			EndIf
		EndIf
		
		print SupostaProduto
		
	EndFor
	
	Exit
EndFor

Footer
	print Rodape
End
]]></Source>
