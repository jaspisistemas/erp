      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AloQtdUni = 0
&AloQtdMor = 0
&AloQtdMorLiq = 0
&count = 0

For each Order EmpCod,AloCod
	Where EmpCod = &EmpCod
	&count+=1
	&AloQtdUni += AloQtdUni
	&AloQtdMor += AloQtdMor
	&AloQtdMorLiq += AloQtdMorLiq
EndFor
]]></Source>
