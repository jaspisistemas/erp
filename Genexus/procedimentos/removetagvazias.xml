      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&File.Source = &NomeArquivoXml // Caminho do arquivo XML
&ArquivoXml = ''

// Verifica se o arquivo existe
//If &File.Exists() 
    // Abre o arquivo e realiza a leitura
    &File.OpenRead(&NomeArquivoXml)
    &ArquivoXml = &File.ReadAllText()
    &File.Close()
    &File.delete()
	
//	if &ArquivoXml.IndexOf('<retTrib/>') > 0
//	    MSG('Encontrado: <retTrib/>')
//	else
//	    MSG('Não encontrado: <retTrib/>')
//	endif
	
    // Realiza as substituições necessárias
    &ArquivoXml = &ArquivoXml.Replace('<retTrib/>', '')
    &ArquivoXml = &ArquivoXml.Replace('<compra/>', '')
	
	&ArquivoXml = &ArquivoXml.ReplaceRegEx('<retTrib\s*/>', " ")
	&ArquivoXml = &ArquivoXml.ReplaceRegEx('<compra\s*/>', " ")
	 
//	
//	if &ArquivoXml.IndexOf('<retTrib/>') > 0
//		MSG('Encontrado 2: <retTrib/>')
//	else
//		MSG('Não encontrado 2: <retTrib/>')
//	endif

	
	&File.source = &NomeArquivoXml
	If not &File.Exists()
		&File.Create()
	    // Abre o arquivo para reescrita (elelreescreve por cima)
	    &File.Open()
	    &File.WriteLine(&ArquivoXml)
	    &File.Close()
//		msg('criado')
	Else
//		msg('o arquivo ja existia')
	Endif
//else
//    MSG('Arquivo não encontrado: ' + &NomeArquivoXml)
//Endif
]]></Source>
