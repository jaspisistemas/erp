      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &CatSalItmDtaFin.IsEmpty()
	&CatSalItmDtaFin = serverdate()
EndIf

For Each Order EmpCod, CatSalCod
	Where EmpCod = &EmpCod
	Where CatSalCod = &CatSalCod
	Where &CatSalItmDtaFin <= CatSalItmDtaFin
	
	&CatSalItmVlr = CatSalItmVlr
	Exit
EndFor
]]></Source>
