      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
RetornaTabelaFilial.Call(&EmpCod, &FilCod, &FiltabCod)
&TipoCodigoBarras = TipoCodigoBarras.Code128


If &ImpTabCod.IsEmpty()   // se tabela selecionada em tela for vazia
	&FiltabCod = RetornaTabelaFilial.udp(&EmpCod, &FilCod) // tabela padrao da filial
Else
	&FiltabCod = &ImpTabCod 
EndIf

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&IsColuna1 = true
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	&EtqQtd = EtqQtd
	&ProCod = EtqProCod
	&ProGraCod = EtqProGraCod
	&Coluna1.SetEmpty()
	&EtqProQtdEmb.SetEmpty()
	&Coluna3.SetEmpty()
	do 'GetPreco'
	
	&NomeEmpresa = trim(&FilFan)
	&EtqProQtdEmb = EtqProQtdEmb
	If not EtqProNroLot.Trim().IsEmpty()
		&Coluna3 = 'Lote: '+trim(EtqProNroLot)
	EndIf
	
	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto += ': ' + trim(str(EtqProCod))
		&Codigo = trim(str(EtqProCod))
	Else
		&CodigoProduto += ': ' + trim(EtqNovProCod)
		&Codigo = trim(EtqNovProCod)
	EndIF
	
	
	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF
	
	&NomeProduto  = GxGetMLi(&EtqProNom, 1, 28)
	&NomeProduto1 = GxGetMLi(&EtqProNom, 2, 28)
	
	Do CAse
		Case EtqProBar.Length() =  13
			&NewProBar = format('%1 %2 %3 %4', substr(EtqProBar, 1, 2), substr(EtqProBar, 3, 7), substr(EtqProBar, 10, 3), substr(EtqProBar, 13, 1))
		Case EtqProBar.Length() =  14
			&NewProBar = format('%1 %2 %3 %4', substr(EtqProBar, 1, 1), substr(EtqProBar, 2, 3), substr(EtqProBar, 5, 8), substr(EtqProBar, 13, 2))
		Otherwise
	EndCase
	
	&CodBarrasImage.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqProBar) + '.jpg'
	If not EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqProBar, EtqProBar)
		EndIF
		If &File.Exists()
			&CodBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf
	
	do 'printEtiquetas'
EndFor


Sub 'GetPreco'
	For Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &FiltabCod
		
		For Each Order EmpCod, TabCod, TabColCod
			Where TabColCod = &ImpTabColCod1
			If &NaoMostrarNome = False
				&Coluna1 = TabColNom.Trim() + ': '
			Else
				&Coluna1 = 'Vlr: '
			EndIf
		
			Exit
		EndFor
	
		&IsTem = False
		For Each Order EmpCod, TabCod, TabColCod
			Where TabColCod = &ImpTabColCod2
			
			If &ImpTabColCod1 = 0
				If &NaoMostrarNome = False
					&Coluna1 = TabColNom.Trim() + ': '
				EndIf
			Else
				If &NaoMostrarNome = False
					&Coluna2 = TabColNom.Trim() + ': '
				ELSE				
					&Coluna1 = 'Vlr: '
				EndIF
			EndIf		
		
			&IsTem = True
			Exit			
		EndFor
		
		For Each Order EmpCod, TabCod, ProCod, ProGraCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			
			Do Case
				Case &ImpTabColCod1 = 1 and not TabPrc1.IsEmpty()
					&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc1))
					
				Case &ImpTabColCod1 = 2and not TabPrc2.IsEmpty()
					&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc2))
					
				Case &ImpTabColCod1 = 3and not TabPrc3.IsEmpty()
					&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc3))
					
				Case &ImpTabColCod1 = 4and not TabPrc4.IsEmpty()
					&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc4))
					
				Case &ImpTabColCod1 = 5and not TabPrc5.IsEmpty()
					&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc5))
					
			EndCase
		
			Do Case
				Case &ImpTabColCod2 = 1 and not TabPrc1.IsEmpty() and &IsTem = True
					If &ImpTabColCod1 = 0
						&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc1))
					Else
						&Coluna2 += 'R$ ' + trim(toformattedString(TabPrc1))
					EndIf
					
				Case &ImpTabColCod2 = 2and not TabPrc2.IsEmpty() and &IsTem = True
					If &ImpTabColCod1 = 0
						&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc2))
					Else
						&Coluna2 += 'R$ ' + trim(toformattedString(TabPrc2))
					EndIf
					
				Case &ImpTabColCod2 = 3and not TabPrc3.IsEmpty() and &IsTem = True
					If &ImpTabColCod1 = 0
						&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc3))
					Else
						&Coluna2 += 'R$ ' + trim(toformattedString(TabPrc3))
					EndIf
					
				Case &ImpTabColCod2 = 4and not TabPrc4.IsEmpty() and &IsTem = True
					If &ImpTabColCod1 = 0
						&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc4))
					Else
						&Coluna2 += 'R$ ' + trim(toformattedString(TabPrc4))
					EndIf
					
				Case &ImpTabColCod2 = 5and not TabPrc5.IsEmpty() and &IsTem = True
					If &ImpTabColCod1 = 0
						&Coluna1 += 'R$ ' + trim(toformattedString(TabPrc5))
					Else
						&Coluna2 += 'R$ ' + trim(toformattedString(TabPrc5))
					EndIf
				OtherWise
					&Coluna2 = ''
			EndCase
		
		EndFor
	EndFor
EndSub

sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		print EtiquetaModelo001Col1
	EndFor
EndSub
]]></Source>
