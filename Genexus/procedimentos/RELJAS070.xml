      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	If &Tipo = 'C'
		&titulo = 'CURVA ABC DE CLIENTES'
	Else
		&titulo = 'CURVA ABC DE FORNECEDORES'
	EndIf
	&Periodo = 'Período: '+dtoC(&PedDtaEms)+' até '+Dtoc(&PedDtaEms_Go)
	print Cabecalho
End

//If &IsGravar = true
//	do 'zeracurva'
//EndIf
&SdtCurvaABC.Clear()
//################################################### CLIENTES #########################################################
If &Tipo = 'C' // Clientes
	&TotalVendas = 0
	&TotalMar    = 0
	&PedVlrMar   = 0
	For each Order EmpCod,FilCod,PedSts,LctAtuEst,LctTip,PedDtaEms
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedSts = Status_Pedido.FECHADO
		Where LctAtuEst = Status_EntradaSaida.Saida
		Where LctTip = TipoLancamento.SaidaMercadoria
		Where PedDtaEms >= &PedDtaEms and PedDtaEms <= &PedDtaEms_Go
		Where PedCliCidCod = &CidCod When not &CidCod.IsEmpty()
		Where PedCliCidUfeCod = &UfeCod when not &UfeCod.IsEmpty()
		Where PedCliSts = Status_AtivoInativo.ATIVO When &Status = False
		Where PedVenCod = &PedVenCod when not &PedVenCod.IsEmpty()
		&TotalVendas += PedVlrItmComDsc
		&TotalMar   += PedVlrItmComDsc - PedVlrItmCus 
		&PedVlrMar = PedVlrItmComDsc - PedVlrItmCus 
		&PedVlrBrt = PedVlrItmComDsc
		&PedCliCod = PedCliCod
		&PedCliRaz = PedCliRaz
		
		&isAchou = False
		For &SdtCurvaABCItem in &SdtCurvaABC
			If &SdtCurvaABCItem.PedCliCod = &PedCliCod
				&isAchou = true
				&SdtCurvaABCItem.PedVlrBrt += &PedVlrBrt
				&SdtCurvaABCItem.PedVlrMar += &PedVlrMar
			EndIf
		EndFor
		If &isAchou = False
			&SdtCurvaABCItem = new()
			&SdtCurvaABCItem.PedCliCod = &PedCliCod
			&SdtCurvaABCItem.PedCliRaz = &PedCliRaz
			&SdtCurvaABCItem.PedVlrBrt = &PedVlrBrt
			&SdtCurvaABCItem.PedVlrMar = &PedVlrMar
			&SdtCurvaABC.Add(&SdtCurvaABCItem)
		EndIf
	EndFor
	
	If &SdtCurvaABC.Count > 0 
		If &CurvaPor = 1 // FATURAMENTO
			&SdtCurvaABC.Sort('[PedVlrBrt]')
			Print Menu
			For &SdtCurvaABCItem in &SdtCurvaABC
				&PrtPedCliCod =  &SdtCurvaABCItem.PedCliCod
				&PrtPedCliRaz = &SdtCurvaABCItem.PedCliRaz
				&AuxPedVlrBrt = 0 
				&AuxPedVlrBrt = &SdtCurvaABCItem.PedVlrBrt
				
				&PerSobVlr = 0
				&PerSobVlr = ((&AuxPedVlrBrt / &TotalVendas) * 100)
				&PerVlrAcu += &PerSobVlr	
			    &PedVlrAcu += &AuxPedVlrBrt
				If (&PerVlrAcu < &CurvaB) or (&PerSobVlr > &CurvaB)
			       &Curva = 'A'
			   	else
					&Curva = IIF(&PerVlrAcu < &CurvaC,'B','C')
				Endif
				
				//			If &IsGravar = true
				//				PesAbcCli = &Curva
				//			EndIf
				Print Dados			
			EndFor
		Else// Rentabilidade
			&PerVlrAcu = 0
			&SdtCurvaABC.Sort('[PedVlrMar]')
			Print MenuRentabilidade
			For &SdtCurvaABCItem in &SdtCurvaABC
				&PrtPedCliCod =  &SdtCurvaABCItem.PedCliCod
				&PrtPedCliRaz = &SdtCurvaABCItem.PedCliRaz
				&AuxPedVlrMar = 0 
				&AuxPedVlrMar = &SdtCurvaABCItem.PedVlrMar
				
				&PerSobMar = 0
				&PerSobMar = ((&AuxPedVlrMar / &TotalMar) * 100)
				&PerVlrAcu += &PerSobMar	
			    &PedVlrAcu += &AuxPedVlrMar
				If (&PerVlrAcu < &CurvaB) or (&PerSobMar > &CurvaB)
			       &Curva = 'A'
			   	else
					&Curva = IIF(&PerVlrAcu < &CurvaC,'B','C')
				Endif
				
				//			If &IsGravar = true
				//				PesAbcCli = &Curva
				//			EndIf
				Print DadosRentabilidade			
			EndFor
		EndIf
	Else
		Print Vazio
	EndIf
Else
	//################################################### FORNECEDORES #########################################################
	&TotalVendas = 0
	&TotalQtd    = 0
	&PedVlrMar   = 0
	For each Order EmpCod,FilCod,PedSts,LctAtuEst,LctTip,PedDtaEms
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedSts = Status_Pedido.FECHADO
		Where LctAtuEst = Status_EntradaSaida.entrada
		Where LctTip = TipoLancamento.entradaMercadoria
		Where PedDtaEms >= &PedDtaEms and PedDtaEms <= &PedDtaEms_Go
		Where PedCliCidCod = &CidCod When not &CidCod.IsEmpty()
		Where PedCliCidUfeCod = &UfeCod when not &UfeCod.IsEmpty()
		Where PedCliSts = Status_AtivoInativo.ATIVO When &Status = False
		Where PedVenCod = &PedVenCod when not &PedVenCod.IsEmpty()
		&TotalVendas += PedVlrItmComDsc
		&PedVlrBrt = PedVlrItmComDsc
		&PedCliCod = PedCliCod
		&PedCliRaz = PedCliRaz
		
		&isAchou = False
		For &SdtCurvaABCItem in &SdtCurvaABC
			If &SdtCurvaABCItem.PedCliCod = &PedCliCod
				&isAchou = true
				&SdtCurvaABCItem.PedVlrBrt += &PedVlrBrt
			EndIf
		EndFor
		If &isAchou = False
			&SdtCurvaABCItem = new()
			&SdtCurvaABCItem.PedCliCod = &PedCliCod
			&SdtCurvaABCItem.PedCliRaz = &PedCliRaz
			&SdtCurvaABCItem.PedVlrBrt = &PedVlrBrt
			&SdtCurvaABC.Add(&SdtCurvaABCItem)
		EndIf
	EndFor
	
	If &SdtCurvaABC.Count > 0
		&SdtCurvaABC.Sort('[PedVlrBrt]')
		Print Menu
		For &SdtCurvaABCItem in &SdtCurvaABC
			&PrtPedCliCod =  &SdtCurvaABCItem.PedCliCod
			&PrtPedCliRaz = &SdtCurvaABCItem.PedCliRaz
			&AuxPedVlrBrt = 0 
			&AuxPedVlrBrt = &SdtCurvaABCItem.PedVlrBrt
			
			&PerSobVlr = 0
			&PerSobVlr = ((&AuxPedVlrBrt / &TotalVendas) * 100)
			&PerVlrAcu += &PerSobVlr	
		    &PedVlrAcu += &AuxPedVlrBrt
			
			If (&PerVlrAcu < &CurvaB) or (&PerSobVlr > &CurvaB)
		       &Curva = 'A'
		   	Else
				&Curva = IIF(&PerVlrAcu < &CurvaC,'B','C')
			Endif
			
			//		If &IsGravar = true
			//			PesAbcCli = &Curva
			//		EndIf
			Print Dados			
		EndFor
	Else
		Print Vazio
	EndIF
EndIf

Footer
	print Rodape
End

