      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedTmpFrpPgtoTip = TipoDuplicata.DINHEIRO
	Exit
When none		
	&sdtPgto = new()
	&sdtPgto.FrpPgtoCod = 2 //Deve ser preenchido
	&sdtPgto.FrpPgtoTip = TipoDuplicata.DINHEIRO //Deve ser preenchido
	
	if &sdtPgto.FrpPgtoCod > 0
		&sdtPgto.PedDtaFat = &CrePagDta
		&sdtPgto.PedTmpCreCliCod = 0
		&sdtPgto.FunPesCod = 0
		&sdtPgto.creVlrDup = &creVlrDup		
		&sdtPgto.PlanCod = &PlanCod
		
		//DINHEIRO
		&sdtPgto.CtaBanCod = &CtaBanCod
		&sdtPgto.CrePagDta = &CrePagDta
		&sdtPgto.CreDupNro = trim(str(&PedCod)) +'-CREDITO'
		&sdtPgto.CreCbrCod = 0
		&sdtPgto.IsPago = true //BAIXA COMO PAGO
		
		MontaDuplicatasPedidoVenda01_JDF.Call('ADD', &EmpCod, &FilCod, &PedCod, &sdtPgto)
	Endif
EndFor
]]></Source>
