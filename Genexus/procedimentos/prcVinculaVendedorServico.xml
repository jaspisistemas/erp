      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each ORder EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod 		= &parmEmpCod
	Where FilCod 		= &parmFilCod
	Where PedCod 		= &parmPedCod
	Where PedItmCod		= &parmPedItmCod
	
	//GRAVA LOG
	&TabelaVarchar 	= 'PEDIDOPRODUTO'	//Nome da Tabela
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&parmEmpCod, &TabelaVarchar)
	
	if &LogErpTabIsLog 	= True
		&LogErpRegCod1 	= Trim(Str(&parmPedCod))
		&LogErpRegCod2 	= Trim(Str(&parmPedItmCod))
		&LogErpRegTip 	= TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		
		prcGravaLog_Registros.Call(&LogErpRegTip, &parmEmpCod, &parmFilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmVenCod', Trim(ToFormattedString(PedItmVenCod)), Trim(ToFormattedString(&parmPedItmVenCod)), &LogErpRegGUID)
	Endif
	//GRAVA LOG
	
	PedItmVenCod		= &parmPedItmVenCod
	
	Exit
EndFor
Commit
]]></Source>
