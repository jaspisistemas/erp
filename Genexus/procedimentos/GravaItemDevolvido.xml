      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, PedCod, PedDevProCod, PedDevProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod 
	Where PedCod = &PedCod
	Where PedDevProCod = &ProCod
	Where PedDevProGraCod = &PrograCod
	Where PedDevProNom = &PedProNom
	PedDevQtd += &PedQtd
	
When none
	&PedDevItmCod = 0
	For Each Order EmpCod, FilCod, PedCod, (PedDevItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod 
		Where PedCod = &PedCod
		&PedDevItmCod = PedDevItmCod
		Exit
	EndFor
	&PedDevItmCod += 1

	new
		EmpCod = &EmpCod
		FilCod = &FIlCod
		PedCod = &PedCod
		PedDevItmCod = &PedDevItmCod
		PedDevProNom = &PedProNom
		PedDevProCod = &ProCod
		PedDevProGraCod = &PrograCod
		PedDevQtd = &PedQtd
	EndNEw

EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
