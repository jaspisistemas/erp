      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	FilCndAut = &FilCndAut
	FilCndVct = &FilCndVct
	FilCndNro = &FilCndNro
	Exit
EndFor


For each Order EmpCod,PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &NfeCliCod
	
	PesCndAut = &PesCndAut
	PesCndVct = &PesCndVct
	PesCndNro = &PesCndNro
	Exit
EndFor


Commit
]]></Source>
