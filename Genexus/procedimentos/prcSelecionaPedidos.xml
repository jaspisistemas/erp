      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtPedidos.Clear()

For Each Order EmpCod, FilCod, PedCliCod, (PedCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCliCod = &PedCliCod
	
	Where PedDtaEms >= &PedDtaEmsIni and PedDtaEms <= &PedDtaEmsFin
	Where PedDtaFat >= &PedDtaFatIni and PedDtaFat <= &PedDtaFatFin
	
	Where PedSts = &PedSts or (&PedSts.IsEmpty() and PedSts <> Status_Pedido.CANCELADO)
	Where PedStsFin = &PedStsFin or (&PedStsFin.IsEmpty() and PedStsFin <> Status_Financeiro.CANCELADO)
	Where PedBlq = Status_SimNao.Nao
	Where LctTip = TipoLancamento.OrcamentoVenda or LctTip = TipoLancamento.SaidaMercadoria when &TipoPedido = 'V'
	Where LctTip = TipoLancamento.OrcamentoCompra or LctTip = TipoLancamento.EntradaMercadoria when &TipoPedido = 'C'
	Where LctTip = TipoLancamento.DevolucaoVenda when &TipoPedido = 'D'
	Where LctTip = TipoLancamento.DevolucaoCompra when &TipoPedido = 'E'
	Where LctCod = &LctCod when not &LctCod.IsEmpty()
	
	&sdtPedidosItem = new()
	&sdtPedidosItem.EmPCod = EmpCod
	&sdtPedidosItem.FiLCod = FilCod
	&sdtPedidosItem.PedCod = PedCod
	&sdtPedidosItem.PedDtaEms = PedDtaEms
	&sdtPedidosItem.PedDtaFat = PedDtaFat
	&sdtPedidosItem.PedVlrLiq = PedVlrLiq
	&sdtPedidosItem.PedVlrFrt = PedVlrFrt
	&sdtPedidosItem.PedCliCodRaz = PedCliCodRaz
	&sdtPedidosItem.PedStsFin = PedStsFin
	&sdtPedidosItem.PedSts = PedSts
	&sdtPedidosItem.PedNovStsNom = PedNovStsNom
	&sdtPedidosItem.PedNovStsFinNom = PedNovStsFinNom
	&sdtPedidosItem.PedCliCidCod = PedCliEntCidCod
	&sdtPedidosItem.PedCliCidNom = PedCliEntCidNom
	
	&sdtPedidosItem.Localizado = 'N'
	
	&PedCod = PedCod
	do 'LocalizaNota'
	
	&sdtPedidosItem.PedNum = &NfeNum
	
	if (&IsPedidosComNF = true and &NfeNum.IsEmpty()) or &IsPedidosComNF <> true
		&sdtPedidos.Add(&sdtPedidosItem)
	Endif
EndFor


Sub 'LocalizaNota'
	&NfeNum = 0
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where NfeFilCod = &FilCod
		Where NfePedCod = &PedCod
		Where NfeSts = Status_NFe.Autorizada
		&NfeNum = NfeNum
		Exit
	EndFor

	if &NfeNum = 0
		For Each Order EmpCod, FilCod, NfeCod, NfeSelPedCod
			Where EmpCod = &EmpCod
			Where NfeFilCod = &FilCod
			Where NfeSts = Status_NFe.Autorizada
			Where NfeSelPedCod = &PedCod
			&NfeNum = NfeNum
			Exit
		EndFor
	Endif
EndSub
]]></Source>
