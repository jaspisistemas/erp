      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CotComItmCod = &parCotComItmCod

if &CotComItmCod > 0
	For Each Order EmpCod, CotComCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod = &CotComItmCod
		
		CotComProCod = &CotComProCod
		CotComProGraCod = &CotComProGraCod
		CotComProRef = &CotComProRef
		CotComProNom = &CotComProNom
		CotComProMarNom = &CotComProMarNom
		CotComProObs = &CotComProObs
		CotComProQtd = &CotComProQtd
		CotComProEmbCod = &CotComProEmbCod
		CotComProBar = &CotComProBar
		CotComProDtaLim = &CotComProDtaLim
		CotComProLctCod = &CotComProLctCod
		CotComProDtaHorLct = ServerNow()
		
		
		For Each Order EmpCod, CotComCod, CotComProForCod
			Delete
		EndFor
		
		Exit
	EndFor
	
	Commit
	
Else		
	for Each Order EmpCod, CotComCod, (CotComItmCod)
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		&CotComItmCod = CotComItmCod
		Exit
	EndFor
	
	&CotComItmCod += 1
	
	New
		EmpCod = &EmpCod
		CotComCod = &CotComCod
		CotComItmCod = &CotComItmCod
		CotComProCod = &CotComProCod
		CotComProGraCod = &CotComProGraCod
		if &CotComProCod = 0 //Produto nao cadastrado
			&GUID= GUID.NewGuid()
			CotComProRef =  &GUID.ToString()
		Else
			CotComProRef = &CotComProRef
		Endif
		
		CotComProNom = &CotComProNom
		CotComProMarNom = &CotComProMarNom
		CotComProObs = &CotComProObs
		CotComProQtd = &CotComProQtd
		CotComProEmbCod = &CotComProEmbCod
		CotComProBar = &CotComProBar
		CotComProDtaLim = &CotComProDtaLim
		CotComProLctCod = &CotComProLctCod
		CotComProDtaHorLct = ServerNow()
	EndNew
	
	Commit
Endif

For &sdtCotacaoCompraFornecedoresItem in &sdtCotacaoCompraFornecedores
	if &sdtCotacaoCompraFornecedoresItem.IsSel = true
		new
			EmpCod = &EmpCod
			CotComCod = &CotComCod
			CotComItmCod = &CotComItmCod
			CotComProForCod = &sdtCotacaoCompraFornecedoresItem.PesCod
		EndNew
	Endif
EndFor

Commit

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
