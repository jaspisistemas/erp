      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'PRODUTOS COM ESTOQUE MENOR QUE X.'
	print Cabecalho
	print TituloRelatorio
End

&mensagem = 'ESTOQUE MENOR QUE:'+trim(&Quantidade.ToFormattedString())
do case
	case  &Ordernar = 'C'	
		&mensagem = 'ORDEM: CÓDIGO'
	case  &Ordernar = 'L'	
		&mensagem = 'ORDEM: LOCAÇÃO'
	case  &Ordernar = 'E'	
		&mensagem = 'ORDEM: ESTOQUE'
EndCase

For Each 
	Order EmpCod, FilCod, ProGraRefPadL when &Ordernar = 'C'
	Order EmpCod, FilCod, EstLoc when &Ordernar = 'L'
	Order EmpCod, FilCod, EstQtd when &Ordernar = 'E'
	
	Where EmpCod = &EmpCod
	where FilCod = &FilCod
	Where ProSts = &ProSts when not &ProSts.IsEmpty()
	where ProSts <> Status_Produto.EXCLUIDO when &ProSts.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &GrupHie when not &GrupHie.IsEmpty()
	Where EstQtd <= &Quantidade
	Where not EstLoc.IsEmpty() when &SomenteComLocacao = Status_SimNao.Sim
	Where EstLoc like &EstLoc when not &EstLoc.Trim().IsEmpty()
	Where (ProIsGra <> true) or (ProIsGra.IsNull() or ProIsGra.IsEmpty()) or ProGraCod > 1
	Where MarCod = &MarCod when not &MarCod.IsEmpty()
	
	if &UltimoBalanco = Status_SimNao.Sim
		&UltimoBalancoData = RetornaUltimoBalanco.Udp(EmpCod, FilCod, ProCod, ProGraCod)
		if EstUltEnt > &UltimoBalancoData or EstUltSai > &UltimoBalancoData
			print Produtos
			if EstQtd_Formatado > 0
				&TotalEstoque += EstQtd_Formatado
			Endif
		EndiF
	Else
		print Produtos	
		if EstQtd_Formatado > 0
			&TotalEstoque += EstQtd_Formatado
		Endif
	EndiF
	
EndFor

print TotalEstoque

Footer
	print Rodape
End
]]></Source>
