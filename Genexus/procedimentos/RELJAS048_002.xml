      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)


iF &Coluna = 1
	&IsColuna1 = true
Else
	&IsColuna1 = false
EndIF

If &Linha > 1	
	For &Count = 1 to &Linha
		print Embranco
	EndFor
	If &coluna = 1
		NoSkip
	EndiF
Else
	print Embranco
	If &coluna = 1
		NoSkip
	EndiF
EndiF


For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	&EtqQtd = EtqQtd
	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto = 'Cod: ' + trim(str(EtqProCod))
	Else
		&CodigoProduto = 'Cod: ' + trim(EtqNovProCod)
	EndIF
	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF

	&NomeProduto  = GxGetMLi(&EtqProNom, 1, 28)
	&NomeProduto1 = GxGetMLi(&EtqProNom, 2, 28)
	
	Do CAse
		CAse EtqProBar.Length() = 13
			&TipoCodigoBarras = TipoCodigoBarras.EAN13//_40X110
		CAse EtqProBar.Length() = 14
			&TipoCodigoBarras = TipoCodigoBarras.EAN14//_40X110
		Otherwise
			&TipoCodigoBarras = TipoCodigoBarras.CODE128C//_40X110
	EndCAse

	&CodBarrasImage.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqProBar) + '.jpg'
	If not EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqProBar, EtqProBar)
		EndIF
		If &File.Exists()
			&CodBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf

	do 'printEtiquetas'
EndFor



sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		If &IsColuna1 = true
			print EtiquetaModelo001Col1
			&IsColuna1 = false
		Else
			noSkip
			print EtiquetaModelo001Col2
			&IsColuna1 = true
		EndIF
	EndFor
EndSub
]]></Source>
