      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

	UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &FilCod,&CreCod)
	RetornaConfSistema.call(&EmpCod, &FilCod, domConfSistema.TCon115_PlanoSaidaCreditoCliente,&Varchar)
	if not &Varchar.IsEmpty()
		RetornaCodigoPlanoContas.Call(&EmpCod, &Varchar, &TCon115_PlanoSaidaCreditoCliente)
	Endif

	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CreCod = &CreCod
		CreDupNro = &CreDupNro	
		CreDtaVct = &Today
		CreVlrDup = &CreVlrDup
		CreCbrCod = 1
		CreDtaEms = &Today
		CreVlrSdo = &CreVlrDup
		CreCliCod = &CreCliCod
		CreVenCod = 0
		CreRecPag =  ReceberPagar.Pagar
		CreBloNro = ''
		CreSts = Status_Duplicata.ATIVO
		
		CreFrpPgtoCod = 1 //TipoDuplicata.DUPLICATA
		
		CreOriDup = OrigemDuplicata.Creditopedido
		CrePlanCod = &TCon115_PlanoSaidaCreditoCliente//DupTmpCrePlanCod
		CrePerComCbr = 0
		CreFilPgt = &FilCod
		CreNovCliRaz = ''
		CrePedCod = &PedCod
	EndNew
	Commit

	GravaCobranca.call(&EmpCod,&FilCod,&CreCod,&CreCobObs,0,0,&CrePrmPag, '00:00:00', TipoObservacaoDuplicata.INTERNA)
	
]]></Source>
