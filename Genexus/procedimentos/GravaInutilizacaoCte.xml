      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CteSer,CteModCod,CteSts,CteCod
	Where EmpCod = &EmpCod //Empresa
	Where FilCod = &FilCod //Filial
	Where CteSer = &CteSer //Serie
	Where CteModCod = &CteModCod //Modelo
    Where CteNum >= &FilInuNroIni and CteNum <= &FilInuNroFin //Intervalo Emissao
	Where CteSts = Status_NFe.Digitando
	
    CteSts = Status_NFe.Inutilizada
	CteAutMsg = &CteAutMsg
	CteAutSts = '102'
	CteAutNumLot = &CteAutNumLot
	CteAutNumRec = &CteAutNumRec
	CteAutDatHorRec = &CteAutDatHorRec
	CteAutNumPro = &CteAutNumPro
EndFor

commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
