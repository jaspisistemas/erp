      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAutorizado = false

Do case
	case &PesCod > 0
		For each Order EmpCod,PesSenItm
			Where EmpCod = &EmpCod
			where PesCod = &PesCod
			Where PesSenLoc = AutorizaTela.LIMITE_CREDITO
			Where PesSenfun = &GAMPassword
			&IsAutorizado = true
			exit
		when none
			msg('USUÁRIO NÃO AUTORIZADO A ESTA OPERAÇÃO!')		
		EndFor
	case &PesCod = 0
		msg('Autorizador inválido!')
	otherwise
		&IsAutorizado = true
		msg('AUTORIZADO PELO SUPORTE DO SISTEMA!')	
EndCase

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
