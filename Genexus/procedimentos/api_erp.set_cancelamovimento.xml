<Object parentGuid="2029c88d-bc03-4d0a-89d8-cf9907782d43" user="SRVORDIG\Administrador" versionDate="2025-04-04T01:57:21.0000000Z" lastUpdate="2025-03-07T12:01:14.0000000Z" checksum="2ac2ea0e771032bd9bae6a5a5d2a8c6e" fullyQualifiedName="api_erp.set_cancelamovimento" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="4b1cf57f-e424-4e74-bd02-4d8c7e07f6b7" name="set_cancelamovimento" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="set_cancelamovimento" parent="api_erp.Financeiro" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	&MovCod = &parMovCod
	
	For Each Order EmpCod, MovCod
		Where EmpCod = &wwpContext.EmpCod
		Where MovCod = &MovCod
		PrcValidaCaixaAberto.Call(EmpCod, MovCtaBanCod, MovDtaCon, &IsCaixaFechado, &Mensagem)
		
		if &IsCaixaFechado = false 
			PrcValidaCaixaAberto.Call(EmpCod, MovCtaBanCod, MovDta, &IsCaixaFechado, &Mensagem)
		Endif
		
		Do Case
			Case MovSts = Status_Caixa.Cancelado
				&sdtRetornoWbsEtc.sts = 'J999'
				&sdtRetornoWbsEtc.obs = 'Movimento já cancelado!'
				Return
				
			Case &IsCaixaFechado = true
				&sdtRetornoWbsEtc.sts = 'J998'
				&sdtRetornoWbsEtc.obs = &Mensagem
				Return
				
			Case not MovFecCod.IsNull() and not MovFecCod.IsEmpty()				
				&sdtRetornoWbsEtc.sts = 'J997'
				&sdtRetornoWbsEtc.obs = 'Movimento já fechado pelo PDV'
				Return
			case MovTip = TipoMovimento.DescontoDuplicataCheque
				&sdtRetornoWbsEtc.sts = 'J996'
				&sdtRetornoWbsEtc.obs = 'Não é possível excluir movimentos de duplicatas e/ou cheques descontados.'
				Return				
		EndCase
		Exit	
	EndFor
	
	
	For each Order EmpCod,MovCod
		Where EmpCod = &wwpContext.EmpCod
		Where MovCod = &MovCod
		&sdtDeleteMovimentoItemItem = new()
		&sdtDeleteMovimentoItemItem.MovCod = MovCod
		&sdtDeleteMovimentoItemItem.MovItmCod    = MovItmCod
		&sdtDeleteMovimentoItemItem.MovItmVlr    = MovItmVlr
		&sdtDeleteMovimentoItemItem.PlanCod       = PlanCod
		&sdtDeleteMovimentoItemItem.MovItmCpl    = MovItmCpl
		&sdtDeleteMovimentoItemItem.MovCreFilCod = MovCreFilCod
		&sdtDeleteMovimentoItemItem.MovCreCod    = MovCreCod		
		&sdtDeleteMovimentoItemItem.MovCrePagCod = MovCrePagCod
		&sdtDeleteMovimentoItemItem.MovTrnOriCod = MovTrnOriCod
		&sdtDeleteMovimentoItemItem.MovTrnOriCodItm = MovTrnOriCodItm
		&sdtDeleteMovimentoItemItem.MovFunAno    = MovFunAno
		&sdtDeleteMovimentoItemItem.MovFunMes    = MovFunMes
		&sdtDeleteMovimentoItemItem.MovFunCod    = MovFunCod
		 
		Do Case
			Case MovTrnOriCod.IsEmpty() and MovTrnOriCodItm.IsEmpty() and PlanUtiTra = true
				&IsTransferencia = True
			Case not MovTrnOriCod.IsEmpty() and not MovTrnOriCodItm.IsEmpty()
				&IsTransferencia = True
			Case not MovCreCod.IsEmpty() and not MovCreFilCod.IsEmpty()
				&IsDuplicata = True
			Case (not MovFunAno.IsEmpty()) and (not MovFunMes.IsEmpty()) and (not MovFunCod.IsEmpty())
				&IsFolhaPgto = True
				if MovFunSts = status_AbertoFechado.Fechado
					&sdtRetornoWbsEtc.sts = 'J200'
					&sdtRetornoWbsEtc.obs = 'Não é possível excluir movimentos de Adiantamentos descontados.'
					return
				endIf
		Endcase
		
		
		&sdtDeleteMovimentoItem.Add(&sdtDeleteMovimentoItemItem)
	EndFor
	
	
	DeletaMovimentoComDependencias.Call(&wwpContext.EmpCod,&MovCod,&IsTransferencia,&IsFolhaPgto,&IsDuplicata,&IsEliminaAdiantamentos)
	
	&sdtRetornoWbsEtc.sts = 'J200'
	&sdtRetornoWbsEtc.obs = 'Lançamento gravado'
	return	
	
	
EndIf

]]></Source>
