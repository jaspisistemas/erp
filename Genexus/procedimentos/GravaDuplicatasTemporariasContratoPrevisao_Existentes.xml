      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order DupTmpEmpCod,DupTmpFilCod,DupTmpPesCod,DupTmpCreCod
	Where DupTmpEmpCod = &EmpCod
	Where DupTmpFilCod = &FilCod
	Where DupTmpPesCod = &PesCod
	Delete
EndFor
	
Commit	
//TABELA SERVICOCLIENTE - SOMENTE CONTRATOS E PREVISOES
For each order EmpCod, SerItmCod
	where EmpCod = &EmpCod
	where SerItmCod = &SerItmCod	
//	where SerItmTip <> TipoLancamentoServico.SERVICO //ajuda no filtro
	&SerFilCod = SerFilCod
	&SerCliCod = SerCliCod
	&SerCliNom = SerCliNom
	//&SerCod  = 0
//	&SerItmTipPlan = SerItmTipPlan
//	&SerItmDesc = SerItmDesc
//	&SerItmDiaVct = SerItmDiaVct
//	&SerItmUltVct = SerItmUltVct
//	&SerItmDtaInicio = SerItmDtaInicio
//	&SerItmDtaFim = SerItmDtaFim
//	&SerItmVlr = SerItmVlr
//	&SerItmTip = SerItmTip
//	&SerItmQtdMes = SerItmQtdMes
//	&SerItmAbv = SerItmAbv
//	&SerItmPlanCod = SerItmPlanCod
	exit
EndFor

For each order EmpCod, FilCod, CreSerItmCod,CreCliCod,CreCod
	where EmpCod = &EmpCod
	where FilCod = &FilCod
	where CreSerItmCod = &SerItmCod
	where CreCliCod = &SerCliCod
	&CreSts = CreSts
	&CreVlrDup = CreVlrDup
	&CreVlrSdo = CreVlrSdo
	&CreDupNro = CreDupNro
	&CreDtaEms = CreDtaEms
	&CreDtaVct = CreDtaVct
	&CreCbrCod = CreCbrCod			
	&CrePlanCod = CrePlanCod
	&CreCod = CreCod
	&CreBloNro = CreBloNro
	&CreRecPag = CreRecPag
	&SerCliCod = CreCliCod
	
	Do 'GravaTmp'
EndFor

Commit

Sub 'GravaTmp'
	New
		DupTmpEmpCod = &EmpCod
		DupTmpFilCod = &FilCod
		DupTmpCreCod = &CreCod
		DupTmpPesCod = &PesCod
		DupTmpCreNovCliRaz = &SerCliNom
		DupTmpCreVenCod = &SerItmCod  // USANDO ESTA CAMPO PARA SerItmCod
		DupTmpCreDupNro = &CreDupNro
		DupTmpCreDtaEms = &CreDtaEms
		DupTmpCreDtaVct = &CreDtaVct  
		DupTmpCreVlrDup = &CreVlrDup 
		DupTmpCreVlrSdo = &CreVlrSdo 
		DupTmpCreCliCod = &SerCliCod 	
		DupTmpCreRecPag = &CreRecPag 
		DupTmpCreCbrCod = &CreCbrCod
		DupTmpCreBloNro = &CreBloNro
		DupTmpCreCodBar = '' 		//&SerCodBar
		DupTmpCrePlanCod = &CrePlanCod
		DupTmpCreFilPgt = &SerFilCod
		DupTmpCreCodAlt = &CreCod
		
		do case
			case &CreVlrDup <> &CreVlrSdo and &CreSts = Status_Duplicata.ATIVO
				DupTmpCreSts = 'P'
				
			case /*&CreVlrDup = &CreVlrSdo and*/ &CreSts = Status_Duplicata.ATIVO
				DupTmpCreSts = 'A' // &DupTmpCreSts depois alterar pra variavel, se tiver paga no for each etc
				
			case &CreSts = Status_Duplicata.CANCELADA
				DupTmpCreSts = 'C'
				
			otherwise 
				DupTmpCreSts = 'A'
		EndCase
	EndNew

EndSub
]]></Source>
