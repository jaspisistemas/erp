      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If not &NomePaizao.IsEmpty()
	&GrupNomCmp = trim(&NomePaizao) + ' | ' + trim(&GrupNom)
Else
	&GrupNomCmp = trim(&GrupNom) 
EndIF

if &GrupNomCmp.Length() > 100
	&GrupNomCmp = Substr(&GrupNomCmp,1, 97) + '...'
EndIf

&auxGrupHie = &GrupHie.Trim() + '.'

GrupoProdutosPaiHierarquico.Call(&EmpCod, &GrupCod, &GrupHie, &NewGrupHie, &auxNomePaizao, &GrupPaiCod, &GrupPaiHie, &paiIsErroHierarquia)

GrupHiePadL_Formata.Call(&GrupHie, &GrupHiePadL)
RetornaCodigoComVirgula.Call(&GrupHie, &GrupHieVir)

//GRAVAR LOG 
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'CATEGORIAPRODUTOS')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
	&LogErpRegTip = iif(&GrupCod = 0, Trnmode.Insert, Trnmode.Update)
	prcCarregaLog_CategoriaProdutos.Call(&EmpCod, &GrupCod, &SdtLogAtributos)
Endif

For Each Order EmpCod, GrupCod
	Where EmpCod = &EmpCod
	Where GrupCod = &GrupCod
	
	GrupNom = &GrupNom
	GrupNomCmp = &GrupNomCmp
	//	GrupHie = &GrupHie
	GrupAnaSin = &GrupAnaSin
	
	If GrupAnaSin = 'A'
		GrupDscMax = &GrupDscMax
		GrupCom = &GrupCom
	Else
		GrupCom = 0
		GrupDscMax = 0
	EndIF

	GrupPaiCod = &GrupPaiCod
	GrupPaiHie = &GrupPaiHie
	GrupHiePadL = &GrupHiePadL
	GrupHieVir = &GrupHieVir
	GrupSmt = &GrupSmt
	GrupArr = &GrupArr
	GrupNCM = &GrupNCM
	GrupPerAcr = &GrupPerAcr
	GrupCatCod = &GrupCatCod
	GrupImpCod = &GrupImpCod
	GrupSpedNatRec = &GrupSpedNatRec
	&NewGrupCod = &GrupCod
	
	Exit
When none
	UltimoCodigoEmpresa.Call(domParCod.GRUPOPRODUTO, &EmpCod, 0, &NewGrupCod)	
	New
		EmpCod = &EmpCod
		GrupCod = &NewGrupCod
		GrupNom = &GrupNom
		GrupNomCmp = &GrupNomCmp
		GrupHie = &GrupHie
		GrupAnaSin = &GrupAnaSin
		If GrupAnaSin = 'A'
			GrupDscMax = &GrupDscMax
			GrupCom = &GrupCom
		Else
			GrupCom = 0
			GrupDscMax = 0
		EndIF
	
		GrupPaiCod = &GrupPaiCod
		GrupPaiHie = &GrupPaiHie
		GrupHiePadL = &GrupHiePadL
		GrupHieVir = &GrupHieVir
		GrupSmt = &GrupSmt
		GrupArr = &GrupArr
		GrupNCM = &GrupNCM
		GrupPerAcr = &GrupPerAcr
		GrupCatCod = &GrupCatCod
		GrupImpCod = &GrupImpCod
		GrupSpedNatRec = &GrupSpedNatRec
	EndNew
EndFor

Commit

For Each Order EmpCod, GrupCod
	Where EmpCod = &EmpCod
	Where GrupCod = &NewGrupCod
	
	GrupCodNom = GrupCodNom_FORMULA
EndFor

Commit

if &LogErpTabIsLog = true //GRAVA LOG
	prcGravaLog_CategoriaProdutos.Call(&LogErpRegTip, &EmpCod, &FilCod, &NewGrupCod, &Pgmname, &wwpContextUserName, &SdtLogAtributos)
Endif

For Each Order EmpCod, GrupCod
	Where EmpCod = &EmpCod
	Where GrupHie like &auxGrupHie
	Where GrupCod <> &GrupCod
	
	GrupoProdutosPaiHierarquico.Call(EmpCod, GrupCod, GrupHie, &NewGrupHie, &GrupNomCmp, &GrupPaiCod, &GrupPaiHie, &IsErroHierarquia)
	GrupHiePadL_Formata.Call(GrupHie, &GrupHiePadL)
	RetornaCodigoComVirgula.Call(GrupHie, &GrupHieVir)
	
	if &IsErroHierarquia = false
		
		&GrupNomCmp = &GrupNomCmp.Trim() + ' | ' + GrupNom
		if &GrupNomCmp.Length() > 100
			&GrupNomCmp = Substr(&GrupNomCmp,1, 97) + '...'
		EndIf
	
	
		GrupNomCmp = &GrupNomCmp 
		
		GrupPaiCod = &GrupPaiCod
		GrupPaiHie = &GrupPaiHie
		GrupHiePadL = &GrupHiePadL
		GrupHieVir = &GrupHieVir
	EndIf
	
	Commit
EndFor


For Each Order EmpCod, GrupCod
	Where EmpCod = &EmpCod
	Where GrupHie like &auxGrupHie
	Where GrupCod <> &GrupCod
	
	GrupCodNom = GrupCodNom_FORMULA
EndFor

Commit
]]></Source>
