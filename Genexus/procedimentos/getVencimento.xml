      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&HojeData = serverdate()

&Key = 'E1D89B0D44CD35AFC9CF69E7E556A97B'
&Descryptografado = decrypt64(&Cryptografado, &Key)

&Jaspi = Substr(&Descryptografado,1,5)
&SoNumeros = Substr(&Descryptografado,6,8)
&EmpCodSec = Substr(&Descryptografado,14,500)

&Ano = val(Substr(&SoNumeros, 5,4))
&Mes = val(Substr(&SoNumeros, 3,2))
&Dia = val(Substr(&SoNumeros, 1,2))

&VencimentoData = yMDtoD(&Ano, &Mes, &Dia) 

if &VencimentoData.IsEmpty()
	&VencimentoData = &HojeData.AddYears(-3)
EndIF
&VencimentoData = &VencimentoData.AddMonths(1)

//&LimiteMaxData = &HojeData - 15

&QtdDias = &HojeData - &VencimentoData
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
