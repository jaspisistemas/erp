EndIf
If &SecureText.Length() > 0 AND (&SecureText.StartsWith(!'=') OR &SecureText.StartsWith(!'+') OR &SecureText.StartsWith(!'-') OR &SecureText.StartsWith(!'@'))
	&SecureText = !"'" + &SecureText
EndIf
]]></Source>
