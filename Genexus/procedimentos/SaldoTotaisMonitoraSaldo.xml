      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &PesCod > 0
	For each Order EmpCod,CtaBanSts
		Where EmpCod = &EmpCod
		Where CtaFunCod = &PesCod
		Where CtaFunIsCx <> Status_SimNao.Nao
		Where CtaBanFilCod in &ColFilCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO
		&CtaBanCod = CtabanCod
		Do "Conta"
	ENDFOR
Else
	For each Order EmpCod,CtaBanSts
		Where EmpCod = &EmpCod
		Where CtaBanFilCod in &ColFilCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO
		&CtaBanCod = CtabanCod
		Do "Conta"
	ENDFOR
	
EndIf


Sub"Conta"
	
	For each Order EmpCod,CtabanCod,CtaBanSts,(SdoDta)
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		Where CtaBanSts = Status_AtivoInativo.ATIVO
		Where SdoDta <= &DataBase
		
		if SdoDta = &DataBase
			&TotSdoEnt += SdoEnt
			&TotSdoSai += SdoSai
			&TotSdoDia += SdoDia
		Endif
	
		&TotSdoAtu += SdoAtu
		Exit	
	EndFor
	
EndSub


]]></Source>
