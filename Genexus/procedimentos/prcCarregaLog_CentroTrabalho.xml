      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &CTrCod = 0 //INSERT
	prcLogAddSdt.Call('CTrNom', '', '', &sdtLogAtributos)
Else
	For Each order EmpCod, CTrCod
		Where EmpCod = &EmpCod
		Where CTrCod = &CTrCod
		
		prcLogAddSdt.Call('CTrNom', trim(CTrNom), '', &sdtLogAtributos)
		prcLogAddSdt.Call('CTrOpc', trim(CTrOpc), '', &sdtLogAtributos)
		
		Exit
	EndFor
Endif
]]></Source>
