      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsExisteUmaVenda = false

For &sdtVinculosItem in &sdtVinculos
	For Each Order EmpCod, PedCliCod, PedVenCod, PedSts, PedCod
		Where EmpCod = &EmpCod
		Where PedCliCod = &sdtVinculosItem.PesCod
		Where PedVenCod = &PedVenCod
		Where PedSts = Status_Pedido.FECHADO
		Where LctAtuEst = Status_EntradaSaida.Saida
		Where LctGerFin = Status_SimNao.Sim
		
		&IsExisteUmaVenda = true
		Exit
	EndFor

	if &IsExisteUmaVenda = true
		Exit
	EndIf
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
