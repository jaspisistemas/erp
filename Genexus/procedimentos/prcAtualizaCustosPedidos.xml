      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProgressIni = serverNow()
&Total = 0
&Count = 0
&Percentual = 0
do 'Atualiza'

//atualizaPedidos
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod when not &PedCod.IsEmpty()
	where LctAtuSal = &LctAtuSal when &PedCod.IsEmpty()
	Where (PedDtaEms >= &PedDtaEms and PedDtaEms <= &PedDtaEms_to and (&FiltrarPor = 'E' or &FiltrarPor = 'A')) 
	or (PedDtaFat >= &PedDtaEms and PedDtaFat <= &PedDtaEms_to and (&FiltrarPor = 'F' or &FiltrarPor = 'A')) when &PedCod.IsEmpty()
	&Total += 1
	
	&sdtPedidosItem = new()
	&sdtPedidosItem.pedCod = PedCod
	&sdtPedidosItem.PedDtaEms = PedDtaEms
	&sdtPedidosItem.PedDtaFat = PedDtaFat
	&sdtPedidosItem.PedVlrCus = PedTotCusLiq
	&sdtPedidosItem.NovPedVlrCus = 0
	If PedCliCodRaz.Trim().Length() > 55
		&sdtPedidosItem.pedCliCodRaz = Substr(PedCliCodRaz,1,55)
	Else
		&sdtPedidosItem.pedCliCodRaz = PedCliCodRaz
	EndIf
	
	&sdtPedidosItem.EmpCod = EmpCod
	&sdtPedidosItem.FilCod = FilCod
	&sdtPedidosCusto.Add(&sdtPedidosItem)
EndFor

&Total += 10

//atualizaPedidos
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod when not &PedCod.IsEmpty()
	where LctAtuSal = &LctAtuSal when &PedCod.IsEmpty()
	Where (PedDtaEms >= &PedDtaEms and PedDtaEms <= &PedDtaEms_to and (&FiltrarPor = 'E' or &FiltrarPor = 'A')) 
	or (PedDtaFat >= &PedDtaEms and PedDtaFat <= &PedDtaEms_to and (&FiltrarPor = 'F' or &FiltrarPor = 'A')) when &PedCod.IsEmpty()
	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	
	do 'Atualiza'
	
	PedNovStsCod_FORMULA.Call(EmpCod, FilCod, PedCod)
		
	AtualizaTotaisPedidoImportacao.Call(EmpCod, FilCod, PedCod, 0, 'C')
		
EndFor


//atualizaPedidos
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod when not &PedCod.IsEmpty()
	where LctAtuSal = &LctAtuSal when &PedCod.IsEmpty()
	Where (PedDtaEms >= &PedDtaEms and PedDtaEms <= &PedDtaEms_to and (&FiltrarPor = 'E' or &FiltrarPor = 'A')) 
	or (PedDtaFat >= &PedDtaEms and PedDtaFat <= &PedDtaEms_to and (&FiltrarPor = 'F' or &FiltrarPor = 'A')) when &PedCod.IsEmpty()
	
	For &sdtPedidosItem in &sdtPedidosCusto
		if &sdtPedidosItem.pedCod = PedCod
			&sdtPedidosItem.NovPedVlrCus = PedTotCusLiq
			Exit
		EndIf
	EndFor
EndFor


For &sdtPedidosItem in &sdtPedidosCusto
	if &sdtPedidosItem.NovPedVlrCus = &sdtPedidosItem.PedVlrCus
		&index = &sdtPedidosCusto.IndexOf(&sdtPedidosItem)
		&sdtPedidosCusto.Remove(&index)
	EndIf
EndFor


&ProgressLogXml = &sdtPedidosCusto.ToJson()
&ProgressFin	= serverNow()
&Percentual = 100
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		ProgressIni = &ProgressIni
		ProgressFin	= &ProgressFin
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml  =  &ProgressLogXml
			ProgressIni = &ProgressIni
			ProgressFin	= &ProgressFin
		Endnew
	endfor

	commit
EndSub
]]></Source>
