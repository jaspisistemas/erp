      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
for Each Order EmpCod, MrkCod, MrkPedSku
	where EmpCod = &EmPCod
	where MrkCod = &MrkCod
	Where MrkPedSku = &MrkPedSku
	
	&MrkPedFilCod = MrkPedFilCod
	&MrkPedShipSku = MrkPedShipSku
	
	&NomeArquivo = trim(MrkTip.ToFormattedString()) + '_'+trim(MrkPedSku) +'-'+&MrkPedShipSku.Trim() + '.pdf'
	
	prcMercadolivreRefreshToken.Call(&EmPCod, &MrkCod, &MrkSession, &IsSucesso)
	Exit
EndFor

if &IsSucesso = true
	&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
	&HttpClient.Execute('GET', 'https://api.mercadolibre.com/shipment_labels?shipment_ids='+&MrkPedShipSku+'&savePdf=Y')
	
	If &HttpClient.StatusCode = 200
		
		&httpclient.ToFile(&CaminhoMensagem)
		
		&File.Source = &CaminhoMensagem
		If &File.Exists()			
			for Each Order EmpCod, MrkCod, MrkPedSku
				where EmpCod = &EmPCod
				where MrkCod = &MrkCod
				Where MrkPedSku = &MrkPedSku
				
				if MrkPedEtqDtaHor.IsEmpty() or MrkPedEtqDtaHor.IsNull()
					MrkPedEtqDtaHor = ServerNow()
				Endif
				
				Exit
			endFor
			
			Commit
			prcAtualizaStatusInterno.Call(&EmPCod, &MrkCod, &MrkPedSku)
		Else
			&IsSucesso = false
		EndIF	
		
	Else
		&IsSucesso = false
		msg('Falha catastrófica! ' + &HttpClient.StatusCode.ToString())
	Endif
	
Endif


]]></Source>
