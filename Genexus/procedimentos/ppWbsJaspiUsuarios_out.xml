      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtSuporteJaspi.Clear()

For Each Order SupCod
	
	&sdtSuporteJaspiItem = new()
	&sdtSuporteJaspiItem.SupCod = SupCod
	&sdtSuporteJaspiItem.SupNom = SupNom
	
	&Status = 'SEM USUARIO'
	&AuxPesExtCod = SupExtID
	
	&SupEmail = ''
	&SupUsu = ''
	&Password.SetEmpty()
	&SupCod = SupCod
	If &AuxPesExtCod <> 0 or &SupCod = -1
		do 'getUsuariosGAM'
	endIf
	
	&sdtSuporteJaspiItem.SupSen = &Password
	&sdtSuporteJaspiItem.SupUsu = &SupUsu
	&sdtSuporteJaspiItem.SupEmail = &SupEmail
	
	&sdtSuporteJaspi.Add(&sdtSuporteJaspiItem)
EndFor


Sub 'getUsuariosGAM'

	&Filter.AuthenticationTypeName	= ''
	&Filter.ReturnAnonymousUser 	= false
	
	if &SupCod = -1 //SUPORTE.JASPI'
		&Filter.Name = 'suporte.jaspi'
		&Filter.ExternalId = ''
	Else		
		&Filter.Name = ''
		&Filter.ExternalId = trim(str(&AuxPesExtCod))
	Endif

	For &User in GAMRepository.GetUsersOrderBy(&Filter, GAMUserListOrder.None, &Errors)
		&SupEmail = &User.EMail
		&SupUsu = &User.Name
		&Password = &User.Password
		
		Do Case
			Case &User.IsBlocked = true
				&Status = 'BLOQUEADO'
				
			Case &User.IsActive = true
				&Status = 'HABILITADO'
				
			Otherwise
				&Status = 'BLOQUEADO'
		EndCAse
		
		Exit
	EndFor

EndSub
]]></Source>
