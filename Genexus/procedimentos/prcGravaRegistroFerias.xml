      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&FerItemDias = (&FerItemFin - &FerItemIni) + 1

For Each ORder EmpCod, PesCod, PesRecCod, FerAnoBas
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	where PesRecCod = &PesRecCod
	Where FerAnoBas = &FerAnoBas
	
	&FerDiaUsu = FerDiaUsu
	&FerDiaUsu += &FerItemDias //usufruido
	
	if FerDtaFin < serverdate()
		&FerDiaTot = 30
	Else			
		&Dias = FerDtaFin-FerDtaIni
		&FerDiaTot = round(&Dias * 0.0821917808219178, 0)
	Endif
	FerDiaPen = &FerDiaTot - &FerDiaUsu
	FerDiaUsu = &FerDiaUsu
	FerDiaTot = &FerDiaTot
	
	For Each ORder EmpCod, PesCod, PesRecCod, FerAnoBas, (FerItemCod)
		&FerItemCod = FerItemCod
		Exit
	EndFor
	&FerItemCod += 1
	do 'gravaFerias'
	
	Commit
EndFor


sub 'gravaFerias'
	new
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesRecCod = &PesRecCod
		FerAnoBas = &FerAnoBas
		FerItemCod = &FerItemCod		
		FerItemIni = &FerItemIni
		FerItemFin = &FerItemFin
		FerItemDias = &FerItemDias
		FerItemObs = &FerItemObs.ToUpper()
		FerItemTip = &FerItemTip
	EndNew
EndSub


]]></Source>
