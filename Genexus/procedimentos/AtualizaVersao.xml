		EmpVerPdvNewDtaLim = serverdate()
		EmpVerPdvNewDtaLim = EmpVerPdvNewDtaLim.AddDays(30)
	Endif

	
	//VERSAO MESAS
	//EmpVerMesas	
	
	//VERSAO ERP - Flutter Android/Ios
	EmpVerSmart = '60' //min BuildNumber
	EmpVerSmartNew = '70' //liberado BuildNumber
EndFor

commit
