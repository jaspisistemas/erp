      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&GrupPaiHie = ''
&GrupPaiCod = 0
&GrupHie = ''
&GrupNom = ''
For Each Order EmpCod, GrupCod
	Where EmpCod = &EmpCod
	Where GrupCod = &GrupCod
	&GrupNom = GrupNom
	&GrupHie = GrupHie
	&GrupCodNom = GrupCodNom
	&GrupPaiHie = GrupPaiHie
	&GrupPaiCod = GrupPaiCod
	Exit
EndFor

&IsExiste = false
For each Order EmpCod,TempUsr,TempGrupCod,TempProCod
	Where EmpCod = &EmpCod
	Where TempUsr = &PesCod
	Where TempGrupCod = &GrupCod
	Where TempProCod = 0
	TempPedVlrLIq += &PedVlrLiq
	TempPedVlrBrt += &PedVlrBrt
	TempPedVlrItmCus += &PedVlrItmCus
	tempProQtd += &CountPro
	TempQuantidade += &PedQtd 
	TempProVlrCus += &PedVlrCus
	&IsExiste = true 
	If TempProVlrCus > 0 	
		&TempProPerRet = ((TempPedVlrLIq * 100) / TempProVlrCus) - 100
	Else
		&TempProPerRet = 0
	EndIf
	
	TempProVlrRet = TempPedVlrLIq - TempProVlrCus
	If &TempProPerRet > 0
		TempProPerRet = &TempProPerRet
	Else
		TempProPerRet = 0
	EndIf
	exit
EndFor
Commit

if &IsExiste = false
	&auxTempRent = 0
	&auxTempRent = &TempRent +1
	New		
		EmpCod = &EmpCod
		TempUsr = &PesCod
		TempRent = &auxTempRent
		TempDtaMod = serverdate()
		TempGruphie = &GrupHie
		TempGrupNom = &GrupNom
		TempGrupCod = &GrupCod
		TempGrupPaiHie = &GrupPaiHie
		TempPedVlrLIq = &PedVlrLiq
		TempPedVlrBrt = &PedVlrBrt
		TempPedVlrItmCus = &PedVlrItmCus
		TempGrupCodNom = &GrupCodNom
		tempProQtd = &CountPro
		TempQuantidade = &PedQtd 
		TempProVlrCus = &PedVlrCus
		If &PedVlrCus > 0
			TempProPerRet = ((&PedVlrLiq * 100) / &PedVlrCus) - 100
		EndIf

		TempProVlrRet = &PedVlrLiq - &PedVlrCus
		TempProCod = 0
	EndNew
	Commit
EndIF

If &GrupPaiCod <> 0
	CarregaSdtPaiCategoria1.Call(&EmpCod, &GrupPaiCod, &PedVlrLiq,&PedQtd,&CountPro,&PedVlrCus, &PesCod,&auxTempRent,&PedVlrBrt,&PedVlrItmCus)
EndIf
]]></Source>
