      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedDtaFat = &parPedDtaFat

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&PedCliCod = PedCliCod
	&LctAtuFor = LctAtuFor
	
	if PedCliTip = TipoPessoa.JURIDICA
		RetornaSoNumeros.Call(PedCliCnpj, &PedCliCnpj)
	Else
		RetornaSoNumeros.Call(PedCliCpf, &PedCliCnpj)
	Endif

	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where PedQtd <> 0
		
		&ProGraRef = ProGraRef
		&ProCod = ProCod
		
		&PedVlrUnt = PedVlrUnt
		&PedItmAcr = PedItmAcr
		&PedItmDsc = PedItmDsc
		&PedProTaxAcrGerItm = PedProTaxAcrGerItm
		&PedProTaxDscGerItm = PedProTaxDscGerItm
		&PedItmIcmSt = PedItmIcmSt
		&PedItmIcm = PedItmIcm
		&PedItmIpi = PedItmIpi
		&PedProEmbQtd = PedProEmbQtd
		
		if &LctAtuFor = Status_SimNao.Sim
			do 'Grava_preco' //GRAVA NO FORNECEDOR   
	    EndIf
		
	    ProVlrCus_Produto.Call(&EmpCod, &ProCod)
		AtualizaCustoVendaZero.Call(&EmpCod, &FilCod, &ProCod)
		
	EndFor

	Exit
EndFor


Sub 'RetornaCodigoProduto'
	&ForErpProRef = ''
	if not &PedCliCnpj.IsEmpty() and not &ProGraRef.IsEmpty()
		For Each Order EmpCod, ForCNPJ, ForProCod
			Where EmpCod = &EmpCod
			Where ForCNPJ = &PedCliCnpj
			Where ForErpProRef = &ProGraRef
			&ForErpProRef = ForProCod
			Exit
		EndFor
	Endif
EndSub

	
Sub 'Grava_preco' //ATUALIZA PRECO DO FORNECEDOR
	if &parPedDtaFat <> serverdate()
		DataUltimaCompraProdutoFornecedor.Call(&EmpCod, &ProCod, &PedCliCod, &PedDtaFat)
	Endif
	
	For Each Order EmpCod, ProCod, ProForCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProForCod = &PedCliCod
		
		if ProForProCod.IsEmpty() or ProForProCod.IsNull()
			do 'RetornaCodigoProduto'
			if not &ForErpProRef.IsEmpty()
				ProForProCod =  &ForErpProRef
			Endif
		Endif
		
		ProForVlrCus = &PedVlrUnt
		ProForAcr = &PedItmAcr
		ProForDsc = &PedItmDsc
		ProForRatAcr = &PedProTaxAcrGerItm
		ProForRatDsc = &PedProTaxDscGerItm
		ProForIcmSt = &PedItmIcmSt
		ProForIcm = &PedItmIcm
		ProForIpi = &PedItmIpi
		ProForQtdEmb = &PedProEmbQtd
		ProForDtaUltCmp = &PedDtaFat
		
		Exit
	when none    
		do 'RetornaCodigoProduto'
		
		new
			EmpCod = &EmpCod
			ProCod = &ProCod
			ProForProCod =  &ForErpProRef			
			ProForCod = &PedCliCod        	
			ProForVlrCus = &PedVlrUnt
			ProForAcr = &PedItmAcr
			ProForDsc = &PedItmDsc
			ProForRatAcr = &PedProTaxAcrGerItm
			ProForRatDsc = &PedProTaxDscGerItm
			ProForIcmSt = &PedItmIcmSt
			ProForIcm = &PedItmIcm
			ProForIpi = &PedItmIpi			
			ProForQtdEmb = &PedProEmbQtd
			ProForDtaUltCmp = &PedDtaFat
		EndNew
	EndFor
	
	Commit
EndSub
]]></Source>
