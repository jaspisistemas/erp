      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


if &PedCod <> 0
	For Each order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&NfeCliCpf.SetEmpty()
		&NfeCliCnpj.SetEmpty()
		&NfeCliTipPes = PedCliTip		
		if PedCliTip = TipoPessoa.FISICA
			&NfeCliCpf = PedCliCpf
		Else
			&NfeCliCnpj = PedCliCnpj
		Endif
		&NfeCliSuf = PedCliSuf
	
		Do Case
			Case PedPrpCod <> 0 and PedCliNfeCod <> 0 and PedCliNfeCod <> PedCliCod
				RetornaInscricaoEstadualpropriedade.Call(EmpCod,PedCliNfeCod,PedPrpCod,&NfeCliIns)
				
				&NfeCliCpf.SetEmpty()
				&NfeCliCnpj.SetEmpty()
				&NfeCliTipPes = PedCliNfeTip		
				if PedCliNfeTip = TipoPessoa.FISICA
					&NfeCliCpf = PedCliNfeCpf
				Else
					&NfeCliCnpj = PedCliNfeCnpj
				Endif
			
				&NfeCliSuf = PedCliNfeSuf
				
				&NfeCliEnd = PedPrpEnd
				&NfeCliEndNro = PedPrpNro
				&NfeCliBai = PedPrpBai
				&NfeCliCidNom = PedPrpCidNom
				&NfeCliCidCod = PedPrpCidCod
				&NfeCliCidIbge = PedPrpCidIbge
				&NfeCliCidUF = PedPrpCidUfeCod
				&NfeCliCep = PedPrpCep
				
				&NfeCliFon = FormataFONE.Udp(PedCliNfeFon)
				&NfeCliCpl = ''
				
			Case PedPrpCod <> 0
				RetornaInscricaoEstadualpropriedade.Call(EmpCod,PedCliCod,PedPrpCod,&NfeCliIns)
				
				&NfeCliEnd = PedPrpEnd
				&NfeCliEndNro = PedPrpNro
				&NfeCliBai = PedPrpBai
				&NfeCliCidNom = PedPrpCidNom
				&NfeCliCidCod = PedPrpCidCod
				&NfeCliCidIbge = PedPrpCidIbge
				&NfeCliCidUF = PedPrpCidUfeCod
				&NfeCliCep = PedPrpCep
				
				&NfeCliFon = FormataFONE.Udp(PedCliPrmFon)
				&NfeCliCpl = ''
				
			Otherwise 
				RetornaInscricaoEstadual.Call(EmpCod,PedCliCod,&NfeCliIns)
				
				&NfeCliEnd = PedCliEntLog
				&NfeCliEndNro = PedCliEntNro
				&NfeCliBai = PedCliEntBai
				&NfeCliCidNom = PedCliEntCidNom
				&NfeCliCidCod = PedCliCidCod
				&NfeCliCidIbge = PedCliEntCidIbge
				&NfeCliCidUF = PedCliEntUfeCod
				&NfeCliCep = PedCliEntCep
				
				&NfeCliFon = FormataFONE.Udp(PedCliPrmFon)
				&NfeCliCpl = PedCliEntCpl
		EndCase
		Exit
	EndFor
Else

	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
			
			RetornaInscricaoEstadual.Call(EmpCod,PesCod,&NfeCliIns)			
		
			&NfeCliCpf.SetEmpty()
			&NfeCliCnpj.SetEmpty()
			&NfeCliTipPes = PesTip		
			if PesTip = TipoPessoa.FISICA
				&NfeCliCpf = PesCpf
			Else
				&NfeCliCnpj = PesCnpj
			Endif
		
			&NfeCliEnd = PesEntLog
			&NfeCliEndNro = PesEntNro
			&NfeCliBai = PesEntBai
			&NfeCliCidNom = PesEntCidNom
			&NfeCliCidCod = PesEntCidCod
			&NfeCliCidIbge = PesEntCidIbge
			&NfeCliCidUF = PesEntUfeCod
			&NfeCliCep = PesEntCep
			
			&NfeCliCpl = PesEntCpl
			
		Exit
	EndFor
Endif
]]></Source>
