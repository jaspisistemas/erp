      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Atualiza Valor do Componente
For Each Order EmpCod, FilCod, CteCod, CteNomPreCom
	Where EmpCod = &EmpCod
	WHere FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteNomPreCom = &CteNomPreCom
	
	CteVlrPreCom = &CteVlrPreCom
	CteDesIcmsCom = &CteDesIcmsCom
	CtePrePagCom = &CtePrePagCom
	
	Exit
When None
	For Each Order EmpCod, FilCod, CteCod, (CtePreCod)
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where CteCod = &CteCod
		&CtePreCod = CtePreCod
		Exit
	EndFor
	
	&CtePreCod += 1
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CtePreCod = &CtePreCod
		CtePrePagCom = &CtePrePagCom
		CteNomPreCom = &CteNomPreCom
		CteVlrPreCom = &CteVlrPreCom
		CteDesIcmsCom = &CteDesIcmsCom
	EndNEw
EndFor

Commit

//Totaliza Componentes
For Each Order EmpCod, FilCod, CteCod, CtePreCod
	Where EmpCod = &EmpCod
	WHere FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteVlrPreCom > 0
	&TotCteVlrPreCom += CteVlrPreCom
EndFor

//Atualiza CTE
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	WHere FilCod = &FilCod
	Where CteCod = &CteCod
	
	CteVlrTotPreSer = &TotCteVlrPreCom
	CteVlrRecSer = &TotCteVlrPreCom
	exit
EndFor

Commit

GravaValorImpostoApi.Call(&EmpCod, &FilCod, &CteCod)

	
]]></Source>
