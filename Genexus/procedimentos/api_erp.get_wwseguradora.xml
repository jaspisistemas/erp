<Object parentGuid="f1aac239-e0a3-49e1-9e9a-289757b343a7" user="WINJEAN\jeanfae" versionDate="2025-06-03T12:09:07.0000000Z" lastUpdate="2025-05-28T21:22:28.0000000Z" checksum="b6c54ef3aecb98184af6dc4b389cde86" fullyQualifiedName="api_erp.get_wwseguradora" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="7a6e32e9-a050-4580-908b-dc3fcbd1bad4" name="get_wwseguradora" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_wwseguradora" parent="api_erp.Cliente" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Captura Filtros
//&wwClientesFiltros.FromJson(&Filtros)

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif

	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	
	&wwClientes.pA = '0'
	&wwClientes.pT = '0'
	&wwClientes.p1 = '0'
	&wwClientes.p2 = '0'
	&wwClientes.p3 = '0'
	&wwClientes.p4 = '0'
	&wwClientes.p5 = '0'
	
	&wwClientes.sts = 'J200'
	
	&IsPaginaOk = false
	retornaConfiguracoesPastas.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &SdtConfiguracoesPasta )
	RetornaTipoAnexo.Call(&wwpContext.EmpCod, '#IMAGEM_PESSOA#', &PesAnxTipCod)
	&imagem.FromImage(sem_imagem)
	
	
	For Each 
		Order EmpCod, SegNom when &Ordem.IsEmpty() or &Ordem = 'A'
		
		Where EmpCod = &wwpContext.empCod
		Where SegNom like &PesRaz when not &PesRaz.IsEmpty()
		Where SegCod = &PesCod when not &PesCod.IsEmpty()
		
		
		if &IsPaginaOk = false
			if &TestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwClientes.Item.Clear()
					&TestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				
				&wwClientesItem = New()
				&wwClientesItem.Cod = SegCod
				&wwClientesItem.Raz = SegNom.Trim()
				&wwClientesItem.TipV = 'CNPJ:'
				&wwClientesItem.Cpf = SegCnpj.Trim()
				&wwClientesItem.Cnom = SegApo.Trim()
				
				&wwClientes.Item.Add(&wwClientesItem)
			Endif		
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&TestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	When none
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwClientes.pA = trim(str(&Pagina))
		&wwClientes.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwClientes.p1, &wwClientes.p2, &wwClientes.p3, &wwClientes.p4, &wwClientes.p5)
		
	Endif
Else
	&wwClientes.sts = 'E999'
	&wwClientes.obs = 'Nada a ver aqui'
Endif
]]></Source>
