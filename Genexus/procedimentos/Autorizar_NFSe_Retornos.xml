      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&LogGUID = GUID.NewGuid() 

For Each Order EmpCod, NfsCod
	Where EmpCod = &SolEmpCod	
	Where NfsCod = &SolNfeCod
	
	&NfsNumRps = NfsNumRps
	Exit
EndFor



For Each ORder EmpCod, FilCod
	Where EmpCod = &SolEmpCod
	Where FilCod = &SolFilCod
	&FilFAn = FilFan
	&FilCpj = RetornaSoNumeros.Udp(FilCpj)
	Exit
EndFor

&NomeArquivo = trim(&FilCpj)+'_'+PadL(trim(str(&NfsNumRps)),5, '0')
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFSretorno.Trim() + trim(&NomeArquivo)+'-ret-loterps.err' 
&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFSretorno.Trim() + trim(&NomeArquivo) + '-ret-loterps.xml'

&File.Source = &Nome_retorno_erro
if &File.Exists() 
	&ResultadoAbertura =   DFROpen(&Nome_retorno_erro)    
	
	Do while dfrnext() = 0 
		&ResultadoAbertura = DFRGTxt(&CampoUnico)
		&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
	EndDo
	&ResultadoAbertura = DFRClose()
	
	&File.Delete()
	
	&Tentativa = 99
	&SolSts = Status_Solicitacao.Falha
	&SolMsg = &conteudo_arquivo
else
	&File.Source = &Nome_retorno_correto
	if &File.Exists()
		
		&IsDeuErro = false
		
		&XmlReader.Open(&Nome_retorno_correto)
		&ret = &XmlReader.ReadType(1, 'temp') 
		if &ret <> 0
			&IsDeuErro = true
			&XmlReader.Read()
			
			Do While (&XmlReader.Name <> 'temp')
				Do Case
					Case &XmlReader.Name = 'erro' or &XmlReader.Name = 'erros'
						&XMLReader.Read()
						do 'erroErros'
				EndCase
				&XmlReader.Read()							
				If &XmlReader.EOF = true
					Exit
				endif
			EndDo
			
			
			if &SolMsgCod = 'E0014' or &AuxSolMsg like '%já existe em uma NFS%'
				&Tentativa = 99
				&SolSts = Status_Solicitacao.Finalizada
				&SolMsg = &SolMsgCod.Trim() + ' Parece que nota está autorizada, realizando uma consulta da NFSe' 	
				
				GravaConsultaSEFAZ_NFSE.Call('CONSULTA_NFSE_RETORNO', &SolEmpCod, &SolFilCod, &SolNfeCod,&SolPesCod, &SolCod)
				
			Else
				&Tentativa = 99
				&SolSts = Status_Solicitacao.Falha
				&SolMsg = &SolMsgCod.Trim() + ' ' + &AuxSolMsg + ' ' + &Aux1SolMsg					
			Endif
		
		Endif
		&XmlReader.close()
		
		if &IsDeuErro = false
			
			&XmlReader.Open(&Nome_retorno_correto)
			&ret = &XmlReader.ReadType(1, 'infNFSe')
			if &ret <> 0					
				&XMLReader.Read()
				Do while (&XmlReader.Name <> 'infNFSe')
					Do Case						
						CAse &XmlReader.Name = 'cStat'
							&auxSolMsgCod = &XMLReader.Value
							//100 - NFS-e Gerada;
							//101 - NFS-e de Substituição Gerada;
							//102 - NFS-e de Decisão Judicial;
							//103 - NFS-e Avulsa;
							//107 - NFS-e MEI;
							//108 - Nota de Crédito;
							//109 - Nota de Débito;"
					Endcase					
					
					&XmlReader.Read()							
					If &XmlReader.EOF = true or (not &auxSolMsgCod.IsEmpty())
						Exit
					endif
				EndDo
			Endif
			&XmlReader.close()
			
			
			if not &auxSolMsgCod.IsEmpty()					
				Do Case
					Case &auxSolMsgCod in ('100', '101', '102', '103', '107', '108', '109')
						
						
						//100 - NFS-e Gerada;
						//101 - NFS-e de Substituição Gerada;
						//102 - NFS-e de Decisão Judicial;
						//103 - NFS-e Avulsa;
						//107 - NFS-e MEI;
						//108 - Nota de Crédito;
						//109 - Nota de Débito;"
						&NfeAutSts = &auxSolMsgCod					
						&SolMsg = &auxSolMsgCod.Trim() + ' - NOTA AUTORIZADA'
						
						&SolSts = Status_Solicitacao.Finalizada
						
						RetornaConfSistema.Call(&SolEmpCod, &SolFilCod, domCOnfSistema.TCon210_EnviarEmailAutorizadoNFSe, &TCon210_EnviarEmailAutorizadoNFSe)
						
						
						For Each Order EmpCod, NfsCod
							Where EmpCod = &SolEmpCod
							Where NfsCod = &SolNfeCod
							
							NfsSts = Status_Nfe.Autorizada
							
							if NfsArqXml.IsEmpty() or NfsArqXml.IsNull()
								&IsGravaXml = true
							Endif
							
							Exit
						EndFor
						
						commit
						
						if &IsGravaXml = true
							GravaArquivoXmlNFSe.Call(&SolEmpCod, &SolFilCod, &SolNfeCod, &Nome_retorno_correto)
							
							if &TCon210_EnviarEmailAutorizadoNFSe <> 'N'								
								For Each Order EmpCod, NfsCod
									Where EmpCod = &SolEmpCod
									Where NfsCod = &SolNfeCod
									
									if NfsArqXml.IsEmpty() or NfsArqXml.IsNull()
										&IsGravaXml = true
										
										&SdtEmail.Clear()
										RetornaEmailFaturamento.Call(EmpCod, NfsCliCod, &SdtEmail)
										If not NfsCliEml.IsEmpty() and not NfsCliEml.IsNull()
											&IsJahTem = false
											For &itemSdtEmail in &SdtEmail
												If &itemSdtEmail.EmlUrl = NfsCliEml
													&IsJahTem = true
													Exit
												EndIF	
											EndFor
											
											If &IsJahTem = false
												&itemSdtEmail = new()
												&itemSdtEmail.EmlUrl = NfsCliEml
												&SdtEmail.Add(&itemSdtEmail)
											EndIf
										EndIF
										
										if not &TCon162_EmailEnviarNotas.IsEmpty()
											&IsJahTem = false
											For &itemSdtEmail in &SdtEmail
												If &itemSdtEmail.EmlUrl = &TCon162_EmailEnviarNotas
													&IsJahTem = true
													Exit
												EndIF	
											EndFor
											
											If &IsJahTem = false
												&itemSdtEmail = new()
												&itemSdtEmail.EmlUrl = &TCon162_EmailEnviarNotas
												&SdtEmail.Add(&itemSdtEmail)
											EndIf
										EndIf
										
										If &SdtEmail.Count > 0
											prcRetornaPlacaPedido.call(EmpCod, NfsPedFilCod, NfsPedCod, &PedVeiPla)
											
											&NfeNum = NfsNum
											
											if &PedVeiPla.Length() = 8
												&EmlAss = format('Nota Fiscal Serviço %1 da %2, Placa: %3', trim(toformattedString(NfsNum)), trim(&FiLFan), &PedVeiPla)
											Else
												&EmlAss = 'Nota Fiscal Serviço ' + trim(toformattedString(NfsNum)) + ' da ' + trim(&FilFan)
											Endif
											
											GravaEnvioEmail.Call(EmpCod, NfsFilCod, NfsCod, 0, TipoContaEmail.Email_Faturamento, &EmlAss, TipoSolicitacao.Envia_NFSE, &SolPesCod, '', &SdtEmail, &sdtBoleto)
										EndIF
										
									EndIf							
									
									
									Exit
								EndFor
							EndIf
						Endif				
				EndCase
			Endif
		EndIF
		
		&File.Delete()
		
	EndIf
Endif



Sub 'erroErros'
	Do while (&XmlReader.Name <> 'erro' and &XmlReader.Name <> 'erros')
		Do Case
			Case &XMLReader.Name = 'codigo' or &XMLReader.Name = 'Codigo'
				&SolMsgCod = &XMLReader.Value
				
			Case &XMLReader.Name = 'descricao' or &XMLReader.Name = 'Descricao'
				&AuxSolMsg = trim(&XMLReader.Value)
				
			Case &XmlReader.Name = 'complemento' or &XmlReader.Name = 'Complemento'
				&Aux1SolMsg = trim(&XMLReader.Value)
		Endcase
		
		&XmlReader.Read()							
		If &XmlReader.EOF = true
			Exit
		endif
	EndDo
EndSub


Sub 'Exception_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXexceptionType',&GXexceptionType)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionDetails',&GXExceptionDetails)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionStack',&GXExceptionStack)
Endsub

Sub 'Error_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &Err',&Err.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBErr',&gxDBErr.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &GxDbSqlState',&GxDbSqlState)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBTxt',&gxDBTxt)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxOper',&gxOper)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrTbl',&gxErrTbl)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrOpt',&gxErrOpt.ToFormattedString())
Endsub
]]></Source>
