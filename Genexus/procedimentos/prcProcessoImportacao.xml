      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do CAse
	CAse &FecharPedidoSelecionado = true and &PedCod > 0 
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			&QtdItens += 1
		EndFor
		
		if &QtdItens > 0
			&QtdItens = &QtdItens*2
			&Total = round(&QtdItens/10,0)
		Endif
		&Total += 15
		
	Case &SalvarPedidoCompra = true
		For Each Order tmpNFeCod, tmpNfeItmCod
			Where tmpNFeCod = &tmpNfeCod
			&QtdItens += 1
		EndFor
		
		if &QtdItens > 0
			&Total = round(&QtdItens/10,0)
		Endif
		&Total += 10
		
	Otherwise
		&Total = 10
EndCase

&Count = 1
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

Do 'VerificaLancamento'
&PedStsGer	= IIf(&LctTip = TipoLancamento.SaidaMercadoria, Pedido_Gerado.Vendas, Pedido_Gerado.Compras)
Do Case
	Case &SalvarPedidoCompra = true
		//SALVA O PEDIDO DE COMPRA
		NotaTemporaria_Pedido.Call(&ProgressId, &Total, &Count, &tmpNFeCod, &EmpCod, &FiLCod,&PedVenCod, &PedStsGer, &LctCod, &tmpNfeFatFilCod,&DevPedCodOciRef, &PedCod, &wwpContextUserName)
	Case &FecharPedidoSelecionado = true and &PedCod > 0 
	
		if &PedCod > 0 and &SubstituirItensPedido = true
			NotaTemporaria_Pedido.Call(&ProgressId, &Total, &Count, &tmpNFeCod, &EmpCod, &FiLCod,&PedVenCod, &PedStsGer, &LctCod, &tmpNfeFatFilCod,&DevPedCodOciRef, &PedCod, &wwpContextUserName)	
		Endif
	
		//ATUALIZA ESTOQUE PEDIDO E FECHA	
		If &LctTip	= TipoLancamento.SaidaMercadoria
			AtualizaEstoqueGerencialVenda_submit.Call(&ProgressId, &EmpCod, &FilCod, &PedCod, &PedDtaFat, &UsuarioPesCod, Status_Pedido.FECHADO, False)
		Else
			AtualizaEstoqueGerencialCompra_submit.Call(&ProgressId, &Total, &Count, &EmpCod, &FiLCod, &PedCod, &PedDtaFat, &UsuarioPesCod, Status_Pedido.FECHADO, false)
		EndIf
EndCase

&Count += 1
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

If &SalvarNotaCompra = true
	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNFeCod
		VerificaNotaJahLancada.Call(&EmpCod, tmpNfeFatFilCod, tmpNfeProTer, tmpEmixCod, tmpNfeNum, tmpNfeSer, tmpModCod, tmpPedCod, &auxNfeCod)
		Exit
	EndFor
	//GRAVA ATUALIZA NOTA FISCAL
	NotaTemporaria_NotaFiscal.Call(&tmpNFeCod, &EmpCod, &FiLCod, &PedCod, &auxNfeCod)
	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
EndiF

&Count += 1
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

//ATUALIZA ICMS RETIDO NOS PRODUTOS
prcAtualizaBaseImcsRetido.call(&tmpNFeCod,  &EmpCod, &FiLCod, &PedCod)

&Count += 1
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

//GRAVA ORDEM COSTURA
If &SalvarOrdemCostura = true and &auxNfeCod > 0
	GravaOrdemCostura_NotaFiscal.Call(&EmpCod, &FiLCod, &auxNfeCod, &tmpNFeCod)
Endif


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &ProgressLogXml
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &ProgressLogXml
		Endnew
	endfor
	
	commit	
EndSub

Sub 'VerificaLancamento'
	
	For Each Order EmpCod, LctCod
		Where EmpCod	= &EmpCod
		Where LctCod	= &LctCod
		
		&LctTip	= LctTip
		
		Exit
	EndFor
	
EndSub
]]></Source>
