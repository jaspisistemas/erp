      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Mensagem.SetEmpty()
&IsErro = false

ValidaCodigoReferenciaRepetido.Call(&EmpCod, &ProCod, &ProGraCod, &ProBarRef, &Mensagem)

if not &Mensagem.IsEmpty()
	&IsErro = true
	return	
Else
	For Each Order EmpCod, ProCod, ProGraCod,ProBarRef
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where ProBarRef = &ProBarRef		
		
		&Mensagem = 'Código Atualizado com sucesso!'
			//A=AVULSO C = CAIXA  R = Referencia B = Barras  E = Etiqueta   O = Original
		if ProBarTip = 'A' or ProBarTip = 'C' or ProBarTip = 'O' //SOMENTE AVULSAS QUE IRAO ATUALZIAR
			ProBarTip = &ProBarTip
			ProBarMarCod = &ProBarMarCod 
			ProBarQtd = &ProBarQtd
		Endif
	
		if &ProBarOrd < 1
			ProBarOrd = 1
		Else
			ProBarOrd = &ProBarOrd
		Endif
	
		Exit
	When none
		For Each Order EmpCod, ProCod, ProGraCod, (ProBarId)
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			&ProBarId = ProBarId
			Exit
		EndFor
		if &ProBarId < 3
			&ProBarId = 2
		Endif
		&ProBarId += 1
		
		New
			EmpCod = &EmpCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
			ProBarId = &ProBarId
			ProBarRef = &ProBarRef
			if &ProBarTip.IsEmpty() or &ProBarTip = 'A'
				ProBarTip = 'A' //AVULSO
			Else
				ProBarTip = &ProBarTip //AVULSO/ETIQUETA/REFERENCIA
			EndIf
		
			if &ProBarOrd < 1
				ProBarOrd = 1
			Else
				ProBarOrd = &ProBarOrd
			Endif
		
			ProBarMarCod = &ProBarMarCod 
			ProBarQtd = &ProBarQtd
		EndNew
			
		&Mensagem = 'Código Inserido com sucesso!'
	EndFor

	Commit
	
	RetornaMaisCodigosCompleto.Call(&EmpCod, &ProCod, &ProGraCod, &ProBarRef_Comp)
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		ProRef_Comp = &ProBarRef_Comp
		
		For Each Order EmpCod, ProCod, ProGraCod
			Where ProGraCod = &ProGraCod
			
			ProBarRef_Comp = &ProBarRef_Comp
			Exit		
		EndFor
	
		Exit
	EndFor

	
	Commit
Endif
]]></Source>
