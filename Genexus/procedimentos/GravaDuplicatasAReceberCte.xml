      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	&CteDtaEms = CteDtaEms
	
	Do case 
		Case CteTomSer = tomador.Remetente
			&CliCod = CteRemCod
		Case CteTomSer = tomador.Destinatario
			&CliCod = CteDesCod
		Case CteTomSer = tomador.Expedidor
			&CliCod = CteExpCod
		Case CteTomSer = tomador.Recebedor
			&CliCod = CteRecCod
		OtherWise
			&CliCod = CteTomCod
	EndCase
	
	&VenCod = &PesCod
	
	
	&IsUmaDup = false
	For Each Order EmpCod, FilCod, CteCod, CteDupCod //Duplicatas Cte
		&IsUmaDup = true
		&CteDupCreCod = CteDupCreSeq
		
		Do CAse
			Case CteDupFilCod > 0 //FILIAL PROPRIA DP.
				&CteDupFilCod = CteDupFilCod		
			Otherwise //FILIAL NOTA
				&CteDupFilCod = &FilCod
		EndCAse
		
		GravaDuplicataAReceberNotaItem.Call(EmpCod, FilCod, CteCod, 0, &CteDupFilCod, &CteDupCreCod, &CteDtaEms, &CliCod, &VenCod, 1, CteDupNro, CteDupDtaVct, CteDupVlr, CteDupCbrCod,'CTE')
		
		CteDupFilCod = &CteDupFilCod
		CteDupCreSeq = &CteDupCreCod
	EndFor
	
	If CtePosDup = Status_SimNao.Sim
		CteStsFin = Status_Financeiro.FECHADO
	EndIf
EndFor



commit

if &IsUmaDup = true and &CtePedCod > 0
	FechaFinanceiroPedido.Call(&EmpCod, &CteFilCod, &CtePedCod)
EndIf
]]></Source>
