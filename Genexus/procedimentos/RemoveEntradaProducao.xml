      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem = ''

For Each Order EmpCod, FilCod, PrdCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PrdCod = &PrdCod
	
	If PrdSts <> Status_Pedido.ABERTO
		WWEntradaProducao.Link()
	EndIF
	
	For Each Order EmpCod, FilCod, PrdCod, PrdItmCod
		Where PrdItmCod = &PrdItmCod
		&Mensagem = 'Produto ' + trim(str(ProCod)) + ' REMOVIDO com sucesso!'
		
		For Each Order EmpCod, FilCod, PrdCod, PrdItmCod,PrdProEstLotCod
			Delete
		EndFor
	
		Delete
		Exit
	EndFor
	Exit
EndFor

Commit
]]></Source>
