      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &FucCod = 0 //INSERT
	prcLogAddSdt.Call('FucCod', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('FucNom', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('FucSmt', '', '', &sdtLogAtributos)
Else
	For Each order EmpCod, FucCod
		Where EmpCod = &EmpCod
		Where FucCod = &FucCod
		
		prcLogAddSdt.Call('FucCod', trim(FucCod.ToString()), '', &sdtLogAtributos)
		prcLogAddSdt.Call('FucNom', trim(FucNom), '', &sdtLogAtributos)
		prcLogAddSdt.Call('FucSmt', trim(FucSmt.ToString()), '', &sdtLogAtributos)
		
		Exit
	EndFor
Endif
]]></Source>
