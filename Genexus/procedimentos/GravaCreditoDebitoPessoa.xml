      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


Do Case
	Case &OqueFazer = 'ADD'
	
		For Each Order EmpCod, PesCod, (PesCtbItmCod)
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			&PesCtbItmCod = PesCtbItmCod
			Exit
		EndFor
		&PesCtbItmCod +=1
		
		New
			EmpCod = &EmpCod
			PesCod = &PesCod
			PesCtbItmCod = &PesCtbItmCod
			PesCtbCreCod = &PesCtbCreCod
			PesCtbHis = &PesCtbHis
			PesCtbTip = &PesCtbTip
			PesCtbCreDeb = &PesCtbCreDeb
			PesCtbVlr = &PesCtbVlr
			PesCtbDadAdi = &PesCtbDadAdi
		EndNEw
		
		commit
		
	Case &OqueFazer = 'UPD'
		
		
		
	Case &OqueFazer = 'DEL'
		
		
EndCAse
]]></Source>
