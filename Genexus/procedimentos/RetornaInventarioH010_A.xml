        <Source><![CDATA[
&sdtEFDH010.Clear()
&AuxFim = serverdate()
&AuxFim = &AuxFim.AddDays(1)
&AuxInicio = &DataInventario.AddDays(1)
&Mes = &DataInventario.Month()
&Ano = &DataInventario.Year()

For Each Order InvEmpCod, InvFilCod, InvAno, InvMes, InvProCod, InvProGraCod, InvProGraRef //when &OrdemExibicao = 'C'
	Where InvEmpCod = &EmpCod
	Where InvFilCod = &FilCod
	Where InvAno = &Ano
	Where InvMes = &MEs
	//Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	Where (InvProIsGra <> true) or (InvProIsGra.IsNull() or InvProIsGra.IsEmpty()) or InvProGraCod > 1
	Where InvProTipDef <> definicao.SERVICO and InvProTipDef <> Definicao.IMOBILIZADO	
	//Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	//where ProPadForCod = &ProPadForCod when &ProPadForCod <> 0
	Where InvProSts = Status_Produto.ATIVO // &ProSts when Not &ProSts.IsEmpty()
	where InvProVlrCus > 0
	where InvProQtd > 0
	
	&EstQtd = InvProQtd
	&AtuEstQtd = InvProQtdAtu
	&ProVlrCus = InvProVlrCus
	&InvEmpCod = InvEmpCod
	&InvProCod = InvProCod
	&INvProGraCod = InvProGraCod
	do 'GetProduto'
	
	//EstoqueAnteriorFichaFiscal.Call(EmpCod, FilCod, ProCod, ProGraCod, 1, &AuxInicio, &AuxFim, &EstQtd)
	
	//SOMENTE PRODUTOS COM ESTOQUE:A, 
	//ACRESCENTAR PRODUTOS SEM ESTOQUE:B, 
	//SOMENTE PRODUTOS SEM ESTOQUE:C
	
//	If (&EstQtd > 0 ) //and &FiltrarProdutos = 'A') or (&FiltrarProdutos = 'B') or (&EstQtd <= 0 and &FiltrarProdutos = 'C')	
	
		
//	EndiF
EndFor

Sub 'GetProduto'
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &InvEmpCod
		Where ProCod = &InvProCod
		Where ProGraCod = &INvProGraCod
		&PedVlrUnt = 0
		&TotPedVlrUNt = 0
		
		&TotProVlrCus = 0
		
//		&ProVlrCus = ProVlrCus
		
		If &EstQtd > 0 and &ProVlrCus > 0
			&TotProVlrCus = &ProVlrCus * &EstQtd
		EndIF
		
		&TotalInventarioMoeda += &TotProVlrCus
		
		RetornaEmbalagemProduto.call(EmpCod, ProCod, &ProEmbCod, &ProEmbNom, &ProTipDef, &GrupSpedNatRec)
		
		&IsAchouInventario = false
		For &sdtEFDH010Item in &sdtEFDH010
			if &sdtEFDH010item.ProRef = ProRef
				&IsAchouInventario = true
				Exit
			endif		
		EndFor
	
		if &IsAchouInventario = false	
			&sdtEFDH010item = new()
			&sdtEFDH010item.ProRef = ProGraRef
			&sdtEFDH010item.ProEmbUnd = ProEmbUnd
			&sdtEFDH010item.ProEmbCod = ProEmbCod
			&sdtEFDH010item.CustoTotal = &TotProVlrCus
			&sdtEFDH010item.CustoUnitario = &ProVlrCus
			&sdtEFDH010item.EstQtd = &EstQtd
			&sdtEFDH010item.GrupSpedCOD_CTA = FilCtaAna
			//		EstoqueAnteriorFichaFiscal.Call(EmpCod, FilCod, ProCod, ProGraCod, 1, &finNfeDtaEms, &finNfeDtaEms, &AtuEstQtd)
			//		
			//		&sdtEFDH010item.AtuEstQtd = &AtuEstQtd
			
			&sdtEFDH010.Add(&sdtEFDH010item)
		Endif		
		
		if &ProEmbCod.IsEmpty()
			&ProEmbCod = 1
			&ProEmbNom = 'UNIDADE'
			&ProTipDef = definicao.REVENDA
		Endif
		
		&IsJaGravado = false
		For &sdtEFD0190Item in &sdtEFD0190
			If &sdtEFD0190Item.UNID = ProEmbUnd
				&IsJaGravado = true
				Exit
			EndIF
		EndFor
		
		If &IsJaGravado = false
			&sdtEFD0190Item = new()
			&sdtEFD0190Item.UNID = ProEmbUnd
			&sdtEFD0190Item.DESCR = &ProEmbNom.Trim()
			&SdtEFD0190Item.EmbCod = &ProEmbCod
			&sdtEFD0190.Add(&sdtEFD0190Item)
		EndIF
		
		&ProGraNom = ProNomGra
		&NfeProGraRef = ProGraRef
		
		do 'sdt0200'
		if &IsJaGravado = false
			&sdtEFD0200item = new()
			&sdtEFD0200item.ProRef = &NfeProGraRef
			&sdtEFD0200item.ProGraNom = &ProGraNom
			&sdtEFD0200item.ProBar = ''//NfeProBar
			&sdtEFD0200item.ProEmbUnd = ProEmbUnd
			&sdtEFD0200item.ProTipDef = &ProTipDef
			&sdtEFD0200item.NcmCod = NcmCod
			&sdtEFD0200item.NcmCestCod = ProNcmCest
			&sdtEFD0200item.COD_ITEM = &COD_PART
			
//			EstoqueAnteriorFichaFiscal.Call(EmpCod, FilCod, ProCod, ProGraCod, 1, &finNfeDtaEms, &finNfeDtaEms, &AtuEstQtd)		
			&sdtEFD0200item.AtuEstQtd = &AtuEstQtd
			
			&sdtEFD0200.Add(&sdtEFD0200item)
		Endif
	EndFor
EndSub



Sub 'sdt0200'
	
	&IsJaGravado = false	
	&COD_PART = trim(&NfeProGraRef)
	
	&IsContinua = true
	do while &IsContinua = true
		&IsAchouCodigo = false
		For &sdtEFD0200item in &sdtEFD0200
			if &sdtEFD0200item.COD_ITEM = &COD_PART					
				if &sdtEFD0200item.ProGraNom = &ProGraNom
					&IsAchouCodigo = false
					&IsContinua = false
					&IsJaGravado = true
					Exit
				Else
					&Count += 1
					&COD_PART = trim(&NfeProGraRef) + 'N'+ trim(str(&Count))
					&IsAchouCodigo = true
					Exit
				Endif
				
			EndIF
		EndFor
		
		if &IsAchouCodigo = false
			&IsContinua = false
			Exit
		Endif
	EndDo
EndSub

]]></Source>
