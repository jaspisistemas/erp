		NfeNum = &auxNfeNum
		NfeSer = &auxNfeSer
		NfeFin = &NfeFin
		NfeDtaEms = &NfeDtaEms
		NfeDtaFat = &NfeDtaFat
		if &NfeDtaFat.IsEmpty()
			NfeDtaFat_Ano = 0
			NfeDtaFat_Mes = 0
		Else
			NfeDtaFat_Ano = &NfeDtaFat.Year()
			NfeDtaFat_Mes = &NfeDtaFat.Month()
		Endif
		NfeDtaDsp = &NfeDtaEms
		NfeHorEms = &NfeHorEms
		NfeLctCod = &LctCod
		NfeEntSai = &LctAtuSal
		NfeIndPres = &NfeIndPres
		if &NfeProTer <> Nota_ProPriaTerceira.PROPRIA
			ModCod = &ModCod
			NfeChv = &NfeChv
		EndIf			
			
		&xNfeDadAdi = RetiraCaracteresEspeciais.Udp(&NfeDadAdi)
		&xNfeDadAdi = strreplace(&xNfeDadAdi,chr(10),';')		
		&xNfeDadAdi = strreplace(&xNfeDadAdi,chr(13),';')	
		NfeDadManAdi = trim(&xNfeDadAdi)

		NfeCliEml = &NfeCliEml
		NfeProTer = &NfeProTer
		
		NfeChvRef = ''
		
		If not &NfeCliEml.IsEmpty()
			NfeEnvEml = NfeEnvEml.Pendente
		Else
			NfeEnvEml = NfeEnvEml.Nao_Enviar
		EndIF
		
		//DESTINATARIO
		NfeCliCod = &NfeCliCod
		NfeCliRaz = RetiraCaracteresEspeciais.Udp(trim(&NfeCliRaz))
		NfeCliTipPes = &NfeCliTipPes
		NfeCliCpf = &NfeCliCpf
		NfeCliCnpj = &NfeCliCnpj
		NfeCliFon = &NfeCliFon
		NfeCliIns = &NfeCliIns
		NfeCliSuf = &NfeCliSuf
		NfeCliEnd = RetiraCaracteresEspeciais.Udp(trim(&NfeCliEnd))
		NfeCliEndNro = &NfeCliEndNro.Trim()
		NfeCliBai = RetiraCaracteresEspeciais.Udp(trim(&NfeCliBai))
		NfeCliCep = &NfeCliCep.Trim()
		NfeCliCidCod = &NfeCliCidCod
		NfeCliCpl = RetiraCaracteresEspeciais.Udp(trim(&NfeCliCpl))
		&CidCod = &NfeCliCidCod
		do 'loadCidade'
		NfeCliCidIbge = &NfeCliCidIbge
		NfeCliCidNom = &NfeCliCidNom //PedCliEntCidNom
		NfeCliCidUF = &NfeCliCidUF
			
		//TRANSPORTE
		
		NfeTraPlaCod = FormataPlACA.Udp(&EmpCod,&NfeTraPlaCod)
		NfeTraPlaUF = &NfeTraPlaUF
		NfeTraRntc = &NfeTraRntc
		NfeMotNom = RetiraCaracteresEspeciais.Udp(trim(&NfeMotNom))
		NfeTraCod = &NfeTraCod
		NfeTraRaz = RetiraCaracteresEspeciais.Udp(trim(&NfeTraRaz))
		NfeTraTipPes = &NfeTraTipPes
		NfeTraEnd = RetiraCaracteresEspeciais.Udp(trim(&NfeTraEnd))
		NfeTraEndNro = &NfeTraEndNro
		NfeTraBai = RetiraCaracteresEspeciais.Udp(trim(&NfeTraBai))
		NfeTraEml = &NfeTraEml
		NfeTraCnpj = &NfeTraCnpj
		NfeTraInsEst = &NfeTraInsEst
		NfeTraCpf = &NfeTraCpf
		NfeTipFrt = &NfeTipFrt
		NfePesLiq = &NfePesLiq
		NfePesBrt = &NfePesBrt
		NfeQtdVol = &NfeQtdVol
		NfeEspVol = &NfeEspVol
		NfeMarVol = &NfeMarVol
		NfeNroVol = &NfeNroVol				
		NfeTraCidCod = &NfeTraCidCod
		&CidCod = &NfeTraCidCod
		do 'loadCidade'
		NfeTraCidNom = &NfeCliCidNom
		NfeTraCidUfeCod = &NfeCliCidUF
		
		NfeCidExp = &NfeCidExp
		NfeXped = &NfeXped
		NfeIsNFAe = &NfeIsNFAe
		
		NfeMrkCnpj = &NfeMrkCnpj
		NfeMrkUser = &NfeMrkUser
