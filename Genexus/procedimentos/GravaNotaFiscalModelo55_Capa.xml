        <Source><![CDATA[
&FilBasImp = RetornaFilialBaseImposto.Udp(&EmpCod, &FilCodFat)

For Each Order EmpCod, LctCod
	Where EmpCod = &EmpCod
	Where LctCod = &LctCod
	&LctAtuSal = LctAtuSal
	Exit
EndFor

	
If &NfeCod = 0
	&NfeCod = UltimoCodigoEmpresa.Udp(domParCod.NOTAFISCAL, &EmpCod, &FilCodFat)
	
	//if &auxNfeNum.IsEmpty()
		//FIZ PEGAR NUMERO SOMENTE QUANDO TRANSMITIR - JDF., QUANDO VEM DE PEDIDOS JA PEGA O NUMERO EM OUTRO PROCEDIMENTO
		//&NfeNum = UltimoCodigoEmpresa.Udp(domParCod.NOTAFISCALNUM, &EmpCod, &FilCodFat)
		//RetornaSerieNF.Call(domParCod.NOTAFISCAL55_SERIE, &EmpCod, &FilCodFat, &NfeSer)
	//Else
		if &NfeProTer = Nota_ProPriaTerceira.TERCEIROS
			&NfeNum = &auxNfeNum
			&NfeSer = &auxNfeSer
		Endif
	
		//if &auxNfeSer.IsEmpty() and &NfeProTer = Nota_ProPriaTerceira.PROPRIA
		//	RetornaSerieNF.Call(domParCod.NOTAFISCAL55_SERIE, &EmpCod, &FilCodFat, &NfeSer)
		//Else
		//	&NfeSer = &auxNfeSer
		//Endif
	//Endif	
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCodFat
		NfeCod = &NfeCod
		NfeFilCod = 0
		NfePedCod = 0
		NfeNum = &NfeNum
		NfeSer = &NfeSer
		NfeSts = Status_NFe.Digitando
		NfeProTer = &NfeProTer
				
		NfeChvRef = '' 
		NfeFin = &NfeFin
		
		NfeDtaEms = &NfeDtaEms
		NfeIndPres = &NfeIndPres
		NfeDtaFat = &NfeDtaFat
		if &NfeDtaFat.IsEmpty()
			NfeDtaFat_Ano = 0
			NfeDtaFat_Mes = 0
		Else
			NfeDtaFat_Ano = &NfeDtaFat.Year()
			NfeDtaFat_Mes = &NfeDtaFat.Month()
		Endif
	
		NfeDtaDsp = &NfeDtaEms
		
		NfeHorEms = &NfeHorEms
		if &NfeProTer <> Nota_ProPriaTerceira.PROPRIA
			ModCod = &ModCod
			NfeChv = &NfeChv
		Else			
			ModCod = '55' //NFCe
			NfeChv = ''
		EndIf

		NfeTipFrt = TipoFrete.SemFrete//PedTipFrt
		NfeLctCod = &LctCod
		NfeEntSai = &LctAtuSal
		&xNfeDadAdi = RetiraCaracteresEspeciais.Udp(&NfeDadAdi)
		&xNfeDadAdi = strreplace(&xNfeDadAdi,chr(10),';')		
		&xNfeDadAdi = strreplace(&xNfeDadAdi,chr(13),';')	
		NfeDadManAdi = trim(&xNfeDadAdi)
		NfeCliEml = &NfeCliEml
		If not &NfeCliEml.IsEmpty()
			NfeEnvEml = NfeEnvEml.Pendente
		Else
			NfeEnvEml = NfeEnvEml.Nao_Enviar
		EndIF
		
		//DESTINATARIO
		NfeCliCod = &NfeCliCod
		NfeCliRaz = RetiraCaracteresEspeciais.Udp(trim(&NfeCliRaz))
		NfeCliTipPes = &NfeCliTipPes
		NfeCliCpf = &NfeCliCpf
		NfeCliCnpj = &NfeCliCnpj
		NfeCliFon = &NfeCliFon
		NfeCliIns = &NfeCliIns
		NfeCliSuf = &NfeCliSuf
		NfeCliEnd = RetiraCaracteresEspeciais.Udp(trim(&NfeCliEnd))
		NfeCliEndNro = &NfeCliEndNro.Trim()
		NfeCliBai = RetiraCaracteresEspeciais.Udp(trim(&NfeCliBai))
		NfeCliCep = &NfeCliCep
		NfeCliCidCod = &NfeCliCidCod
		NfeCliCpl = RetiraCaracteresEspeciais.Udp(trim(&NfeCliCpl))
		&CidCod = &NfeCliCidCod
		do 'loadCidade'
		NfeCliCidIbge = &NfeCliCidIbge
		NfeCliCidNom = &NfeCliCidNom.Trim() //PedCliEntCidNom
		NfeCliCidUF = &NfeCliCidUF
				
		//TRANSPORTE
		NfeTraPlaCod = FormataPlACA.Udp(&EmpCod,&NfeTraPlaCod)
		NfeTraPlaUF = &NfeTraPlaUF
		NfeTraRntc = &NfeTraRntc
		NfeMotNom = RetiraCaracteresEspeciais.Udp(trim(&NfeMotNom))
		NfeTraCod = &NfeTraCod
		NfeTraRaz = RetiraCaracteresEspeciais.Udp(trim(&NfeTraRaz))
		NfeTraTipPes = &NfeTraTipPes
		NfeTraEnd = RetiraCaracteresEspeciais.Udp(trim(&NfeTraEnd))
		NfeTraEndNro = &NfeTraEndNro
		NfeTraBai = RetiraCaracteresEspeciais.Udp(trim(&NfeTraBai))
		NfeTraEml = &NfeTraEml
		NfeTraCnpj = &NfeTraCnpj
		NfeTraInsEst = &NfeTraInsEst
		NfeTraCpf = &NfeTraCpf
		NfeTraCep = &NfeTraCep
		NfeTipFrt = &NfeTipFrt
		NfePesLiq = &NfePesLiq
		NfePesBrt = &NfePesBrt
		NfeQtdVol = &NfeQtdVol
		NfeEspVol = &NfeEspVol
		NfeMarVol = &NfeMarVol
		NfeNroVol = &NfeNroVol				
		NfeTraCidCod = &NfeTraCidCod
		&CidCod = &NfeTraCidCod
		do 'loadCidade'
		NfeTraCidNom = &NfeCliCidNom.Trim()
		NfeTraCidUfeCod = &NfeCliCidUF
		NfeCidExp = &NfeCidExp
		
		
		//OUTROS DADOS
		NfeVlrTotPro = 0 //&NfeVlrTotPro
		NfeVlrTotFrt = 0 //&NfeVlrTotFrt
		NfeVlrTotIpi = 0 //&NfeVlrTotIpi
		NfeVlrTot = 0 //&NfeVlrTot
		NfeVlrTotSeg = 0 //&NfeVlrTotSeg
		NfeVlrTotOutDsp = 0 //&NfeVlrTotOutDsp
		NfeVlrTotDsc = 0 //&NfeVlrTotDsc
		NfeVlrTotBasIcms = 0 //&NfeVlrTotBasIcms
		NfeVlrTotIcms = 0 //&NfeVlrTotIcms
		NfeVlrTotBasIcmsSt = 0 //&NfeVlrTotBasIcmsSt
		NfeVlrTotIcmsSt = 0 //&NfeVlrTotIcmsSt				
		NfeVlrTotPdg = 0
		NfeEmiGnre = Status_SimNao.Nao	
		NfeXped = &NfeXped
		NfeIsNFAe = &NfeIsNFAe
		
		NfeMrkCnpj = &NfeMrkCnpj
