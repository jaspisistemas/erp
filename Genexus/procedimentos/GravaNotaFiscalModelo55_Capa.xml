Commit

if not &NfeChvRef.IsEmpty()
	&sdtNotasReferenciadasItem = new()
	&sdtNotasReferenciadasItem.NfeDocRefNfe = retornasoNumeros.Udp(&NfeChvRef)
	&sdtNotasReferenciadasItem.NfeDocRefMod = Substr(&NfeChvRef, 21, 2)
	&sdtNotasReferenciadas.Add(&sdtNotasReferenciadasItem)
	prcGravaDocumentosReferenciados.Call(&EmpCod, &FilCodFat, &NfeCod, &sdtNotasReferenciadas)
Endif

Sub 'loadCidade'
	&NfeCliCidIbge.SetEmpty()
	&NfeCliCidNom.SetEmpty()
	&NfeCliCidUF.SetEmpty()
	
	for Each Order EmpCod, CidCod
		where EmpCod = &EmpCod
		Where CidCod = &CidCod
		&NfeCliCidIbge = CidIBGE
		&NfeCliCidNom = CidNom
		&NfeCliCidUF = UfeCod
		Exit
	EndFor
EndSub
