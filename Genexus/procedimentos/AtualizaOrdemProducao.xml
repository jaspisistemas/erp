      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//RetornaCollGrupoProduto.Call(&EmpCod, &GrupHie, &ColGrupCod)
&auxGrupHie = &GrupHie.Trim() + '.'
Do Case
	Case &OqueFazer = 'A' //ZERAR QTD A FABRICAR
		For Each Order EmpCod, FilCod, ProCod, ProGraCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where ProSetCod = &SetCod or &SetCod = 0
			Where GrupHie like &auxGrupHie or GrupHie = &GrupHie when not &GrupHie.IsEmpty()
			EstFab = &Quantidade
		EndFor
		
	Case &OqueFazer = 'B' //PREENCHER COM VALOR DA SUGESTAO
		For Each Order EmpCod, FilCod, ProCod, ProGraCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where ProSetCod = &SetCod or &SetCod = 0
			Where GrupHie like &auxGrupHie or GrupHie = &GrupHie when not &GrupHie.IsEmpty()
			&EstSug = EstSug
			
			If &EstSug > 0
				If &EstSug > EstFabMin
					EstFab = &EstSug
				Else
					EstFab = EstFabMin
				EndIF
			Else
				EstFab = 0
			EndIF
			
		EndFor
		
EndCase


commit
]]></Source>
