      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsErro	= True

Do 'GetContaBancaria'
&DataHora	= ServerNow()
&jtiVarChar	= Trim(Str(DateTimeToTimestamp.Udp(&DataHora) * -1)) + '000'
&AuxBody	= StrReplace(&Body, Chr(13), '')
&Content	= 'POST' + newLine() + '/v1/boleto-hibrido/registrar-boleto' + newLine() + newLine() + &AuxBody + newLine() + &token.Trim() + newLine() + &jtiVarChar + newLine() + Trim(Str(&DataHora.Year())) + '-' + PadL(Trim(Str(&DataHora.Month())), 2, '0') + '-' + PadL(Trim(Str(&DataHora.Day())), 2, '0') + 'T' + PadL(Trim(Str(&DataHora.Hour())), 2, '0') + ':' + PadL(Trim(Str(&DataHora.Minute())), 2, '0') + ':00-00:00' + newLine() + 'SHA256'
&Content	= StrReplace(&Content, Chr(13), '')

&CaminhoVarChar	= &sdtConfiguracoesPasta.PastaDiretorioTempFis + 'request.txt'
&File.Source = &CaminhoVarChar
If Not &File.Exists()
    &File.Create()
EndIf
&File.WriteAllText(&Content)
&File.Close()
&Signature	= &AsymmetricSigner.DoSignFile(&PrivateKey, HashAlgorithm.SHA256, &CaminhoVarChar)

If &AsymmetricSigner.HasError()	= False
	&Signature	= StrReplace(&Signature, '=', '')
	&Signature	= StrReplace(&Signature, ' ', '')
	&Signature	= StrReplace(&Signature, '+', '-')
	&Signature	= StrReplace(&Signature, '/', '_')
	
	/*
	&VarChar	= 'X-Brad-Timestamp ' + Trim(Str(&DataHora.Year())) + '-' + PadL(Trim(Str(&DataHora.Month())), 2, '0') + '-' + PadL(Trim(Str(&DataHora.Day())), 2, '0') + 'T' + PadL(Trim(Str(&DataHora.Hour())), 2, '0') + ':' + PadL(Trim(Str(&DataHora.Minute())), 2, '0') + ':00-00:00'
	Msg('Authorization: Bearer ' + &token + newLine() + 'X-Brad-Signature: ' + &Signature.Trim() + newLine() + 'X-Brad-Nonce ' + &jtiVarChar + newLine() + &VarChar)
	Msg('Body: ' + &AuxBody)
	*/
	
	&HttpClient.AddHeader('Authorization', 'Bearer '+ &token)
	&HttpClient.AddHeader('X-Brad-Signature', &Signature.Trim())
	&HttpClient.AddHeader('X-Brad-Nonce', &jtiVarChar)
	&HttpClient.AddHeader('X-Brad-Timestamp', Trim(Str(&DataHora.Year())) + '-' + PadL(Trim(Str(&DataHora.Month())), 2, '0') + '-' + PadL(Trim(Str(&DataHora.Day())), 2, '0') + 'T' + PadL(Trim(Str(&DataHora.Hour())), 2, '0') + ':' + PadL(Trim(Str(&DataHora.Minute())), 2, '0') + ':00-00:00')
	&HttpClient.AddHeader('X-Brad-Algorithm', 'SHA256')
	&HttpClient.AddHeader('Access-token', &CtaBanPixCliSec)
	&HttpClient.AddHeader('cpf-cnpj', &CbrCnpj)
	&HttpClient.AddHeader('Content-Type', 'application/json')
	&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
	&HttpClient.AddHeader('Connection', 'keep-alive')
	&HttpClient.AddString(&AuxBody)
	
	&ExecuteUrl	= IIf(&CbrCtaBanPixApi = 'P', 'https://openapi.bradesco.com.br/v1/boleto-hibrido/registrar-boleto', 'https://proxy.api.prebanco.com.br/v1/boleto-hibrido/registrar-boleto')
	&HttpClient.Execute('POST', &ExecuteUrl)
	If &HttpClient.ErrCode	= 0
		&IsErro	= False
		&BradescoRegistroBoleto_Response.FromJson(&HttpClient.ToString())
		msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso! " + Trim(Str(&HTTPClient.StatusCode)), 'Boleto registrado com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))
		padraoUsuario.Call('G', 'BRADESCO_REGISTRABOLETOH_SUCESSO', &PesCod, &EmpCod, &HttpClient.ToString(), ServerDate())
	Else
		padraoUsuario.Call('G', 'BRADESCO_REGISTRABOLETOH_ERRO', &PesCod, &EmpCod, &HttpClient.ToString(), ServerDate())
		msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro " + Trim(Str(&HTTPClient.StatusCode)) + '!', &HTTPClient.ErrDescription + newLine() + &HttpClient.ToString(), DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf
Else
	msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro ao Assinar!",  &AsymmetricSigner.GetErrorDescription(), DVMessageType.error, "", DVMessageBoolean.True,""))
EndIf

Sub 'GetContaBancaria'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&CtaBanPixCliSec	= CtaBanPixCliSec
		&CbrCtaBanFilCod	= CbrCtaBanFilCod
		&CbrCtaBanPixApi	= CbrCtaBanPixApi
		Do 'GetFilial'
		
		Exit
	EndFor
	
	RetornaConfiguracoesPastas.Call(&EmpCod, &CbrCtaBanFilCod, &sdtConfiguracoesPasta)
	&CaminhoVarChar	= &SdtConfiguracoesPasta.PastaDiretorioCertificado + &FilCerNom
	&PrivateKey.LoadPKCS12(&CaminhoVarChar, "", &FilCerPsw)
	
EndSub

Sub 'GetFilial'
	
	For Each Order EmpCod, FilCod
		Where EmpCod	= &EmpCod
		Where FilCod	= &CbrCtaBanFilCod
		
		&FilCerNom	= FilCerNom
		&FilCerPsw	= FilCerPsw
		
		Exit
	EndFor
	
EndSub
	
	
]]></Source>
