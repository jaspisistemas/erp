      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

If &IsAcessoConcedido = true //Acesso concedido

	&EmpCod = &wwpContext.EmpCod
	&sdtRetornoWbsEtc.c1 = '0' //pedqtd
	&sdtRetornoWbsEtc.c2 = '0,00' //pedVlrUnt
	&sdtRetornoWbsEtc.c3 = '0,00' //PedItmVlr
	&sdtRetornoWbsEtc.c4 = '0,00' //PedItmVlrComDsc
	
	If &parPedQtd.IsEmpty() or &parPedVlrUnt.IsEmpty()
		Return
	Endif

	&PedQtd = &parPedQtd
	&PedVlrUnt = &parPedVlrUnt
	&PedItmDsc = &parPedItmDsc
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &Filcod
		Where PedCod = &PedCod
		
		&PedLctUntArr = PedLctUntArr
		&PedDtaEms = PedDtaEms
		&TabPrmCod = TabPrmCod
		&TabColCod = TabColCod
		&PedPerSrv1 = PedPerSrv1 
		&PedPerSrv2 = PedPerSrv2
		&PedPerPrm1 = PedPerPrm1 
		&PedPerPrm2 = PedPerPrm2 
		&PedPerSpm1 = PedPerSpm1 
		&PedPerSpm2 = PedPerSpm2
		
		Exit
	Endfor

	For Each ORder EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&ProTipDef = ProTipDef
		
		Exit
	EndFor
	
	//DESCONTO 
	&DescontoCapa = 0	
	&PedItmPrm = RetornaPrecoUnitarioTipo.Udp(&EmpCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedItmDsc)
	
    &PedVlrUntDsc = &PedVlrUnt
    if &PedItmDsc <> 0
		&PedVlrUntDsc = round(&PedVlrUnt - (&PedVlrUnt * &PedItmDsc * 0.01), 2)
    	&PedVlrUntDsc = round(&PedVlrUnt - (&PedVlrUnt * &PedItmDsc * 0.01), 2)
	Else
		Do Case
			Case &ProTipDef = Definicao.SERVICO
				&DescontoCapa = ( round((&PedVlrUnt * &PedPerSrv1 * 0.01),2) + (round(((&PedVlrUnt - round((&PedVlrUnt * &PedPerSrv1 * 0.01),2)) * &PedPerSrv2 * 0.01),2)))
			CAse &PedItmPrm = 'P' or &PedItmPrm = 'D'
				&DescontoCapa = (round((&PedVlrUnt * &PedPerPrm1 * 0.01),2) + (round(((&PedVlrUnt - round((&PedVlrUnt * &PedPerPrm1 * 0.01),2)) * &PedPerPrm2 * 0.01),2)))
			Otherwise
				&DescontoCapa = ( round((&PedVlrUnt * &PedPerSpm1 * 0.01) + (((&PedVlrUnt - (&PedVlrUnt * &PedPerSpm1 * 0.01)) * &PedPerSpm2 * 0.01)),2))
		EndCase
		
		&PedVlrUntDsc =  &PedVlrUnt - &DescontoCapa
    endif

	//TOTAL
	&PedVlrItm = round(&PedQtd * &PedVlrUntDsc, 2)
	//	&TotProPesLiq = &ProPesLiq * &PedQtd

	&sdtRetornoWbsEtc.sts = 'J200'
	
	//&PedVlrUntDsc
	&Varchar = trim(&PedQtd.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(0,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c1 = &Varchar//pedqtd
	
	&Varchar = trim(&pedVlrUnt.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c2 = &Varchar//pedVlrUnt

	&Varchar = trim(&PedVlrItm.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c3 = &Varchar //PedItmVlr
	
	&Varchar = trim(&PedVlrUntDsc.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(&PedLctUntArr, &Varchar, &Varchar)
	&sdtRetornoWbsEtc.c4 = &Varchar //PedVlrUntDsc
	
	
	&sdtRetornoWbsEtc.c5 = &ProCod.ToFormattedString()
	&sdtRetornoWbsEtc.c6 = &parPedQtd.ToFormattedString()
	&sdtRetornoWbsEtc.c7 = &parPedVlrUnt.ToFormattedString()
	&sdtRetornoWbsEtc.c8 = &parPedItmDsc.ToFormattedString()
	&sdtRetornoWbsEtc.c9 = &PedCod.ToFormattedString()
	&sdtRetornoWbsEtc.c10 = &Filcod.ToFormattedString()
		
EndIf


]]></Source>
