      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&UniqueID = &DeviceId

//CONEXAO
&GUID = GUID.NewGuid()
&DevRandon = &GUID.ToString()
&wwpContext.DeviceRandon = &DevRandon
if &UniqueID = 'UNIQUEID' 
	&UniqueID = &DevRandon
Endif

//DEVICE
for Each Order DeviceId
	WHere DeviceId = &UniqueID
	Exit
When none
	new
		DeviceId = &UniqueID
	EndNew
EndFor

commit

new
	DeviceId = &UniqueID
	DevRandon = &DevRandon
	DevAtu = true
	DevSts = Status_AtivoInativo.ATIVO
	DevRandonUltSync = now()
	DevWwpContext = &wwpContext.ToJson()
EndNEw

Commit


For Each Order DeviceId, DevRandon, DevTabCod
	Where DevRandon = &DevRandon
	delete
EndFor

Commit
]]></Source>
