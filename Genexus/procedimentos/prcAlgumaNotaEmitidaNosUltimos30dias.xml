      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&DataBase = serverdate()
&DataBase = &DataBase.AddDays(-30)

&IsTem = false

For Each order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where NfeDtaEms >= &DataBase
	Where NfeNum > 0
	Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
	
	&IsTem = true
	Exit
Endfor

if &IsTem = false //CTE
	For Each order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where CteDtaEms >= &DataBase
		Where CteNum > 0
		Where CteProTer = Nota_ProPriaTerceira.PROPRIA
		
		&IsTem = true
		Exit
	Endfor
Endif

if &IsTem = false //Nota servico
	For Each order EmpCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsDtaEms >= &DataBase
		Where NfsNum > 0
		Where NfsProTer = Nota_ProPriaTerceira.PROPRIA
		
		&IsTem = true
		Exit
	Endfor
EndIf
]]></Source>
