      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For EAch Order EmpCod, CxPdvCod, CxCod
	Where EmpCod = &EmpCod
	Where CxPdvCod = &CxPdvCod
	Where CxCod = &CxCod
	
	//GRAVA LOG
	&TabelaVarchar = 'CAIXA'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&CxPdvCod))
		&LogErpRegCod2 = trim(Str(&CxCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'CxUsuDin', trim(toformattedString(CxUsuDin)), trim(toformattedString(&CxUsuDin)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'CxUsuChq', trim(toformattedString(CxUsuChq)), trim(toformattedString(&CxUsuChq)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'CxUsuCar', trim(CxUsuCar.toformattedString()), trim(&CxUsuCar.toformattedString()), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'CxUsuCre', trim(CxUsuCre.toformattedString()), trim(&CxUsuCre.toformattedString()), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	CxUsuDin = &CxUsuDin
	CxUsuChq = &CxUsuChq
	CxUsuCar = &CxUsuCar
	CxUsuCre = &CxUsuCre

	Exit
Endfor


Commit
]]></Source>
