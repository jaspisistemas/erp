      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PEdCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&PedCod))
		&LogErpRegTip = TrnMode.Update
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedStsEnv', trim(toformattedString(PedStsEnv)), trim(toformattedString(&PedStsEnv)), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	Do CAse
		Case &PedStsEnv = Status_Rastreamento.Pendente
			if PedStsEnv = Status_Rastreamento.Enviada
				PedSts = Status_Pedido.ABERTO
			EndiF
			
		Case &PedStsEnv = Status_Rastreamento.Enviada
			If PedStsEnv <> Status_Rastreamento.Entregue
				if &LogErpTabIsLog = true //GRAVA LOG
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedEnvCod', trim(PedEnvCod), trim(&PedEnvCod), &LogErpRegGUID )
				Endif //GRAVA LOG
				
				PedEnvCod = &PedEnvCod
				PedSts = Status_Pedido.FECHADO
				PedDtaFat = PedDtaEms
				PedDtaFic = PedDtaEms
			EndIF
			
		Case &PedStsEnv = Status_Rastreamento.Entregue
			if &LogErpTabIsLog = true //GRAVA LOG
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedDtaDsp', trim(toformattedString(PedDtaDsp)), trim(toformattedString(&PedDtaDsp)), &LogErpRegGUID )
			Endif //GRAVA LOG
			
			PedDtaDsp = &PedDtaDsp
			
		Otherwise
			&AuxPedDtaDsp.SetEmpty()
			if &LogErpTabIsLog = true //GRAVA LOG
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedDtaDsp', trim(toformattedString(PedDtaDsp)), trim(toformattedString(&AuxPedDtaDsp)), &LogErpRegGUID )
			Endif //GRAVA LOG
		
			PedDtaDsp.SetEmpty()
	EndCase
	
	PedStsEnv = &PedStsEnv
	
	Exit
EndFor

commit

PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &PedCod)
]]></Source>
