      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVA ANEXOS DO FILAENVIOEMAIL EM BASE64 no FILAENVIOEMAILANEXOS

&AuxEmlAnxCod.SetEmpty()

For each order EmpCod, EmlTip,EmlCod,(EmlAnxCod)
	where EmpCod = &EmpCod
	where EmlTip = &EmlTip
	where EmlCod = &EmlCod
	&AuxEmlAnxCod = EmlAnxCod
	exit
EndFor

&File.Source = &Arquivo

If &File.Exists()
	
 	&Blob = &File.GetAbsoluteName()
	&EmlAnxNom = &File.GetName()
	&longVarChar = &Blob.ToBase64String()
	
EndIF

Do 'new'

Commit

Sub 'New'
	New
		EmpCod = &EmpCod
		EmlTip = &EmlTip
		EmlCod = &EmlCod
		EmlAnxCod = &AuxEmlAnxCod + 1
		EmlAnxNom = &EmlAnxNom
		EmlAnxBase64 = &longVarChar
	EndNew
EndSub
		
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
