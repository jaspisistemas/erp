      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem.SetEmpty()
&PedCliCodRaz.SetEmpty()
&PedVlrLiq.SetEmpty()
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&PedCliCodRaz = PedCliCodRaz
	&PedVlrLiq = PedVlrLiq
	Exit
When none
	&Mensagem = 'PEDIDO NÃO LOCALIZADO!'
	Return	
EndFor
]]></Source>
