      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
LoadWWPContext.Call(&Context)
&AutGrpCod.FromXml(&webSession.Get('PERFILUSUARIO'))
if &AutGrpCod.Count = 0
	CarregaSdtPerfil.Call(&Context.EmpCod, &Context.PesCod, &AutGrpNom)
	&AutGrpCod.FromXml(&webSession.Get('PERFILUSUARIO'))
Endif	

&AutNiv = 0

If &Context.TipoPerfil <> 3 //SUPORTE SISTEMA
	For Each Order EmpCod, AutGrpCod, AutIsAdm
		Where EmpCod = &Context.EmpCod
		Where AutGrpCod in &AutGrpCod
		where AutIsAdm = true //ADM EMPRESA
		&AutNiv = 3
			
		Exit
	When none
		For Each Order EmpCod, AutCod, (AutNiv)
			Where EmpCod = &Context.EmpCod
			Where AutGrpCod in &AutGrpCod
			Where AutCod = &AutCod
			
			&AutNiv = AutNiv
			
			Exit
		EndFor
	EndFor
	
	&IsExisteRotinaGravada = IsExisteRotinaGravada.Udp(&Context.EmpCod, &AutCod)
	if &IsExisteRotinaGravada = false
		&AutNiv = 0
	EndIF

Else //ADMINISTRADOR SUPORTE [MASTER]
	&AutNiv = 4
EndIF

If &AutNiv < &NivelRequerido and &RedirecionarErro = Status_SimNao.Sim
	if &NivelRequerido = 4
		&Mensagem = 'Não autorizado a rotina [' + trim(&AutCod) + '] Tela não acessível ao usuário. Dúvidas contacte o suporte.'
	Else
		&Mensagem = 'Não autorizado a rotina [' + trim(&AutCod) + '] Requerido nível ' + trim(str(&NivelRequerido))
	EndIF

	NaoAutorizadoRotina.Link(&Mensagem)
EndIF
]]></Source>
