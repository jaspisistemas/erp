      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProGraCod = 0
&ProCod = 0
&ProRef = ''
&ProNom = ''
	
if not &ForErpProRef.IsEmpty()
	For Each Order EmpCod, ProGraRef, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProGraRef = &ForErpProRef
		&ProGraCod = ProGraCod
		&ProCod =  ProCod
		&ProRef = ProGraRef
		&ProNom = ProNomGra
		
		if not &tmpProQtdCmpEmb.IsEmpty()
			ProQtdCmpEmb = &tmpProQtdCmpEmb
		Endif
	
		&tmpProNcmCod =  NcmCod
		&tmpProBar = ProBar
		Exit
	EndFor
EndIF


For Each Order tmpNFeCod 
	Where tmpNFeCod like '%'+&NomeTemporario.Trim()
	Where tmpPedCliCnpj like &AuxForCnpj or tmpPedCliCpf like &AuxForCnpj
	Where tmpProForCod = &ForProCod
	Where tmpNfeProBar = &ForProBar

	if not &tmpProQtdCmpEmb.IsEmpty()
		tmpProQtdCmpEmb = &tmpProQtdCmpEmb
	Endif

	tmpProGraCod = &ProGraCod
	tmpProCod = &ProCod
	tmpProRef = &ProRef
	tmpProNomERP = &ProNom
	tmpProNcmCod =  &tmpProNcmCod 
	
	If 	&tmpProNcmCod = 99 and tmpNcmCod <> 99 and not tmpNcmCod.IsNull()
		&tmpNcmCod = tmpNcmCod
		Do 'AtualizaProduto'
	EndIf

	tmpProBar = &tmpProBar 
	If not &tmpCFOP.trim().IsEmpty()
		tmpCFOP= &tmpCFOP
	EndIf

	If Not &tmpEntCFOP.Trim().IsEmpty()
		tmpEntCFOP = &tmpEntCFOP
	EndIf
EndFor

Commit

Sub  'AtualizaProduto'
	For Each Order EmpCod, ProGraRef, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraRef = &ForErpProRef
		NcmCod = &tmpNcmCod
	EndFor
EndSub
]]></Source>
