      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsDeuMerda = true
Do while &IsDeuMerda = true
	&GUID = GUID.NewGuid()
	&PesAceGuid  = &Guid.ToString()
	
	For Each Order EmpCod, PesAceGuid
		Where PesAceGuid = &PesAceGuid
		
		exit
	When none
		&IsDeuMerda = false
	EndFor
EndDo

if &IsDeuMerda = false
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		PesAceGuid = &PesAceGuid
		
		Exit
	EndFor
	
	Commit
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
