      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, ProCod, ProForCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProForCod = &ProForCod
	
	&ProForQtdEmb = ProForQtdEmb
	Exit
When none
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProForQtdEmb = ProQtdCmpEmb
		Exit
	EndFOr
EndFor

If &ProForQtdEmb.IsEmpty()
	&ProForQtdEmb = 1
EndiF
]]></Source>
