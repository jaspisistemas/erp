      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&WebNotification.Load(&WebNotificationId)

If &WebNotification.Fail()
	WWPBaseObjects.WWP_Logger.Error(&Pgmname, !"Web notificaiton not found with id: " + &WebNotificationId.ToString())
	return
EndIf

&WebNotification.WWPWebNotificationProcessed = ServerNow()
&WebNotification.WWPWebNotificationStatus = &WebNotificationStatus
&WebNotification.WWPWebNotificationDetail = &WebNotificationDetail
&WebNotification.Save()

If &WebNotification.Fail()
	WWPBaseObjects.WWP_Logger.Error(&Pgmname, !"Error updating web notification status with id: " + &WebNotificationId.ToString())
	return
EndIf
]]></Source>
