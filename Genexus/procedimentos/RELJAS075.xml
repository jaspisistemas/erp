      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'LISTAGEM DE AMOSTRA PRODUTOS X PEDIDOS REALIZADOS'
	print Cabecalho
	
End


For Each 
	Order EmpCod, FilCod, PedDtaEms, PedCod When &ORdem = 'A' and &IsAgrupar <> True
	Order EmpCod, FilCod, PedDtaDsp, PedCod When &ORdem = 'B' and &IsAgrupar <> True
	Order EmpCod, FilCod, PedVenCod, PedDtaEms, PedCod When &ORdem = 'A' and &IsAgrupar = true
	Order EmpCod, FilCod, PedVenCod, PedDtaDsp, PedCod When &ORdem = 'B' and &IsAgrupar = true
	
	
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedVenCod = &PedVenCod or &PedVenCod.IsEmpty()
	Where PedCliCod = &PedCliCod or &PedCliCod.IsEmpty()
	Where PedDtaEms >= &iniPedDtaEms when not &iniPedDtaEms.IsEmpty()
	Where PedDtaEms <= &finPedDtaEms when not &finPedDtaEms.IsEmpty()
	Where PedDtaDsp >= &iniPedDtaDsp when not &iniPedDtaDsp.IsEmpty()
	Where PedDtaDsp <= &finPedDtaDsp when not &finPedDtaDsp.IsEmpty()
	Where PedBlq = Status_Simnao.Sim
	Where PedStsGer = Pedido_gerado.Amostra
	&Vendedor = trim(str(PedVenCod)) + ' - ' + trim(PedVenRaz)
	
	If &PedVenCod <> PedVenCod and &IsAgrupar = true 
		if &PedVenCod > 0
			Eject
		EndiF
	
		print Vendedor
		print Titulo
	Else
		if &PedVenCod = 0
			print Titulo
		EndiF
	EndIF

	&PedCliRaz = trim(str(PedCliCod)) + ' - ' + trim(PedCliRaz)
	&PedCliRaz = gxGetMLi(&PedCliRaz, 1, 50)
	&PedVenRaz = trim(str(PedVenCod)) + ' - ' + trim(PedVenRaz)
	&PedVenRaz = gxGetMLi(&PedVenRaz, 1, 21)
	&ProNom = trim(str(ProCod)) + ' - ' + trim(ProNom)
	&ProNom = gxGetMLi(&ProNom, 1, 50)
	
	&PedUltCmp.SetEmpty()
	
	UltimaVendaProduto.Call(EmpCod, FilCod, PedCliCod, PedVenCod, ProCod, ProGraCod, &PedUltCmp)
	
	print rastreio
EndFor


Footer
	print Rodape
End
]]></Source>
