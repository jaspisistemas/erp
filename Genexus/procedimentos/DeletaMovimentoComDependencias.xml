      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&sdtDeleteMovimentoItem.FromXml(&webSession.Get('DuplicataPagamento'))

If &IsEliminaTransferencia = True
	//#################################  TRANSFERÊNCIAS #######################################
	Do 'TransIdentifica'
EndIf


//#################################  MOVIMENTO  #######################################
For Each Order EmpCod,MovCod
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	
	For each Order EmpCod,MovCod,MovItmCod
		MovItmSts = Status_Caixa.Cancelado
		
		if MovItmIsCon = Status_SimNao.Sim
			For each order EmpCod, LanBanDoc
				where LanBanDoc = MovItmDoc
				where LanBanData = MovItmDtaCon
				where CtabanCod = MovCtaBanCod
				
				LanBanStatus = StatusConciliacao.Pendente
			EndFor
		endif
	EndFor
	
	AtualizaSaldoConta.Call(TrnMode.Delete,EmpCod,MovCtaBanCod,MovDtaCon,MovCreDeb,MovVlr,&dataVazia,0,'')
	
	
	MovSts = Status_Caixa.Cancelado
	
	Exit
EndFor

Commit


If &sdtDeleteMovimentoItem.Count > 0
	Do Case
		Case &IsEliminaPgtoDP = true
			//#################################  PAGAMENTOS #######################################
			For &sdtDeleteMovimentoItemItem in &sdtDeleteMovimentoItem
				For each Order EmpCod,CreCod
					Where EmpCod = &EmpCod
					Where CreCod = &sdtDeleteMovimentoItemItem.MovCreCod
					Where FilCod = &sdtDeleteMovimentoItemItem.MovCreFilCod
					
					For each Order EmpCod,CreCod,CrePagCod
						Where CrePagCod = &sdtDeleteMovimentoItemItem.MovCrePagCod
						CrePagSts = Status_Caixa.Cancelado
					EndFor
					
					Exit
				EndFor
				
				AtualizaSaldoDuplicata.Call(&EmpCod,&sdtDeleteMovimentoItemItem.MovCreCod,&sdtDeleteMovimentoItemItem.MovCreFilCod)
				
			EndFor
			
			Commit
			
			For &sdtDeleteMovimentoItemItem in &sdtDeleteMovimentoItem
				prcAtualizaStatusCheque.Call(&EmpCod, &sdtDeleteMovimentoItemItem.MovCreFilCod, &sdtDeleteMovimentoItemItem.MovCreCod)
			EndFor
			
			
		Case &IsEliminaFolhaPgto = true
			For &sdtDeleteMovimentoItemItem in &sdtDeleteMovimentoItem
				DeletarPagamentoFolha.Call(&EmpCod,&sdtDeleteMovimentoItemItem.MovFunAno,&sdtDeleteMovimentoItemItem.MovFunMes,&sdtDeleteMovimentoItemItem.MovFunCod, &MovCod, 0)
			EndFor
			
		Case &IsEliminaAdiantamentos = true
			For &sdtDeleteMovimentoItemItem in &sdtDeleteMovimentoItem
//				DeletarPagamentoFolha.Call(&EmpCod,&sdtDeleteMovimentoItemItem.MovFunAno,&sdtDeleteMovimentoItemItem.MovFunMes,&sdtDeleteMovimentoItemItem.MovFunCod, &MovCod, 0)
			EndFor
			
	EndCase
EndIf

Sub 'TransIdentifica'

	&IsDestino = False
	&IsOrigem = False
	For each Order EmpCod,MovCod  //Destino
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		Where MovCreDeb = 'C'
		&DstMovCod    = MovCod		
		&MovTrnOriCod = MovTrnOriCod
		&MovTrnOriCodItm = MovTrnOriCodItm
		&IsDestino = true
	When none
		For each Order EmpCod,MovCod  //Origem
			Where EmpCod = &EmpCod
			Where MovCod = &MovCod
			Where MovCreDeb = 'D'
			&OriMovCod    = MovCod
			&IsOrigem = True
			&OriMovTrnOriCod = MovTrnOriCod
			&OriMovTrnOriCodItm = MovTrnOriCodItm
		EndFor		
	EndFor
	
	If &IsDestino = true
		Do 'TransOrigem'
	Else
		DO 'TransDestino'
	EndiF

	Do 'Delete'
EndSub

Sub 'TransOrigem'
	For each Order EmpCod,MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovTrnOriCod
		&OriMovCod    = MovCod
	EndFor
EndSub

Sub 'TransDestino'
	For each Order EmpCod,MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &OriMovTrnOriCod
		&DstMovCod    = MovCod
	EndFor
	
EndSub

Sub 'Delete'
	
	For each Order EmpCod,MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &OriMovCod
		
		For each Order  EmpCod,MovCod,MovItmCod
			
			MovItmSts = Status_Caixa.Cancelado
		EndFor
		
		AtualizaSaldoConta.Call(TrnMode.Delete,EmpCod,MovCtaBanCod,MovDtaCon,MovCreDeb,MovVlr,&dataVazia,0,'')
		
		MovSts = Status_Caixa.Cancelado
	EndFor
	Commit
	
	For each Order EmpCod,MovCod
		Where EmpCod = &EmpCod
		Where MovCod = &DstMovCod
		
		For each Order  EmpCod,MovCod,MovItmCod
			MovItmSts = Status_Caixa.Cancelado
		EndFor		
		AtualizaSaldoConta.Call(TrnMode.Delete,EmpCod,MovCtaBanCod,MovDtaCon,MovCreDeb,MovVlr,&dataVazia,0,'')
		MovSts = Status_Caixa.Cancelado
	EndFor
EndSub
]]></Source>
