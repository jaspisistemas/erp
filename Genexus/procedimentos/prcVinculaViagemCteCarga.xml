      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[LoadWWPContext.Call(&Context)

//CARREGA INFORMAÇÕES DO CTE
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod	= &parmEmpCod	//EMPRESA
	Where FilCod 	= &parmFilCod	//FILIAL
	Where CteCod 	= &parmCteCod	//CTE
	
	CteViaCod	 		= &parmViaCod	//RELACIONA A VIAGEM AO CTE
	
	&CteChv				= CteChv		//CHAVE DO CTE
	&ViaCarProPre		= CteCarProPre	//CARGA PREDOMINANTE
	&ViaCarVlrFreLiq	= CteVlrRecSer	//VALOR FRETE
	&ViaCarVlrFreBrt	= CteVlrTotPreSer
	
	For each order EmpCod, FilCod, CteCod, CteCarCod
		If CteCarUnd = UnidadeMedidaCte.UNIDADE AND CteCarTip = 'UNIDADE'
			&ViaCarCteQtd = CteCarQtd
		EndIf			
		
		If CteCarUnd = UnidadeMedidaCte.M3 and CteCarTip = 'METROS CUBICOS'
			&ViaCarCteVol = CteCarQtd
		EndIf
		
		If CteCarUnd = UnidadeMedidaCte.KG and CteCarTip = 'PESO BRUTO'
			&ViaCarCteTotPes = CteCarQtd
		EndIf
		
		If CteCarUnd = UnidadeMedidaCte.KG and CteCarTip = 'PESO LIQUIDO'
			&ViaCarCteTotPes = CteCarQtd
		EndIf
	EndFor

	&ViaCarUfeOri		= CteIniUfe		//UF DE ORIGEM  
	&ViaCarCidCodOri	= CteIniCidCod	//CIDADE DE ORIGEM
	&ViaCarCteTomSer	= CteTomSer		//TIPO DO TOMADOR
	&ViaCarCteDstCod	= CteDesCod
	&ViaCarUfeDst		= CteDesUfe		//UF DE DESTINO 
	&ViaCarCidCodDst	= CteDesCidCod	//CIDADE DE DESTINO
	
	Exit
EndFor

New
	EmpCod			= &parmEmpCod 			//empresa
	FilCod			= &parmFilCod 			//filial
	ViaCod			= &parmViaCod 			//viagem
	ViaCarCod		= 1 					//código da carga
	ViaCarCteDta	= ServerDate() 			//data adicionada
	ViaCarCteHor	= ServerTime()			//horário adicionado
	ViaCarTip		= 'C' 					//se foi preenchido com informações do CT-e ou manualmente (C = 'CTE'; M = 'Manual')
	ViaCarSts		= 'T'					//Status de transporte da carga (T = 'Em Trânsito'; C = 'Cancelada'; E = 'Entregue')
	ViaCarCteChv	= &CteChv				//Chave CT-e da carga
	ViaCarProPre	= &ViaCarProPre		 	//Produto predominante
	ViaCarVlrFreLiq	= &ViaCarVlrFreLiq		//Valor frete líquido
	ViaCarVlrFreBrt	= &ViaCarVlrFreBrt		//Valor frete bruto
	ViaCarCteVol	= &ViaCarCteVol			//Quantidade em m³ da carga
	ViaCarCteQtd	= &ViaCarCteQtd			//quantidade de itens na carga
	ViaCarCteTotPes	= &ViaCarCteTotPes		//Quantidade em Kg da carga
	ViaCarUfeOri	= &ViaCarUfeOri			//Uf de Origem
	ViaCarCidCodOri	= &ViaCarCidCodOri		//Cidade de Origem
	ViaCarCteTomSer	= &ViaCarCteTomSer		//Quem é o tomador
	ViaCarCteDstCod	= &ViaCarCteDstCod		//Código do Destinatário/Tomador da carga
	ViaCarUfeDst	= &ViaCarUfeDst			//Uf de destino da Carga
	ViaCarCidCodDst	= &ViaCarCidCodDst	 	//Código IBGE da cidade de Destino da carga
	ViaCarFun		= &Context.PesCod		//Pessoa que adicionou a carga na viagem
EndNew
		
Commit
]]></Source>
