      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
		&EmpCod = &wwpContext.EmpCod
		
		RetornaConfSistema_PedidoVendas.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &SdtConfig_wwpVendas_3)
				
		For Each Order EmpCod, PesCod
			Where EmpCod = &wwpContext.empCod
			Where PesCod = &PesCod
			
			&sdtCapaPedido.Sts = 'J200'
			
			&sdtCapaPedido.PedTraRedCod = PesCod
			&sdtCapaPedido.PedTraRedRaz = PesRaz
			
	//		&PesVenAprz = PesVenAprz
//			&PedCliObs = trim(PesObs) + ' ' + trim(PesObsMas)
//			&sdtCapaPedido.txtPedCliObs = &PedCliObs.Trim()
			
			&IsErroCliente = false
			
			Exit
		When None
			&IsErroCliente = true	
			&sdtCapaPedido.Obs = 'Pessoa não localizada!'
			&sdtCapaPedido.Sts = 'E001'
		EndFor

//		if  &IsErroCliente <> true	and &SdtConfig_wwpVendas_3.TCon020_ClientePadraoVista <> &PesCod
//			&sdtCapaPedido.PagamentoMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &sdtCapaPedido.PedCliCod, 'P')
//			&sdtCapaPedido.CreditoMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &sdtCapaPedido.PedCliCod, 'C')
//			&sdtCapaPedido.AvisoPedidoMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &sdtCapaPedido.PedCliCod, 'A')
//			&sdtCapaPedido.VinculosMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, &PedCod, &sdtCapaPedido.PedCliCod, 'V')
//		Endif
		
	


Endif

]]></Source>
