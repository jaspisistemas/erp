      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	&FilTabCod = FilTabCod
	Exit
EndFor

RetornaEmpresaModulo.Call(&EmpCod, modulosistema.INDAGRIL, &INDAGRIL)
Do 'OpenDocument'

&CellRow = 1

Do 'WriteColumnTitles'
Do 'CloseDocument'

Sub 'OpenDocument'
	If &FilenameFisico.IsEmpty()
		&Random = Random() * 10000
		&FilenameVirtual ="ExportProdutos-" + &Random.ToString().Trim() + !".xlsx"
		&ExcelDocument.Open(&FilenameVirtual)
		&ExcelDocument.AutoFit = 1
		Do 'CheckStatus'
		&ExcelDocument.Clear()
	Else		
		&ExcelDocument.Open(&FilenameFisico)
		&ExcelDocument.AutoFit = 1
		Do 'CheckStatus'
		&ExcelDocument.Clear()
	EndIf
EndSub



Sub 'WriteColumnTitles'
	&ExcelDocument.Cells(&CellRow,1).Bold = True
	&ExcelDocument.Cells(&CellRow,1).Text = "PRODUTOS"
	&CellRow+=2
	if &INDAGRIL = 'S'
		&ExcelDocument.Cells(&CellRow,1).Bold = True
		&ExcelDocument.Cells(&CellRow,1).Text = "CÓDIGO"
	Endif

	&ExcelDocument.Cells(&CellRow,2).Bold = True	
	&ExcelDocument.Cells(&CellRow,2).Text = "REFERÊNCIA"
	&ExcelDocument.Cells(&CellRow,3).Bold = True
	
	&ExcelDocument.Cells(&CellRow,3).Text = "NOME DO PRODUTO"
	
	&ExcelDocument.Cells(&CellRow,4).Bold = True
	&ExcelDocument.Cells(&CellRow,4).Text = "MARCA"
	
	&ExcelDocument.Cells(&CellRow,5).Bold = True
	&ExcelDocument.Cells(&CellRow,5).Text = "QUANTIDADE MIN. EMBALAGEM"
	
	&ExcelDocument.Cells(&CellRow,6).Bold = True
	&ExcelDocument.Cells(&CellRow,6).Text = "NCM"
	
	&Count = 7
	If &PrecoVenda = 'S'
		&ExcelDocument.Cells(&CellRow,&Count).Bold = True
		&ExcelDocument.Cells(&CellRow,&Count).Text = "VALOR TABELA (R$)"
		&Count += 1
	Endif
	
	&ExcelDocument.Cells(&CellRow,&Count).Bold = True
	&ExcelDocument.Cells(&CellRow,&Count).Text = "PESO"
	&Count += 1
					
	&ExcelDocument.Cells(&CellRow,&Count).Bold = True
	&ExcelDocument.Cells(&CellRow,&Count).Text = "GRUPO"
	&Count += 1
	
	&ExcelDocument.Cells(&CellRow,&Count).Bold = True
	&ExcelDocument.Cells(&CellRow,&Count).Text = "LOCACAO"
	Do 'Produtos'
EndSub


Sub 'Produtos'
	&auxGrupHie = &GrupHie.Trim() + '.'
	
	For each
		Order EmpCod, FilCod, ProNom when &Ordem = 'A' //ALFABETICA
		Order EmpCod, FilCod, ProGraRefPadL when &Ordem = 'C' //CÓDIGO
		Order EmpCod, FilCod, GrupHiePadL when &Ordem = 'G' //GRUPO
		Order EmpCod, FilCod, EstLoc when &Ordem = 'L' //LOCAÇão
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProTipDef = &ProTipDef when not &ProTipDef.IsEmpty()
		Where ProSts = &ProSts When not &ProSts.IsEmpty()
		where ProSts <> Status_Produto.EXCLUIDO when &ProSts.IsEmpty()
		//Where MarCod = &MarCod when not &MarCod.IsEmpty()
		Where ProEmbCod = &ProEmbCod when not &ProEmbCod.IsEmpty()
		Where ProCatCod = &ProCatCod when not &ProCatCod.IsEmpty()
		Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
		Where ProPadForCod = &ProPadForCod when Not &ProPadForCod.IsEmpty()
		Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
		Where EstQtd > 0 when &modelo = 'A' //Com Estoque:A, Sem Estoque:B
		Where EstQtd < 0 when &modelo = 'B'
		Where (ProIsGra <> true) or (ProIsGra.IsNull() or ProIsGra.IsEmpty()) or ProGraCod > 1
		where ProDtaCad >= &iniProDtaCad when not &iniProDtaCad.IsEmpty() 
		where ProDtaCad <= &finProDtaCad when not &finProDtaCad.IsEmpty()
		
		&IsImprime = true
		
		&ProBarRef_Comp = ''
		RetornaProdutoCodigosMarca.call(EmpCod, ProCod, &MarCod, &ProBarRef_Comp)
		
		if not &ProBarRef_Comp.IsEmpty() or MarCod = &MarCod Or &MarCod.IsEmpty()
			
			RetornaPrecoUnitarioVenda.Call(EmpCod, &FilTabCod, '', ProCod, ProGraCod, 1, Serverdate(), &PedDtaVct , &PedVlrUnt )
			
			If &IsListarSemPreco = true		
				
				if not &PedVlrUnt.IsEmpty()
					&IsImprime = false
				EndIF
			EndIF
			
			RetornaEstoquePedido.call(EmpCod, FilCod, ProCod, ProGraCod, &PedSts, &EstLoc, &EstQtd, &EstSdo, &Mensagem)
			
			if &ListarSomenteComLocacao = true	
				if not &EstLoc.IsEmpty()
					&IsImprime = false
				Endif
			EndIf
			
			if &IsImprime = true
				
				For Each Order EmpCod, ProCod, ProGraCod, ProBarId
					where ProBarMarCod = &MarCod when not &MarCod.IsEmpty()
					Where ProBarTip = 'A' Or ProBarTip = 'O'						
					
					&CellRow += 1
					
					if &INDAGRIL = 'S'
						&ExcelDocument.Cells(&CellRow,1).Bold = false
						&ExcelDocument.Cells(&CellRow,1).Text = ProGraRef.Trim()
					Endif
					
					&ExcelDocument.Cells(&CellRow,2).Bold = false
					&ExcelDocument.Cells(&CellRow,2).Text = ProBarRef.Trim()
					
					&ExcelDocument.Cells(&CellRow,3).Bold = false
					&ExcelDocument.Cells(&CellRow,3).Text = ProNomGra.Trim()
					
					if ProBarMarCod > 0
						RetornaNomeMarca.Call(EmpCod, ProBarMarCod, &ProBarMarNom)
						&ExcelDocument.Cells(&CellRow,4).Bold = false
						&ExcelDocument.Cells(&CellRow,4).Text = &ProBarMarNom.Trim()
					Else
						&ExcelDocument.Cells(&CellRow,4).Bold = false
						&ExcelDocument.Cells(&CellRow,4).Text = MarNom.Trim()
					Endif
					
					&ExcelDocument.Cells(&CellRow,5).Bold = false
					&ExcelDocument.Cells(&CellRow,5).Text = ProQtdEmb.ToString()
					
					&ExcelDocument.Cells(&CellRow,6).Bold = false
					&ExcelDocument.Cells(&CellRow,6).Text = NcmCod.ToString()
					
					&Count = 7
					If &PrecoVenda = 'S'
						&ExcelDocument.Cells(&CellRow,&Count).Bold = false
						&ExcelDocument.Cells(&CellRow,&Count).Number = &PedVlrUnt
						&Count += 1
					Endif
				
					&ExcelDocument.Cells(&CellRow,&Count).Bold = false
					&ExcelDocument.Cells(&CellRow,&Count).Text = trim(toformattedString(ProPesLiq))
					&Count += 1
					
					&ExcelDocument.Cells(&CellRow,&Count).Bold = false
					&ExcelDocument.Cells(&CellRow,&Count).Text = GrupCodNom.Trim()
					&Count += 1
					
					&ExcelDocument.Cells(&CellRow,&Count).Bold = false
					&ExcelDocument.Cells(&CellRow,&Count).Text = &EstLoc.Trim()
					
				When none
					&CellRow += 1
					
					if &INDAGRIL = 'S'
						&ExcelDocument.Cells(&CellRow,1).Bold = false
						&ExcelDocument.Cells(&CellRow,1).Text = ProGraRef.Trim()
					Endif
				
					&ExcelDocument.Cells(&CellRow,2).Bold = false
					&ExcelDocument.Cells(&CellRow,2).Text = ProGraRef.Trim()
					
					&ExcelDocument.Cells(&CellRow,3).Bold = false
					&ExcelDocument.Cells(&CellRow,3).Text = ProNomGra.Trim()
					
					&ExcelDocument.Cells(&CellRow,4).Bold = false
					&ExcelDocument.Cells(&CellRow,4).Text = MarNom.Trim()
					
					&ExcelDocument.Cells(&CellRow,5).Bold = false
					&ExcelDocument.Cells(&CellRow,5).Text = ProQtdEmb.ToString()
					
					&ExcelDocument.Cells(&CellRow,6).Bold = false
					&ExcelDocument.Cells(&CellRow,6).Text = NcmCod.ToString()
					
					&Count = 7
					If &PrecoVenda = 'S'
						&ExcelDocument.Cells(&CellRow,&Count).Bold = false
						&ExcelDocument.Cells(&CellRow,&Count).Number = &PedVlrUnt
						&Count += 1
					Endif
					
					&ExcelDocument.Cells(&CellRow,&Count).Bold = false
					&ExcelDocument.Cells(&CellRow,&Count).Text = trim(toformattedString(ProPesLiq))
					&Count += 1
					
					&ExcelDocument.Cells(&CellRow,&Count).Bold = false
					&ExcelDocument.Cells(&CellRow,&Count).Text = GrupCodNom.Trim()
					&Count += 1
					
					&ExcelDocument.Cells(&CellRow,&Count).Bold = false
					&ExcelDocument.Cells(&CellRow,&Count).Text = &EstLoc.Trim()
				EndFor
			EndiF		
		Endif		
	EndFor
EndSub



Sub 'CloseDocument'
	&ExcelDocument.Save()
	Do 'CheckStatus'
	&ExcelDocument.Close()
EndSub

Sub 'CheckStatus'
	If (&ExcelDocument.ErrCode <> 0)
		&FilenameVirtual = ""
		&ErrorMessage = &ExcelDocument.ErrDescription
		&ExcelDocument.Close()
		Return
	EndIf
EndSub
]]></Source>
