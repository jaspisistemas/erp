      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where CreCod = &CreCod
	
	&CreDtaPrmPag.SetEmpty()
	
	For each Order EmpCod,FilCod,CreCod, CrePagDta 
		Where CrePagSts.IsEmpty() or CrePagSts.IsNull() or CrePagSts <> Status_Caixa.Cancelado
		&CreDtaPrmPag = CrePagDta
		Exit
	EndFor
	
	For each Order EmpCod,FilCod,CreCod, CreRenDta
		Where CreRenVlr.IsEmpty() or CreRenVlr.IsNull()
		Delete
	EndFor
	Commit

	For each Order EmpCod,FilCod,CreCod, CreRenDta
		Where CreRenVlr > 0
		if (&CreDtaPrmPag > CreRenDta or &CreDtaPrmPag.IsEmpty()) and not CreRenDta.IsEmpty()
			&CreDtaPrmPag = CreRenDta
		EndIf
		
		Exit
	EndFor
	
	&Varchar = ''
	&AuxCrePrmPag.SetEmpty()
	&CreDtaCob.SetEmpty()
	For Each Order EmpCod, FilCod, CreCod, (CreDtaLig), (CreHorLig)
		Where (not CrePrmPag.IsEmpty()) and (not CrePrmPag.IsNull())
		//Where CrePagSts.IsEmpty() or CrePagSts.IsNull() or CrePagSts <> Status_Caixa.Cancelado
		&CreDtaCob = CreDtaLig
		FormataHORA.Call(CrePrmPagHor, &AuxCrePrmPagHor)
		&AuxCrePrmPag = CrePrmPag
		&Varchar = DtoC(CrePrmPag)
		&Varchar += ' ' + &AuxCrePrmPagHor
		Exit
	EndFor
	
	Exit
EndFor

For each Order EmpCod,FilCod,CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	
	CreDtaCob = &CreDtaCob
	CreDtaProPag = &AuxCrePrmPag
	CreDtaProPagHor = CtoT(&Varchar)
	CreDtaPrmPag = &CreDtaPrmPag
	
	CreAbvDup = CreAbvDup_FORMULA
	&CreVlrSdo = CreVlrSdo_FORMULA
	&CheCod = CreCheCod
	
	CreVlrSdo = &CreVlrSdo
	
	Exit
EndFor

commit

if &CheCod > 0
	//ATUALIZA MOTIVO CHEQUE
	For Each Order EmpCod, CheCod
		Where EmpCod = &EmpCod
		Where CheCod = &CheCod
		
		If &CreVlrSdo > 0 and CheMot = MotivoCheque.COMPENSADO
			CheMot = MotivoCheque.EMITIDO
		Endif
		
		If &CreVlrSdo = 0 and CheTip = TipoCheque.Proprio //and CheMot = MotivoCheque.COMPENSADO
			CheMot = MotivoCheque.COMPENSADO
		Endif
	
		Exit
	EndFor
	
	Commit
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
