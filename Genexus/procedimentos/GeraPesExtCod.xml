      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsOk = false
do while &IsOk = false
	&AuxPesExtCod = random()
	&PesExtCod = round(&AuxPesExtCod * 10000000, 0)
	
	if &PesExtCod <> 0
		For Each Order PesExtCod
			Where PesExtCod = &PesExtCod
			
			Exit
		When none
			For Each Order CrtExtId
				Where CrtExtId = &PesExtCod
				
				Exit
			When none
				For Each Order SupExtID
					Where SupExtID = &PesExtCod
					
					Exit
				When None
					&IsOk = true
				EndFor
			EndFor	
		EndFor
	EndIF
EndDo
]]></Source>
