      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &EmpEmlCod = 0 //INSERT
	prcLogAddSdt.Call('EmpEml', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('EmpEmlTip', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('EmpEmlAut', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('EmpEmlHos', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('EmpEmlUsr', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('EmpEmlPor', '', '', &sdtLogAtributos)
	prcLogAddSdt.Call('EmpEmlSec', '', '', &sdtLogAtributos)
Else
	For Each order EmpCod, EmpEmlCod
		Where EmpCod = &EmpCod
		Where EmpEmlCod = &EmpEmlCod
		
		prcLogAddSdt.Call('EmpEml', trim(EmpEml), '', &sdtLogAtributos)
		prcLogAddSdt.Call('EmpEmlTip', trim(EmpEmlTip), '', &sdtLogAtributos)
		prcLogAddSdt.Call('EmpEmlAut', trim(EmpEmlAut.ToFormattedString()), '', &sdtLogAtributos)
		prcLogAddSdt.Call('EmpEmlHos', trim(EmpEmlHos), '', &sdtLogAtributos)
		prcLogAddSdt.Call('EmpEmlUsr', trim(EmpEmlUsr), '', &sdtLogAtributos)
		prcLogAddSdt.Call('EmpEmlPor', trim(toformattedString(EmpEmlPor)), '', &sdtLogAtributos)
		prcLogAddSdt.Call('EmpEmlSec', trim(toformattedString(EmpEmlSec)), '', &sdtLogAtributos)
				
		Exit
	EndFor
Endif

]]></Source>
