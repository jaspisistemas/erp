      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&outNfeCCeCod = &NfeCCeCod

If &OqueFazer = 'G'
    //GRAVA/ATUALIZA
    For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeCCeCod = &outNfeCCeCod
		
        //do 'GetUltimoCod'
        NfeCCeCor = &NfeCCeCor.Trim()
		NfeCCeDta = serverdate()
		NfeCCeHor = SysTime()
        NfeCCeEvtCod = &NfeCCeEvtCod
		
        Exit
    When none //ATUALIZA
        do 'GetUltimoCod'
        new
			EmpCod = &EmpCod
            FilCod = &FilCod
            NfeCod  = &NfeCod
            NfeCCeCod = &outNfeCCeCod
            NfeCCeCor = &NfeCCeCor.Trim()
            NfeCCeDta = serverdate()
            NfeCCeHor = SysTime()
            NfeCCeSts = Status_NFe.Digitando
            NfeCCeDsc = 'CARTA DE CORRECAO'
            NfeCCeEvtCod = &NfeCCeEvtCod
        EndNew
    EndFor


Else //DELETA

    For Each Order EmpCod, FilCod, NfeCod, NfeCCeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeCCeCod = &outNfeCCeCod
       
	   	NfeCCeSts = Status_NFe.Cancelada
		NfeCCeEvtCod = 0
    Exit
    EndFor
EndIF

commit


Sub 'GetUltimoCod'
    //Pega Ultima Sequencia Cadastrada
    For Each Order EmpCod, FilCod, NfeCod, (NfeCCeCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
        &outNfeCCeCod = NfeCCeCod
        Exit
    EndFor
    &outNfeCCeCod += 1
EndSub
]]></Source>
