      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do 'GetContaBancaria'

&VerificaMensagemToken	= 0
&VerificaMensagemScopo	= 0
&LongVarChar			= &SdtEmitirCobranca_Inter.ToJson()
&Password				= '1234'
&Mensagem.SetEmpty()

If Not &contaCorrente.IsEmpty()
	&HttpClient.AddHeader('x-conta-corrente', &contaCorrente)
EndIf
&HttpClient.AddHeader('Content-Type', 'application/json')
&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
&HttpClient.AddHeader('Connection', 'keep-alive')
&HTTPClient.AddHeader('Authorization', 'Bearer ' + &CbrChaTra.Trim())
&HttpClient.AddString(&LongVarChar)

//Carrega o Certificado ao Handler
CSHARP try
CSHARP { [!&HttpClient!].AddCertificate([!&PathCert!],[!&Password!]); }
CSHARP catch (Exception ex)
CSHARP { [!&ErrorDescription!] = ex.ToString();
CSHARP }

&HttpClient.Execute('POST', 'https://cdpj.partners.bancointer.com.br/cobranca/v3/cobrancas')
If &HttpClient.StatusCode	= 200
	
	
	GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'A-'+&HttpClient.ToString(),0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
	
	&SdtEmitirCobranca_Inter_Response.FromJson(&HttpClient.ToString())
	
	
	
Else
//	&SdtEmitirCobranca_Inter_Response.FromJson(&HttpClient.ToString())
	
	
	GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'B-'+&HttpClient.ToString(),0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
	
	
	&SdtErroAPI_Inter.FromJson(&HttpClient.ToString())
	&Mensagem		= &SdtErroAPI_Inter.title + ' ' + &SdtErroAPI_Inter.detail
	
	If &SdtErroAPI_Inter.violacoes.Count >= 1
		For &violacoes In &SdtErroAPI_Inter.violacoes
			&Mensagem  += ' ' + &violacoes.razao.Trim() + ' Propriedade: ' + &violacoes.propriedade.Trim()
		EndFor
	EndIf
	
	&Mensagem	   += IIf(&ErrorDescription.IsEmpty(), '', ' - Erro CSHARP:' + &ErrorDescription.Trim())
	
	//Verifica se é erro de Token
	If &Mensagem.IsEmpty()
		&Mensagem				= &HttpClient.ToString()
		&VerificaMensagemToken	= StrSearch(&Mensagem, 'Token inválido.', 1)
	EndIf
	If &Mensagem.IsEmpty()
		&Mensagem		= &HttpClient.StatusCode.ToString() 
		
	Endif

	//Se for erro de token, realiza a autenticação automaticamente
	Do CAse
		CAse &VerificaMensagemToken > 0
			GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'E-'+&AuxCbrChaTra,0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
			
			prcOAuth_Inter.Call(&EmpCod, &FilCod, &PesCod, &CbrCod, &AuxCbrChaTra, &Mensagem)
			If &Mensagem.IsEmpty()
				GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'G-'+&Mensagem,0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
				prcEmitirCobranca_Inter.Call(&EmpCod, &FilCod, &CreCod, &PesCod, &CbrCod, &AuxCbrChaTra, &SdtEmitirCobranca_Inter, &contaCorrente, &Mensagem, &SdtEmitirCobranca_Inter_Response)
			Else
				GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'F-'+&Mensagem,0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
				msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &Mensagem, DVMessageType.error, "", DVMessageBoolean.True, ""))
			EndIf
		Case &Mensagem = '429.00' //muitas requisicoes
			&Mensagem	+= 'Muitas requisicoes, aguardando 20seg para reiniciar'
			GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'M-'+&Mensagem,0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
			&dorme = sleep(20)
			prcEmitirCobranca_Inter.Call(&EmpCod, &FilCod, &CreCod, &PesCod, &CbrCod, &AuxCbrChaTra, &SdtEmitirCobranca_Inter, &contaCorrente, &Mensagem, &SdtEmitirCobranca_Inter_Response)
	otherwise
		
		//Se for erro de escopo, sinaliza o escopo
		&VerificaMensagemScopo	= StrSearch(&Mensagem, 'escopos', 1)
		If &VerificaMensagemScopo > 0
			&Mensagem			= 'Faltando escopos necessários. Verifique na Conta Bancária se há os seguintes escopos: boleto-cobranca.write boleto-cobranca.read'
		EndIf
		GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'C-'+&Mensagem,0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
		GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'D-'+&LongVarChar,0,0,&CrePrmPag, &Hora, TipoObservacaoDuplicata.INTERNA)
	EndCase
	
EndIf

Sub 'GetContaBancaria'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
				
		//Faz o genexus criar um arquivo temporario do certificado
		//Pega o caminho da web dele
		&Path			= PathToUrl(CtaBanPixCer)
		&InicioPath		= StrSearch(&Path, 'PublicTempStorage', 1)
		&Path			= SubStr(&Path, &InicioPath, &Path.Length())
		
		//Pesquisa o caminho fisico temporario do certificado
		&File.Source	= CtaBanPixCerNom
		&PathCert		= &File.GetPath() + !"\" + &Path
		&PathCert		= StrReplace(&PathCert, '/', '\')
		&File.Close()		
		
		Exit
	EndFor
	
EndSub
]]></Source>
