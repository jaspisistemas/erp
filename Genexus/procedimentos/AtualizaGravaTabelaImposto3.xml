      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	
		
	RetornaRegimeTributarioFilial.Call(&EmpCod, &FilCod, &FilRegTrib, &CIMpOriUfeCod)
	
	&sdtCadastroTabelaImpostoCbs = new()
		
		&sdtCadastroTabelaImpostoCbs.EmpCod = &EmpCod
		&sdtCadastroTabelaImpostoCbs.CImpTbFilCod = &FilCod 
		&sdtCadastroTabelaImpostoCbs.CImpLctCod = &LctCod 
		&sdtCadastroTabelaImpostoCbs.CImpOriUfeCod = &CIMpOriUfeCod 
		&sdtCadastroTabelaImpostoCbs.CImpDstUfeCod = &UfeCod 
		&sdtCadastroTabelaImpostoCbs.CImpGruImpCod = &GruImpCod 
		&sdtCadastroTabelaImpostoCbs.CImpCatCod = &CatCod 

		&sdtCadastroTabelaImpostoCbs.CImpDtaIni = serverdate()
		
		
		&sdtCadastroTabelaImpostoCbs.CImpCfoCod = &parImpCfoCod
		&sdtCadastroTabelaImpostoCbs.CImpCstCod = &parCImpCstCod
//		&sdtCadastroTabelaImpostoCbs.CImpObsInf = &CImpObsInf	
		&sdtCadastroTabelaImpostoCbs.CImpDtaAlt = serverNow()
		
		
		&sdtCadastroTabelaImpostoCbs.CImpAlqMVA = &ParImpAlqMVA
		&sdtCadastroTabelaImpostoCbs.CImpAlqIcmInt = &ParimpAlqIcmInt
		&sdtCadastroTabelaImpostoCbs.CImpRedAlqIcmInt = &parImpRedAlqIcmInt
		&sdtCadastroTabelaImpostoCbs.CImpAlqIcmExt = &parImpAlqIcmExt
		&sdtCadastroTabelaImpostoCbs.CImpRedAlqIcmExt = &parImpRedAlqIcmExt
		&sdtCadastroTabelaImpostoCbs.CImpDif = &parImpDif			
		&sdtCadastroTabelaImpostoCbs.CImpCBenef = &parImpCBenef
		&sdtCadastroTabelaImpostoCbs.CImpAlqIcmUFDest = &parImpALqIcmUFDest
		&sdtCadastroTabelaImpostoCbs.CImpIcmsMotDes = &parImpIcmsMotDes
		&sdtCadastroTabelaImpostoCbs.CImpTaxFecop = &parImpTaxFecop
//		&sdtCadastroTabelaImpostoCbs.CImpIcmsRet = &CImpIcmsRet			
//		&sdtCadastroTabelaImpostoCbs.CImpAlqIcmStUF = &CImpAlqIcmStUF
		
		//INCLUIR E EXCLUIR
//		&sdtCadastroTabelaImpostoCbs.CImpIncIPI = &CImpIncIPI
//		&sdtCadastroTabelaImpostoCbs.CImpExcPisCofins = &CImpExcPisCofins
		
		//IPI
		&sdtCadastroTabelaImpostoCbs.CImpCstIpi = &parImpCstIpi
		&sdtCadastroTabelaImpostoCbs.CImpIpi = &parImpIPI
//		&sdtCadastroTabelaImpostoCbs.CImpIpiEnq = &CImpIpiEnq
		
		//INSS
		&sdtCadastroTabelaImpostoCbs.CImpAlqInss = &parImpAlqinss
		
		//PIS e COFINS
		&sdtCadastroTabelaImpostoCbs.CImpCstPisCofins = &parImpCstPis
		&sdtCadastroTabelaImpostoCbs.CImpCofins = &parImpCofins
		&sdtCadastroTabelaImpostoCbs.CImpCofinsRed = &parImpCofinsRed
		&sdtCadastroTabelaImpostoCbs.CImpPis = &parImpPis
		&sdtCadastroTabelaImpostoCbs.CImpPisRed = &parImpPisRed
	
	
	For Each Order EmpCod,CImpTbFilCod,CImpLctCod,CImpOriUfeCod, CImpDstUfeCod,CImpGruImpCod,CImpCatCod 
		where EmpCod = &EmpCod
		where CImpTbFilCod = &FilCod
		where CImpLctCod = &LctCod
		Where CImpOriUfeCod = &CIMpOriUfeCod
		where CImpDstUfeCod = &UfeCod
		where CImpGruImpCod = &GruImpCod
		where CImpCatCod = &CatCod
	
		
		if &IsAtualizarCfop <> true
			&sdtCadastroTabelaImpostoCbs.CImpCfoCod = CImpCfoCod
		Endif
	
		if &IsAtualizarSit <> true
		&sdtCadastroTabelaImpostoCbs.CImpCstCod = CImpCstCod
		EndIf
		&sdtCadastroTabelaImpostoCbs.CImpObsInf = CImpObsInf	
		&sdtCadastroTabelaImpostoCbs.CImpDtaAlt = serverNow()		
		
		if &IsAtualizarMVA <> true
			&sdtCadastroTabelaImpostoCbs.CImpAlqMVA = CImpAlqMVA
		Endif
	
		if &IsAtualizarAlqInt <> true
			&sdtCadastroTabelaImpostoCbs.CImpAlqIcmInt = CImpAlqIcmInt
		EndIf
	
		if &IsAtualizarRedAlqInt <> true
			&sdtCadastroTabelaImpostoCbs.CImpRedAlqIcmInt = CImpRedAlqIcmInt
		Endif	
		if &IsAtualizarAlqExt <> true
			&sdtCadastroTabelaImpostoCbs.CImpAlqIcmExt = CImpAlqIcmExt
		EndIf
		if &IsAtualizarRedAlqExt <> true
			&sdtCadastroTabelaImpostoCbs.CImpRedAlqIcmExt = CImpRedAlqIcmExt
		Endif
		if &IsAtualizarDif <> true
			&sdtCadastroTabelaImpostoCbs.CImpDif = CImpDif			
		EndIf
		
		if &IsAtualizarBenef <> true
			&sdtCadastroTabelaImpostoCbs.CImpCBenef = CImpCBenef
		EndIf
		if &IsAtualizarImpALqIcmUFDest <>  true
			&sdtCadastroTabelaImpostoCbs.CImpAlqIcmUFDest = CImpAlqIcmUFDest
		Endif
		if &IsAtualizarDeson <> true
			&sdtCadastroTabelaImpostoCbs.CImpIcmsMotDes = CImpIcmsMotDes
		EndIf
	
		if &IsAtualizarFecop <> true
			&sdtCadastroTabelaImpostoCbs.CImpTaxFecop = CImpTaxFecop
		Endif
	
		&sdtCadastroTabelaImpostoCbs.CImpIcmsRet = CImpIcmsRet			
		&sdtCadastroTabelaImpostoCbs.CImpAlqIcmStUF = CImpAlqIcmStUF
		
		//INCLUIR E EXCLUIR
		&sdtCadastroTabelaImpostoCbs.CImpIncIPI = CImpIncIPI
		&sdtCadastroTabelaImpostoCbs.CImpExcPisCofins = CImpExcPisCofins
		
		//IPI
		If &IsAtualizarCstIpi <> true
			&sdtCadastroTabelaImpostoCbs.CImpCstIpi = CImpCstIpi
		Endif
		If &IsAtualizarIPI <> true
			&sdtCadastroTabelaImpostoCbs.CImpIpi = CImpIpi
		Endif
		&sdtCadastroTabelaImpostoCbs.CImpIpiEnq = CImpIpiEnq
		
		//INSS
		if &IsAtualizarINSS <> true
			&sdtCadastroTabelaImpostoCbs.CImpAlqInss = CImpAlqInss
		Endif
	
		//PIS e COFINS
		If &IsAtualizarCSTPIS <> true
			&sdtCadastroTabelaImpostoCbs.CImpCstPisCofins = CImpCstPisCofins
		Endif
		If &IsAtualizarCOFIN <> true
			&sdtCadastroTabelaImpostoCbs.CImpCofins = CImpCofins
		Endif
		if &IsImpCofinsRed <> true
			&sdtCadastroTabelaImpostoCbs.CImpCofinsRed = CImpCofinsRed
		Endif		
		If &IsAtualizarPIS <> true
			&sdtCadastroTabelaImpostoCbs.CImpPis = CImpPis
		EndIF
		if &IsImpPisRed <> true
			&sdtCadastroTabelaImpostoCbs.CImpPisRed = CImpPisRed
		Endif
		
		
		
		if &IsAtualizarObs <> true
			For Each Order EmpCod,CImpTbFilCod,CImpLctCod,CImpOriUfeCod, CImpDstUfeCod,CImpGruImpCod,CImpCatCod , ObsCod
				
				&sdtObservacaoNotaItem = new()
				&sdtObservacaoNotaItem.ObsCod = ObsCod
				&sdtObservacaoNota.Add(&sdtObservacaoNotaItem)
				
			EndFor
		Endif
		
	EndFor
	

	prcGravaNovaConfiguracaoImposto.Call('ADD', &sdtCadastroTabelaImpostoCbs, &sdtObservacaoNota)
]]></Source>
