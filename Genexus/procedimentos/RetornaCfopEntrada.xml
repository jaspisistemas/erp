      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &CfoCod.Length() = 5 //1.102
	&AuxCfoCod = &CfoCod
Else
	&AuxCfoCod = format('%1.%2', substr(&CfoCod, 1, 1), substr(&CfoCod, 2, 3))
EndIf

For Each ORder CfoCod, CfoEmpCod, CfoLctCod
	Where CfoCod = &AuxCfoCod
	Where CfoEmpCod = &EmpCod
	Where CfoLctCod = &LctCod
	
	&CfoInvCod = CfoEmpEntCod
	
	if CfoEmpAprvCredIcms = 'N'
		&CfoEmpAprvCredIcmsPer = CfoEmpAprvCredIcmsPer
	Endif

	Exit
When None
	Do Case
		Case Substr(&CfoCod, 1, 1) = '6'
			&CfoInvCod = '2' + Substr(&CfoCod, 2, 4)
		case Substr(&CfoCod, 1, 1) = '5'
			&CfoInvCod = '1' + Substr(&CfoCod, 2, 4)
		Otherwise
			&CfoInvCod = &CfoCod
	EndCase
	
	For each Order CfoCod
		Where CfoCod = &CfoCod
		
		if not CfoInvCod.IsEmpty() and len(CfoInvCod) >= 4
			&CfoInvCod = CfoInvCod 
		EndIf
		
		Exit
	EndFor
	
	Do Case
		Case &CfoInvCod = '1.405' or &CfoInvCod = '1405'
			&CfoInvCod = '1.403'
		Case &CfoInvCod = '2.405' or &CfoInvCod = '2405'
			&CfoInvCod = '2.403'
	EndCase
EndFor

]]></Source>
