      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsErroLancada = false
&Mensagem = ''
	
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod <> &CteCod
	Where CteChv = &CteChv
	Where CteProTer = Nota_ProPriaTerceira.TERCEIROS
	Where CteSts <> Status_NFe.Importada
	
	&IsErroLancada = true
	&Mensagem = 'CHAVE JA LANÇADA NO CTE SEQUÊNCIA: ' + trim(str(CteCod))
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
