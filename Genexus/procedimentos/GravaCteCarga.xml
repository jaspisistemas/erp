      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &CteModCod = '67'
	For each Order EmpCod,FilCod,CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		CteSerDes = &CteSerDes
	EndFor
	
	Do 'AtualizaCarga'
	&auxCteCarCod = 0
	Do 'GetCodCarga'
	If  &auxCteCarQtd > 0 //############################################ 'UNIDADE'
		&auxCteCarCod+=1
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CteCod = &CteCod
			CteCarCod = &auxCteCarCod
			CteCarUnd = UnidadeMedidaCte.UNIDADE 
			CteCarQtd = &auxCteCarQtd
			CteCarTip = 'UNIDADE'
			CtecarIns = 'A' //automatico
		EndNew
	EndIf
	
	Commit
	
	//############################################ SEGURO	
	For each Order EmpCod,FilCod,CteCod,CteSegCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteSegCod = &CteSegCod
		CteSegRef = &CteSegRef
		CteSegNom = &CteSegNom
		CteSegApl = &CteSegApl
		CteSeqVlrCar = &CteCarVlrTot
		Exit
	When none
		For each Order EmpCod,FilCod,CteCod,CteSegCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CteCod = &CteCod
			Delete
		EndFor
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CteCod = &CteCod
			CteSegCod = &CteSegCod
			CteSegRef = &CteSegRef
			CteSegNom = &CteSegNom
			CteSegApl = &CteSegApl
			CteSeqVlrCar = &CteCarVlrTot
		EndNew
	EndFor
Else
	Do Case
		Case &CteFinEms = FinalidadeCte.Complemento
			For each Order EmpCod,FilCod,CteCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where CteCod = &CteCod
				CteTomChvCpl = &CteTomChvCpl
				exit
			EndFor		
			
		Case &CteFinEms = FinalidadeCte.Anulacao
			&Index = 0 
			For each Order EmpCod,FilCod,CteCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where CteCod = &CteCod
				CteTomChvAnaOri = &CteTomChvAnaOri
				CteTomDtaEmsDec = &CteTomDtaEmsDec
				
				//41 1912 19182981000163 57 001 000000280 1 00000280 2
				&CteNum = val(substr(&CteTomChvAnaOri,26,9) )
				&Index = strSearch(CteObsGer,'ANULACAO',1)
				If &Index = 0 
					CteObsGer += ' CTE DE ANULACAO DE VALORES RELATIVO A PRESTACAO DE SERVICO DE TRASNPORTE TOMADOS POR MEIO DO CT-E, NUMERO '+trim(str(&CteNum))+', SERIE '+substr(&CteTomChvAnaOri,23,3)+', CHAVE DE ACESSO:'+trim(&CteTomChvAnaOri)+', EMITIDO EM XX/XX/XXXX, NO VALOR DE R$ 00,00, COM ERRO XXXXXXXX.'  
				EndIf
				
				exit
			EndFor	
		OtherWise
		
			&Index = 0 	
		
			//############################################ CTE CARGA CAPA	
			For each Order EmpCod,FilCod,CteCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where CteCod = &CteCod
				CteCarProPre = &CteCarProPre.ToUpper()
				CteCarVlrTot= &CteCarVlrTot
				CteCarOtrCar = &CteCarOtrCar.ToUpper()
				
				
				If &CteFinEms = FinalidadeCte.Substituicao
					CteTomChvAnaOri = &AuxCteTomChvAnaOri
					CteTomChvAna = &CteTomChvAna
					CteTomChvEmt = &CteTomChvEmt
					CteTomVlrDoc = &CteTomVlrDoc
					CteTomDtaEmsDoc = &CteTomDtaEmsDoc
					
					&CteNum = val(substr(&AuxCteTomChvAnaOri,26,9))
					&Index = strSearch(CteObsGer,'SUBSTITUI',1)
					If &Index = 0 
						CteObsGer += ' ESTE DOCUMENTO SUBSTITUI O CTE-E NUMERO '+trim(str(&CteNum))+', SERIE '+substr(&AuxCteTomChvAnaOri,23,3)+', CHAVE DE ACESSO:'+trim(&AuxCteTomChvAnaOri)+', EMITIDO EM XX/XX/XXXX, EM VIRTUDE DE ...(descrever o erro).'
					EndIf						
				EndIf
				Exit
			EndFor			
			//############################################ CARGA
			Do 'AtualizaCarga'
			&auxCteCarCod = 0
			Do 'GetCodCarga'
			If &M3CteCarQtd > 0 //############################################ 'METROS CÚBICOS'
				&auxCteCarCod+=1
				new 
					EmpCod = &EmpCod
					FilCod = &FilCod
					CteCod = &CteCod
					CteCarCod = &auxCteCarCod
					CteCarUnd = UnidadeMedidaCte.M3	
					CteCarQtd = &M3CteCarQtd
					CteCarTip = 'METROS CUBICOS'
					CtecarIns = 'A'
				Endnew
			EndIf
			Commit
			
			If  &LiqCteDocPes > 0 //############################################ 'PESO LÍQUIDO'
				&auxCteCarCod+=1
				New
					EmpCod = &EmpCod
					FilCod = &FilCod
					CteCod = &CteCod
					CteCarCod = &auxCteCarCod
					CteCarUnd = UnidadeMedidaCte.KG 
					CteCarQtd = &LiqCteDocPes
					CteCarTip = 'PESO LIQUIDO'
					CtecarIns = 'A'
				EndNew
			EndIf
			
			Commit
			
			If  &BrtCteDocPes > 0 //############################################ 'PESO BRUTO'
				&auxCteCarCod+=1
				New
					EmpCod = &EmpCod
					FilCod = &FilCod
					CteCod = &CteCod
					CteCarCod = &auxCteCarCod
					CteCarUnd = UnidadeMedidaCte.KG 
					CteCarQtd = &BrtCteDocPes
					CteCarTip = 'PESO BRUTO'
					CtecarIns = 'A'
				EndNew
			EndIf
			Commit
			
			If  &CteCarQtd > 0 //############################################ 'UNIDADE'
				&auxCteCarCod+=1
				New
					EmpCod = &EmpCod
					FilCod = &FilCod
					CteCod = &CteCod
					CteCarCod = &auxCteCarCod
					CteCarUnd = UnidadeMedidaCte.UNIDADE 
					CteCarQtd = &CteCarQtd
					CteCarTip = 'UNIDADE'
					CtecarIns = 'A' //automatico
				EndNew
			EndIf
			Commit
			//#######################################################################################################
	EndCase
EndIf


Sub 'GetCodCarga'
	For each Order EmpCod,FilCod,CteCod,(CteCarCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&CteCarCod = CteCarCod
		Exit
	EndFor
	&auxCteCarCod = &CteCarCod
EndSub

Sub 'AtualizaCarga'
	For each Order EmpCod,FilCod,CteCod,CteCarTip
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CtecarIns = 'A'
		delete
	EndFor
EndSub	
			
]]></Source>
