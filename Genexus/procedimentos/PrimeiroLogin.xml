      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 2
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&um = 1
do while &um <= 2
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	&Dorme = sleep(2)
	&um += 1
EndDo


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		//ProgressLogXml = &sdtEstoque.ToXml()
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			//				ProgressLogXml = &sdtEstoque.ToXml()
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub
]]></Source>
