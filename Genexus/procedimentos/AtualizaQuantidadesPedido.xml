      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	if PedSts <> Status_Pedido.ABERTO //or PedStsFin <> status_Financeiro.ABERTO
		return
	Endif


	For Each order EmpCod, FilCod, PedCod, PedItmCod
	
		For &sdtPedidoProdutoItem in &sdtPedidoProduto
			if &sdtPedidoProdutoItem.PeditmCod = PedItmCod
				if &sdtPedidoProdutoItem.PedQtd > 0
					&PedQtd = (PedQtd - &sdtPedidoProdutoItem.PedQtd)
					if &PedQtd < 0
						&PedQtd = 0
					Endif
					&PedQtdCan = PedQtdCan + &PedQtd
					
					gravaItemPedidoVenda.Call(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod, &PedQtd, &PedQtdCan, 0, PedVlrUnt, PedVlrTab, PedItmDsc, PedItmCmp, PedItmVenCod,  PedCodOciRefItm, &Mensagem, &Mensagem, &wwpContextUserName)
				Endif
				Exit
			Endif
		EndFor
	EndFor		
EndFor

	
]]></Source>
