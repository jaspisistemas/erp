      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
InicializaFormasPagamentoPadrao.call(&EmpCod)

For Each ORder EmpCod, FrpPgtoCodNomPadl
	Where EmpCod = &EmpCod
	Where FrpPgtoSts = Status_AtivoInativo.ATIVO
	Where FrpPgtoIsPedVen = &FrpPgtoIsPedVen or FrpPgtoIsPedVen.IsEmpty() or FrpPgtoIsPedVen.IsNull() when not &FrpPgtoIsPedVen.IsEmpty()
	Where FrpPgtoRecPag = 'T' or FrpPgtoRecPag = &FrpPgtoRecPag
	
	if &padFrpPgtoCod.IsEmpty() and FrpPgtoTip = '2' //PADRAO DINHEIRO
		&padFrpPgtoCod = FrpPgtoCod
	EndIf
	
	&IsAcessoConcedido = false
	If FrpPgtoAllFun = true or &TipoPerfil = 3
		&IsAcessoConcedido = true
	Else
		For Each Order EmpCod, FrpPgtoCodNomPadl, FrpPgtoFunCod
			Where FrpPgtoFunCod = &PesCod
			
			&IsAcessoConcedido = true
			Exit
		EndFor		
	EndIF
	
	if &IsAcessoConcedido = true
		&sdtFormasPagamentoItem = new()
		&sdtFormasPagamentoItem.FrpPgtoTip = FrpPgtoTip
		&sdtFormasPagamentoItem.FrpPgtoNom = FrpPgtoNom
		&sdtFormasPagamentoItem.FrpPgtoCodExib = FrpPgtoCodExib
		&sdtFormasPagamentoItem.FrpPgtoCod = FrpPgtoCod
		&sdtFormasPagamento.Add(&sdtFormasPagamentoItem)
	Endif
EndFor
]]></Source>
