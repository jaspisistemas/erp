        <Source><![CDATA[
RetornaVersaoNotas.Call(VersaoNota.VersaoNFSe, &Versao)

RetornaConfiguracoesPastas.Call(&EmpCod, &NfsFilCod, &sdtConfiguracoesPasta)

//If &DeOndeVem = 'WWMANIFESTACAO' or &DeOndeVem = 'WWMANIFESTACAO1'
//	do 'TableManifestacao'
//Else	
//	Do 'TableNota'
	
//	prcCopiaEnvioEnviado.Call(&EmpCod, &NfsFilCod, &NfeCod)
	//CASO JA ESTEJA AUTORIZADO E NAO TENHA O ARQUIVO .XML AUTORIZADO. JDF, nao funcionou
//	if &IsEnviaProcessamento = true
//		if &ModCod = '55'
//			geraXmlNfeModelo55_4.Call(&EmpCod, &NfsFilCod, &NfeCod, 'S', -1, 'P',  &SolCod)
//		Else
//			geraXmlNfeModelo65_4.Call(&EmpCod, &NfsFilCod, &NfeCod, 'S', -1, 'P', &SolCod)
//		Endif
//	Endif
//EndIf

//commit

For Each Order EmpCod, NfsCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NfsCod
	
	if NfsChv.IsEmpty() or NfsChv.IsNull()
		&NFsChv = NfsDpsChv
		&Nome_enviar = &sdtConfiguracoesPasta.PastaNFSenvio.Trim() + trim(&NFsChv) + '-ped-sitnfserps.xml'
	Else
		&NFsChv = NfsChv
		&IsNota = true
		&Nome_enviar = &sdtConfiguracoesPasta.PastaNFSenvio.Trim() + trim(&NFsChv) + '-ped-sitnfse.xml'
	Endif

	// Abrir o arquivo XML
	&ArqNota.Open(&Nome_enviar)
	&ArqNota.WriteStartDocument('UTF-8')
	&ArqNota.Indentation = 0
	
	if &IsNota = true
		&ArqNota.WriteStartElement('NFSe')
		&ArqNota.WriteAttribute('versao',&Versao)
		&ArqNota.WriteAttribute('xmlns','http://www.sped.fazenda.gov.br/nfse')
		
		&ArqNota.WriteElement('infNFSe')
		&ArqNota.WriteAttribute('Id','NFS'+&NFsChv.Trim())
	Else
		&ArqNota.WriteStartElement('DPS')
		&ArqNota.WriteAttribute('versao',&Versao)
		&ArqNota.WriteAttribute('xmlns','http://www.sped.fazenda.gov.br/nfse')
		
		&ArqNota.WriteElement('infDPS')
		&ArqNota.WriteAttribute('Id','DPS'+&NFsChv.Trim())
	Endif
	
	&ArqNota.WriteEndElement()
	&ArqNota.Close()
	
	Exit
EndFor


//If &DeOndeVem = 'WWMANIFESTACAO' or &DeOndeVem = 'WWMANIFESTACAO1'
//	GravaSolicitacao.Call(&EmpCod, &NfsFilCod, &NfeCod, 0, TipoSolicitacao.Consulta_SEFAZ_DFE, &PesCod, &SolCod)
//Else	
if &DeOndeVem <> 'CONSULTA_NFSE_RETORNO'
	GravaSolicitacao.Call(&EmpCod, &NfsFilCod, &NfsCod, 0, TipoSolicitacao.Consulta_NFSE, &PesCod, &SolCod)
EndIf
]]></Source>
