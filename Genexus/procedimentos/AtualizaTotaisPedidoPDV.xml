      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//ATUALIZA TOTAIS DOS ITENS
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where (PedItmCod = &PedItmCod) or (&CapaItem = 'C')	
	
	&PedVlrUntDsc 	= PedVlrUntDsc_FORMULA
	PedVlrUntDsc    = &PedVlrUntDsc
	PedVlrUntComDsc = &PedVlrUntDsc
	PedVlrItm 		= PedVlrItm_FORMULA
	
	&IsAtualizaCusto = false
	If LctAtuSal = Status_EntradaSaida.Saida
		RetornaPrecoUnitarioTipo.call(EmpCod, TabPrmCod, ProCod, ProGraCod, TabColCod, PedDtaEms, PedItmDsc, &PedItmPrm)
		
		//JDF Fazer calcular a comissao so quando for tirar um relatorio de comissao.
		//Melhora performance de uma informacao que nao precisa ter agora.		
		//If PedItmVenCod > 0
		//	retornaComissaoVendedor.call(EmpCod, PedItmVenCod, LctPagCom, LctCod, GrupCom, &PedItmPrm, &TotalFaturadoMoeda, &PedItmCom)
		//Else
		//	retornaComissaoVendedor.call(EmpCod, PedVenCod, LctPagCom, LctCod, GrupCom, &PedItmPrm, &TotalFaturadoMoeda, &PedItmCom)
		//EndIF		
		//If PedRspCod > 0 //Feito por TTS 06/09/18
		//	retornaComissaoVendedor.call(EmpCod, PedRspCod, LctPagCom, LctCod, GrupCom, &PedItmPrm, &TotalFaturadoMoeda, PedItmComRsp)
		//EndIf
		//PedItmCom = &PedItmCom
		
		//Atualiza Desconto total Item.
		&PedItmDsc = 0
		&TotalDescontos = 0
		IF (PedVlrUnt <> PedVlrTab) AND (PedVlrUnt > 0) AND (PedVlrTab > 0)
			&PedItmDsc = (100 - ((PedVlrUnt / PedVlrTab) * 100))
		EndIF
		
		&PedItmDsc += PedItmDsc
		
		if &PedItmDsc >= 0
			verificaDescontoMaximoPedidoItem_percentual.Call(EmpCod, FilCod, PedCod, &VazioWwpContext, PedItmCod, PedItmPrm, PedVlrItm, &PedItmDsc, PedVlrUnt, &TotalDescontos)
		Else
			&TotalDescontos = &PedItmDsc
		Endif
		PedItmDscTot = &TotalDescontos
		
	Else
		&IsAtualizaCusto = true
		&PedItmPrm = domPedItmPrm.NORMAL
	EndIF

	PedItmPrm = &PedItmPrm
	
	commit
EndFor

&RateioAcrescimos = 0
&RateioDescontos = 0

//ATUALIZA TOTAIS DO PEDIDO
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	if PedDtaFat.IsEmpty() or PedDtaFat.IsNull()
		PedDtaFic = PedDtaEms
	Else
		PedDtaFic = PedDtaFat
	EndIF
	
	&PedTotVlrPrm = PedTotVlrPrm_FORMULA
	&PedTotVlrSpm = PedTotVlrSpm_FORMULA
	&PedTotVlrSrv = PedTotVlrSrv_FORMULA
	PedTotVlrPrm = &PedTotVlrPrm
	PedTotVlrSpm = &PedTotVlrSpm
	PedTotVlrSrv = &PedTotVlrSrv
	
	PedVlrDscPrm 	= PedVlrDscPrm_FORMULA	
	PedVlrDscSpm 	= PedVlrDscSpm_FORMULA
	PedVlrDscSrv 	= PedVlrDscSrv_FORMULA		
	PedVlrBrt 		= PedVlrBrt_FORMULA
	
	Commit
	
	&PedVlrLiq		= &PedTotVlrPrm + &PedTotVlrSpm + &PedTotVlrSrv
	&PedVlrFrt 		= PedVlrFrt_FORMULA
	PedVlrLiq 		= PedVlrLiq_FORMULA
	PedVlrFrt		= &PedVlrFrt
	
	commit
	
	&RateioDescontos = PedVlrDscGlb
	&RateioAcrescimos = &PedVlrFrt + PedVlrOut + PedVlrGnre
	Exit
EndFor

//DESCONTOS GERAL
&PedProTaxDscGerItm = 0
if &RateioDescontos > 0 and &PedVlrLiq > 0
	&PedProTaxDscGerItm = round((&RateioDescontos*100)/&PedVlrLiq,2)
EndIF

//ACRESCIMOS GERAL
&PedProTaxAcrGerItm = 0
if &RateioAcrescimos > 0 and &PedVlrLiq > 0
	&PedProTaxAcrGerItm = round((&RateioAcrescimos*100)/&PedVlrLiq,2)
EndIF

If &PedItmCod <> 0 and (&PedProTaxAcrGerItm = 0 and &PedProTaxDscGerItm = 0)
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedItmCod = &PedItmCod
		
		PedVlrUntComDsc = PedVlrUntComDsc_FORMULA
		&PedVlrItmComDsc = PedVlrItmComDsc_FORMULA
		PedVlrItmComDsc = &PedVlrItmComDsc
		
		
		PedProTaxAcrGerItm = &PedProTaxAcrGerItm
		PedProTaxDscGerItm = &PedProTaxDscGerItm
			
		Exit
	EndFor
	
	Commit
	
	if &IsAtualizaCusto = true //Somente pedidos Compra
		For Each Order EmpCod, FilCod, PedCod, PedItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedItmCod = &PedItmCod
			
			PedVlrCus 		= PedVlrCusCmp_FORMULA
			PedVlrCusPrd    = PedVlrCusPrd_FORMULA
			Exit
		EndFor
		commit
	EndIf

	
Else
	AtualizaItemPedidoDescontoTotal.Call( &EmpCod, &FilCod, &PedCod, &PedProTaxDscGerItm, &PedProTaxAcrGerItm, &IsAtualizaCusto)
EndIf
]]></Source>
