      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ContadorLInhas = 0
&Hoje = serverdate()
&TotVencido = 0
&TotDescont = 0
&TotAVencer = 0
&TotCreVlr  = 0
&SdtHistCliente.Clear()
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon161_MesesAtrazoMedio, &Varchar)
&TCon161_MesesAtrazoMedio = val(&Varchar)

if &TCon161_MesesAtrazoMedio > 0
	&TCon161_MesesAtrazoMedio = &TCon161_MesesAtrazoMedio * -1
	&DataBaseAtrazoMedio = &Hoje.Addmonths(&TCon161_MesesAtrazoMedio)
	&TCon161_MesesAtrazoMedio = &TCon161_MesesAtrazoMedio * -1
Else
	&TCon161_MesesAtrazoMedio = 0
Endif


If &IsVinculos = True
	RetornaVinculos.Call(&EmpCod,&CreCliCod,&sdtVinculos)
Else
	&sdtVinculos.Clear()
	&sdtVinculosItem = new()
	&sdtVinculosItem.PesCod = &CreCliCod
	&sdtVinculosItem.PesRaz = &CreCliRaz
	&sdtVinculosItem.PesIsMat = false //iif(pesVinCod = PesCod, true, false) //JDF SEM VINCULOS NAO PRECISA
	&sdtVinculos.Add(&sdtVinculosItem)
EndIF

MediaDiasCompra.Call(&EmpCod, &LogFilCod, &sdtVinculos, &PeriodoCompra)

&collCreCliCod.clear()
For &sdtVinculosItem in &sdtVinculos        
	&collCreCliCod.Add(&sdtVinculosItem.PesCod)
EndFor

&Total = 0
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	where CreSts <> Status_Duplicata.CANCELADA
	Where CreCliCod in &collCreCliCod
	Where CreVlrSdo > 0 when &IsAbertos = true
	&Total += 1
EndFor

&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

For Each 
	Order EmpCod, CreDtaVct when &Ordem = 'C'
	Order EmpCod,(CreDtaVct) when &Ordem = 'D'
	Where EmpCod = &EmpCod
	where CreSts <> Status_Duplicata.CANCELADA
	Where CreCliCod in &collCreCliCod
	Where CreVlrSdo > 0 when &IsAbertos = true
	
	&Calcula += 1
	if &Calcula >= 500
		&Count += &Calcula
		If &Count > 0
			&Percentual = round((&Count / &Total) * 100, 0)
		EndIF
		If &Percentual >= 100
			&Percentual = 99
		EndIf
		do 'Atualiza'
		&Calcula = 0
	EndiF

	do 'limpaVariavel'
	&CreVlrDup = CreVlrDup
	&CreRecPag = CreRecPag
	&CreVlrSdo = CreVlrSdo
	&gridEmpCod		 = EmpCod   
	&gridFilCod		 = FilCod   
	&gridCreCod		 = CreCod   
	&gridCreCliCod   =  CreCliCod
	&gridCreCliRaz   =  CreCliRaz
	&gridCreRecPag   =  CreRecPag
	&gridCreDupNro   =  CreDupNro
	&gridCreVlrDup   =  CreVlrDup
	&gridCreVlrSdo   =  CreVlrSdo
	&gridCreDtaEms   =  CreDtaEms
	&gridCreDtaVct   =  CreDtaVct
	&gridCreCbrCod   =  CreCbrCod
	&gridCreCbrNom   =  CreCbrNom
	&gridCrePedCod   =  CrePedCod
	&gridCreVenCod   =  CreVenCod
	&gridCreDtaCrt   =  CreDtaCrt
	&gridCreDtaPrt   =  CreDtaPrt
	Do Case
		Case (CreCbrImp = TipoImpressao.GerarBoleto)
			&IsBoleto = True
		Case (CreCbrImp = TipoImpressao.ImprimirBoleto) and CreBloNro <> ''
			&IsBoleto = True
		Case CreCbrImp = TipoImpressao.ImprimirDuplicata
			&IsBoleto = True
		Otherwise
			&IsBoleto = False
	EndCase

	&CrePedCod = 0
	&CreDtaVct = CreDtaVct
	
	&CrePedCod = CrePedCod
	&FilCod = FilCod
		
	If CreRecPag = ReceberPagar.Receber
		If &IsAbertos = False
			&TotCreVlr += CreVlrDup
		Else
			&TotCreVlr += CreVlrSdo
		EndIf
		
		Do 'Busca_Valor_Liquido'
		
		If CreVlrSdo > 0 
			Do Case 
				Case CreDtaVct < &Hoje
					&TotVencido += CreVlrSdo  // Total vencido
				Case CreSts = Status_Duplicata.DESCONTADA                     
					&TotDescont += CreVlrSdo   // Total Descontada/Negociada
				Otherwise
					&TotAVencer += CreVlrSdo   // Total a vencer
			EndCase
		EndIf	
	EndIf
	&CreDtaEms = CreDtaEms
	&CreDiaAtr = 0
	&ParcialTotal = 'T'
	
	For Each Order EmpCod,FilCod,CreCod, CrePagCod  
		Where CrePagSts <> Status_Caixa.Cancelado or CrePagSts.IsEmpty() or CrePagSts.IsNull()
		&CrePagDta = CrePagDta
		
		&gridCrePagDta    = &CrePagDta
		&gridCrePagVlrDsc = CrePagVlrDsc
		&gridCrePagVlrJur = CrePagVlrJur                
		&gridCrePagVlr    = CrePagVlr
		
		If &CreRecPag = ReceberPagar.Receber
			
			&CreDiaAtr = (CrePagDta - &CreDtaVct)   // Qtd de Dias em atrazo
				
			if CrePagDta >= &DataBaseAtrazoMedio or &CreDtaVct >= &DataBaseAtrazoMedio or &TCon161_MesesAtrazoMedio.IsEmpty()
				&VlrTotPrzMed += (&CreDiaAtr *  CrePagVlr)		
				&VlrBasPrzMed += CrePagVlr
			Endif
		
			If &CreVlrSdo > 0
				&ParcialTotal = 'P'
			Else
				&ParcialTotal = 'T'
			EndIF
		Else
			&CreDiaAtr = 0 //(&CrePagDta - &CreDtaVct)   // Qtd de Dias em atrazo
		EndIf
		
		&CrePagTotItm += CrePagTotItm
		
		&gridQtdDiaAtz = &CreDiaAtr
		
		If &CreDtaEms >= &DtaIni
			do 'CarregaImpressao'
		Endif
	When none
		If &CreDtaVct < &Hoje and &CreRecPag = ReceberPagar.Receber
			&CreDiaAtr = &Hoje - &CreDtaVct
			if &CreDtaVct >= &DataBaseAtrazoMedio or &TCon161_MesesAtrazoMedio.IsEmpty()
				&VlrTotPrzMed += (&CreDiaAtr *  &CreVlrDup)
				&VlrBasPrzMed += &CreVlrDup
			Endif
		
		Else
			&CreDiaAtr = 0 //(&Hoje - &CreDtaVct)   // Qtd de Dias em atrazo
		EndIf
		
		&gridQtdDiaAtz = &CreDiaAtr
		
		If &CreDtaEms >= &DtaIni
			do 'CarregaImpressao'
		Endif
	EndFor
	
EndFor	

If &VlrTotPrzMed <> 0 and &VlrBasPrzMed <> 0
	&AtzMed = round(&VlrTotPrzMed / &VlrBasPrzMed, 0)
EndIf

//PROTESTOS
&Protesto = 0
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	where CreSts <> Status_Duplicata.CANCELADA
	Where CreCliCod in &collCreCliCod
	Where not CreDtaPrt.IsEmpty()
	&Protesto += 1
EndFor

&sdtHisCliente.Mensagem = &SdtHistCliente.ToJson()
&sdtHisCliente.TotalDuplicataMoeda = &TotCreVlr
&sdtHisCliente.TotalPagamentoMoeda = &CrePagTotItm
&sdtHisCliente.TotalVencerMoeda = &TotAVencer
&sdtHisCliente.TotalDescontoMoeda = &TotDescont
&sdtHisCliente.TotalVencidoMoeda = &TotVencido
&sdtHisCliente.AtrazoMedio = &AtzMed
&sdtHisCliente.ValorMedioMoeda = &ValorMedio
&sdtHisCliente.PeriodoCompra = &PeriodoCompra
&SdtHisCliente.QtdPrt = &Protesto

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &sdtHisCliente.ToXml()
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &sdtHisCliente.ToXml()
		Endnew
	endfor
	
	commit	
EndSub

Sub 'LimpaVariavel'
	&gridEmpCod.SetEmpty()
	&gridFilCod.SetEmpty()
	&gridCreCod.SetEmpty()
	&gridCreCliCod.SetEmpty()
	&gridCreCliRaz.SetEmpty()
	&gridCreRecPag.SetEmpty()
	&gridCreDupNro.SetEmpty()
	&gridCreVlrDup.SetEmpty()
	&gridCreVlrSdo.SetEmpty()
	&gridCreDtaEms.SetEmpty()
	&gridCreDtaVct.SetEmpty()
	&gridCreCbrCod.SetEmpty()
	&gridCreCbrNom.SetEmpty()
	&gridCrePedCod.SetEmpty()
	&gridCreVenCod.SetEmpty()
	&gridCreDtaCrt.SetEmpty()
	&gridCreDtaPrt.SetEmpty()
	&gridCrePagDta.SetEmpty()
	&gridCrePagVlrDsc.SetEmpty()
	&gridCrePagVlrJur.SetEmpty()
	&gridCrePagVlr.SetEmpty()
	&gridQtdDiaAtz.SetEmpty()
	&gridPedVlrLiq.SetEmpty()

EndSub

Sub 'CarregaImpressao'
	If &ContadorLInhas < 2500
		&ContadorLInhas += 1
		
		&SdtHistClienteItem = new()
		&SdtHistClienteItem.EmpCod = &gridEmpCod
		&SdtHistClienteItem.FilCod = &gridFilCod
		&SdtHistClienteItem.CreCod = &gridCreCod
		&SdtHistClienteItem.CreCliCod = &gridCreCliCod
		&SdtHistClienteItem.CreCliRaz = &gridCreCliRaz
		&SdtHistClienteItem.CreRecPag = &gridCreRecPag
		&SdtHistClienteItem.CreDupNro = &gridCreDupNro
		&SdtHistClienteItem.CreVlrDup = &gridCreVlrDup
		&SdtHistClienteItem.CreVlrSdo = &gridCreVlrSdo
		&SdtHistClienteItem.CreDtaEms = &gridCreDtaEms
		&SdtHistClienteItem.CreDtaVct = &gridCreDtaVct
		&SdtHistClienteItem.CreCbrCod = &gridCreCbrCod
		&SdtHistClienteItem.CreCbrNom = &gridCreCbrNom
		&SdtHistClienteItem.CrePedCod = &gridCrePedCod
		&SdtHistClienteItem.CreVenCod = &gridCreVenCod
		&SdtHistClienteItem.CreDtaCrt = &gridCreDtaCrt
		&SdtHistClienteItem.CreDtaPrt = &gridCreDtaPrt
		&SdtHistClienteItem.CrePagDta    = &gridCrePagDta
		&SdtHistClienteItem.CrePagVlrDsc = &gridCrePagVlrDsc
		&SdtHistClienteItem.CrePagVlrJur = &gridCrePagVlrJur  
		&SdtHistClienteItem.CrePagVlr = &gridCrePagVlr
		&SdtHistClienteItem.QtdDiaAtz = &gridQtdDiaAtz
		&SdtHistClienteItem.CrePedVlrLiq = &gridPedVlrLiq
		&SdtHistClienteItem.ParcialTotal = &ParcialTotal
		&SdtHistClienteItem.FilRaz = Substr(trim(&FilRaz), 1, 3)
		&SdtHistClienteItem.Isboleto = &IsBoleto
		&SdtHistClienteItem.CrePagTotItm = ((&SdtHistClienteItem.CrePagVlr - &SdtHistClienteItem.CrePagVlrJur) + &SdtHistClienteItem.CrePagVlrDsc)
		if not &gridPedDtaFat.IsEmpty()
			&SdtHistClienteItem.PedDtaFat = &gridPedDtaFat
		Else
			&SdtHistClienteItem.PedDtaFat = &gridCreDtaEms
		EndIF
		
		&SdtHistCliente.Add(&SdtHistClienteItem)
		
		&gridCreVlrDup.SetEmpty()
		&gridCreVlrSdo.SetEmpty()
	EndiF
EndSub


Sub 'Busca_Valor_Liquido'
	&gridPedVlrLiq = 0
	&gridPedDtaFat.SetEmpty()
	
	 For Each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
	    Where FilCod = &FilCod
	    Where PedCod = &CrePedCod
		
		&gridPedVlrLiq = PedVlrLiq
		&gridPedDtaFat = PedDtaFat
		&IsAchou = false
		For &sdtPedidositem in &sdtPedidos
			If &sdtPedidositem.PedCod = &CrePedCod
				&IsAchou = true
				Exit
			EndIF
		EndFor
		
		if &IsAchou = false
			&TotPedVlrLiq += PedVlrLiq
			
			&sdtPedidositem = new()
			&sdtPedidositem.PedCod = PedCod
			&sdtPedidos.Add(&sdtPedidositem)
		EndIF
		Exit
	EndFor
	
	&FilRaz = RetornaNomeFilialNota_3.Udp(&CrePedCod, &FilCod, &EmpCod)
	
	If &sdtPedidos.Count
		&ValorMedio = &TotPedVlrLiq / &sdtPedidos.Count
	EndIf
EndSub
]]></Source>
