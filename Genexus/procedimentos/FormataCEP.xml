      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SoNumeros = retornaSoNumeros.Udp(&CEPentrada)
&CEPFormatado = ''
Do CAse
	CAse &SoNumeros.Length() >= 8
		&CEPFormatado = substr(&SoNumeros,1,5) + '-' + substr(&SoNumeros,6,3)
	Case &SoNumeros.Length() <= 8 and not &SoNumeros.IsEmpty()
		&SoNumeros = &SoNumeros.Padright(8, '0')
		&CEPFormatado = substr(&SoNumeros,1,5) + '-' + substr(&SoNumeros,6,3)
EndCase
]]></Source>
