        <Source><![CDATA[

//A4 - IMPRESSÃO RECIBO CARTAO (WWDUPLICATASCARTAO)
MB 4
MT 2
Do 'Filial'
Do 'Cartao'
Print Cabecalho
Print Rodape
Print Tesoura

//############### SUBS ##################\\

Sub 'Cartao'
	
	For each order EmpCod,FilCod,CreCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where CreCod = &CreCod
		where CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
		where CreRecPag = ReceberPagar.Receber
		where CreSts <> Status_Duplicata.CANCELADA
		&CreCarBanNom = CreCarBanNom.ToUpper()
		&CreCarCreDeb = CreCarCreDeb
		&CreVlrDup = CreVlrDup
		&CreDtaVct = CreDtaVct
		&CreDtaEms = CreDtaEms
		&CreCarCreDeb = CreCarCreDeb
		&CreCliCodRaz = CreCliCodRaz
		&CpfCnpj = iif(CreCliTip = 'J', CreCliCnpj,CreCliCpf)
		if &CreCarBanNom.IsEmpty()
			&CreCarBanNom = 'NÃO INFORMADO'
		EndIf
		
		if &CreCarCreDeb = 1
			&CreditoDebito = ' DÉBITO'
		else //0 = Crédito
			&CreditoDebito = ' CRÉDITO'
		EndIf
		
		exit
	EndFor

EndSub

Sub 'Filial'
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilFan    = FilFan.Trim().ToUpper()
		&FilLogNro = FilLogNro.Trim()
		&FilLogNro += ' '+FilBai.Trim() 
		&FilCepCidUfe = FilCepCidUfe.Trim()
		&FilDes = FilCpj.Trim() +'/'+ FilFonNum.Trim()
		&FilCidNom = FilCidNom.Trim()
		&FilCpj = FilCpj.Trim()
		If FilImg_LogRel.IsEmpty()
			&Image.FromImage('FilialSemImagem')  
		Else
			&Image = FilImg_LogRel
		EndIF
		&Operador = &FilFan
		Exit
	EndFor
	
EndSub
]]></Source>
