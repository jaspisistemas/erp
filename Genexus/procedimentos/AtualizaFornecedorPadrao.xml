      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//ATUALIZA FORNECEDOR PADRAO.
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod when &ProCod > 0
	Where ProPadForCod = &ProPadForCod
	
	&AuxProCod = ProCod
	do 'GetMenorPrecoFornecedor'
	ProPadForCod = &NovoProForCod 
EndFor

Commit


Sub 'GetMenorPrecoFornecedor'
	For Each Order EmpCod,ProCod,ProForVlrCusTot
		Where EmpCod = &EmpCod
		Where ProCod = &AuxProCod
		
		&NovoProForCod = ProForCod
		Exit
	EndFor

EndSub
]]></Source>
