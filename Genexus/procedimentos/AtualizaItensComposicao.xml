      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsPrimeira = true
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCodRef = &PedItmCod and (PedItmCod <> &ExcetoPedItmCod)
	
	if &IsPrimeira = true
		GravaItemPedidoVenda.Call(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod, &NewPrimeiraPedQtd, 0, 0, PedVlrUnt, PedVlrTab, PedItmDsc, PedItmCmp, PedItmVenCod, &PedItmCod,  &InsereMensagem, &AlteraMensagem, &wwpContextUserName)
	Else
		GravaItemPedidoVenda.Call(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod, &NewPedQtd, 0, 0, PedVlrUnt, PedVlrTab, PedItmDsc, PedItmCmp, PedItmVenCod, &PedItmCod,  &InsereMensagem, &AlteraMensagem, &wwpContextUserName)
	Endif
	&IsPrimeira = false
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
