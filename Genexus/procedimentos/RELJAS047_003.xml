      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[MT 0
MB 0

If &PedCod <> 0
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PesRaz = substr(PedCliRaz,1,40)
		&PesCidNom = PedCliEntUfeCod.Trim() +  ' - ' + trim(PedCliEntCidNom)
		
		&Nota = ''
		If &NfeNUm <> 0
			&Nota = PadL(trim(str(&NfeNUm)),8, '0')
			&PedidoNota =  trim(&Nota) 
		Else
			&Nota = '        '
			&PedidoNota = ''
		EndIf	
		
		//TRANPORTADORA 
		&PedTraSaiRaz = PedTraSaiRaz.Trim()
		&PedTraRedRaz = PedTraRedRaz.Trim()
		Exit
	EndFor
Else
	//CLIENTE
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod	
		&PesRaz = substr(PesRaz,1,40)
		&PesCidNom = PesEntUfeCod.Trim() +  ' - ' + trim(PesEntCidNom)
		
		Exit
	EndFor
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedTraSaiCod
		&Nota = ''
		If &NfeNUm <> 0
			&Nota = PadL(trim(str(&NfeNUm)),8, '0')
			&PedidoNota = trim(&Nota) 
		Else
			&Nota = '        '
			&PedidoNota = ''
		EndIf
		&PedTraSaiRaz = PesRaz.Trim()
		Exit
	EndFor

	Do 'Redespacho'
EndIF


//VOLUME
&FinDigitos = trim(Str(&FinPedQtdVol))
&QtdDigitos = &FinDigitos.Length()
If &QtdDigitos = 1
	&QtdDigitos = 2
EndIF


&Etiqueta = &FinPedQtdVol
Do While &Etiqueta >= &IniPedQtdVol
	
	&Volume = padL(trim(str(&Etiqueta)), &QtdDigitos, '0') + '/' + padL(trim(Str(&FinPedQtdVol)), &QtdDigitos, '0')
	print EtiquetaModelo1opcaoA
	&Etiqueta -= 1
EndDo


Sub 'Redespacho'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedTraRedCod
		&PedTraRedRaz = PesRaz.Trim()
		Exit
	EndFor
EndSub
]]></Source>
