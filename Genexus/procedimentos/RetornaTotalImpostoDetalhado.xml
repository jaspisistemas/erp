      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ImpostoCadastrado = false

if &IsNotas = false
	do 'CalculaValorUnitarioTotal'
	&tmpProCod = &ProCod
	do 'tabImposto'
	
	&sdtImpostoProduto = new()
	&sdtImpostoProduto.ProBasVlrIcm = &PedVlrItm
	&sdtImpostoProduto.ProBasVlrIcmSt = &PedVlrItm
	&sdtImpostoProduto.ProBasVlrIpi = &PedVlrItm
	&sdtImpostoProduto.ProBasPis = &PedVlrItm
	&sdtImpostoProduto.ProBasCofins = &PedVlrItm
	&sdtImpostoProduto.ValorTotalProduto = &PedVlrItm // TOTAL PRODUTO 
	
	CalculaImposto_IBSCBS.Call(&sdtCadastroTabelaImpostoCbs, &sdtImpostoProduto)
	if &sdtCadastroTabelaImpostoCbs.CImpIcmsMotDes <> '' and &sdtImpostoProduto.ProVlrIcm > 0
		&sdtImpostoProduto.ProVlrIcm = &sdtImpostoProduto.ProVlrIcm*-1
	Endif
	
Else
	&ImpostoCadastrado = true
	For Each Order EmpCod, NfeFilCod, NfePedCod,NfeProCod,NfeProTer
		Where EmpCod = &EmpCod
		Where NfeFilCod = &FilCod
		Where NfePedCod = &PedCod
		Where NfeProCod = &ProCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts in (Status_NFe.Autorizada,Status_NFe.Digitando)
		&sdtImpostoProduto.ProVlrIpi = NfeProVlrIpi
		&sdtImpostoProduto.ProVlrIcmSt = NfeProVlrImcsSt
		&sdtImpostoProduto.ProVlrFCPIcmsSt = NfeProVlrFCPIcmsSt
	EndFor
EndIF


//futuramente fazer retornar o sdt
&ImpAlqIcmInt = &sdtCadastroTabelaImpostoCbs.CImpAlqIcmInt
&impIPI = &sdtCadastroTabelaImpostoCbs.CImpIPI
&ImpAlqIcmExt = &sdtCadastroTabelaImpostoCbs.CImpAlqIcmExt
&tmpProVlrIcm = &sdtImpostoProduto.ProVlrIcm
&tmpProVlrIpi = &sdtImpostoProduto.ProVlrIpi
&tmpProVlrIcmSt = &sdtImpostoProduto.ProVlrIcmSt
&tmpProVlrFCPIcmsSt = &sdtImpostoProduto.ProVlrFCPIcmsSt
&tmpProVlrCOFINS = &sdtImpostoProduto.ProVlrCOFINS
&tmpProVlrPIS = &sdtImpostoProduto.ProVlrPIS


Sub 'CalculaValorUnitarioTotal'
	&tmpPedVlrUntNov = &PedVlrUnt
	
	If &PedTpcVlr > 0
		&tmpPedVlrUntNov = &tmpPedVlrUntNov - round(((&tmpPedVlrUntNov * &PedTpcVlr) / 100), 5)
	EndIF
	&PedVlrItm = Round(&tmpPedVlrUntNov * &Pedqtd, 2)
EndSub

sub 'tabImposto'
	
	RetornaRegimeTributarioFilial.Call(&EmpCod, &FilBasImp, &FilRegTrib, &CImpOriUfeCod)
	&sdtCadastroTabelaImpostoCbs = new()
	&sdtCadastroTabelaImpostoCbs.EmpCod = &EmpCod
	&sdtCadastroTabelaImpostoCbs.CImpTbFilCod = &FilBasImp
	&sdtCadastroTabelaImpostoCbs.CImpLctCod = &LctBasImpCod
	&sdtCadastroTabelaImpostoCbs.CImpOriUfeCod = &CImpOriUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpDstUfeCod = &PedCliCidUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpGruImpCod = &PedCliGruImpCod
	&sdtCadastroTabelaImpostoCbs.CImpCatCod = &ImpCatCod
	&sdtCadastroTabelaImpostoCbs.CImpDtaIni = serverdate()
	&sdtCadastroTabelaImpostoCbs.ProCod = &tmpProCod
	prcRetornaConfiguracaoImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs)
	
	if &sdtCadastroTabelaImpostoCbs.sts = 'S'
		&ImpostoCadastrado = true
	Endif
EndSub

]]></Source>
