      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &CteEveCod = 0
	For Each Order EmpCod, FilCod, CteCod, (CteEveCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		&auxCteEveCod = &CteEveCod
		exit
	EndFor
	&auxCteEveCod += 1
	
	do 'newEvento'
	
	For &StdComprovanteCteItem in &StdComprovanteCte
		&CteEveChv = &StdComprovanteCteItem.CteEveChv
		do 'NewEventDoc'
	EndFor
Else
	
EndIf

Sub 'newEvento'
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteEveCod = &auxCteEveCod
		CteEveDoc = &CteEveDoc
		CteEveNom = &CteEveNom
		CteEveDtaEnt = &CteEveDtaEnt
		CteEveGeo = &CteEveGeo
		CteEveSts = Status_Nfe.Digitando
		CteEveMotivo = &CteEveMotivo
	EndNew
	
	Commit
	
EndSub

Sub 'NewEventDoc'
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CteEveCod = &auxCteEveCod
		CteEveChv = &CteEveChv
	EndNew
	Commit
EndSub
]]></Source>
