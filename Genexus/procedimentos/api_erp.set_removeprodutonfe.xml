      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	&EmpCod = &wwpContext.EmpCod
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		If NfeSts <> Status_NFe.Digitando and NfeProTer = Nota_ProPriaTerceira.PROPRIA
			&sdtRetornowbs.Sts = 'E006'
			&sdtRetornowbs.Obs = 'NFe já não esta em modo de digitação, não é possível alterar produtos'
			Return
		Endif
		
		Exit
	When none
		&sdtRetornowbs.Sts = 'E007'
		&sdtRetornowbs.Obs = 'NFe não localizada'
		Return
	EndFor

	RemoveItemNf.Call(&EmpCod, &FilCod, &NfeCod, &NfeItmCod)
	&sdtRetornowbs.Sts = 'J200'
	&sdtRetornowbs.Obs = 'Item removido com sucesso!'
Endif

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
