if &PesCod.IsEmpty() //INSERT
	//QUando insert inserido os campos no proprio processo de gravar.
Else
	For Each order EmpCod, PesCod, PesEmlCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&IdVarchar = trim(str(PesEmlCod))
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesEml', trim(PesEml), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesEmlFat', trim(PesEmlFat.ToString()), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesEmlFin', trim(PesEmlFin.ToString()), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesEmlPed', trim(PesEmlPed.ToString()), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesEmlCht', trim(PesEmlCht), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesEmlCon', trim(PesEmlCon), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PesEmlDtaNas', trim(PesEmlDtaNas.ToFormattedString()), '', &sdtLogAtributosLevel)
		
	EndFor
Endif


