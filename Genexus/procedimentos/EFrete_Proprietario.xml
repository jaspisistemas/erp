      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	//###############################################################   Parametros Para Gravar
	&ProprietariosServiceGravarRequest.Integrador = Trim(&FilFrtHash)
	&ProprietariosServiceGravarRequest.Token = trim(&Token)
	&ProprietariosServiceGravarRequest.Versao = 3
	Do 'GetProprietario'
	//#######################################################################################
	
	Do 'GravarProprietario'

Sub 'GetProprietario'
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		If PesTip = TipoPessoa.FISICA
			&ProprietariosServiceGravarRequest.CNPJ = val(RetornaSoNumeros.Udp(PesCpf))
			&ProprietariosServiceGravarRequest.TipoPessoa = ProprietariosServiceTipoPessoa.Fisica
		Else
			&ProprietariosServiceGravarRequest.CNPJ = val(RetornaSoNumeros.Udp(PesCnpj))
			&ProprietariosServiceGravarRequest.TipoPessoa = ProprietariosServiceTipoPessoa.Juridica
		EndIf
		
		&ProprietariosServiceGravarRequest.Endereco.Bairro = trim(PesBai)
		&ProprietariosServiceGravarRequest.Endereco.CEP = trim(PesCep)
		&ProprietariosServiceGravarRequest.Endereco.CodigoMunicipio = PesCidIBGE
		&ProprietariosServiceGravarRequest.Endereco.Rua = trim(PesLog)
		&ProprietariosServiceGravarRequest.Endereco.Numero = trim(PesNro)
		&ProprietariosServiceGravarRequest.Endereco.Complemento = trim(PesCpl)
		&ProprietariosServiceGravarRequest.RazaoSocial = trim(PesRaz)
		&ProprietariosServiceGravarRequest.RNTRC = val(PesRntrc)
		
		For each Order EmpCod,PesCod
			Do case
				Case PesFonTpo = TipoTelefone.CELULAR
					&ProprietariosServiceGravarRequest.Telefones.Celular.DDD = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),1,2))
					&ProprietariosServiceGravarRequest.Telefones.Celular.Numero = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),3,20))
				Case PesFonTpo = TipoTelefone.COMERCIAL
					&ProprietariosServiceGravarRequest.Telefones.Fixo.DDD = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),1,2))
					&ProprietariosServiceGravarRequest.Telefones.Fixo.Numero = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),3,20)) 
			EndCase
		EndFor
		exit
	EndFor
EndSub


Sub 'GravarProprietario'
//	HostWebServiceEfrete.Call(&EmpWebHost, &EmpWebBaseUrl, &EmpWebPor,&IsSecure)
	&Location = GetLocation('ProprietariosService') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost 	     //servidor 
	&Location.Port = &EmpWebPor 	//porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	If &IsSecure = true
		&Location.Secure = 1
	ELSE
		&Location.Secure = 0 //false 
	EndIf		       //false 
	&Location.CancelOnError = 2 	   //tratar exceção do WS 	
	csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.SecurityProtocolType.Tls11 | System.Net.SecurityProtocolType.Tls;
	&ProprietariosServiceGravarResponse = &ProprietariosService.Gravar(&ProprietariosServiceGravarRequest)
	
	padraoUsuario.Call('G', '#EFRETEPROPRIETARIO', &Context.PesCod, &Context.EmpCod, &ProprietariosServiceGravarRequest.ToXml(), &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
	padraoUsuario.Call('G', '#EFRETEPROPRIETARIORESPOSTA', &Context.PesCod, &Context.EmpCod, &ProprietariosServiceGravarResponse.ToXml(), &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
	
	If GetSOAPErr() = 0 // Resposta do Obter proprietario
		If &ProprietariosServiceGravarResponse.Sucesso = True
			&Mensg = 'Gravado com Sucesso '+ &ProprietariosServiceGravarResponse.Excecao.Mensagem
			Do 'AtualisaProprietario'
		Else
			&Mensg = &ProprietariosServiceGravarResponse.Excecao.Mensagem
		EndIf
	Else 
		&Erro = val(str(GetSOAPErr()))
		&Mensg += 'DESC. ERRO:'+GetSOAPErrMsg() 
	EndIf
EndSub

Sub 'AtualisaProprietario'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		PesStsEfr = Status_EFrete.Homologado
		Exit
	EndFor
EndSub
]]></Source>
