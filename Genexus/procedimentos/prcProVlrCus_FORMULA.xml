      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do Case
	CAse &ProTipCus = TipoCusto.Receita
		&ProVlrCus = RetornaCustoReceita.udp(&EmpCod, &ProCod) 
	Case &ProTipCus = TipoCusto.MenorPreco
		&ProVlrCus = MenorCustoFornecedor.udp(&EmpCod, &ProCod) 
	Case &ProTipCus = TipoCusto.UltimaCompra
		&ProVlrCus = RetornaCustoUltimaCompra.udp(&EmpCod, &ProCod) 
	Case &ProTipCus = TipoCusto.CustoMedio
		&ProVlrCus = RetornaCustoMedio.udp(&EmpCod, 1, &ProCod) 
	Case &ProTipCus = TipoCusto.CustoFixo
		&ProVlrCus = RetornaCustoFixo.udp(&EmpCod, &ProCod) 
	Case &ProTipCus = TipoCusto.FornecedorPadrao
		&ProVlrCus = RetornaCustoFornecedorPadrao.udp(&EmpCod, &ProCod, &ProPadForCod) 
	Case &ProTipCus = TipoCusto.CustoProdutoEstoque
		&ProVlrCus = RetornaCustoProdutoEstoque.udp(&EmpCod, &ProEstProCod) 
EndCAse

]]></Source>
