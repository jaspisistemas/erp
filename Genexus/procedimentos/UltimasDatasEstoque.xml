      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//ULTIMA COMPRA
For Each Order EmpCod, FilCod, PedSts, ProCod, (PedDtaFat)
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PedSts = Status_Pedido.FECHADO
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGracod > 1
	Where LctTip = TipoLancamento.EntradaMercadoria
	Where LctAtuEst = Status_EntradaSaida.Entrada
	Where PedQtd > 0
	&EstUltEnt = PedDtaFat
	Exit
EndFor

//ULTIMA VENDA
For Each Order EmpCod, FilCod, PedSts, ProCod,  (PedDtaFat)
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PedSts = Status_Pedido.FECHADO
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGracod > 1
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where LctAtuEst = Status_EntradaSaida.Saida
	Where PedQtd > 0
	&EstUltSai = PedDtaFat
	Exit
EndFor

//ULTIMA ENTRADA PRODUCAO
For Each Order EmpCod, FilCod, PedSts, ProCod,  (PedDtaFat)
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PedSts = Status_Pedido.FECHADO
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGracod > 1
	//Where LctTip = TipoLancamento.MovimentacaoValores
	Where LctAtuEst = Status_EntradaSaida.Entrada
	Where LctAtuPro = Status_EntradaSaida.Saida
	Where PedQtd > 0
	&EstUltFab = PedDtaFat
	Exit
EndFor
]]></Source>
