      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Count = 0
&SalFamVlr = 0
&AuxSalFamVlr = 0
For each Order EmpCod,PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	&PesHerIda = age(PesHerDtaNas,ServerDate())

	If &PesHerIda < 14   // Ate 14 é idade que o filho recebe Salário Familia
		&Count += 1            // Quantidade de Filhos Menor de 14 Anos
	EndIf
EndFor

For each Order EmpCod,SalFamIni,SalFamFin
	Where EmpCod = &EmpCod
	Where SalFamIni <= &PesVlrSalCat and  SalFamFin >= &PesVlrSalCat 
	&AuxSalFamVlr = SalFamVlr   // Faixa Salarial quente
	Exit
EndFor

If &Count > 0 and &AuxSalFamVlr > 0
	&SalFamVlr = (&Count * &AuxSalFamVlr)
Endif
]]></Source>
