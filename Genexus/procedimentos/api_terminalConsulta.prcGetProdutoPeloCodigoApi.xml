      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &TermRandCom.IsEmpty()
	&ProNom = '#JASPIENCERRAR#' //ENCERRA E DESLOGA CASO INATIVADO
	//Return
EndIf

//PRIMEIRO LOCALIZA TERMINAL
For Each Order EmpCod, TermCod
	Where EmpCod = &EmPCod
	Where TermRandCom = &TermRandCom 
	
	if TermSts = status_AtivoInativo.INATIVO
		&ProNom = '#JASPIENCERRAR#' //ENCERRA E DESLOGA CASO INATIVADO
		//Return
	Endif
	
	TermUltDtaHor = now()
	Exit
When none
	&ProNom = '#CETADOIDO#' //NAO ENCERRAR
	
	&sdtDadosProduto.ProNom = &ProNom	
	Return
EndFor

Commit


if not &ProGraBar.IsEmpty() and not &ProNom = '#JASPIENCERRAR#'
	//RETORNA TABELA PADRAO DA FILIAL
	RetornaTabelaColunaFilial_BuscaPreco.Call(&EmPCod, 1, &TabCod, &tabPrmCod, &TabColCod)
	
	For Each Order EmpCod, ProBarRef //PEGA PRODUTO 
		Where EmpCod = &EmpCod
		Where ProBarRef = &ProGraBar
		where ProSts = Status_AtivoInativo.ATIVO
		Where ProBarTip <> 'R' //DIFERENTE DE REFERENCIA
		
		&ProCod = ProCod
		&ProNom = ProNomGra
		
		//PEGA VALOR DE VENDA
		RetornaPrecoUnitarioVenda_BuscaPreco.Call(EmpCod, &TabCod, &tabPrmCod, ProCod, ProGraCod, &TabColCod, ServerDate(), &TabPrc1, &PedItmPrm)
		&ValorVenda = trim(toformattedString(&TabPrc1))
		if &PedItmPrm = domPedItmPrm.PROMOCAO
			&IsPromocao = true
		Endif
		
		do 'GetImagem'
		
		
		//EMBALAGEM DE CAIXA
		&EmbalagemComUnidades = ''
		if &TabPrc1 > 0 and ProEtqEmbQtd > 0
			&CaixaMoeda = &TabPrc1 * ProEtqEmbQtd
			&ProEtqEmbVarchar = trim(toformattedString(ProEtqEmbQtd))
			RetiraZerosDepoisVirgulaxCasas.Call(0, &ProEtqEmbVarchar, &ProEtqEmbVarchar)
			Do CAse
				CAse ProEtqEmbRef = 'A' //CAIXA C/ X UNIDADES
					&EmbalagemComUnidades = FORMAT('CAIXA COM %1 UNIDADES', trim(toformattedString(&ProEtqEmbVarchar)))
					
				CAse ProEtqEmbRef = 'B'//FARDO C/ X UNIDADES
					&EmbalagemComUnidades = FORMAT('FARDO COM %1 UNIDADES', trim(toformattedString(&ProEtqEmbVarchar)))
					
				CAse ProEtqEmbRef = 'C'//PACOTEC/ X UNIDADES
					&EmbalagemComUnidades = FORMAT('PACOTE COM %1 UNIDADES', trim(toformattedString(&ProEtqEmbVarchar)))
			EndCAse
		Endif
		
		&DescricaoCaixa = &EmbalagemComUnidades
		&ValorCaixa = trim(toformattedString(&CaixaMoeda))
		Exit
	When None
		&ProNom = '#NAOENCONTRADO#'
	EndFor
	
Endif


&sdtDadosProduto.ProNom = &ProNom
&sdtDadosProduto.ProVlr = &ValorVenda
&sdtDadosProduto.ProCxNom = &DescricaoCaixa
&sdtDadosProduto.ProCxVlr = &ValorCaixa
&sdtDadosProduto.ProImg = &CAminhoImagem
&sdtDadosProduto.IsProm = &IsPromocao


Sub 'GetImagem'
	For Each Order EmpCod,ProCod,ProImgCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProImgPri = true
		
		&ProImg1024 = ProImg325
		&CAminhoImagem = ProImg325.ImageURI
		Exit
	EndFor
EndSub

]]></Source>
