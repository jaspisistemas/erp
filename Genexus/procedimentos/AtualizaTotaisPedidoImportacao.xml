      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[	
//ATUALIZA TOTAIS DOS ITENS
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where (PedItmCod = &PedItmCod) or (&CapaItem = 'C')
	
	PedVlrUntDsc = PedVlrUntDsc_FORMULA
	PedVlrItm = PedVlrItm_FORMULA
	
	commit
EndFor

commit

//ATUALIZA TOTAIS DO PEDIDO
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod

	&PedTotVlrPrm = PedTotVlrPrm_FORMULA
	&PedTotVlrSpm = PedTotVlrSpm_FORMULA
	&PedTotVlrSrv = PedTotVlrSrv_FORMULA
	PedTotVlrPrm = &PedTotVlrPrm
	PedTotVlrSpm = &PedTotVlrSpm
	PedTotVlrSrv = &PedTotVlrSrv
	
	PedVlrDscPrm = PedVlrDscPrm_FORMULA	
	PedVlrDscSpm = PedVlrDscSpm_FORMULA
	PedVlrDscSrv = PedVlrDscSrv_FORMULA
	
	PedVlrLiq = PedVlrLiq_FORMULA
	PedVlrBrt = PedVlrBrt_FORMULA
	
	Commit 
	
	&PedVlrBrt = &PedTotVlrPrm + &PedTotVlrSpm + &PedTotVlrSrv
	&RateioDescontos = PedVlrDscGlb
	&RateioAcrescimos = PedVlrFrt + PedVlrOut + PedVlrGnre

	Exit
EndFor

commit

//DESCONTOS GERAL
&PedProTaxDscGerItm = 0
if &RateioDescontos > 0 and &PedVlrBrt > 0
	&PedProTaxDscGerItm = round((&RateioDescontos*100)/&PedVlrBrt,2)
EndIF

//ACRESCIMOS GERAL
&PedProTaxAcrGerItm = 0
if &RateioAcrescimos > 0 and &PedVlrBrt > 0
	&PedProTaxAcrGerItm = round((&RateioAcrescimos*100)/&PedVlrBrt,2)
EndIF

AtualizaItemPedidoDescontoTotal.Call(&EmpCod, &FilCod, &PedCod, &PedProTaxDscGerItm, &PedProTaxAcrGerItm, true)
PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &PedCod)
]]></Source>
