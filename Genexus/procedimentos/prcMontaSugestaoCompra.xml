      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//cancela todos os produtos e cancela pedido
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	DeletaItemPedidoCompra.Call(EmpCod, FilCod, PedCod, 0)
	
	PedSts = Status_Pedido.CANCELADO //jdf muda para cancelado pois em baixo tem o abre estoque.
	PedStsFin = Status_Financeiro.CANCELADO
EndFor

Commit

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&PedCliCod = PedCliCod
    
    exit
Endfor

&Count = 0
For Each Order EmpCod, ProForCod, ProSts, ProCod
	Where EmpCod = &EmpCod
	Where ProForCod = &PedCliCod
	Where ProSts = Status_Produto.ATIVO
	Where ProTipDef in (Definicao.MATERIAPRIMA,Definicao.REVENDA, Definicao.SUBPRODUTO)
	Where ProTipCus <> TipoCusto.Receita
	
	&ProCod = ProCod
	&ProGraCod = 1
	&ProForQtdEmb = ProForQtdEmb
	
	Do 'BuscaEstoque'
	
	If &EstFab > 0
		&Count += 1
		Do CAse
			Case &ProForQtdEmb < 0
				&PedQtdEmb = (&EstFab / &ProForQtdEmb) * -1
			Case &ProForQtdEmb > 0                    
				&PedQtdEmb = (&EstFab * &ProForQtdEmb)
			Otherwise
				&PedQtdEmb = &EstFab
		EndCase
		
		&PedQtdEmb = round(&PedQtdEmb,0)
		
		Do case
			CAse &ProForQtdEmb < 0
				&PedQtd = (&PedQtdEmb * &ProForQtdEmb) * -1
			CAse &ProForQtdEmb > 0                    
				&PedQtd = (&PedQtdEmb / &ProForQtdEmb) 
			Otherwise
				&PedQtd = &EstFab
		EndCase
		
		RetornaCustoFornecedor.Call(&EmpCod, &PedCliCod, &ProCod, &PedItmIcmSt, &PedItmIcmStPob, &PedItmIcm, &PedItmIpi, &PedItmAcr, &PedItmDsc, &ProForRatDsc,  &ProForRatAcr, &PedVlrUnt, &MensagemProdutoUnitario)
		
		&sdtAddPedidoProduto = new()			
		&sdtAddPedidoProduto.PedItmAcr = &PedItmAcr
		&sdtAddPedidoProduto.PedItmDsc = &PedItmDsc
		&sdtAddPedidoProduto.PedItmIpi = &PedItmIpi
		&sdtAddPedidoProduto.PedItmIcmSt = &PedItmIcmSt
		&sdtAddPedidoProduto.PedItmIcmStPob = &PedItmIcmStPob
		&sdtAddPedidoProduto.PedItmIcm = &PedItmIcm
		&sdtAddPedidoProduto.PedQtdEmb = &PedQtdEmb
		&sdtAddPedidoProduto.PedProEmbQtd = &ProForQtdEmb
		&sdtAddPedidoProduto.PedItmCmp = &PedItmCmp
		&sdtAddPedidoProduto.PedItmAjuIpiBas = &PedItmAjuIpiBas
		&sdtAddPedidoProduto.PedItmAjuIcmBas = &PedItmAjuIcmBas
		&sdtAddPedidoProduto.PedItmAjuIcmStBas = &PedItmAjuIcmStBas
		&sdtAddPedidoProduto.PedItmAjuPisBas = &PedItmAjuPisBas
		&sdtAddPedidoProduto.PedItmPis = &PedItmPis
		&sdtAddPedidoProduto.PedItmCofins = &PedItmCofins
		
		&sdtAddPedidoProduto.PedItmAjuIcmVlr = &PedItmAjuIcmVlr
		&sdtAddPedidoProduto.PedItmAjuCofinsVlr  = &PedItmAjuCofinsVlr
		&sdtAddPedidoProduto.PedItmAjuIcmsStPobVlr  = &PedItmAjuIcmsStPobVlr
		&sdtAddPedidoProduto.PedItmAjuIcmStVlr  = &PedItmAjuIcmStVlr
		&sdtAddPedidoProduto.PedItmAjuIpiVlr  = &PedItmAjuIpiVlr 
		&sdtAddPedidoProduto.PedItmAjuPisVlr  = &PedItmAjuPisVlr
		
		GravaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, 0, &ProCod, &ProGraCod, &PedQtd, &PedVlrUnt, &sdtAddPedidoProduto, &sdtProdutoLote, &inseridoMensagem, &AlteradoMensagem, &WwpContextUserName, 'N')
	EndIF		
EndFor

//AtualizaTotais Pedido
AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')
AtualizaEstoqueGerencialCompra.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &EmpCod,  Status_Pedido.ABERTO)

&mensagem = 'Trabalho realizado, Adicionado (' + trim(Str(&Count)) + ') produtos.'

Sub 'BuscaEstoque'
    &EstCom = 0
    &EstVen = 0 
    &EstSdo = 0
    &EstFab = 0

    For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
    Where FilCod = &FilCod
    Where ProCod = &ProCod
	Where ProGraCod = &ProGracod
	
		&EstCom = EstCom
		&EstVen = EstVen
		If &ConsiderarPedidosAbertos = 'S'
			&EstSdo = EstSdo
		Else
			&EstSdo = EstQtd
		EndIf
			
		&EstFab = EstMin
		
		Exit
    EndFor

    &EstFab = &EstFab - &EstSdo
    &EstFab = round(&EstFab+0.49,0)
EndSub
]]></Source>
