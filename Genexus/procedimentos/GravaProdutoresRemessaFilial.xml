      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TotPedAssNfeVlr = 0
&IsFirst = false

For each Order EmpCod,AssFilCod
	Where EmpCod = &EmpCod
	Where AssFilCod = &AssFilCod
	&PesCod = PesCod
	&AssVlrCot = AssVlrCot
	
	If &IsFirst = false
		&FirstPesCod = PesCod
		&IsFirst = True
	EndIf

	If AssVlrCot > 0 and &TotAssVlrCot > 0
		&PerAssVlrCot = ((AssVlrCot *100) / &TotAssVlrCot ) /100
	Else
		&PerAssVlrCot = 0
	EndIf

	Do 'NewPedassociado'
EndFor
Commit

&SobraPedAssNfeVlr = 0
&SobraPedAssNfeVlr = (&PedVlrLiq - &TotPedAssNfeVlr)
Do 'Sobra'

Sub 'Sobra'
	For Each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedAssPesCod = &FirstPesCod
		PedAssNfeVlr += &SobraPedAssNfeVlr
		Exit
	EndFor
EndSub	
	
Sub 'NewPedassociado'
	For Each Order EmpCod,FilCod,PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedAssPesCod = &PesCod
		
		PedAssPesCod = &PesCod
		PedAssPesCot = &AssVlrCot
		PedAssNfeVlr = &PedVlrLiq * &PerAssVlrCot
		&TotPedAssNfeVlr += &PedVlrLiq * &PerAssVlrCot
		exit
	When none
		&PedAssCod = 0
		For Each Order EmpCod,FilCod,PedCod,(PedAssCod)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			&PedAssCod = PedAssCod
			Exit
		EndFor
		&PedAssCod +=1
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			PedAssCod = &PedAssCod
			PedAssPesCod = &PesCod
			PedAssPesCot = &AssVlrCot
			PedAssNfeVlr = &PedVlrLiq * &PerAssVlrCot
			&TotPedAssNfeVlr += &PedVlrLiq * &PerAssVlrCot
		EndNew
	EndFor
EndSub



]]></Source>
