      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&LctCodVar.SetEmpty()
&LctCod.SetEmpty()
&LctCodNom.SetEmpty()

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon113_TipoLancamentoDevolucaoVenda, &Varchar)
if not &Varchar.IsEmpty()
	&LctCod = val(&Varchar)
	
	For Each order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &LctCod
		&LctCodVar = trim(Str(LctCod))
		&LctCodNom = LctCodNom	
		Exit
	EndFor

Else
	For Each order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctTip = &LctTip
		&LctCodVar = trim(Str(LctCod))
		&LctCod = LctCod
		&LctCodNom = LctCodNom	
		Exit
	EndFor
Endif
]]></Source>
