      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NfeCod = 0
If &NfeProTer = Nota_ProPriaTerceira.PROPRIA
	For Each Order EmpCod, FilCod, NfeNum, NfeSer, ModCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeNum = &NfeNum
		Where NfeSer = &NfeSer
		Where ModCod = &ModCod
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
			&NfeCod = NfeCod
		Exit	
	EndFor
Else //Terceiros
	For Each Order EmpCod, FilCod, NfeNum, NfeSer, ModCod, NfeCliCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeNum = &NfeNum
		Where NfeSer = &NfeSer
		Where ModCod = &ModCod
		Where NfeProTer = Nota_ProPriaTerceira.TERCEIROS
		Where (NfeCliCod = &NfeCliCod and &NfeCliCod > 0) or (NfePedCod = &NfePedCod and &NfePedCod > 0)
			&NfeCod = NfeCod
		Exit	
	EndFor
EndiF
]]></Source>
