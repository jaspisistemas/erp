      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CheCod = &parCheCod
&IsNew = false

Do Case
	Case &OqueFazer = 'ADD' //Adiciona/Altera
		&CreDupNro = 'CHQ-' + trim(str(&CheNro))
		
		For Each Order EmpCod, CheCod
			Where EmpCod = &EmpCod
			Where CheCod = &CheCod
			
			CheTip 			= &CheTip
			TalCod 			= &TalCod
			TalCtabanCod 	= &TalCtabanCod
			CheCom 			= &CheCom
			CheBanCod		= &CheBanCod
			CheAgeCod		= &CheAgeCod
			CheCon			= &CheCon
			CheNro			= &CheNro
			CheVarNro = 'CHQ-'+ trim(str(&CheNro))
			CheVlr			= &CheVlr
			CheDtaEmi		= &CheDtaEmi
			CheDtaVct		= &CheDtaVct
			CheTitNom		= &CheTitNom
			CheTitCpf		= &CheTitCpf
			CheTitRg		= &CheTitRg
			CheTel			= &CheTel
			CheCmc			= &CheCmc
			CheCreCliCod    = &CreCliCod
			CheCtaBanCod 	= &CheCtaBanCod
			
			if CheMot.IsEmpty() or CheMot.IsNull() or CheMot = MotivoCheque.NAOEMITIDO
				CheMot			= MotivoCheque.EMITIDO
			Endif
			
			&CreCod = CheCreCod
			
			RetornaSoNumeros.Call(CheCon, &AuxCheCon)							
			CheBanAgeCon = trim(CheBanCod) +'/'+ trim(str(CheAgeCod)) + '/'+ trim(&AuxCheCon) +'/'+ trim(str(CheNro))
			
			Exit
		When none
			
			&CheCod = 0
			For Each Order EmpCod, (CheCod)
				Where EmpCod = &EmpCod
				&CheCod = CheCod
				Exit
			EndFor
			&CheCod += 1
			
			UltimoCodigoEmpresa.Call(domParCod.DUPLICATA,&EmpCod, &FilCod,&CreCod)
			
			New
				EmpCod 			= &EmpCod
				CheCod 			= &CheCod
				CheTip 			= &CheTip
				TalCod 			= &TalCod
				TalCtabanCod 	= &TalCtabanCod
				CheCom 			= &CheCom
				CheBanCod		= &CheBanCod
				CheAgeCod		= &CheAgeCod
				CheCon			= &CheCon
				CheNro			= &CheNro
				CheVarNro = 'CHQ-'+ trim(str(&CheNro))
				CheVlr			= &CheVlr
				CheDtaEmi		= &CheDtaEmi
				CheDtaVct		= &CheDtaVct
				CheTitNom		= &CheTitNom
				CheTitCpf		= &CheTitCpf
				CheTitRg		= &CheTitRg
				CheTel			= &CheTel
				CheCmc			= &CheCmc
				CheCreCliCod    = &CreCliCod
				CheCtaBanCod 	= &CheCtaBanCod
				CheMot			= MotivoCheque.EMITIDO
				CheCreCod = &CreCod
				CheCreFilCod = &FilCod
				
				RetornaSoNumeros.Call(CheCon, &AuxCheCon)							
				CheBanAgeCon = trim(CheBanCod) +'/'+ trim(str(CheAgeCod)) + '/'+ trim(&AuxCheCon) +'/'+ trim(str(CheNro))
			EndNEw
			
			commit
			
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				CreCod = &CreCod
				CreDupNro = &CreDupNro
				CreDtaEms = &CheDtaEmi 
				CreDtaVct = &CheDtaVct
				
				CreFrpPgtoCod = 4 //CHEQUE TERCEIROS
				
				CreVlrDup = &CheVlr
				CreVlrSdo = &CheVlr
				CreCliCod = &CreCliCod
				CreVenCod = &CreVenCod
				CreRecPag = ReceberPagar.Receber
				CreCbrCod = &CreCbrCod
				CreBloNro = ''
				CreCodBar = ''
				CreSts    = Status_Duplicata.ATIVO
				CreOriDup = OrigemDuplicata.LancamentoManual
				CrePlanCod = &PlanCod
				CreCheCod = &CheCod
				CreDtaCrt = &CreDtaCrt
				CreDtaPrt = &CreDtaPrt
				CreFilPgt = &CreFilPgt
				CreIsPer = &CreIsPer
			EndNew
		
			if not &CheObs.IsEmpty()
				GravaCobranca.call(&EmpCod,&FilCod,&CreCod,&CheObs,0,0,&CrePrmPag, '00:00:00', TipoObservacaoDuplicata.USUARIO)
			EndiF
		
			&IsNew = true
		EndFor
		
		commit
		
		if &IsNew = false
			For Each  Order EmpCod, FilCod, CreCod
				Where EmpCod = &EmpCod
				Where CreCod = &CreCod
				CreDupNro = &CreDupNro
				CreDtaEms = &CheDtaEmi 
				CreDtaVct = &CheDtaVct
				CreVlrDup = &CheVlr
				CreCliCod = &CreCliCod
				CreVenCod = &CreVenCod
				CreCbrCod = &CreCbrCod
				CrePlanCod = &PlanCod
				CreDtaCrt = &CreDtaCrt
				CreDtaPrt = &CreDtaPrt
				CreFilPgt = &CreFilPgt
				CreIsPer = &CreIsPer
				Exit		
			EndFor
			
			commit
		Endif
	
		//ATUALIZA SALDO DUPLICATA
		AtualizaSaldoDuplicata.Call(&EmpCod, &CreCod, &FilCod)
		 
	
	Case &OqueFazer = 'DEL' //ELIMINAR TEMPORARIA
		
		For Each Order EmpCod, CheCod
			Where EmpCod = &EmpCod
			Where CheCod = &CheCod
			
			Delete
		EndFor
		
		Commit
EndCase
]]></Source>
