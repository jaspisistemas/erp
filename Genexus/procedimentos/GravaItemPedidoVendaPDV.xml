      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&OldPedQtd = 0
&PedQtdFat = 0

For Each Order EmpCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&PedVlrCus = ProVlrCus
	
	&PedVlrCusPrd = 0
	Do Case
		Case ProTipCus = TipoCusto.Receita 
			&PedVlrCusPrd    = ProVlrCusPrd
			
		Case ProTipCus = TipoCusto.CustoProdutoEstoque
			&PedVlrCusPrd    = retornaCustoProducao.Udp(EmpCod, ProEstProCod)				
	EndCase
			
	&PedProEstProCod	= ProEstProCod		
	&PedProEstProGraCod = &ProGraCod
	
	Exit
EndFor 


For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCod = &PedItmCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	&OldPedQtd = PedQtd
	&OldPedQtdSdo = PedQtdSdo
	&PedQtdFat = PedQtdFat
	
	&OldPedVlrCus = PedVlrCus
	//&PedVlrCusPrd = PedVlrCusPrd
	
	PedProEstProCod	   = &PedProEstProCod		
	PedProEstProGraCod = &PedProEstProGraCod
	
	
	PedQtd = &PedQtd
	
	If &PedQtdCan >= 0 
		PedQtdCan = &PedQtdCan
	Else
		PedQtdCan = 0
	EndIF
	
	PedVlrCus = &PedVlrCus
	PedVlrCusPrd    = &PedVlrCusPrd
	PedItmCmp = &PedItmCmp
	PedItmVenCod = &PedItmVenCod
	PedProEmbQtd = 0
	PedQtdEmb = &PedQtd
	PedVlrTab = &PedVlrTab
	PedVlrUnt = &PedVlrUnt
	PedItmDsc = &PedItmDsc
	
       Exit
   When none
	if &PedItmCod = 0
        For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
			Where EmpCod = &EmpCod
	        Where FilCod = &FilCod
	        Where PedCod = &PedCod
            &PedItmCod = PedItmCod
	        Exit
        EndFor
		
        &PedItmCod += 1
	Endif
	
    new
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedItmCod = &PedItmCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		PedProEstProCod	   = &PedProEstProCod		
		PedProEstProGraCod = &PedProEstProGraCod
		PedProEmbQtd = 0
		PedQtdEmb = &PedQtd
		PedQtd = &PedQtd
		PedQtdCan = 0
		PedVlrCus = &PedVlrCus
		PedVlrCusPrd    = &PedVlrCusPrd
		//PedItmIpi
		//PedItmIcmSt
		//PedItmAcr
		
		PedItmCmp = &PedItmCmp
		PedItmVenCod = &PedItmVenCod
		PedVlrTab = &PedVlrTab
		PedVlrUnt = &PedVlrUnt
		PedItmDsc = &PedItmDsc
		//PedItmPrm = &PedItmPrm
		//PedItmCom = &PedItmCom
		PedItmDtaAdd = ServerNow()
		PedItmGUID = &PedItmGUID
		PedCodOciRefItm = 0				
       EndNew
   EndFor

commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
