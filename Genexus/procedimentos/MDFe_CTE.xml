      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &CteCidNom.Trim().IsEmpty()
	Do 'getCidade'	
EndIf

If &OqueFazer = 'ADD'
	For Each Order EmpCod, FilCod, MDFeCod, MDFeCteFilCod, MDFeCteCod,MDFeCteChv
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeCteFilCod = &CTeFilCod
		Where MDFeCteCod = &CTeCod
		Where MDFeCteChv = &CteChv
		
		msg('ATENÇÃO, O conhecimento de Sequência '+trim(str(&CTeCod))+' e valor ' +&CteVlrTot.ToFormattedString()+ ' Alterado!')
		MDFeCteChv = &CteChv
		MDfeCteCidCod = &CteCidCod
		MDFeCteCidNom = &CteCidNom
		MdfeCteUfeCod = &CteUfeCod
		MDFeCteVlrTot = &CteVlrTot
		MDfeCtePso = &CtePso
		MDFeCteChv2 = &MDFeCteChv2
		Exit
	When none
		
		For Each Order EmpCod, FilCod, MDFeCod, (MDFeCteItm)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			&MDFeCTeItm = MDFeCteItm
			Exit
		EndFor
		&MDFeCTeItm += 1
		
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MdfeCod
			MDFeCteItm =  &MDFeCTeItm
			MDFeCteFilCod = &CTeFilCod
			MDFeCteCod = &CTeCod
			MDFeCteChv = &CteChv
			MDfeCteCidCod = &CteCidCod
			MDFeCteCidNom = &CteCidNom
			MdfeCteUfeCod = &CteUfeCod
			MDFeCteVlrTot = &CteVlrTot
			MDfeCtePso = &CtePso
			MDFeCteChv2 = &MDFeCteChv2
			msg('Conhecimento de Sequência '+trim(str(&CTeCod))+' e valor ' +&CteVlrTot.ToFormattedString()+ ' foi adicionado com sucesso!')
		EndNEw
		COMMIT
		
		Do 'ADICIONACIOT'
		
		Do 'ADICIONA_AVERBACAO'
		
	EndFor

Else
	For Each Order EmpCod, FilCod, MDFeCod, MDFeCteItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeCteItm = &ParMDFeCTeItm
		Delete
		Exit
	EndFor
EndIF

Commit
	
Sub 'getCidade'
	For each Order EmpCod,CidIBGE, CidCod
		Where EmpCod = &EmpCod
		Where CidIBGE = &CteCidCod		
		&CteCidNom = CidNom
		exit
	EndFor
EndSub

Sub 'ADICIONACIOT'
	If not &CteCiotNro.Trim().IsEmpty()
		For Each Order EmpCod, FilCod, MDFeCod, MDFeCIOT
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			Where MDFeCIOT = &CteCiotNro
			&IsAchou = true
			Exit
		When none
			For Each Order EmpCod, FilCod, MDFeCod, (MdfeCiotCod)
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where MDFeCod = &MDFeCod
				&MdfeCiotCod = MdfeCiotCod
				exit
			EndFor
		
			&MdfeCiotCod += 1
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				MDFeCod = &MdfeCod
				MdfeCiotCod = &MdfeCiotCod
				MDFeCIOT = &CteCiotNro
				MDFeCIOTCnpj = &FilCpj
			EndNew
		commit
		EndFor
	EndIf
EndSub

Sub 'ADICIONA_AVERBACAO'
	
	For Each Order EmpCod, FilCod,CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CTeCod
		
		If not CteAveCnpjSeq.Trim().IsEmpty()
			&CteAveCnpjSeq = CteAveCnpjSeq
			&CteAveApo = CteAveApo
			Do 'BuscaCadastro'
			
			For Each order EmpCod, FilCod,MDFeCod,MdfeSegCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where MDFeCod = &MDFeCod
				Where MdfeSegRes = ResponsavelSeguro.Contratante
				Where MdfeSegCnpj = &CteAveCnpjSeq
				&MdfeSegCod = MdfeSegCod
				exit
			When none
				New
					EmpCod = EmpCod
					FilCod = FilCod
					MDFeCod = &MDFeCod
					MdfeSegCod = 1
					MdfeSegRef = &SegCod
					MdfeSegRes = ResponsavelSeguro.Contratante
					MdfeSegCnpj = CteAveCnpjSeq
					MdfeSegNom = &SegNom
					MdfeSegNroApo = CteAveApo
				EndNew
				Commit
			EndFor			
			
			New
				EmpCod = EmpCod
				FilCod = FilCod
				MDFeCod = &MDFeCod
				MdfeSegCod = &MdfeSegCod
				MdfeSegNroAve = CteAveNro
			EndNew
			Commit
		EndIf
		Exit
	EndFor
EndSub


Sub 'BuscaCadastro'
	For each order EmpCod,SegCnpj
		Where EmpCod = &EmpCod
		Where retornaSoNumeros.Udp(SegCnpj) = retornaSoNumeros.Udp(&CteAveCnpjSeq)
		&SegNom = SegNom
		&SegCod = SegCod
		Exit
	When none
		UltimoCodigoEmpresa.Call(domParCod.SEGURADORA, &EmpCod,  0, &SegCod)
		ValidaCpfCnpj.call(&CteAveCnpjSeq,0,'')
		if not &CteAveCnpjSeq.IsEmpty() and &CteAveCnpjSeq.Length() > 14
			ConsultaRFB.call(&EmpCod, &CteAveCnpjSeq,&AuxPesRaz,'','','','','','',0,'', '',&HttpClient)
			if not &AuxPesRaz.IsEmpty()
				&SegNom = &AuxPesRaz
			EndiF
		EndIf
	
		New
			EmpCod = &EmpCod
			SegCod = &SegCod
			SegCnpj = &CteAveCnpjSeq
			SegNom = &SegNom
			SegApo = &CteAveApo
		EndNew
	
	commit
	EndFor
EndSub




