        <Source><![CDATA[

For &sdtDuplicatasItem in &sdtDuplicatas
	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &sdtDuplicatasItem.FilCod
		Where CreCod = &sdtDuplicatasItem.CreCod
		
		CreCarNroAut = &sdtDuplicatasItem.CreCarNroAut
		CreCarBanCod = &sdtDuplicatasItem.CreCarBanCod
		
	EndFor
	
EndFor

commit

]]></Source>
