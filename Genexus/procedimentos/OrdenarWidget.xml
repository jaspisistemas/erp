      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&WidOrdUsr = 1
For Each Order EmpCod, WidPesCod, (WidIsSel), WidOrdUsr
	Where EmpCod = &EmpCod
	Where WidPesCod = &WidPesCod
	
	&WidOrdUsr += 1	
	WidOrdUsr = &WidOrdUsr
EndFor

commit

For Each Order EmpCod, WidPesCod, WidSync //PEGA A ORDEM DO OBJETO A SER MUDADO
	Where EmpCod = &EmpCod
	Where WidPesCod = &WidPesCod
	Where WidSync = &WidSync
	&AtualWidOrdUsr = WidOrdUsr
	If &SubirDescer = 'SUBIR'
		&NovaWidOrdUsr = &AtualWidOrdUsr - 1
	Else
		&NovaWidOrdUsr = &AtualWidOrdUsr + 1
	EndIF
	WidOrdUsr = &NovaWidOrdUsr
	Exit
EndFor

commit

For Each Order EmpCod, WidPesCod, WidOrdUsr
	Where EmpCod = &EmpCod
	Where WidPesCod = &WidPesCod
	Where WidOrdUsr = &NovaWidOrdUsr
	Where WidSync <> &WidSync
	WidOrdUsr = &AtualWidOrdUsr
EndFor

commit

]]></Source>
