      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsTodosInformados = true
For Each order EmpCod, FilCod, BalCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	Where ProCod = &ProCod when not &ProCod.IsEmpty()
	Where ProGraCod = &ProGraCod when not &ProGraCod.IsEmpty()
	Where BalQtd <> BalTotLotQtd
	Where ProSolLot = SolicitarLote.SIM_CONTROLAR
	
	&IsTodosInformados = false
	
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
