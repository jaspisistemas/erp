      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&MrkCod = &parMrkCod


if &MrkCod = 0
	
	UltimoCodigoEmpresa.Call(domParCod.MARKETPLACE, &EmpCod, 0, &MrkCod)
	&GUID = GUID.NewGuid()
	&MrkGuid = &GUID.ToString()
	
	new
		EmpCod = &EmpCod
		MrkCod = &MrkCod
		MrkGuid  =&MrkGuid
		
		MrkSts  = Status_AtivoInativo.ATIVO
		MrkStsInt = StatusMarketplace.Pendente
		
		MrkNom = &MrkNom
		MrkTip = &MrkTip
		
		MrkPadFilCod = &MrkPadFilCod
		MrkPadNfeFilCod = &MrkPadNfeFilCod
		MrkPadVenCod = &MrkPadVenCod
		
		MrkPadCliCod = &MrkPadCliCod
		MrkPadGrvCli = &MrkPadGrvCli 
		MrkPadLctCod = &MrkPadLctCod
		MrkPadTraCod = &MrkPadTraCod
	endnew

	commit
else
	
	For Each ORder EmpCod, MrkCod
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		
		MrkNom = &MrkNom
		
		MrkPadFilCod = &MrkPadFilCod
		MrkPadNfeFilCod = &MrkPadNfeFilCod
		MrkPadVenCod = &MrkPadVenCod
		
		MrkPadCliCod = &MrkPadCliCod
		MrkPadGrvCli = &MrkPadGrvCli 
		MrkPadLctCod = &MrkPadLctCod
		MrkPadTraCod = &MrkPadTraCod
		
		Exit
	EndFor

commit
EndIF
]]></Source>
