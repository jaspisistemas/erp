      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&mensagem.SetEmpty()

For Each Order EmpCod,VeiRen, VeiCod
	Where EmpCod = &EmpCod
	Where VeiRen = &VeiRen
	Where VeiCod <> &VeiCod
	&mensagem = 'Renavam já Cadastrado em outro Veículo!'
	Exit
EndFor
]]></Source>
