      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&IsColuna1 = true
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	
	&SdtEtiquetasItem = new()
	
	
	&SdtEtiquetasItem.QtdEtiqueta = EtqQtd
	&SdtEtiquetasItem.Linha1 = trim(&FilFan)
	
	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF

	&SdtEtiquetasItem.Linha2  = GxGetMLi(&EtqProNom, 1, 28)
	&SdtEtiquetasItem.Linha3 = GxGetMLi(&EtqProNom, 2, 28)
	
	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&SdtEtiquetasItem.Linha4 = trim(str(EtqProCod))
	Else		
		&SdtEtiquetasItem.Linha4 = trim(EtqNovProCod)
	EndIF

	&SdtEtiquetasItem.Linha5 = trim(toformattedString(EtqProQtdEmb))
	
	&ProCod = EtqProCod
	&ProGraCod = EtqProGraCod
	&Coluna1.SetEmpty()

	If not EtqProNroLot.Trim().IsEmpty()
		&SdtEtiquetasItem.Linha6 = 'Lote: '+trim(EtqProNroLot)
	EndIf

	&SdtEtiquetasItem.Linha7 = trim(EtqProBar)
	&SdtEtiquetasItem.Linha8 = format('%1 %2 %3 %4', substr(EtqProBar, 1, 2), substr(EtqProBar, 3, 7), substr(EtqProBar, 10, 3), substr(EtqProBar, 13, 1))
	
	&SdtEtiquetas.add(&SdtEtiquetasItem)
EndFor

PrcGravaImpressaoDataHora.Call(&EmpCod, &EmpImpCod, 'RELJAS048_R10', 0,0, &PEsCod, &SdtEtiquetas.ToXml(), 0, &FiDtaIni, &Today)
]]></Source>
