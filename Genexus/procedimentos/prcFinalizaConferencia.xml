      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, PedCod, PedConCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&SDTPedidoProdutoItem = new()
	&SDTPedidoProdutoItem.ConPedQtd = PedConQtd
	&SDTPedidoProdutoItem.ProCod = PedConProCod
	&SDTPedidoProdutoItem.ProGraCod = PedConProGraCod
	
	&ProCod = PedConProCod
	&ProGraCod = PedConProGraCod
	do 'getProduto'
	&SDTPedidoProdutoItem.ProBar = &ProBar
	&SDTPedidoProdutoItem.ProNom = &ProNom
	&SDTPedidoProdutoItem.ProGraRef = &ProGraRef
  	&SDTPedidoProduto.Add(&SDTPedidoProdutoItem)
EndFor

PadraoUsuario.Call('G', 'SDT_CONFITENSPEDIDO',&PesCod,&EmpCod,&SDTPedidoProduto.ToJson(),&Today)	

sub 'GetProduto'
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&ProBar = ProGraBar
		&ProNom = ProNomGra
		&ProGraRef = ProGraRef
		Exit
	EndFor
EndSub
]]></Source>
