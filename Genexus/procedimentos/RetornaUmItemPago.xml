      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsPagto = false
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedSts = Status_Pedido.ABERTO
	where PedItmPagVlrTot > 0 or PedItmPagQtdTot > 0 //tem pgto?
	
	//Tem que verificar se tem o pgto no pedido, mas na ordem de cerregamento por usar o msg proc., tem que desconsiderar o credito que é a qtde e vlr selecionado, que puxou de um pagto do pedido principal.	
		
	If (PedItmPagVlrTot > 0 and PedItmPagVlrTot > PedItmPagVlrTotCreOrd) or (PedItmPagQtdTot > 0 and PedItmPagQtdTot > PedItmPagQtdTotCreOrd) // se tiver pago e for maior que o credito significa que houve pagto na ordem,
		//ou no pedido, no pedido não vai existir credito na ordem sim caso ouver pgto antecipado.
		&IsPagto = true
	EndIf

	Exit
EndFor
]]></Source>
