      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//GRAVA CONFIGURAÇÃO PADRÃO 168 (COMPONENTES PRESTAÇÃO CTE)
For Each Order EmpCod, TConCod
	Where EmpCod 	= &parmEmpCod
	Where TConCod	= &TConCod
	
	//GRAVA LOG
	&TabelaVarchar = 'CONFSISTEMA'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&TConCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TCon168', trim(TCon168), trim(&parmTCon168), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	TCon168	= &parmTCon168
	Commit
	Exit
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
