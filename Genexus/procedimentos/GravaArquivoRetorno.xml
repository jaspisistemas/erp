      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For each Order EmpCod,RemRetCodEmp,RemRetDta
	Where EmpCod = &EmpCod
	Where RemRetCodEmp = &RemRetCodEmp
	Where RemRetDta    = &RemRetDta 
	
	RemRetCodEmp = &RemRetCodEmp
	RemRetNomEmp = &RemRetNomEmp
	RemRetDta = &RemRetDta
	RemRetTxt = &RemRetTxt
	RemRetSdtJson = &RemSdtJson
	RemRetCbrCod	= &RemRetCbrCod
When none
	
	For each Order EmpCod,(RemRetCod)
		Where EmpCod = &EmpCod
		&auxRemRetCod = RemRetCod
		Exit
	EndFor
	&RemRetCod = &auxRemRetCod+ 1
	
	New
		EmpCod = &EmpCod
		RemRetCod = &RemRetCod
		RemRetCodEmp = &RemRetCodEmp
		RemRetDta = &RemRetDta
		RemRetNomEmp = &RemRetNomEmp
		RemRetTxt = &RemRetTxt
		RemRetSdtJson = &RemSdtJson
		RemRetCbrCod	= &RemRetCbrCod
	EndNew
EndFor

commit


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
