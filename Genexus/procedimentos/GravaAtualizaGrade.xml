      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, ProCod, (ProGraCod)
	Where EmpCod = &EmpCod
	Where ProCod = &PrOCod
	
	&ProGraCod = ProGraCod
	Exit
EndFor

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &PrOCod
	
	if &ProGraCod > 1
		ProIsGra = true
	Else
		ProIsGra = false
	EndIF
	
	Exit
EndFor

Commit

]]></Source>
