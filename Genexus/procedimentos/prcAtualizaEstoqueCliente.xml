      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedQtd = &EstCliTipCmp - &EstCliTipRet

If &Sinal = '+' //SOMAR
	&AuxEstCliTipQtd = &PedQtd
	&AuxEstCliTipCmp = &EstCliTipCmp
	&AuxEstCliTipRet = &EstCliTipRet

Else //DIMINUIR
	&AuxEstCliTipQtd = &PedQtd * -1
	&AuxEstCliTipCmp = &EstCliTipCmp * -1
	&AuxEstCliTipRet = &EstCliTipRet * -1
EndIF	


If not &PedDtaFat.IsEmpty()
	&EstCliAno = year(&PedDtaFat)
	&EstCliMes = month(&PedDtaFat)
Else
	&EstCliAno = year(Serverdate())
	&EstCliMes = month(Serverdate())
EndIF

UltimasDatasEstoqueCliente.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &EstPedCliCod, &EstCliUltSai)

For Each Order EmpCod, FilCod ProCod, ProGraCod,EstPedCliCod //ESTOQUE CLIENTE
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstPedCliCod = &EstPedCliCod
	
	EstCliUltSai = &EstCliUltSai
	EstCliQtd += &AuxEstCliTipQtd

	Exit
When None
    New   //ESTOQUE
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstPedCliCod = &EstPedCliCod
		EstCliUltSai = &EstCliUltSai
		EstCliQtd = &AuxEstCliTipQtd
    EndNew
EndFor

commit


//ESTOQUE CLIENTE MES
For Each Order EmpCod, FilCod ProCod, ProGraCod,EstPedCliCod,EstCliAno,EstCliMes
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstPedCliCod = &EstPedCliCod
	Where EstCliAno = &EstCliAno
	Where EstCliMes = &EstCliMes
	
	EstCliTipQtd += &AuxEstCliTipQtd
	EstCliTipCmp += &AuxEstCliTipCmp
	EstCliTipRet += &AuxEstCliTipRet
	
	//VERIFICA MESES PARA FRENTE
	Do 'MesesFrente'
	
	Exit
When None
	
	//VERIFICAR MESES ANTERIORES
	do 'MES_ANTERIOR'
	
	New
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstPedCliCod = &EstPedCliCod
		EstCliAno = &EstCliAno
		EstCliMes = &EstCliMes
		
		EstCliQtdAnt = &AntEstCliTipQtd
		
		EstCliTipQtd = &AntEstCliTipQtd + &AuxEstCliTipQtd
		EstCliTipCmp = &AuxEstCliTipCmp
		EstCliTipRet = &AuxEstCliTipRet
	EndNew

	//VERIFICA MESES PARA FRENTE
	Do 'MesesFrente'
EndFor

commit


Sub 'MES_ANTERIOR'
    &AntEstCliTipQtd = 0
	
	For Each Order EmpCod, FilCod ProCod, ProGraCod,EstPedCliCod,(EstCliAno),(EstCliMes)
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
    Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstPedCliCod = &EstPedCliCod
	Where (EstCliAno = &EstCliAno and EstCliMes < &EstCliMes) or EstCliAno < &EstCliAno 
		&AntEstCliTipQtd = EstCliTipQtd
        exit
    EndFor
EndSub


Sub 'MesesFrente'
	For Each Order EmpCod, FilCod ProCod, ProGraCod,EstPedCliCod,EstCliAno,EstCliMes
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where EstPedCliCod = &EstPedCliCod
		Where (EstCliAno = &EstCliAno and EstCliMes > &EstCliMes) or EstCliAno > &EstCliAno 
		EstCliQtdAnt += &AuxEstCliTipQtd		
		EstCliTipQtd += &AuxEstCliTipQtd	
    EndFor
EndSub
]]></Source>
