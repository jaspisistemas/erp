      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PesInsEst = ''


For each Order EmpCod,PesCod,PesPrpCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesPrpCod = &PesPrpCod
	&PesInsEst = PesPrpIns
	If &PesInsEst.Trim().IsEmpty()
		Do 'Cliente'
	EndIf

	exit
EndFor

Sub 'Cliente'
	
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Do Case
			Case not PesCadPro.IsEmpty() and PesTip = tipoPessoa.FISICA
				&PesInsEst = PesCadPro
			Case not PesInsEst.IsEmpty() and PesTip = tipoPessoa.JURIDICA
				&PesInsEst = PesInsEst
			OtherWise
				&PesInsEst = 'ISENTO'
		EndCase
	EndFor

EndSub
]]></Source>
