      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//&PedItmVenCod
//&ComposicaoPedVlrUnt

&QtdItensComposicao = RetornaTotalItensComposicao.UDP(&EmpCod, &FilCod, &PedCod, &PedItmCod)
if &MdpVenQtdMeio > 0
	If &QtdItensComposicao > 0
		&QtdItensComposicao += 1
		&ComposicaoPedQtd = round(1 / &QtdItensComposicao, 2)
		
		&diferenca = (1 - (&ComposicaoPedQtd * &QtdItensComposicao))
		&PrimeiraComposicaoPedQtd = &ComposicaoPedQtd + &diferenca
	Else
		&ComposicaoPedQtd = 1
	Endif	
Else
	&ComposicaoPedQtd = 1
Endif
if &PrimeiraComposicaoPedQtd = 0
	&PrimeiraComposicaoPedQtd = &ComposicaoPedQtd
Endif

if &OqueFazer = 'ADD'
	RetornaProdutoReferencia.Call(&EmpCod, &ComposicaoProRef, &ComposicaoProCod, &ComposicaoProGraCod, &ComposicaoProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ComposicaoMensagem)
		
	//GRAVA PRINCIPAL
	GravaItemPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, &ComposicaoPedItmCod, &ComposicaoProCod, &ComposicaoProGraCod, &ComposicaoPedQtd, 0, 0, &ComposicaoPedVlrUnt, &ComposicaoPedVlrUnt, 0, '', &PedItmVenCod, 0, &MensagemInserida, &MensagemAlterado, &wwpContextUserName)
	GravaItemReferencia.Call(&EmpCod, &FiLCod, &PedCod, &ComposicaoPedItmCod, &PedItmCod, 'A')
	
	//ATUALIZA RESTANTE COMPOSICAO
	AtualizaItensComposicao.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &ComposicaoPedItmCod, &ComposicaoPedQtd, &PrimeiraComposicaoPedQtd, &wwpContextUserName)	
	
Endif
]]></Source>
