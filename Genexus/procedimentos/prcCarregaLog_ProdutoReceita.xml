      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &ProCod = 0 //INSERT
	//QUando insert inserido os campos no proprio processo de gravar.
Else
	For Each order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		For Each order EmpCod, ProCod, RecItmCod
			&IdVarchar = trim(toformattedString(RecItmCod))
			prcLogAddSdtLevel.Call(&IdVarchar, 'RecItmCod', trim(toformattedString(RecItmCod)), '', &sdtLogAtributosLevel)
			prcLogAddSdtLevel.Call(&IdVarchar, 'RecProCod', trim(toformattedString(RecProCod)), '', &sdtLogAtributosLevel)
			prcLogAddSdtLevel.Call(&IdVarchar, 'RecProQtd', trim(toformattedString(RecProQtd)), '', &sdtLogAtributosLevel)
			
		EndFor
		
		Exit
	EndFor
Endif

]]></Source>
