      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//PEGA ULTIMO RECEBIMENTO DE PRODUTOS
&PedProPagDtaHor = serverNow()
For Each Order EmpCod, FilCod, PedCod, (PedProPagItm)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&PedProPagItm = PedProPagItm
	Exit
EndFor
&PedProPagItm += 1

new
	EmpCod = &EmpCod
	FilCod = &FilCod
	PedCod = &PedCod
	PedItmCod = -1
	PedProPagItm = &PedProPagItm
	PedProPagVlr = &PedItmPagVlrSel		
	PedProPagObs = '[AVULSO]'
	PedProPagDtaHor = &PedProPagDtaHor
EndNew

Commit

]]></Source>
