      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Varchar = &destinoPasta

&PastaAutorizada = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "autorizados\"


&PastaTemporaria  = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() +'xmlCTe-'+ trim(&Varchar)
&Directory.Source = &PastaTemporaria
if not &Directory.Exists()
	&Directory.Create()
Else
	&Directory.Delete()
	&Directory.Create()
endif

&IsExistDiretorio = false
For Each Order EmpCod, FilCod,CteProTer,CteModCod,CteDtaEms,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where (CteDtaEms >= &iniNfeDtaEms and CteDtaEms <= &finNfeDtaEms) //When &TipoData = 'E'
	Where CteNum <> 0
	Where (CteSts = Status_NFe.Autorizada )	or (CteSts <> Status_NFe.Digitando and &SomenteAutorizadas = Status_SimNao.Nao)
	where CteProTer = Nota_ProPriaTerceira.PROPRIA
//	Where CteModCod = '57'
	Where CteChv <> ''
	
	//BUSCAR CONHECIMENTO AUTORIZADO
	&AnoMesEnviado = PadL(LTrim(str(Year(CteDtaEms))), 4, '0') + PadL(LTrim(str(Month(CteDtaEms))), 2, '0')
	
	//CRIA DIR TMPCTE
	&IsExistDiretorio = true
	
	&ArquivoXML =  &PastaAutorizada.Trim() + &AnoMesEnviado.Trim() +"\"+ CteChv.Trim() + '-procNFe.xml'
	&ArquivoDestino = &PastaTemporaria +"\"+ CteChv.Trim() + '-procNFe.xml'
	
	&File.Source = &ArquivoXML.Trim()		
	if &File.Exists()
		//COPIA PASTA TEMPORARIA
		&File.Copy(&ArquivoDestino)
	else		
		&XmlWriter.Open(&ArquivoDestino)
		&XmlWriter.WriteRawText(CteArqXml)
		&XmlWriter.Close()
	endif
	&File.Close()
	
	&ArquivoXML =  &PastaAutorizada.Trim() + &AnoMesEnviado.Trim() +"\"+ CteChv.Trim() + '_110111_01-procEventoNFe'
	&ArquivoDestino = &PastaTemporaria +"\"+ CteChv.Trim() + '_110111_01-procEventoNFe'
	
	&File.Source = &ArquivoXML.Trim()
	if &File.Exists()
		//COPIA PASTA TEMPORARIA
		&File.Copy(&ArquivoDestino)
	EndIF
	&File.Close()
	
	&ArquivoXML =  &PastaAutorizada.Trim() + &AnoMesEnviado.Trim() +"\"+ CteChv.Trim() + '-ped-inu.xml'
	&ArquivoDestino = &PastaTemporaria +"\"+ CteChv.Trim() + '-ped-inu.xml'
	
	&File.Source = &ArquivoXML.Trim()
	if &File.Exists()
		//COPIA PASTA TEMPORARIA
		&File.Copy(&ArquivoDestino)
	EndIF	
	&File.Close()
	
	If &EnviaPdfCte = Status_SimNao.Sim /// envia os pdf
		&ArquivoPdf =  &sdtConfiguracoesPasta.PastaNFpdf.Trim() +"\"+ CteChv.Trim() + '.pdf'
		&ArquivoDestino = &PastaTemporaria +"\"+ CteChv.Trim() + '.pdf'
		&File.Source = &ArquivoPdf.Trim()		
		if &File.Exists()
			//COPIA PASTA TEMPORARIA
			&File.Copy(&ArquivoDestino)
		else
			&URLFisico = &PastaTemporaria +"\"+ CteChv.Trim() + '.pdf'
			RELJAS085_Print.Call(EmpCod,FilCod,CteCod,&URLFisico)
		endif
		&File.Close()
	EndIf
EndFor

if &IsExistDiretorio = true
	&inputFolderPath =  &PastaTemporaria.Trim()
	&destinoPasta = &PastaTemporaria + ".zip"
	
	&File.Source = &destinoPasta
	if &File.Exists()
		&File.Delete()
	EndIf
	&File.Close()
	
	//Compacta
	&ZipUtil.ZipFiles(&inputFolderPath, &destinoPasta, &password)
EndIF
]]></Source>
