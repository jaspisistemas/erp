      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//PROCEDIMENTO PARA REALIZAR O ESTORNO DAS DESPESAS DA VIAGEM

For Each Order EmpCod, FilCod, ViaCod, ViaLanCod
	Where EmpCod	=	&parmEmpCod
	Where FilCod 	= 	&parmFilCod
	Where ViaCod	= 	&parmViaCod
	Where ViaLanCod	= 	&parmViaLanCod
	
	ViaLanStsPag	= Status_SimNao.Nao //ALTERA O STATUS DA DESPESA PARA NÃO PAGO 

	//ATUALIZA O STATUS DO MOVIMENTO E O SALDO DO CAIXA
	Do 'GetMovimento'
	Commit
	
	Exit
EndFor

Sub 'GetMovimento'
	
	&DataVazia.SetEmpty()
	For Each Order EmpCod, MovCod
		Where EmpCod 		= &parmEmpCod
		Where MovViaCod		= &parmViaCod
		Where MovViaLanCod	= &parmViaLanCod
		Where MovSts		= Status_Caixa.Lancado
		
		&AuxMovCod			= MovCod
		For Each Order EmpCod, MovCod, MovItmCod
			Where MovItmSts		= Status_Caixa.Lancado
			Where MovTrnOriCod	= &AuxMovCod
			
			MovItmSts			= Status_Caixa.Cancelado
		EndFor
				
		AtualizaSaldoConta.Call(TrnMode.Delete, EmpCod, MovCtaBanCod, ServerDate(), MovCreDeb, MovVlr, &DataVazia, 0,'')
		MovSts 				= Status_Caixa.Cancelado
				
		Exit
	EndFor
EndSub
]]></Source>
