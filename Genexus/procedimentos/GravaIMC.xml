      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod when &ProCod <> 0
//	Where ProSetCod = &ProsetCod when &ProsetCod <> 0
//	Where GrupCod = &GrupCod when &GrupCod <> 0

	ProImcCusInd	 = &ProImcCusInd
	ProImcDesAdm	 = &ProImcDesAdm
	ProImcDesFin	 = &ProImcDesFin
	ProImcDesVen	 = &ProImcDesVen
	ProImcMarLuc	 = &ProImcMarLuc
EndFor

Commit

For Each Order EmpCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod when &ProCod <> 0
//	Where ProSetCod = &ProsetCod when &ProsetCod <> 0
//	Where GrupCod = &GrupCod when &GrupCod <> 0

	ProIMCTot = ProIMCTot_Formula
EndFor

Commit


if &AtualizarIMC = true
	
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod when &ProCod <> 0
//		Where ProSetCod = &ProsetCod when &ProsetCod <> 0
//		Where GrupCod = &GrupCod when &GrupCod <> 0
		
		if ProIMCTot_Formula > 0
			&NovaVenda = round((100 / (ProIMCTot_Formula/100)),2)
		EndIF
		
		ProIMC = round(100 - ((&NovaVenda / 100) * 100), 2)
		if ProIMC < 0
			ProIMC = ProIMC * -1
		EndIF
	EndFor
	
	Commit
	
EndIF

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
