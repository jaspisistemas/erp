      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PREENCHIDO = 0
&IsErro = false
&Mensagem.SetEmpty()


For Each Order EmpCod, CreCod, CreRecPag
	Where EmpCod 	= &EmpCod
	Where CreCod 	= &CreCod
	Where CreRecPag = ReceberPagar.Receber
	Where CreDtaVct>= serverdate()
	
	&CreCbrCod		= CreCbrCod
	Do 'GetLocalCobraca'
	
	If &ErroCobraca = 0 //Se encontrou o Local de Cobrança e obteve sucesso ao Autenticar
		
		&contacorrente		= &CbrNroCon.Trim() + &CbrNroConDig.Trim()
		&CreCliRaz 			= RetiraCaracteresEspeciais.Udp(CreCliRaz)
		&CreCliEndCob 		= RetiraCaracteresEspeciais.Udp(CreCliEndCob)
		&CreCliCobCidNom 	= RetiraCaracteresEspeciais.Udp(CreCliCobCidNom)
		
		// ################################################## DADOS DO PAGADOR #############################################################################
		&SdtEmitirCobranca_Inter.pagador.cpfCnpj		= IIF(CreCliTip	= TipoPessoa.FISICA, trim(RetornaSoNumeros.Udp(CreCliCpf)), trim(RetornaSoNumeros.Udp(CreCliCnpj)))
		&SdtEmitirCobranca_Inter.pagador.tipoPessoa		= IIF(CreCliTip	= TipoPessoa.FISICA, 'FISICA', 'JURIDICA')
		&SdtEmitirCobranca_Inter.pagador.nome			= Substr(trim(&CreCliRaz), 1, 100)
		&SdtEmitirCobranca_Inter.pagador.endereco		= Substr(trim(&CreCliEndCob), 1, 100)
		&SdtEmitirCobranca_Inter.pagador.cidade			= Substr(trim(&CreCliCobCidNom), 1, 60)
		&SdtEmitirCobranca_Inter.pagador.uf				= CreCliCobUfeCod
		&SdtEmitirCobranca_Inter.pagador.cep			= SubStr(RetornaSoNumeros.Udp(CreCliCobCep), 1, 8)
		&SdtEmitirCobranca_Inter.pagador.telefone		= SubStr(RetornaSoNumeros.Udp(CreCliPrmFon), 3, 9) 
		&SdtEmitirCobranca_Inter.pagador.ddd			= SubStr(RetornaSoNumeros.Udp(CreCliPrmFon), 1, 2) 
		&SdtEmitirCobranca_Inter.pagador.email			= Substr(trim(CreCliPrmEml), 1, 50)
		&SdtEmitirCobranca_Inter.pagador.numero			= SubStr(Trim(CreCliCobNro), 1, 10)
		&SdtEmitirCobranca_Inter.pagador.bairro			= SubStr(Trim(CreCliCobBai), 1, 60)
		
		//################################################## DADOS BENEFICIARIO FINAL ##########################################################		
		
		&CreFilPgt = CreFilPgt// Filial de Pagamento/Recebimento
		
		Do 'GetFilial'
		&SdtEmitirCobranca_Inter.beneficiarioFinal.nome			= SubStr(&CbrRazSoc.Trim(), 1, 100)
		&SdtEmitirCobranca_Inter.beneficiarioFinal.tipoPessoa	= 'JURIDICA'
		&SdtEmitirCobranca_Inter.beneficiarioFinal.cpfCnpj		= Trim(RetornaSoNumeros.Udp(&CbrCnpj))
		&SdtEmitirCobranca_Inter.beneficiarioFinal.endereco		= SubStr(Trim(&FilLog), 1, 100)
		&SdtEmitirCobranca_Inter.beneficiarioFinal.bairro		= SubStr(Trim(&FilBai), 1, 60)
		&SdtEmitirCobranca_Inter.beneficiarioFinal.cidade		= SubStr(Trim(&FiLCidNom), 1, 60)
		&SdtEmitirCobranca_Inter.beneficiarioFinal.uf			= SubStr(Trim(&FilCidUfeCod), 1, 2)
		&SdtEmitirCobranca_Inter.beneficiarioFinal.cep			= SubStr(RetornaSoNumeros.Udp(&FilCep), 1, 8)
		
		//################################################## DADOS BOLETO ##########################################################		
		
		&SdtEmitirCobranca_Inter.numDiasAgenda	= IIf(&CbrTipBol = 'H', &CbrValQrCode, 30)
		&SdtEmitirCobranca_Inter.seuNumero		= SubStr(PadL(Trim(Str(FilCod)),2, '0') + PadL(Trim(Str(CreCod)),8, '0'), 1, 15)
		
		&dia 									= Day(CreDtaVct)
		&mes 									= Month(CreDtaVct)
		&Ano 									= Year(CreDtaVct)
		&Datavarchar 							= padL(str(&ano),4,'0') +'-'+padL(str(&mes),2,'0')+'-'+padL(str(&dia),2,'0')
		&SdtEmitirCobranca_Inter.dataVencimento = &Datavarchar
		&SdtEmitirCobranca_Inter.valorNominal	= CreVlrDup
		
		//################################################## DADOS DESCONTO ##########################################################		
		
		Do Case 
			Case &CbrDesDia <> 0   // Percentual de desconto pgt EM DIA
				&SdtEmitirCobranca_Inter.desconto1.codigoDesconto 	= 'VALORFIXODATAINFORMADA'
				&DesCreVlrDup 										= (CreVlrDup * (&CbrDesDia / 100))
				&CreDtaVct 											= CreDtaVct.AddDays((&CbrQtdDiaDesc*-1))
				&dia 												= Day(&CreDtaVct)
				&mes 												= Month(&CreDtaVct)
				&Ano 												= Year(&CreDtaVct)
				&Datavarchar 										= padL(str(&ano),4,'0') +'-'+padL(str(&mes),2,'0')+'-'+padL(str(&dia),2,'0')
				
				&SdtEmitirCobranca_Inter.desconto1.data			 	= &Datavarchar			        
				&SdtEmitirCobranca_Inter.desconto1.valor 			= &DesCreVlrDup
				
			Case &CbrDesAnt	<> 0
				&SdtEmitirCobranca_Inter.desconto2.codigoDesconto	= 'VALORFIXODATAINFORMADA'
				&DesCreVlrDup 										= (CreVlrDup * (&CbrDesAnt / 100))
				&CreDtaVct 											= CreDtaVct-1
				&dia 												= Day(&CreDtaVct)
				&mes 												= Month(&CreDtaVct)
				&Ano 												= Year(&CreDtaVct)
				&Datavarchar 										= padL(str(&ano),4,'0') +'-'+padL(str(&mes),2,'0')+'-'+padL(str(&dia),2,'0')
				
				&SdtEmitirCobranca_Inter.desconto2.data				= &Datavarchar				        
				&SdtEmitirCobranca_Inter.desconto2.valor			= &DesCreVlrDup
				
		EndCase		
		
		&Juro_Dia 	= round((CreVlrDup * &JurTaxDia), 2) 
		If &JurTaxDia > 0 and &Juro_Dia > 0
			&SdtEmitirCobranca_Inter.mora.codigo	= 'VALORDIA'
			&SdtEmitirCobranca_Inter.mora.valor		= &Juro_Dia
		EndIf
		
		If &CbrMltVlr > 0
			&SdtEmitirCobranca_Inter.multa.codigo 	= 'VALORFIXO'
			&SdtEmitirCobranca_Inter.multa.valor	= &CbrMltVlr
		EndIf
		
		
		&auxCbrInsBol1 								= RetiraCaracteresEspeciais.Udp(&CbrInsBol1)
		&SdtEmitirCobranca_Inter.mensagem.linha1	= Substr(trim(&auxCbrInsBol1), 1, 80)
		
		&PREENCHIDO = 1
	EndIf
	
When none
	
	&Mensagem 	= 'Impossível gerar Boleto para esta Duplicata!, a Mesma NÃO pode estar vencida, e tem que ser tipo RECEBER, e com opção boleto online no local de Cobrança!'
	&IsErro		= true
	
EndFor
//#################################################################################################################################################

If &PREENCHIDO = 1
	
	prcEmitirCobranca_Inter.Call(&EmpCod, &FilCod, &CreCod, &PesCod, &CreCbrCod, &CbrChaTra, &SdtEmitirCobranca_Inter, &contacorrente, &RetornoMensagem, &SdtEmitirCobranca_Inter_Response)
	If &RetornoMensagem.IsEmpty()
		prcGravaCodigoSolicitacao_Inter.Call(&EmpCod, &CreCod, &SdtEmitirCobranca_Inter_Response.codigoSolicitacao.Trim())

		prcRecuperarCobranca_Inter.Call(&EmpCod, &FilCod, &PesCod, &CreCbrCod, &CbrChaTra, &contacorrente, &SdtEmitirCobranca_Inter_Response.codigoSolicitacao.Trim(), &RecuperarMensagem, &SdtRecuperarCobranca_Inter)
		If &RecuperarMensagem.IsEmpty()
			prcAtualizaDadosRetorno_Inter.Call(&EmpCod, &CreCod, &SdtRecuperarCobranca_Inter)
			If &SdtRecuperarCobranca_Inter.boleto.nossoNumero.Trim().IsEmpty()
				
				&Mensagem	= 'EM REMESSA! Boleto INTER registrado porém sem retorno recupere a cobrança.'
			Else
				&Mensagem	= 'Sucesso! Boleto INTER registrado com sucesso.'
			EndIf
			
		Else
			&Mensagem	= 'ERRO ao Recuperar Cobrança! ' + Trim(&RecuperarMensagem)
			&IsErro 	= true
		EndIf
	Else
		&Mensagem	= 'ERRO ao emitir Cobrança! ' + Trim(&RetornoMensagem)
		&IsErro 	= true
	EndIf
Else
	&Mensagem = 'A estrutura não está prenchida para poder consumir os servidores! Chave de Transação não encontrada  ou chave master inválida!'
	&IsErro = true
EndIf



Sub 'GetFilial'
	
	For Each Order EmpCod, FilCod
		Where EmpCod 	= &EmpCod
		Where FilCod 	= &CreFilPgt
		
		&FiLCidNom 		= FilCidNom.Trim() 
		&FilCidUfeCod 	= trim(FilCidUfeCod)
		&FilLog 		= Trim(FilLog)
		&FilBai			= Trim(FilBai)
		&FiLCidNom		= Trim(FilCidNom)
		&FilCidUfeCod	= Trim(FilCidUfeCod)
		&FilCep 		= StrReplace(FilCep, '-', '')
		
		Exit
	EndFor

EndSub

Sub 'GetLocalCobraca'

	&ErroCobraca 		= 0
	For each Order EmpCod,CbrCod,CrbRegAut,CbrTipImp
		Where EmpCod 	= &EmpCod
		Where CbrCod 	= &CreCbrCod
		Where CrbRegAut = Status_SimNao.Sim
		
		&CbrCtaBanAgeCod 	= CbrCtaBanAgeCod
		&CbrCtaBanAgeDig 	= CbrCtaBanAgeDig
		&CbrCtaBanCrt 		= CbrCtaBanCrt
		&CbrCtaBanBanCod 	= CbrCtaBanBanCod
		&CbrNroCon 			= CbrNroCon
		&CbrNroConDig		= CbrNroConDig
		&CbrCarCod 			= CbrCarCod
		&CbrDesDia 			= CbrDesDia
		&CbrQtdDiaDesc		= CbrQtdDiaDesc
		&CbrDesAnt 			= CbrDesAnt
		&CbrInsBol1 		= CbrInsBol1
		&CbrMltVlr 			= CbrMltVlr
		&CtaBanNosNro 		= CtaBanNosNro
		&CbrTipBol 			= CbrTipBol
		&CbrRazSoc 			= CbrRazSoc 
		&CbrCnpj 			= CbrCnpj 
		&CbrApiKey 			= CbrApiKey
		&CbrProAut 			= CbrProAut
		&CbrProQtd 			= CbrProQtd
		&CbrNegQtd 			= CbrNegQtd
		&CbrNegAut 			= CbrNegAut
		&CbrValQrCode 		= CbrValQrCode
		
		If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow() //chave de Transação esta Vencida?
			&CbrChaTra 			= CbrChaTra
			&IschaveTransacao 	= true 
		Else
			prcOAuth_Inter.Call(&EmpCod, &FilCod, &PesCod, CbrCod, &CbrChaTra, &Mensagem)
			If Not &Mensagem.IsEmpty()
				&ErroCobraca	= 1
				&IsErro			= True
			EndIf
		EndIf
		&CbrJurCod = CbrJurCod
		&JurTaxDia = 0
		Do 'Juros'
		
	when none
		
		&ErroCobraca 	= 1
		&Mensagem 		= 'Local de cobrança, não encontrado.'
		&IsErro 		= True
		
	EndFor

EndSub

Sub 'Juros'	
	
	For each Order EmpCod,JurCod,(JurAno),(JurMes)
		Where EmpCod = &EmpCod
		Where JurCod = &CbrJurCod
		
		&JurTax 	= JurTax
		&JurTaxDia 	= JurTaxDia
		
		Exit
	EndFor

EndSub
]]></Source>
