      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, PraCod
	Where EmpCod = &EmpCod
	Where PraCod = &PraCod
	
	&PraColMax = PraColMax
	&PraColMin = PraColMin
	&PraMedBlo = PraMedBlo
	
	&PraTipParc = PraTipParc
	&PraIsVis   = PraIsVis
	&PraQtdMax  = iif(PraQtdMax > 0, PraQtdMax, 25)
	if PraIsVis = true
		&PraQtdMax = 1
	Endif
	
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
