if &PraCod.IsEmpty() //INSERT
	//QUando insert inserido os campos no proprio processo de gravar.
Else
	For Each order EmpCod,PraCod,PraParCod
		Where EmpCod = &EmpCod
		Where PraCod = &PraCod
		
		&IdVarchar = trim(str(PraParCod))
		prcLogAddSdtLevel.Call(&IdVarchar, 'PraParCod', trim(str(PraParCod)), '', &sdtLogAtributosLevel)
		prcLogAddSdtLevel.Call(&IdVarchar, 'PraParNom', trim(PraParNom), '', &sdtLogAtributosLevel)
		
	EndFor
Endif
]]></Source>
