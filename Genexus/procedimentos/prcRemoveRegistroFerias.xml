      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//deleta registro
For Each Order EmpCod, PesCod, PesRecCod, FerAnoBas, FerItemCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesRecCod = &PesRecCod
	Where FerAnoBas = &FerAnoBas
	Where FerItemCod = &FerItemCod
	
	delete
	
	exit
EndFor

commit

//soma quantidades
For Each Order EmpCod, PesCod, PesRecCod, FerAnoBas, FerItemCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesRecCod = &PesRecCod
	Where FerAnoBas = &FerAnoBas
	Where FerItemCod = &FerItemCod
	
	&FerDiaUsu += FerItemDias
	
EndFor

//atualizacapa
For Each ORder EmpCod, PesCod, PesRecCod, FerAnoBas
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	where PesRecCod = &PesRecCod
	Where FerAnoBas = &FerAnoBas
		
	if FerDtaFin < serverdate()
		&FerDiaTot = 30
	Else			
		&Dias = FerDtaFin-FerDtaIni
		&FerDiaTot = round(&Dias * 0.0821917808219178, 0)
	Endif
	FerDiaPen = &FerDiaTot - &FerDiaUsu
	FerDiaUsu = &FerDiaUsu
	FerDiaTot = &FerDiaTot
	
	Commit
EndFor
]]></Source>
