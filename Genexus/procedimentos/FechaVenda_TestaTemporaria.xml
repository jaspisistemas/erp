      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem = ''
&IsErroTemporaria = false
&IsErroDuplicataRepetida = false

For Each Order EmpCod, FilCod, PedCod, PedTmpDupCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedTmpDupVlr > 0
	
	if PedFrpPgtoTip = TipoDuplicata.DUPLICATA //Aceita Repetido? S=SIM N=NAO PARA DUPLICATAS
		if &TCon075_ValidaNroDuplicata <> 'S' //Aceita Repetido? S=SIM N=NAO PARA DUPLICATAS
			ValidaNumeroDuplicataRepetido2.Call(EmpCod, FilCod, PedTmpCreCod, PedCliCod, ReceberPagar.Receber, PedTmpDupNro, &IsErroDuplicataRepetida, &Mensagem)
		EndiF
	Endif
	
	Do Case
		Case &IsErroDuplicataRepetida = true
			&IsErroTemporaria = true
			Exit
			
		Case PedTmpDupNro.IsEmpty() and PedTmpSts = Status_SimNao.Nao
			&Mensagem = 'Informe o número em todas as DUPLICATAS!'
			&IsErroTemporaria = true
			Exit				
		Case PedTmpDupVct.IsEmpty() and PedTmpSts = Status_SimNao.Nao
			&Mensagem = 'Informe a data de Vencimento em todas as DUPLICATAS!'
			&IsErroTemporaria = true
			Exit				
		Case PedTmpDupCbrCod.IsEmpty() and PedTmpSts = Status_SimNao.Nao and (PedFrpPgtoTip = TipoDuplicata.DUPLICATA)
			&Mensagem = 'Informe o Local de Cobrança em Todas as DUPLICATAS!'
			&IsErroTemporaria = true
			Exit				
		Case PedTmpPlanCod.IsEmpty() and (PedTmpFrpPgtoTip = TipoDuplicata.DINHEIRO or PedTmpFrpPgtoTip = TipoDuplicata.PIX or PedTmpFrpPgtoTip = TipoDuplicata.DEPOSITO) and PedTmpSts = Status_SimNao.Nao
			&Mensagem = 'Informe o Plano/Categoria nas duplicatas Recebidas em DINHEIRO!'
			&IsErroTemporaria = true
			Exit
	EndCAse
EndFor
]]></Source>
