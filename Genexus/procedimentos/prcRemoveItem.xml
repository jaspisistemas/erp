      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, NfsCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NfsCod
	
	&NfsTipNF = NfsTipNF
	&NfsPedFiLCod = NfsPedFilCod
	&NFsPedCod = NfsPedCod
		
	Exit
EndFor

For Each Order EmpCod, NfsCod, NfsItmCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NfsCod
	Where NfsItmCod = &nfsItmCod
	
	delete
EndFor

commit

if &NfsTipNF = 'S'
	&sdtDadosItens.Clear()
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &NfsPedFiLCod
		Where PedCod = &NFsPedCod
		
		if not PedVeiPla.IsEmpty() and not PedVeiPla.IsNull() and PedVeiPla.Length() > 6
			&NfsDisSer = 'PLACA: ' + trim(PedVeiPla)
		Endif
		
		Exit
	EndFor
	
	//tem que atualizar a descricao do servico
	//add num sdt
	For Each Order EmpCod, NfsCod, NfsItmCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NfsCod
		Where NfsItmCod > 1
		
		&sdtDadosItensItem = new()
		&sdtDadosItensItem.NfsItmCod = NfsItmCod
		&sdtDadosItensItem.NfsItmProCod = NfsItmProCod
		&sdtDadosItensItem.NfsItmProGraCod = NfsItmProGraCod
		&sdtDadosItensItem.NfsItmProNom = NfsItmProNom
		&sdtDadosItensItem.NfsItmQtd = NfsItmQtd
		&sdtDadosItensItem.NfsItmValUnt = NfsItmValUnt
		&sdtDadosItensItem.NfsItmValTot = NfsItmValTot
		&sdtDadosItensItem.NfsItmDesc = NfsItmDesc
		&sdtDadosItens.Add(&sdtDadosItensItem)
	EndFor	
	
	For &sdtDadosItensItem in &sdtDadosItens
		
		if &wpNFSData.DadosNFSE.ProCod.IsEmpty()
			&wpNFSData.DadosNFSE.ProCod = &sdtDadosItensItem.NfsItmProCod
			&wpNFSData.DadosNFSE.ProGraCod = &sdtDadosItensItem.NfsItmProGraCod
		EndIf		
		
		if &NfsTribNac.IsEmpty() 
			&ProCod = &sdtDadosItensItem.NfsItmProCod
			do 'getClassificacaoFiscal'
			&NfsTribNac = &ProTribNac
			&NfsNbs = &NcmCod
		Endif
		
		if &NfsDisSer.IsEmpty()
			&NfsDisSer = &sdtDadosItensItem.NfsItmProNom.Trim()
		Else
			&NfsDisSer += ', ' +  &sdtDadosItensItem.NfsItmProNom.Trim()
		EndIf
	
		&wpNFSData.Itens.NfsItmCod = &sdtDadosItensItem.NfsItmCod
		&wpNFSData.Itens.NfsItmProCod = &sdtDadosItensItem.NfsItmProCod
		&wpNFSData.Itens.NfsItmProGraCod = &sdtDadosItensItem.NfsItmProGraCod
		&wpNFSData.Itens.NfsItmValTot = &sdtDadosItensItem.NfsItmValTot
		//		&wpNFSData.Itens.NfsItmEmbUnd = ''
		&wpNFSData.Itens.NfsItmValUnt = &sdtDadosItensItem.NfsItmValUnt
		&wpNFSData.Itens.NfsItmQtd = &sdtDadosItensItem.NfsItmQtd
		&wpNFSData.Itens.NfsItmProNom = &sdtDadosItensItem.NfsItmProNom
		//		&wpNFSData.Itens.ProRef = &sdtDadosItensItem.NfsItmProNom
		
		prcGravaItemNFSe.Call(&EmpCod, &NfsCod, &wpNFSData)
		
		&PedVlrItm += &sdtDadosItensItem.NfsItmValTot
	EndFor
	
	&wpNFSData.DadosNFSE.NfsItmValTot = &PedVlrItm
	&wpNFSData.DadosNFSE.NfsTribNac = &NfsTribNac 
	&wpNFSData.DadosNFSE.NfsNbs = &NfsNbs 
	
	&wpNFSData.DadosNFSE.NfsDisSer = &NfsDisSer	
	prcGravaDadosNFSe.Call(&EmpCod, &NfsCod, &wpNFSData)
	
Else
	prcTotalizaNFSe.Call(&EmpCod, &NfsCod)
Endif

sub 'getClassificacaoFiscal'
	For Each ORder EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		&ProTribNac = ProTribNac
		&NcmCod = NcmCod
		Exit
	EndFor

EndSub

			
]]></Source>
