      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MdfeCod
	
	If &CountCte = 1 and (MDFeTipEmt  = Mdfe_TipoEmitente.Prestador or MDFeTipEmt  = Mdfe_TipoEmitente.NaoPrestador) 
		MDFePgtFrt = Status_SimNao.Sim
		MDFeTomFrt = 1
	Else
		MDFePgtFrt = Status_SimNao.Nao
		MDFeTomFrt = 0
	EndIf
	
	MDfeUnd = &MDfeUnd
	MDFePsoBrt = &MDFePsoBrt
	MDFeVlrTot = &MDFeVlrTot
	MdfeIndCanalVerde = &MdfeIndCanalVerde
	MdfeIndCarregaPosterior = &MdfeIndCarregaPosterior
	MDFeTipCar = &MDFeTipCar
	MDFeProPre = &MDFeProPre
	MDFeProPreNcm = &MDFeProPreNcm
	//	MDFeLotDesGeo =  &MdfeLotGeoDst
	//	MDFeLotCarGeo = &MdfeLotGeoOri
	Exit
EndFor

commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
