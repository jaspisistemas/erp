        <Source><![CDATA[
&LogGUID = GUID.NewGuid()

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon124_DataEmissaoPedidoImportarXml, &TCon124_DataEmissaoPedidoImportarXml)

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	&TabCod = FilTabCod
	&TabPrmCod = FilTabPrmCod
	&TabColCod = FilTabColCod
	If &TabColCod.IsEmpty()
		&TabColCod = 1
	EndIF
	
	Exit
EndFor

	For Each Order tmpNFeCod
		Where tmpNFeCod = &tmpNfeCod
		//		&tmpDestxCod = tmpDestxCod
		&PedCliCod = tmpEmixCod
		//		&tmpNfeProTer = tmpNfeProTer
		//		&tmpImpEntSai = tmpImpEntSai
//		&LctCod = tmpLctCod
		&TmpPedNum = tmpPedNum
		&TmpnfeArqXml = tmpNfeArqXml
		//		&tmpNfeFatFilCod = tmpNfeFatFilCod
		//		tmpStsNF = 'S'
		
		&PedTraRedCod = tmpTraxCod
		Exit
	EndFor

	LeituraXmlDanfe.Call(&TmpnfeArqXml, &TNfeProc)
	
//	if &PedCod = 0 //JDF AGORA GERA O PEDCOD LA NA TELA.
//		&PedCod = UltimoCodigoEmpresa.Udp(domParCod.PEDIDO, &EmpCod, &FilCod)	
//	Endif

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
	    Where FilCod = &FilCod
	    Where PedCod = &pedCod
		
		DeletaItemPedidoCompra.Call(EmpCod, FilCod, PedCod, 0) //DELETA TUDO
		
		Exit
	When None
		New
			EmpCod = &EmpCod
		    FilCod = &FilCod
		    PedCod = &pedCod
			TabCod = &TabCod
			TabPrmCod = &TabPrmCod
			TabColCod = &TabColCod
		    LctCod = &LctCod
			If not &TmpPedNum.IsEmpty()
				PedNum = &TmpPedNum
			EndIf
			
			PedFatFilCod = &PedFatFilCod 
			
			&dhEmi = substr(&TNFeProc.NFe.infNFe.ide.dhEmi ,9,2) +'/'+ Substr(&TNFeProc.NFe.infNFe.ide.dhEmi,6,2) +'/'+ Substr(&TNFeProc.NFe.infNFe.ide.dhEmi,1,4)
			&NfeDtaEms = CtoD(&dhEmi)
			&PedHorEms = Substr(&TNFeProc.NFe.infNFe.ide.dhEmi, 12,8)
			
			if &TCon124_DataEmissaoPedidoImportarXml = 'S'
			    PedDtaEms = &NfeDtaEms
			    PedHorEms = &PedHorEms
			Else
				PedDtaEms = Serverdate()
			    PedHorEms = SysTime()
			Endif
			
			
			PedVenCod = &PedVenCod
			PedTipFrt.FromString(&TNfeProc.NFe.infNFe.transp.modFrete.ToString())
			PedCliCod = &PedCliCod
			
			PedCodOciRef = &PedCodOciRef
			if not &PedTraRedCod.IsEmpty()
				PedTraRedCod = &PedTraRedCod
				PedTraSaiCod = &PedTraRedCod
			Else
				PedTraRedCod = 1
				PedTraSaiCod = 1
			Endif
			
			PedSts = Status_Pedido.CANCELADO
			PedStsFin = Status_Financeiro.CANCELADO
			
			PedFrpPgtoCod = 1 //DUPLICATA
			
			do 'getPrazoColuna'
			if &PedPraCod.IsEmpty()
				PedPraCod = 1
				PedPraParNom = '001'
			Else
				PedPraCod = &PedPraCod
				PedPraParNom = &PedPraParNom
			EndIF
			
			PedFicCod = 0
			PedStsCrd = Status_Autorizado.NAO_AUTORIZADO
			PedStsAna = Status_Analisado.NaoAnalisado
			PedBlq = Status_SimNao.Nao
			PedStsGer = &PedStsGer
			
		EndNew
	EndFor
Commit

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon015_DuplicadoCompra, &DuplicadoCompra) //ACEITA PRODUTO EM DUPLICIDADE NA COMPRA

For Each Order tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNfeCod
	
	//Atualiza
	&auxCount += 1
	If &auxCount > 10 and &Total > 0
		&Count += 1
		&Percentual = round((&Count / &Total) * 100, 0)
		&auxCount = 0
		
		If &Percentual >= 100
			&Percentual = 99
		EndIf
		&ProgressLogXml = &Pgmname + ' ' + tmpProRef
		do 'Atualiza'
	EndIF				
	//Atualiza
	
	&ProCod = tmpProCod
	&ProGraCod = tmpProGraCod
	if tmpProQtdCmpEmb <> 0
		&ProForQtdEmb = tmpProQtdCmpEmb
	Else
		&ProForQtdEmb = RetornaQtdEmbalagem.Udp(&EmpCod, &PedCliCod, &ProCod)
	EndIF
		
	&PedQtdEmb = tmpPedQtd	
	 Do case
        Case &ProForQtdEmb > 0
            &PedQtd = ((&PedQtdEmb * &ProForQtdEmb)) 
        Case &ProForQtdEmb < 0 and &PedQtdEmb > 0
            &PedQtd = (&PedQtdEmb / (&ProForQtdEmb*-1))  
        Otherwise
            &PedQtd = &PedQtdEmb
    EndCase

	&PedVlrUnt = tmpPedVlrUnt
	&PedVlrItm = tmpPedVlrTot
	&PedItmVlrDsc = tmpPedVlrDsc
	&PedItmVlrAcr = tmpProVlrFrt + tmpProVlrOut
	
	&PedItmIcm = 0
	&PedItmIcmSt = 0
	&PedItmIcmStPob = 0
	&PedItmDsc = 0
	&PedItmAcr = 0
	&PedItmIpi = 0
	
	&PedItmVlrIcmStPob = tmpProVlrFCPIcmsSt
	
	&PedItmPis = tmpProPerPIS
	&PedItmCofins = tmpProPerCOFINS
	
	//PIS e COFINS
	&PedItmAjuPisBas = 0
	&PedItmAjuPisVlr = 0
	&PedItmAjuCofinsVlr = 0
	IF tmpProBasPIS > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasPIS
		&PedItmAjuPisBas = 100 - (tmpProBasPIS/tmpPedVlrTot) * 100
		&PedItmAjuPisBas = &PedItmAjuPisBas *-1
		
		&Moeda = round(tmpProBasPIS * tmpProPerPIS * 0.01, 2)	
		
		if &Moeda <> tmpProVlrPIS and &Moeda > 0 and tmpProVlrPIS > 0
			&PedItmAjuPisVlr = 100 - (tmpProVlrPIS/&Moeda ) * 100
			&PedItmAjuPisVlr = &PedItmAjuPisVlr*-1
		Endif
	
		&Moeda = round(tmpProBasPIS * tmpProPerCOFINS * 0.01, 2)	
		
		if &Moeda <> tmpProVlrCOFINS and &Moeda > 0 and tmpProVlrCOFINS > 0
			&PedItmAjuCofinsVlr = 100 - (tmpProVlrCOFINS/&Moeda ) * 100
			&PedItmAjuCofinsVlr = &PedItmAjuCofinsVlr*-1
		Endif
		
	Endif

	
	
	//IPI
	&PedItmAjuIpiBas = 0
	&PedItmIpi = tmpProPerIpi
	IF tmpProBasVlrIpi > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasVlrIpi
		&PedItmAjuIpiBas = 100 - (tmpProBasVlrIpi/tmpPedVlrTot) * 100
		&PedItmAjuIpiBas = &PedItmAjuIpiBas*-1
		
		&Moeda = round(tmpProBasVlrIpi * tmpProPerIpi * 0.01, 2)	
		
		if &Moeda <> tmpProVlrIpi and &Moeda > 0 and tmpProVlrIpi > 0
			&PedItmAjuIpiVlr = 100 - (tmpProVlrIpi/&Moeda ) * 100
			&PedItmAjuIpiVlr = &PedItmAjuIpiVlr*-1
		Endif
	Endif		
	
	//ICMS
	&PedItmAjuIcmBas = 0	
	&PedItmAjuIcmVlr = 0
	&PedItmIcm = tmpProPerIcm
	IF tmpProBasVlrIcm > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasVlrIcm
		&PedItmAjuIcmBas = 100 - (tmpProBasVlrIcm/tmpPedVlrTot ) * 100
		&PedItmAjuIcmBas = &PedItmAjuIcmBas*-1
		
		&Moeda = round(tmpProBasVlrIcm * tmpProPerIcm * 0.01, 2)	
		
		if &Moeda <> tmpProVlrIcm and &Moeda > 0 and tmpProVlrIcm > 0
			&PedItmAjuIcmVlr = 100 - (tmpProVlrIcm/&Moeda ) * 100
			&PedItmAjuIcmVlr = &PedItmAjuIcmVlr*-1
		Endif
	Endif

	//ICMS ST
	&PedItmAjuIcmStBas = 0	
	&PedItmAjuIcmStVlr = 0
	&PedItmIcmSt = tmpProPerIcmSt
	IF tmpProBasVlrIcmSt > 0 and tmpPedVlrTot > 0 and tmpPedVlrTot <> tmpProBasVlrIcmSt
		&PedItmAjuIcmStBas = 100 - (tmpProBasVlrIcmSt/tmpPedVlrTot ) * 100
		&PedItmAjuIcmStBas = &PedItmAjuIcmStBas*-1
		
		&Moeda = round(tmpProBasVlrIcmSt * tmpProPerIcmSt * 0.01, 2)	
		
		if &Moeda <> tmpProVlrIcmSt and &Moeda > 0 and tmpProVlrIcmSt > 0
			&PedItmAjuIcmStVlr = 100 - (tmpProVlrIcmSt/&Moeda ) * 100
			&PedItmAjuIcmStVlr = &PedItmAjuIcmStVlr*-1
		Endif
	Endif

	if not &PedItmVlrAcr.IsEmpty() and &PedVlrItm > 0
		&PedItmAcr = round((&PedItmVlrAcr * 100) / &PedVlrItm, 4)
	EndiF
	
	If not &PedItmVlrDsc.IsEmpty() and &PedVlrItm > 0
		&PedItmDsc = round((&PedItmVlrDsc * 100) / &PedVlrItm, 4)
	EndIF
	
	If not &PedItmVlrIcmStPob.IsEmpty() and &PedVlrItm > 0
		&PedItmIcmStPob = round((&PedItmVlrIcmStPob * 100) / &PedVlrItm, 4)
	EndiF

	&PedItmCod = 0
	
	&sdtAddPedidoProduto = new()			
	&sdtAddPedidoProduto.PedItmAcr = &PedItmAcr
	&sdtAddPedidoProduto.PedItmDsc = &PedItmDsc
	&sdtAddPedidoProduto.PedItmIpi = &PedItmIpi
	&sdtAddPedidoProduto.PedItmIcmSt = &PedItmIcmSt
	&sdtAddPedidoProduto.PedItmIcmStPob = &PedItmIcmStPob
	&sdtAddPedidoProduto.PedItmIcm = &PedItmIcm
	&sdtAddPedidoProduto.PedQtdEmb = &PedQtdEmb
	&sdtAddPedidoProduto.PedProEmbQtd = &ProForQtdEmb
	&sdtAddPedidoProduto.PedItmCmp = &PedItmCmp
	&sdtAddPedidoProduto.PedItmAjuIpiBas = &PedItmAjuIpiBas
	&sdtAddPedidoProduto.PedItmAjuIcmBas = &PedItmAjuIcmBas
	&sdtAddPedidoProduto.PedItmAjuIcmStBas = &PedItmAjuIcmStBas
	&sdtAddPedidoProduto.PedItmAjuPisBas = &PedItmAjuPisBas
	&sdtAddPedidoProduto.PedItmPis = &PedItmPis
	&sdtAddPedidoProduto.PedItmCofins = &PedItmCofins
	
	&sdtAddPedidoProduto.PedItmAjuIcmVlr = &PedItmAjuIcmVlr
	&sdtAddPedidoProduto.PedItmAjuCofinsVlr  = &PedItmAjuCofinsVlr
	&sdtAddPedidoProduto.PedItmAjuIcmsStPobVlr  = &PedItmAjuIcmsStPobVlr
	&sdtAddPedidoProduto.PedItmAjuIcmStVlr  = &PedItmAjuIcmStVlr
	&sdtAddPedidoProduto.PedItmAjuIpiVlr  = &PedItmAjuIpiVlr 
	&sdtAddPedidoProduto.PedItmAjuPisVlr  = &PedItmAjuPisVlr
	
	GravaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &ProCod, &ProGraCod, &PedQtd, &PedVlrUnt, &sdtAddPedidoProduto, &sdtProdutoLote, &inseridoMensagem, &AlteradoMensagem, &wwpContextUserName, 'N')
	GravaItemPedidoCompra_Cfop.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, tmpEntCFOP, tmpNfeSitCod, false, &wwpContextUserName)
EndFor

commit

//AtualizaTotais Pedido
AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')
AtualizaEstoqueGerencialCompra.Call(&EmpCod, &FilCod, &PedCod, &PedDtaFat, &EmpCod,  Status_Pedido.ABERTO)

sub 'getPrazoColuna'
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		Where TabColCod = &TabColCod
		
		&PedPraCod = TabColPrzPad
	EndFor
	
	RetornaPrimeiraParcela.Call(&EmpCod, &PedPraCod, &PedPraParNom)
 EndSUb


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		Exit
	endfor
	
	commit	
EndSub


Sub 'Exception_handler'
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXexceptionType',&GXexceptionType)
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionDetails',&GXExceptionDetails)
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionStack',&GXExceptionStack)
Endsub

Sub 'Error_handler'
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Error_handler: &Err',&Err.ToFormattedString())
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBErr',&gxDBErr.ToFormattedString())
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Error_handler: &GxDbSqlState',&GxDbSqlState)
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBTxt',&gxDBTxt)
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxOper',&gxOper)
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrTbl',&gxErrTbl)
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrOpt',&gxErrOpt.ToFormattedString())
Endsub
