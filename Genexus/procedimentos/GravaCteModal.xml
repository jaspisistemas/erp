      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	If &WizardData.Modal.CtePosDup = Status_SimNao.Sim  // Grava como aberto por quando clicar em transmitir vai gravas as duplicatas e alterar para fechado
		CteStsFin = Status_Financeiro.ABERTO
	Else
		CteStsFin = Status_Financeiro.CANCELADO //padrao é cancelado quando nao gera duplicata
	EndIf
	
	CtePosDup = &WizardData.Modal.CtePosDup	
	CteModRodRNTRC = &WizardData.Modal.CteModRodRNTRC
	CteModRodCol = &WizardData.Modal.CteModRodCol
	CteModRodNroRegEst = &CteModRodNroRegEst
	CteModRodTaf = &CteModRodTaf
	CteTipFrt = &CteTipFrt
	CteDtaHorVia = &CteDtaHorVia
	Exit
EndFor

commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
