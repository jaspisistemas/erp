      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Soma = 0
&Peso = 2

for &Contador = Len(&String) to 1 step -1
    &Soma += val(substr(&String,&Contador,1)) * &Peso
    if &Peso < 9 
        &Peso += 1
    else
        &Peso = 2
    Endif        
EndFor

&Mod11 = (int(&Soma/11) * 11)
&Mod11 = &soma - &Mod11 

&Digito = 11 - &Mod11

if (&Digito > 9)
    &Digito = 0
Endif
&Retorno = str(&Digito,1)
]]></Source>
