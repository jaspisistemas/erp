      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For &SdtAlojamentoWebItem in &SdtAlojamentoWeb
	If &SdtAlojamentoWebItem.Select = true
		UltimoCodigoEmpresa.Call(domParCod.BIOMETRIA,&EmpCod,0,&BioCod)
		New
			EmpCod = &EmpCod
			BioCod = &BioCod
			BioFilCod = &BioFilCod
			BioAloLin = &SdtAlojamentoWebItem.AloLin
			BioQtdAmo = &BioQtdAmo
			BioTotPeso = &BioPesTot
			BioObs ='Dados Replicados'
			BioDta = &BioDta
			BioHor = ServerNow()
			BioAloCod = &SdtAlojamentoWebItem.AloCod
			
		EndNew
		commit
		AtualizaStatusAlojamento.Call(TrnMode.Insert,&EmpCod,&SdtAlojamentoWebItem.AloCod,&SdtAlojamentoWebItem.AloUniProCod)
	EndIf
EndFor
	
]]></Source>
