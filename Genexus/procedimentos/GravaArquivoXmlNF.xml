      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NfeArqXml = ''
&xmlNFe.Open(&ArquivoPronto)    
Do While  not &xmlNFe.EOF
    &NfeArqXml += &xmlNFe.ReadRawXML()
    &xmlNFe.Read()
Enddo
&xmlNFe.Close()

If &NfeArqXml <> ''
	LeituraXmlDanfe.Call(&NfeArqXml, &TNfeProc)
	&dhEmi = substr(&TNFeProc.NFe.infNFe.ide.dhEmi ,9,2) +'/'+ Substr(&TNFeProc.NFe.infNFe.ide.dhEmi,6,2) +'/'+ Substr(&TNFeProc.NFe.infNFe.ide.dhEmi,1,4)
	&NfeDtaEms = CtoD(&dhEmi)
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		NfeDtaEms = &NfeDtaEms
		NfeDtaDsp = &NfeDtaEms
		NfeArqXml = &NfeArqXml
		
		if NfeProTer = Nota_ProPriaTerceira.PROPRIA or NfePedCod = 0
			NfeDtaFat = &NfeDtaEms
			NfeDtaFat_Ano = &NfeDtaEms.Year()
			NfeDtaFat_Mes = &NfeDtaEms.Month()
		Endif	
	
		Exit
	EndFor
EndIF

commit

]]></Source>
