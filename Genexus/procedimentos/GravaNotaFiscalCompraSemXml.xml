      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order tmpNFeCod
	Where tmpNFeCod = &tmpNfeCod
		&tmpModCod = tmpModCod
		&tmpNfeDtaDsp = tmpNfeDtaDsp
		&tmpNfeDtaEms = tmpNfeDtaEms
		&tmpNfeChv = tmpNfeChv
		&tmpNfeSer = tmpNfeSer
		&tmpNfeNum = tmpNfeNum
		&tmpNfeFatFilCod = tmpNfeFatFilCod
		
		&tmpTotPro = tmpTotPro
		&tmpTotFrt = tmpTotFrt
		&tmpTotSeg = tmpTotSeg
		&tmpTotOut = tmpTotOut
		&tmpTotDsc = tmpTotDsc
		&tmpTotPed = tmpTotPed
		&tmpTotBasIcm = tmpTotBasIcm
		&tmpTotVlrIcm = tmpTotVlrIcm
		&tmpTotBasSt = tmpTotBasSt
		&tmpVlrSt = tmpVlrSt
		&tmpTotIpi = tmpTotIpi
		&tmpTotNFe = tmpTotNFe
		
		&tmpNfePesBrt = tmpNfePesBrt
		&tmpNfeQtdVol = tmpNfeQtdVol
	Exit
EndFor

//RetornaFilialBaseImposto.Call(&EmpCod, &tmpNfeFatFilCod, &FilBasImp )

//CAPA DA NFE		
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	UltimoCodigoEmpresa.Call(domParCod.NOTAFISCAL, &EmpCod, &tmpNfeFatFilCod, &NfeCod)
	
	New
		EmpCod = &EmpCod
		FilCod = &tmpNfeFatFilCod
		NfeCod = &NfeCod
		NfeNum = &tmpNfeNum
		NfeSer = &tmpNfeSer
		NfeFilCod = &FilCod
		NfePedCod = &PedCod
		NfeSts = Status_NFe.Autorizada
		NfeProTer = Nota_ProPriaTerceira.TERCEIROS 
		NfeDtaEms = &tmpNfeDtaEms
		NfeHorEms = '00:00:00'
		NfeDtaDsp = &tmpNfeDtaDsp
		NfeDtaFat = &tmpNfeDtaDsp
		NfeDtaFat_Ano = &tmpNfeDtaDsp.Year()
		NfeDtaFat_Mes = &tmpNfeDtaDsp.Month()
		NfeCliCod = PedCliCod
		
		//USAR OUTRO NOME DO CADASTRO DO CLIENTE
		if PedCliRazNF.IsEmpty() or PedCliRazNF.IsNull()
			NfeCliRaz = PedCliRaz
		Else
			NfeCliRaz = PedCliRazNF
		Endif			
				
		NfeEntSai = Status_EntradaSaida.Entrada
		NfeChv = &tmpNfeChv
		ModCod = &tmpModCod
		NfeLctCod = LctCod
		NfeEntSai = LctAtuSal
		
		//CLIENTE
		NfeCliEnd = PedCliEntLog
		NfeCliEndNro = PedCliEntNro
		NfeCliBai = PedCliEntBai
		NfeCliCidCod = PedCliCidCod
		NfeCliCidNom = PedCliEntCidNom
		NfeCliCidIbge = PedCliEntCidIbge
		NfeCliCidUF = PedCliEntUfeCod
		NfeCliCep = PedCliEntCep
		
		NfeCliFon = FormataFONE.Udp(PedCliPrmFon)
		
		NfeCliTipPes = PedCliTip
		if PedCliTip = TipoPessoa.JURIDICA
			NfeCliCnpj = PedCliCnpj
			NfeCliIns = PedCliInsEst
			NfeCliSuf = PedCliSuf
		else
			NfeCliCpf = PedCliCpf
		endif
		
		//TRANSPORTE
		//NfsTipFrt    = '9'                      // Tipo Frete N (1.0)    
		//NfsTraCod    = PedTraCodSai                      // Cod.Transp. N (4.0)    				
		//NfsTraNom   = trim(PedTraNomDsp) //  Transportadora C ( 40 )    
		//NfsTraEnd   = PedTraEndDsp    //  Transp-Endereço C ( 40 )    
		//NfsTraCidNom= PedTraCidNomDsp //  Trans-Cidade C ( 40 )    
		//NfsTraCidEst= PedTraCidUfeDsp //  Transp-Ufe C ( 2 )    
		//NfsTraCgc   = udp(PSICRT79, PedTraCgcDsp)    //  Transp.CNPJ C ( 16 )    
		//NfsTraCpf   = udp(PSICRT79, PedTraCpf)    //  Transp.CNPJ C ( 16 )    
		//NfsTraIns   = PedTraInsDsp    //  Trans.Insc. C ( 16 )    
				
		NfeVlrTot = &tmpTotNFe
		NfeVlrTotFrt = &tmpTotFrt
		NfeVlrTotIpi = &tmpTotIpi
		NfeVlrTotPro = &tmpTotPro
		NfeVlrTotSeg = &tmpTotSeg
		NfeVlrTotOutDsp = &tmpTotOut
		NfeVlrTotDsc = &tmpTotDsc
		NfeVlrTotPdg = &tmpTotPed
		NfeVlrTotBasIcms = &tmpTotBasIcm
		NfeVlrTotIcms = &tmpTotVlrIcm
		NfeVlrTotBasIcmsSt = &tmpTotBasSt
		NfeVlrTotIcmsSt = &tmpVlrSt
		
		NfeQtdVol    = &tmpNfeQtdVol                      // Qtd.Volumes N (2.0)    
		If &tmpNfeQtdVol > 0
			NfeEspVol = 'CAIXAS'
		EndIF
	
		NfePesBrt = &tmpNfePesBrt                   // PsoBruto N (9.2)     
		NfePesLiq = &tmpNfePesBrt                   // Pso.Liquido N (9.2)    		
	EndNew
	
	Exit
EndFor

commit

&count = 0
For Each Order tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNfeCod
	Where tmpPedQtd > 0
	&count += 1
	New
		EmpCod = &EmpCod
		FilCod = &tmpNfeFatFilCod
		NfeCod = &NfeCod
		NfeItmCod = &count
		NfeProCod = tmpProCod
		NfeProNom = tmpProNom
		NfeProGraCod = tmpProGraCod
		NfeNcmCod = tmpNcmCod
		NfeNcmCest = tmpNcmCEST

		&tmpEntCFOP = retornaSoNumeros.Udp(tmpCFOP)
		NfeCfoCod = Substr(&tmpEntCFOP,1,1) + '.' + Substr(&tmpEntCFOP,2,3)
		
		//NfeOriTriCod = tmp
		NfeSitCod = tmpNfeSitCod
		
		NfeEmbUnd = tmpUnd
		NfeProQtd = tmpPedQtd
		
		NfeProDadAdi = tmpNfeProDadAdi
		//tmpMarCodNom
		
		NfeOriTriCod = tmpNfeOriCod
		NfeProVlrUnt = tmpPedVlrUnt
		NfeProVlrDsc = tmpPedVlrDsc
		//tmpPedVlrUntNov
		//tmpPedVlrTotNov
		NfeProVlrFrt = tmpProVlrFrt
		NfeProVlrTot = tmpPedVlrTot
		
		//tmpProPerRedIcm
		//tmpProPerIcm
		if tmpProVlrIcm > 0
			NfeProVlrIcms = tmpProVlrIcm
			NfeProBasIcms = tmpProBasVlrIcm
			NfeProTaxIcms = tmpProPerIcm
		Endif
	
		//DIFERIMENTO
		NfeProTaxDif = 0
		NfeProVlrDif = 0
		//tmpNfeProTaxMvaSt
		
		if tmpProVlrIcmSt > 0
			NfeProBasIcmsSt = tmpProBasVlrIcmSt
			NfeProTaxRedIcmsSt = tmpProPerRedIcmSt
			NfeProTaxIcmsSt = tmpProPerIcmSt
			NfeProVlrImcsSt = tmpProVlrIcmSt
		Endif
	
		//IPI PIS COFINS
		if tmpProVlrIpi > 0
			NfeProBasIpi = tmpProBasVlrIpi
			NfeProTaxIpi = tmpProPerIpi
			NfeProVlrIpi = tmpProVlrIpi
		Else
			NfeProBasIpi = 0
			NfeProTaxIpi = 0
			NfeProVlrIpi = 0
		Endif
		
		//tmpNfeCstPIS
		if tmpProVlrPIS > 0
			NfeProPisRed = tmpProPerRedPis
			NfeProBasPIS = tmpProBasPIS
			NfeProTaxPIS = tmpProPerPIS
			NfeProVlrPIS = tmpProVlrPIS
		Endif
	
		NfeCstPIS = tmpNfeCstPIS
		NfeCstCofins = tmpNfeCstCofins
	
		//tmpNfeCstCofins
		if tmpProVlrCOFINS > 0
			NfeProBasCofins = tmpProBasCofins
			NfeProTaxCofins = tmpProPerCOFINS
			NfeProCofinsRed = tmpProPerRedCofins
			NfeproVlrCofins = tmpProVlrCOFINS
		Endif
	
	EndNEw
EndFor


commit


AtualizaTotaisNFe.Call(&EmpCod, &tmpNfeFatFilCod, &NfeCod, 0)	
]]></Source>
