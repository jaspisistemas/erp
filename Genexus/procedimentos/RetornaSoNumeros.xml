        <Source><![CDATA[&Pos = 1
&Numeros = ''

&Final = &Caractere.Length()

Do While &Pos <= &Final
    if substr(&Caractere,&Pos,1) >= '0' and substr(&Caractere,&Pos,1) <= '9'
        &Numeros += substr(TRIM(&Caractere),&Pos,1)
    Endif
    &Pos += 1
EndDo
]]></Source>
