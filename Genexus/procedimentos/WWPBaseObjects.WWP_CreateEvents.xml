      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[Do 'DeleteGamEvents'

&GAMEvents = GAMEvents.User_Insert
Do 'CreateGamEvents'

&GAMEvents = GAMEvents.User_Update
Do 'CreateGamEvents'

&GAMEvents = GAMEvents.User_Delete
Do 'CreateGamEvents'

Sub 'DeleteGamEvents'
	
	&GAMEventSubscriptionCollection = GAMRepository.GetEventSubscriptions(&GAMEventSubscriptionFilter, &GAMErrorCollection)
	For &GAMEventSubscription in &GAMEventSubscriptionCollection
		&GAMEventSubscription.Delete()
	EndFor
	commit
	
EndSub

Sub 'CreateGamEvents'
		    
    &GAMEventSubscription = new()
    &GAMEventSubscription.Description = 'GAM Sync'
    &GAMEventSubscription.Event = &GAMEvents
    java [!&FileName!] = "awwp_synchandler.class";
    java [!&ClassName!] = [!&KBPackageName!] + ".wwpbaseobjects.awwp_synchandler";
    csharp [!&FileName!] = "wwpbaseobjects.awwp_synchandler.dll";
    csharp [!&ClassName!] = "GeneXus.Programs.wwpbaseobjects.awwp_synchandler";

	&GAMEventSubscription.FileName = &FileName
    &GAMEventSubscription.ClassName = &ClassName
    &GAMEventSubscription.MethodName = !"execute"
    &GAMEventSubscription.Save()
	
    if &GAMEventSubscription.Success()
	    commit
	    // Subscription activation:
	    &Ok = GAMRepository.SubscribeEvent(&GAMEventSubscription.Id, &GAMErrorCollection)
	    if &Ok
		    do 'ConvertGAMErrorToMessages'
		    commit
	    else
			WWP_Logger.Error(Format(!"GAMEvents: %1 - %2, Fail to activate event: %3", &GAMEvents, GAMEvents.EnumerationDescription(&GAMEvents), &Messages.ToJson()), &Pgmname)
	    endif
    else
	    &GAMErrorCollection = &GAMEventSubscription.GetErrors()
	    do 'ConvertGAMErrorToMessages'
		WWP_Logger.Error(Format(!"GAMEvents: %1 - %2, Fail to subscribe: %3", &GAMEvents, GAMEvents.EnumerationDescription(&GAMEvents), &Messages.ToJson()), &Pgmname)
    endif

EndSub

Sub 'ConvertGAMErrorToMessages'
	
	for &GAMError in &GAMErrorCollection
		&Message = new()
		&Message.Type = MessageTypes.Error
		&Message.Description = &GAMError.Message
		&Message.Id = Format(!"GAM%2", &GAMError.Code)
		&Messages.Add(&Message)
	endfor

EndSub
]]></Source>
