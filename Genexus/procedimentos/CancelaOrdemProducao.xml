      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProgressIni = serverNow()
&Total = 0
&Count = 0
&Percentual = 0
do 'Atualiza'

For Each Order EmpCod, FilCod, OrdCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod 
	Where OrdCod = &OrdCod
	
	&Percentual = 20
	do 'Atualiza'
	
	AtualizaEstoqueGerencialVenda_submit.Call('AtualizaEstoqueGerencialVenda_submit', EmpCod, FilCod, OrdSaiPedCod, &PedDtaEms, &PesCod, Status_Pedido.ABERTO, false)
	AtualizaEstoqueGerencialVenda_submit.Call('AtualizaEstoqueGerencialVenda_submit', EmpCod, FilCod, OrdSaiPedCod, &PedDtaEms, &PesCod, Status_Pedido.CANCELADO, false)
	
	&Percentual = 50
	do 'Atualiza'
	
	AtualizaEstoqueGerencialCompra.Call(EmpCod, FilCod, OrdEntPedCod, &PedDtaEms, &PesCod, Status_Pedido.ABERTO)
	AtualizaEstoqueGerencialCompra.Call(EmpCod, FilCod, OrdEntPedCod, &PedDtaEms, &PesCod, Status_Pedido.CANCELADO)
	
	&Percentual = 75
	do 'Atualiza'
	
	
	OrdSts = Status_Producao.Cancelada
	Exit
EndFor

Commit

&Percentual = 100
do 'Atualiza'
	

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
		Endnew
	endfor

	commit
EndSub
]]></Source>
