      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&MEnsagem = ''

For Each Order EmpCod, FilCod, FrtDoc, FrtTraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where FrtDoc = &FrtDoc
	Where FrtTraCod = &FrtTraCod
    where FrtCod <> &FrtCod
  
        &MEnsagem = &MEnsagem.Trim() + newLine() + 'Encontra-se já lançado outro conhecimento de Frete com o mesmo Nº Documento e Transportadora. Seq:' + trim(str(FrtCod)) + '!'
EndFor


]]></Source>
