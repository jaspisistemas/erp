      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//LER AS CONFIGURACOES
Do Case
	CAse &OqueFazer =  'L' //LER
		
		&PadObs = ''
	    For Each Order PadRotLin, PadPesCod, PadEmpCod
		    Where PadRotLin = &PadRotLin
		    Where PadPesCod = &PadPesCod
			Where PadEmpCod = &PadEmpCod
	        &PadObs = PadObs
			&PadDtaMod = PadDtaMod
			&PadDtaHorMod = PadDtaHorMod
			
			if PadTemPer.IsEmpty() or PadTemPer.IsNull()
				PadTemPer = &PadTemPer 
				Commit			
			Else
				&PadTemPer = PadTemPer
			Endif	
			
			Exit
	    EndFor
	CAse  &OqueFazer =  'G' //GRAVAR
		&PadDtaHorMod = now()
		&PadDtaMod =  serverdate()
	    For Each Order PadRotLin, PadPesCod, PadEmpCod
		    Where PadRotLin = &PadRotLin
		    Where PadPesCod = &PadPesCod
			Where PadEmpCod = &PadEmpCod
	        PadObs = &PadObs
			PadDtaMod = &PadDtaMod
			PadDtaHorMod = &PadDtaHorMod
			PadTemPer = &PadTemPer
	    when none
	        new
	            PadRotLin = &PadRotLin
	            PadPesCod = &PadPesCod
				PadEmpCod = &PadEmpCod
	            PadObs = &PadObs
				PadTemPer = &PadTemPer
				PadDtaMod = &PadDtaMod
				PadDtaHorMod = &PadDtaHorMod
	        EndNew    
	    EndFor
		
		commit
		
	CAse  &OqueFazer =  'X' //APAGAR
	    For Each Order PadRotLin, PadPesCod, PadEmpCod
		    Where PadRotLin = &PadRotLin
		    Where PadPesCod = &PadPesCod
			Where PadEmpCod = &PadEmpCod
			delete
		EndFor
	
		Commit
EndCase
	
	
]]></Source>
