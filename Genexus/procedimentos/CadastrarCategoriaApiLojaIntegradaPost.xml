      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[LoadWWPContext.Call(&Context)
&PesCod = &Context.PesCod

HostWebServiceLojaIntegrada.Call(&Host, &BaseUrl, &Port,&LojVirUsr,&LojVirSen,&LojVirApiKey,&LojVirToken)

&HttpClient.Host = &Host //servidor
&HttpClient.Secure = 1
&httpclient.AddHeader(!'Content-type',!'application/json')
&String = '/v1/categoria?&chave_api='+trim(&LojVirApiKey)+'&chave_aplicacao='+trim(&LojVirToken)

&httpclient.AddString(&sdtCategoriaLojaIntegrada.toJson())
&HttpClient.Execute('POST',&String)

padraoUsuario.Call('G', '#LOJAINTEGRADACATEGORIA', &PesCod, &EmpCod, &HttpClient.toString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
padraoUsuario.Call('G', '#LOJAINTEGRADACATEGORIAPARAMETRO', &PesCod, &EmpCod, &sdtCategoriaLojaIntegrada.toJson(), &PadDtaMod)  // Grava PARAMETRO como um LOG para Consulta
//################################# sem erro de comunicação ################################################################################

Do Case
	Case &HttpClient.ErrCode = 0  //HTTP_CREATED  Operação realizada com sucesso
		&sdtCategoriaLojaIntegrada.fromJson(&HttpClient.toString())  // retorna dados de Saida
		Do 'AtualizaDadosRetorno'
		&IsSucesso = True
	Otherwise
		&IsSucesso = False
EndCase
	
Sub 'AtualizaDadosRetorno'
	
	For Each Order EmpCod,GrupCod
		Where EmpCod = &EmpCod
		Where GrupCod = &sdtCategoriaLojaIntegrada.id_externo
		GrupLojVirIntId = &sdtCategoriaLojaIntegrada.id
		GrupLojVirIntSeo = &sdtCategoriaLojaIntegrada.seo
		GrupLojVirIntUri = &sdtCategoriaLojaIntegrada.resource_uri
		commit
		
	EndFor
EndSub
]]></Source>
