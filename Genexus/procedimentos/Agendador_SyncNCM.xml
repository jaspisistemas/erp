      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PaginaEspecifica = 1
&IsExecutou = false
Do while &PaginaEspecifica > 0
	
	msg('Syncroniza NCM: Pag: ' + trim(str(&PaginaEspecifica)), status)
	HostWebServiceJaspiADM.Call(&EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	&Location = GetLocation('ppJASPI_Ncm_V2') //objeto externo onde foi importado o WSDL no GX XEV1 
	&Location.Host = &EmpWebHost //servidor 
	&Location.Port = &EmpWebPor //porta  
	&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
	&Location.Secure = false //false 
	&Location.CancelOnError = 2 //tratar exceção do WS 	
	
	&ppJASPI_Ncm_V2sdtEstruturaNcm_V2 = &ppJASPI_NCM_V2.Execute(&EmpSyncNcm, &EmpCodSec, &PaginaEspecifica)
	
	If GetSOAPErr()= 0
		msg('Syncronizado Gravar Pag: ' + trim(str(&PaginaEspecifica)), status)
		prcWbsNCM_V2.Call('prcWbsNCM_V2_age', &EmpCod, &PaginaEspecifica, &ppJASPI_Ncm_V2sdtEstruturaNcm_V2, &PaginaEspecifica)
		&IsExecutou = true
	Else 
		&mensagem = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&mensagem += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&mensagem, status) 
	EndIf
EndDo
]]></Source>
