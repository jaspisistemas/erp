      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&sdtPedidos.Clear()

if &NfeNum <> 0
	For Each order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where NfeNum = &NfeNum
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		
		&FilCod = NfeFilCod
		&PedCod = NfePedCod
		&Localizado = 'NF: ' + trim(str(NfeNum)) + ' FIL.: ' + trim(str(FilCod))
		do 'loadPedido'
		
	EndFor	

	For Each order EmpCod, FilCod, NfeCod, NfeSelPedCod
		Where EmpCod = &EmpCod
		Where NfeNum = &NfeNum
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		
		&FilCod = NfeFilCod
		&PedCod = NfeSelPedCod
		&Localizado = 'NF: ' + trim(str(NfeNum)) + ' FIL.: ' + trim(str(FilCod))
		do 'loadPedido'
		
	EndFor	
EndiF



sub 'loadPedido'
	For Each order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&sdtPedidosItem = new()
		if PedCliCodRaz.Length() > 40
			&sdtPedidosItem.PedCliCodRaz = substr(PedCliCodRaz,1,40) + '..' //#Gordinho falou pra diminuir
		else
			&sdtPedidosItem.PedCliCodRaz = PedCliCodRaz
		EndIf
		&sdtPedidosItem.PedCod = PedCod
		&sdtPedidosItem.PedDtaDsp = PedDtaDsp
		&sdtPedidosItem.PedDtaEms = PedDtaEms
		&sdtPedidosItem.PedDtaFat = PedDtaFat
		&sdtPedidosItem.LctTip = LctTip
		&sdtPedidosItem.PedVlrLiq = PedVlrLiq
		&sdtPedidosItem.PedStsFin = PedStsFin
		&sdtPedidosItem.PedNum = PedNum
		&sdtPedidosItem.Localizado = &Localizado
		If PedVenCodRaz.Length() > 25
			&sdtPedidosItem.PedVenCodRaz = substr(PedVenCodRaz,1,25) + '...' //#25TaBom
		else
			&sdtPedidosItem.PedVenCodRaz = substr(PedVenCodRaz,1,25)
		EndIf
		&sdtPedidos.Add(&sdtPedidosItem)
		Exit
	Endfor
	
endSub
]]></Source>
