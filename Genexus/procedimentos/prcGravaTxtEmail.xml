      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfiguracoesPastas.Call(&EmpCod,&FilCod,&SdtConfiguracoesPasta)

&dia = day(Serverdate())
&mes = month(Serverdate())

&RemNomArq = 'Emails'+padL(Str(&dia),2,'0')+padL(str(&mes),2,'0') +trim(str(&PesCod))+ '.txt'
&nomArq = &SdtConfiguracoesPasta.PastaDiretorioCobFis+&RemNomArq.Trim() 
&link = &SdtConfiguracoesPasta.PastaDiretorioCobVir+ &RemNomArq.Trim()

&file.Source = &nomArq
If &file.Exists()
	&file.Delete()
Endif
&file.Close()


&ResultadoAbertura = DfwOpen(&NomArq,'','', 0, 'ISO-8859-1') 

For &sdtEmailItem in &sdtEmail
	if &TipoVarchar = 'A'
		&ResultadoNext=  dfwptxt(&sdtEmailItem.EmlUrl, 400)// Grava Linha 
		&ResultadoNext = dfwnext()
	Endif
EndFor

if &TipoVarchar = 'B'
	&ResultadoNext=  dfwptxt(&Mensagem)// Grava Linha 
	&ResultadoNext = dfwnext()  
Endif

&ResultadoAbertura = dfwclose()
]]></Source>
