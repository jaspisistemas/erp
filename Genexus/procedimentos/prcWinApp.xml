      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[if not &WinAppGUID.IsEmpty()
	do case
		case &OQueFazer = 'INI'
			&isContinua = true
			
			do 'VerificaLimite'
			
			if &isContinua
				&isContinua = &ProcessManager.StartProcess(&WinAppPath,'')
				if &isContinua
					&UserMessage = prcUserMessage(DVMessageType.success, 'Iniciado com sucesso', 'Processo foi iniciado com sucesso')
				else
					&UserMessage = prcUserMessage(DVMessageType.error, 'Não foi possível iniciar', 'Não foi possível iniciar')
				endif
			else
				&UserMessage = prcUserMessage(DVMessageType.error, 'Limite atingido', '')
			endif
			
		case &OQueFazer = 'STP'
			if not &WinAppInsGUID.IsEmpty()
				&resultBoolean = &ProcessManager.StopProcess(&WinAppPID)
				
				if &resultBoolean
					prcInstanciaApp('STP',&WinAppGUID,&WinAppInsGUID,0,&WinAppLog)
					&UserMessage = prcUserMessage(DVMessageType.success, 'Aplicativo finalizado', '')
				else
					&UserMessage = prcUserMessage(DVMessageType.error, 'Não foi possível finalizar', '')
				endif
			else
				&UserMessage = prcUserMessage(DVMessageType.error, 'GUID da instância inválida', '')
			endif
			
		case &OQueFazer = 'DESAB'
			for each order WinAppGUID,WinAppInsGUID
				where WinAppGUID    = &WinAppGUID
				WinAppIsHabilitado = false
				&UserMessage = prcUserMessage(DVMessageType.success, 'Desabilitado com sucesso', '')
				exit
			when none
				&UserMessage = prcUserMessage(DVMessageType.success, 'Aplicativo não encontrado', '')
			endfor
			commit
			
		case &OQueFazer = 'HAB'
			for each order WinAppGUID,WinAppInsGUID
				where WinAppGUID    = &WinAppGUID
				WinAppIsHabilitado = true
				&UserMessage = prcUserMessage(DVMessageType.success, 'Habilitado com sucesso', '')
				exit
			when none
				&UserMessage = prcUserMessage(DVMessageType.success, 'Aplicativo não encontrado', '')
			endfor
			commit
			
		case &OQueFazer = 'DESAT'
			for each order WinAppGUID,WinAppInsGUID
				where WinAppGUID    = &WinAppGUID
				where WinAppInsGUID = &WinAppInsGUID
				WinAppInsSts = Status_Instancia.DESLIGAR
				WinAppInsLog = 'Desativado. Aguarde o processo encerrar sozinho'
				&UserMessage = prcUserMessage(DVMessageType.success, 'Desativado com sucesso', '')
				exit
			when none
				&UserMessage = prcUserMessage(DVMessageType.success, 'Aplicativo não encontrado', '')
			endfor
			commit
			
		otherwise
			&UserMessage = prcUserMessage(DVMessageType.error, 'Parâmetro inválido', '')
	endcase
endif
	
Sub 'VerificaLimite'
	for each order WinAppGUID
		where WinAppGUID       = &WinAppGUID
		where WinAppIsCriaNovo = true
		exit
	when none
		&isContinua = false
	endfor
EndSub
]]></Source>
