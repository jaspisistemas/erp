<Object parentGuid="cb7d507a-ac2b-42b9-a5ea-8d6a322e9b4e" user="SRVORDIG\Administrador" versionDate="2025-12-18T23:40:07.0000000Z" lastUpdate="2025-12-17T13:08:24.0000000Z" checksum="6eeb21c2d74a5976de28d98a23887aff" fullyQualifiedName="ExcluirCte" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="8b8ddc45-5002-4b85-84ec-40b2cefc350d" name="ExcluirCte" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Excluir Cte" parent="prcCTE" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	If CteProTer = Nota_proPriaTerceira.TERCEIROS // se for terceiros deixa excluir
		
		DeletaDocCte.Call(EmpCod,FilCod,CteCod,0)
		
		For each Order EmpCod,FilCod,CteCod,CteSegCod //seguro
			Delete
		EndFor
		
		For each Order EmpCod,FilCod,CteCod,CteCarCod //Carga
			Delete 
		EndFor
		
		For Each Order EmpCod,FilCod,CteCod,CteVeiCod //Veículo
			Delete
		EndFor
		
		For Each Order EmpCod,FilCod,CteCod,CteColCod //Coletas
			Delete
		EndFor
		
		For Each Order EmpCod,FilCod,CteCod,CtePreCod //Prestacao Componentes
			Delete
		EndFor
	
		For Each Order EmpCod,FilCod,CteCod,CteDupCod //duplicatas
			Delete
		EndFor
	
		For Each Order EmpCod,FilCod,CteCod,CteEveCod //EventoEntrega
			Delete
		EndFor
	
		For Each Order EmpCod,FilCod,CteCod, CteDocAntCod //Documento Anterior 
			Delete
		EndFor
		
		For Each Order EmpCod,FilCod,CteCod, CteCCeCod,CteCCeInfCod //CCe Inf
			Delete
		EndFor
	
		For Each Order EmpCod,FilCod,CteCod, CteCCeCod //CCe 
			Delete
		EndFor
		
		For Each Order EmpCod,FilCod,CteCod, CtePerCod //Percurso 
			Delete
		EndFor
	
		Delete
	else
		If CteSts = Status_NFe.Digitando
			CteSts = Status_NFe.Excluida //excluido
		EndiF
	EndiF
When none
	msg('Atenção CT-e sem status digitando, não é possível excluir!')
EndFor

commit

]]></Source>
