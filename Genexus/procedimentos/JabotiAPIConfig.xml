      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&BaseURL.SetEmpty()
&EmpJaspiChatFon.SetEmpty()
&EmpJaspiChatToken.SetEmpty()

For each Order EmpCod
	where EmpCod = &EmpCod
	where not EmpJaspiChatAPIUrl.IsNull() and not EmpJaspiChatAPIUrl.IsEmpty()
	&BaseURL = EmpJaspiChatAPIUrl
	&EmpJaspiChatFon = EmpJaspiChatFon
	&EmpJaspiChatToken = EmpJaspiChatToken
	exit
when none
	/*
		Caso não encontre uma url para a empresa solicitada, pegue a primeira url válida
	*/
	For each Order EmpCod
		where not EmpJaspiChatAPIUrl.IsNull() and not EmpJaspiChatAPIUrl.IsEmpty()
		&BaseURL = EmpJaspiChatAPIUrl
		&EmpJaspiChatFon = EmpJaspiChatFon
		&EmpJaspiChatToken = EmpJaspiChatToken
		exit
	Endfor
Endfor
]]></Source>
