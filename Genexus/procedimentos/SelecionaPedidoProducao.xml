      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&OrdCod = 0
&PedDtaHorSelPrd = ServerNow()

//CAPA ORDEM PRODUCAO
For Each Order EmpCod, FilCod, OrdSts, (OrdCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdSts = Status_Producao.Aguardando
	Where OrdGrupHie.IsEmpty() or OrdGrupHie.IsNull()
	Where OrdSetCod.IsEmpty() or OrdSetCod.IsNull()
	
	OrdTip = &OrdTip
	
	If OrdDta <> serverdate()
		For Each Order EmpCod, FilCod, OrdCod, OrdPedItmCod
			AtualizaStatusProducaoPedido.Call(EmpCod, OrdPedFilCod, OrdPedCod, Status_Producao.Aguardando, &vaziaData, &PedDtaHorSelPrdVazia)
			delete
		EndFor
	
		OrdDta = serverdate()
		commit
	EndIF
	&OrdCod = OrdCod
	
	Exit
When none
	For Each Order EmpCod, FilCod, (OrdCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&OrdCod = OrdCod
		Exit
	EndFor

	&OrdCod += 1
	&OrdSts = Status_Producao.Aguardando
	
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		OrdCod = &OrdCod
		OrdEntPedCod = 0
		OrdSaiPedCod = 0
		OrdSts = &OrdSts
		OrdTip = &OrdTip
		OrdDta = serverdate()
		OrdSetCod = 0//&SetCod
		OrdGrupHie = ''//&GrupHie
	EndNEw
EndFor

commit

Do Case
	Case &OqueFazer = 'DEL' //SOMENTE DELETAR
		For Each Order EmpCod, FilCod, OrdCod, OrdPedFilCod, OrdPedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where OrdCod = &OrdCod
			Where OrdPedFilCod = &FiLCod
			Where OrdPedCod = &PedCod
			
			AtualizaStatusProducaoPedido.Call(&EmpCod, &FiLCod, &PedCod, Status_Producao.Aguardando, &vaziaData, &PedDtaHorSelPrdVazia)
			Delete
			Exit
		When none
			AtualizaStatusProducaoPedido.Call(&EmpCod, &FiLCod, &PedCod, Status_Producao.Aguardando, &vaziaData, &PedDtaHorSelPrdVazia)
		EndFor
		
	Case &OqueFazer = 'ADD' //ADICIONAR
		For Each Order EmpCod, FilCod, OrdCod, OrdPedFilCod, OrdPedCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where OrdCod = &OrdCod
			Where OrdPedFilCod = &FiLCod
			Where OrdPedCod = &PedCod
			
			AtualizaStatusProducaoPedido.Call(&EmpCod, &FiLCod, &PedCod, Status_Producao.NaFila, &vaziaData, &PedDtaHorSelPrd)
			//Delete
			Exit
		When none
			&OrdPedItmCod = 0
			For Each Order EmpCod, FilCod, OrdCod, (OrdPedItmCod)
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where OrdCod = &OrdCod
				&OrdPedItmCod = OrdPedItmCod
				Exit
			EndFor
			&OrdPedItmCod += 1
			
			New
				EmpCod = &EmpCod
				FilCod = &FiLCod
				OrdCod = &OrdCod
				OrdPedItmCod = &OrdPedItmCod
				OrdPedFilCod = &FiLCod
				OrdPedCod = &PedCod
			EndNEw
			
			AtualizaStatusProducaoPedido.Call(&EmpCod, &FiLCod, &PedCod, Status_Producao.NaFila, &vaziaData, &PedDtaHorSelPrd)
		EndFor
		
		Commit
EndCAse



]]></Source>
