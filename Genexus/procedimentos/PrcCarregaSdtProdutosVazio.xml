      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&SdtProduto.Clear()

For &Index = &ProCod to &ProCodFin step 1
    &ProRef = trim(Str(&Index))
	
	//## Referencia Repetido
	For Each Order EmpCod, ProGraRef
		Where EmpCod = &EmpCod
		Where ProGraRef = &ProRef
		
	    exit
	when none
		
		&SdtProdutoItem= new()
		&SdtProdutoItem.ProCod = &Index
		&SdtProduto.Add(&SdtProdutoItem)
	EndFor		

	if &SdtProduto.Count = 1000
		Exit
	EndIf
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
