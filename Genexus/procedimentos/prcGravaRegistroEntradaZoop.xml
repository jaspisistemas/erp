      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ZoopID = &zoopEvent.id
if &ZoopID.IsEmpty()
	return
endif

new
	EmpCod = &EmpCod
	FilCod = &FIlCod
	ZoopId = &ZoopID
EndNEw
commit

//VERIFICA JA LANCADO 
For Each Order EmpCod, FilCod, ZoopId
	Where EmpCod = &EmpCod
	Where FilCod = &FIlCod
	WHere ZoopId = &ZoopID
	
	If ZoopJaspiSts.IsEmpty()
		ZoopJaspiSts = 'P'//PENDENTE/VINCULADO AO MONITORA PAGAMENTOS
	EndIf
	ZoopVlr = val(&zoopEvent.amount)
	Do cAse
		Case upper(&zoopEvent.payment_type) = 'BOLETO'
			ZoopTip = 'B'
		Case upper(&zoopEvent.payment_type) = 'CREDIT'
			ZoopTip = 'C'
		Case upper(&zoopEvent.payment_type) = 'DEBIT'
			ZoopTip = 'D'
		Case upper(&zoopEvent.payment_type) = 'COMMISSION'
			ZoopTip = 'E'
	EndCase
	
	&ZoopTip = ZoopTip
	
	&ZoopTax = val(&zoopEvent.fees)
	ZoopTax = &ZoopTax 
	
	&created_at = &zoopEvent.created_at
	do 'captaCampos'
	ZoopDta = YMDHMStoT(&Ano, &Mes, &dia, &Hour, &Minutes, &Seconds)
	
	if &zoopEvent.voided = true or
		&created_at = &zoopEvent.voided_at
	Else
		&created_at = &zoopEvent.updated_at
	Endif
	do 'captaCampos'
	ZoopDtaUpd = YMDHMStoT(&Ano, &Mes, &dia, &Hour, &Minutes, &Seconds)
	
	&created_at = &zoopEvent.expected_on
	do 'captaCampos'
	ZoopPgtoExp= YMDtoD(&Ano, &Mes, &dia)
	&DataZoopPgtoExp = ZoopPgtoExp
	
	ZoopCodCli = &zoopEvent.customer	
	ZoopNomCli = &zoopEvent.payment_method.holder_name
	ZoopCarBan = &zoopEvent.payment_method.card_brand
	ZoopCardId = &zoopEvent.payment_authorization.authorization_code
	ZoopCardNSU = &zoopEvent.payment_authorization.authorization_nsu
	
	&ZoopCardId = ZoopCardId
	ZoopBolId = &zoopEvent.reference_id
	
	&CreCod = ZoopCreCod
	&CreFilCod = ZoopFilCod
	ZoopQtdPar = val(&zoopEvent.installment_plan.number_installments)
	&ZoopQtdPar = ZoopQtdPar
	
	Do Case
		Case &CreCod.IsEmpty() and &ZoopTip = 'B' and not ZoopBolId.IsEmpty() //	BOLETO
			GetDuplicataNro_JaspiPagamentos.Call(EmpCod, ZoopBolId.Trim(), '0', &CreFilCod, &CreCod, &IsAchou)
			ZoopFilCod = &CreFIlCod
			ZoopCreCod = &CreCod
		Case &CreCod.IsEmpty() and (&ZoopTip = 'C' or &ZoopTip = 'D') and not ZoopCardId.IsEmpty() and &ZoopQtdPar <= 1//	CARTAO
			GetDuplicata_AutorizacaoCArtao.Call(EmpCod, ZoopCardId.Trim(), ZoopCardNSU.Trim(),  '', &CreFilCod, &CreCod, &IsAchou)
//			ZoopFilCod = &CreFIlCod
//			ZoopCreCod = &CreCod //JDF GRAVAR SOMENTE NO BOLETO
//			if &CreCod <> 0
//				prcGravaDadosBandeiraPercentual.Call(&EmpCod, &CreFIlCod, &CreCod, &zoopEvent, &zoopEvent)
//			Endif
		
	EndCase
	
	////	SO SE NAO ESTIVER LIQUIDADO
	if not ZoopCreCod.IsEmpty() and ZoopJaspiSts = 'P'
		ZoopJaspiSts = 'V'
	Endif

	if upper(&zoopEvent.status) = 'CANCELED'
		ZoopJaspiSts = 'C' //CANCELADO
	Endif

	if not &ZoopObs.IsEmpty()
		ZoopObs = &ZoopObs
	Endif
	
	Exit	
EndFor

Commit

//VERIFICA Atualiza Pagamentos
For Each Order EmpCod, FilCod, ZoopId, ZoopHisId
	Where EmpCod = &EmpCod
	Where FilCod = &FIlCod
	WHere ZoopId = &ZoopID
	
	&GravaZOOP = ZoopHisObs
	&auxzoopEvent = new()
	&auxzoopEvent.fee_details.Clear()
	&auxzoopEvent.history.Clear()
	&auxzoopEvent.FromJson(&GravaZOOP)
	
	prcGravaRegistroEntradaZoop_Recebimento.Call(EmpCod, FilCod, &auxzoopEvent, &GravaZOOP)
	
EndFor

Sub 'CaptaCampos'
	&Ano = val(Substr(&created_at, 1,4)) //: "2020-02-17 12:09:09"
	&Mes = val(Substr(&created_at,6,2)) //MES 
	&dia = val(Substr(&created_at,9,2)) //dia
	&Hour = val(Substr(&created_at,12,2)) //Hora
	&Minutes = val(Substr(&created_at,15,2)) //Minute
	&Seconds = val(Substr(&created_at,18,2)) //seconds
EndSub
]]></Source>
