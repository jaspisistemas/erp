<Object parentGuid="bfc50589-8947-4552-847b-80bfdf8aee52" user="WINJEAN\jeanfae" versionDate="2025-06-16T20:01:29.0000000Z" lastUpdate="2025-06-11T20:36:34.0000000Z" checksum="7d1f68be7c7ebca603303e116fdfdf6b" fullyQualifiedName="api_erp.get_wwmdfe" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="0fb94994-1fd8-497b-9aa4-de784edb881a" name="get_wwmdfe" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_wwmdfe" parent="api_erp.Notas" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	//, in:&CteDtaEmsIniTmpSec, in:&CteDtaEmsFinTmpSec, in:&CtePlc, in:&CteSts, in:&CteModCod, out:&wwMdfe);
	
	if not &Status.IsEmpty() and not &Status = 'T'
		&MDFeSts.FromString(&Status)
	Endif

	&Pagina = &parPagina
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif

	&wwMdfe.sts = 'J200'
	&wwMdfe.pA = '0'
	&wwMdfe.pT = '0'
	&wwMdfe.p1 = '0'
	&wwMdfe.p2 = '0'
	&wwMdfe.p3 = '0'
	&wwMdfe.p4 = '0'
	&wwMdfe.p5 = '0'
	&IsPaginaOk = false
	
	&Varchar = RetornaSoNumeros.Udp(&consultanome)
	&Numero = val(&Varchar)
	
	TimestampToDate.Call(&MdfeDtaEmsIniTmpSec, &iniMdfeDtaEms)
	TimestampToDate.Call(&MdfeDtaEmsFinTmpSec, &finMdfeDtaEms)
	For Each 
		Order EmpCod, (MDFeDtaEms), (MDFeCod) when &Ordem.IsEmpty() or &Ordem = 'DD'
		Order EmpCod, MDFeDtaEms, MDFeCod when &Ordem.IsEmpty() or &Ordem = 'DC'
		
		Where EmpCod = &wwpContext.empCod 
		Where FilCod = &FilCod when not &FilCod.IsEmpty()
		Where MDFeNum = &Numero or  MdfeVeiPlaTra like &consultanome or MDFeOriUfeCod like &consultanome or MDFeDstUfeCod like &consultanome when not &consultanome.IsEmpty()
		Where MDFeCod = &MdfeCod when not &MdfeCod.IsEmpty()
		where MDFeNum = &MdfeNum when not &MdfeNum.IsEmpty()
		Where MDFeSts = &MDFeSts when not &MDFeSts.IsEmpty() 
		Where (MDFeDtaEms >= &iniMdfeDtaEms and MDFeDtaEms <= &finMdfeDtaEms)
		


		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwMdfe.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
		
			if &IsPaginaOk = false
				
				&wwMdfeItem = New()
				&wwMdfeItem.FilCod = FilCod
				&wwMdfeItem.MdfeCod = MDFeCod
				&wwMdfeItem.MdfeDtaEmsTmp = DateToTimestamp.Udp(MDFeDtaEms)
				&wwMdfeItem.MdfeSts = MDFeSts
				
				&wwMdfeItem.UFOri = MDFeOriUfeCod
				&wwMdfeItem.UFDest = MDFeDstUfeCod
				
				RetornaNomeCidade.Call(EmpCod, MDFeDesCidCod, &MDFeDesCidNom)
				&wwMdfeItem.CidCodDest = MDFeDesCidCod
				&wwMdfeItem.CidNomDest = &MDFeDesCidNom
				
				&wwMdfeItem.MdfeNum = MDFeNum
				&wwMdfeItem.MDFeSer = MDFeSer
				&wwMdfeItem.MDFeVlrTotVar = trim(toformattedString(MDFeVlrTot))
				&wwMdfeItem.MdfeVeiPlaTra = MdfeVeiPlaTra
				
				&FilAtmCod = FilAtmCod
				&FilAtmUsu = FilAtmUsu
				&FilAtmSen = FilAtmSen
	
				if MDFeAveSts <> Status_nfe.Autorizada and ( &FilAtmCod.Trim().IsEmpty() or &FilAtmUsu.Trim().IsEmpty() or &FilAtmSen.Trim().IsEmpty())
					&wwMdfeItem.AveSts = 'X'
				Else
					&wwMdfeItem.AveSts = trim(MDFeAveSts.ToString())
				Endif
			
				
				&wwMdfe.Item.Add(&wwMdfeItem)
			Endif
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
	
	When none
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwMdfe.pA = trim(str(&Pagina))
		&wwMdfe.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwMdfe.p1, &wwMdfe.p2, &wwMdfe.p3, &wwMdfe.p4, &wwMdfe.p5)
	Endif
	
Endif
]]></Source>
