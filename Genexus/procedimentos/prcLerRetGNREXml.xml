      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NomeXmlRet = &AuxNomeFisicoFinal

&File.Source = &NomeXmlRet
If &File.Exists()
	
	//## Lê o primeiro XML de Retorno ##\\
	&LeituraXml.Open(&NomeXmlRet)
	&LeituraXml.ReadType(1, 'ns1:TRetLote_GNRE')
	&LeituraXml.Read()
	
	Do While (&LeituraXml.Name <> 'ns1:TRetLote_GNRE' and &LeituraXml.Name <> '')
		Do Case
			Case &LeituraXml.Name = 'ns1:codigo'			//## Código do retorno que indica a situação da recepção do lote		##\\
				&SitRecp = &LeituraXml.Value
				
			Case &LeituraXml.Name = 'ns1:descricao'			//## Descrição literal do retorno										##\\
				&DescRet = &LeituraXml.Value
				
			Case &LeituraXml.Name = 'ns1:numero'			//## Número do recibo gerado pelo portal GNRE							##\\
				&NumRecb = &LeituraXml.Value
				
			Case &LeituraXml.Name = 'ns1:dataHoraRecibo'	//## Data e Hora do recebimento do lote. Formato: AAAA-MM-DD HH:MM:SS 	##\\
				&DatHorRec = &LeituraXml.Value
				
			Case &LeituraXml.Name = 'ns1:tempoEstimadoProc'	//## Tempo estimado para processamento do lote em ms					##\\
				&TempProc = &LeituraXml.Value		
				
		EndCase
		
		&LeituraXml.Read()
		
	EndDo
	
	&LeituraXml.Close()
	
EndIf


]]></Source>
