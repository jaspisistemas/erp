      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

// ############ abre arquivo e transforma em xml na variavel ##########################
&Linha = 1
&Fim = 0
&Excel.Open(&CaminhoArquivoXml)
&IsSucess = false
// ######################################################################################

RetornaConfSistema.Call(&EmpCod, &Context.FilCod, domConfSistema.TCon175_GerarDuplicatas, &CfgVlr)
&IsGeraDuplicatas = iif(trim(&CfgVlr) = 'S',true,False) 

If &Excel.ErrCode <> 0
	msg('Ocorreu o seguinte erro ao abrir o arquivo: ' + &Excel.ErrDescription)
Else
	Do While &Linha < 500	
		If &Excel.Cells(&Linha,1).Value.Trim().IsEmpty()
			&IsSucess = true
            Exit
	    EndIf
		
		&CteNum =  val(&Excel.Cells(&Linha,1).Value)
		&CteNomPreCom =  upper(&Excel.Cells(&Linha,2).Value)
		&CteVlrPreCom =  val(&Excel.Cells(&Linha,3).Value,',')
		
		If not &CteNomPreCom.Trim().IsEmpty()
			Do 'ClonarCTE'
			Do 'AtualizaImposto'
		EndIf
		&Linha+=1
	EndDo	
EndIf

sub 'AtualizaImposto'
	For each Order EmpCod,FilCod,CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCodFat
		Where CteCod = &NewCteCod
		RetornaNomeCFOP.Call(CteCfop, &CfoNom)
		GravaValorImposto.call(EmpCod,FilCod,CteCod,CteVlrRecSer,CteVlrTotPreSer,CtePosPre,CteCfop,&CfoNom,CteImpCst,CteImpPerRed,CteImpAli,CteVlrTotPreSer,CteImpVlrCre,CteImpVstRet,CteImpVbcRet,CteImpAliRet,CteImpAliTotTri,&CteImpTriVlrPis,&CteImpTriVlrCofins,&CteImpTriVlrCsll,&CteImpTriAliInss,&CteImpTriVlrI,&IsGeraDuplicatas)
		EXIT
	EndFor
EndSub

Sub 'ClonarCTE'	 
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCodFat
		&FilTipEms = FilTipEms
		&FilRNTRC = FilRNTRC
		Exit
	EndFor
	
	For Each Order EmpCod, FilCod, CteNum
		Where EmpCod = &EmpCod
		Where FilCod = &FilCodFat
		Where CteNum = &CteNum
		&HojeData = serverdate()
		&NewCteCod = UltimoCodigoEmpresa.Udp(domParCod.CTE, &EmpCod, &FilCodFat)
		
		&NewCteNum = UltimoCodigoEmpresa.Udp(domParCod.CTENUM, &EmpCod, &FilCodFat)
		&CteSer = RetornaSerieNF.Udp(domParCod.CTESER, &EmpCod, &FilCodFat)
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCodFat
			CteCod = &NewCteCod
			CteRemCod = CteRemCod
			CteRemRaz = CteRemRaz
			CteIniUfe = CteIniUfe
			CteIniCidCod = CteIniCidCod
			CteIniCidNom = CteIniCidNom
			CteDesCod = CteDesCod
			CteDesRaz = CteDesRaz
			CteDesCnpj = CteDesCnpj
			CteDesCpf = CteDesCpf
			CteDesIns = CteDesIns
			CteTerUfe = CteTerUfe
			CteTerCidCod = CteTerCidCod
			CteTerCidNom = CteTerCidNom
			CteTomSer = CteTomSer
			CteTomCod    = CteTomCod
			CteTomRaz    = CteTomRaz
			CteProTer = Nota_ProPriaTerceira.PROPRIA
			CteModCod    = '57'
			CteNum       = &NewCteNum
			CteSer       = &CteSer
			CteTipSer    = CteTipSer
			CteMod       = CteMod
			CteindGlo    = CteindGlo
			CtePosPre = Status_SimNao.Sim
			CteFinEms    = finalidadeCte.Complemento
			CteTomChvCpl = CteChv					
			CteDtaEms    = &Today
			CteHorEms    = ServerTime()
			CteDadAdiTra = CteDadAdiTra.ToUpper()
			CteDadAdiSer = CteDadAdiSer.ToUpper()
			CteIndRec    = CteIndRec
			CteIndRecDes = CteIndRecDes
			CteLctCod    = CteLctCod
			CteNcmCod    = CteNcmCod
			CteModRodRNTRC = CteModRodRNTRC //&FilRNTRC
			CteImpCst    = CteImpCst
			CteConSplNac = CteConSplNac
			CteEnvEml    = NfeEnvEml.Pendente
			CteSts       = Status_NFe.Digitando
			CteImpAliTotTri = 0
			CteImpAli    = CteImpAli
			CteImpPerRed = CteImpPerRed				
			CteCarProPre = CteCarProPre.ToUpper()
			CteCarVlrTot = CteCarVlrTot
			CteCarOtrCar = CteCarOtrCar.ToUpper()
			
			CteVlrRecSer = &CteVlrPreCom
			CteVlrTotPreSer =  &CteVlrPreCom
			
			CteCfop   = CteCfop
			CteImpCst = CteImpCst
			CteImpVlrTotTri = CteImpVlrTotTri
			
			CteModRodRNTRC = CteModRodRNTRC
			CteModRodCol = CteModRodCol
			
			CteChv = ''
			CteAutNumPro = ''
			CteArqXml = ''
			CteAutSts = ''
			CteAutNumLot = ''
			CteAutNumRec = ''
			CteAutDigVal = ''
			CteAutDatHorRec = ''
			CteAutMsg = ''
			CteEnvEml = NfeEnvEml.Pendente
			CteStsImp = ''
			CtePosDup = CtePosDup
			CtePosVei = CtePosVei
			CtePosDocAnt = CtePosDocAnt
			CteAveApo = ''
			CteAveArq = ''
			CteAveCnpjSeq = ''
			CteAveDta.SetEmpty()
			CteAveNro = ''
			CteAveProt = ''
			CteAveSts = Status_NFe.Digitando
		endNew
		
		For Each Order EmpCod,FilCod,CteCod,CteDocTip
			new
				EmpCod = &EmpCod
				FilCod = &FilCodFat
				CteCod = &NewCteCod
				
				CtePreCod = 1
				CteNomPreCom = &CteNomPreCom
				CteVlrPreCom = &CteVlrPreCom
				CteDesIcmsCom = false
			Endnew
		EndFor		
		
		For Each Order EmpCod,FilCod,CteCod,CteVeiCod
			new
				EmpCod = &EmpCod
				FilCod = &FilCodFat
				CteCod = &NewCteCod
				CteVeiCod = CteVeiCod
				CteVeiRen = CteVeiRen
				CteVeiPla = CteVeiPla
				CteVeiTar = CteVeiTar
				CteVeiCap = CteVeiCap
				CteVeiCap2 = CteVeiCap2
				CteVeiPro = CteVeiPro
				CteVeiTip = CteVeiTip
				CteVeiTipCarr = CteVeiTipCarr
				CteVeiTipRod = CteVeiTipRod
				CteVeiUfeCod = CteVeiUfeCod
				CteVeiRNTRC = CteVeiRNTRC				
			EndNew
		EndFor
		
		Exit
	EndFor
	
	Commit
	
 EndSub
]]></Source>
