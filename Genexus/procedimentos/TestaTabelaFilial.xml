      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&HojeData = Serverdate()
&Mensagem.SetEmpty()
&IstabelaFilial = false
&IsExisteTabela = false

//PODE TER PEDIDO SEM TABELA PROMOCAO
For Each Order EmpCod, TabCod
	Where EmpCod = &EmpCod
	Where TabCod = &TabCod
	where TabSts <> StatusTabela.Inativa 
	
	&IsExisteTabela = true
	&IstabelaFilial = true
	&TabIsAntAcr = TabIsAntAcr
	
	Do case
		case TabDtaFin < &HojeData
			&Mensagem = 'Tabela: '+trim(&TabCod)+' não está mais vigente.'
			&IsExisteTabela = false
		case TabDtaIni > &HojeData
			&Mensagem = 'Tabela: '+trim(&TabCod)+' ainda não está vigente.'
			&IsExisteTabela = false
			
		Case TabIsAllFil = false //SOMENTE SE NAO FOR TODAS FILIAIS		
			For Each Order TabCod, TabFilCod
		        Where TabFilCod = &TabFilCod
				
				Exit
	        When none
				&Mensagem = TabNom.Trim()
				&IstabelaFilial = false
	        EndFor
	EndCAse

	Exit
When None
	&Mensagem = 'Tabela: '+trim(&TabCod)+' Não Localizada.'
EndFor

]]></Source>
