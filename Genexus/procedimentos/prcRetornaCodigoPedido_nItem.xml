      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&PedNItmPed.SetEmpty()
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where PedQtd > 0
	&PedNItmPed = PedNItmPed
	Exit
EndFor
]]></Source>
