      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


Do CAse
	CAse &OqueFAzer = 'UPD'
		For Each Order EmpCod, TipEtqCod
			Where EmpCod = &EmpCod
			Where TipEtqCod = &TipEtqCod
			
			TipEtqNom = &TipEtqNom.ToUpper()
			TipEtqSts = &TipEtqSts
			
			TipEtqAlt = &parTipEtqAlt
			TipEtqLar = &parTipEtqLar
			TipEtqEspCol = &parTipEtqEspCol
			TipEtqMrgEsq = &parTipEtqMrgEsq
			TipEtqMrgDir = &parTipEtqMrgDir 
			
			TipEtqFor = &TipEtqFor
			
			TipEtqPadImpCod = &TipEtqPadImpCod
			TipEtqGap = &TipEtqGap
			TipEtqSpe = &TipEtqSpe
			TipEtqDen = &TipEtqDen			
			
			Exit
		EndFor
	
		Commit
		
	Case &OqueFAzer = 'NEW'		
		
//		Do Case
//			CAse &TipEtQtdCol = 1
				&TipEtqAlt = 25
				&TipEtqLar = 40
			
		if &TipEtQtdCol > 1
			&TipEtqEspCol = 2
		Else
			&TipEtqEspCol = 0
		Endif
	
		&TipEtqMrgEsq = 0
		&TipEtqMrgDir = 0
		
		For Each ORder EmpCod, (TipEtqCod)
			Where EmpCod = &EmpCod
			&TipEtqCod = TipEtqCod
			Exit
		EndFor
		&TipEtqCod += 1
		
		new
			EmpCod = &EmpCod
			TipEtqCod = &TipEtqCod
			TipEtqNom = &TipEtqNom.ToUpper()
			TipEtqModTip = 'P' //Produto
			TipEtqSts = &TipEtqSts
			TipEtqModBas = &TipEtqModBas
			TipEtqForm = &TipEtqForm
			TipEtQtdCol = &TipEtQtdCol
			
			TipEtqFor = &TipEtqFor
			
			//aqui vamos identificar o modelo base selecionado e preencher os campos
			prcRetornaJsonEtiquetaNew.Call(&TipEtqModBas, &TipEtqJson)
		 	TipEtqJson = &TipEtqJson
		 
 			TipEtqAlt = &TipEtqAlt
			TipEtqLar = &TipEtqLar
			TipEtqEspCol = &TipEtqEspCol
			TipEtqMrgEsq = &TipEtqMrgEsq
			TipEtqMrgDir = &TipEtqMrgDir
			
			TipEtqGap = &TipEtqGap
			TipEtqSpe = &TipEtqSpe
			TipEtqDen = &TipEtqDen	
		EndNEw
		
		Commit
		
		
EndCAse
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
