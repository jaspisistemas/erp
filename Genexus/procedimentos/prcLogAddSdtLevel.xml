      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsAchou = false
For &sdtLogAtributosLevelItem in &sdtLogAtributosLevel
	if &sdtLogAtributosLevelItem.LvID = &IdLevel
		
		&sdtLogAtributosLevelItemAtributos = new()
		&sdtLogAtributosLevelItemAtributos.Att = &NomeCampo
		&sdtLogAtributosLevelItemAtributos.Old = &ValorAntigo
		&sdtLogAtributosLevelItemAtributos.New = &ValorNovo
		&sdtLogAtributosLevelItem.Atributos.Add(&sdtLogAtributosLevelItemAtributos)
		
		&IsAchou = true
		Exit
	Endif
EndFor

if &IsAchou = false
	&sdtLogAtributosLevelItem = new()
	&sdtLogAtributosLevelItem.LvID = &IdLevel
	&sdtLogAtributosLevelItem.IsSts = 'N'
	
	&sdtLogAtributosLevelItemAtributos = new()
	&sdtLogAtributosLevelItemAtributos.Att = &NomeCampo
	&sdtLogAtributosLevelItemAtributos.Old = &ValorAntigo
	&sdtLogAtributosLevelItemAtributos.New = &ValorNovo
	&sdtLogAtributosLevelItem.Atributos.Add(&sdtLogAtributosLevelItemAtributos)
	
	&sdtLogAtributosLevel.Add(&sdtLogAtributosLevelItem)
Endif
]]></Source>
