      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAchouProduto = false
&Mensagemerro = 'Produto não Localizado!'

if not &ProGraRef.IsEmpty()
	For Each Order EmpCod, ProBarRef //Codigo Barras Diversos
		Where EmpCod = &EmpCod
		Where ProBarRef = &ProGraRef
		Where ProGraCod = 1
		
		&ProGraCod = 1
		&ProCod = ProCod
		&ProNom = ProNom		
		&IsAchouProduto = true		
		&Mensagemerro = ''
		Exit
	When none
		
		For Each Order EmpCod, ProRef //Codigo Barras 
			Where EmpCod = &EmpCod
			Where ProRef = &ProGraRef or ProBar = &ProGraRef
			
			&ProGraCod = 1
			
			&ProCod = ProCod
			&ProNom = ProNom
			
			&IsAchouProduto = true
			
			&Mensagemerro = ''
			
			GravaCodigoProdutoRefBarras.Call(EmpCod, ProCod, 1, ProGraRef, 'R') //REFERENCIA
			GravaCodigoProdutoRefBarras.Call(EmpCod, ProCod, 1, ProGraBar, 'B') //BARRAS
			Exit
			
		EndFor
	EndFor
Endif
]]></Source>
