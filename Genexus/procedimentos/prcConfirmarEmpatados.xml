      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


Do CAse
	Case &CriterioDesempate = 'A' //QUEM INFORMOU O PRECO PRIMEIRO
		For Each Order EmpCod, CotComCod, CotComItmCod
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComProSelForCod.IsEmpty() or CotComProSelForCod.IsNull() when &IsConfirmarOsNaoConfirmados = true
			
			&MenorValor = 0
			&ValorEmpateMoeda = 0
			&CotComProForCod = 0
			&CotComProForDtaHorLct.SetEmpty()
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				Where CotComProForSts = StatusprodutoCotado.COTADO
				Where CotComProForVlrFin > 0
				
				Do Case
					Case CotComProForVlrFin < &MenorValor or &MenorValor = 0//Valor Menor
						&MenorValor = CotComProForVlrFin
						if &ValorEmpateMoeda = 0
							&CotComProForCod = CotComProForCod
							&CotComProForDtaHorLct = CotComProForDtaHorLct
						Endif
						
					Case CotComProForVlrFin = &MenorValor //Valor Empate			
						&ValorEmpateMoeda = CotComProForVlrFin
						if &CotComProForDtaHorLct > CotComProForDtaHorLct
							&CotComProForCod = CotComProForCod
							&CotComProForDtaHorLct = CotComProForDtaHorLct
						Endif
				EndCase
				
			EndFor
			
			if &ValorEmpateMoeda > 0 and &MenorValor > 0
				CotComProSelForCod = &CotComProForCod
			endif
		EndFor
		
		commit
		
	Case &CriterioDesempate = 'B' //MENOR PRAZO ENTREGA
		For Each Order EmpCod, CotComCod, CotComItmCod
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComProSelForCod.IsEmpty() or CotComProSelForCod.IsNull() when &IsConfirmarOsNaoConfirmados = true
			
			&MenorValor = 0
			&ValorEmpateMoeda = 0
			&CotComProForCod = 0
			&CotComPrzEnt.SetEmpty()
			&AuxCotComPrzEnt.SetEmpty()
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				Where CotComProForSts = StatusprodutoCotado.COTADO
				Where CotComProForVlrFin > 0
				
				Do Case
					Case CotComProForVlrFin < &MenorValor or &MenorValor = 0//Valor Menor
						&MenorValor = CotComProForVlrFin
						if &ValorEmpateMoeda = 0
							&CotComProForCod = CotComProForCod
							&auxCotComProForCod = CotComProForCod
							do 'getPrazoEntrega'
							&CotComPrzEnt = &AuxCotComPrzEnt
						Endif
						
					Case CotComProForVlrFin = &MenorValor //Valor Empate
						&ValorEmpateMoeda = CotComProForVlrFin
						
						&auxCotComProForCod = CotComProForCod
						do 'getPrazoEntrega'
						if &CotComPrzEnt > &AuxCotComPrzEnt or &CotComPrzEnt.IsEmpty() and &AuxCotComPrzEnt > 0
							&CotComProForCod = CotComProForCod
							&CotComPrzEnt = &AuxCotComPrzEnt
						Endif
				EndCase
				
			EndFor
			
			if &ValorEmpateMoeda > 0 and &MenorValor > 0
				CotComProSelForCod = &CotComProForCod
			endif
		EndFor
		
		commit
EndCase

Sub 'getPrazoEntrega'
	For Each Order EmpCod, CotComCod, CotComForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComForCod = &auxCotComProForCod
		&AuxCotComPrzEnt = CotComForPrzEnt
		Exit
	EndFor
EndSub


]]></Source>
