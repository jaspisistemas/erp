      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&FicNom.SetEmpty()
For Each Order EmpCod, FicCod
	Where EmpCod = &EmpCod
	Where FicCod = &Ficcod
	&FicNom = FicNom.Trim() + ': ' + trim(str(FicCod))
	Exit
EndFor
]]></Source>
