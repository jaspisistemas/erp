      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each  Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	EstFab = &EstFab
	
	&EstDias = 0
	
	&EstSdo = EstSdo + &EstFab
	if EstPrd > 0
		&EstSdo += EstPrd
	EndIF

	If &EstSdo > 0 and EstMin > 0 and EstMinDia > 0
		&EstDias = round((&EstSdo * EstMinDia) / EstMin,0)
	EndIf
	EstDias = &EstDias
EndFor

commit


//SEPARADO POR CAUSA DA FORMULA //JDF
For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	EstSug = EstSug_FORMULA
	Exit
EndFor
Commit
]]></Source>
