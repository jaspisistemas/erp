      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&DataHoje = serverdate()

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesSts = Status_AtivoInativo.ATIVO
	Where not PesDtaAdm.IsEmpty() and not PesDtaAdm.IsNull()
	Where PesIsFun = true
	
	&PesCod = PesCod
	&PesDtaAdm = PesDtaAdm
	
	&PesRecCod = 0
	For EAch Order EmpCod, PesCod, (PesRecCod)
		Where PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsEmpty() or PesRecSts.IsNull()
		where not PesRecDtaAdm.IsEmpty() and not PesRecDtaAdm.IsNull()
		Where PesRecDtaDem.IsEmpty() or PesRecDtaDem.IsNull()
		&PesRecCod = PesRecCod
		Exit
	EndFor

	if &PesRecCod > 0
		do 'addFerias'
	Endif
EndFor

Sub 'addFerias'
	&isContinua = true
	&FerDtaIni = &PesDtaAdm
	
	do while (&isContinua = true)
		&FerDtaFin = &FerDtaIni.AddYears(1)
		&FerDtaFin = &FerDtaFin.AddDays(-1)
		&FerAnoBas = year(&FerDtaFin)
		
		do 'gravacasoNaoexistir'
		
		if &FerDtaFin > &DataHoje 
			&isContinua = false
		Endif
	
		&FerDtaIni = &FerDtaFin.AddDays(1)
	EndDo
	
EndSub

sub 'gravacasoNaoexistir'
	For EAch Order EmpCod, PesCod, PesRecCod, FerAnoBas
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesRecCod = &PesRecCod
		Where FerAnoBas = &FerAnoBas
		
		FerDtaIni = &FerDtaIni
		FerDtaFin = &FerDtaFin
		FerDtaLim = &FerDtaFin.AddYears(1)
		
		if FerDiaTot <> 30			
			//Ferias Totais
			if FerDtaFin < &DataHoje
				FerDiaTot = 30
			Else			
				&Dias = &FerDtaFin-&FerDtaIni
				FerDiaTot = round(&Dias * 0.0821917808219178, 0)
			Endif
			
			//Atualiza ferias Pendentes
			&FerItemDias = 0
			For Each Order EmpCod, PesCod, PesRecCod, FerAnoBas, FerItemCod
				&FerItemDias += FerItemDias
			EndFor
			
			FerDiaUsu = &FerItemDias
			FerDiaPen = FerDiaTot-&FerItemDias
			
			Commit
		Endif
		
		Exit
	When none
		new
			EmpCod = &EmpCod
			PesCod = &PesCod
			PesRecCod = &PesRecCod
			FerAnoBas = &FerAnoBas
			FerDtaIni = &FerDtaIni
			FerDtaFin = &FerDtaFin
			FerDtaLim = &FerDtaFin.AddYears(1)
			FerDiaUsu = 0
			
			if &FerDtaFin < &DataHoje
				FerDiaTot = 30
				FerDiaPen = 30
			Else
				&Dias = &FerDtaFin-&FerDtaIni
				FerDiaPen = round(&Dias * 0.0821917808219178, 0)
				FerDiaTot = FerDiaPen
			Endif
		EndNew
		
	EndFor
	Commit
EndSub
]]></Source>
