      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	
	For Each Order EmpCod, PesCod, ComLctCod
		Where ComLctCod = &LctCod
		
		if PesTipCom.IsEmpty() or PesTipCom.IsNull()
			AtualizaComissao.Call(EmpCod)
		Endif
	
		&sdtComissaoVendedor.PesTipCom = PesTipCom
				
		Do CAse
			CAse PesTipCom = 'S' //Faturamento
				
				For each Order EmpCod, PesCod, ComLctCod, ComFatVlr	
					&sdtComissaoVendedorItem = new()
					&sdtComissaoVendedorItem.Sts = 'S'
					&sdtComissaoVendedorItem.LctCod = ComLctCod
					&sdtComissaoVendedorItem.lctNom = ComLctNom
					&sdtComissaoVendedorItem.ComTipo = 'Comissão por Faturamento'
					
					&sdtComissaoVendedorItem.ComValorFat = ComFatVlr
					&sdtComissaoVendedorItem.ComTabNor = ComFatTabNor
					&sdtComissaoVendedorItem.ComTabPrm = ComFatTabPrm
					&sdtComissaoVendedor.Item.Add(&sdtComissaoVendedorItem)
				EndFor
			
			CAse PesTipCom = 'D' //Desconto
				
				For Each ORder EmpCod, PesCod, ComLctCod, ComDscTax
					&sdtComissaoVendedorItem = new()
					&sdtComissaoVendedorItem.Sts = 'S'
					&sdtComissaoVendedorItem.LctCod = ComLctCod
					&sdtComissaoVendedorItem.lctNom = ComLctNom
					&sdtComissaoVendedorItem.ComTipo = 'Comissão por Desconto'
					
					&sdtComissaoVendedorItem.ComPer = ComDscTax
					&sdtComissaoVendedorItem.ComTabNor = ComDscNor
					&sdtComissaoVendedorItem.ComTabPrm = ComDscPrm

					&sdtComissaoVendedorItem.ComDscTabCod = ComDscTabCod
					&sdtComissaoVendedorItem.ComDscTabColCod = ComDscTabColCod
					
					&sdtComissaoVendedor.Item.Add(&sdtComissaoVendedorItem)
				EndFor
				
			Otherwise
				&sdtComissaoVendedorItem = new()
				&sdtComissaoVendedorItem.Sts = 'S'
				&sdtComissaoVendedorItem.ComTipo = 'Comissão Fixa'
				&sdtComissaoVendedorItem.ComTabNor = ComTabNor
				&sdtComissaoVendedorItem.ComTabPrm = ComTabPrm
				&sdtComissaoVendedor.Item.Add(&sdtComissaoVendedorItem)
		EndCase
	EndFor
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
