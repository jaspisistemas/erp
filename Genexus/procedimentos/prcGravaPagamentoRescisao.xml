      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&FPagCod = &parFPagCod

For Each Order EmpCod, PesCod, PesRecCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	where PesRecCod= &PesRecCod
	if &FerAnoBas = year(serverdate())
		&FPagMes = month(serverdate())
	Else
		&FPagMes = month(PesDtaAdm) //grava mes da admissao como mes base pagamento ferias.
	Endif

	Exit
EndFor


prcGravaPagamentoFolha.Call(&EmpCod, &FPagCod, TipoPagamentoFolha.Rescisao, &PesCod, &FerAnoBas, &FPagMes, false, &FPagCod)
prcGravaPagamentoFolhaItem.call(&EmpCod, &FPagCod, &sdtItensFolha, &sdtPagamentosFolhaContas, &sdtPagamentoFolhaAdiantamentos)


//Atualiza status
For Each ORder EmpCod, FPagCod
	Where EmpCod = &EmpCod
	Where FPagCod = &FPagCod
	FPagDtaDem = &FPagDtaDem
	FPagIsBloUsu = &FPagIsBloUsu
	FPagIsRemFun = &FPagIsRemFun
	Exit
EndFor

Commit
]]></Source>
