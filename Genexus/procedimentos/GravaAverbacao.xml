      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod, MDFeCod,MdfeSegCod
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeSegCod = 1
		MdfeSegRes = &MdfeSegRes
		
	When none
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MDFeCod
			MdfeSegCod = 1
			MdfeSegRes = &MdfeSegRes
		EndNew		
	EndFor
	
	commit
	
	//averbações
	For Each Order EmpCod, FilCod, MDFeCod, MdfeSegCod, MdfeSegNroAve
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeSegCod = 1
		Where MdfeSegNroAve = &MdfeSegNroAve
	When none
		New
			EmpCod = &EmpCOd
			FilCod = &FilCod
			MDFeCod = &MDFeCod
			MdfeSegCod = 1
			MdfeSegNroAve = &MdfeSegNroAve
		EndNew
	EndFor

	commit
]]></Source>
