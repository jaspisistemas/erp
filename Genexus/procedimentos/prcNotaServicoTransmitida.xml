      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each ORder EmpCod, NfsCod
	Where EmpCod = &EmpCod
	Where NfsCod = &NfsCod
	
	&NfsTipNf = NfsTipNF
	NfsIsEnv = true
	Exit
EndFor

Commit


if &NfsTipNf  = 'S'
	For Each ORder EmpCod, NfsCod, NfsItmCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NFsCod
		Where NfsItmCod > 1
		delete
	EndFor

	Commit
EndIf
]]></Source>
