      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if not &MovCod.IsEmpty()
	For Each Order EmpCod, MovCod, MovCreCod
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		Where MovCreCod = &MovCreCod
		
		&PlanCod = PlanCod
		Exit
	When none
		For Each Order EmpCod, MovCod
			Where EmpCod = &EmpCod
			Where MovCod = &MovCod
			//Where MovCreCod = &MovCreCod
			
			&PlanCod = PlanCod
			Exit
		EndFor
	
	EndFor
EndIf
]]></Source>
