      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//FILHOS
For &SdtArtItem in &SdtArt
	&IsSalvo = true
	For each order EmpCod, PesCod, PesArtCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		where PesArtCod = &SdtArtItem.PesArtCod
		
		If &SdtArtItem.PesArtSts = Status_SimNao.Sim 
			PesArtNro = &sdtartItem.PesArtNro
			PesArtUfe = &sdtartItem.PesArtUfe
			PesArtSeqIni = &sdtartItem.PesArtSeqIni 
			PesArtSeqFin = &sdtartItem.PesArtSeqFin		
			
			If &SdtArtItem.PesArtNro.Trim().IsEmpty()
				&IsSalvo = false
				Delete
			EndIf
		Else 
			&IsSalvo = false
			Delete // se tiver Sts = nao - deleta
		EndIf
		
	When none
		If &SdtArtItem.PesArtSts = Status_SimNao.Sim 
			If not &SdtArtItem.PesArtNro.Trim().IsEmpty()
				New
					EmpCod = &EmpCod
					PesCod = &PesCod
					PesArtCod = &sdtartItem.PesArtCod
					PesArtNro = &sdtartItem.PesArtNro
					PesArtUfe = &sdtartItem.PesArtUfe
					PesArtSeqIni = &sdtartItem.PesArtSeqIni 
					PesArtSeqFin = &sdtartItem.PesArtSeqFin
				EndNew
			Else
				&IsSalvo = false
			EndIf
		EndIf
	
	EndFor
	
	Commit
EndFor


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
