      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[retornaAutorizacao.Call('WWTABELAPRECO', Status_SimNao.Sim, 2, &AutNiv)

RetornaColunasTabelas.Call(&EmpCod, &TabCod, &TabPerCol1, &TabPerCol1, &TabPerCol1, &TabPerCol1,&TabPerCol1,&TabPerCol1,&TabPerCol1,&TabPerCol1,&TabPerCol1,&Tem1,&Tem2,&Tem3,&Tem4,&Tem5,&Tem6,&Tem7,&Tem8,&Tem9)

&ProGraCod = 1
&Linha = &PrimeiraLinha
&Excel.Open(&selectedURL)
If &Excel.ErrCode <> 0
	msg(&Excel.ErrDescription)
Else
	Do While &Fim < 500
		
		Do 'LimpaCampos'
		&AuxColuna = &ColunaVlr
		
		&ProRef = &Excel.Cells(&Linha,&ColunaProduto).Text
		&TabPrc1 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1
		
		&TabPrc2 = &Excel.Cells(&Linha,&AuxColuna).number 
		&AuxColuna+=1
	
		&TabPrc3 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1
	
		&TabPrc4 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1
	
		&TabPrc5 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1
	
		&TabPrc6 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1
	
		&TabPrc7 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1
	
		&TabPrc8 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1
	
		&TabPrc9 = &Excel.Cells(&Linha,&AuxColuna).number
		&AuxColuna+=1		
		
		&TabProDtaIni = &Excel.Cells(&Linha,&AuxColuna).Date
		&AuxColuna+=1
		&TabProDtaFin = &Excel.Cells(&Linha,&AuxColuna).Date
		&AuxColuna+=1
		
		If &ProRef.IsEmpty()
			&Fim += 1
		Else
			If &TabPrc1 > 0	
				Do 'GetProduto'
				Do 'GravaSdt'
			Else
				&IsErro = 'S'	
				msg('Preço da primeira coluna do produto: '+trim(&ProRef)+ ' não pode ser zero!')
			EndIf
			
			&Fim = 0
		EndIF
		&Linha += 1
	EndDo
EndIf

sub 'GravaSdt'
	For &SdtTabelaPrecoItem in &SdtTabelaPreco
		if &SdtTabelaPrecoItem.ProGraRef = &ProRef
			&IsErro = 'S'	
			&Mensagem = 'DUPLICIDADE: Produto já Adicionado!'
			Exit
		EndIF	
	EndFor

		&SdtTabelaPrecoItem = new()		
		&SdtTabelaPrecoItem.EmpCod    = &EmpCod
		&SdtTabelaPrecoItem.TabCod    = &TabCod
		&SdtTabelaPrecoItem.ProGraCod = &ProGraCod
		&SdtTabelaPrecoItem.ProGraRef = &ProRef
		&SdtTabelaPrecoItem.ProCod    = &ProCod
		&SdtTabelaPrecoItem.ProNom    = &ProNom
		&SdtTabelaPrecoItem.TabPrc1   = &TabPrc1
		&SdtTabelaPrecoItem.TabPrc2   = &TabPrc2
		&SdtTabelaPrecoItem.TabPrc3   = &TabPrc3
		&SdtTabelaPrecoItem.TabPrc4   = &TabPrc4
		&SdtTabelaPrecoItem.TabPrc5   = &TabPrc5
		&SdtTabelaPrecoItem.TabPrc6   = &TabPrc6
		&SdtTabelaPrecoItem.TabPrc7   = &TabPrc7
		&SdtTabelaPrecoItem.TabPrc8   = &TabPrc8
		&SdtTabelaPrecoItem.TabPrc9   = &TabPrc9
		&SdtTabelaPrecoItem.TabProDtaIni = &TabProDtaIni
		&SdtTabelaPrecoItem.TabProDtaFin = &TabProDtaFin
		&SdtTabelaPrecoItem.Mensagem  = &Mensagem
		&SdtTabelaPrecoItem.Erro      = &IsErro
		&SdtTabelaPreco.Add(&SdtTabelaPrecoItem)
	
EndSub

Sub 'LimpaCampos'
	&Mensagem = ''
	&IsErro = 'N'
EndSub

Sub 'GetProduto'
	
    For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
	    Where ProGraRef = &ProRef
		&ProNom = ProGraNom 	
		&ProCod = ProCod
		&ProGraCod = ProGraCod
//		If ProSts = Status_AtivoInativo.INATIVO
//			&Mensagem = 'Produto código: '+trim(str(ProCod))+' Inativo!'
//			&IsErro = 'S'
//		EndIf
		
	    Exit
	When none
		&ProNom = 'PRODUTO NÃO LOCALIZADO'
		&IsErro = 'S'
		
		If not &ProRef.IsEmpty()
           &Mensagem = 'Produto código: ' +trim(&ProRef) + ' não localizado!'
        EndIF
    EndFor
EndSub
]]></Source>
