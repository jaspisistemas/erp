      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if not &NfeProVeiCor.IsEmpty()
	For Each Order EmpCod, CorCod
		Where EmpCod = &EmpCod
		Where CorNom = &NfeProVeiCor
		&CorCod = CorCod
		Exit
	when none
		UltimoCodigoEmpresa.Call(domParCod.COR, &EmpCod, 0, &CorCod)
		new
			EmpCod = &EmpCod
			CorCod = &CorCod
			CorNom = &NfeProVeiCor
		EndNew
		
		commit
		
		//GRAVA LOG
		&TabelaVarchar = 'COR'
		&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(Str(&CorCod))
			&LogErpRegTip = TrnMode.Insert
			&LogErpRegGUID.SetEmpty()
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'CorNom', '', trim(&NfeProVeiCor), &LogErpRegGUID )
		Endif
		//GRAVA LOG
	EndFor
Endif


For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	Where NfeItmCod = &NfeItmCod
	
	&NfeProCod = NfeProCod
	NfeProVeiRen = &NfeProVeiRen
	NfeProVeiCha = &NfeProVeiCha
	NfeProVeiAnoFab = &NfeProVeiAnoFab
	NfeProVeiAnoMod = &NfeProVeiAnoMod
	NfeProVeiCor = &NfeProVeiCor
	NfeProVeiPla = &NfeProVeiPla
	NfeProVeiCom =  &NfeProVeiCom
	NfeProVeiKm = &NfeProVeiKm
	Exit
EndFor

Commit


if not &NfeProVeiPla.IsEmpty()
	For Each Order EmpCod, VeiPla
		Where EmpCod = &EmpCod
		Where VeiPla = &NfeProVeiPla
		
		VeiMod = &NfeProNom
		VeiRen = &NfeProVeiRen
		VeiCha = &NfeProVeiCha
		VeiAnoFab = &NfeProVeiAnoFab
		VeiAnoMod = &NfeProVeiAnoMod
		CorCod = &CorCod
		VeiComb = &NfeProVeiCom
		VeiUltKm = &NfeProVeiKm
		VeiNfeProCod = &NfeProCod
		Exit
	When none
		UltimoCodigoEmpresa.Call(domParCod.VEICULO, &EmpCod, 0, &VeiCod)
		
		new
			EmpCod = &EmpCod
			VeiCod = &VeiCod
			VeiPla = &NfeProVeiPla
			VeiMod = &NfeProNom
			VeiUfeCod = ''
			VeiMarCod = 0
			VeiAnoFab = &NfeProVeiAnoFab
			VeiAnoMod = &NfeProVeiAnoMod
			VeiCha = &NfeProVeiCha
			VeiRen = &NfeProVeiRen
			CorCod = &CorCod
			VeiComb = &NfeProVeiCom
			VeiUltKm = &NfeProVeiKm
			VeiNfeProCod = &NfeProCod
		EndNew
		
	EndFor

	
	Commit
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
