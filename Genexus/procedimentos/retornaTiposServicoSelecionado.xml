      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&SdtTiposServico.Clear()

For Each ORder TipSerCod,TipSerItmCod,TipSerEmpCod,TipSerEmpIsUse
	Where TipSerEmpCod = &EmPCod
	Where TipSerEmpIsUse = true
	
	//adiciona os selecionados.	
	if TipSerCod <> &TipSerCod or &TipSerCod.IsEmpty()
		&TipSerCod = TipSerCod
		&SdtTiposServicoItem = new()
		&SdtTiposServicoItem.TipSerCod = TipSerCod
		&SdtTiposServicoItem.TipSerNom = TipSerNom
		&SdtTiposServico.Add(&SdtTiposServicoItem)
		
	Endif

	
EndFor
]]></Source>
