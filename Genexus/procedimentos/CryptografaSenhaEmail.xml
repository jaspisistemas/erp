      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Key = RetornaKeyCryptografia.UDP('EMAIL')

For Each Order EmpCod, EmpEmlCod
	Where EmpCod = &EmpCod
	Where EmpEmlCod = &EmpEmlCod
	EmpEmlSen = Encrypt64(&EmpEmlSen, &Key)
	Exit
EndFor

commit
	
]]></Source>
