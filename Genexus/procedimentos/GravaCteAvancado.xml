      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod, FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	CteObsGer = &WizardData.Avancado.CteObsGer.ToUpper()
	CtePlcTra = &WizardData.Avancado.CtePlaTra //tração
	CtePlc = &WizardData.Avancado.CtePla //reboque
	CteNroCon = &WizardData.Avancado.CteNroCon
	CteCpfMot = &WizardData.Avancado.CteCpfMot
	CteNomMot = &WizardData.Avancado.CteNomMot 
	CteDocTra = &WizardData.Avancado.CteDocTra
	CtePosVei = &WizardData.Avancado.CtePosVei
	CtePosDocAnt = &WizardData.Avancado.CtePosDocAnt 
	CteCiotNro = trim(&WizardData.Avancado.CteCiotNro)
	CteAveCodLim = &WizardData.Avancado.CteAveCodLim
	CteAveRam = &WizardData.Avancado.CteAveRam
	CteVlrAva = &WizardData.Avancado.CteVlrAva
	CteVlrAce = &WizardData.Avancado.CteVlrAce
	CteVlrCon = &WizardData.Avancado.CteVlrCon
EndFor
Commit


AtualizaFaturaCte.call(&EmpCod,&FilCod,&CteCod)

AtualizaObsAutomaticaCte.Call(&EmpCod, &FilCod, &CteCod)

