      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AuxVeiPla = &parmVeiPla
if Substr(&AuxVeiPla, 1, 1) <> '-'
	FormataPLACA.call(&EmpCod, &AuxVeiPla, &parmVeiPla)
Endif


if &PEsCod = 0
	For Each Order EmpCod, VeiPla
		Where EmpCod = &EmpCod
		Where VeiPla = &parmVeiPla
		
		For Each Order EmpCod, VeiPla, PesCod
			Where VeiSts = Status_SimNao.Sim
				&PEsCod = PesCod
			Exit
		EndFor
		Exit
	EndFor
EndIF
]]></Source>
