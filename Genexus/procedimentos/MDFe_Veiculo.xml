      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &OqueFAzer = 'ADD'
	For Each Order EmpCod, FilCod, MDFeCod, MDFeVeiCod
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		msg('MDFe já possui um veículo de Tração!')
		Exit
	When none
		For Each Order EmpCod, VeiCod
			Where EmpCod = &EmpCod
			Where VeiPla = &MDFeVeiPla
			Where VeiTip = VeiculoTipo.Tracao
			&MDFeVeiUF 		 = VeiUfeCod
			&MDFeVeiTar		 = VeiTar
			&MDFeVeiCap		 = VeiCap
			&MDFeVeiCapM3	 = VeiCapM3
			&MDFeVeiTipCar	 = VeiTipCarr
			&MDFeVeiTipRod	 = VeiTipRod
			&MDFeVeiRen 	 = VeiRen
			
			If VeiPro <> PropriedadeVeiculo.Proprio
				&MDFeVeiRNTRC    = VeiProRNTRC.Trim()
				&MDFeVeiProCnpj = VeiProCnpj
				&MDFeVeiProIe = VeiProIe.Trim()
				&MDFeVeiProRaz = VeiProRaz.Trim()
				&MdfeVeiProTip = VeiPro
				&MDFeVeiProUf = VeiProUf
			Else
				&MDFeVeiRNTRC = ''
				&MDFeVeiProCnpj = ''
				&MDFeVeiProIe = ''
				&MDFeVeiProRaz = ''
				&MdfeVeiProTip = PropriedadeVeiculo.Proprio
				&MDFeVeiProUf = ''
			EndIf
		
			Exit
		When none 
			msg('Veículo de Tração, não localizado!')
			Return
		EndFor
		
		For Each Order EmpCod, FilCod, MDFeCod, (MDFeVeiCod)
			Where EmpCod = &EmpCod
			WHere FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			&NewMdfeVEiCod = MDFeVeiCod
			Exit
		EndFor
		&NewMdfeVEiCod += 1
		
		NEw
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MDFeCod
			MDFeVeiCod = &NewMdfeVEiCod
			MDFeVeiPla = &MDFeVeiPla
			MDFeVeiUF = &MDFeVeiUF
			MDFeVeiTar = &MDFeVeiTar
			MDFeVeiCap = &MDFeVeiCap
			MDFeVeiCapM3 = &MDFeVeiCapM3
			MDFeVeiTipCar = &MDFeVeiTipCar
			MDFeVeiTipRod = &MDFeVeiTipRod
			MDFeVeiRen = &MDFeVeiRen
			
			///dados do proprietario do veiculo
			MDFeVeiRNTRC = &MDFeveiRNTRC
			MDFeVeiProCnpj = &MDFeVeiProCnpj
			MDFeVeiProIe = &MDFeVeiProIe 
			MDFeVeiProRaz = &MDFeVeiProRaz
			MdfeVeiProTip = &MdfeVeiProTip
			MDFeVeiProUf = &MDFeVeiProUf
			
		EndNEw
	EndFor

Else //DELETAR	
	For Each Order EmpCod, FilCod, MDFeCod, MDFeVeiCod
		Where EmpCod = &EmpCod
		WHere FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeVeiCod = &MdfeVEiCod
		delete
	EndFor	
EndIF

Commit

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
