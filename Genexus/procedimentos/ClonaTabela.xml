      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do case
	Case &oquefazer = 1 //Criar nova Tabela
		Do 'NewTable'
	Case &oquefazer = 2 //Usar Tabela Existente
	If &DstFazer = 1 // Limpar Tabela Destino e importar tabela de origem
		Do 'ClearTable'
	Else
		Do 'UpdateTable'
	EndIf
EndCase

Sub 'NewTable'
	For each Order EmpCod TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		
		New 
			EmpCod      = &EmpCod
			TabCod      = &NewTabCod
			TabNom      = 'Novo Clone da tabela '+&TabCod.Trim()
			TabDtaIni   = TabDtaIni
			TabDtaFin   = TabDtaFin
			TabIsAllUfe = TabIsAllUfe
			TabIsAllFil = TabIsAllFil
			TabIsAllAre = TabIsAllAre
			TabSts      = StatusTabela.EmConstrucao
			TabIsPerCol1= TabIsPerCol1
			TabRecCol   = TabRecCol
			TabUltAlt   = 1
		EndNew
		commit 
		
		ClonaArea.Call(EmpCod,TabCod,&NewTabCod)
		ClonaColunas.Call(EmpCod,TabCod,&NewTabCod)
		ClonaEstados.Call(EmpCod,TabCod,&NewTabCod)
		
		Do 'Produtos'
	EndFor
EndSub

Sub 'Produtos'
	For each Order EmpCod TabCod ProCod ProGraCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		Where TabAltCod = TabUltAlt
		NEW
			EmpCod    = &EmpCod
			TabCod    = &NewTabCod
			ProCod    = ProCod
			ProGraCod = 1
			TabAltCod = 1
			TabPrc1   = TabPrc1
			TabPrc2   = TabPrc2
			TabPrc3   = TabPrc3
			TabPrc4   = TabPrc4
			TabPrc5   = TabPrc5
			TabPrc6   = TabPrc6
			TabPrc7   = TabPrc7
			TabPrc8   = TabPrc8
			TabPrc9   = TabPrc9
			TabProDtaIni = TabProDtaIni
			TabProDtaFin = TabProDtaFin
		EndNew
	EndFor

	commit
EndSub


//############################################## &DstFazer  = 1 ##########################################
//Limpar tabela destino e importar da tabela de origem.:1,
Sub 'ClearTable'
	For each Order EmpCod TabCod ProCod //Limpa Tabela de Destino
		Where EmpCod = &EmpCod
		Where TabCod = &DstTabCod
		delete
	EndFor

	commit
	
	For each Order EmpCod TabCod ProCod //pega tabela origem e insere os produtos na de destino
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		Where TabAltCod = TabUltAlt
		
		&ProCod    = ProCod
		&ProGraCod = ProGraCod
		&TabAltCod = TabAltCod
		&TabPrc1   = TabPrc1
		&TabPrc2   = TabPrc2
		&TabPrc3   = TabPrc3
		&TabPrc4   = TabPrc4
		&TabPrc5   = TabPrc5
		&TabPrc6   = TabPrc6
		&TabPrc7   = TabPrc7
		&TabPrc8   = TabPrc8
		&TabPrc9   = TabPrc9
		Do 'ProdutoUpdate'
	EndFor
EndSub

Sub 'ProdutoUpdate'
	New
		EmpCod    = &EmpCod
		TabCod    = &DstTabCod
		ProCod    = &ProCod
		ProGraCod = &ProGraCod
		TabAltCod = &TabAltCod
		TabPrc1   = &TabPrc1
		TabPrc2   = &TabPrc2
		TabPrc3   = &TabPrc3
		TabPrc4   = &TabPrc4
		TabPrc5   = &TabPrc5
		TabPrc6   = &TabPrc6
		TabPrc7   = &TabPrc7
		TabPrc8   = &TabPrc8
		TabPrc9   = &TabPrc9
		TabProDtaIni.SetEmpty()
		TabProDtaFin.SetEmpty()
	EndNew

	commit
EndSub

//############################################## &DstFazer  = 2 ##########################################
//Importar produtos da tabela de origem que não estão na tabela destino.
Sub 'UpdateTable'
	
	For each Order EmpCod TabCod ProCod //pega tabela origem e insere os produtos na de destino quando não existir
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		Where TabAltCod = TabUltAlt
		&ProCod    = ProCod
		&ProGraCod = ProGraCod
		&TabAltCod = TabAltCod
		&TabPrc1   = TabPrc1
		&TabPrc2   = TabPrc2
		&TabPrc3   = TabPrc3
		&TabPrc4   = TabPrc4
		&TabPrc5   = TabPrc5
		&TabPrc6   = TabPrc6
		&TabPrc7   = TabPrc7
		&TabPrc8   = TabPrc8
		&TabPrc9   = TabPrc9
		Do 'ValidaInsere'
	EndFor
EndSub

Sub 'ValidaInsere'
	For each Order EmpCod TabCod ProCod //Valida se existe produto na tabela de dcestino Caso não tenha Insere
		Where EmpCod = &EmpCod
		Where TabCod = &DstTabCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where TabAltCod = TabUltAlt
		&TabAltCod = TabAltCod
		&Isachou = True
		Exit
	When none
		New
			EmpCod    = &EmpCod
			TabCod    = &DstTabCod
			ProCod    = &ProCod
			ProGraCod = &ProGraCod
			TabAltCod = &TabAltCod
			TabPrc1   = &TabPrc1
			TabPrc2   = &TabPrc2
			TabPrc3   = &TabPrc3
			TabPrc4   = &TabPrc4
			TabPrc5   = &TabPrc5
			TabPrc6   = &TabPrc6
			TabPrc7   = &TabPrc7
			TabPrc8   = &TabPrc8
			TabPrc9   = &TabPrc9
			TabProDtaIni.SetEmpty()
			TabProDtaFin.SetEmpty()
		EndNew
	
		commit
	EndFor
EndSub
]]></Source>
