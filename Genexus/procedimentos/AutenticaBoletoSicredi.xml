        <Source><![CDATA[/*A operação POST “autenticacao” é responsável por criar uma chave criptografada, denominada
“chaveTransacao”, baseada na Chave Master. O formato de entrada e saída é JSON, considerando que a saída
sempre é composta da entidade a ser retornada e um código HTTP dentro de um Response.
Observação : deve ser respeitada a orientação da segurança da informação referente a expiração da Chave de
Transação, observando o parâmetro “dataExpiracao” de retorno do serviço (expira a cada 24 horas). Caso o
beneficiário possua mais de uma conta, cada conta terá que ter a sua própria Chave Master, podendo assim,
gerar a Chave de Transação para cada conta específica. Não há a possibilidade de renovar o token de transação
antes da expiração. Somente com a geração de outra Chave Master será possível gerar uma nova Chave de
Transação antes da expiração.
*/

//1.1 Recurso Autenticacão
//Post passando a chave master como Header "token" 
//https://api-parceiro.sicredi.com.br/sb/auth/openapi/token

csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.SecurityProtocolType.Tls11 | System.Net.SecurityProtocolType.Tls;
HostWebServiceBoletoApi.Call('HIBRIDO',748, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor) // 748 = Sicredi
&HttpClient.Host = &EmpWebHost //servidor
&HttpClient.Secure = 1
&httpclient.AddHeader(!'Content-type',!'application/x-www-form-urlencoded')
&httpclient.AddHeader('x-api-key', trim(&CbrApiKey))
&httpclient.AddHeader('context','COBRANCA')

&HttpClient.AddVariable('scope','cobranca')
&HttpClient.AddVariable('grant_type','password')

&auxCbrNroCon = trim(&CbrNroCon)+padL(substr(trim(&CbrCtaBanAgeCod),1,4),4,'0')

If trim(&CbrCtaBanAgeCod) = '6789' and padL(substr(trim(&CbrNroCon),1,5),5,'0') = '12345'  // DIGITO DA AGENCIA '03'
	//################# no homolocação ##############################################
	&HttpClient.AddVariable('username','123456789')
	&HttpClient.AddVariable('password','teste123')
	&String = '/sb/auth/openapi/token'
Else
	//################# no produção #################################################
	&HttpClient.AddVariable('username',trim(&auxCbrNroCon)) //Beneficiário + Cooperativa
	&HttpClient.AddVariable('password',trim(&CbrChaMas)) //chave master do cliente
	&String = '/auth/openapi/token'
EndIf

padraoUsuarioHora.Call('G', '#BOLETOAPIHIBRIDOAUTHPREV', &Context.PesCod, &Context.EmpCod, &HttpClient.toString(), &PadDtaMod,ServerNow(),'T')  // Grava resultado do Post só como um LOG para Consulta

&HttpClient.Execute('POST',&String)

padraoUsuarioHora.Call('G', '#BOLETOAPIHIBRIDOAUTH', &Context.PesCod, &Context.EmpCod, &HttpClient.toString(), &PadDtaMod,ServerNow(),'T')  // Grava resultado do Post só como um LOG para Consulta


If &HttpClient.ErrCode = 0 //sem erro de comunicação
	&StdautenticacaoBoletoSicredi.fromJson(&HttpClient.toString())
	If not &StdautenticacaoBoletoSicredi.access_token.IsEmpty()
		Do 'GravaAutenticacaoLocalCobranca'
	EndIf
	&IschaveTransacao = True
	Msg('Autenticado com sucesso! '+&HttpClient.StatusCode)
Else
	&StdautenticacaoBoletoErro.fromJson(&HttpClient.toString())
	&MsgErro = &StdautenticacaoBoletoErro.codigo.Trim()+' Msg: '+&StdautenticacaoBoletoErro.mensagem.Trim() +' Parametro: '+&StdautenticacaoBoletoErro.parametro.Trim()
	msg( DVMessageBasicNotification.Udp(!"Error!", &MsgErro,DVMessageType.error, "", DVMessageBoolean.True))
	&IschaveTransacao = False
EndIf

commit

Sub 'GravaAutenticacaoLocalCobranca'
	For each Order EmpCod,CbrCod,CbrTipImp
		Where EmpCod = &EmpCod
		Where CbrCod = &CbrCod
		&CbrChaTra = &StdautenticacaoBoletoSicredi.access_token
		CbrChaTra = &StdautenticacaoBoletoSicredi.access_token
		&Tempo = &StdautenticacaoBoletoSicredi.expires_in
		&datahora = ServerNow()
		&CbrChaTraVct = &datahora.AddSeconds(&Tempo)
		//"2019-08-29T08:20:21"
		CbrChaTraVct = &CbrChaTraVct

		exit
	EndFor
	Commit
EndSub

]]></Source>
