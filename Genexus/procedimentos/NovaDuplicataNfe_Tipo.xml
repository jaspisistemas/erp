      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do Case
	Case &OqueFazer = 'ALT'
		For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeDupItmCod = &inNfeDupItmCod
			
			NfeDupNro = &NfeDupNro
			NfeDupVlr = &NfeDupVlr	
			NfeDupVct = &NfeDupVct
			NfeCbrCod = &NfeCbrCod
			
			Exit
		EndFor
		
		Commit
		
	Case &OqueFazer = 'ADD'
		&Parcela = &qtdParcela
		&PedVlrBas = &NfeDupVlr
		
		&CreVlrDup = round((&PedVlrBas / &Parcela),2)
		&ResCreVlrDup = round(&PedVlrBas,2) - (round((&PedVlrBas / &Parcela),2) * &Parcela)
		
		&ParMax  = &Parcela
		&Parcela = 1
		
		&AuxNfeDupVct = &NfeDupVct
		
		&NfeDupItmCod = 0 
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			
			&CreCbrCod = FilCbrCod
			&NfeCLiCod = NfeCliCod
			do 'GetCliente'
			For Each Order EmpCod, FilCod, NfeCod, (NfeDupItmCod)
				&NfeDupItmCod = NfeDupItmCod				
				Exit
			EndFor
			Exit
		EndFor
	
		Do while &Parcela <= &ParMax
			&NfeDupItmCod += 1
			
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				NfeCod = &NfeCod
				NfeDupItmCod = &NfeDupItmCod	
				
				NfeDupCreSeq = 0
				NfeDupFiLCod = 0
				
				NfeDupFrpPgtoCod = &NfeDupFrpPgtoCod
				
				&AuxCreDupNro = ltrim(str(&NfeDupItmCod))
				NfeDupNro =  trim(&AuxCreDupNro)

				if &Parcela = 1
					NfeDupVlr = (&CreVlrDup + &ResCreVlrDup)
				else
					NfeDupVlr = &CreVlrDup
				endif
				
				NfeDupVct = &AuxNfeDupVct
				
				//&PedTmpSem = substr(cdow(&CreDtaVct(&Parcela)), 1, 3)
				//PedTmpSem = &PedTmpSem
				
				//&PedTmpPrz = (&CreDtaVct(&Parcela) - &PedDtaFat) 
				//PedTmpPrz = &PedTmpPrz
				
			    do Case
					Case &CreCbrCod <> 0
						NfeCbrCod = &CreCbrCod
					Case &PedCliCbrCod = 0
				        NfeCbrCod = 1
				    Otherwise
				        NfeCbrCod = &PedCliCbrCod
			    EndCase
			 	//FIM DUPLICATA
				
				
				//			if &CrePlanCod.IsEmpty()
				//				RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &TCon044_PlanoRecCliente)
				//				RetornaCodigoPlanoCOntas.Call(&EmpCod, &TCon044_PlanoRecCliente, &PlanCod)
				//			Else
				//				&PlanCod = &CrePlanCod
				//			EndiF
				//			PedTmpPlanCod = &PlanCod
			EndNew
			
			&Parcela += 1
			&AuxNfeDupVct = &AuxNfeDupVct.AddMonths(1)
		EndDo
		
		commit
		
	Case &OqueFazer = 'DEL'
		For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeDupItmCod = &inNfeDupItmCod
			&NfeDupFiLCod = NfeDupFiLCod
			&NfeDupCreSeq = NfeDupCreSeq
			
			delete
			Exit
		EndFor
		
		commit
		
		//		&NfeDupFiLCod = NfeDupFiLCod
		//		&NfeDupCreSeq = NfeDupCreSeq
EndCase


sub 'GetCliente'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NfeCliCod
		&PedCliCbrCod = PesCbrCod
		Exit
	EndFor
EndSub
]]></Source>
