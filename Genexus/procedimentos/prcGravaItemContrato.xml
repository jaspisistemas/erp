      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


if &SerItmProId = 0
	For Each ORder EmpCod, SerItmCod, (SerItmProId) //PEGA ULTIMO CODIGO
		Where EmpCod = &EmpCod
		Where SerItmCod = &SerItmCod
		
		&SerItmProIdNew = SerItmProId
		Exit
	EndFor
	&SerItmProIdNew += 1

	New	 //GRAVA NOVO ITEM
		EmpCod = &EmpCod
		SerItmCod = &SerItmCod
		SerItmProId = &SerItmProIdNew
		
		SerItmProCod = &SerItmProCod
		SerItmProGraCod = &SerItmProGraCod
		SerItmProQtd = &SerItmProQtd
		SerItmProVlrUnt = &SerItmProVlrUnt
		SerItmProVlrTot = &SerItmProVlrUnt*&SerItmProQtd
	EndNew
	
	Commit
Else
	For Each ORder EmpCod, SerItmCod, SerItmProId //ATUALIZA
		Where EmpCod = &EmpCod
		Where SerItmCod = &SerItmCod
		Where SerItmProId = &SerItmProId
		
		SerItmProCod = &SerItmProCod
		SerItmProGraCod = &SerItmProGraCod
		SerItmProQtd = &SerItmProQtd
		SerItmProVlrUnt = &SerItmProVlrUnt
		SerItmProVlrTot = &SerItmProVlrUnt*&SerItmProQtd
		
		Exit
	EndFor
	
	Commit
EndIf


For Each ORder EmpCod, SerItmCod, SerItmProId
	Where EmpCod = &EmpCod
	Where SerItmCod = &SerItmCod
	
	&SerItmProVlrTot += SerItmProVlrTot
	
EndFor

For Each ORder EmpCod, SerItmCod
	Where EmpCod = &EmpCod
	Where SerItmCod = &SerItmCod
	
	SerItmVlr = &SerItmProVlrTot
	
	Exit
EndFor

Commit

]]></Source>
