      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//ATUALIZA DATAS DE FATURAMENTO
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	//Where (NfePedDtaFat_FORMULA >= &iniNfeDtaEms and NfePedDtaFat_FORMULA <= &finNfeDtaEms ) or NfePedDtaFat_FORMULA.IsEmpty() or //JDF ESSE FILTRO TAVA TRAVANDO O ENVIO DE NOTAS SINTEGRA MERCADO PLUMA
	
	//Where (NfeDtaEms >= &iniNfeDtaEms and NfeDtaEms <= &finNfeDtaEms ) or (NfeDtaDsp >= &iniNfeDtaEms and NfeDtaDsp <= &finNfeDtaEms  ) or (NfeDtaFat >= &iniNfeDtaEms and NfeDtaFat <= &finNfeDtaEms)
	Where NfeDtaFat.IsNull() or NfeDtaFat.IsEmpty() or NfeDtaFat_Mes.IsNull() or NfeDtaFat_Ano.IsNull() or NfeDtaFat_Ano.IsEmpty() or NfeDtaFat_Mes.IsEmpty()
	//Where NfePedCod > 0 or NfeDtaFat.IsNull() or NfeDtaFat.IsEmpty() or NfeDtaFat_Mes.IsNull() or NfeDtaFat_Ano.IsNull() or NfeDtaFat_Ano.IsEmpty() or NfeDtaFat_Mes.IsEmpty()	

	
	&NfeDtaFat = NfePedDtaFat_FORMULA
	if NfeDtaEms <= &NfeDtaFat or &NfeDtaFat.IsEmpty()
		NfeDtaFat = &NfeDtaFat
		if &NfeDtaFat.IsEmpty()
			NfeDtaFat_Mes = 0
			NfeDtaFat_Ano = 0
		Else
			NfeDtaFat_Mes = &NfeDtaFat.Month()
			NfeDtaFat_Ano = &NfeDtaFat.Year()
		Endif
	Endif
EndFor

commit
]]></Source>
