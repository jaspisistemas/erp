        <Source><![CDATA[

&LogGUID = GUID.NewGuid()

//csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.ServicePointManager.SecurityProtocol;

&EmlSts = Status_Solicitacao.Pendente
&EmlTip = TipoContaEmail.Email_Faturamento

For Each Order EmpCod, EmlTip, EmlCod
	Where EmpCod = &EmpCod
	Where EmlTip = &EmlTip
	Where EmlCod = &EmlCod
	
	&CteCod = EmlSeqCod
	
	do 'Filial'
	Do 'Login'
	
	&PesCod = EmlPesCod
	do 'Funcionario'
		
	do 'CTe'

	&EmlAss = EmlAss
	&EmlObs = EmlObs
    Exit
EndFor


	//=====Insere o assunto da mensagem=====

&mensagem = 'Destinatarios'

For Each Order EmpCod, EmlTip, EmlCod, EmlItmCod
	Where EmpCod = &EmpCod
	Where EmlTip = &EmlTip
	Where EmlCod = &EmlCod
	&mensagem += '; ' + trim(EmlUrl)
	//Destinatário de email
	&Destinatarios.Add(EmlUrl)
EndFor

do 'mensagem'	
&mensagem = 'Anexos: '

if not &CteArqXml.IsEmpty()
	geraPdfDacte_web.Call(&EmpCod, &EmlFilCod, &CteCod, &UrlVirtual, &URlFisico)
	
	&File.Source = &URlFisico //PDF
	If &File.Exists()
		&mensagem += ' ' + trim(&URlFisico)
		do 'mensagem'
		//=====Adiciona Anexo a partir de um caminho do servidor=====
		&Attachments.Add(&URlFisico)
		GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &URlFisico)
	EndIF
EndIF

//XML

&File.Source = &PastaAutorizadas
If &File.Exists()
	&mensagem += '; ' + trim(&PastaAutorizadas)
 	&Attachments.Add(&PastaAutorizadas)
	GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &PastaAutorizadas)
Else
	GravaXmlCtedoBancoDados.Call(&EmpCod, &EmlFilCod, &CteCod, &sdtConfiguracoesPasta)
	&File.Source = &PastaBancoDados
	If &File.Exists()
		&mensagem += '; ' + trim(&PastaBancoDados)
		do 'mensagem'
		&Attachments.Add(&PastaBancoDados)	
		GravaAnexosEmailBase64.Call(&EmpCod, &EmlTip, &EmlCod, &PastaBancoDados)
	EndIF
EndIf				

Do 'PreencheHTML'

//finaliza login
&Result = &JASPI_enviaEmail.SendEmailSafeJson(&HostVarchar, &PortNumeric, &UserNameVarchar, &EmpEmlSen, &imapHost, &imapPort, &imapSsl, &FilRaz, &AddressVarchar, &FunEmailContato, &FilRaz, &Destinatarios, &EmlAss, &Obs, &Attachments, true)
	
&EmailResult.FromJson(&Result)

If &EmailResult.Success = true
    // Marca como enviado
	&EmlMsg = 'Enviado com Sucesso!'
	&Tentativa = 99
	&EmlSts = Status_Solicitacao.Finalizada
Else
	&EmlMsg = &EmailResult.ErrorCode + " - " + &EmailResult.Message
	&Tentativa = 99
	
	&EmlSts = Status_Solicitacao.Falha
EndIf

Sub 'CTe'
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &EmlFilCod
		Where CteCod = &CteCod
		&CteSer = CteSer
		&CteNum = CteNum
		&auxCteNum = CteNum
		&CteModCod = CteModCod
		&CteChv = CteChv
		&CteVlrTotPreSer = CteVlrTotPreSer
		&CteRemRaz = CteRemRaz
		&PastaDanfeNota = str(year(CteDtaEms),4,0)+padl(trim(str(month(CteDtaEms),2,0)),2,'0')
		&CteArqXml = CteArqXml
		
		&CtePlcTra = CtePlcTra
		&CtePlc = CtePlc
		&CteMotNom = CteCpfMot
		&CteMotNom += '-'+CteNomMot
		&CteDocTra = CteDocTra
		&CteNroCon = CteNroCon
		
		&AnoMes = str(year(CteDtaEms),4,0)+padl(trim(str(month(CteDtaEms),2,0)),2,'0')
		&PastaAutorizadas = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "Autorizados\" + &AnoMes.trim() + "\" + &CteChv.Trim() + '-procCTe.xml'
		&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\" + CteChv.Trim() + '-jaspi.xml'
		
		Exit
	EndFor
EndSub

Sub 'Filial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &EmlFilCod
		
	 	&FilRaz = iif(FilFan.IsEmpty() or FilFan.IsNull(), FilRaz,FilFan)
		&FilFonNum = FormataFONE.Udp(FilFonNum)
		Exit
	EndFor
EndSub

Sub 'login'
	For Each Order EmpCod, EmpEmlCod
		Where EmpCod = &EmpCod
		Where EmpEmlTip = &EmlTip
		
		If EmpEml = 'nao_responda@jaspi.com.br' or EmpEml = 'nao.responda.jaspi@gmail.com' //adiciona a mensagem dados do remetente
			&EmpEmlCod = EmpEmlCod
			do 'EmailPadrao'
		Else
			&AddressVarchar = EmpEml
			//&FilRaz
			&AuthenticationNumeric = EmpEmlAut
			&SecureNumeric 		= EmpEmlSec
			&TimeoutNumeric        = 600
			&HostVarchar 			= EmpEmlHos
			&UserNameVarchar 		= EmpEmlUsr
			&EmpEmlSen 		= DecryptSenhaEmail.Udp(EmpCod, EmpEmlCod, EmpEml)
			&PortNumeric 			= EmpEmlPor
			&imapHost = EmpEmlImapHos
			&imapPort = EmpEmlImapPor
			&imapSsl = EmpEmlImapSsl
		EndIF
		
		Exit
	When None
		GravaRemetentePadrao.Call(&EmpCod, &EmlTip, &EmpEmlCod)
		do 'EmailPadrao'
	EndFor
EndSub

sub 'EmailPadrao'
	EmailPadrao.call(&AddressVarchar, &AuthenticationNumeric, &SecureNumeric, &TimeoutNumeric, &HostVarchar, &UserNameVarchar, &PortNumeric, &imapHost, &imapPort, &ImapSSl)
	&EmpEmlSen = DecryptSenhaEmail.Udp(&EmpCod, &EmpEmlCod, &AddressVarchar)
	
EndSub

sub 'PreencheHTML'
	
	&Obs =  '<html > '
	&Obs +=  ' <head> '
	&Obs +=  ' <meta http-equiv="Content-Type" content="text/html; charset=utf-8" /> '
	&Obs +=  ' <style type="text/css"> '
	&Obs +=  ' <!-- '
	&Obs +=  ' .A2B {	color: #900; '
	&Obs +=  ' } '
	&Obs +=  ' body,td,th,p { '
	&Obs +=  ' font-size: 13px; '
	&Obs +=  ' color: #000; '
	&Obs +=  ' } '
	&Obs +=  ' body { '
	&Obs +=  ' background-color: #F0F0F0; '
	&Obs +=  ' } '
	&Obs +=  ' a:link { '
	&Obs +=  ' color: #069; '
	&Obs +=  ' text-decoration: none; '
	&Obs +=  ' } '
	&Obs +=  ' a:visited { '
	&Obs +=  ' text-decoration: none; '
	&Obs +=  ' color: #069; '
	&Obs +=  ' } '
	&Obs +=  ' a:hover { '
	&Obs +=  ' text-decoration: underline; '
	&Obs +=  ' } '
	&Obs +=  ' a:active { '
	&Obs +=  ' text-decoration: none; '
	&Obs +=  ' } '
	&Obs +=  ' #A1A { '
	&Obs +=  ' font-size: 22px; '
	&Obs +=  ' } '
	&Obs +=  ' .A3A { '
	&Obs +=  ' color: #069; '
	&Obs +=  ' } '
	&Obs +=  ' --> '
	&Obs +=  ' </style> '
	&Obs +=  ' </head> '
	
	&Obs +=  ' <body> '
	
	&Obs +=  ' <p>Conhecimento de Transporte enviado por: '+trim(&FilRaz)+'<br/> '
	&Obs +=  ' Nome de Contato: '+ trim(&FunNom) +'<br/> '
	
	if not &FunEmailContato.IsEmpty()
		&Obs +=  'E-mail de Contato: <a href="mailto:'+ trim(&FunEmailContato) +'">'+ trim(&FunEmailContato) +'</a><br/> '
	EndIF

	if not &FilFonNum.IsEmpty()
		&Obs +=  'Fone de Contato: '+ trim(&FilFonNum)+'</p>'
	EndIF
	
	&Obs +=  '<p>'
		if not &CtePlcTra.IsEmpty()
			&Obs +=  'Tração: '+ trim(&CtePlcTra)+'<br/>'
		EndIF
	
		if not &CtePlc.IsEmpty()
			&Obs +=  'Reboque: '+ trim(&CtePlc)+'<br/>'
		EndIF
	
		if not &CteMotNom.IsEmpty()
			&Obs +=  'Motorista: '+ trim(&CteMotNom)+'<br/>'
		EndIF
		
		if not &CteDocTra.IsEmpty()
			&Obs +=  'DT: '+ trim(&CteDocTra)+'<br/>'
		EndIF
		
		if not &CteNroCon.IsEmpty()
			&Obs +=  'Container: '+ trim(&CteNroCon)+'<br/>'
		EndIF
	&Obs +=  '</p>'
	
	&Obs +=  ' <p>#Essa mensagem foi enviada por <a href="http://www.jaspi.com.br">JASPI - Soluções em Software</a>, <span class="A2B">não utilize a opção responder o e-mail.</span>#<br/> '
	&Obs +=  ' -------------------------------------------------------------------------------------------------------------------</p>'
	
	If not &EmlObs.IsEmpty()
		&Obs += ' <ul> '
		&Obs +=  ' <li id="A1A">    <strong>'+trim(&EmlObs)+'</strong></li> '
		&Obs += ' </ul> '
		&Obs +=  ' <p>-------------------------------------------------------------------------------------------------------------------</p> '
	EndIF
	
	&Obs +=  ' <p>Prezado cliente,</p> '
	&Obs +=  ' <blockquote> '
	&Obs +=  ' <p>Você está recebendo o conhecimento de transporte número '+ trim(toformattedString(&auxCteNum)) +', série ' +  padl(trim(str(&CteSer)), 3, '0')  + ' de ' +trim(&FilRaz)+ ', no valor de R$ ' 
	+ trim(ToFormattedString(&CteVlrTotPreSer)) + '. Além disso, junto com a mercadoria seguirá o DACTE (Documento Auxiliar do Conhecimento de Transporte Eletrônico), impresso em papel que acompanha o transporte das mesmas. '
	&Obs +=  ' <br/>Anexo à este e-mail você está recebendo também o arquivo XML do Conhecimento de Transporte Eletrônico. Este arquivo deve ser armazenado eletronicamente por sua empresa pelo prazo de 05 (cinco) anos, conforme previsto na legislação tributária (Art. 173 do Código Tributário Nacional e § 4º da Lei 5.172 de 25/10/1966). '
	&Obs +=  ' <br/>O DACTE em papel pode ser arquivado para apresentação ao fisco quando solicitado. Todavia, se sua empresa também for emitente de CT-e, o arquivamento eletrônico do XML de seus fornecedores é obrigatório, sendo passível de fiscalização. '
	&Obs +=  ' <br/>Para se certificar que este CT-e é válido, queira por favor consultar sua autenticidade no site nacional do projeto CT-e <a href="http://www.cte.fazenda.gov.br/portal/consulta.aspx?tipoConsulta=completa&tipoConteudo=mCK/KoCqru0="> (www.cte.fazenda.gov.br) </a>, utilizando a chave de acesso contida no DACTE.</p> '
	&Obs +=  ' </blockquote> '
	&Obs +=  ' <p> Atenciosamente, '
	&Obs +=  ' <br/> '
	&Obs +=  trim(&FilRaz)+ '.</p> '
	&Obs +=  ' <p>Descrição dos anexos: '
	
	&arquivoXML = &CteChv.Trim() + '-procCTe.xml'
	&ArquivoPDF = &CteChv.Trim() + '.pdf'
	&Obs +=  ' <br/>- <span class="A3A">' + trim(&arquivoXML) + '</span> - Esse arquivo é o próprio Conhecimento de Transporte Eletrônico, que deve ser guardada pelo período de 05 anos. Ele contém todas as informações do emitente, Remetente, Destinatário, Tomador, Tributação, etc. Esse arquivo, além de guardado, deve ser enviado para o setor de contabilidade. <br/> '
	&Obs +=  ' - <span class="A3A">' + trim(&ArquivoPDF) + '</span> - DACTE é o Documento Auxiliar do Conhecimento de Transporte Eletrônico, utilizado para acompanhar o trânsito da mercadoria. É uma representação gráfica simplificada do Conhecimento de Transporte Eletrônico, em papel comum e em via única.</p> '
	&Obs +=  ' <p>-------------------------------------------------------------------------------------------------------------------<br/>#Essa mensagem foi enviada por <a href="http://www.jaspi.com.br">JASPI - Soluções em Software</a>, <span class="A2B">não utilize a opção responder o e-mail.</span>#</p> '
	&Obs +=  ' </body> '
	&Obs +=  ' </html> '
EndSUb

Sub 'Mensagem'
	msg(&mensagem  + ' Hora: ' + serverTime(), status)
EndSub

Sub 'Funcionario'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&FunNom = PesRaz
		
		For Each Order EmpCod, PesCod, PesEmlCod
			&FunEmailContato = PesEml
			Exit
		EndFor
		
		Exit
	EndFor
EndSub


Sub 'Exception_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXexceptionType',&GXexceptionType)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionDetails',&GXExceptionDetails)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionStack',&GXExceptionStack)
Endsub

Sub 'Error_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &Err',&Err.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBErr',&gxDBErr.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &GxDbSqlState',&GxDbSqlState)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBTxt',&gxDBTxt)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxOper',&gxOper)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrTbl',&gxErrTbl)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrOpt',&gxErrOpt.ToFormattedString())
Endsub

