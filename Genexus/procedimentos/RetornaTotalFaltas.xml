      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TotalFaltas = 0

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where PedQtdCan > 0 when (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
		Where PedQtd > 0 and EstQtd < PedQtd when (PedSts <> Status_Pedido.FECHADO and PedSts <> Status_Pedido.SEPARANDO)
		
		If (PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
			&PedQtdCan = PedQtdCan
		Else		
			if EstQtd < 0
				&PedqtdCan = PedQtd
			Else
				&PedqtdCan = PedQtd - EstQtd
			EndIf
		EndIf
		
		&PedVlrItm = PedVlrUnt * &PedQtdCan
		
		&TotalFaltas += &PedVlrItm
	EndFor

EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
