      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	if &ProRef.IsEmpty() //cadastro novo, se vier de novo ai retorna dados basicos, senao retorna erro
		&sdtProduto.sts = 'E900'
		&sdtProduto.obs = 'Informe Referencia do produto.'
		return
	Else
		RetornaProdutoReferencia.Call(&wwpContext.EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &MensagemErro)
		
		if &procod = 0
			&sdtProduto.sts = 'E901'
			&sdtProduto.obs = 'ERRO: ' + &MensagemErro.Trim()
			return
		Else
			For Each Order EmpCod, ProCod
				Where EmpCod = &wwpContext.EmpCod
				Where ProCod = &procod
				
				&sdtProduto.Cod = ProCod
				&sdtProduto.GraCod = &ProGraCod
				&sdtProduto.Ref = ProRef
				&sdtProduto.Nom = ProNom
				&sdtProduto.Bar = ProBar
				&sdtProduto.MarN = MarNom
				//&sdtProduto.MarC
				//&sdtProduto.PItmCod
				//&sdtProduto.PQtd
				//&sdtProduto.PVlrUnt
				//&sdtProduto.PVlrUntDsc
				//&sdtProduto.PInfPrc
				//&sdtProduto.PDsc
				//&sdtProduto.PVlrItm
				//&sdtProduto.PCpl
				
				//DADOS DO VALOR
				retornaPrecoUnitarioVenda.Call(&wwpContext.EmpCod, &tabCod, '', &ProCod, &ProGraCod, &TabColCod, serverdate(), &PedDtaVct, &PedVlrUnt)
				&sdtProduto.Vlr = RetiraZerosDepoisVirgulaxCasas.Udp(2, &PedVlrUnt.ToFormattedString())
			
				//&sdtProduto.VlrPrm
				//&sdtProduto.ProIs
				//&sdtProduto.ImgUrl
				//&sdtProduto.Est
				//&sdtProduto.Sdo
				//&sdtProduto.MDsc
				Exit			
			EndFor
		Endif
	Endif
Else
	&sdtProduto.sts = 'E999'
	&sdtProduto.obs = 'Algo errado!'
	return
Endif
]]></Source>
