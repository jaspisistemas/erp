      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For &Mes=1 to 12
	For Each Order EmpCod, PesCod, PesMetAno, PesMetMes
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesMetAno = &PesMetAno
		Where PesMetMes = &Mes
		Do Case
			CAse &Mes = 1
				PesMetVlr = &JanPesMetVlr
			CAse &Mes = 2
				PesMetVlr = &FevPesMetVlr
			CAse &Mes = 3
				PesMetVlr = &MarPesMetVlr
			CAse &Mes = 4
				PesMetVlr = &AbrPesMetVlr
			CAse &Mes = 5
				PesMetVlr = &MaiPesMetVlr
			CAse &Mes = 6
				PesMetVlr = &JunPesMetVlr
			CAse &Mes = 7
				PesMetVlr = &JulPesMetVlr
			CAse &Mes = 8
				PesMetVlr = &AgoPesMetVlr
			CAse &Mes = 9
				PesMetVlr = &SetPesMetVlr
			CAse &Mes = 10
				PesMetVlr = &OutPesMetVlr
			CAse &Mes = 11
				PesMetVlr = &NovPesMetVlr
			CAse &Mes = 12
				PesMetVlr = &DezPesMetVlr
		EndCase
		Exit
	When none
		New
			EmpCod = &EmpCod
			PesCod = &PesCod
			PesMetAno = &PesMetAno
			PesMetMes = &Mes
			Do Case
				CAse &Mes = 1
					PesMetVlr = &JanPesMetVlr
				CAse &Mes = 2
					PesMetVlr = &FevPesMetVlr
				CAse &Mes = 3
					PesMetVlr = &MarPesMetVlr
				CAse &Mes = 4
					PesMetVlr = &AbrPesMetVlr
				CAse &Mes = 5
					PesMetVlr = &MaiPesMetVlr
				CAse &Mes = 6
					PesMetVlr = &JunPesMetVlr
				CAse &Mes = 7
					PesMetVlr = &JulPesMetVlr
				CAse &Mes = 8
					PesMetVlr = &AgoPesMetVlr
				CAse &Mes = 9
					PesMetVlr = &SetPesMetVlr
				CAse &Mes = 10
					PesMetVlr = &OutPesMetVlr
				CAse &Mes = 11
					PesMetVlr = &NovPesMetVlr
				CAse &Mes = 12
					PesMetVlr = &DezPesMetVlr
			EndCase
		EndNew
		
	EndFor
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
