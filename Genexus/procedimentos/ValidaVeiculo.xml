      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsErro = False
If &VeiPla <> ''
	For Each Order EmpCod,VeiCod
		Where EmpCod = &EmpCod 
		Where VeiPla = &VeiPla
		&Veicod = VeiCod
		If VeiRen.Trim().IsEmpty()
			&IsErro = True
			msg('ATENÇÃO! Nro do renavam do veículo inválido. Verifique!')
		EndIf
		
		If VeiPla.Trim().IsEmpty()
			&IsErro = True
			msg('ATENÇÃO! Placa do veículo inválida. Verifique!')
		EndIf 
		
		If VeiTip <> VeiculoTipo.Tracao and VeiTip <> VeiculoTipo.Reboque
			&IsErro = True
			msg('ATENÇÃO! Tipo de veículo diferente de tração ou reboque. Verifique!')
		EndIf
	EndFor
Else
	msg('ATENÇÃO! Veículo não Cadatrado. Verifique!')
	&IsErro = True
EndIf

]]></Source>
