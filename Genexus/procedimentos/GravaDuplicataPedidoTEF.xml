      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do Case
	CAse &OqueFazer = 'DEL'
		if not &TefGuid.IsEmpty()
			For Each Order EmpCod, FilCod, PedCod, PedFrpItmCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where PedCod = &PedCod
				Where PedFrpTefGUID = &TefGuid
				Delete
			EndFor
		Endif

		Commit
		
	Case &OqueFazer = 'ID'
		For EAch ORder EmpCod, FilCod, PedCod, PedFrpItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedFrpTefGUID = &TefGuid
			
			if 	not &PedFrpAutNsu.IsEmpty() and (PedFrpAutNsu.IsEmpty() or PedFrpAutNsu.IsNull())
				PedFrpAutNsu = &PedFrpAutNsu
			Endif
		
			Exit
		EndFor
	
		COMMIT
	Case &OqueFazer = 'ADD'
		For EAch ORder EmpCod, FilCod, PedCod, PedFrpItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedFrpTefGUID = &TefGuid
			
			if not &PedFrpAutCrt.IsEmpty()
				PedFrpAutCrt = &PedFrpAutCrt
			Endif
			
			if 	not &PedFrpAutNsu.IsEmpty()
				PedFrpAutNsu = &PedFrpAutNsu
			Endif
			
			if 	not &PedFrpCardNom.IsEmpty()
				PedFrpCardNom = &PedFrpCardNom
			Endif
		
		
			exit
			
		When none
			For Each Order EmpCod, FilCod, PedCod, (PedFrpItmCod)
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where PedCod = &PedCod
				
				&PedFrpItmCod = PedFrpItmCod
				Exit
			EndFor
			
			&PedFrpItmCod += 1
			New
				EmpCod = &EmpCod
				FilCod = &FilCod		
				PedCod = &PedCod		
				PedFrpItmCod = &PedFrpItmCod
				PedItmFrpPgtoCod = &PedItmFrpPgtoCod
				PedTipVlr = &PedTipVlr
				PedFrpCliCod = &PedFrpCliCod
				PedFrpDtaVct = &PedFrpDtaVct
				
				Do Case
					CAse PedFrpDtaVct.DayOfWeek()= 1
						PedFrpDtaVct = PedFrpDtaVct.AddDays(1)
					CAse PedFrpDtaVct.DayOfWeek()= 7
						PedFrpDtaVct = PedFrpDtaVct.AddDays(2)
				EndCase
				
				PedFrpAutCrt = &PedFrpAutCrt
				PedFrpAutNsu = &PedFrpAutNsu
				PedFrpIsTefCod = &PedFrpIsTefCod 
				
				PedFrpTefGUID = &TefGuid
				PedFrpBanCarCod = &TEfBancArCod
				
				&GUID = GUID.NewGuid()
				PedFrpGUID = &GUID.ToString()
			EndNEw
			
			Commit
		EndFor
		
EndCAse



]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
