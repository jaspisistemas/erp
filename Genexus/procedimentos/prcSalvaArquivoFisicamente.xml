      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)

For Each Order EmpCod, PesCod, PesAnxCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesAnxCod = &PesAnxCod
	
	&DiretorioVarchar = &SdtConfiguracoesPasta.PastaAnexosFis.Trim()
	
	&Directory.Source = &DiretorioVarchar
	if not &Directory.Exists()
		&Directory.Create()
	Endif
	
	&PesAnxGuidNom = PesAnxNom
	&PesAnxGuidExt = PesAnxExt
	&CaminhoVarchar = &DiretorioVarchar.Trim() + trim(&PesAnxGuidNom.ToString())+'_'+trim(PesAnxGuid.ToString()) +'.'+ trim(&PesAnxGuidExt)
	
	&File.Source = &CaminhoVarchar
	If not &File.Exists()
		//&File.Create()
		&File.FromBase64String(PesAnxArq.ToBase64String())
	EndIf
	&File.Close()
	
	PesAnxGuidNom = &PesAnxGuidNom
	PesAnxGuidExt = &PesAnxGuidExt
	
	PesAnxNom.SetEmpty()
	PesAnxExt.SetEmpty()
	PesAnxArq.SetEmpty()
	
	Exit
EndFor

Commit
]]></Source>
