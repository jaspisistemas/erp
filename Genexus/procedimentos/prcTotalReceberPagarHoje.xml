      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//PAGAR
For each Order EmpCod,FilCod,CreRecPag,CreDtaVct,CreCod
	Where EmpCod = &EmpCod
	where FilCod = &FilCod
	Where CreRecPag = ReceberPagar.Pagar
	Where CreDtaVct = ServerDate()
	Where CreVlrSdo > 0
	where CreSts <> Status_Duplicata.CANCELADA
	&PagarMoeda += CreVlrSdo
EndFor

//RECEBER
For each Order EmpCod,FilCod,CreRecPag,CreDtaVct,CreCod
	Where EmpCod = &EmpCod
	where FilCod = &FilCod
	Where CreRecPag = ReceberPagar.Receber
	Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA or CreFrpPgtoTip = TipoDuplicata.DEPOSITO or CreFrpPgtoTip = TipoDuplicata.PIX
	Where CreDtaVct = ServerDate()
	Where CreVlrSdo > 0
	where CreSts <> Status_Duplicata.CANCELADA
	&ReceberMoeda +=CreVlrSdo
EndFor
]]></Source>
