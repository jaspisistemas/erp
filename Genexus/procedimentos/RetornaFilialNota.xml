      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&NfeFilCod  = 0

For Each Order EmpCod, NfeFilCod, NfePedCod
	Where EmpCod = &EmpCod
	Where NfePedCod = &PedCod
	Where NfeFilCod = &FilCod
	where NfeSts = Status_Nfe.Autorizada or NfeSts = Status_nfe.Digitando
	&NfeFilCod = FilCod
	Exit
EndFor
]]></Source>
