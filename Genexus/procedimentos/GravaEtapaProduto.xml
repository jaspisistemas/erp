      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
do case
	case &OqueFazer = 'DEL'
		For Each Order EmpCod, GrupCod, GrupCTrOrd
			Where EmpCod = &EmpCod
			Where GrupCod = &GrupCod
			where GrupCTrOrd = &inGrupCTrOrd when &inGrupCTrOrd <> 0
			delete
		EndFor
		
		commit
	case &OqueFazer = 'ADD'
		&GrupCTrOrd = 0
		For Each Order EmpCod, GrupCod, (GrupCTrOrd)
			Where EmpCod = &EmpCod
			Where GrupCod = &GrupCod
			&GrupCTrOrd = GrupCTrOrd
			Exit
		EndFor
		&GrupCTrOrd += 1
		
		New
			EmpCod = &EmpCod
			GrupCod = &GrupCod
			GrupCTrOrd = &GrupCTrOrd
			GrupCTrCod = &GrupCTrCod
			GrupCTrQtd = &GrupCTrQtd
		EndNEw
		
		commit
		
	case &OqueFazer = 'COP'
		For Each Order EmpCod, GrupCod, GrupCTrOrd
			Where EmpCod = &EmpCod
			Where GrupCod = &GrupCod
			delete
		EndFor
		
		commit

		For Each Order EmpCod, GrupCod, GrupCTrOrd
			Where EmpCod = &EmpCod
			Where GrupCod = &GrupCTrCod
			
			New
				EmpCod = &EmpCod
				GrupCod = &GrupCod
				GrupCTrOrd = GrupCTrOrd
				GrupCTrCod = GrupCTrCod
				GrupCTrQtd = GrupCTrQtd
			EndNEw
		
		EndFor
		
		commit
endcase

]]></Source>
