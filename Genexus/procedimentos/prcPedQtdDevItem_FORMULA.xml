      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//COM PEDIDO CAPA
&PedQtd = 0
For Each Order EmpCod, FilCod, PedSts, ProCod, ProGraCod,PedCodOciRef
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ((PedCodOciRefItm.IsNull() or PedCodOciRefItm.IsEmpty()) and PedCodOciRef = &PedCod) or PedCodOciRefItm = &PedCod
	Where ((PedItmCodOciRefItm.IsEmpty() or PedItmCodOciRefItm.IsNull()) and PedCodOciRef = &PedCod) or PedItmCodOciRefItm = &PedItmCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where PedSts = Status_Pedido.FECHADO
	//Where LctGerFin = Status_SimNao.Sim
	Where PedStsGer = Pedido_Gerado.DevolucaoVendas or PedStsGer = Pedido_Gerado.TrocaMercadorias
	
	&PedQtd += PedQtd
	
EndFor

