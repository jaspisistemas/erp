      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&QtdItensComposicao = 0
For Each Order EmpCod, FilCod, PedCod, PedItmCodRef, PedItmProdComp
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCodRef = &PedItmCod
	Where PedItmProdComp  = 'A' //COMPOSICAO
	
	&QtdItensComposicao += 1
EndFor
]]></Source>
