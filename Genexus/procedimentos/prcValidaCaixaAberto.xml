      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsCaixaFechado = false
&Mensagem.SetEmpty()
if not &DataLancamento.IsEmpty()
	For Each ORder EmpCod, CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod 
		if CtaFecDta > &DataLancamento
			&IsCaixaFechado = true
			&Mensagem = 'CONTA: ' + trim(CtaBanCodNom) + ' encontra-se com data de FECHAMENTO no dia ' + trim(ToformattedString(CtaFecDta)) + '. Favor ABRIR caixa para efetuar essa operação!'
		EndIF
		
		Exit
	EndFor
EndiF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
