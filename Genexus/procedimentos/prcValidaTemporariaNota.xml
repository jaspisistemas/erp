      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsErro = false
For Each Order tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNFeCod 
	
	&EmpCod = tmpEmpCod
	if tmpProCod.IsEmpty()
		&IsErro = true
	Else
		&AuxtmpEntCFOP = tmpEntCFOP
		&AuxtmpCFOP = tmpCFOP
		do 'VerificaCFOP'
		
		if &IsErro = false
			&erptmpNcmCod = tmpProNcmCod
			do 'ValidaNCM'
		Endif		
	
		if &IsErro = false
			&ProCod = tmpProCod
			do 'ValidaProduto'
		EndIf
	
	Endif
	
	if &IsErro = true
		&mensagem += ' PRODUTO: ' + trim(tmpProRef) + ' - ' + trim(tmpProNomERP)
		Exit
	Endif
EndFor


Sub 'ValidaProduto'
	For Each ORder EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		if ProSts <> Status_Produto.ATIVO
			&IsErro = true
			&mensagem += ' STATUS PRODUTO DIFERENTE DE ATIVO: '
		Endif
	
		Exit
	endFor

EndSub

Sub 'VerificaCFOP'
	RetornaSoNumeros.Call(&AuxtmpCFOP, &AuxtmpCFOP)
	&tmpCFOP = Substr(&AuxtmpCFOP, 1, 1) + '.' + Substr(&AuxtmpCFOP, 2, 3)
	
	RetornaSoNumeros.Call(&AuxtmpEntCFOP, &AuxtmpEntCFOP)
	&CfoCod = Substr(&AuxtmpEntCFOP, 1, 1) + '.' + Substr(&AuxtmpEntCFOP, 2, 3)
	
	For Each Order CfoCod
		Where CfoCod = &CfoCod
		
		if &tmpCFOP = &CfoCod //JDF FIZ O BLOQUEIO PARA OBRIGAR O USUARIO INFORMAR O CFOP DE LANCAMENTO, OPERACAO INVERSA AO QUE VEIO NA NOTA.
			//ERRO ICTUS QUE O USUARIO NAO INFORMA O CFOP E ACABA LANCANDO COM O MESMO DA NOTA, NA HORA DE GERAR SPED DA ERRO.
			&mensagem = 'CFOP LANCAMENTO NÃO INFORMADO : ' + trim(&CfoCod) + '!'
			&IsErro = true
		Endif
	
		Exit
	When none
		&mensagem = 'CFOP: ' + trim(&CfoCod) + ' Inválido!'
		&IsErro = true
	EndFor
	
EndSub



Sub 'ValidaNCM'

	For Each Order NcmCod
		Where NcmCod = &erptmpNcmCod and &erptmpNcmCod <> 99
		
		if NcmFinVig <= serverdate() and not NcmFinVig.IsEmpty() and not NcmFinVig.IsNull()
			&mensagem = 'FIM DA VIGENCIA ' + trim(str(NcmCod))
			&IsErro = true
		Endif
		
		Exit
	When none
		Do CAse
			CAse &erptmpNcmCod =  0
				&mensagem = 'CÓDIGO 00000000 - SERVIÇOS'
			CAse &erptmpNcmCod =  99
				&mensagem = 'CÓDIGO NCM NÃO INFORMADO!'
				&IsErro = true
			Otherwise
				&mensagem = 'CÓDIGO NCM : ' + trim(str(&erptmpNcmCod)) + ' NÃO CADASTRADO/INVÁLIDO!'
				&IsErro = true
		EndCAse
	EndFor

EndSub
]]></Source>
