      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For each Order EmpCod,PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod 
	If not PesCnpj.Trim().IsEmpty()
		&PesCnpj = PesCnpj
	Else
		&PesCnpj = PesCpf
	EndIF

	&PesRaz = PesRaz
	&PesInsEst = PesInsEst
	&PesCidUfeCod = PesCidUfeCod
	&PesRNTRc = PesRntrc
	Exit
EndFor
]]></Source>
