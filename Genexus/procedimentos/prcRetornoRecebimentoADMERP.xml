      <Part type="e4c4ade7-53f0-4a56-bdfd-843735b66f47">
        <Variable Name="HttpClient">
          <Documentation />
          <Properties><Property><Name>Name</Name><Value>HttpClient</Value></Property><Property><Name>idIsAutoDefinedVariable</Name><Value>True</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>ext:HttpClient</Value></Property></Properties>
