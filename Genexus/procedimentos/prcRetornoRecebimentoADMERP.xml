<Object parentGuid="558e60e3-2d04-4274-9521-daa6a7bdbae1" user="WINJEAN\jeanfae" versionDate="2025-05-08T19:33:44.0000000Z" lastUpdate="2025-05-07T19:34:53.0000000Z" checksum="197a136b818467ac4d8d5b2cd224b682" fullyQualifiedName="prcRetornoRecebimentoADMERP" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="082c2e90-032a-4e61-974c-4caa6acfc833" name="prcRetornoRecebimentoADMERP" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Retorno Recebimento ADMERP" parent="API_Recebimentos" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Body	= '{'
&Body  += '    "beneficiario": "' + &convenioBeneficiario + '"'
&Body  += '}'
&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
&HttpClient.AddHeader('Connection', 'keep-alive')
&HttpClient.AddHeader('Content-Type', 'application/json')
&HttpClient.AddString(&Body)

&HttpClient.Execute('POST', 'https://adm.jaspi.com.br/retorno/prcEnviaADMtoERP')
If &HttpClient.StatusCode = 200
	&RetornoRecebimentoADMERP.FromJson(&HttpClient.ToString())
	
	If &RetornoRecebimentoADMERP.Erros.Count = 0
		For &Item In &RetornoRecebimentoADMERP.Retornos
			Do Case
				Case &Item.bancoTipo	= BancoAPI.INTER
					Do Case
						Case &Item.evento	= !"CANCELADO"
							prcCancelaDuplicata_Webhook.Call(&Item.codigoIdentificacao, &CreDupNro)

						Case &Item.evento	= !"RECEBIDO"
							
							&evento			= &Item.evento
							&dataOcorrencia	= &Item.dataEvento
							If &dataOcorrencia.IsEmpty()
								&dataOcorrencia	= ServerDate()
							EndIf
							&RetCreVlrDup	= &Item.valorLiquidacao
							&RetDtaCreDta	= &Item.dtaPrvPagamento
							If &RetDtaCreDta.IsEmpty()
								&RetDtaCreDta	= ServerDate()
							EndIf
						
							prcProcuraDuplicata_Webhook.Call(&parmEmpCod, &Item.codigoIdentificacao, BancoAPI.INTER, &parmCbrCtaBanCod, &FilCod, &CreCod, &IsAchou)
							If &IsAchou = True
								Do 'GetDuplicata'
							EndIf
					EndCase
					
				Case &Item.bancoTipo	= BancoAPI.SICREDI
					&evento				= &Item.evento
					&dataOcorrencia	= &Item.dataEvento
					If &dataOcorrencia.IsEmpty()
						&dataOcorrencia	= ServerDate()
					EndIf

					//Sicredi está registrando um digito a mais, por isso o -1
					&RetCreBloNro		= &Item.nossoNumero
					&Length				= &RetCreBloNro.Length() - 1
					&RetCreBloNro		= SubStr(&Item.nossoNumero, 1, &Length)
					
					&RetCreVlrDup		= &Item.valorLiquidacao
					&RetCrePagVlrDsc	= &Item.valorDesconto
					&RetCrePagVlrJur	= &Item.valorJuros
					&RetCrePagVlrMlt	= &Item.valorJuros
					&RetBanCod			= &Item.posto
					&RetCbrNroCon		= &Item.beneficiario
					&RetDtaCreDta		= &Item.dtaPrvPagamento
					If &RetDtaCreDta.IsEmpty()
						&RetDtaCreDta	= ServerDate()
					EndIf
					
					prcProcuraDuplicata_Webhook.Call(&parmEmpCod, &RetCreBloNro, BancoAPI.SICREDI, &parmCbrCtaBanCod, &FilCod, &CreCod, &IsAchou)
					If &IsAchou = True
						Do 'GetDuplicata'
					EndIf
					
			EndCase
		EndFor
		Do 'Processar_Retorno'
	Else
		&DataHora		= ServerNow()
		&Mensagem		= 'SINCRONIZAÇÃO: ' + Trim(&DataHora.ToFormattedString())
		For &Erro In &RetornoRecebimentoADMERP.Erros
			&Mensagem  +=  ' - ' + &Erro.errDescription
		EndFor
		PadraoUsuario.Call('G', 'RETORNO_ADMtoERP', 0, 0, &Mensagem, &PadDtaMod)
	EndIf
	
	PadraoUsuarioHora.Call('G', 'SUCESSORETORNO_ADMtoERP', 0, 0, &HttpClient.ToString(), &PadDtaMod, ServerNow(), '')
	
Else
	&Mensagem	= Trim(Str(&HttpClient.ErrCode)) + ' - ' + Trim(&HttpClient.ErrDescription)
	PadraoUsuarioHora.Call('G', 'ERRORETORNO_ADMtoERP', 0, 0, &Mensagem, &PadDtaMod, ServerNow(), '')
EndIf

Sub 'GetDuplicata'
	
	For Each Order EmpCod, FilCod, CreCod
	    Where EmpCod 	= &parmEmpCod 
		Where FilCod 	= &FilCod
		Where CreCod 	= &CreCod
		Where CreRecPag = ReceberPagar.Receber
		Where CreSts   <> Status_Duplicata.CANCELADA
		where CreVlrSdo > 0
		
		&RetPlanCod		= CrePlanCod
		&JurVct			= 0
		&Multa			= 0
		&QtdDias		= 0
		&CampoUnico		= CreDupNro
		&RemFilRaz		= FilRaz

		&CreQtdDias		= &dataOcorrencia - CreDtaVct
		If &CreQtdDias 	> 0
			retornaFeriadoPeriodo.Call(EmpCod, 'S', CreCliCobCidCod, CreDtaVct, &dataOcorrencia, &QtdDias)
			If &QtdDias > 1
				CalculaJuros.Call(EmpCod, CreCbrJurCod, CreDtaVct, &dataOcorrencia, CreVlrDup, &JurVct, CreCbrMltVlr, &Multa)
			EndIf
		EndIf
		
		&SdtBaixadeRemessaItem			= New()
		&CreVlrSdo						= CreVlrSdo
		&CreDtaRet						= IIf(CreDtaRet.IsEmpty(), &dataOcorrencia, CreDtaRet)
		&SdtBaixadeRemessaItem.DevJur	= &JurVct
		&SdtBaixadeRemessaItem.DevMul	= &Multa
		&SdtBaixadeRemessaItem.DevTot	= &Multa + &JurVct
		
		&SdtBaixadeRemessaItem.EmpCod		= EmpCod
		&SdtBaixadeRemessaItem.FilCod		= FilCod
		&SdtBaixadeRemessaItem.CreCod		= CreCod
		&SdtBaixadeRemessaItem.CreDupNro	= CreDupNro
		&SdtBaixadeRemessaItem.CrePedCOd	= CrePedCod
		&SdtBaixadeRemessaItem.CreDtaEms	= CreDtaEms
		&SdtBaixadeRemessaItem.CreCliCod	= CreCliCod
		&SdtBaixadeRemessaItem.CreCliRaz	= CreCliRaz
		&SdtBaixadeRemessaItem.CreSts		= CreSts
		&SdtBaixadeRemessaItem.CreDtaVct	= CreDtaVct
		If CreBloNro.IsEmpty()
			CreBloNro	= &RetCreBloNro
		EndIf
		&SdtBaixadeRemessaItem.CreVlrDup		= CreVlrDup
		&SdtBaixadeRemessaItem.RemCrePagVlr		= &RetCreVlrDup
		&SdtBaixadeRemessaItem.CreBloNro		= CreBloNro
		&SdtBaixadeRemessaItem.CreChv			= CreChv
		&SdtBaixadeRemessaItem.CreCbrCod		= CreCbrCod
		&SdtBaixadeRemessaItem.CreCbrCtaBanCod	= CreCbrCtaBanCod
		&SdtBaixadeRemessaItem.RemFilRaz		= FilRaz
		&SdtBaixadeRemessaItem.RemDtaArq		= &dataOcorrencia
		
		if &CreCbrCod	<> CreCbrCod
			&CreCbrCod		= CreCbrCod
			Do 'GetLocalCobranca'			
		Endif
		
		&SdtBaixadeRemessaItem.RemCbrNroCon		= IIf(&RetCbrNroCon.IsEmpty(), '', &RetCbrNroCon)
		
		&SdtBaixadeRemessaItem.RemCbrNroCon 	= &CbrNroCon
		&SdtBaixadeRemessaItem.RemCtaBanCrt 	= &CbrCtaBanCrt
		&SdtBaixadeRemessaItem.RemDtaOco    	= &dataOcorrencia
		&SdtBaixadeRemessaItem.RemRetBanCodMot 	= &evento
		&SdtBaixadeRemessaItem.RemRetBanCod 	= &CbrCtaBanBanCod
		&SdtBaixadeRemessaItem.RemRetBanNom 	= &CbrCtaBanBanNom
		&SdtBaixadeRemessaItem.RemRetPlanCod 	= &RetPlanCod
		&SdtBaixadeRemessaItem.RemRetPlanCatTip = 'C'
		
		&SdtBaixadeRemessaItem.RemDtaCreDta		= &RetDtaCreDta
		&SdtBaixadeRemessaItem.RemCreBloNro 	= &RetCreBloNro
		&SdtBaixadeRemessaItem.RemCreChv    	= CreChv
		&SdtBaixadeRemessaItem.RemCreDupNro 	= CreDupNro
		&SdtBaixadeRemessaItem.RemCreVlrDup 	= &RetCreVlrDup
		&SdtBaixadeRemessaItem.RemCrePagVlrDsc 	= &RetCrePagVlrDsc
		&SdtBaixadeRemessaItem.RemCrePagVlrJur 	= &RetCrePagVlrJur
		
		&AuxRetCrePagVlr = (&RetCreVlrDup - &RetCrePagVlrJur) + &RetCrePagVlrDsc
		Do Case
			CAse &AuxRetCrePagVlr > CreVlrDup
				&SdtBaixadeRemessaItem.RemCrePagVlrJur +=  &AuxRetCrePagVlr - CreVlrDup		
			Case &AuxRetCrePagVlr > 0
				&SdtBaixadeRemessaItem.RemCrePagVlrDsc += CreVlrDup - &AuxRetCrePagVlr
		EndCase		
		
		&SdtBaixadeRemessaItem.IsEncontrada 		= True
		&SdtBaixadeRemessaItem.IsBaixada 			= False
		&SdtBaixadeRemessaItem.CreObs 				= ''
		&SdtBaixadeRemessaItem.CreAdmCod 			= CreAdmCod
		&SdtBaixadeRemessaItem.CreCliPesEmpSecCod 	= CreCliPesEmpSecCod
		&SdtBaixadeRemessa.Add(&SdtBaixadeRemessaItem)
		
		
		if (CreFrpPgtoTip = TipoDuplicata.DUPLICATA and &CbrTaxBol <> 0 or &CbrTaxVlrMinBol <> 0 or &CbrTaxVlrMaxBol <> 0) or (CreFrpPgtoTip = TipoDuplicata.PIX and &CbrTaxPix <> 0 or &CbrTaxVlrMinPix <> 0 or &CbrTaxVlrMaxPix <> 0)
			
			if (CreFrpPgtoTip = TipoDuplicata.DUPLICATA) //Duplicata
				Do CAse
					CAse &CbrTaxBol <> 0 //CAso tenha taxa definida
						&ValorTarifaPixBoleto = round(CreVlrDup * (&CbrTaxBol / 100), 2)
						Do Case
							CAse &ValorTarifaPixBoleto > &CbrTaxVlrMaxBol
								&ValorTarifaPixBoleto = &CbrTaxVlrMaxBol
							Case &ValorTarifaPixBoleto <= &CbrTaxVlrMinBol
								&ValorTarifaPixBoleto = &CbrTaxVlrMinBol
						EndCAse
					Case &CbrTaxVlrMinBol > 0
						&ValorTarifaPixBoleto = &CbrTaxVlrMinBol
					CAse &CbrTaxVlrMaxBol > 0
						&ValorTarifaPixBoleto = &CbrTaxVlrMaxBol
				EndCAse	
				&TarifaPlanCod = RetornaCodigoPlanoContas.Udp(EmpCod, &CbrTaxPlanHieBol)
			Else //Pix
				Do CAse
					CAse &CbrTaxPix <> 0 //CAso tenha taxa definida
						&ValorTarifaPixBoleto = round(CreVlrDup * (&CbrTaxPix / 100), 2)
						Do Case
							CAse &ValorTarifaPixBoleto > &CbrTaxVlrMaxPix
								&ValorTarifaPixBoleto = &CbrTaxVlrMaxPix
							Case &ValorTarifaPixBoleto <= &CbrTaxVlrMinPix
								&ValorTarifaPixBoleto = &CbrTaxVlrMinPix
						EndCAse
					Case &CbrTaxVlrMinPix > 0
						&ValorTarifaPixBoleto = &CbrTaxVlrMinPix
					CAse &CbrTaxVlrMaxPix > 0
						&ValorTarifaPixBoleto = &CbrTaxVlrMaxPix
				EndCAse
				&TarifaPlanCod = RetornaCodigoPlanoContas.Udp(EmpCod, &CbrTaxPlanHiePix)
			Endif
			
			if &ValorTarifaPixBoleto > 0
				&SdtBaixadeRemessaItem			= New()
				//			&CreVlrSdo						= CreVlrSdo
				//			&CreDtaRet						= IIf(CreDtaRet.IsEmpty(), &dataOcorrencia, CreDtaRet)
				&SdtBaixadeRemessaItem.DevJur	= 0
				&SdtBaixadeRemessaItem.DevMul	= 0
				&SdtBaixadeRemessaItem.DevTot	= 0
				
				&SdtBaixadeRemessaItem.EmpCod		= EmpCod
				&SdtBaixadeRemessaItem.FilCod		= FilCod
				&SdtBaixadeRemessaItem.CreCod		= CreCod
				&SdtBaixadeRemessaItem.CreDupNro	= CreDupNro
				&SdtBaixadeRemessaItem.CrePedCOd	= CrePedCod
				&SdtBaixadeRemessaItem.CreDtaEms	= CreDtaEms
				&SdtBaixadeRemessaItem.CreCliCod	= CreCliCod
				&SdtBaixadeRemessaItem.CreCliRaz	= CreCliRaz
				&SdtBaixadeRemessaItem.CreSts		= CreSts
				&SdtBaixadeRemessaItem.CreDtaVct	= CreDtaVct
				//			If CreBloNro.IsEmpty()
				//				CreBloNro	= &RetCreBloNro
				//			EndIf
				&SdtBaixadeRemessaItem.CreVlrDup		= CreVlrDup
				&SdtBaixadeRemessaItem.RemCrePagVlr		= 0
				&SdtBaixadeRemessaItem.RemCreVlrTar     = &ValorTarifaPixBoleto
				&SdtBaixadeRemessaItem.CreBloNro		= CreBloNro
				&SdtBaixadeRemessaItem.CreChv			= CreChv
				&SdtBaixadeRemessaItem.CreCbrCod		= CreCbrCod
				&SdtBaixadeRemessaItem.CreCbrCtaBanCod	= CreCbrCtaBanCod
				&SdtBaixadeRemessaItem.RemFilRaz		= FilRaz
				&SdtBaixadeRemessaItem.RemDtaArq		= &dataOcorrencia
				
				&SdtBaixadeRemessaItem.RemCbrNroCon		= IIf(&RetCbrNroCon.IsEmpty(), '', &RetCbrNroCon)
				
				&SdtBaixadeRemessaItem.RemCbrNroCon 	= &CbrNroCon
				&SdtBaixadeRemessaItem.RemCtaBanCrt 	= &CbrCtaBanCrt
				&SdtBaixadeRemessaItem.RemDtaOco    	= &dataOcorrencia
				
				&SdtBaixadeRemessaItem.RemRetBanCodMot 	= &evento
				&SdtBaixadeRemessaItem.RemRetBanCod 	= 'TAXA'
				&SdtBaixadeRemessaItem.RemRetBanNom 	= &CbrCtaBanBanNom
				&SdtBaixadeRemessaItem.RemRetPlanCod 	= &TarifaPlanCod
				&SdtBaixadeRemessaItem.RemRetPlanCatTip = 'D'
				
				&SdtBaixadeRemessaItem.RemDtaCreDta		= &RetDtaCreDta
				&SdtBaixadeRemessaItem.RemCreBloNro 	= &RetCreBloNro
				&SdtBaixadeRemessaItem.RemCreChv    	= CreChv
				&SdtBaixadeRemessaItem.RemCreDupNro 	= CreDupNro
				&SdtBaixadeRemessaItem.RemCreVlrDup 	= 0
				&SdtBaixadeRemessaItem.RemCrePagVlrDsc 	= 0
				&SdtBaixadeRemessaItem.RemCrePagVlrJur 	= 0
				
				&SdtBaixadeRemessaItem.RemCrePagVlrJur =  0	
				&SdtBaixadeRemessaItem.RemCrePagVlrDsc = 0	
				
				&SdtBaixadeRemessaItem.IsEncontrada 		= True
				&SdtBaixadeRemessaItem.IsBaixada 			= False
				&SdtBaixadeRemessaItem.CreObs 				= ''
				&SdtBaixadeRemessaItem.CreAdmCod 			= CreAdmCod
				&SdtBaixadeRemessaItem.CreCliPesEmpSecCod 	= CreCliPesEmpSecCod
				&SdtBaixadeRemessa.Add(&SdtBaixadeRemessaItem)
			Endif
		Endif
		
		Exit
	EndFor
	
	GravaArquivoRetorno.Call(&parmEmpCod, &CampoUnico, &Today, &RemFilRaz, &RetornoRecebimentoADMERP.ToJson(), &SdtBaixadeRemessa.ToJson(), &CreCbrCod)
	&WEBSESSION.Set('Retorno_cobranca',&SdtBaixadeRemessa.ToJson())
	
EndSub

Sub 'GetLocalCobranca'
	
	For each Order EmpCod, CbrCod
		Where EmpCod 	= &parmEmpCod
		Where CbrCod 	= &CreCbrCod
		
		&CbrCtaBanAgeCod 	= CbrCtaBanAgeCod
		&CbrCtaBanAgeDig 	= CbrCtaBanAgeDig
		&CbrCtaBanCrt 		= CbrCtaBanCrt
		&CbrCtaBanBanCod 	= CbrCtaBanBanCod
		&CbrCtaBanBanNom	= CbrCtaBanBanNom
		&CbrNroCon 			= CbrNroCon
				
		//TAXA PIX
		&CbrTaxPix = CbrTaxPix
		&CbrTaxVlrMaxPix = CbrTaxVlrMaxPix
		&CbrTaxVlrMinPix = CbrTaxVlrMinPix
		&CbrTaxPlanHiePix = CbrTaxPlanHiePix

		//TAXA BOLETO 
		&CbrTaxBol = CbrTaxBol
		&CbrTaxVlrMaxBol = CbrTaxVlrMaxBol
		&CbrTaxVlrMinBol = CbrTaxVlrMinBol
		&CbrTaxPlanHieBol = CbrTaxPlanHieBol

		Exit
	EndFor
EndSub

Sub 'Processar_Retorno'
	
	&SdtBaixadeRemessa.Sort('RemRetBanCod')
	For &SdtBaixadeRemessaItem In &SdtBaixadeRemessa
		&RemRetBanCod		= &SdtBaixadeRemessaItem.RemRetBanCod
//		&RemRetBanCodMot	= &SdtBaixadeRemessaItem.RemRetBanCodMot
		&AuxEmpCod			= &SdtBaixadeRemessaItem.EmpCod
		&AuxFilCod			= &SdtBaixadeRemessaItem.FilCod
		&AuxCreCod			= &SdtBaixadeRemessaItem.CreCod
		&AuxCreSts			= &SdtBaixadeRemessaItem.CreSts
		&AuxCrePedCod		= &SdtBaixadeRemessaItem.CrePedCOd
		&AuxCreCliCod		= &SdtBaixadeRemessaItem.CreCliCod
		&AuxCreCliRaz		= &SdtBaixadeRemessaItem.CreCliRaz
		&AuxDtaOco			= &SdtBaixadeRemessaItem.RemDtaOco
		&AuxCreChv			= &SdtBaixadeRemessaItem.CreChv
		&AuxCreCbrCod		= &SdtBaixadeRemessaItem.CreCbrCod
		&AuxCreCbrCtaBanCod	= &SdtBaixadeRemessaItem.CreCbrCtaBanCod
		&AuxRemCreBloNro	= &SdtBaixadeRemessaitem.RemCreBloNro
		&AuxRemCreDupNro	= &SdtBaixadeRemessaItem.RemCreDupNro
		&AuxRemCrePagVlr	= &SdtBaixadeRemessaItem.RemCrePagVlr
		&AuxRemCreVlrTar	= &SdtBaixadeRemessaItem.RemCreVlrTar
		&AuxRemDtaCreDta	= &SdtBaixadeRemessaItem.RemDtaCreDta
		&AuxRemCrePagVlrDsc	= &SdtBaixadeRemessaItem.RemCrePagVlrDsc
		&AuxRemCrePagVlrJur	= &SdtBaixadeRemessaItem.RemCrePagVlrJur
		&IsBaixada			= &SdtBaixadeRemessaItem.IsBaixada
		&AuxPlanCod			= &SdtBaixadeRemessaItem.RemRetPlanCod
		&AuxCreAdmCod		= &SdtBaixadeRemessaItem.CreAdmCod
		
		If &SdtBaixadeRemessaItem.IsEncontrada = True
			If &IsBaixada = False
				DuplicataBaixaLct.Call(&AuxEmpCod, &AuxFilCod, &AuxCreCod, &AuxCreSts, &AuxDtaOco, &AuxCreCbrCod, &AuxCreCbrCtaBanCod, &BanCod, &RemRetBanCod, &AuxRemCrePagVlr, &AuxRemCreVlrTar, &AuxRemCreVlrOut, &AuxRemDtaCreDta, &AuxRemCrePagVlrDsc, &AuxRemCrePagVlrJur, '', &AuxCreCliCod, &AuxCreCliRaz, &AuxPlanCod)
			EndIf
	
			Do 'GravaOcorrencia'
			Do 'Grava_data_retorno'
		EndIf
	EndFor
	
	For &SdtBaixadeRemessaItem In &SdtBaixadeRemessa
		If &SdtBaixadeRemessaItem.CreAdmCod > 0
			&ppJASPI_DuplicatasPagasdtDuplicatasItems 				= New()
			&ppJASPI_DuplicatasPagasdtDuplicatasItems.CreCod 		= &SdtBaixadeRemessaItem.CreAdmCod
			&ppJASPI_DuplicatasPagasdtDuplicatasItems.CliCodSync	= &SdtBaixadeRemessaItem.CreCliPesEmpSecCod
			&ppJASPI_DuplicatasPagasdtDuplicatas.Duplicatas.Items.Add(&ppJASPI_DuplicatasPagasdtDuplicatasItems)
		 Endif
	 Endfor
 
	//LIBERA LICENCA
	If &ppJASPI_DuplicatasPagasdtDuplicatas.Duplicatas.Items.Count > 0
		prcAtualizaStatusLiberado.Call('S', &parmEmpCod, 1, &ppJASPI_DuplicatasPagasdtDuplicatas)
	Endif
	
EndSub

Sub 'GravaOcorrencia'
	
	For Each Order EmpCod, RemFilCod, RemCreSeq
		Where EmpCod	= &AuxEmpCod
		Where RemFilCod	= &AuxFilCod
		Where RemCreSeq	= &AuxCreCod
		
		RemOcoCod		= &RetBanCod
		RemDtaRet		= &dataOcorrencia
		
		Exit
	EndFor
	Commit
	
EndSub

Sub 'Grava_data_retorno'
	
    For Each Order EmpCod, FilCod, CreCod
	    Where EmpCod = &AuxEmpCod
		Where FilCod = &AuxFilCod
		Where CreCod = &AuxCreCod
		
		If CreDtaRet.IsEmpty()
	        CreDtaRet = &dataOcorrencia
		EndIf
	
		Exit
    EndFor
	Commit
	
EndSub
