      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//PEDIDO
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PEdCod
	
	&OldPedCliCod = PedCliCod
	&LctTip = LctTip
	
	&CreCobObs = 'TROCADO CLIENTE DO PEDIDO, CLIENTE ANTERIOR: '+ trim(PedCliCodRaz) + ' NOVO CLIENTE: ' + trim(str(&PedCliCod))
	GravaStatusPedido.Call(EmpCod, FilCod, PedCod, 0, &CreCobObs, 0, &ContextPesCod)
	
	PedCliCod = &PedCliCod

	Exit
EndFor
Commit


//DUPLICATAS
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CrePedCod = &PEdCod
	
	&CreCobObs = 'TROCADO CLIENTE DO PEDIDO, CLIENTE ANTERIOR: '+ trim(CreCliCodRaz) + ' NOVO CLIENTE: ' + trim(str(&PedCliCod))
	Gravacobranca.Call(EmpCod, FilCod, CreCod, &CreCobObs, 0, 0, &CrePrmPag, &CrePrmPagHor, TipoObservacaoDuplicata.INTERNA)
	
	CreCliCod = &PedCliCod
	
	Exit
EndFor
Commit


if &LctTip = TipoLancamento.SaidaMercadoria
	//ATUALIZAR ULTIMA COMPRAS CLIENTE OLD.
	&AuxPedCliCod = &OldPedCliCod
	do 'AtualizaUltimaVendaCliente'
	
	//ATUALIZAR ULTIMA COMPRAS CLIENTE NOVO
	&AuxPedCliCod = &PedCliCod
	do 'AtualizaUltimaVendaCliente'
Endif

prcAtualizaDataModificacaoPessoa.Call(&EmpCod, &OldPedCliCod)
prcAtualizaDataModificacaoPessoa.Call(&EmpCod, &PedCliCod)


sub 'AtualizaUltimaVendaCliente'
	&sdtVinculos.Clear()
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon042_TrocarTransportadoraPadrao, &TrocarTransportadora)
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon139_TrocarVendedorPadrao, &TCon139_TrocarVendedorPadrao)
	
	
	//ATUALIZA ULTIMA VENDA CLIENTE E VINCULOS
	&sdtVinculos = RetornaVinculos.Udp(&EmpCod, &AuxPedClICod)
	
	PesUltVenDta_FORMULA.Call(&EmpCod, &sdtVinculos, &PesUltVenDta, &PesUltVenVlr, &PedTraRedCod, &PedTraSaiCod, &PesIntVenCod, &PesExtVenCod)
	
	For &sdtVinculosItem in &sdtVinculos
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &sdtVinculosItem.PesCod
			Where PesIsCli = true
			
			PesUltVenDta = &PesUltVenDta
			PesUltVenVlr = &PesUltVenVlr
			
			If &PesIntVenCod <> 0 and &TCon139_TrocarVendedorPadrao <> 'N'
				PesIntVenCod = &PesIntVenCod
			EndIF
			
			If &PesExtVenCod <> 0 and &TCon139_TrocarVendedorPadrao <> 'N'
				PesExtVenCod = &PesExtVenCod
			EndIF
			
			if &PedTraRedCod <> 0 and &TrocarTransportadora = 'S'
				PesCliTraCod = &PedTraRedCod
			Endif
			if &PedTraSaiCod <> 0 and &TrocarTransportadora = 'S'
				PesCliTraSaiCod = &PedTraSaiCod
			EndIF
			
			Exit
		EndFor
	EndFor

	Commit
EndSub
]]></Source>
