      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SoNumeros = retornaSoNumeros.Udp(&ProBar)
&SoNumeros = trim(&SoNumeros)

if &ProBar.IsEmpty() //NAO TEM CODIGO BARRAS
    &OutProBar = '333' + padL(trim(str(&ProCod)),9,'0')
else
	do Case
		Case &SoNumeros.Length() = 14
		    &OutProBar = substr(TRIM(&SoNumeros),1,13)
		Case &SoNumeros.Length() = 13
		    &OutProBar = substr(TRIM(&SoNumeros),1,12)
		Case &SoNumeros.Length() = 12
			&OutProBar = substr(TRIM(&SoNumeros),1,11)
		Case &SoNumeros.Length() = 8
		    &OutProBar = substr(TRIM(&SoNumeros),1,7)
		Otherwise
		    &OutProBar = substr(TRIM(&SoNumeros),1,12)
	EndCase
Endif
&OutProBar = trim(&OutProBar)

Do case
	Case &OutProBar.Length() = 13 //DUN14
		DigitoDUN14.Call(&OutProBar, &NewProBar)
	Case &OutProBar.Length() = 12 //EAN13
		DigitoEAN13.Call(&OutProBar, &NewProBar)
	Case &OutProBar.Length() = 11 //UPC12
		DigitoUPC12.Call(&OutProBar, &NewProBar)
	Case &OutProBar.Length() = 7 //EAN8
		DigitoEAN8.Call(&OutProBar, &NewProBar)
	Otherwise
		DigitoEAN13.Call(&OutProBar, &NewProBar)
EndCase



if &ProBar <> &NewProBar AND (NOT &ProBar.IsEmpty())
    &Mensagem = 'Código de barras não corresponde aos padrões DUN14/EAN13/UPC12/EAN8'
	&NewProBar = &OutProBar.Trim()
Endif
]]></Source>
