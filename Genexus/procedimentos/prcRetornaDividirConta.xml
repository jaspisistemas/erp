      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtDividirConta_Produtos.Clear()

For Each order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCodRef.IsEmpty() or PedItmCodRef.IsNull() or PedItmCodRef = PedItmCod
	//PENDENTES PAGAMENTO:P,TODOS OS ITENS:T

	&ProGraNom = PedProNom
	&DescontoPedVlrItm = round(PedVlrItm + (PedVlrItm * PedProTaxAcrGerItm* 0.01) - (PedVlrItm * PedProTaxDscGerItm * 0.01),2)
	
	RetornaObsComplementos_Dividir.Call(EmpCod, FilCod, PedCod, PedItmCod, &AuxPedVlrItm, &PedItmPagVlrTot, &PedItmPagVlrSel, &GridProdutosPedidoComplemento)
	RetornaObs_Composicao_Dividir.Call(EmpCod, FilCod, PedCod, PedItmCod, &ComposicaoPedVlrItm, &ComPedItmPagVlrTot, &ComPedItmPagVlrSel, &ComposicaoMensagem)
	&ProGraNom += ' ' + &ComposicaoMensagem + ' '+ &GridProdutosPedidoComplemento	
	&PedVlrItm = (&DescontoPedVlrItm + &AuxPedVlrItm+&ComposicaoPedVlrItm) - (&ComPedItmPagVlrTot+&PedItmPagVlrTot+PedItmPagVlrTot)

	&PedVlrUntDiv = PedItmPagVlrSel+&PedItmPagVlrSel+&ComPedItmPagVlrSel
	&IsMarcadoBol = PedItmPagIsSel

	if &PedVlrUntDiv < 0 or &PedVlrItm < 0
		&PedVlrItm = 0
		&PedVlrUntDiv = 0
	Endif

	//SELECIONAD
	if PedItmPagIsSel = true and &PedVlrUntDiv > 0
		&IsMarcadoBol = True
	Else
		&IsMarcadoBol = false
	Endif

	if &MostrarItens = 'T' or (&MostrarItens = 'P'  and &PedVlrItm > 0)
		&sdtDividirConta_ProdutosItem = new()
		&sdtDividirConta_ProdutosItem.PedItmCod = PedItmCod
		&sdtDividirConta_ProdutosItem.ProGraRef = ProGraRef
		&sdtDividirConta_ProdutosItem.ProGraNomCompleto = &ProGraNom
		&sdtDividirConta_ProdutosItem.PedVlrItm = &PedVlrItm
		&sdtDividirConta_ProdutosItem.PedVlrUntDiv = &PedVlrUntDiv
		&sdtDividirConta_ProdutosItem.PedQtd = PedQtd
		&sdtDividirConta_ProdutosItem.PedQtdDiv = PedQtd
		&sdtDividirConta_ProdutosItem.PedItmPagIsSel = &IsMarcadoBol
		&sdtDividirConta_Produtos.Add(&sdtDividirConta_ProdutosItem)
	Endif

EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
