<Object parentGuid="7529ae64-c871-4084-a67d-a1ef9467c563" user="SRVORDIG\Administrador" versionDate="2024-05-02T16:59:08.0000000Z" lastUpdate="2024-04-30T12:46:00.0000000Z" checksum="5d869ae885e1a0f2d5a6f654ff7ff1ff" fullyQualifiedName="prcGravaLogGNRE_Novo" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="249a9b92-0b0e-4b1c-99c7-52198c2273b6" name="prcGravaLogGNRE_Novo" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Grava Log GNRE_Novo" parent="GNRE" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//LoadWWPContext(&Context)
RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

//## Define o nome dos Arquivos

&parmXML 		= 	&sdtConfiguracoesPasta.PastaNFretorno+Trim(&nomeFinal)+'_guias-pro-rec.xml'
&parmPDF 		= 	&sdtConfiguracoesPasta.PastaNFretorno+Trim(&nomeFinal)+'_guias-gnre.pdf'

//################################\\

//## Pesquisa o Arquivo em XML

&File.Source 	= 	&parmXML

//################################\\

//## Se o Arquivo existe	
If &File.Exists()
	
	For Each Order EmpCod, FilCod, GNRENumRec		//## Verifica se há algum registro referente a GNRE emetida		
		Where EmpCod 		=	 &EmpCod			//## Código da Empresa	(por parâmetro)
		Where FilCod	 	=	 &FilCod			//## Código da Filial	(por parâmetro)
		Where GNRENumRec 	=	 &parmGNRENumRec	//## Recibo da GNRE		(por parâmetro)	
		
		GNREDtaEms 			= 	&Today				//## Data de Emissão do Registro		
		GNREFunCod 			= 	&PesFunCod	//## Funcionário que emitiu a GNRE	
		
	When None										//## Se não há registro									
		
		New											 
			EmpCod 		= &EmpCod					//## Código da Empresa		
			FilCod 		= &FilCod					//## Código da Filial	
			GNRENumRec 	= &parmGNRENumRec			//## Recibo da GNRE			
			GNREDtaEms 	= &Today					//## Data de Emissão		
			GNREFunCod 	= &PesFunCod				//## Funcionário que emitiu
		EndNew
		
	EndFor
	
	Commit
	
	&LeituraXML.Open(&parmXML)						//## Abre o Arquivo 	
	&Ret = &LeituraXML.ReadType(1, 'ns1:situacaoProcess')	//## Lê todos os dados dentro da TAG: 'ns1:TResultLote_GNRE'	
	If &Ret <> 0
		&LeituraXML.Read()
		Do While &LeituraXml.Name <> 'ns1:situacaoProcess' //## Repete enquanto o arquivo não acabar	
			Do Case
				Case &LeituraXML.Name 	= 	'ns1:codigo'
					&GNRESts 			= 	&LeituraXML.Value
			EndCase
			&LeituraXML.Read()
		EndDo
	EndIf
	&LeituraXML.Close()
	
	If &GNRESts 	= '401'
		&parmPDF.SetEmpty()
		&parmXML.SetEmpty()
		&Mensagem	= 'STATUS 401 - Lote em processamento. Cancele o envio e transmita novamente em alguns instantes.'
		prcGravaGNREEmitida.Call(&EmpCod, &FilCod, &parmGNRENumRec, &GNREChavNot, &parmGnreTipo, &GNRESts, &GNREVlrTot, &Mensagem, &parmPDF, &parmXML)
		Return
	EndIf

	&LeituraXML.Open(&parmXML)
	&LeituraXML.ReadType(1, 'ns1:resultado')
	&LeituraXML.Read()
			
	Do While (&LeituraXml.Name <> 'ns1:resultado' and &LeituraXml.Name <> '')
		Do Case
			Case &LeituraXML.Name 	= 'ns1:receita'
				&GNRETipo 		  	= &LeituraXML.Value 
			Case &LeituraXML.Name 	= 'ns1:dataVencimento'
				&CreDtaVct 			= &LeituraXML.Value
			Case &LeituraXML.Name 	= 'ns1:valorGNRE'
				&GNREVlrTot 		= &LeituraXML.Value
			Case &LeituraXML.Name	= 'ns1:codigoBarras'
				&CreCodBar			= &LeituraXML.Value
			Case &LeituraXML.Name 	= 'ns1:motivosRejeicao'
				&LeituraXML.Read()
				Do While (&LeituraXml.Name <> 'ns1:motivosRejeicao' and &LeituraXml.Name <> '')
					Do Case 
						Case &LeituraXML.Name = 'ns1:motivo'
							&LeituraXML.Read()
							Do While (&LeituraXml.Name <> 'ns1:motivo' and &LeituraXml.Name <> '')
								Do Case
									Case &LeituraXML.Name = 'ns1:codigo'
										&Mensagem	+= 'ERRO ' + &LeituraXML.Value
									Case &LeituraXML.Name = 'ns1:descricao'
										&Mensagem 	+= ' - ' + &LeituraXML.Value + ' '
								EndCase
								&LeituraXML.Read()
							EndDo
					EndCase
					&LeituraXML.Read()
				EndDo
		EndCase
		&LeituraXML.Read()
	EndDo
	&LeituraXML.Close()
	
	If &GNRESts <> '402'
		&parmPDF.SetEmpty()
		&parmXML.SetEmpty()
	EndIf

	prcGravaGNREEmitida.Call(&EmpCod, &FilCod, &parmGNRENumRec, &GNREChavNot, &GNRETipo, &GNRESts, &GNREVlrTot, &Mensagem, &parmPDF, &parmXML)
	
	//## Caso necessário gerar a DUPLICATA, atribui as informações e salva	##\\
	If &GerarDuplicata = 1 And &GNRESts	= '402'
		//## Concatena de forma certa as informações ##\\
		&Day 				= Trim(SubStr(&CreDtaVct, 9, 2))
		&Mes				= Trim(SubStr(&CreDtaVct, 6, 2))
		&Ano 				= Trim(SubStr(&CreDtaVct, 1, 4))
		&CreDtaVct			= Trim(&Day)+'/'+Trim(&Mes)+'/'+Trim(&Ano)
		//#############################################\\
		
		&SdtAdiantamento.Clear()
		&SdtAdiantamentoItem 			= 	New()
		&SdtAdiantamentoItem.Data 		= 	CtoD(&CreDtaVct)		//## Data de Vencimento			
		&SdtAdiantamentoItem.Valor 		= 	&GNREVlrTot.ToNumeric()	//## Valor da GNRE			
		&SdtAdiantamentoItem.PlanCod 	= 	&PlanCod				//## Plano de Contas			
		&SdtAdiantamentoItem.Nro		= 	&CreDupNro				//## Número da Duplicata			
		&SdtAdiantamento.Add(&SdtAdiantamentoItem)
		
		&SdtDuplicata.CreFilPgt 		= 	&FilCod					//## Código da Filial			
		&sdtDuplicata.CreRecPag 		= 	ReceberPagar.Pagar		//## Tipo da DUPLICATA (PAGAR)	
		
		For Each Order EmpCod, FrpPgtoCod		//## Busca a Forma de Pagamento
			Where EmpCod 		= 	&EmpCod
			Where FrpPgtoNom 	= 	'DUPLICATA'
			
			&CreFrpPgtoCod = FrpPgtoCod
			
			Exit
		EndFor
		
		&sdtDuplicata.CreFrpPgtoCod	= 	&CreFrpPgtoCod			//## Forma de Pagamento		
		&sdtDuplicata.CreDupNro 	= 	&CreDupNro				//## Número da DUPLICATA	
		&sdtDuplicata.CreDtaEms 	= 	&Today					//## Data de Emissão 		
		&sdtDuplicata.CreDtaVct 	= 	CtoD(&CreDtaVct)		//## Data de Vencimento		
		&sdtDuplicata.CreCliCod 	= 	&PesCodFornecedor		//## Cliente				
		&sdtDuplicata.CreVenCod 	= 	&PesFunCod				//## Funcionário			
		&sdtDuplicata.CreVlrDup 	= 	&GNREVlrTot.ToNumeric()	//## Valor da DUPLICATA		
		&sdtDuplicata.CreCbrCod 	= 	1						//## Forma de Cobrança		
		&sdtDuplicata.CreNumConGNRE = 	&parmGNRENumRec			//## GNRE de Origem 		
		
		&sdtDuplicata.CrePlanCod 	= 	&PlanCod				//## Plano de Contas		
		&sdtDuplicata.CreIsPer 		= 	False
		
		&sdtDuplicata.CreCodBar 	= 	&CreCodBar				//## Código de Barras		
		&sdtDuplicata.CreCobObs	 	=	'DUPLICATA GERADA APÓS A EMISSÃO DA GNRE'
		
		GravaAtualizaDuplicatas.Call('INS', &EmpCod, &FilCod, 0, &PesFunCod, &sdtDuplicata, &SdtAdiantamento)
		
	EndIf
	//#######################################################################\\
	
EndIf
]]></Source>
