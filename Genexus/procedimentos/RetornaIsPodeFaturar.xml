      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsPodeFaturar = true

retornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon010_LiberarCreditoPedido, &TCon010_LiberarCreditoPedido)


For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &pedCod
		
	if (PedCliCrd <> 999999999.99 or PedCliCrd.IsNull()) and (PedStsCrd <> Status_Autorizado.AUTORIZADO or PedStsCrd.IsNull()) and ((LctGerFin = Status_SimNao.Sim or &TCon010_LiberarCreditoPedido = 'S') or LctTip = TipoLancamento.OrcamentoVenda)
		&IsPodeFaturar = false
	EndIF

	Exit
EndFor
]]></Source>
