      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVAR LOG
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'PRODUTORECEITA')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
	&LogErpRegTip = TrnMode.Update
	prcCarregaLog_ProdutoReceita.Call(&EmpCod, &FilCod, &ProCod, &SdtLogAtributosLevel)
Endif


//ATUALIZA CADASTRO
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
		
	ProQtdPro = &ProQtdPro
	ProTipCus = &ProTipCus
	ProTipDef = &ProTipDef
	ProEmbCod = &ProEmbCod
	ProTipCusAcrRec = &ProTipCusAcrRec
	ProAtuEst = &ProAtuEst
	ProSepIsKit = &ProSepIsKit
	
	//DELETA RECEITAS
	For &sdtProdutoReceitaItem in &sdtProdutoReceita
		For Each Order EmpCod, ProCod, RecItmCod
			Where RecItmCod = &sdtProdutoReceitaItem.RecItmCod
			if &sdtProdutoReceitaItem.RecSts <> 'A' or &sdtProdutoReceitaItem.RecProCod.IsEmpty()
				delete
			Else
				RecProCod = &sdtProdutoReceitaItem.RecProCod
				RecProQtd = &sdtProdutoReceitaItem.RecProQtd
			Endif
		when none
			if &sdtProdutoReceitaItem.RecSts = 'A' and not &sdtProdutoReceitaItem.RecProCod.IsEmpty()
				New
					EmpCod = &EmpCod
					ProCod = &ProCod
					RecItmCod = &sdtProdutoReceitaItem.RecItmCod
					RecProCod = &sdtProdutoReceitaItem.RecProCod
					RecProQtd = &sdtProdutoReceitaItem.RecProQtd
				EndNEw
			Endif
		
		EndFor
	Endfor

	//CUSTOS FIXOS
	For &sdtCustosFixosItem in &sdtCustosFixos
		For Each Order EmpCod, ProCod, RecCusPrdItm
			Where RecCusPrdItm = &sdtCustosFixosItem.RecCusPrdItm
			if &sdtCustosFixosItem.RecCusSts <> 'A' or &sdtCustosFixosItem.CusPrdCod.IsEmpty()
				delete
			Else
				CusPrdCod = &sdtCustosFixosItem.CusPrdCod
				RecCusPrdQtd = &sdtCustosFixosItem.RecCusPrdQtd
			Endif
		when none
			if &sdtCustosFixosItem.RecCusSts = 'A' and not &sdtCustosFixosItem.CusPrdCod.IsEmpty()
				New
					EmpCod = &EmpCod
					ProCod = &ProCod
					RecCusPrdItm = &sdtCustosFixosItem.RecCusPrdItm
					CusPrdCod = &sdtCustosFixosItem.CusPrdCod
					RecCusPrdQtd = &sdtCustosFixosItem.RecCusPrdQtd
				EndNEw
			Endif
		EndFor
	EndFor

	//OBSERVACAO
	For &sdtObservacoesItem in &sdtObservacoes
		For Each Order EmpCod, ProCod, PreItmCod
			Where PreItmCod = &sdtObservacoesItem.PreItmCod
			if &sdtObservacoesItem.PreSts <> 'A' or &sdtObservacoesItem.PreObs.IsEmpty()
				delete
			Else
				PreObs = &sdtObservacoesItem.PreObs
			Endif
		when none
			if &sdtObservacoesItem.PreSts = 'A' and not &sdtObservacoesItem.PreObs.IsEmpty()
				New
					EmpCod = &EmpCod
					ProCod = &ProCod
					PreItmCod = &sdtObservacoesItem.PreItmCod
					PreObs = &sdtObservacoesItem.PreObs
				EndNEw
			Endif
		EndFor
	EndFor
EndFor

Commit

if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
	prcGravaLog_ProdutoReceita.Call(&EmpCod, &FilCod, &ProCod, &Pgmname, &wwpContextUserName, &SdtLogAtributosLevel)
Endif

//ATUALIZACOES PRODUTO
GravaGradeProduto.Call(&EmpCod, &ProCod, &NcmCod)
ProVlrCus_Produto.Call(&EmpCod, &ProCod)
ProPesLiqCal_Produto.Call(&EmpCod, &ProCod)
PrcTestaReceitas.Call(&EmpCod, &ProCod)
]]></Source>
