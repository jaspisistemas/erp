      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&Pagina += 1
	&titulo = 'LISTA DE PREÇOS COMBINADOS'
	print Cabecalho
	print Cliente
	
End

For Each Order EmpCod, PesCod, EspProRefPadL
	Where PesCod = &PesCod When &PesCod <> 0
	Where PesRaz = &FilPesRaz When not &FilPesRaz.IsEmpty()
	
	&PesCodRaz = PesCodRaz
	
    If PesCod <> &AuxPesCod 
		if &AuxPesCod <> 0
	        eject
			&Pagina = 0
		EndIf
	
		//print Cliente
    EndIf
	
    print Produtoi
	
	&AuxPesCod = PesCod
	
EndFor


//Footer
//	print Rodape
//End
]]></Source>
