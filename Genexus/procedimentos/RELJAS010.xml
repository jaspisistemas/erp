      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	print Cabecalho
	print Titulo
	If &Page <> 1
		print tituloPedidos
	EndIf
End

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	&ProCodNom = ProCodNom
	Exit
EndFor

&AuxFim = serverdate()
&AuxFim = &AuxFim.addDays(1)
EstoqueAnteriorFicha.Call(&EmpCod, &FilCod, &ProCod, &ProGracod, 1, &PedDtaFat, &AuxFim, &AntEstQtd)
&TotSaldoPedQtd = &AntEstQtd
print EstoqueAnterior

print tituloPedidos

For Each Order EmpCod, FilCod,ProCod,PedDtaFic,PedSts,LctAtuEst
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGracod when &ProGracod > 1
	Where PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO
	Where PedDtaFic >= &PedDtaFat and PedDtaFic <= &PedDtaFat_to
	Where LctAtuEst = Status_EntradaSaida.Saida or LctAtuEst = Status_EntradaSaida.Entrada
	Where PedCliCod = &PedCliCod or &PedCliCod = 0
	Where PedVenCod = &PedVenCod or &PedVenCod = 0
   	Where PedQtd <> 0
	
	&qtdEntrada = ''
	&qtdSaida = ''
//	&printPedDtaFat = PedDtaFat
//	If &printPedDtaFat.IsEmpty()
		&printPedDtaFat = PedDtaFic
//	EndIF

	&QuantidadeFormatada = PedQtd

	if LctAtuEst = Status_EntradaSaida.Saida
		&PedQtd = PedQtd * -1
		
		&TotEntrada += PedQtd
		&TotSaldoPedQtd += &PedQtd
		&qtdSaida = trim(toformattedString(&QuantidadeFormatada))
    else
		&TotSaida += PedQtd
		&TotSaldoPedQtd += PedQtd
		&qtdEntrada = trim(toformattedString(&QuantidadeFormatada))
    endif

	print Pedido
EndFor

print Total


Footer
	print Rodape
End
]]></Source>
