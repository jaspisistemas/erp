      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&SolDtaHorIni = serverNow()
if &EmpCod > 0 and &FilCod > 0
	&SolCod = 0
	For Each Order SolEmpCod, (SolCod)
		where SolEmpCod = &EmpCod
		&SolCod = SolCod
		Exit
	EndFor
	&SolCod += 1
	
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		&EmpA1A3 = EmpA1A3
		Exit
	EndFor
	if &EmpA1A3.IsEmpty()
		&EmpA1A3 = 'A1'
	EndIf

	new
		SolEmpCod = &EmpCod
		SolCod = &SolCod 
		SolFilCod = &FilCod
		SolNfeCod = &NfeCod
		SolItmCod = &SolItmCod
		SolSts = Status_Solicitacao.PENDENTE
		SolTip = &SolTip
		SolDtaEms = serverdate()
		SolDtaEmsHor = serverTime()
		SolDtaHorIni = &SolDtaHorIni.AddSeconds(5)
		SolDtaFat = nullvalue(SolDtaFat)
		SolPesCod = &PesCod
		SolQtdTen = 0
		SolA1A3 = &EmpA1A3
	EndNew
	
	commit
EndIF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
