      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where ProBarTip = &ProBarTip or ProBarRef = &ProBarRef //VERIFICA O TIPO OU ALGUM IGUAL
		
		Do Case
			Case ProBarTip = &ProBarTip and ProBarRef <> &ProBarRef
				&IsContinua = true
				Delete
				
			Case ProBarTip <> &ProBarTip and ProBarRef = &ProBarRef
				&IsContinua = true
				Delete
		EndCase
	When None
		&IsContinua = true
	EndFor

	commit
	
	if &IsContinua = true
		if &ProBarTip = 'B' // BARRAS
			&ProBarId = 2
		Else
			&ProBarId = 1
		Endif	
		
		
		New
			EmpCod = &EmpCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
			ProBarId = &ProBarId
			ProBarRef = &ProBarRef
			ProBarTip = &ProBarTip
			ProBarQtd = 0
			Do Case
				Case ProBarTip = 'R' //REFERENCIA
					ProBarOrd = 10
				Case  ProBarTip = 'E' //ETIQUETA
					ProBarOrd = 99
				Case  ProBarTip = 'B' //BARRAS
					ProBarOrd = 98					
				Case ProBarTip = 'C' //CAIXA
					ProBarOrd = 97
				Case ProBarTip = 'O' //ORIGINAL
					ProBarOrd = 96 
				OtherWise
					ProBarOrd = 95
			EndCase
		
		EndNew
		
		Commit
		
		
		RetornaMaisCodigosCompleto.Call(&EmpCod, &ProCod, &ProGraCod, &ProBarRef_Comp)
		For Each Order EmpCod, ProCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			
			ProRef_Comp = &ProBarRef_Comp
			
			For Each Order EmpCod, ProCod, ProGraCod
				Where ProGraCod = &ProGraCod
				
				ProBarRef_Comp = &ProBarRef_Comp
				Exit		
			EndFor
			
			Exit
		EndFor
		
		Commit
	Endif
]]></Source>
