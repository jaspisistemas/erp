      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&MensagemAlterada = ''
&MensagemInserida = ''
&OldPedQtd = 0
&IsSucesso  = false

&FaltaDevolverPedQtd = &PedQtd

//GRAVA LOG
&TabelaVarchar = 'PEDIDOPRODUTO'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
&LogErpRegCod1 = trim(Str(&PedCod))

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&PedSts = PedSts

    For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
		Where PedItmCod = &PedItmCod when &PedItmCod <> 0
		Where ProCod = &ProCod when &PedItmCod = 0
		Where ProGraCod = &ProGraCod when &PedItmCod = 0
		Where PedVlrUnt = &PedVlrUnt
		
		if PedProEstProCod.IsEmpty() or PedProEstProCod.IsNull()
			PedProEstProCod	   = ProEstProCod		
			PedProEstProGraCod = ProGraCod
		Endif	
		
		&OldPedQtd = PedQtd
		
		Do CAse
			CAse PedQtd >= &FaltaDevolverPedQtd
				GravaItemDevolvido.call(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod, &FaltaDevolverPedQtd, PedProNom)
				
				PedQtd -= &FaltaDevolverPedQtd	
				
				if &LogErpTabIsLog = true
					&LogErpRegCod2 = trim(toformattedString(PedItmCod))
					&LogErpRegTip = TrnMode.Update
					&LogErpRegGUID.SetEmpty()
					//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedQtd', trim(toformattedString(&OldPedQtd)), trim(toformattedString(PedQtd)), &LogErpRegGUID )
				Endif
			
				PedQtdEmb = PedQtd
				&FaltaDevolverPedQtd = 0
				&ProNomGra = ProNomGra 
				
			Case &FaltaDevolverPedQtd > 0
				if &LogErpTabIsLog = true
					&LogErpRegCod2 = trim(toformattedString(PedItmCod))
					&LogErpRegTip = TrnMode.Delete
					&LogErpRegGUID.SetEmpty()
					//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProCod', trim(toformattedString(ProCod)), '0', &LogErpRegGUID )
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmCmp', trim(toformattedString(PedItmCmp)), '0', &LogErpRegGUID )
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedQtd', trim(toformattedString(PedQtd)), '0', &LogErpRegGUID )
					prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVlrUnt', trim(toformattedString(PedVlrUnt)), '0', &LogErpRegGUID )
				Endif
		
				GravaItemDevolvido.call(EmpCod, FilCod, PedCod, PedItmCod, ProCod, ProGraCod, PedQtd, PedProNom)
				
				&FaltaDevolverPedQtd -= PedQtd
				PedQtd = 0
				PedQtdEmb = 0
		EndCAse
		
		&IsSucesso  = true
		&IsDeletou = false
		if PedQtd <= 0
			&IsDeletou = True
			delete			
		Else
			If &PedQtdCan >= 0 
				PedQtdCan = &PedQtdCan
			Else
				PedQtdCan = 0
			EndIF
			
			PedQtdEmb = PedQtd
			
			if &ProTipDef = Definicao.SERVICO
				&MensagemInserida = 'Serviço ' +trim(str(&ProCod))+ ', atualizado com sucesso.'
			Else
				&MensagemInserida = 'Produto ' +trim(str(&ProCod))+ ', atualizado com sucesso.'
			EndIF
			commit
			
			AtualizaTotaisPedido.Call(EmpCod, FilCod, PedCod, PedItmCod, 'I')
		EndIF
		
		if &FaltaDevolverPedQtd	= 0
	        Exit
		EndIF
    EndFor
	
	Exit
EndFor

commit

AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')

If  &PedSts <> Status_Pedido.FECHADO and &PedSts <> Status_Pedido.SEPARANDO
	AtualizaEstoqueCompradoVendido.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &OldPedQtd, &PedQtd, &LctAtuEst)
EndIF
]]></Source>
