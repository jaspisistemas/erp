        <Source><![CDATA[for each Balanco order EmpCod, FilCod, BalCod
	where EmpCod = &EmpCod
	where FilCod = &FilCod
	where BalPedCod = &PedCod
	
	&sdtBalancoPorPedido.BalCod = BalCod
	&sdtBalancoPorPedido.BalNfeCod = BalNfeCod
	&sdtBalancoPorPedido.BalObs = BalObs
	&sdtBalancoPorPedido.BalDta = BalDta
	
	exit
endfor
]]></Source>
