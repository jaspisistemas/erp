      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem = ''
For Each Order EmpCod, CtabanCod
	Where EmpCod = &EmpCod
	Where CtabanCod = &CbrCod
	
	&FilCod = CtaBanFilCod
	do 'GetFilial'
	
	if &PedFrpPgtoTip = TipoDuplicata.DEPOSITO
		&Mensagem = 'BANCO: ' + trim(CtaBanBanCod) + ' - ' + trim(CtaBanBanNom) + ' , AG: '+ trim(CtaBanAgeCod) 
		if not CtaBanAgeDig.IsEmpty()
			&Mensagem += '-'+ trim(CtaBanAgeDig)
		EndIf
		
		&Mensagem += ' , C/C: '+ trim(CtaBanCrt) +'-'+ trim(CtaBanCrtDig) + ' , FAVORECIDO: ' + trim(&FilRaz)
	Else	
		&Mensagem = 'FAVORECIDO: ' + trim(&FilRaz)
		if not CtaBanPix.IsEmpty() and not CtaBanPix.IsNull()
			&Mensagem += ' PIX: ' + trim(CtaBanPix)
		EndIf
	Endif

	exit
EndFor

Sub 'GetFilial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilRaz = FilRaz + ' CNPJ:' + trim(FilCpj)
		Exit
	EndFor
EndSub
]]></Source>
