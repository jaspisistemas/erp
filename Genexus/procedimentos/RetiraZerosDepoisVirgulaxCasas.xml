      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AuxEntrada = &EntradaVarchar.Trim()

&QtdTot = &AuxEntrada.Length()
&VirgulaID = &AuxEntrada.IndexOf(',', 1)
if &VirgulaID.IsEmpty()
	&VirgulaID = &AuxEntrada.IndexOf(',', 1)
Endif
&Count = &VirgulaID

For &in = &VirgulaID to &QtdTot
	&AnalisaCAmpo = Substr(&AuxEntrada, &in, 1)
	
	if &AnalisaCAmpo <> '0'
		&UltimoNumeric = &in
	Endif
EndFor

&Falta = &UltimoNumeric-&VirgulaID
Do CAse
	CAse &UltimoNumeric <= &VirgulaID
		if &xcASAS = 0
			&UltimoNumeric = &VirgulaID - 1
		Else
			&UltimoNumeric = &VirgulaID + &xcASAS
		Endif
	
	CAse &Falta < &xcASAS and &Falta > 0
		&UltimoNumeric += &xcASAS - (&Falta)
EndCAse

	
&SaidaVarchar = Substr(&AuxEntrada, 1, &UltimoNumeric)
]]></Source>
