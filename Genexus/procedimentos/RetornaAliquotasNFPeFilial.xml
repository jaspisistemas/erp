      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	&PerFabov = IIF(FilPerFabov>0,((FilPerFabov/100)*FilBasUpf),0)
	&PerIagro =  IIF(FilPerIagro>0,(((FilPerIagro/100)*FilBasUpf)/1000),0)
	&PerFethabGado =  IIF(FilPerFethabGado>0,((FilPerFethabGado/100)*FilBasUpf),0)
	&PerFethabSoja =  IIF(FilPerFethabSoja>0,(((FilPerFethabSoja/100)*FilBasUpf)/1000),0)
	&FilPerFun =  IIF(FilPerFun>0,(FilPerFun/100),0) //sobre o total da nota
	&FilPerSenar =  IIF(FilPerSenar>0,(FilPerSenar/100),0) //sobre o total da nota
	Exit
	
Endfor
 
]]></Source>
