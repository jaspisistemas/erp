        <Source><![CDATA[
&EmpCnpj = '21826923000177'
&EmpRaz = 'JEAN DIEGO FAE'
&EmpEml = 'contato@jaspi.com.br'
&EmpFon = '44997538680'
&IdCSRT = '01'

//Passo 1: Concatenar o CSRT com a chave de acesso da NF-e/NFC-e que está sendo emitida.
//CSRT JASPI: OP8B0CSTADDSS5VKH6YL1LE0T0UFM5VW6QWK 
&StringTotal = 'OP8B0CSTADDSS5VKH6YL1LE0T0UFM5VW6QWK'+&ChaveNfe
//&StringTotal = 'G8063VRTNDMO886SFNK5LDUDEI24XJ22YIPO41180678393592000146558900000006041028190697' //TESTE RECEITA

//Passo 2: Aplicar o algoritmo SHA-1 sobre o resultado da concatenação do passo 1, gerando uma string de 40 caracteres em hexadecimal.
&CryptoHash.Algorithm = CryptoHashAlgorithm.SHA1
&novaString = &CryptoHash.Compute(&StringTotal)

//Passo 3: Converter o resultado do passo anterior para Base64, resultando em uma string de 28 caracteres (20 bytes).
&hashCSRT = &Base64Encoder.FromStringHexaToBase64(&novaString)
]]></Source>
