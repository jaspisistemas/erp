Sub 'DescontoMaximo'
	
	if &IsAutorizadoDescontoMaximo <> true
		
		
		&TotalDescontos = 0
		IF (&PedVlrUnt <> &PedVlrTab) AND (&PedVlrUnt > 0) AND (&PedVlrTab > 0)
			&TotalDescontos = (100 - ((&PedVlrUnt / &PedVlrTab) * 100))
		EndIF
		
		//if &PedItmDsc > 0
			&TotalDescontos += &PedItmDsc
		//EndIF
		if &PedItmDsc < 0
			&TotalDescontos = 0
		Endif

		VerificaDescontoMaximoPedidoItem.Call(&EmpCod, &FilCod, &PedCod, &wwpContext, &PedItmCod, &PedItmPrm, &PedVlrItm, &TotalDescontos, &PedVlrUnt, &TCon017_DescMax, &TCon131_DescMaxTabPromocao, &PesDscMax, &ProDesMax, &GrupDscMax, &PedLibAutPedQtd, &PedLibAutPedVlr, &PedLibAutPedDesc, &ProRef, &ProNom, &Mensagem, &IsErro)
		&ErroDescontoMaximo = iif(&IsErro = true, 1, 0)
		
	EndIF
EndSub

sub 'GetTotal'
	//TOTAL
	&PedVlrItm = round(&PedQtd * &PedVlrUntDsc, 2)
	//	&TotProPesLiq = &ProPesLiq * &PedQtd
EndSub

Sub 'GetDesconto'
	
	//DESCONTO
	&DescontoCapa = 0	
	&PedItmPrm = RetornaPrecoUnitarioTipo.Udp(&EmpCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedItmDsc)

    &PedVlrUntDsc = &PedVlrUnt
    if &PedItmDsc <> 0
		&PedVlrUntDsc = round(&PedVlrUnt - (&PedVlrUnt * &PedItmDsc * 0.01), 2)
    	&PedVlrUntDsc = round(&PedVlrUnt - (&PedVlrUnt * &PedItmDsc * 0.01), 2)
	Else
		Do Case
			Case &ProTipDef = Definicao.SERVICO
				&DescontoCapa = ( round((&PedVlrUnt * &PedPerSrv1 * 0.01),2) + (round(((&PedVlrUnt - round((&PedVlrUnt * &PedPerSrv1 * 0.01),2)) * &PedPerSrv2 * 0.01),2)))
			CAse &PedItmPrm = 'P' or &PedItmPrm = 'D'
				&DescontoCapa = (round((&PedVlrUnt * &PedPerPrm1 * 0.01),2) + (round(((&PedVlrUnt - round((&PedVlrUnt * &PedPerPrm1 * 0.01),2)) * &PedPerPrm2 * 0.01),2)))
			Otherwise
				&DescontoCapa = ( round((&PedVlrUnt * &PedPerSpm1 * 0.01) + (((&PedVlrUnt - (&PedVlrUnt * &PedPerSpm1 * 0.01)) * &PedPerSpm2 * 0.01)),2))
		EndCase
		
		&PedVlrUntDsc =  &PedVlrUnt - &DescontoCapa
    endif
	
EndSub


Sub 'validaQTD'

    &ErroQuantidade = 0
	&Mensagem.SetEmpty()
	
	
	if &IsAutorizadoDescontoMaximo <> true
		//if &PedBlq <> Status_SimNao.Sim and &DescontoQuantidadePermitida < 1
		if &PedQtd > &TCon033_MaiorQtdVendida and &TCon033_MaiorQtdVendida > 0 and (&PedQtd > &PedLibAutPedQtd and &PedLibAutPedQtd > 0)
	        &Mensagem = 'Atenção quantidade digitada é maior que ' + trim(toformattedString(&TCon033_MaiorQtdVendida)) + ' [CONF213]'
	        &ErroQuantidade = 1
	    Else
			If &PedQtd <> &OLDPedQtd
				&PedQtdCan = &PedQtdCan + (&OLDPedQtd - &PedQtd)
			EndIF
			
			If &PedQtd > 0 and  (&PedQtd <> &PedLibAutPedQtd)
				If &ProQtdEmb > 1 //QTD EMBALAGEM
					&Resto = round((&PedQtd / &ProQtdEmb),0)
					&Resto = &PedQtd - (&Resto * &ProQtdEmb)
					
					If &Resto <> 0				
						&Mensagem = 'Quantidade inválida para produtos Embalados! Quantidade por Embalagem: '+ trim(str(&ProQtdEmb))
						&ErroQuantidade = 1
					EndIf
				EndIF
				
				if &ErroQuantidade = 0
					If &ProQtdVol > 1 //QTD POR VOLUME
						&Resto = round((&PedQtd / &ProQtdVol),0)
						&Resto = &PedQtd - (&Resto * &ProQtdVol)
						
						If &Resto <> 0				
							&Mensagem = 'Quantidade inválida para volumes! Quantidade por Volume: '+ trim(str(&ProQtdVol))
							&ErroQuantidade = 1
						EndIf
					EndIF
				EndIF
				
//				if (&PedSts = Status_Pedido.FECHADO OR &PedSts = Status_Pedido.SEPARANDO)
//				    &newEstQtd = &EstQtd + &OLDPedQtd
//				Else
//					&newEstQtd = &EstQtd
//				Endif
				
//				If &PedQtd > &newEstQtd and &AlertarProdutoSemEstoque = 'S'
//					&Mensagem = 'Produto com estoque insuficiente! Em estoque:' + trim(str(&newEstQtd)) +  ' [CONF181]'
//				Endif
				
			EndIF
	    EndIf
//	Else
		
//		if (&PedSts = Status_Pedido.FECHADO OR &PedSts = Status_Pedido.SEPARANDO)
//		    &newEstQtd = &EstQtd + &OLDPedQtd
//		Else
//			&newEstQtd = &EstQtd
//		Endif
		
//		If &PedQtd > &newEstQtd and &AlertarProdutoSemEstoque = 'S'
//			&Mensagem = 'Produto: '+ trim(&CodigoProduto)+ ', com estoque insuficiente! Em estoque: ' + trim(str(&newEstQtd)) +  ' [CONF181]'
//		Endif
		
	EndiF

//	do 'sonsERRO'
//	if &ErroQuantidade = 1
//		&PedQtd.SetFocus()
//	EndIF

EndSub
