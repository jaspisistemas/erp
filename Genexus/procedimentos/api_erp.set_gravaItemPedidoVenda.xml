        <Source><![CDATA[//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

If &IsAcessoConcedido = true //Acesso concedido

	&EmpCod = &wwpContext.EmpCod
	&PEdItmCod = &parPEdItmCod
	
	&sdtRetornoWbsEtc.c1 = '0' //pedqtd
	&sdtRetornoWbsEtc.c2 = '0,00' //pedVlrUnt
	&sdtRetornoWbsEtc.c3 = '0,00' //PedItmVlr
	&sdtRetornoWbsEtc.c4 = '0,00' //PedItmVlrComDsc
	
	If &parPedQtd.IsEmpty() or &parPedVlrUnt.IsEmpty()
		Return
	Endif	
	
	if &wwpContext.TipoPerfil <> 3 //SUPORTE ADM
		RetornaAutorizacaoDescontoMaximo.Call(&EmpCod, &wwpContext.PesCod, &IsAutorizadoDescontoMaximo)
	Else
		&IsAutorizadoDescontoMaximo = true
	Endif	
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon033_MaiorQtdVendida, &CfgVlr)
    &TCon033_MaiorQtdVendida = val(&CfgVlr)
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon017_DescMax, &CfgVlr)
	&TCon017_DescMax = iif(&CfgVlr.IsEmpty(), 0, val(&CfgVlr)) 
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon131_DescMaxTabPromocao, &CfgVlr)
	&TCon131_DescMaxTabPromocao = iif(&CfgVlr.IsEmpty(), 0, val(&CfgVlr)) 
	
	
	&PedQtd = &parPedQtd
	&PedVlrUnt = &parPedVlrUnt
	&PedItmDsc = &parPedItmDsc
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &Filcod
		Where PedCod = &PedCod
		
		&PedCliCod = PedCliCod
		&PesDscMax = PedCliDscMax
		&PedSts = PedSts
		&PedLctUntArr = PedLctUntArr
		&LctRetCus = LctRetCus
		&LctInfPrc = LctInfPrc
		&PedDtaEms = PedDtaEms
		&TabCod = TabCod
		&TabIsAntAcr = TabIsAntAcr 
			
		&TabPrmCod = TabPrmCod
		&TabColCod = TabColCod
		&PedPerSrv1 = PedPerSrv1 
		&PedPerSrv2 = PedPerSrv2
		&PedPerPrm1 = PedPerPrm1 
		&PedPerPrm2 = PedPerPrm2 
		&PedPerSpm1 = PedPerSpm1 
		&PedPerSpm2 = PedPerSpm2
		
		For Each ORder EmpCod, FilCod, PedCod, PedItmCod
			Where PedItmCod = &PEdItmCod
			
			&OLDPedQtd = PedQtd
			&PedQtdCan = PedQtdCan
			&PedVlrTab = PedVlrTab
			&PedItmVenCod = PedItmVenCod
			&PedCodOciRefItm = PedCodOciRefItm
			&TabPerAnt = PedItmTabPerAnt
			&TabPerAcr = PedItmTabPerAcr
			&TabDtaVct = PedItmTabDtaVct
			&PedItmProRefDig = PedItmProRefDig
			&PedNItmPed = PedNItmPed
			Exit
		EndFor
	
		Exit
	Endfor

	For Each ORder EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		where ProSts <> Status_Produto.EXCLUIDO
		
		&ProRef = ProRef
		&ProNom = ProNom
		
		&ProReqVlr = ProReqVlr
		&ProTipDef = ProTipDef
		&ProQtdEmb = ProQtdEmb
		&ProQtdVol = ProQtdVol
		
		&ProDesMax = ProDesMax 
		&GrupDscMax = GrupDscMax
		
		if &ProGraCod =1 and ProIsGra = true
			&sdtRetornoWbsEtc.obs = 'Produto com Variação, é preciso inserir o Código da Variação!'
			&sdtRetornoWbsEtc.sts = 'E000'
			Return
		Endif
	
		//GRADE
		For Each Order EmpCod, ProCod, ProGraCod
			Where ProGraCod = &ProGraCod
			&ProGraRef = ProGraRef
			Exit
		EndFor
		
		//ESTOQUE
		For Each Order EmpCod, FilCod, ProCod, ProGraCod
			Where FilCod = &Filcod
			Where ProGraCod = &ProGraCod
			
			&EstQtd = EstQtd
			
			Exit
		EndFor
		
		If ProSts = Status_Produto.INATIVO and &EstQtd <= 0
			&sdtRetornoWbsEtc.obs = 'Produto Inativo com Estoque Zero! Produto:' + trim(ProRef)
			&sdtRetornoWbsEtc.sts = 'E000'
			Return
		EndIf
	
		Exit
	When none
		&sdtRetornoWbsEtc.sts = 'E000'
		&sdtRetornoWbsEtc.obs = 'PRODUTO NAO LOCALIZADO!'
		return
	EndFor

	RetornaTotalAutorizado.Call(&EmpCod, &FilCod, &PedCod, &ProCod, &ProGraCod, &PedLibAutPedQtd, &PedLIbAutPedVlr, &PedLibAutPedDesc)
	
	Do Case
		Case (&LctRetCus = Status_SimNao.Sim) //and &PedVlrUnt <= 0
			//&PedVlrUnt = &ProVlrCus
			&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaEms)
			
		Case (&LctInfPrc = Status_SimNao.Nao and &ProReqVlr <> true) //or &PedVlrUnt <= 0
			&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaEms)
			
			if &TabIsAntAcr = true			
				RetornaPrecoUnitarioVendaPrecificado.Call(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct, &PedVlrUnt, &TabPerAcr, &TabPerAnt, &TabDtaVct)
			Else
				&PedVlrUnt = &PedVlrTab
				&TabPerAcr.SetEmpty()
				&TabPerAnt.SetEmpty()
				&TabDtaVct.SetEmpty()
			EndIf
	EndCase	
		
	do 'validaQTD'
	if &ErroQuantidade > 0
		&sdtRetornoWbsEtc.sts = 'E000'
		&sdtRetornoWbsEtc.obs = &Mensagem
		return
	Endif

	Do 'GetDesconto'
	Do 'GetTotal'
	
	Do 'DescontoMaximo'
	if &ErroDescontoMaximo > 0
        &sdtRetornoWbsEtc.sts = 'E000'
		&sdtRetornoWbsEtc.obs = &Mensagem
		return
	Endif
	
	Do Case
		CAse &PedVlrUnt <= 0
			&sdtRetornoWbsEtc.sts = 'E000'
			&sdtRetornoWbsEtc.obs = 'Produto: ' + trim(&ProGraRef) + ' Valor unitário menor ou igual a Zero!'
			return
		CAse &PedVlrTab <= 0 and (&LctRetCus <> Status_SimNao.Sim and (&LctTip = TipoLancamento.OrcamentoVenda or &LctTip = TipoLancamento.SaidaMercadoria))
			&sdtRetornoWbsEtc.sts = 'E000'
			&sdtRetornoWbsEtc.obs = 'Produto fora da tabela de preço:'+trim(&TabCod)+', não permitido sua venda!'
			return
	EndCase
	
	//Validar tecnico mecanico
////	Do Case
////		CAse &PedItmPesIsFun = false and &PedItmVenCod <> 0
////			&Mensagem = 'Técnico/Mecânico, inválido!'
////			do 'sonsERRO'

	do 'Gravar'
	
	RetornaTotalLiquidoBruto.Call(&EmpCod, &FilCod, &PedCod, &PedVlrBrt, &PedVlrLiq)
	
	//SOMAR A QTD DE ITENS
	
	
	&sdtRetornoWbsEtc.sts = 'J200'
	
	&Varchar = trim(&PedQtd.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(0,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c1 = &Varchar//pedqtd
	
	&Varchar = trim(&pedVlrUnt.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c2 = &Varchar//pedVlrUnt

	&Varchar = trim(&PedVlrItm.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
	&sdtRetornoWbsEtc.c3 = &Varchar //PedItmVlr
	
	&Varchar = trim(&PedVlrUntDsc.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(&PedLctUntArr, &Varchar, &Varchar)
	&sdtRetornoWbsEtc.c4 = &Varchar //PedVlrUntDsc
	
	&Varchar = trim(&PedVlrLiq.ToFormattedString())
	retiraZerosDepoisVirgulaxCasas.Call(&PedLctUntArr, &Varchar, &Varchar)
	&sdtRetornoWbsEtc.c5 = &Varchar //PedVlrLiq
	
//	&Varchar = trim(&PedVlrLiq.ToFormattedString())
//	retiraZerosDepoisVirgulaxCasas.Call(&PedLctUntArr, &Varchar, &Varchar)
//	&sdtRetornoWbsEtc.c6 = &Varchar //qtdItens
	
EndIf


