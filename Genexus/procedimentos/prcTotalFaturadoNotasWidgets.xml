      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For &Count =1 to 12
	&sdtNotasFiscaisItem = New()
	&sdtNotasFiscaisItem.DataBase = YMDtoD(&NfeDtaFat_Ano, &Count, 1)
	&sdtNotasFiscaisItem.NfeDtaFat_Mes = &Count
	&sdtNotasFiscais.Add(&sdtNotasFiscaisItem)
EndFor

//ATUALIZA DATAS DE FATURAMENTO
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where  (NfeDtaFat.IsEmpty() or NfeDtaFat.IsNull()) or (NfeDtaFat_Mes.IsEmpty() or NfeDtaFat_Mes.IsNull())
	or (NfeDtaFat_Ano.IsEmpty() or NfeDtaFat_Ano.IsNull())
		
	&NfeDtaFat = NfePedDtaFat_FORMULA
	NfeDtaFat = &NfeDtaFat
	if &NfeDtaFat.IsEmpty()
		NfeDtaFat_Mes = 0
		NfeDtaFat_Ano = 0
	Else
		NfeDtaFat_Mes = &NfeDtaFat.Month()
		NfeDtaFat_Ano = &NfeDtaFat.Year()
	Endif

EndFor

commit

//NOTAS Modelo 55 e 65
For Each Order EmpCod, FilCod, NfeDtaFat_Ano, NfeFin, NfeDtaFat_Mes, NfeEntSai
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	where NfeDtaFat_Ano = &NfeDtaFat_Ano
	Where (NfeSts = Status_Nfe.Autorizada) or (NfeProTer = Nota_ProPriaTerceira.TERCEIROS and NfeSts = Status_Nfe.Digitando) 
	Where NfeFin = NotaFinalidade.EmissaoNormal
	Where NfeLctGerFin = Status_SimNao.Sim
	
	if (&NfeDtaFat_Mes <> NfeDtaFat_Mes or &NfeEntSai <> NfeEntSai) and not &NfeDtaFat_Mes.IsEmpty()
		do 'addSDT'
	Endif
	
	&NfeVlrTot += NfeVlrTot
	&NfeDtaFat_Mes = NfeDtaFat_Mes
	&NfeEntSai = NfeEntSai
EndFor

if &NfeVlrTot > 0
	do 'addSDT'
Endif

//NOTAS SERVICO
&NfeDtaFat_Mes = 0
&NfeVlrTot = 0
For Each Order EmpCod, NfsFilCod, NfsDtaFat, NfsEntSai
	Where EmpCod = &EmpCod
	Where NfsFilCod = &FilCod
	where NfsDtaFat.Year() = &NfeDtaFat_Ano
	Where (NfsSts = Status_Nfe.Autorizada) or (NfsProTer = Nota_ProPriaTerceira.TERCEIROS and NfsSts = Status_Nfe.Digitando) 
	
	if (&NfeDtaFat_Mes <> NfsDtaFat.Month() or &NfeEntSai <> NfsEntSai) and not &NfeDtaFat_Mes.IsEmpty()
		do 'addSDT'
	Endif
	
	&NfeVlrTot += NfsVlrTot
	&NfeDtaFat_Mes = NfsDtaFat.Month()
	&NfeEntSai = NfsEntSai
EndFor

if &NfeVlrTot > 0
	do 'addSDT'
Endif

padraoUsuarioHora.Call('G', '#WidGet_FaturamentoFiscalEntSai#', &PesCod, &EmpCod, &sdtNotasFiscais.ToXml(), &PadDtaMod, &PadDtaHorMod, 'T')

Sub 'addSDT'
	For &sdtNotasFiscaisItem in &sdtNotasFiscais
		If &sdtNotasFiscaisItem.NfeDtaFat_Mes = &NfeDtaFat_Mes 
			if &NfeEntSai = Status_EntradaSaida.Saida
				&sdtNotasFiscaisItem.NfeVlrTotSai += &NfeVlrTot
			Else
				&sdtNotasFiscaisItem.NfeVlrTotEnt += &NfeVlrTot
			Endif		
			
			Exit
		EndIf
	EndFor	
	
	&NfeVlrTot = 0	
EndSub
]]></Source>
