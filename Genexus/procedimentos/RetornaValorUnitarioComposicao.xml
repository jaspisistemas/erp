        <Source><![CDATA[
&TabPrc1.SetEmpty()
For Each Order EmpCod, TabCod, ProCod, ProGraCod, TabAltCod
	Where EmpCod = &EmpCod
	Where TabCod = &TabCod
	Where ProCod = &PRoCod
	Where ProGraCod = &ProGraCod
	Where TabUltAlt = TabAltCod
	
	&TabPrc1 = TabPrc1
	Exit
EndFor
]]></Source>
