      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsTemUmMensagem.SetEmpty()
&IsDeve = false
&collPedCliCod.Clear()
RetornaVinculos.Call(&EmpCOd, &PedCliCod, &sdtVinculos)
For &sdtVinculosItem in &sdtVinculos
	&collPedCliCod.Add(&sdtVinculosItem.PesCod)
EndFor


For Each Order EmpCod, FilCod, PedCliCod
	Where EmpCod = &EmpCOd
	Where FilCod = &FilCod
	Where PedCliCod in &collPedCliCod
	Where PedSts = Status_Pedido.ABERTO or PedSts = Status_Pedido.SEPARANDO
	Where LctTip = TipoLancamento.SaidaMercadoria or LctTip = TipoLancamento.OrcamentoVenda
	&IsTemUmMensagem = 	'Pedido: ' + trim(str(PedCod))
	if PedCliCod <> &PedCliCod
		&IsTemUmMensagem += ' Cliente: ' + trim(str(PedCliCod))
	Endif

	Exit
EndFor

For Each order EmpCod, CreCliCod
	Where EmpCod = &EmpCod
	Where CreCliCod in &collPedCliCod
	Where CreVlrSdo > 0
	Where CreDtaVct <= Serverdate()
	Where CreSts <> Status_duplicata.CANCELADA
	
	&IsDeve = true
	Exit
EndFor
]]></Source>
