      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


Do Case 
	Case &OqueFazer = 'INS'
		For Each Order EmpCod, CotComCod
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComForCod = &CotComForCod
			exit
		when none
			New
				EmpCod = &EmpCod
				CotComCod = &CotComCod
				CotComForCod = &CotComForCod
				CotComForSts = StatusCotacaoFornecedor.BLOQUEADO
				CotComForNum = &CotComForNum
				CotComForEmail = &CotComForEmail
			EndNEw
		EndFor
		
		commit
		
		//adicionar o fornecedor em todos os produtos da cotacao
		if &IsAdicionarTodos = true
			For Each Order EmpCod, CotComCod, CotComItmCod
				Where EmpCod = &EmpCod
				Where CotComCod = &CotComCod
				
				&CotComItmCod = CotComItmCod
				New //Grava FornecedorProduto
					 EmpCod = &EmpCod
					CotComCod = &CotComCod
					CotComItmCod = &CotComItmCod
					CotComProForCod = &CotComForCod
				EndNew
			EndFor
			
			Commit
		EndIf
		
	Case &OqueFazer = 'UPD'		
		For Each Order EmpCod, CotComCod
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComForCod = &CotComForCod
			
			CotComForNum = &CotComForNum
			CotComForEmail = &CotComForEmail
			Exit
		EndFor
		
		commit
		
	Case &OqueFazer  = 'DEL'
		//remove itens
		For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComProForCod = &CotComForCod
			
			delete
		EndFor
		
		Commit
		
		//Remove
		For Each Order EmpCod, CotComCod, CotComForCod
			Where EmpCod = &EmpCod
			Where CotComCod = &CotComCod
			Where CotComForCod = &CotComForCod
			
			delete
		EndFor
		
		Commit
		
EndCase


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
