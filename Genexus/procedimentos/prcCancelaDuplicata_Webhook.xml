      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,CreCod
	Where CreCodSol	= &CreCodSol
	
	&CreCod		= CreCod
	&CreDupNro	= CreDupNro
	&CreDtaRet.SetEmpty()
	
	CreDtaRet 	= &CreDtaRet
	CreCodBar 	= ''
	CreLinDig 	= ''
	CreQrCode 	= ''
	CreTxId 	= ''
	CreBloNro	= ''
	CreCodSol	= ''
	
	Exit
EndFor

If not &CreCod.IsEmpty()
	Commit
EndIf
]]></Source>
