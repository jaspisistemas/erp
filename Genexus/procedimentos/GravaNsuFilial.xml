      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each order EmpCod,FilCod  //faz update
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	If &Tipo = 'NFE' //JDF SE FOR MAIOR QUE ZERO
		if &FilUltNSU > 0 and &FilUltNSU > FilUltNSU
			FilUltNSU = &FilUltNSU 
		Endif
		if &FilMaxNSU > 0 and &FilMaxNSU > FilMaxNSU
			FilMaxNSU = &FilMaxNSU
		Endif
	
		if &cStat = '656'
			FilNsuBlqDtaHor = serverNow()
			FilNsuBlqDtaHor = FilNsuBlqDtaHor.AddHours(1)
		Endif
	Else
		if &FilUltNSU > 0 and &FilUltNSU > FilUltNSUCte
			FilUltNSUCte = &FilUltNSU 
		Endif

		if &FilMaxNSU > 0 and &FilMaxNSU > FilMaxNSUCte
			FilMaxNSUCte = &FilMaxNSU
		Endif
	
		if &cStat = '656'
			FilNsuCteBlqDtaHor = serverNow()
			FilNsuCteBlqDtaHor = FilNsuCteBlqDtaHor.AddHours(1)
		Endif
	
	EndIf

	FilUltSin = &FilUltSin
	exit
EndFor


commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
