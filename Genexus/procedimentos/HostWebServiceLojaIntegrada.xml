      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[LoadWWPContext.Call(&Context)
&EmpCod = &Context.EmpCod


For each Order EmpCod,LojVirTip
	Where EmpCod = &EmpCod
	Where LojVirTip = LojaVirtual.LojaIntegrada
	&Host = LojVirUrl
	&BaseUrl = LojVirBasUrl
	&LojVirUsr = LojVirUsr
	&LojVirSen = LojVirSen
	&LojVirApiKey = LojVirApiKey  // chave_api westseller fb57ea3997e255368702  usuario:tiago_ordig@hotmail.com senha:ti406500
	&LojVirToken = LojVirToken   // chave_aplicacao	      edd4bb11-24ec-49c0-8203-6b6c8d8c6202	fornecido somente no plano pago pelo chat da loja integrada.(chamado suporte)
	Exit
When none
	&Host = ''
	&BaseUrl = ''
	&LojVirUsr = ''
	&LojVirSen = ''
	&LojVirApiKey = ''  // chave_api westseller fb57ea3997e255368702  usuario:tiago_ordig@hotmail.com senha:ti406500
	&LojVirToken = ''
	msg( DVMessageBasicNotification.Udp(!"Erro!", 'Cadastro da (Loja Integrada) não encontrado!',DVMessageType.error, "", DVMessageBoolean.True) )
EndFor
]]></Source>
