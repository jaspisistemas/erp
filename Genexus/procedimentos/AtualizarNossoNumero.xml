      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FilCod,CreCod
    Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	&CreCbrCod = CreCbrCod
	If &auxRemCreBloNro.Trim() = CreBloNro.Trim()
		Do 'LocalCobranca'
		GerarNossoNumero.CALL(&CbrCtaBanBanCod,&CbrNroCon,&CtaBanNosNro,CreDtaEms,&AuxCreBloNro,&Erro)
		CreBloNro = trim(&AuxCreBloNro)
	EndIf
	exit
EndFor

commit 

Sub 'Conta'
	For each Order EmpCod,CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &CbrCtaBanCod
		CtaBanNosNro += 1
		&CtaBanNosNro = CtaBanNosNro
		Exit
	EndFor
EndSub

Sub 'LocalCobranca'
	For each Order EmpCod,CbrCod
		Where EmpCod = &EmpCod
		Where CbrCod = &CreCbrCod
		Where CbrTipImp = TipoImpressao.GerarBoleto  //Gerar Boleto
		&CbrCtaBanCod = CbrCtaBanCod
		Do 'Conta'
		
		&CbrCtaBanBanCod = CbrCtaBanBanCod
		&CbrNroCon = CbrNroCon
		exit
	EndFor
EndSub

]]></Source>
