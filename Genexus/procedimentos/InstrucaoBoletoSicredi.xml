      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&MsgErro = ''
&MsgSucesso = ''
For Each Order EmpCod,FilCod,CreCod,CreRecPag
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	Where CreRecPag = ReceberPagar.Receber
	
	&CreCbrCod = CreCbrCod
	Do 'GetLocalCobraca'
	
	If &ErroCobraca = 0 and &IschaveTransacao = True
		&CreBloNro = padL(substr(trim(&CbrCtaBanAgeCod),1,4),4,'0')+padL(substr(trim(&CbrCtaBanAgeDig),1,2),2,'0') + padL(trim(&CbrNroCon),5,'0')+padL(trim(CreBloNro),8,'0')						      // Pega Nosso Número da Duplicata	
		CalculaDigNosNro.Call(&CbrCtaBanBanCod, '', 2, &CreBloNro)
		&nossoNumero = padL(trim(&CreBloNro), 9, '0') 
		
		//##################################################################################### chamada ao webservice 
		&Authorization = 'Bearer '+ trim(&CbrChaTra)

		HostWebServiceBoletoApi.Call('HIBRIDO',748, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor) // 748 = Sicredi
		&HttpClient.Host = &EmpWebHost //servidor
		&HttpClient.Secure = 1

		&httpclient.AddHeader(!'Content-type',!'application/json')
		&httpclient.AddHeader(!'x-api-key', Trim(&CbrApiKey))
		&httpclient.AddHeader(!'Authorization', trim(&Authorization))
		&httpclient.AddHeader(!'cooperativa', padL(substr(trim(&CbrCtaBanAgeCod),1,4),4,'0'))
		&httpclient.AddHeader(!'posto', padL(substr(trim(&CbrCtaBanAgeDig),1,2),2,'0'))
		&httpclient.AddHeader(!'codigoBeneficiario', Trim(&CbrNroCon))
		
		If padL(substr(trim(&CbrCtaBanAgeCod),1,4),4,'0') = '6789' and padL(substr(trim(&CbrCtaBanAgeDig),1,2),2,'0') = '03' and padL(substr(trim(&CbrNroCon),1,5),5,'0') = '12345'
			&String = '/sb/cobranca/boleto/v1/boletos'
		Else
			//############################################################# PRODUÇÃO ######################
			&String = '/cobranca/boleto/v1/boletos'
		EndIF
		Do Case
			Case &CreCmdIns = ComandoInstrucao.PEDIDO_BAIXA
				&String = &String + '/' + Trim(&nossoNumero) + '/baixa'
				&Body	= '{' + NewLine() + '}'
				
			Case &CreCmdIns = ComandoInstrucao.ALTERACAO_VENCIMENTO
				&String += '/'+TRIM(&nossoNumero)+'/data-vencimento'
				&dia = day(&CampoData)
				&mes = month(&CampoData)
				&Ano = year(&CampoData) 
				
				&SdtBoletoInstrucaoSicredi.dataVencimento = padL(str(&ano),4,'0')+'-'+padL(str(&mes),2,'0') +'-'+padL(str(&dia),2,'0') 
				&Body	= &SdtBoletoInstrucaoSicredi.ToJson()
			OtherWise
				Msg('Somente os métodos de baixa e alteraçao de vencimentos são possíveis de realizar nas opções de boleto hibrido')
		EndCase		
		&HttpClient.AddString(&Body)
		
		padraoUsuario.Call('G', '#BOLETOAPIECOMMERCEINSTRUCAOENVIO', &PesCod, &EmpCod, &Body, &PadDtaMod) 
		&httpclient.Execute(HttpMethod.Patch, &String)
		padraoUsuario.Call('G', '#BOLETOAPIECOMMERCEINSTRUCAO', &PesCod, &EmpCod, &HttpClient.toString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
		
		Do Case
			Case &HttpClient.StatusCode = 422 And &CreCmdIns = ComandoInstrucao.PEDIDO_BAIXA
				Msg('Comando de Instrução realizado, título já baixado! ' + &HttpClient.StatusCode)			
				Do 'AtualizaDuplicata'
			Case &HttpClient.StatusCode < 400
				&SdtBoletoInstrucaoSicrediRetorno.fromJson(&HttpClient.toString())  // retorna dados de Saida			
				Msg('Comando de Instrução realizado com sucesso! ' + &HttpClient.StatusCode)			
				Do 'AtualizaDuplicata' 
			Otherwise
				&SdtBoletoSicrediErro.fromJson(&HttpClient.toString())
				If &SdtBoletoSicrediErro.error.IsEmpty()
					Msg('ERRO ' + Trim(Str(&HttpClient.StatusCode)) + ' - ' + Trim(&HttpClient.ErrDescription))
				Else
					Msg('ERRO - '+trim(str(&HttpClient.StatusCode)) +': '+&SdtBoletoSicrediErro.status.Trim()+' Msg: '+&SdtBoletoSicrediErro.error.Trim() +' Parametro: '+&SdtBoletoSicrediErro.message.Trim())
				EndIf
				&IsErro = true
		EndCase		
	EndIf
EndFor


	//#################################################################################################################################################
Sub 'GetLocalCobraca'
	
	&ErroCobraca = 0
	For each Order EmpCod,CbrCod,CbrTipImp
		Where EmpCod = &EmpCod
		Where CbrCod = &CreCbrCod
		
		&CbrCtaBanAgeCod = CbrCtaBanAgeCod
		&CbrCtaBanAgeDig = CbrCtaBanAgeDig
		&CbrCtaBanCrt = CbrCtaBanCrt
		&CbrCtaBanBanCod = CbrCtaBanBanCod
		&CbrNroCon = CbrNroCon
		&CbrCarCod = CbrCarCod
		&CbrDesDia = CbrDesDia
		&CbrQtdDiaDesc = CbrQtdDiaDesc
		&CbrDesAnt  = CbrDesAnt
		&CbrInsBol1 = CbrInsBol1
		&CbrMltVlr  = CbrMltVlr
		&CbrApiKey = CbrApiKey
		
		If not CbrChaMas.Trim().IsEmpty()  // chave master NÃO esta Vazia?
			&CbrChaMas = CbrChaMas                                                 
			If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow() //chave de Transação esta Vencida?
				&CbrChaTra = CbrChaTra
				&IschaveTransacao = true  // pega chave transação jah existente ou a nova no else.
			Else
				AutenticaBoletoSicredi.Call(EmpCod,CbrCod,CbrChaMas,CbrApiKey,CbrCtaBanAgeCod,CbrNroCon,&IschaveTransacao,&CbrChaTra) 			
			EndIf
		Else
			&ErroCobraca = 1
			&Mensagem = 'Chave master inválida verifique!'
			&IsErro = true
		EndIF
	
		&CbrJurCod = CbrJurCod             // Local Cobrança Juros Código
		&JurTaxDia = 0
		Do 'Juros'
	EndFor
EndSub

Sub 'Juros'	
	For each Order EmpCod,JurCod,(JurAno),(JurMes)
		Where EmpCod = &EmpCod
		Where JurCod = &CbrJurCod
		&JurTax = JurTax
		&JurTaxDia = JurTaxDia
		Exit
	EndFor
EndSub


Sub 'AtualizaDuplicata'
	&IsComandoExecutado = False
	
	AtualizaInstrucaoDuplicata.call(&EmpCod,&FilCod,&CreCod,&CreCmdIns,&CampoData,&PesCod,&PesRaz,&SdtBoletoInstrucaoSicrediRetorno)
	
EndSub

]]></Source>
