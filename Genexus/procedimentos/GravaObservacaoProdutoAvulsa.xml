      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod, PedItmCod, PedProOGrupCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCod = &PedItmCod
	Where PedProOGrupCod = &PedProOGrupCod
	PedProOGrupNom = &PedProOGrupNom
	Exit
When none
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedItmCod = &PedItmCod
		PedProOGrupCod = &PedProOGrupCod
		PedProOGrupNom = &PedProOGrupNom
		PedProOGrupQtd = 1
	EndNEw
EndFor

Commit
]]></Source>
