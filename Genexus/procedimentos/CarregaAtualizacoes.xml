      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&DateTime	= ServerNow()
&DateTime	= &DateTime.AddMonths(-2)
LoadWWpContext.Call(&WWpContext)

for each order (VerCod)
	Where VerDtaLct >= &DateTime
	&sdtGridVersao = new()
	&sdtGridVersao.data = VerDtaLct
	&sdtGridVersao.compilacao = '#' + Trim(VerCmp)
	
	for each
		order (VerItmTip)
		unique VerCod,VerItmTip
		&tipo = new()
		&tipo.Tipo = TipoItemDaVersao.EnumerationDescription(VerItmTip)
		&tipo.itens = RetornaItemDaCompilacao(VerCod,VerItmTip)
		&sdtGridVersao.tipos.Add(&tipo)
	endfor
	
	&sdtGridVersoes.Add(&sdtGridVersao)
	
	if not VerIsLid
		prcAtualizaVersoesLidas(&WWpContext.EmpCod, &WWpContext.PesCod)
	endif
	
when none
	&sdtVersionAPI = new()
	&sdtVersionAPI.Error.Code = 404
	&sdtVersionAPI.Error.Description = 'Nenhuma versão encontrada'
	&sdtVersionAPI.Error.Type = DVMessageType.error
endfor
]]></Source>
