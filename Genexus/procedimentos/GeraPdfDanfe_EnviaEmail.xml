      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	&ModCod = ModCod
	&NfeChv = NfeChv
	
	Exit
EndFor

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtCOnfiguracoesPasta)

&URLFisico = &SdtCOnfiguracoesPasta.PastaNFpdf + &NfeChv.Trim() + '.pdf'
&URLVirtual = &SdtCOnfiguracoesPasta.PastaNFpdfVir + &NfeChv.Trim() + '.pdf'

&File.Source = &URLFisico
If &File.Exists()
	&File.Delete()
EndIf

if &ModCod = '65'
	
//	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon067_ModeloNFCe, &TCon067_ModeloNFCe)
	
//	If &TCon067_ModeloNFCe = 'B'
