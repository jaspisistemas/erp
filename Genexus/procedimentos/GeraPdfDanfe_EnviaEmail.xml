//	Else
		
		RELJAS057_toFile.Call(&EmpCod, &FilCod, &NfeCod, &URLFisico)
//	EndIF

Else
	RELJAS043_ToFile.Call(&EmpCod, &FilCod, &NfeCod, &URLFisico)
EndIF

]]></Source>
