      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&JaExiste = 0
&NovosAdicionados = 0

if &DeletarSelecionados = Status_SimNao.Sim
	
	For Each Order EmpCod, MalTabCod, MalPesCod
		Where EmpCod = &EmpCod
		Where MalTabCod = &MalTabCod
		delete 
	EndFor

	commit
EndIf

//PESSOA
For Each Order EmpCod, PesSts, PesCod	
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod when &PesCod <> 0
	Where PesIsCli = &PesIsCli when &PesIsCli = true
	Where RatCod = &RatCod When &RatCod <> 0
	Where PesSts = Status_AtivoInativo.ATIVO
	Where (PesDtaCad >= &PesDtaCad or (PesUltVenDta >= &iniPesUltVenDta and PesUltVenDta <= &finPesUltVenDta)) when &SomenteNaoCompraram = 'S' //+ Clientes que Compraram no Período:S
	Where (PesUltVenDta >= &iniPesUltVenDta and PesUltVenDta <= &finPesUltVenDta) when &SomenteNaoCompraram = 'C' //Somente Clientes que Compraram no Período:C
	where (PesDtaCad >= &PesDtaCad and (PesUltVenDta.IsEmpty() or PesUltVenDta.IsNull()))  when &SomenteNaoCompraram = 'N'//Somente Clientes que não Compraram:N
	
	Where PesCliTabCod <> &PesCliTabCod when not &PesCliTabCod.IsEmpty()
	Where PesCidUfeCod = &PesCidUfeCod When not &PesCidUfeCod.IsEmpty()
	Where PesCidUfeCod <> &ExcPesCidUfeCod when not &ExcPesCidUfeCod.IsEmpty()
	
	
	//MALA DIRETA
	For Each Order EmpCod, MalTabCod, MalPesCod
		Where EmpCod = &EmpCod
		Where MalTabCod = &MalTabCod
		Where MalPesCod = PesCod
		&JaExiste += 1
		Exit
	When None
		&NovosAdicionados += 1
		new
			EmpCod = &EmpCod
			MalTabCod = &malTabCod
			MalPesCod = PesCod
		EndNew
	EndFor

EndFor

Commit


&Mensagem = trim(str(&NovosAdicionados)) + ' Clientes Novos Adicionados.' + trim(str(&JaExiste)) + ' já estavam Selecionados'
msg(&Mensagem)
]]></Source>
