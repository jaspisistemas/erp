      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&count = 0

For Each Order EmpCod, CImpTbFilCod, CImpLctCod, CImpOriUfeCod, CImpDstUfeCod, CImpGruImpCod, CImpCatCod, (CImpDtaIni)
	Where EmpCod = &EmpCod
	Where CImpTbFilCod = &CImpTbFilCod when not &CImpTbFilCod.IsEmpty()
	Where CImpLctCod = &CImpLctCod when not &CImpLctCod.IsEmpty()
	Where CImpOriUfeCod = &CImpOriUfeCod when not &CImpOriUfeCod.IsEmpty()
	Where CImpDstUfeCod = &CImpDstUfeCod when not &CImpDstUfeCod.IsEmpty()
	Where CImpGruImpCod = &CImpGruImpCod when not &CImpGruImpCod.IsEmpty()
	Where CImpCatCod = &CImpCatCod when not &CImpCatCod.IsEmpty()
	Where CImpDtaIni <= &CImpDtaIni when not &CImpDtaIni.IsEmpty()
	Where CImpCfoCod like &filtroCImpCfoCod when not &filtroCImpCfoCod.IsEmpty()
	Where CImpCstCod = &filtroCImpCstCod when not &filtroCImpCstCod.IsEmpty()
	
	if (&EmpCod = EmpCod and
		&auxCImpTbFilCod = CImpTbFilCod  and
		&auxCImpLctCod = CImpLctCod  and
		&auxCImpOriUfeCod = CImpOriUfeCod  and
		&auxCImpDstUfeCod = CImpDstUfeCod  and
		&auxCImpGruImpCod = CImpGruImpCod  and
		&auxCImpCatCod = CImpCatCod  )
		
	Else
		&count += 1
		
		&auxCImpOriUfeCod = CImpOriUfeCod  
		&auxCImpDstUfeCod = CImpDstUfeCod  
	
		&sdtCadastroTabelaImpostoCbsGridItem = new()
		
		&sdtCadastroTabelaImpostoCbsGridItem.EmpCod = EmpCod
		
		if CImpTbFilCod  <> &auxCImpTbFilCod //Get Filial
			&auxCImpTbFilCod = CImpTbFilCod
			do 'getGrupoFilial'
		Endif
		if CImpLctCod <> &auxCImpLctCod //Tipo lancamento
			&auxCImpLctCod = CImpLctCod
			do 'getTipoLancamento'
		Endif	
		if CImpGruImpCod <> &auxGruImpCod //Grupo Pessoa
			&auxGruImpCod = CImpGruImpCod 
			do 'getGrupoImposto'
		Endif	
		if CImpCatCod <> &auxCImpCatCod //Categoria Produto
			&auxCImpCatCod = CImpCatCod
			do 'getCategoriaProduto'
		Endif

		&sdtCadastroTabelaImpostoCbsGridItem.CImpTbFilCod = CImpTbFilCod 
		&sdtCadastroTabelaImpostoCbsGridItem.CImpTbFilNom = &TbImpFilNom
		&sdtCadastroTabelaImpostoCbsGridItem.CImpLctCod = CImpLctCod 
		&sdtCadastroTabelaImpostoCbsGridItem.CImpLctNom = &LctNom
		&sdtCadastroTabelaImpostoCbsGridItem.CImpOriUfeCod = CImpOriUfeCod 
		&sdtCadastroTabelaImpostoCbsGridItem.CImpDstUfeCod = CImpDstUfeCod 
		&sdtCadastroTabelaImpostoCbsGridItem.CImpGruImpCod = CImpGruImpCod 
		&sdtCadastroTabelaImpostoCbsGridItem.CImpGruImpNom = &GruImpNom
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCatCod = CImpCatCod 
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCatNom = &CatNom
		&sdtCadastroTabelaImpostoCbsGridItem.CImpDtaIni = CImpDtaIni 
		
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCfoCod = CImpCfoCod
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCstCod = CImpCstCod
		&sdtCadastroTabelaImpostoCbsGridItem.CImpObsInf = CImpObsInf	
		&sdtCadastroTabelaImpostoCbsGridItem.CImpDtaAlt = serverNow()
		
		&sdtCadastroTabelaImpostoCbsGridItem.CImpAlqMVA = CImpAlqMVA
		&sdtCadastroTabelaImpostoCbsGridItem.CImpAlqIcmInt = CImpAlqIcmInt
		&sdtCadastroTabelaImpostoCbsGridItem.CImpRedAlqIcmInt = CImpRedAlqIcmInt
		&sdtCadastroTabelaImpostoCbsGridItem.CImpAlqIcmExt = CImpAlqIcmExt
		&sdtCadastroTabelaImpostoCbsGridItem.CImpRedAlqIcmExt = CImpRedAlqIcmExt
		&sdtCadastroTabelaImpostoCbsGridItem.CImpDif = CImpDif			
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCBenef = CImpCBenef
		&sdtCadastroTabelaImpostoCbsGridItem.CImpAlqIcmUFDest = CImpAlqIcmUFDest
		&sdtCadastroTabelaImpostoCbsGridItem.CImpIcmsMotDes = CImpIcmsMotDes
		&sdtCadastroTabelaImpostoCbsGridItem.CImpTaxFecop = CImpTaxFecop
		&sdtCadastroTabelaImpostoCbsGridItem.CImpIcmsRet = CImpIcmsRet			
		&sdtCadastroTabelaImpostoCbsGridItem.CImpAlqIcmStUF = CImpAlqIcmStUF
		
		//INCLUIR E EXCLUIR
		&sdtCadastroTabelaImpostoCbsGridItem.CImpIncIPI = CImpIncIPI
		&sdtCadastroTabelaImpostoCbsGridItem.CImpExcPisCofins = CImpExcPisCofins
		
		//IPI
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCstIpi = CImpCstIpi
		&sdtCadastroTabelaImpostoCbsGridItem.CImpIpi = CImpIpi
		&sdtCadastroTabelaImpostoCbsGridItem.CImpIpiEnq = CImpIpiEnq
		
		//INSS
		&sdtCadastroTabelaImpostoCbsGridItem.CImpAlqInss = CImpAlqInss
		
		//PIS e COFINS
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCstPisCofins = CImpCstPisCofins
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCofins = CImpCofins
		&sdtCadastroTabelaImpostoCbsGridItem.CImpCofinsRed = CImpCofinsRed
		&sdtCadastroTabelaImpostoCbsGridItem.CImpPis = CImpPis
		&sdtCadastroTabelaImpostoCbsGridItem.CImpPisRed = CImpPisRed
				
		&sdtCadastroTabelaImpostoCbsGrid.Add(&sdtCadastroTabelaImpostoCbsGridItem)
		
		if &count = 50
			Exit
		Endif
	Endif
EndFor

Sub 'getGrupoFilial'
	&TbImpFilNom = ''
	For Each ORder EmpCod
		Where EmpCod = &EmpCod
		Where TbImpFilCod = &auxCImpTbFilCod
		&TbImpFilNom = TbImpFilNom
		Exit
	EndFor
EndSub

Sub 'getGrupoImposto'
	&GruImpNom = ''
	For Each Order EmpCod, GruImpCod
		Where EmpCod = &EmpCod
		Where GruImpCod = &auxGruImpCod
		&GruImpNom = GruImpNom		
		Exit
	EndFor

EndSub

Sub 'getTipoLancamento'
	&LctNom = ''
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &auxCImpLctCod
		&LctNom = LctNom
		Exit
	EndFor
EndSub

sub 'getCategoriaProduto'	
	&CatNom = ''
	For Each Order EmpCod, CatCod
		Where EmpCod = &EmpCod
		Where CatCod = &auxCImpCatCod
		&CatNom = CatNom
		Exit
	EndFor
Endsub
]]></Source>
