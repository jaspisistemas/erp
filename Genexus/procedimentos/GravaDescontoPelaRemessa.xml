      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//### Procura um Desconto da Remessa


For each Order EmpCod,DesRetCodEmp
	Where EmpCod = &EmpCod
	Where DesRetCodEmp = &RemRetCodEmp
	&DesCod = DesCod
	&DesSts = DesSts
	Exit
When none
	//############## Cria um Novo Desconto.
	Do 'NovoDesconto'
EndFor


//#### faz retorno ou atualiza
If &DesSts = Status_AbertoFechado.Fechado
	Return
	&Obs_350 = 'Retorno contém duplicata descontada, Porém desconto nro: '+Trim(Str(&DesCod))+' com Status Fechado'
Else
	Do 'GetUltCodItm'
	
	For Each Order EmpCod, DesCod,DesDupItmCod
		Where EmpCod = &EmpCod
		Where DesCreCod = &DesCreCod
		Where DesFilCod = &DesFilCod
		
		// Duplicata já adicionada.
	When none
		new
			EmpCod = &EmpCod
			DesCod = &DesCod
			DesDupItmCod = &DesDupItmCod
			DesCreCod = &DesCreCod
			DesFilCod = &DesFilCod
		EndNew
		Commit
		
		//sts duplicata = descontada
		AlteraStatusDuplicataDescontada.Call(&EmpCod,&DesFilCod ,&DesCreCod, Status_Duplicata.DESCONTADA)
		//grava obs duplicata
		GravaCobranca.call(&EmpCod,&DesFilCod ,&DesCreCod,('DUPLICATA DESCONTADA - Cód. Desc.: ' + &DesCod.ToFormattedString()) ,0,0, ServerDate(), '00:00:00', TipoObservacaoDuplicata.INTERNA)
		
	EndFor
	commit
EndIf


Sub 'GetUltCodItm'
	&DesDupItmCod = 0
	For each order EmpCod, DesCod, (DesDupItmCod)
		where EmpCod = &EmpCod
		where DesCod = &DesCod
		&DesDupItmCod = DesDupItmCod
		exit
	EndFor
	&DesDupItmCod += 1
EndSub


Sub 'NovoDesconto'
	UltimoCodigoEmpresa.Call(domParCod.DESCONTO, &EmpCod, 0, &NewDesCod)
	
	New
		EmpCod = &EmpCod
		DesCod = &NewDesCod
		DesDta = &DtaOco
		DesTip = 'D' //duplicata	
		DesSts = Status_AbertoFechado.Aberto
		DesRetCodEmp = &RemRetCodEmp
	EndNew
	Commit
	
	
	new
		EmpCod = &EmpCod
		DesCod = &NewDesCod
		DesDupItmCod = 1
		DesCreCod = &DesCreCod
		DesFilCod = &DesFilCod
	EndNew
	Commit
	
	AlteraStatusDuplicataDescontada.Call(&EmpCod,&DesFilCod ,&DesCreCod, Status_Duplicata.DESCONTADA)
	//grava obs duplicata
	GravaCobranca.call(&EmpCod,&DesFilCod ,&DesCreCod,('DUPLICATA DESCONTADA - Cód. Desc.: ' + &DesCod.ToFormattedString()) ,0,0, ServerDate(), '00:00:00', TipoObservacaoDuplicata.INTERNA)
	commit
	
EndSub
]]></Source>
