      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsTem = false
&FPagCod = 0
For EAch Order EmpCod, FPagCod
	Where EmpCod = &EmpCod
	Where FPagPesCod = &FPagPesCod
	WHere FPagMes = &FPagMes
	Where FPagAno = &FPagAno 
	Where FPagTip = TipoPagamentoFolha.FolhaMensal
	
	&FPagCod = FPagCod
	&IsTem = true
	
	Exit
EndFor
]]></Source>
