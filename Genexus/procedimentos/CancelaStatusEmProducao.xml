      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, OrdCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdCod = &OrdCod

	OrdSts = Status_Producao.Cancelada
	
	AtualizaEstoqueGerencialVenda_submit.Call('AtualizaEstoqueGerencialVenda_submit',&EmpCod, &FilCod, OrdSaiPedCod, &PedDtaFat, &PesCod, Status_Pedido.ABERTO, false)
	AtualizaEstoqueGerencialVenda_submit.Call('AtualizaEstoqueGerencialVenda_submit',&EmpCod, &FilCod, OrdSaiPedCod, &PedDtaFat, &PesCod, Status_Pedido.CANCELADO, false)
	
	AtualizaEstoqueGerencialVenda_submit.Call('AtualizaEstoqueGerencialVenda_submit',&EmpCod, &FilCod, OrdEntPedCod, &PedDtaFat, &PesCod, Status_Pedido.ABERTO, false)
	AtualizaEstoqueGerencialVenda_submit.Call('AtualizaEstoqueGerencialVenda_submit',&EmpCod, &FilCod, OrdEntPedCod, &PedDtaFat, &PesCod, Status_Pedido.CANCELADO, false)
	
	Exit
EndFor

commit 


For Each Order EmpCod, FilCod, PedCod //add novamente os pedidos
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedStsPrd = Status_Producao.NaFila
	PedStsPrd = Status_Producao.Aguardando
EndFor

Commit
	
For Each Order EmpCod, FilCod, OrdCod, OrdPedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdCod = &OrdCod
	
	AtualizaStatusProducaoPedido.Call(EmpCod, FilCod, OrdPedCod, Status_Producao.NaFila, &VaziaData, &PedDtaHorSelPrd)
	CriticasPedido.Call(EmpCod, FilCod, OrdPedCod, TipoCriticaPedido.CanceladoProducao, &PesCod)
EndFor

Commit

prcSelecionaPedidosProducao.Call(&EmpCod, &FilCod, 0, '', &OrdCod)
]]></Source>
