      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&SdtPedidos.Clear()

For Each order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	where PedDtaEms.year()  = &AnoEmissao
	where PedDtaEms.Month() = &MesEmissao
	where PedDtaEms.Day()   = &DiaEmissao when not &DiaEmissao.IsEmpty()
	where PedSerItmCod > 0
	Where PedSts = Status_Pedido.FECHADO
	Where PedStsFin = Status_Financeiro.FECHADO
	Where PedCliRaz like &PesRaz or PedCliFan like &PesRaz when not &PesRaz.IsEmpty()
	
	&SdtPedidosItem = new()
	&SdtPedidosItem.isMarcar = false
	&SdtPedidosItem.EmPCod = EmpCod
	&SdtPedidosItem.FiLCod = FilCod
	&SdtPedidosItem.PedCod = PedCod
	&SdtPedidosItem.PedDtaEms = PedDtaEms
	&SdtPedidosItem.PedCliCod = PedCliCod
	&SdtPedidosItem.PedCliCodRaz = PedCliCodRaz
	&SdtPedidosItem.PedVlrLiq = PedVlrLiq
	
	&NfeCod.SetEmpty()
	&NfeNum.SetEmpty()
	&NfeSts.SetEmpty()
	
	&NfsCod.SetEmpty()
	&NfsNum.SetEmpty()
	&NfsSts.SetEmpty()

	//pega nota de servico
	&NfsPedCod = PedCod
	&NfsPedFilCod = FilCod
	do 'getNFSe'
	
	//pega nota de prodt
	&NfePedCod = PedCod
	&NfeFilCod = FilCod
	do 'getNFe'
	
	&SdtPedidosItem.NfeCod = &NfeCod
	&SdtPedidosItem.NfeNum = &NfeNum
	&SdtPedidosItem.NfeSts = &NfeSts
	
	
	&SdtPedidosItem.NfsCod = &NfsCod
	&SdtPedidosItem.NfsNum = &NfsNum
	&SdtPedidosItem.NfsSts = &NfsSts
	
	//localiza Duplicata
	For Each ORder EmpCod, FilCod, CreCod
		Where CrePedCod = PedCod
		Where CreSts <> Status_Duplicata.CANCELADA
//		Where CreVlrDup = CreVlrSdo //JDF TEM QUE PEGAR A DUP.
		
		&SdtPedidosItem.CreCod = CreCod
		&SdtPedidosItem.CreDupNro = CreDupNro
		&SdtPedidosItem.CreDtaRet = CreDtaRet
		&SdtPedidosItem.CreSts = CreSts
		Exit
	EndFor
	&PedCliCod = PedCliCod
	do 'getEmailFone'
	
	&SdtPedidosItem.IsJaEnviou = false
	For Each Order EmpCod, EmlTip, EmlFilCod, EmlSeqCod
		Where EmlTip = TipoContaEmail.Email_Financeiro
		Where EmlTipEml = TipoSolicitacao.Envia_Mensalidade
		Where EmlFilCod = FilCod
		Where EmlSeqCod = PedCod
		&SdtPedidosItem.IsJaEnviou = true
		Exit
	When none
		For Each ORder EmpCod, WaPedCod
			Where WaPedCod = PedCod
			&SdtPedidosItem.IsJaEnviou = true
			Exit
		EndFor
	EndFor

	if &IsNotaAutorizada = false or ((&NfsCod > 0 and &NfsSts = Status_NFe.Autorizada) or (&NfeCod > 0 and &NfeSts = Status_NFe.Autorizada)) 
		if &IsBoletoRegistrado = false or (not &SdtPedidosItem.CreDtaRet.IsEmpty())
			
			if &IsNaoEnviados = false or (&SdtPedidosItem.IsJaEnviou = false)
				&SdtPedidos.Add(&SdtPedidosItem)
			EndIf
		Endif
	Endif

EndFor

Sub 'getEmailFone'
	//localiza primeiro email financeiro
	For Each Order EmpCod, PesCod, PesEmlCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		Where PesEmlFin = true
		
		&SdtPedidosItem.PesPrmEml = PesEml
		Exit
	EndFor
	
	//localiza Primeiro Fone Financeiro
	For Each Order EmpCod, PesCod, PesFonCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		Where PesFonWhatsBol = true
		
		&SdtPedidosItem.PesPrmFon = PesFonNum
		Exit
	EndFor
EndSub


Sub 'getNFe'
	For Each ORder EmpCod, NfeFilCod, NfePedCod, (NfeCod)
		Where EmpCod = &EmpCod
		Where NfePedCod = &NfePedCod
		Where NfeFilCod = &NfeFilCod
		Where NfeSts = Status_Nfe.Autorizada or NfeSts = Status_Nfe.Digitando
		
		&NfeCod = NfeCod
		&NfeNum = NfeNum
		&NfeSts = NfeSts		
		if NfeSts = Status_Nfe.Autorizada
			Exit
		Endif
		
	EndFor
EndSub

Sub 'getNFSe'
	For Each ORder EmpCod, NfsPedFilCod, NfsPedCod, (NfsCod)
		Where EmpCod = &EmpCod
		Where NfsPedCod = &NfsPedCod
		Where NfsPedFilCod = &NfsPedFilCod
		Where NfsSts = Status_Nfe.Autorizada or NfsSts = Status_Nfe.Digitando
		
		&NfsCod = NfsCod
		&NfsNum = NfsNum
		&NfsSts = NfsSts
		if NfsSts = Status_Nfe.Autorizada
			Exit
		Endif
		
	EndFor
EndSub

]]></Source>
