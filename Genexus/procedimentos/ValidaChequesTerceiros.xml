      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

RetornaSoNumeros.Call(&CheCon, &AuxCheCon)										
&CheBanAgeCon = trim(&CheBanCod) +'/'+ trim(str(&CheAgeCod)) + '/'+ trim(&AuxCheCon) +'/'+ trim(str(&CheNro))

&ErroMensagem.SetEmpty()
&AlertaMensagem.SetEmpty()
For Each Order EmpCod, CheNro
	Where EmpCod = &EmpCod
	Where (CheBanCod = &CheBanCod and CheAgeCod = &CheAgeCod and CheCon = &CheCon) or (CheBanAgeCon = &CheBanAgeCon)
	Where CheMot <> MotivoCheque.CANCELADO
	Where CheCod <> &CheCod
	
	if CheBanAgeCon.IsEmpty() or CheBanAgeCon.IsNull()
		RetornaSoNumeros.Call(CheCon, &AuxCheCon)
		CheBanAgeCon = trim(CheBanCod) +'/'+ trim(str(CheAgeCod)) + '/'+ trim(&AuxCheCon) +'/'+ trim(str(CheNro))
	EndIf

	if CheNro = &CheNro
		&ErroMensagem = 'ERRO: O cheque informado já encontra-se lançado Sequência: '+trim(str(CheCod)) + ' Motivo: ' + CheMot.EnumerationDescription()
		Exit
	Endif
EndFor

Commit

RetornaSoNumeros.Call(&CheCon, &AuxCheCon)		
&CheBanAgeCon = trim(&CheBanCod) +'/'+ trim(str(&CheAgeCod)) + '/'+ trim(&AuxCheCon) + '/'
For Each Order EmpCod, CheNro
	Where EmpCod = &EmpCod
	Where EmpCod = &EmpCod
	Where CheMot = MotivoCheque.MOTIVO11 or CheMot = MotivoCheque.MOTIVO12
	Where (CheBanCod = &CheBanCod and CheAgeCod = &CheAgeCod and CheCon = &CheCon) or CheBanAgeCon like &CheBanAgeCon
	Where CheMot <> MotivoCheque.CANCELADO
	
	&AlertaMensagem = 'Atenção: Conta do Cheque já possuí Movitos de Devolução:' + trim(str(CheNro))
	Exit
EndFor

Commit
]]></Source>
