<Object parentGuid="69276173-76cd-45fd-9f52-1af9cde0578d" user="" versionDate="2022-06-28T23:50:51.0000000Z" lastUpdate="2020-08-28T13:16:16.0000000Z" checksum="71432b0b6a995cbddf448a5c3e7d0c0b" fullyQualifiedName="prcMontaGrade" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="50531f9b-acfa-4fee-84cc-7a797a936343" name="prcMontaGrade" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Monta Grade" parent="ProPrc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&MdpCodUm.SetEmpty()
&MdpCodCinco.SetEmpty()
&MdpCodQuatro.SetEmpty()
&MdpCodTres.SetEmpty()
&MdpCodDois.SetEmpty()

&Count = 1

For &sdtModalidadesItem in &sdtModalidades
	
	Do Case
		Case &MdpCodUm.IsEmpty()
			&MdpCodUm = &sdtModalidadesItem.MdpCod
		Case &MdpCodDois.IsEmpty()
			&MdpCodDois = &sdtModalidadesItem.MdpCod
		Case &MdpCodTres.IsEmpty()
			&MdpCodTres = &sdtModalidadesItem.MdpCod
		Case &MdpCodQuatro.IsEmpty()
			&MdpCodQuatro = &sdtModalidadesItem.MdpCod
		Case &MdpCodCinco.IsEmpty()
			&MdpCodCinco = &sdtModalidadesItem.MdpCod
	EndCase

EndFor 

//ADD AO NEW SDT
For Each Order EmpCod, MdpCod, MdpItmCod
	Where EmpCod = &EmpCod
	Where MdpCod = &MdpCodUm
	Where MdpItmSts <> Status_AtivoInativo.INATIVO
	
	&MdpCodNom = MdpItmNom.Trim()
	
	if MdpItmOrd > 0
		&MdpItmCod = MdpItmOrd
	Else
		&MdpItmCod = MdpItmCod+1
		MdpItmOrd = MdpItmCod+1
	Endif
	
	if not &MdpCodDois.IsEmpty()
		do 'GetDois'
	Else
		&AddMdpCodNom = &MdpCodNom.Trim()
		do 'AddNewSdtModalidades'
	EndIf
EndFor

for Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	ProMdpCod = &MdpCod
	&ProRef = ProRef
	Exit
EndFor

Commit

For &NewsdtModalidadesItem in &NewsdtModalidades
	&ProGraBar =  '3' + padR(trim(str(&ProCod)), 8, '0') + padL(trim(str(&NewsdtModalidadesItem.MdpCod)), 3, '0')
	digitoEAN13.Call(&ProGraBar, &ProGraBar)
	ValidaCodigoReferenciaRepetido.Call(&EmpCod, &ProCod, &NewsdtModalidadesItem.MdpCod, &ProGraBar, &RepetidoEanMensagem)
	do While Not &RepetidoEanMensagem.IsEmpty()
		&Codigo8 = Random() * 1000
		&ProGraBar =  '3'+padR(trim(str(&ProCod)), 8, '0') + padL(trim(str(&Codigo8)), 3, '0')
		digitoEAN13.Call(&ProGraBar, &ProGraBar)
		ValidaCodigoReferenciaRepetido.Call(&EmpCod, &ProCod, &NewsdtModalidadesItem.MdpCod, &ProGraBar, &RepetidoEanMensagem)
	EndDo

	&ProGraRef = trim(&ProRef) + PadL(trim(str(&NewsdtModalidadesItem.MdpCod)), 3, '0')
	ValidaCodigoReferenciaRepetido.Call(&EmpCod, &ProCod,  &NewsdtModalidadesItem.MdpCod, &ProGraRef, &RepetidoReferenciaMensagem) 
	Do while not &RepetidoReferenciaMensagem.IsEmpty()
		&Codigo8 = Random() * 1000
		&ProGraRef = trim(&ProRef) + PadL(trim(str(&Codigo8)), 4, '0')
		&ProGraRef = trim(substr(&ProGraRef, 1, 18))
		ValidaCodigoReferenciaRepetido.Call(&EmpCod, &ProCod,  &NewsdtModalidadesItem.MdpCod, &ProGraRef, &RepetidoReferenciaMensagem) 
	EndDo

	
	New
		EmpCod = &EmpCod
		ProCod = &ProCod
		ProGraCod = &NewsdtModalidadesItem.MdpCod
		ProGraBar = &ProGraBar
		ProGraRef = &ProGraRef
		ProGraRefPadL = padL(&ProGraRef, 18, '0')
		ProGraNom = &NewsdtModalidadesItem.MdpCodNom
		ProGraSts = Status_AtivoInativo.ATIVO
	EndNEw

	commit
	
	GravaCodigoProdutoRefBarras.Call(&EmpCod, &ProCod, &NewsdtModalidadesItem.MdpCod, &ProGraRef, 'R') //REFERENCIA
	GravaCodigoProdutoRefBarras.Call(&EmpCod, &ProCod, &NewsdtModalidadesItem.MdpCod, &ProGraBar, 'B') //BARRAS
EndFor

if &NewsdtModalidades.Count > 0
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		ProIsGra = true
		Exit
	EndFor

	Commit
EndIF



Sub 'GetDois'
	For Each Order EmpCod, MdpCod, MdpItmCod
		Where EmpCod = &EmpCod
		Where MdpCod = &MdpCodDois
		Where MdpItmSts <> Status_AtivoInativo.INATIVO
		
		&DoisMdpCodNom = &MdpCodNom.Trim() + ' ' + trim(MdpItmNom)
		
		if not &MdpCodTres.IsEmpty()
			do 'GetTres'
		Else
			&AddMdpCodNom = &DoisMdpCodNom.Trim()
			do 'AddNewSdtModalidades'
		EndIf
	EndFor
EndSub


Sub 'GetTres'
	For Each Order EmpCod, MdpCod, MdpItmCod
		Where EmpCod = &EmpCod
		Where MdpCod = &MdpCodTres
		Where MdpItmSts <> Status_AtivoInativo.INATIVO
		
		&TresMdpCodNom = &DoisMdpCodNom.Trim() + ' ' + trim(MdpItmNom)
		
		if not &MdpCodQuatro.IsEmpty()
			do 'GetQuatro'
		Else
			&AddMdpCodNom = &TresMdpCodNom.Trim()
			do 'AddNewSdtModalidades'
		EndIf
	EndFor
EndSub


Sub 'GetQuatro'
	For Each Order EmpCod, MdpCod, MdpItmCod
		Where EmpCod = &EmpCod
		Where MdpCod = &MdpCodQuatro
		Where MdpItmSts <> Status_AtivoInativo.INATIVO
		
		&QuatroMdpCodNom = &TresMdpCodNom.Trim() + ' ' + trim(MdpItmNom)
		
		if not &MdpCodCinco.IsEmpty()
			do 'GetCinco'
		Else
			&AddMdpCodNom = &QuatroMdpCodNom
			do 'AddNewSdtModalidades'
		EndIf
	EndFor
EndSub

Sub 'GetCinco'
	For Each Order EmpCod, MdpCod, MdpItmCod
		Where EmpCod = &EmpCod
		Where MdpCod = &MdpCodCinco
		Where MdpItmSts <> Status_AtivoInativo.INATIVO
		
		&CinCoMdpCodNom = &QuatroMdpCodNom.Trim() + ' ' + trim(MdpItmNom)
		
		&AddMdpCodNom = &CinCoMdpCodNom.Trim()
		do 'AddNewSdtModalidades'
	EndFor
EndSub

sub 'AddNewSdtModalidades'
	if &MdpCod.IsEmpty()
		&Count += 1
	Else
		&Count = &MdpItmCod
	Endif

	&NewsdtModalidadesItem = new()
	&NewsdtModalidadesItem.MdpCod = &Count
	&NewsdtModalidadesItem.MdpCodNom = &AddMdpCodNom
	&NewsdtModalidades.add(&NewsdtModalidadesItem)
EndSub
]]></Source>
