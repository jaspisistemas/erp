      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	&IsSucesso = false
	//getcodeacesso
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		&EmpCodSec = EmpCodSec
		Exit
	EndFor	
	
	//get url
	For Each Order EmpCod
		if &PdvCod > 0
			&EmpDirVirPdv = EmpDirVirPdv
		else
			&EmpDirVirPdv = EmpDirVirMon
		Endif
	
		Exit
	EndFor
	
	if &EmpDirVirPdv.IsEmpty()
		if &PdvCod > 0
			&Mensagem = 'Diretório virtual do PDV não configurado!'
		else
			&Mensagem = 'Diretório virtual do Monitor não configurado!'
		Endif
	
		Return
	Endif

	if &PdvCod > 0
		For Each Order EmpCod, PdvCod 
			Where EmpCod = &EmpCod
			Where PdvCod = &PdvCod
			
			&GUID = GUID.NewGuid()
			//PdvRandon = &GUID.ToString() //esse é random comunicacao
			&pdvValidacao = &GUID.ToString() //esse é o random instalacao
			PdvValidacao = &pdvValidacao
			
			&GUID = GUID.NewGuid()
			&PdvRandon = &GUID.ToString() //esse é o random instalacao
			PdvRandon = &PdvRandon
			
			&MonTip= MonTip
			
			PdvStsSync = Status_pdv.PENDENTE
			
			Exit
		EndFor
	Else
		For Each Order EmpCod, MonCod 
			Where EmpCod = &EmpCod
			Where MonCod = &MonCod
			
			&GUID = GUID.NewGuid()
			//PdvRandon = &GUID.ToString() //esse é random comunicacao
			&pdvValidacao = &GUID.ToString() //esse é o random instalacao
			MonValidacao = &pdvValidacao
			
			&GUID = GUID.NewGuid()
			&PdvRandon = &GUID.ToString() //esse é o random instalacao
			MonRandon = &PdvRandon
			
			&MonTip= MonTip
			If MonTip = TipoApp.BI //Utilizado por planilhas em excel.
				MonSts = Status_pdv.INSTALADO
				&pdvValidacao = &PdvRandon
			Else
				MonSts = Status_pdv.PENDENTE
			Endif
		
			Exit
		EndFor
	EndIf

	if &MonTip <> TipoApp.BI
		//chama sincronizador
		&LongVarchar = '{'
		&LongVarchar += '"OqueFazer": "ADD", '
		
	  	&LongVarchar += '"CnxTip": "PDV", '
	  	&LongVarchar += '"CnxGuid": "'+trim(&pdvValidacao)+'", '
		&LongVarchar += '"CnxUrl": "'+trim(&EmpDirVirPdv)+'", '
		&LongVarchar += '"CnxEmpCodSec": "'+trim(&EmpCodSec)+'" '
		
		&LongVarchar += '}'
		
		&HttpClient.AddString(&LongVarchar)
		&HttpClient.Execute('POST', 'https://adm.jaspi.com.br/erpterminais/gravaterminal')
		
		If &HttpClient.StatusCode = 200
			&sdtConfiguracaoTerminal.FromJson(&HttpClient.ToString())
			
			if &sdtConfiguracaoTerminal.Sts = 'J200'
				Commit
				&IsSucesso = true			
				&Mensagem = &pdvValidacao
			Else
				
				&Mensagem = &sdtConfiguracaoTerminal.Msg
			Endif
		Else
			&Mensagem = &HttpClient.ErrDescription
		Endif	
	Else
		&IsSucesso = true			
		&Mensagem = &pdvValidacao
		Commit
	EndIf
]]></Source>
