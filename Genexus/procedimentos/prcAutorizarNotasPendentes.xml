      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
InicializaAgendador.Call(&EmpCod, TipoAgendamento.AutorizarValorXNotas, 0, &AgdCod)
For Each Order EmpCod, AgdCod
	Where EmpCod = &EmpCod
	Where AgdCod = &AgdCod
	
	&AgdSts = AgdSts
	&AgdTip = AgdTip
	
	&AgdUltDtaHora = AgdUltDtaHora
	&AgdExeFilCod = AgdExeFilCod
	
	Exit
EndFor

&sdtAgendadorFiltros.FromXml(&AgdFiltro)
For &sdtAgendadorFiltrosItem in &sdtAgendadorFiltros
	//--NOTAS PROPRIAS
	Do Case
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'AUTNOTPERCE'
			&Percentual = val(&sdtAgendadorFiltrosItem.AgdValue)
			&Percentual = &Percentual
			&PercentualFaturar = 100 - &Percentual
			&PercentualFaturar = &PercentualFaturar * 0.01
			
		Case &sdtAgendadorFiltrosItem.AgdFiltro = 'XMLCPFAUTORIZAR'
			&sdtAgendadorCPF.FromJson(&sdtAgendadorFiltrosItem.AgdValue)
	EndCase
EndFor


&Hoje = serverdate() //JDF comentei por hora
//if (&Hoje - &AgdUltDta) > 1
//	msg('EXECUTAR AJUSTE NOTAS', nowait)
//Else
//	msg('JA EXECUTOU UMA VEZ HOJE', nowait)
//	return	
//Endif

&DataFinal = eoM(&Hoje)
&Mes = Month(&DataFinal)
&Ano = Year(&DataFinal)
&dataInicial = yMDtoD(&Ano, &Mes, 1)

//retorna Total Faturado em Pedido
TotalFaturadoPeriodoVendas.call(&EmpCod, &dataInicial, &DataFinal, &TotalFaturadoMoeda)

//REtorna Total Faturado em Notas.
TotalFaturadoNotasVendas.call(&EmpCod, &dataInicial, &DataFinal, &TotalNotasMoeda)


//calcula quanto deveria ter em notas.
&TotalDeveriaFaturarMoeda = &TotalFaturadoMoeda * &PercentualFaturar

&mensagem = format('TOTAL PEDIDO: %1, TOTAL NOTA: %2, DEVERIA FATURAR: %3, %4%', trim(toformattedString(&TotalFaturadoMoeda)), trim(toformattedString(&TotalNotasMoeda)), trim(toformattedString(&TotalDeveriaFaturarMoeda)), trim(toformattedString(&PercentualFaturar)))
msg(&mensagem, nowait)

//manda autorizar notas pendentes sem numero de nfe
&DiferencaMoeda = &TotalDeveriaFaturarMoeda - &TotalNotasMoeda

&mensagem = format('PRECISA FATURAR MAIS: %1', trim(toformattedString(&DiferencaMoeda)))
msg(&mensagem, nowait)

//&dorme = sleep(2)
RetornaConfSistema.Call(&EmpCod, 1, DomConfSistema.TCon020_ClientePadraoVista, &TCon020_ClientePadraoVista )
&VistaPesCod = val(&TCon020_ClientePadraoVista)

For &sdtAgendadorCPFItem in &sdtAgendadorCPF
	if &sdtAgendadorCPFItem.PesUltEms.Month() <> &Hoje.Month()
		&sdtAgendadorCPFItem.PesVlrTotEm = 0
	Endif
EndFor

if &DiferencaMoeda > 0
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where NfeNum.IsEmpty() or NfeNum.IsNull()
		Where NfeVlrTot > 0
		Where NfeEntSai = Status_EntradaSaida.Saida
		Where ModCod = '65' //SOMENTE CONSUMIDOR
		Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
		Where NfeSts = Status_Nfe.Digitando
		Where NfeCliCnpj <> FilCpj
		
		if &EmitNfeCod > 0 //FIZ ISSO POIS POR CAUSA DO COMMIT DENTRO DO FOR PARA SALVAR O CPF, NAO IA O CPF NO XML
			GeraXmlNFeModelo65_4.Call(&EmitEmpCod, &EmitFilCod, &EmitNfeCod, 'S', 1, 'E', &SolCod)	
		EndIf
		
		if &DiferencaMoeda > NfeVlrTot
			if (&Hoje - NfeDtaEms) >= 1				
				if NfeCliCpf.IsEmpty() or NfeCliCpf.IsNull()
					For &sdtAgendadorCPFItem in &sdtAgendadorCPF
						if &sdtAgendadorCPFItem.PesVlrTotEm < &sdtAgendadorCPFItem.PesVlrTot
							
							NfeCliCod = &VistaPesCod
							NfeCliCpf = &sdtAgendadorCPFItem.PesCpf
							NfeCliRaz = 'CONSUMIDOR FINAL'
							//NfeCliRaz = &sdtAgendadorCPFItem.PesRaz
							NfeCliTipPes = TipoPessoa.FISICA
							
							&NfeNum = UltimoCodigoEmpresa.Udp(domParCod.NOTA65NUM, EmpCod,  FilCod)
							&Serie = RetornaSerieNF.UDP(domParCod.NOTAFISCAL65_SERIE, EmpCod, FilCod)
							&NfeSer = trim(str(&Serie))
							NfeNum = &NfeNum
							NfeSer = &NfeSer
														
							NfeDtaEms = &Hoje
							NfeDtaFat_Ano = &Hoje.Year()
							NfeDtaFat_Mes = &Hoje.Month()
							
							Commit
							
							&sdtAgendadorCPFItem.PesVlrTotEm += NfeVlrTot
							&sdtAgendadorCPFItem.PesUltEms = &Hoje
							Exit
						Endif
					EndFor
					
					&sdtAgendadorCPF.Sort("PesVlrTotEm")
				Endif
				
				&DiferencaMoeda -= NfeVlrTot
				
				&mensagem = 'AUTORIZAR NF COD: ' +trim(str(NfeCod)) + 'VALOR: ' + trim(toformattedString(NfeVlrTot))
				msg(&mensagem, nowait)
				
				&EmitEmpCod = EmpCod
				&EmitFilCod = FilCod
				&EmitNfeCod = NfeCod
				
			Endif
			
			if &DiferencaMoeda <= 0
				Exit
			Endif
		Endif
		
	Endfor

	if &EmitNfeCod > 0 //FIZ ISSO POIS POR CAUSA DO COMMIT DENTRO DO FOR PARA SALVAR O CPF, NAO IA O CPF NO XML
		GeraXmlNFeModelo65_4.Call(&EmitEmpCod, &EmitFilCod, &EmitNfeCod, 'S', 1, 'E', &SolCod)	
	EndIf

ENdif

&sdtAgendadorFiltros.Clear()

&sdtAgendadorFiltrosItem = new()
&sdtAgendadorFiltrosItem.AgdFiltro = 'AUTNOTPERCE'
&sdtAgendadorFiltrosItem.AgdValue = trim(str(&Percentual))
&sdtAgendadorFiltros.Add(&sdtAgendadorFiltrosItem)

&sdtAgendadorFiltrosItem = new()
&sdtAgendadorFiltrosItem.AgdFiltro = 'XMLCPFAUTORIZAR'
&sdtAgendadorFiltrosItem.AgdValue = &sdtAgendadorCPF.ToJson()
&sdtAgendadorFiltros.Add(&sdtAgendadorFiltrosItem)

&outAgdFiltro = &sdtAgendadorFiltros.ToXml()
//GravaTarefa.Call(&EmpCod, &AgdCod, &AgdSts, &AgdTip, &AgdExeFilCod, )
&IsExecutou = true
]]></Source>
