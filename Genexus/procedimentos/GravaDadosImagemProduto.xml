      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Grava Dados Imagem
For Each Order EmpCod, ProCod, ProImgCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProImgCod = &ProImgCod
	ProImgNom = &ProImgNom
	ProImgTip = &ProImgTip
	
	ProImgPri = &ProImgPri
	ProImgNomFis = &ProImgNomFis
	ProImg180 = &ProImg
	
	ProImg325 = &ProImg325
	ProImg1024 = &ProImg1024
	ProImgOriginal = &ProImgOriginal
	ProImgDtaUltMod = now()
	Exit
When none
	New
		EmpCod = &EmpCod
		ProCod = &ProCod
		ProImgCod = &ProImgCod
		ProImgNom = &ProImgNom
		ProImgTip = &ProImgTip
		
		ProImgPri = &ProImgPri
		ProImgNomFis = &ProImgNomFis
		ProImg180 = &ProImg
		
		ProImg325 = &ProImg325
		ProImg1024 = &ProImg1024
		ProImgOriginal = &ProImgOriginal
		ProImgDtaUltMod = now()
	EndNew
EndFor

Commit

ProdutoImagemPrincipal.Call(&EmpCod, &ProCod, &ProImgCod, &ProImgPri, &ProImgTip)
]]></Source>
