      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//parm(in:&EmpCod, in:&NfsCNAE, in:&NfsCnaeSer, in:&AliquotaISS);

For Each Order EmpCod, CnaeCod
	Where EmpCod = &EmpCod
	Where CnaeCod = &NfsCNAE
	Exit
when none
	new
		EmpCod = &EmpCod
		CnaeCod = &NfsCNAE
		CnaeDesc = &NfsCNAE.Trim()
		CnaeSts = Status_AtivoInativo.ATIVO
	EndNew

	Commit
EndFor

For Each Order EmpCod, CnaeCod, CnaeItmCod
	Where EmpCod = &EmpCod
	Where CnaeCod = &NfsCNAE
	Where CnaeFilCod = &CnaeFiLCod
	Where CnaeItmCod = &NfsCnaeSer
	Exit
When none
	&NcmCod = val(&NfsCnaeSer)
	For Each ORder NcmCod
		Where NcmCod = &NcmCod
		&NcmObs = NcmObs
		Exit
	EndFor

	NEw
		EmpCod = &EmpCod
		CnaeCod = &NfsCNAE
		CnaeFilCod = &CnaeFiLCod
		CnaeItmCod = &NfsCnaeSer
		CnaeItmDesc = &NcmObs
		CnaeItmSts = Status_AtivoInativo.ATIVO
		CnaeItmTax = &AliquotaISS
	EndNew

	commit
EndFor
]]></Source>
