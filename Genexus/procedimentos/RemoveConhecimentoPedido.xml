      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVAR LOG
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'FRETENOTAS')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVO	
	prcCarregaLog_FreteNotas.Call(&EmpCod, &FilCod, &FrtCod, &SdtLogAtributosLevel)
Endif

&AuxNfeEntSai.FromString(&NfeEntSai)

If &FrtPedCod = 0 //NAO TEM O NUMERO DO PEDIDO
    For Each Order EmpCod, FilCod, NfeEntSai, NfeCod
    Where EmpCod = &EmpCod
	Where FilCod = &FrtNfeFilCod
	Where NfeCod = &FrtNfeCod
	Where NfeEntSai = &AuxNfeEntSai
	
		&PedidoFilCod = NfeFilCod
		&PedidoPedCod = NfePedCod
        exit
    EndFor
Else
    &PedidoFilCod = &FrtPedFiLCod
	&PedidoPedCod = &FrtPedCod
EndIF    


If &PedidoPedCod <> 0
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &PedidoFilCod
		Where PedCod = &PedidoPedCod
		PedCnhFrt.SetEmpty()
		PedCnhVlr = 0
		PedCnhEms.SetEmpty()
		PedCnhTraCod.SetEmpty()
		Exit
	ENdFor

	Commit
EndIF


For Each Order EmpCod, FilCod, FrtCod, FrtItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where FrtCod = &FrtCod
	Where FrtItmCod = &FrtItmCod
	Delete
	Exit
EndFor

Commit

if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVO	
	prcGravaLog_FreteNotas.Call(&EmpCod, &FilCod, &FrtCod, &Pgmname, &WwpContextUserName, &SdtLogAtributosLevel)
Endif

RateiaFreteItens.Call(&EmpCod, &FilCod, &FrtCod)
]]></Source>
