      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem = ''
&PedCod = 0
&FicCod = 0
For Each Order EmpCod, FicBar
	Where EmpCod = &EmpCod
	Where FicBar = &FicBar
	&FicCod = FicCod
	&FicPedCod = FicPedCod
	Exit
When none
	&Mensagem = 'Ficha não Localizada!'
EndFor

if &Mensagem.IsEmpty() and &FicPedCod <> 0
	For Each Order EmpCod, FilCod, PedCod, PedSts, PedFicCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &FicPedCod
		Where PedFicCod = &FicCod
		Where PedSts = Status_Pedido.ABERTO
		&PedCod = PedCod
		&IsLimite = False
//		If PedVlrLmt > 0 
//			If PedVlrLiq >= PedVlrLmt
//				&IsLimite = True
//				&Mensagem = 'ATENÇÃO! Limite de crédito atingido. Dirija-se ao caixa para fazer acerto.'
//			EndIf
//		EndIf
//comentado coloquei o limite na hr de add o produto
		Exit
	When none
		&PedCod = 0
	EndFor
	
EndIF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
