      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedVlrItm = 0
&Mensagem = ''

if &PedItmCod > 0
	For Each Order EmpCod, FilCod, PedCod, ProCod, ProGraCod, PedItmCodRef
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedItmCodRef = &PedItmCod and PedItmCodRef <> PedItmCod and not PedItmCodRef.IsEmpty() and not PedItmCodRef.IsNull()
		Where PedQtd > 0
		Where PedItmProdComp = 'C' //COMPLEMENTO
		
		if &AuxProGraRef <> ProGraRef and not &AuxProGraRef.IsEmpty()
			do 'AdicionaObs'
		Endif
		
		&ProNom = iif(ProDet.IsEmpty() or ProDet.IsNull(), ProNom, ProDet)
		&AuxProGraRef = ProGraRef
		&PedQtd += PedQtd
		&PedVlrItm += PedVlrItm
	EndFor
	
	if &PedQtd > 0
		do 'AdicionaObs'
	Endif
Endif


sub 'AdicionaObs'
	&Mensagem = &Mensagem.Trim()
	&Mensagem += ' ('+trim(Str(&PedQtd))+') ' + trim(&ProNom)
	&PedQtd = 0
	&ProNom = ''
EndSub
]]></Source>
