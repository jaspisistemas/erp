      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&RepetidoEanMensagem = ''

For Each Order EmpCod, FicBar
	Where EmpCod = &EmpCod
	Where FicBar = &FicBar
	Where FicCod <> &FicCod
    &RepetidoEanMensagem = 'Código de barras já utilizado na Ficha : '+ trim(str(FicCod))+' - '+trim(FicNom)
    exit
EndFor
]]></Source>
