For Each ORder EmpCod, CotComCod
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	
	Do CAse
		Case &OqueFazer = 'E' //empatados
			&Cotacao = format('COTAÇÃO: %1.%2 - PRODUTOS EMPATADOS', padL(trim(str(CotComCod)), 3, '0'), padL(trim(str(CotComVer)), 3, '0'))
		case &OqueFazer = 'N' //nao confirmados
			&Cotacao = format('COTAÇÃO: %1.%2 - PRODUTOS NÃO CONFIRMADOS', padL(trim(str(CotComCod)), 3, '0'), padL(trim(str(CotComVer)), 3, '0'))
		Case &OqueFazer = 'L' //listagem produtos cotados
			&Cotacao = format('COTAÇÃO: %1.%2 - LISTAGEM PRODUTOS COTADOS', padL(trim(str(CotComCod)), 3, '0'), padL(trim(str(CotComVer)), 3, '0'))
	EndCase
	
	&QtdItens = 0
	&TotalCotComProForVlrFin = 0
	
	print titulo
	
	For Each Order EmpCod, CotComCod, CotComItmCod
		Where CotComProMenForCod = -999 when &OqueFazer = 'E' 
		Where CotComProSelForCod.IsEmpty() or CotComProSelForCod.IsNull() or CotComProSelForCod = 0 when &OqueFazer = 'N'
		
		if CotComProCod.IsEmpty() or CotComProCod.IsNull()
			&CotComProNom = CotComProNom
		Else
			&CotComProNom = CotComProRef + ' - ' + CotComProNom
		Endif
		
		if &EmbCod <> CotComProEmbCod
			&EmbCod = CotComProEmbCod
			do 'getEmbalagem'
		Endif
		
		&CotComProForVlrFin = 0
		&UnidadeMedida = ''
		if CotComProQtd > 0
			&UnidadeMedida = RetiraZerosDepoisVirgulaxCasas.Udp(0, CotComProQtd.ToFormattedString())
			//&CotComProForVlrFin = (CotComProForVlrFin*CotComProQtd)
			//&TotalCotComProForVlrFin += &CotComProForVlrFin 
		Endif		 
		&UnidadeMedida += ' | ' +&auxUnidadeMedida.Trim()
		
		print Item	
		
		
		//print observacao fornecedor
		if not CotComProObs.IsEmpty() and not CotComProObs.IsNull()			
			&item = gxMLines(CotComProObs, 100)
			for &i = 1 to &item
				&Observacao = gxGetMLi(CotComProObs.ToUpper(), &i, 100)
				print ObservacaoRed
			Endfor
		Endif
		
		
		If  &OqueFazer = 'E' or &OqueFazer = 'N'//Empatados ou Nao Confirmados
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				Where CotComProForSts = StatusProdutoCotado.COTADO
				&Observacao = trim(str(CotComProForCod)) + ' - ' + trim(CotComProForRaz)
				&CotComProForVlrFin = CotComProForVlrFin
				print Fornecedor
				
				&DadosImposto = ''
				if CotComProForVlrIcms > 0
					&Varchar = retirazerosDepoisVirgulaxCasas.Udp(0, CotComProForVlrIcms.ToFormattedString())
					&DadosImposto += 'ICMS: '+&Varchar.Trim() + '%'
				EndIf
				If CotComProForVlrIpi > 0
					&Varchar = retirazerosDepoisVirgulaxCasas.Udp(0, CotComProForVlrIpi.ToFormattedString())
					if not &DadosImposto.IsEmpty()
						&DadosImposto += ', '
					Endif
					&DadosImposto += 'IPI: '+&Varchar.Trim() + '%'
				Endif
				If CotComProForVlrIcmsSt > 0
					&Varchar = retirazerosDepoisVirgulaxCasas.Udp(0, CotComProForVlrIcmsSt.ToFormattedString())
					if not &DadosImposto.IsEmpty()
						&DadosImposto += ', '
					Endif
					&DadosImposto += 'ICMS ST: '+&Varchar.Trim() + '%'
				Endif
				
				print DadosImposto
				
				//print observacao fornecedor
				if not CotComProForObs.IsEmpty() and not CotComProForObs.IsNull()			
					&item = gxMLines(CotComProForObs, 100)
					for &i = 1 to &item
						&Observacao = gxGetMLi(CotComProForObs.ToUpper(), &i, 100)
						print Observacao
					Endfor
				Endif
			EndFor			
		Endif	
	
		print Traco
		
		&QtdItens += 1
		
	EndFor
	
	Exit
EndFor


