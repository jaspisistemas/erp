      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//PROCEDIMENTO PARA CALCULAR O PESO TOTAL DA OPERAÇÃO DE TRANSPORTE

For Each Order EmpCod, FilCod, OpeCod
	Where EmpCod = &parmEmpCod
	Where FilCod = &parmFilCod
	Where OpeCod = &parmOpeCod
	
	For Each Order EmpCod, FilCod, OpeCod, OpeNfeCod
		
		&OpePso += OpeNfeQtdMerEmb //SOMA O VALOR DE TODAS AS MERCADORIAS DA NOTA
		 
	EndFor
	
	OpePso	= &OpePso
	
	Exit
EndFor
Commit
]]></Source>
