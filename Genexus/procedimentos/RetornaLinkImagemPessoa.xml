      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta )
RetornaTipoAnexo.Call(&EmpCod, '#IMAGEM_PESSOA#', &PesAnxTipCod)

For Each Order EmpCod, PesAnxCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	where PesAnxTipCod = &PesAnxTipCod
	&PesAnxCod = PesAnxCod
	if PesAnxMod.IsEmpty() or PesAnxMod.IsNull()
		PesAnxMod = serverdate()
		commit
	Endif

	&PesAnxMod = PesAnxMod
	if not PesAnxArq.IsEmpty() and not PesAnxArq.IsNull()
		&link = pathToUrl(PesAnxArq)
	Else
		&link = &SdtConfiguracoesPasta.PastaDiretoriovirtual.Trim() +'appjaspi\anexos\'+ trim(str(EmpCod)) + '\' + trim(PesAnxGuidNom)+'_'+trim(PesAnxGuid.ToString()) +'.'+ trim(PesAnxGuidExt)
	Endif
	
	Exit
EndFor
]]></Source>
