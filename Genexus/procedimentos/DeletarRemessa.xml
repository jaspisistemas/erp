      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,RemCbrCod,RemNum
	Where EmpCod = &EmpCod
	Where RemCbrCod = &RemCbrCod
	Where RemNum = &RemNum
	
	For each order RemFilCod,RemCreSeq
		
		&RemFilCod = RemFilCod
		&RemCreSeq = RemCreSeq
		Do 'atualizaduplicata'
		
		Delete
	EndFor
	Do 'atualizaseqlocalcobranca'
	Delete
EndFor

Commit

Sub 'atualizaduplicata'
	For each order EmpCod,FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &RemFilCod
		Where CreCod = &RemCreSeq
			If CreSts <> Status_Duplicata.CANCELADA
				CreSts = Status_Duplicata.ATIVO
			EndIf
		Exit
	EndFor
EndSub


Sub 'atualizaseqlocalcobranca'
	For each Order EmpCod,CbrCod
		Where EmpCod = &EmpCod
		Where CbrCod = &RemCbrCod
		CbrUltRem -= 1 
		If CbrUltRem <= 0
			CbrUltRem = 0
		EndIf

		Exit
	EndFor
EndSub
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
