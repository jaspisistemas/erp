      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedFatFilCod.SetEmpty()

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod	
	
	if PedFatFilCod.IsEmpty() or PedFatFilCod.IsNull()
		&PedFatFilCod = FilCod
	Else
		&PedFatFilCod = PedFatFilCod
	Endif

	Exit
EndFor
]]></Source>
