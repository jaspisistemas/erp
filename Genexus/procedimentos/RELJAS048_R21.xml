      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
RetornaTabelaFilial.Call(&EmpCod, &FilCod, &FiltabCod)
&TipoCodigoBarras = TipoCodigoBarras.Code128

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&IsColuna1 = 0
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	&EtqQtd = EtqQtd
	&ProCod = EtqProCod
	&ProGraCod = EtqProGraCod
	&Coluna1.SetEmpty()

	do 'GetPreco'
	Do 'getTipoProduto'
//	If &ProTip = 2
//		&NomeEmpresa = trim(&FilFan)
//	Else
//		&NomeEmpresa = '* '+trim(&FilFan)+' *'
//	EndIf
	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto = trim(str(EtqProCod))
	Else
		&CodigoProduto = trim(EtqNovProCod)		
	EndIF

	
	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.Trim().IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF

	&EtqProNom    =	&CodigoProduto.Trim() +' -'+&EtqProNom.Trim()
	&NomeProduto  = GxGetMLi(&EtqProNom, 1, 22)
	&NomeProduto1 = GxGetMLi(&EtqProNom, 2, 22)
	&NomeProduto2 = GxGetMLi(&EtqProNom, 3, 22)
	&CodBarrasImage.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(EtqProBar) + '.jpg'
	If not EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, EtqProBar, EtqProBar)
		EndIF
		If &File.Exists()
			&CodBarrasImage.FromURL(&NomeImagem)
		EndIF
	EndIf

	do 'printEtiquetas'
EndFor

sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		Do Case
			Case &IsColuna1 <= 1
				print EtiquetaModelo001Col1
				&IsColuna1 = 2
			Case &IsColuna1 = 2
				noSkip
				print EtiquetaModelo001Col2
				&IsColuna1 = 3
			otherwise
				noSkip
				print EtiquetaModelo001Col3
				&IsColuna1 = 1
		EndCase
	EndFor
EndSub

Sub 'GetPreco'
	For Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &FiltabCod
		
		For Each Order EmpCod, TabCod, ProCod, ProGraCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			
			if not TabPrc1.IsEmpty()
				&Coluna1 = 'R$ ' + trim(toformattedString(TabPrc1))
			EndIF
			
		EndFor
	EndFor
EndSub


Sub 'getTipoProduto'
	For each Order EmpCod,ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProTip = ProTip
		Exit
	EndFor
EndSub
]]></Source>
