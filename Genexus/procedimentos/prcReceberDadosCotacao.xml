      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, CotComCod, CotComItmCod
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	&Total += 1
	
EndFor

&IsUmErro = false

For Each ORder EmpCod
	Where EmpCod = &EmpCod
	&EmpCodSec = EmpCodSec
	Exit
endFor

&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

HostWebServiceJaspiADM.Call(&EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)

&pagina = 1
&paginaTotal = 0
do 'getApi'

if &IsUmErro = false
	if &paginaTotal > 1
		Do while &pagina <= &paginaTotal
			
			do 'getApi'
			if &IsUmErro = true
				Exit
			Endif
		EndDo
	Endif
Endif

//atualizaTotaisfornecec
prcVerificaStatusFornecedores.Call(&EmpCod, &CotComCod, &OqueFazer)

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


sub 'getApi'
	&LongVarChar		= 'chaveacesso=' + Trim(&EmpCodSec) +'&codigocotacao='+ Trim(str(&CotComCod)) +'&pagina='+ trim(str(&pagina))
	&HttpClient.AddHeader('Accept', 'application/json')
	&HttpClient.AddHeader('Connection', 'keep-alive')
	&HttpClient.AddHeader('Content-Type', 'application/json')
	
	&HttpClient.Execute('GET', 'https://'+&EmpWebHost+'/cotacaocompra/RecebeValoresCotados?' + &LongVarChar)
		
	If &HttpClient.StatusCode = 200
		
		&ProgressLogXml = &HttpClient.ToString()
		&versao += 1
		padraousuario.Call('G', 'JEANEnviaDadosCapaRetorno1'+trim(str(&Versao)), 1, 1, &ProgressLogXml, &PadDtaMod)
		
		&sdtDadosRecebidosCotacao.FromJson(&HttpClient.ToString())
		
		if &paginaTotal = 0
			&paginaTotal = &sdtDadosRecebidosCotacao.qtdPag
		Endif
		
		&Count += &sdtDadosRecebidosCotacao.qtd
		&Percentual = round((&Count / &Total) * 100, 0)
		If &Percentual < 2
			&Percentual = 2
		EndIF
		
		If &Percentual >= 100
			&Percentual = 99
		EndIf		
		do 'Atualiza'
	
		if &sdtDadosRecebidosCotacao.sts = 'J200'
			prcGravaValorCotado.Call(&EmpCod, &CotComCod, &sdtDadosRecebidosCotacao)
		Else
			&IsUmErro = true
		Endif
	
		&SdtWbsRetorno.sts = &sdtDadosRecebidosCotacao.sts 
		&SdtWbsRetorno.obs = &sdtDadosRecebidosCotacao.obs
		&ProgressLogXml = &SdtWbsRetorno.ToJson()
		
		&pagina += 1
	else
		&IsUmErro = true
		&SdtWbsRetorno.sts = 'F999'
		&SdtWbsRetorno.obs = 'Não foi Possível fazer a sincronização com servidor cotações. Erro: ' + trim(&HttpClient.StatusCode.ToString()) + ' - ' + &HttpClient.ErrDescription
		&ProgressLogXml = &SdtWbsRetorno.ToJson()
	Endif
EndSub


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub
]]></Source>
