Sub 'GravaNovaNfe'
	&NfeCod = UltimoCodigoEmpresa.Udp(domParCod.NOTAFISCAL, &EmpCod, &FilCodFat)
	&NfeNum = UltimoCodigoEmpresa.Udp(domParCod.NOTAFISCALNUM, &EmpCod, &FilCodFat)
	RetornaSerieNF.Call(domParCod.NOTAFISCAL55_SERIE, &EmpCod, &FilCodFat, &Serie)
	&NfeSer = trim(str(&Serie))
	New
		EmpCod = &EmpCod
		FilCod = &FilCodFat
		NfeCod = &NfeCod
		NfeFilCod = &FilCod
		NfePedCod = &PedCod
		NfeNum = &NfeNum
		NfeSer = &NfeSer
		NfeSts = Status_NFe.Digitando
		NfeProTer = Nota_ProPriaTerceira.PROPRIA
		
//		NfeChvRef = &tmpNfeChvRef
		NfeCidExp = &tmpExpCidCod
		NfeFin = &tmpNfeFin
		
		NfeDtaEms = &HojeData
		NfeDtaDsp = &HojeData
		NfeHorEms = SysTime()
		ModCod = '55' //NFe
		NfeTipFrt = &PedTipFrt
		
		If not &PedCliGruImpLctCod.IsEmpty() and &LctTip = TipoLancamento.SaidaMercadoria
			NfeLctCod = &PedCliGruImpLctCod
		Else
			NfeLctCod = &LctCod
		EndIF
		
		NfeEntSai = &LctAtuSal
		
		If &tmpNfeEnvEml = true
			NfeEnvEml = NfeEnvEml.Pendente
		Else
			NfeEnvEml = NfeEnvEml.Nao_Enviar
		EndIF
		
		NfeCliCod = &tmpDestxCod
		NfeCliRaz = &tmpPedCliNom
		NfeCliTipPes = &tmpPedCliTip
		NfeCliCpf = &tmpPedCliCpf
		NfeCliCnpj = &tmpPedCliCnpj
		Do 'ProdutorRemessa'
		RetornaInscricaoEstadual.Call(&EmpCod,&tmpDestxCod,&NfeCliIns)
		
		NfeCliIns = &NfeCliIns			
		NfeCliSuf = &NfeCliSuf		
		NfeCliEnd = &NfeCliEnd
		NfeCliEndNro = &NfeCliEndNro
		NfeCliBai = &NfeCliBai
		NfeCliCidNom = &NfeCliCidNom
		NfeCliCidCod = &NfeCliCidCod
		NfeCliCidIbge = &NfeCliCidIbge
		NfeCliCidUF = &NfeCliCidUF
		NfeCliCep = &NfeCliCep
		NfeCliFon = &NfeCliFon
		NfeCliCpl = &NfeCliCpl	
		//TRANPORTADORA
		&PesFonNum = retornaPrimeiroTelefone.Udp(&EmpCod, &PedTraRedCod)
		
		NfeTraCod = &PedTraRedCod
		If &PesFonNum.IsEmpty()
			NfeTraRaz = &PedTraRedRaz 
		Else
			NfeTraRaz = &PedTraRedRaz + ' - ' + &PesFonNum.Trim()
		EndIF
		
		NfeTraEnd = &PedTraRedLog
		NfeTraEndNro = &PedTraRedNro
		NfeTraBai = &PedTraRedBai
		NfeTraCidCod = &PedTraRedCidCod
		NfeTraCidNom = &PedTraRedCidNom
		NfeTraCidUfeCod = &PedTraRedUfeCod
		NfeTraCnpj = &PedTraRedCnpj
		NfeTraCpf = &PedTraRedCPF
		NfeTraInsEst = &PedTraRedInsEst
		NfeTraTipPes = &PedTraRedTipPes		
		
		NfeChv = '' //CHAVE DA NFE
		
		NfeVlrTotPro = &NfeVlrTotPro
		NfeVlrTotFrt = &NfeVlrTotFrt
		NfeVlrTotIpi = &NfeVlrTotIpi
		NfeVlrTot = &NfeVlrTot
		
		If ((&tmpNroNfp.Trim() <> '') and (not &tmpEmsNfp.IsEmpty()))
			&tmpManNfeDadAdi += 'NOTA DE PRODUTOR Nº '+trim(&tmpNroNfp) +', EMITIDA EM '+ &tmpEmsNfp.ToFormattedString()+' '
		Endif
		If &TmpTotFun > 0
			NfeTotFun  = &TmpTotFun
			&tmpManNfeDadAdi += 'DESCONTO DE FUNRURAL '+ trim(&FilPerFun.ToFormattedString())+'% NO VALOR DE R$ '+trim(&TmpTotFun.ToFormattedString())
		Else
			NfeTotFun = 0
		EndIf
	
		NfeVlrTotSeg = &NfeVlrTotSeg
		NfeVlrTotOutDsp = &NfeVlrTotOutDsp
		NfeVlrTotDsc = &NfeVlrTotDsc + &TmpTotFun
		NfeVlrTotBasIcms = &NfeVlrTotBasIcms
		NfeVlrTotIcms = &NfeVlrTotIcms
		NfeVlrTotBasIcmsSt = &NfeVlrTotBasIcmsSt
		NfeVlrTotIcmsSt = &NfeVlrTotIcmsSt
		NfeNroNfp = &tmpNroNfp
		NfeEmsNfp = &tmpEmsNfp
		
		&TotLin  =  GxMlines(&tmpManNfeDadAdi, 100)
		&NumLin  =  1
		Do While &NumLin <= &TotLin
			NfeDadAdi = NfeDadAdi.Trim() + ' ' +GxGetMLi(&tmpManNfeDadAdi, &NumLin, 100)
			&NumLin += 1
		EndDo
		
		&TotLin  =  GxMlines(&tmpAutNfeDadAdi, 100)
		&NumLin  =  1
		Do While &NumLin <= &TotLin
			NfeDadAdi = NfeDadAdi.Trim() + ' ' +GxGetMLi(&tmpAutNfeDadAdi, &NumLin, 100)
			&NumLin += 1
		EndDo
		
		
		NfeDadManAdi = Trim(&tmpManNfeDadAdi)
		NfeDadAutAdi = &tmpAutNfeDadAdi
		
		NfeQtdVol = &NfeQtdVol
		NfeEspVol = &NfeEspVol
		
		NfeVlrTotPdg = 0
		NfeNroVol = ''
		NfeMarVol = ''
		NfeMotNom = ''
		NfeTraPlaCod = ''
		NfeTraPlaUF = ''
		
		NfePesLiq = &NfePesLiq
		NfePesBrt = &NfePesBrt
		
		NfeEmiGnre = Status_SimNao.Nao
		
		NfeDI = &NfeDI
		//NfsEstExp = &NfsEstExp	
	EndNew
EndSub


