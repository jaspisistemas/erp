Sub 'ProdutorRemessa'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &tmpDestxCod
		&NfeCliSuf = PesSuf		
		&NfeCliEnd = PesEntLog
		&NfeCliEndNro = PesEntNro
		&NfeCliBai = PesEntBai
		&NfeCliCidNom = PesEntCidNom
		&NfeCliCidCod = PesCidCod
		&NfeCliCidIbge = PesEntCidIbge
		&NfeCliCidUF = PesEntUfeCod
		&NfeCliCep = PesEntCep		
		&NfeCliFon = FormataFONE.Udp(PesPrmFon)
		&NfeCliCpl = PesEntCpl	
		Exit
	EndFor	
EndSub


