      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, PesCod, PesFunObsCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesFunObsCod = &PesFunObsCod
		//PesFunObsUsuCod = &PesFunObsUsuCod
		//PesFunObsDtaHor = servertime()
		PesFunObs = &PesFunObs
	Exit
When None
	For Each Order EmpCod, PesCod, (PesFunObsCod)
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		&newPesFunObsCod = PesFunObsCod
		Exit
	EndFor
	&newPesFunObsCod += 1

	new
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesFunObsCod = &newPesFunObsCod
		PesFunObsUsuCod = &PesFunObsUsuCod
		PesFunObsDtaHor = ServerNow()
		PesFunObs = &PesFunObs
	EndNew
EndFor


Commit
]]></Source>
