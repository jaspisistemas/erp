      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon020_ClientePadraoVista, &CfgVlr)
&VisPedCliCod = val(&CfgVlr)

&PagamentoMensagem = ''

If &PedCliCod <> &VisPedCliCod
	Do Case
		Case &OqueRetornar = 'P' //PAGAMENTO
			For Each Order EmpCod, PesCod
				Where EmpCod = &EmpCod
				Where PesCod = &PedCliCod
				
				if not PesEnvSpc.IsNull() and not PesEnvSpc.IsEmpty()
					&PagamentoMensagem = 'CLIENTE ENVIADO AO SPC POR ESTA EMPRESA!' + newLine()
				EndiF
				
				if PesVenAprz = 'N'
					&PagamentoMensagem += 'CLIENTE COM RESTRIÇÃO DE VENDA À PRAZO!' + newLine()
				EndiF
				
				Exit
			EndFor
			
			RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon038_QtdDiasDupVencida, &CfgVlr)
			&Dias = val(&CfgVlr)
			&BaseData = serverdate() - &Dias
			
			For Each Order  EmpCod, CreCliCod, CreRecPag
				Where EmpCod = &EmpCod
				Where CreRecPag = ReceberPagar.Receber
				Where CreSts <> Status_Duplicata.CANCELADA
				Where CreFrpPgtoTip <> TipoDuplicata.CARTAOD and CreFrpPgtoTip <> TipoDuplicata.CARTAOC
				Where CreCliCod = &PedCliCod
				Where CreDtaVct < &BaseData
				Where CreVlrSdo  > 0
				&PagamentoMensagem += 'Cliente Possui Duplicatas Vencidas!' + newLine()
				exit
			EndFor
			
			&TotalMensagem = &PagamentoMensagem.Trim()
			
		CAse &OqueRetornar = 'P1'
			RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon038_QtdDiasDupVencida, &CfgVlr)
			&Dias = val(&CfgVlr)
			&BaseData = serverdate() - &Dias

			For Each Order  EmpCod, CreCliCod, CreRecPag
				Where EmpCod = &EmpCod
				Where CreRecPag = ReceberPagar.Receber
				Where CreSts <> Status_Duplicata.CANCELADA
				Where CreFrpPgtoTip <> TipoDuplicata.CARTAOD and CreFrpPgtoTip <> TipoDuplicata.CARTAOC
				Where CreCliCod = &PedCliCod
				Where CreDtaVct < &BaseData
				Where CreVlrSdo  > 0
				&PagamentoMensagem = 'Cliente Possui DUPLICATAS VENCIDAS!'
				exit
			EndFor
			
			&TotalMensagem = &PagamentoMensagem.Trim()
			
		Case &OqueRetornar = 'C' //CREDITO
			
			For Each Order EmpCod, CreCliCod, CreRecPag
				Where EmpCod = &EmpCod
				Where CreRecPag = ReceberPagar.Pagar
				Where CreFrpPgtoTip <> TipoDuplicata.CARTAOD and CreFrpPgtoTip <> TipoDuplicata.CARTAOC
				Where CreSts <> Status_Duplicata.CANCELADA
				Where CreCliCod = &PedCliCod
				Where CreVlrSdo  > 0
				&CreditoMensagem = 'Cliente com crédito no contas a Pagar!' + newLine()
				Exit
			EndFor
		
			&TotalMensagem = &CreditoMensagem.Trim()
		Case &OqueRetornar = 'A' //PEDIDO
			
			For Each Order EmpCod, FilCod, PedCliCod, PedCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where PedCliCod = &PedCliCod
				Where PedCod <> &PedCod
				Where PedSts = Status_Pedido.ABERTO or PedSts = Status_Pedido.SEPARANDO
				Where LctAtuSal = Status_EntradaSaida.Saida
				Where PedCliCod <> 0
				&AvisoPedidoMensagem = 'Existe pedido(s) ABERTO/SEPARANDO deste cliente '+NewLine()+ ' Primeiro Pedido Número: ' + trim(str(PedCod)) + newLine()
				exit
			EndFor
		
			&TotalMensagem = &AvisoPedidoMensagem.Trim()
		Case &OqueRetornar = 'V' //VINCULOS
			retornaVinculos.Call(&EmpCod, &PedCliCod, &sdtVinculos)
			
			For &sdtVinculosItem in &sdtVinculos
				If &sdtVinculosItem.PesCod <> &PedCliCod		
					if &VinculosMensagem.IsEmpty()
						&VinculosMensagem = 'CLIENTES VINCULADOS'
					EndIf
				
					if &sdtVinculosItem.PesIsMat = true
						&VinculosMensagem += NewLine() + '[MATRIZ] ' + trim(str(&sdtVinculosItem.PesCod)) + ' - ' + trim(&sdtVinculosItem.PesRaz)
					Else
						&VinculosMensagem += NewLine() + '[VINCULO] ' + trim(str(&sdtVinculosItem.PesCod)) + ' - ' + trim(&sdtVinculosItem.PesRaz)
					Endif
				EndIF
			EndFor
		
			&TotalMensagem = &VinculosMensagem.Trim()
	EndCAse
	
EndIF

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
