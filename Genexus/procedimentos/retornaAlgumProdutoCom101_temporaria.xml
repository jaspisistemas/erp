      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//&IsAlgum101 = false
&TotalCredito = 0

For Each Order tmpNFeCod
	Where tmpNFeCod = &tmpNFeCod
	
		if tmpNfeSitCod = '101' or tmpNfeSitCod = '201' and tmpPedVlrTotNov > 0
			
			&valorMoeda = Round((tmpPedVlrTotNov * &FilCrdIcm) / 100, 2)
			&TotalCredito += &valorMoeda
			
//			&IsAlgum101 = true
		Endif
	
endfor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
