      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Hora    = val(Substr(&inHora, 1, 2))
&minuto  = val(Substr(&inHora, 4, 2))
&Segundo = val(Substr(&inHora, 7, 2))

&minuto += (&Hora * 60)
&IniSegundo = &Segundo + (&minuto * 60)

&Hora    = val(Substr(&finHora, 1, 2))
&minuto  = val(Substr(&finHora, 4, 2))
&Segundo = val(Substr(&finHora, 7, 2))

&minuto += (&Hora * 60)
&FinSegundo = &Segundo + (&minuto * 60)


if &FinSegundo > &IniSegundo
	&SegundosDiferenca = &FinSegundo - &IniSegundo
	&DataDiferenca = serverDate()
	&DataDiferenca = &DataDiferenca.AddSeconds(&SegundosDiferenca)
	//99/99/9999 99:99:99
	&mensagem = trim(toformattedString(&DataDiferenca))
	&TotHora = Substr(&mensagem,12,8)
Else
	&TotHora = '00:00:00'
EndIF
]]></Source>
