      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[LoadWWPContext.Call(&wwpContext)
	
if &FilCod > 0 //Se tiver filial add no collection
	&CollFilCod.Add(&FilCod)
Else //se for zero pega todas autorizadas do usuario

	&CollFilCod = RetornaFiliaisAutorizadas.UDP(&wwpContext)
 Endif
 
&sdtMovimentoMensal.Clear()

For &Count = 1 to 12
	&AtualMes = &Count
	
	do 'Totaliza'
	
	do 'addsdtTotal'
	if &PlanCatTip = 'D' 
		&TotalMoedaPago = &TotalMoeda
		do 'addsdtTotalPago'
	Endif

EndFor


&PadObs = &sdtMovimentoMensal.ToJson()
padraoUsuarioHora.Call('G', '#WidGet_GraficoVendasAnualPagoRecebido#', &WwpContext.PesCod, &WwpContext.EmpCod, &PadObs , &PadDtaMod, &PadDtaHorMod, 'T')

&PadObs = &sdtMovimentoMensalPago.ToJson()
padraoUsuarioHora.Call('G', '#WidGet_GraficoVendasAnualPago#', &WwpContext.PesCod, &WwpContext.EmpCod, &PadObs , &PadDtaMod, &PadDtaHorMod, 'T')

Sub 'Totaliza'
	For each order EmpCod, MovDtaCon, MovCreDeb, PlanHiePadL
		Where EmpCod = &EmpCod
		Where MovCtaBanFilCod in &CollFilCod
		Where Year(MovDtaCon) = &Ano
		Where month(MovDtaCon) = &AtualMes
		Where MovItmSts <> Status_Caixa.Cancelado or MovItmSts.IsEmpty() or MovItmSts.IsNull()
		Where MovSts <> Status_Caixa.Cancelado or MovSts.IsNull() or MovSts.IsEmpty()
		Where MovTip <> TipoMovimento.Transferencia
		
		if (&PlanCatTip <> PlanCatTip)
			&TotalMoedaPago = &TotalMoeda 
			do 'addsdtTotal'
			&TotalMoeda  = 0
		Endif
	
		if PlanPaiHie <> &PLanPaiHie and not &PLanPaiHie.IsEmpty()
			if &PlanCatTip = 'D' 
				&TotalMoedaPago = &TotalMoeda
				do 'addsdtTotalPago'
			Endif
		
			&TotalMoedaPago = 0
			&PLanPaiHie.SetEmpty()
		Endif
	 
		&PLanPaiHie = PlanPaiHie
		&TotalMoeda += MovItmVlr
		&PlanCatTip = PlanCatTip
	EndFor
EndSub


Sub 'addsdtTotalPago'
	&IsAchouMes = false
	For &sdtMovimentoMensalPagoItem in &sdtMovimentoMensalPago
		if &sdtMovimentoMensalPagoItem.PlanoContas = &PLanPaiHie and &sdtMovimentoMensalPagoItem.Mes = &AtualMes
			&IsAchouMes = true
//			do CAse
//				CAse &AtualMes = 1
					&sdtMovimentoMensalPagoItem.PlanoContasValores.ValorPago1 += &TotalMoedaPago
//				CAse &AtualMes = 1
//					&sdtMovimentoMensalPagoItem.ValorPago2 += &TotalMoedaPago
//				CAse &AtualMes = 1
//					&sdtMovimentoMensalPagoItem.ValorPago3 += &TotalMoedaPago
//			EndCase
		
			Exit	
		Endif
	ENdFor
	
	if &IsAchouMes = false
		&sdtMovimentoMensalPagoItem = new()
//		
		&sdtMovimentoMensalPagoItem.Mes = &AtualMes
		&sdtMovimentoMensalPagoItem.PlanoContas = &PLanPaiHie
//		do CAse
//			CAse &AtualMes = 1
				&sdtMovimentoMensalPagoItem.PlanoContasValores.ValorPago1 += &TotalMoedaPago
//			CAse &AtualMes = 1
//				&sdtMovimentoMensalPagoItem.ValorPago2 += &TotalMoedaPago
//			CAse &AtualMes = 1
//				&sdtMovimentoMensalPagoItem.ValorPago3 += &TotalMoedaPago
//		EndCase
	
		
		&sdtMovimentoMensalPago.Add(&sdtMovimentoMensalPagoItem)
	EndIf
EndSub



Sub 'addsdtTotal'
	&IsAchouMes = false
	For &sdtMovimentoMensalItem in &sdtMovimentoMensal
		if &sdtMovimentoMensalItem.Mes = &AtualMes
			&IsAchouMes = true
			
			Do CAse
				CAse &PlanCatTip = 'C' //Credito
					&sdtMovimentoMensalItem.ValorRecebido += &TotalMoeda
				Case  &PlanCatTip = 'D' //Debito
					&sdtMovimentoMensalItem.ValorPago += &TotalMoeda
			EndCase
			Exit	
		Endif
	ENdFor

	if &IsAchouMes = false
		&sdtMovimentoMensalItem = new()
		
		&sdtMovimentoMensalItem.Mes = &AtualMes
		Do CAse
			CAse &PlanCatTip = 'C' //Credito
				&sdtMovimentoMensalItem.ValorRecebido += &TotalMoeda
			Case  &PlanCatTip = 'D' //Debito
				&sdtMovimentoMensalItem.ValorPago += &TotalMoeda
		EndCase
	
		&sdtMovimentoMensal.Add(&sdtMovimentoMensalItem)
	EndIf
EndSub


]]></Source>
