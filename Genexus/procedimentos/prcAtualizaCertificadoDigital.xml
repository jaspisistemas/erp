      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For each Order EmpCod, FilCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	
	if not &LongVarchar.IsEmpty() and &LongVarchar.Length() > 100
		FilCert = &FilCert
	Endif

	FilCerNom =  &FilCerNom
	FilCerPsw = &FilCerPsw
	FilCerDtaHor = &FilCerDtaHor
	FilCerA1A3 = &FilCerA1A3
	
	FilIdQrCode = &FilIdQrCode
	FilSenQrCode = &FilSenQrCode
	
	FilVctCer = &FilVctCer 
	Exit
EndFor

Commit



//GRAVAR FISICAMENTE NA PASTA /appjaspi/
]]></Source>
