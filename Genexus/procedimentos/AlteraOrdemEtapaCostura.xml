<Object parentGuid="a005aaf5-dd8b-4d7a-9cb0-9b92dd1a3244" user="" versionDate="2022-06-28T23:50:51.0000000Z" lastUpdate="2017-09-06T13:14:46.0000000Z" checksum="49fbbcb75c42b56e4a3d925d27d1f513" fullyQualifiedName="AlteraOrdemEtapaCostura" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="239ae965-66a3-4745-afe2-5ce7842571f0" name="AlteraOrdemEtapaCostura" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Altera Ordem Etapa Costura" parent="ProdPrc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
		For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
			Where EmpCod = &EmpCod
			Where OcsCod = &OcsCod
			Where OcsItm = &OcsItm
			where OcsEtpItm = &OcsEtpItm
			
			new
				OcsEtpItm = 99
			EndNEw
			
			Commit
		EndFor
		
		AlteraOrdemEtapaCostura2.Call(&EmpCod, &OcsCod, &OcsItm, &OcsEtpItm, 99)
		
		if &NovoOcsEtpItm < &OcsEtpItm
			&AuxNovoOcsEtpItm = &NovoOcsEtpItm
			&continua = true
			do while &continua = true
				For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
					Where EmpCod = &EmpCod
					Where OcsCod = &OcsCod
					Where OcsItm = &OcsItm
					Where OcsEtpItm = &AuxNovoOcsEtpItm
					&AuxNovoOcsEtpItm += 1
					Exit
				When none
					&continua = false
				EndFor
			EndDo
			
			if &AuxNovoOcsEtpItm <> &NovoOcsEtpItm //Existr Registros
				&DimOcsEtpItm = &AuxNovoOcsEtpItm
				&continua = true
				do while &continua = true
					&DimOcsEtpItm -= 1
					
					For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
						Where EmpCod = &EmpCod
						Where OcsCod = &OcsCod
						Where OcsItm = &OcsItm
						Where OcsEtpItm = &DimOcsEtpItm
						
						new
							OcsEtpItm = &AuxNovoOcsEtpItm
						EndNEw
						
						commit
						
						AlteraOrdemEtapaCostura2.Call(&EmpCod, OcsCod, OcsItm, OcsEtpItm, &AuxNovoOcsEtpItm)
						&AuxNovoOcsEtpItm -= 1
						Exit
					When none
						&continua = false
					EndFor
					
					if &DimOcsEtpItm = &NovoOcsEtpItm
						&continua = false
					EndIF
				EndDo
			EndIF
		Else
			&AuxNovoOcsEtpItm = &NovoOcsEtpItm
			&continua = true
			do while &continua = true
				For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
					Where EmpCod = &EmpCod
					Where OcsCod = &OcsCod
					Where OcsItm = &OcsItm
					Where OcsEtpItm = &AuxNovoOcsEtpItm
					&AuxNovoOcsEtpItm -= 1
					Exit
				When none
					&continua = false
				EndFor
				
				if &AuxNovoOcsEtpItm = 1 
					&continua = false
				EndIF
			EndDo
			
			if &AuxNovoOcsEtpItm <> &NovoOcsEtpItm //Existr Registros
				&DimOcsEtpItm = &AuxNovoOcsEtpItm
				&continua = true
				do while &continua = true
					&DimOcsEtpItm += 1
					
					For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
						Where EmpCod = &EmpCod
						Where OcsCod = &OcsCod
						Where OcsItm = &OcsItm
						Where OcsEtpItm = &DimOcsEtpItm
						
						new
							OcsEtpItm = &AuxNovoOcsEtpItm
						EndNEw
						
						commit
						
						AlteraOrdemEtapaCostura2.Call(&EmpCod, OcsCod, OcsItm, OcsEtpItm, &AuxNovoOcsEtpItm)
						&AuxNovoOcsEtpItm += 1
						Exit
					When none
						&continua = false
					EndFor
					
					if &DimOcsEtpItm = &NovoOcsEtpItm
						&continua = false
					EndIF
				EndDo
			EndIF
		EndIF
		
		For Each Order EmpCod, OcsCod, OcsItm, OcsEtpItm
			Where EmpCod = &EmpCod
			Where OcsCod = &OcsCod
			Where OcsItm = &OcsItm
			Where OcsEtpItm = 99
			
			new
				OcsEtpItm = &NovoOcsEtpItm
			EndNEw
			
			Commit
		EndFor
		
		AlteraOrdemEtapaCostura2.Call(&EmpCod, &OcsCod, &OcsItm, 99, &NovoOcsEtpItm)
		
]]></Source>
