<Object parentGuid="95d16465-d829-4d44-9e43-64d569b56373" user="WIN-JEAN\jean.fae" versionDate="2022-08-24T17:38:59.0000000Z" lastUpdate="2022-08-24T17:37:27.0000000Z" checksum="1cfef556664c8808dcb26aa1c66a93d7" fullyQualifiedName="prcInativarClientesSemCompra" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="e914a748-22db-4914-ab8d-48fde4de9ba7" name="prcInativarClientesSemCompra" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Inativar Clientes Sem Compra" parent="InativarCadastros" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&HojeData = serverdate()

RetornaConfSistema.Call(&EmpCod, 1,domConfSistema.TCon158_DiasSemVendas, &TCon158_DiasSemVendas)
&Dias = val(&TCon158_DiasSemVendas)

if &Dias > 0
	//Localiza Clientes
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesSts = Status_AtivoInativo.ATIVO
		Where PesIsCli = true
		Where PesClaTip <> ClienteClassificacao.OTIMO
		
		prcRetornaUltimaCompra.Call(EmpCod, PesCod, &PedDtaFat)
		
		if not &PedDtaFat.IsEmpty() and ((&HojeData - &PedDtaFat) > &Dias)
			
			PesSts  	= Status_AtivoInativo.INATIVO
			PesDtaAlt 	= serverdate()
			PesDtaHorAlt = serverNow()
			GravaObservacaoPessoa.Call(EmpCod, PesCod, 0, -1, '#JASPI# CLIENTE DESATIVADO POR INATIVIDADE DE VENDAS')
			
			Commit
			
			AtualizaEnderecoCliente.Call(EmpCod, PesCod)
		EndIf
		
	EndFor
Endif
]]></Source>
