      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each	
	Where AuditRecordId = &AuditRecordID
		&AuditRecordAttributeGuid = AuditRecordAttributeGuid
		&AuditRecordTableGuid = AuditRecordTableGuid
		
		For Each
			Where AuditAttributeMetadataGuid = &AuditRecordAttributeGuid
			Where AuditTableMetadataGuid = &AuditRecordTableGuid
				If AuditRecordAttributesOldValue <> AuditRecordAttributesNewValue OR (AuditRecordAttributesOldValue.IsNull() AND NOT AuditRecordAttributesNewValue.IsNull()) OR (NOT AuditRecordAttributesOldValue.IsNull() AND AuditRecordAttributesNewValue.IsNull())
					if &AuditRecordModifiedAttributes.IsEmpty()
						&AuditRecordModifiedAttributes = AuditRecordAttributesName
					else
						If &IsGrid
							&AuditRecordModifiedAttributes = &AuditRecordModifiedAttributes + " - " + AuditRecordAttributesName
						Else							
							&AuditRecordModifiedAttributes = &AuditRecordModifiedAttributes + NewLine() + AuditRecordAttributesName
						EndIf					
					endif
				EndIf
		EndFor	
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
