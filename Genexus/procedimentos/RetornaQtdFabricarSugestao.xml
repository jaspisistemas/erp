      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TotalSugestao = 0
&TotalFabricar = 0
&AuxGrupHie = &GrupHie.Trim() + '.'
&QtdTotProducao = 0

For Each Order EmpCod, FilCod, ProSts ProGraCod, ProSetCod, ProTipDef
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProSetCod = &ProSetCod
	Where ProTipDef = &ProTipDef 
	Where ProGraCod = 1
	Where ProSts = Status_Produto.ATIVO 
	Where (GrupHie like &AuxGrupHie or GrupHie = &GrupHie) and GrupAnaSin = 'A'
	Where EstSug > 0
	&TotalSugestao += EstSug
EndFor


For Each Order EmpCod, FilCod, ProSts ProGraCod, ProSetCod, ProTipDef
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProSetCod = &ProSetCod
	Where ProTipDef = &ProTipDef 
	Where ProGraCod = 1
	Where ProSts = Status_Produto.ATIVO 
	Where (GrupHie like &AuxGrupHie or GrupHie = &GrupHie) and GrupAnaSin = 'A'
	Where EstFab > 0
	&TotalFabricar += EstFab
EndFor


For Each Order EmpCod, FilCod, ProSts ProGraCod, ProSetCod, ProTipDef
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProSetCod = &ProSetCod
	Where ProTipDef = &ProTipDef 
	Where ProGraCod = 1
	Where ProSts = Status_Produto.ATIVO 
	Where (GrupHie like &AuxGrupHie or GrupHie = &GrupHie) and GrupAnaSin = 'A'
	Where EstPrd > 0
	&QtdTotProducao += EstPrd
EndFor
]]></Source>
