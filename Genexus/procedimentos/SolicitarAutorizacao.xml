      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do Case
	CAse &OqueFazer = 'ADD'
		For Each Order EmpCod, FilCod, PedCod, PedLibItm //UPD
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedLibItm = &PedLibItm
			Where PedLibTip = &PedLibTip
			Where PedLibCliCod = &PedCliCod
			
			PedLibObs = &PedLibObs
			PedLibProCod = &ProCod
			PedLibProGraCod = &ProGraCod
			
			PedLibSolPedQtd = &PedLibAutPedQtd
			PedLIbSolPedVlr = &PedLibAutPedVlr
			PedLibSolPedDesc = &PedLibAutPedDesc
			
			PedLibObs = &PedLibObs
			PedLibSolDta = ServerNow()
			
			Exit
		When none
			//ADD
			For Each Order EmpCod, FilCod, PedCod, (PedLibItm)
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where PedCod = &PedCod
				&NEwPedLibItm = PedLibItm 
				Exit
			EndFor
			&NEwPedLibItm += 1
			
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				PedCod = &PedCod
				PedLibItm = &NEwPedLibItm
				PedLibTip = &PedLibTip
				PedLibCliCod = &PedCliCod
				
				PedLibObs = &PedLibObs
				PedLibProCod = &ProCod
				PedLibProGraCod = &ProGraCod
				
				PedLibSolPedQtd = &PedLibAutPedQtd
				PedLIbSolPedVlr = &PedLibAutPedVlr
				PedLibSolPedDesc = &PedLibAutPedDesc
				
				PedLibAutPedQtd = 0
				PedLibAutPedVlr = 0 
				PedLibAutPedDesc = 0 
				PedLibSolDta = ServerNow()
				PedLibSolFun = &PedLibSolFun
				PedLibSts = StatusLiberacao.Aguardando
				PedLIbRea = 0
			EndNEw
		EndFor
		
		commit
	CAse &OqueFazer = 'REA'
		For Each Order EmpCod, FilCod, PedCod, PedLibItm //UPD
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where PedLibItm = &PedLibItm
			Where PedLibTip = &PedLibTip
			Where PedLibCliCod = &PedCliCod
			
			PedLibObs = &PedLibObs
			PedLibProCod = &ProCod
			PedLibProGraCod = &ProGraCod
			
			PedLibSolPedQtd = &PedLibAutPedQtd
			PedLIbSolPedVlr = &PedLibAutPedVlr
			PedLibSolPedDesc = &PedLibAutPedDesc
			
			PedLibObs = &PedLibObs
			PedLibSolDta = ServerNow()
			PedLIbRea = 1
			Exit
		EndFor
		
		commit
EndCase

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
