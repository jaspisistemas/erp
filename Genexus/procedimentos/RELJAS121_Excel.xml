<Object parentGuid="2a44768c-29ee-45db-8775-9aa5477983a4" user="WIN-JEAN\jean.fae" versionDate="2024-07-15T12:49:24.0000000Z" lastUpdate="2024-07-12T11:45:45.0000000Z" checksum="58b3295ff0cf19baaed1871415c2e319" fullyQualifiedName="RELJAS121_Excel" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="62b20055-4e59-4c07-9263-fdf22562b65d" name="RELJAS121_Excel" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="RELJAS121_Excel" parent="FatProc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&linha = 1

&File.Source = &LinkFisico //apaga arquivo gerado com mesmo nome.
if &File.Exists()
	&File.Delete()
Endif
&File.Close()

&ExcelDocument.Open(&LinkFisico)

&titulo = upper('Produtos Vendidos / Comprados no período')
&ExcelDocument.Cells(&linha, 1).Text = &titulo
&linha += 1

&IsCabecalhoProdutos = true

&Primeira_area = 'S'
&primeiro_vendedor = 'S'
&primeiro_Grupo = 'S'
&TotPedQtd = 0
&TotPedVlrItm = 0
&TotPedVlrItmComDsc = 0 
&AuxTotPedVlrItmCus = 0
&AuxTotPedVlrItmCusMat = 0
&AuxTotPedVlrItmCusPrd = 0
&auxGrupHie = &GrupHie.Trim() + '.'

//#####################################################################
For Each 
	Order EmpCod,FilCod, LctAtuEst, ProNom,ProGraNom When &OrdemExibicao = 'N'
	Order EmpCod,FilCod, LctAtuEst, ProGraRefPadL When &OrdemExibicao = 'C'
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where LctAtuEst = &LctAtuEst
	Where LctCod = &LctCod  when not &LctCod.IsEmpty()
	Where LctGerFin = &LctGerFin when not &LctGerFin.IsEmpty()
	Where ProCod = &ProCod when not &ProCod.IsEmpty()
	Where ProVarNcm = &ProVarNcm when not &ProVarNcm.IsEmpty()
	Where MarCod = &MarCod when not &MarCod.IsEmpty()
	Where ProPadForCod = &ProPadForCod when not &ProPadForCod.IsEmpty()
	Where PedCliCod = &PesCliCod when not &PesCliCod.IsEmpty()
	Where (PedDtaFat >= &PedDtaEms and PedDtaFat <= &PedDtaEms_Go) when &PedSts = Status_Pedido.FECHADO and &TCon096_HoraProdutoVendido <> Status_simNao.Sim
	Where (PedDtaFic >= &PedDtaEms and PedDtaFic <= &PedDtaEms_Go) when (&PedSts <> Status_Pedido.FECHADO or &PedSts.IsEmpty()) and &TCon096_HoraProdutoVendido <> Status_simNao.Sim
	Where (PedHorFat >= &PedHorFat and PedHorFat <= &PedHorFat_Go) When &PedSts = Status_Pedido.FECHADO and &TCon096_HoraProdutoVendido = Status_simNao.Sim
	Where PedSts = &PedSts when not &PedSts.IsEmpty()
	Where PedSts <> Status_Pedido.CANCELADO when &PedSts.IsEmpty()
	Where PedItmVenCod = &PesVenCod when not &PesVenCod.IsEmpty()
	Where PedVenAreCod = &AreCod when not &AreCod.IsEmpty()		
	Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	where ProTipDef = Definicao.SERVICO when &TipoProduto = 'S' 
	where ProTipDef <> Definicao.SERVICO when &TipoProduto = 'P' 
	Where ProClsPrdCod =  &ProClsPrdCod when not &ProClsPrdCod.IsEmpty()
	
    If &Primeira_area = 'S' and &AreCod <> 0
		&PedVenAreNom = TRIM(Str(PedVenAreCod))+'-'+TRIM(PedVenAreNom)
		&ExcelDocument.Cells(&linha, 1).Text = 'Area: '+ &PedVenAreNom
		&linha += 1
        &Primeira_area = 'N'
    Endif

    If &primeiro_vendedor = 'S' and &PesVenCod <> 0 
		&PedVenCodRaz = PedVenCodRaz
		&ExcelDocument.Cells(&linha, 1).Text = 'Vendedor: '+ &PedVenCodRaz
		&linha += 1
        &primeiro_vendedor = 'N'
    EndIf

	If &primeiro_Grupo = 'S' and not &GrupHie.IsEmpty()
		&GrupCodNom = GrupCodNom
		&ExcelDocument.Cells(&linha, 1).Text = 'Grupo: '+ &GrupCodNom
		&linha += 1
		&primeiro_Grupo = 'N'
	EndIf

	if &IsCabecalhoProdutos = true
		if &tipoCusto = 'C'
			&Coluna = 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Ref.Código'		
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Produto'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Und'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Custo Unit.Mat.'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Quantidade'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Custo T.Prod.'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Custo T.Mat.'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Custo Total'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Valor liq.'
		Else
			&Coluna = 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Ref.Código'		
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Produto'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Und'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Custo Unitário'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Quantidade'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Custo Total'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Valor Líq.'
			&Coluna += 1
			&ExcelDocument.Cells(&linha, &Coluna).Text = 'Valor Bruto'
		Endif
		&linha += 1
		
		&IsCabecalhoProdutos = false
	Endif


	If &ProGraRef <> ProGraRef and &ProGraRef <> ''
		If &PedQtd > 0
			&PedVlrCus = (&PedVlrItmCus/&PedQtd)
			&PedVlrCusPrd = (&PedVlrItmCusPrd/&PedQtd)
			&PedVlrCusMat = 0
			if &PedVlrCus > &PedVlrCusPrd
				&PedVlrCusMat = &PedVlrCus - &PedVlrCusPrd
			Endif
			
			&TotPedQtd += &PedQtd
			&TotPedVlrItm += &PedVlrItm
			&TotPedVlrItmComDsc += &PedVlrItmComDsc
			&AuxTotPedVlrItmCus += &PedVlrItmCus
			&AuxTotPedVlrItmCusMat += &PedVlrItmCusMat
			&AuxTotPedVlrItmCusPrd += &PedVlrItmCusPrd
			
			do 'pastLInha'
			
			&PedQtd = 0
			&PedVlrItm = 0
			&PedVlrItmComDsc = 0
			&PedVlrCus = 0
			&PedVlrCusPrd = 0
			&PedVlrCusMat = 0
			&PedVlrItmCus = 0
			&PedVlrItmCusPrd = 0
			&PedVlrItmCusMat = 0
		EndIf
	EndIf

	
	&auxProNom 		=ProNomGra 
	&ProGraRef = ProGraRef
	&ProEmbUnd = ProEmbUnd
	
	Do Case
		Case &QtdTipo = 1//somente Vendidos
			&PedQtd += PedQtd
			&PedVlrItm += PedVlrItm
			&PedVlrItmComDsc += PedVlrItmComDsc
			&PedVlrItmCus += PedVlrItmCus
			&PedVlrItmCusPrd += (PedVlrCusPrd * PedQtd)
			
			&CustoMateriaPrima = iif(PedVlrCus > PedVlrCusPrd, (PedVlrCus - PedVlrCusPrd), 0)
			&PedVlrItmCusMat +=  (&CustoMateriaPrima * PedQtd)
			
		Case &QtdTipo = 2// Somente Canceladas
			&PedQtd += PedQtdCan
			&PedVlrItm += PedVlrItm
			&PedVlrItmComDsc += PedVlrItmComDsc
			&PedVlrItmCus += (PedVlrCus *PedQtdCan)
			&PedVlrItmCusPrd += (PedVlrCusPrd * PedQtdCan)
			
			&CustoMateriaPrima = iif(PedVlrCus > PedVlrCusPrd, (PedVlrCus - PedVlrCusPrd), 0)
			&PedVlrItmCusMat +=  (&CustoMateriaPrima * PedQtdCan)
			
		Case &QtdTipo = 3//Vendidas + Canceladas
			&PedQtd += PedQtd + PedQtdCan
			&PedVlrItm += PedVlrItm
			&PedVlrItmComDsc += PedVlrItmComDsc
			&PedVlrItmCus += (PedVlrItmCus + (PedVlrCus *PedQtdCan))
			&PedVlrItmCusPrd += (PedVlrCusPrd * (PedQtd + PedQtdCan))
			
			&CustoMateriaPrima = iif(PedVlrCus > PedVlrCusPrd, (PedVlrCus - PedVlrCusPrd), 0)
			&PedVlrItmCusMat +=  (&CustoMateriaPrima * (PedQtd + PedQtdCan))
	EndCase
EndFor

//################################  FINAL
If &PedQtd > 0
	&PedVlrCus = (&PedVlrItmCus/&PedQtd)
	&PedVlrCusPrd = (&PedVlrItmCusPrd/&PedQtd)
	
	&PedVlrCusMat = 0
	if &PedVlrCus > &PedVlrCusPrd
		&PedVlrCusMat = &PedVlrCus - &PedVlrCusPrd
	Endif
	
	&TotPedQtd += &PedQtd
	&TotPedVlrItm += &PedVlrItm
	&TotPedVlrItmComDsc += &PedVlrItmComDsc
	&AuxTotPedVlrItmCus += &PedVlrItmCus
	&AuxTotPedVlrItmCusMat += &PedVlrItmCusMat
	&AuxTotPedVlrItmCusPrd += &PedVlrItmCusPrd
	
	do 'pastLinha'
EndIf

//################################

if &tipoCusto = 'C'
	&Coluna = 4
	&ExcelDocument.Cells(&linha, &Coluna).Text = 'Total:'
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedQtd
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &AuxTotPedVlrItmCusPrd
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &AuxTotPedVlrItmCusMat
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &AuxTotPedVlrItmCus
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItmComDsc
Else
	&Coluna = 4
	&ExcelDocument.Cells(&linha, &Coluna).Text = 'Total:'
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedQtd
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &AuxTotPedVlrItmCus
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItmComDsc
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &TotPedVlrItm
Endif
&linha += 1
Do 'printPedidos'

&ExcelDocument.Save() //Salva e fecha
&ExcelDocument.Close()


sub 'pastLinha'
	if &tipoCusto = 'C'
		&Coluna = 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = &ProGraRef		
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = &auxProNom
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = &ProEmbUnd
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrCusMat
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedQtd
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmCusPrd
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmCusMat
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmCus
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmComDsc
	Else
		&Coluna = 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = &ProGraRef		
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = &auxProNom
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = &ProEmbUnd
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrCus
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedQtd
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmCus
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItmComDsc
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Number = &PedVlrItm
	Endif
	&linha += 1
EndSub

Sub 'printPedidos'
    If &ProCod <> 0 and &DetalharItens = True
		&auxPedQtd = 0
		&PedPedCod = 0
		&linha += 1
		
		&Coluna = 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = 'Pedidos'
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = 'Data Faturamento'
		&Coluna += 1
		&ExcelDocument.Cells(&linha, &Coluna).Text = 'Quantidade'
		&linha += 1
		
        For Each Order EmpCod,FilCod, ProCod,LctAtuEst, PedCod, (PedDtaFic)
			Where EmpCod = &EmpCod
	        Where FilCod = &FilCod
			Where ProCod = &ProCod
	        Where LctAtuEst = &LctAtuEst
			Where LctCod = &LctCod  when not &LctCod.IsEmpty()
			Where LctGerFin = &LctGerFin when not &LctGerFin.IsEmpty()
			Where ProVarNcm = &ProVarNcm when not &ProVarNcm.IsEmpty()
			Where MarCod = &MarCod when not &MarCod.IsEmpty()
			Where ProPadForCod = &ProPadForCod when not &ProPadForCod.IsEmpty()
			Where PedCliCod = &PesCliCod when not &PesCliCod.IsEmpty()
			Where (PedDtaFat >= &PedDtaEms and PedDtaFat <= &PedDtaEms_Go) when &PedSts = Status_Pedido.FECHADO and &TCon096_HoraProdutoVendido <> Status_simNao.Sim
			Where (PedDtaFic >= &PedDtaEms and PedDtaFic <= &PedDtaEms_Go) when (&PedSts <> Status_Pedido.FECHADO or &PedSts.IsEmpty()) and &TCon096_HoraProdutoVendido <> Status_simNao.Sim
			Where (PedHorFat >= &PedHorFat and PedHorFat <= &PedHorFat_Go) When &PedSts = Status_Pedido.FECHADO and &TCon096_HoraProdutoVendido = Status_simNao.Sim
			Where PedSts = &PedSts when not &PedSts.IsEmpty()
			Where PedSts <> Status_Pedido.CANCELADO when &PedSts.IsEmpty()
			Where PedVenCod = &PesVenCod when not &PesVenCod.IsEmpty()
			Where PedVenAreCod = &AreCod when not &AreCod.IsEmpty()		
			Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
			Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
			where ProTipDef = Definicao.SERVICO when &TipoProduto = 'S' 
			where ProTipDef <> Definicao.SERVICO when &TipoProduto = 'P' 
			Where ProClsPrdCod =  &ProClsPrdCod when not &ProClsPrdCod.IsEmpty()
			
			If &PedPedCod <> PedCod and &auxPedQtd > 0
				do 'PedidoItens'
				&auxPedQtd = 0
			EndIf
			&PedDtaFat = PedDtaFat
			&auxPedQtd += PedQtd
			&PedPedCod = PedCod
        EndFor		
		do 'PedidoItens'
    EndIf
EndSub

Sub 'PedidoItens'
	&Coluna = 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &PedPedCod
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Text = &PedDtaFat.ToString()
	&Coluna += 1
	&ExcelDocument.Cells(&linha, &Coluna).Number = &auxPedQtd
	&linha += 1
EndSub
]]></Source>
