      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&VarChar.SetEmpty()
&Count = 0 
&CountSoc = 0
For each order EmpCod,PesCod,PesSocCod
	where EmpCod = &EmpCod
	where PesCod = &PesCod
	where PesSocAdm = Status_SimNao.Sim
	&CountSoc += 1
EndFor
	

For each order EmpCod,PesCod,PesSocCod
	where EmpCod = &EmpCod
	where PesCod = &PesCod
	where PesSocAdm = Status_SimNao.Sim
	if &CountSoc >= 2
		if not &VarChar.IsEmpty()
			&VarChar += ','	
		EndIf
		&VarChar += substr(PesSocNom,1,14)
		&Count += 1
		if &Count >= 3 //45 caracter / 3 sócios/ADMs
			exit
		EndIf
	else
		&VarChar = substr(PesSocNom,1,45)
		exit
	EndIf
when none 
	
	For each order EmpCod,PesCod,PesSocCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		&VarChar += substr(PesSocNom,1,14) + ','
		&Count += 1
		if &Count >= 5 //85 caracter / 5 sócios
			exit
		EndIf
	when none
		&VarChar = '-----'
	EndFor

EndFor
]]></Source>
