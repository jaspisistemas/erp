      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&sdtVencimentos.Clear()

For Each Order EmpCod, FilCod, (NfeCod)
	Where EmpCod = &EmpCod
	Where NfeFilCod = &FiLCod
	Where NfePedCod = &PedCod
	
	&NfeNum = NfeNum
	if not NfeArqXml.IsEmpty()
		leituraXmlDanfe.Call(NfeArqXml, &TNfeProc)
	Endif
	Exit
Endfor

	
For &dup in &TNFeProc.NFe.infNFe.cobr.dups
	RetornaSoNumeros.Call(&dup.nDup, &Varchar)
	&Numeric = val(&Varchar)
	&NfeDupNro = trim(str(&NfeNum)) + '-' + trim(str(&Numeric))
	&NfeDupVct = substr(&dup.dVenc,9,2)+'/'+ substr(&dup.dVenc,6,2) +'/'+substr(&dup.dVenc,1,4)
	&NfeDupVlr = val(&dup.vDup)
	
	&sdtVencimentosItem = new()
	&sdtVencimentosItem.CreDupNro = &NfeDupNro
	&sdtVencimentosItem.CreDtaVct.FromString(&NfeDupVct)
	&sdtVencimentosItem.CreVlrDup = &NfeDupVlr
	&sdtVencimentos.Add(&sdtVencimentosItem)
EndFor
]]></Source>
