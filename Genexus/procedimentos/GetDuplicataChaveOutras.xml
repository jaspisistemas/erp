      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAchou = False
For Each Order EmpCod,FilCod,CreCod,CreRecPag
    Where EmpCod = &EmpCod     // Empresa
	Where FilCod = &RemFilCod  // Filial
	Where CreCod = &RemCreSeq  // Sequencia
	Where CreRecPag = 'R'      // Duplicata a Receber
	where CreSts <> Status_Duplicata.CANCELADA
	&IsAchou = True
	&FilCod = FilCod
	&CreCod = CreCod
	Exit
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
