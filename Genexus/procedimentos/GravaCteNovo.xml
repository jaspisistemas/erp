        <Source><![CDATA[
For each Order EmpCod,FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilRNTRC = FilRNTRC
	Exit
EndFor
	
//Inicia Novo CT-e	
&FilBasImp = RetornaFilialBaseImposto.Udp(&EmpCod, &FilCod)
&HojeData = serverdate()
&CteCod = UltimoCodigoEmpresa.Udp(domParCod.CTE, &EmpCod, &FilCod)

//######################################### Lcto Padrao #############################
if &sdtCte.CteLctCod.IsEmpty()
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon098_LctoCte, &CfgVlr)
	&CteLctCod = val(&CfgVlr)
	
	If &CteLctCod = 0
		RetornaConfSistema.Call(&EmpCod, &WwpContextFiLCod, domConfSistema.TCon019_LctoOrcamento, &CfgVlr)
		&CteLctCod = val(&CfgVlr)
	EndIf
else
	&CteLctCod = &sdtCte.CteLctCod
Endif

//#####################################################################################

	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		
		//remetente
		CteRemCod = &CteRemCod
		CteRemRaz = &CteRemRaz
		CteRemCnpj = &CteRemCnpj
		CteRemCpf = &CteRemCpf
		CteRemIns = &CteRemInsEst
		CteRemFan = &CteRemFan
		CteRemFon = &CteRemFon
		CteRemLog = &CteRemLog
		CteRemNro = &CteRemNro
		CteRemCpl = &CteRemCpl
		CteRemBai = &CteRemBai
		CteRemCidCod = &CteRemCidCod
		CteRemCidNom = &CteRemCidNom
		CteRemUfe = &CteRemUfe
		CteRemCep = &CteRemCep
		CteRemPaiCod = &CteRemPaiCod
		CteRemPaiNom = &CteRemPaiNom
		CteRemEml = &CteRemEml
		
		CteIniUfe = &CteRemUfe
		CteIniCidCod = &CteRemCidCod
		CteIniCidNom = &CteRemCidNom
		
		// Valida/Busca Cadastro do Destiantario e se nao tiver ja vai cadastrar
		CteDesCod = &CteDesCod
		CteDesRaz = &CteDesRaz
		CteDesCnpj = &CteDesCnpj
		CteDesCpf = &CteDesCpf
		CteDesIns = &CteDesIns
		CteDesRaz = &CteDesRaz
		CteDesFon = &CteDesFon
		CteDesLog = &CteDesLog
		CteDesNro = &CteDesNro
		CteDesCpl = &CteDesCpl
		CteDesBai = &CteDesBai
		CteDesCidCod = &CteDesCidCod
		CteDesCidNom = &CteDesCidNom
		CteDesUfe = &CteDesUfe
		CteDesCep = &CteDesCep
		CteDesPaiCod = &CteDesPaiCod
		CteDesPaiNom = &CteDesPaiNom
		CteDesEml = &CteDesEml
		CteDesSuf = &CteDesSuf
		
		CteTerUfe = &CteDesUfe
		CteTerCidCod = &CteDesCidCod
		CteTerCidNom = &CteDesCidNom
	 	
		if &sdtCte.CteModCod = '67' //OS
			CteTomSer = Tomador.Outros  //Tomador
		Else
			CteTomSer = Tomador.Remetente  //Tomador
		Endif
	
		CteProTer    = Nota_ProPriaTerceira.PROPRIA
		CteModCod    = &sdtCte.CteModCod
		 
		CteCarVlrTot = 0
		//CteNum       = &CteNum
		//CteSer       = &CteSer
		 
		CtePosDocAnt = Status_SimNao.Nao
		CteTipSer    = &sdtCte.CteTipSer
		CteMod       = modalCte.Rodoviario
		CteindGlo    = False
		CteFinEms    = &sdtCte.CteFinEms
		
		If CteObsGer.Trim().IsEmpty()
			CteObsGer = &ObsNom.ToUpper()
		EndIf
		
		CteAnoEms = Year(ServerDate())
		CteMesEms = Month(ServerDate())
		CteDtaEms    = ServerDate()
		CteHorEms    = ServerTime()
		CteIndRec    = IndicaRecebedor.Nao
		CteIndRecDes = ' '
		
		RetornaConfSistema.Call(&EmpCod, &WwpContextFiLCod, domConfSistema.TCon073_NbsPadraoCte, &CfgVlr)
		&CteNcmCod = val(&CfgVlr)
		CteNcmCod    = &CteNcmCod
		Do 'GetNBS'
		
		CteModRodRNTRC = &FilRNTRC
		CteImpAliTotTri = 0
		CteLctCod    = &CteLctCod
		
		CteCfop      = &CteCfop
		CteNatOpe    = &ImpCfoNom
		CteImpCst    = &CteImpCst
		CteConSplNac = &CteConSplNac
		CteImpAli    = &CteImpAli
		CteImpPerRed = &CteImpPerRed
		
		// ##############   procura alguma placa na obs da nfe
		//		If not &TNFeProc.NFe.infNFe.infAdic.infCpl.Trim().IsEmpty()
		//			&LongvarcharMB15 = &TNFeProc.NFe.infNFe.infAdic.infCpl
		//			
		//			for &varchar in regexMatches(&LongvarcharMB15,'\b[A-Z]{3}(?:[\s-]*[A-Za-z0-9]+)')
		//				&placa = &varchar
		//				do 'retornaSoNumeroAndLetra'
		//				do 'validaPlaca'
		//				if &isContinua
		//					CtePlc = &placa
		//				else
		//					&placa.SetEmpty()
		//				endif
		//			endfor
		//		EndIf
		//########################################################
		
		CteEnvEml    = NfeEnvEml.Pendente
		CteSts       = Status_NFe.Importada //JDF importada
		CteAveApo = ''
		CteAveArq = ''
		CteAveCnpjSeq = ''
		CteAveDta.SetEmpty()
		CteAveNro = ''
		CteAveProt = ''
		CteAveSts = Status_NFe.Digitando
		
	EndNew

	Commit
	
	
Sub 'GetNBS'

	For each order NcmCod
		Where NcmCod = &CteNcmCod
		&CteNcmDes = NcmDes
		Exit
	EndFor

EndSub
