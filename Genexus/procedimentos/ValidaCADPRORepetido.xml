      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensg = ''
&IsErro = False
For Each Order EmpCod, PrpSts,PrpCod
	Where EmpCod = &EmpCod
	Where PrpSts = Status_Propriedade.Ativa
	Where PrpIns = &PrpIns when &PrpIns <> 'ISENTO'
	&Mensg = 'Propriedade: '+ trim(str(PrpCod)) + ' já cadastrada com esse CAD-PRO. Verifique e apenas vincule o cliente.'
    &IsErro = true
    exit
EndFor
]]></Source>
