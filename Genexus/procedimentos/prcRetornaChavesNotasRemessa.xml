      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, (NfeCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
	Where NfeSts = Status_Nfe.Autorizada
	Where NfeLctTip in (TipoLancamento.RemessaEntrada, TipoLancamento.RemessaSaida)
	
	If NfeLctTip = TipoLancamento.RemessaSaida
		&sdtNotasReferenciadasItem = new()
		&sdtNotasReferenciadasItem.NfeDocRefNfe = retornasoNumeros.Udp(NfeChv)
		&sdtNotasReferenciadasItem.NfeDocRefMod = Substr(&sdtNotasReferenciadasItem.NfeDocRefNfe, 21, 2)
		&sdtNotasReferenciadas.Add(&sdtNotasReferenciadasItem)
	Else
		Exit
	Endif
EndFor	
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
