      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&LogGUID = guid.NewGuid()

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	For Each Order DeviceId, DevRandon, DevTabCod
		Where DevRandon = &DevRandon
		Where DevTabCod = &DevTabCod
		//	DeviceId
		//	DevRandon
		//	DevTabCod
		&DevTabAtu = DevTabAtu
	 	&DevTabDtaUltSync = DevTabDtaUltSync
		Exit
	When none
		For Each Order DeviceId, DevRandon
			Where DevRandon = &DevRandon
			
			new
				DeviceId = DeviceId
				DevRandon = &DevRandon
				DevTabCod = &DevTabCod
			 	DevTabDtaUltSync.SetEmpty()
				DevTabAtu = true
				&DevTabDtaUltSync = DevTabDtaUltSync
				&DevTabAtu = true
			EndNew
			
			Exit
		EndFor
	
		commit
	EndFor
	
Endif

Sub 'subException_handler'
	
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'subException_handler','subException_handler')
	
EndSub

Sub 'subError_handler'
	
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'subError_handler','subError_handler')
	
EndSub
]]></Source>
