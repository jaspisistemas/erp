      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	CtePosDup = Status_SimNao.Sim
	Exit
EndFor

&CteDupCod = 0
For Each Order EmpCod,FilCod,CteCod,(CteDupCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	&CteDupCod = CteDupCod
	exit
EndFor
&CteDupCod+=1

New
	EmpCod = &EmpCod
	FilCod = &FilCod
	CteCod = &CteCod
	CteDupCod = &CteDupCod
	CteDupNro = &CteDupNro
	CteDupDtaVct = &CteDupDtaVct
	CteDupVlr = &CteDupVlr
	Msg('Duplicata gravada com sucesso!')
EndNew
]]></Source>
