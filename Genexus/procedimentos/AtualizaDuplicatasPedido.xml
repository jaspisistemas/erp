      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedStsGer = Pedido_Gerado.PDV
	
	Exit
When none
	For Each Order EmpCod, FilCod, CrePedCod
		Where EmpCod 	= &EmpCod
		Where FilCod    = &FilCod
		Where CrePedCod = &PedCod
		Where CreSts <> Status_Duplicata.CANCELADA
		
	    CreVenCod = &PedVenCod
		CreCliCod = &PedCliCod
		If &CreFilPgt.IsEmpty()
			CreFilPgt = 1
		Else
			CreFilPgt = &CreFilPgt
		EndIf
		&CheCreCod = CreCod
		
		if CreFrpPgtoTip = TipoDuplicata.CHEQUEP or CreFrpPgtoTip = TipoDuplicata.CHEQUET
			&CreCheCod = CreCheCod
			do 'AtualizaCheque'
		Endif
	EndFor
	
	commit	
EndFor

sub 'AtualizaCheque'
	if &CreCheCod  <> 0
		For Each ORder EmpCod, CheCod
			Where EmpCod = &EmpCod
			Where CheCod = &CreCheCod
			CheCreCliCod = &PedCliCod
			if CheCreCod.IsEmpty() or CheCreCod.IsNull()
				CheCreFilCod = &FilCod
				CheCreCod = &CheCreCod
			Endif
		
			Exit
		Endfor
	Endif
EndSub

]]></Source>
