      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, CTrCod
	Where EmpCod = &EmPCod
	
	if &IsDeletou = true
		if &LogErpTabIsLog = true //GRAVA LOG
			prcGravaLog_CentroTrabalho.Call(&LogErpRegTip, &EmpCod, &FilCod, &CTrCod, &Pgmname, &WWpContextUserName, &SdtLogAtributos)
		Endif
	endIf
	&IsDeletou = false
	
	&CtrCod= CTrCod
	do 'localizaEtapa'
	if &IsTemUm = false
		//GRAVAR LOG
		&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmPCod, 'CENTROTRABALHO')
		if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
			&LogErpRegTip = TrnMode.Delete
			prcCarregaLog_CentroTrabalho.Call(&EmpCod, &CTrCod, &SdtLogAtributos)
		Endif
		
		&IsDeletou = true
		
		delete
	EndIf
	
EndFor

Commit

if &IsDeletou = true
	if &LogErpTabIsLog = true //GRAVA LOG
		prcGravaLog_CentroTrabalho.Call(&LogErpRegTip, &EmpCod, &FilCod, &CTrCod, &Pgmname, &WWpContextUserName, &SdtLogAtributos)
	Endif
endIf



Sub 'localizaEtapa'
	&IsTemUm = false
	For Each Order EmpCod, GrupCod, GrupCTrOrd
		Where EmpCod = &EmPCod
		Where GrupCTrCod = &CtrCod
		&IsTemUm = true
		Exit
	EndFor

EndSub

]]></Source>
