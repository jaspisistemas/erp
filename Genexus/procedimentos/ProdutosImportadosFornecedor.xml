      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &IsZerarTabela  = True
	Do 'ZeraTabela'
EndIf


&Total = &SdtProdutoFornecedor.Count + 10
&Count = 5
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&Count += 5
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

	
For &SdtProdutoFornecedorItem in &SdtProdutoFornecedor
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	If &SdtProdutoFornecedorItem.Erro = 'N'
		
		&ProCod    = &SdtProdutoFornecedorItem.ProCod
		&ProForDsc = &SdtProdutoFornecedorItem.ProForDsc
		&ProForAcr = &SdtProdutoFornecedorItem.ProForAcr
		&ProForRatDsc = &SdtProdutoFornecedorItem.ProForRatDsc
		&ProForRatAcr = &SdtProdutoFornecedorItem.ProForRatAcr
		
		&ProForIpi = &SdtProdutoFornecedorItem.ProForIpi
		&ProForQtdEmb = &SdtProdutoFornecedorItem.ProForQtdEmb
		&ProForVlrCus = &SdtProdutoFornecedorItem.ProForVlrCus
		&ProForProCod = &SdtProdutoFornecedorItem.ProForProCod
		&ProForIcmsSt = &SdtProdutoFornecedorItem.ProForIcmSt
		
		Do 'GetProduto'
		
		
		GravaProdutoFornecedor.Call(&EmpCod,&ProCod,&PesCod,&ProForIcmsSt,&ProForDsc,&ProForQtdEmb,&ProForVlrCus,&ProForProCod, '', &ProForAcr, &ProForIpi, &ProForIcm, &ProForRatDsc, &ProForRatAcr, &Mensagem)
		ProVlrCus_Produto.Call(&EmpCod, &ProCod)
	EndIF
EndFor

  
&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
	
	&ProCod    = 0
	&ProForCod = 0
	&ProForDsc = 0
	&ProForAcr = 0
	&ProForRatDsc = 0
	&ProForRatAcr = 0
	&ProForIpi = 0
	&ProForIcm = 0
	&ProForQtdEmb = 0
	&ProForVlrCus = 0
	&ProForProCod = ''
	&ProForIcmsSt = 0
EndSub

Sub 'ZeraTabela'
	For each Order EmpCod,ProForCod
		Where EmpCod = &EmpCod
		Where ProForCod = &PesCod
		Delete
	EndFor
EndSub

Sub 'GetProduto'
	For each Order EmpCod,ProForCod,ProCod
		Where EmpCod = &EmpCod
		Where ProForCod = &PesCod
		Where ProCod = &ProCod
		If &IsCustoUnt = False 
			&ProForVlrCus = ProForVlrCus
		EndIf
		
		If &IsQtdEmb = False
			&ProForQtdEmb = ProForQtdEmb
		EndIf 
		
		If &IsDesconto = False
			&ProForDsc = ProForDsc
		EndIf	
		
		If &IsAcrescimo = False
			&ProForAcr = ProForAcr
		EndIF
		
		If &IsNewDesconto = False
			&ProForRatDsc = ProForRatDsc
		EndIf	
		
		If &IsNewAcrescimo = False
			&ProForRatAcr = ProForRatAcr
		EndIF
	
		If &IsSt = False
			&ProForIcmsSt = ProForIcmSt
		EndIf
		
		If &IsIpi = False
			&ProForIpi = ProForIpi
		EndIF
	
	
		Exit
	Endfor
EndSub
]]></Source>
