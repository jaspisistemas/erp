      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PedDtaFat.SetEmpty()
&PedHorFat.SetEmpty()
For Each Order EmpCod, ProCod, PedSts,LctTip, LctAtuFor,(PedDtaFat)
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where PedSts = Status_Pedido.FECHADO
	Where LctTip = TipoLancamento.EntradaMercadoria
	Where LctAtuFor = Status_SimNao.Sim
	&PedDtaFat = PedDtaFat
	if PedHorFat.IsEmpty() or PedHorFat.IsNull()
		&PedHorFat = '00:00:00'
	Else
		&PedHorFat = TtoC(PedHorFat,0,8)
	EndIF
	Exit
EndFor


&SoNumeros = RetornaSoNumeros.Udp(&PedHorFat)
&ValHora = val(&SoNumeros)

For Each Order EmpCod, ProCod, (ProCusCod)
	where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&SoNumeros = RetornaSoNumeros.Udp(ProCusHor)
	&ValNova = val(&SoNumeros)
	
	if ProCusDta >= &PedDtaFat
		if (&ValNova >= &ValHora) or ProCusDta > &PedDtaFat //JDF adicionei o OR por que se for data menor nao precisa verificar a hora.
			&ProVlrUltCmp = ProCusVlr
		Endif
	EndIF

	Exit
EndFor
]]></Source>
