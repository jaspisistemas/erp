      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each ORder EmpCod, ProCod, ProForCod 
	Where EmpCod = &EmpCodDestino
	Where ProForCod = &PesCodDestino
	Where ProCod = &ProCodDestino
	
	ProForProCod = &ProRefOrigem
	Exit
When None
	New
		EmpCod = &EmpCodDestino
		ProForCod = &PesCodDestino
		ProCod = &ProCodDestino		
		ProForProCod = &ProRefOrigem
	EndNew

Endfor

Commit
	

prcRemoveVinculoProduto.Call(&EmpCodDestino, &ProCodDestino, &PesCodDestino, &ProRefOrigem)
]]></Source>
