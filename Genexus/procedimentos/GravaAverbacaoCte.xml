      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	CteAveArq = &SdtRetornoAverbacao.ToXml()
	If CteSts = Status_NFe.Autorizada
		CteAveSts = Status_NFe.Autorizada
	Else
		CteAveSts = Status_NFe.Cancelada
	EndIf
	
	CteAveDta = &SdtRetornoAverbacao.Averbado.dhAverbacao
	CteAveProt = &SdtRetornoAverbacao.Averbado.Protocolo
	
	Msg('Averbado com Sucesso! Protocolo: '+ trim(&SdtRetornoAverbacao.Averbado.Protocolo ))
	For &SdtRetornoAverbacaoDadosSeguro in &SdtRetornoAverbacao.Averbado.DadosSeguro
		&CteAveCnpjSeq = &SdtRetornoAverbacaoDadosSeguro.CNPJSeguradora
		&CteAveApo = &SdtRetornoAverbacaoDadosSeguro.NumApolice
		&CteAveNro = &SdtRetornoAverbacaoDadosSeguro.NumeroAverbacao
	EndFor
	
	CteAveNro = &CteAveNro
	CteAveCnpjSeq = &CteAveCnpjSeq
	CteAveApo = &CteAveApo
EndFor


commit

&mensagem = ''

For &SdtRetornoAverbacaoInfos in &SdtRetornoAverbacao.Infos
	&mensagem = &SdtRetornoAverbacaoInfos.Codigo +' - '+ &SdtRetornoAverbacaoInfos.Descricao
	If not &mensagem.IsEmpty()
		msg(&mensagem)
	EndIf
EndFor
]]></Source>
