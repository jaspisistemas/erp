      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Mensagem.SetEmpty()
For Each Order EmpCod, FilCod, NfeCod, NfeItmCod, NfeProLotCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	Where NfeItmCod = &NfeItmCod
	
	&NfeProLotCod = trim(toformattedString(NfeProLotVct))
	
	if (NfeProLotCod <> '#SEM_LOTE' and not NfeProLotCod.IsEmpty()) or not NfeProLotVct.IsEmpty()
		if &Mensagem.IsEmpty()
			if NfeProLotCod = '#SEM_LOTE'
				&Mensagem += 'LT:' + trim(toformattedString(NfeProLotVct))
			Else				
				&Mensagem += 'LT:' + trim(NfeProLotCod)
			EndIF
			
			if not NfeProLotVct.IsEmpty() and (&NfeProLotCod <> NfeProLotCod) and (NfeProLotCod <> '#SEM_LOTE')
				&Mensagem += ' ' + trim(toformattedString(NfeProLotVct))
			Endif
			
			//			&PedQtd = PedQtd
			&Mensagem += ' QTD: ' + trim(toformattedString(NfeProLotQtd))
		Else
			//			If &PedQtd > 0
			//				&Mensagem += ' QTD: ' + trim(toformattedString(&PedQtd))
			//				&PedQtd = 0
			//			Endif
			
			if NfeProLotCod = '#SEM_LOTE'
				&Mensagem += '; LT:' + trim(toformattedString(NfeProLotVct))
			Else				
				&Mensagem += '; LT:' + trim(NfeProLotCod)
			EndIF
			if not NfeProLotVct.IsEmpty() and (&NfeProLotCod <> NfeProLotCod) and (NfeProLotCod <> '#SEM_LOTE')
				&Mensagem += ' ' + trim(toformattedString(NfeProLotVct))
			Endif
			&Mensagem += ' QTD: ' + trim(toformattedString(NfeProLotQtd))
		Endif
	Endif
EndFor

]]></Source>
