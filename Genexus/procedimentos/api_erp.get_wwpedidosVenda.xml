      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif

	&wwPedidos.qtd = 0

	&wwPedidos.pA = '0'
	&wwPedidos.pT = '0'
	&wwPedidos.p1 = '0'
	&wwPedidos.p2 = '0'
	&wwPedidos.p3 = '0'
	&wwPedidos.p4 = '0'
	&wwPedidos.p5 = '0'
	&IsPaginaOk = false
	
	if not &parPedSts.IsEmpty() and &parPedSts <> 'T'
		&PedSts.FromString(&parPedSts)
	Endif
	if not &parPedStsFin.IsEmpty() and &parPedStsFin <> 'T'
		&PedStsFin.FromString(&parPedStsFin)
	Endif	
	
	TimestampToDate.Call(&PedDtaEmsIniTmpSec, &PedDtaEmsIni)
	TimestampToDate.Call(&PedDtaEmsFinTmpSec, &PedDtaEmsFin)
		
	For Each 
		Order EmpCod, FilCod, (PedDtaEms), (PedCod) when &Ordem = 'ED' or &Ordem.IsEmpty()
		Order EmpCod, FilCod, PedDtaEms, PedCod when &Ordem = 'ES'
		
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod When not &PedCod = 0
		Where (PedSts = &PedSts or ((&parPedSts.IsEmpty() or &parPedSts = 'T') and PedSts <> Status_Pedido.CANCELADO)) or &PedCod <> 0
		Where (PedStsFin = &PedStsFin or &PedStsFin.IsEmpty()) or &PedCod <> 0
		Where PedDtaEms >= &PedDtaEmsIni and PedDtaEms <= &PedDtaEmsFin when &PedCod = 0
		Where PedCliCod = &PedCliCod when not &PedCliCod.IsEmpty() and &PedCod = 0
		Where PedCliRaz like &PedCliRaz when not &PedCliRaz.IsEmpty() and &PedCod = 0
		Where PedFatFilCod = &PedFatFilCod or (PedFatFilCod.IsNull() or PedFatFilCod.IsEmpty() and &PedFatFilCod = 1) when not &PedFatFilCod.IsEmpty()
		Where (LctTip = TipoLancamento.OrcamentoVenda or LctTip = TipoLancamento.SaidaMercadoria) and PedStsGer <> Pedido_Gerado.AgruparFaturar
		Where LctAtuSal = Status_entradaSaida.Saida
		Where PedBlq = Status_SimNao.Nao
		
		if &IsPaginaOk = false
			if &TestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwPedidos.qtd = 0
					&wwPedidos.Pedidos.Clear()
					&TestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				
				&wwPedidos.qtd += 1
				&wwPedidosItem = new()
				&wwPedidosItem.FilCod = FilCod
				&wwPedidosItem.PedCod = PedCod
				
				&wwPedidos.Pedidos.Add(&wwPedidosItem)
			Endif
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&TestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwPedidos.pA = trim(str(&Pagina))
		&wwPedidos.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwPedidos.p1, &wwPedidos.p2, &wwPedidos.p3, &wwPedidos.p4, &wwPedidos.p5)
		
		For &wwPedidosItem in &wwPedidos.Pedidos
			For Each Order EmpCod, FilCod, PedCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &wwPedidosItem.FilCod
				Where PedCod = &wwPedidosItem.PedCod
				
				&wwPedidosItem.LctCod = LctCod
				&wwPedidosItem.LctNom = LctNom
				&wwPedidosItem.PedCliCod = PedCliCod
				&wwPedidosItem.PedCliRaz = PedCliRaz
				&wwPedidosItem.PedCod = PedCod
				&wwPedidosItem.PedDtaEms = trim(PedDtaEms.ToFormattedString())
				&wwPedidosItem.PedDtaFat = trim(PedDtaFat.ToFormattedString())
				&wwPedidosItem.PedDtaPrv = trim(PedDtaPrv.ToFormattedString())
				
				&wwPedidosItem.PedSts = PedSts
				&wwPedidosItem.PedStsFin = PedStsFin
				
				&wwPedidosItem.PedNovStsNom = PedNovStsNom
				&wwPedidosItem.PedNovStsFinNom = PedNovStsFinNom
				
				&Varchar = trim(PedVlrLiq.ToFormattedString())
				retiraZerosDepoisVirgulaxCasas.Call(2,&Varchar,&Varchar)
				&wwPedidosItem.PedVlrLiq = &Varchar
				
				if &PedNovStsCod <> PedNovStsCod
					&PedNovStsCod = PedNovStsCod
					&StsCod = PedNovStsCod
					do 'getStatusCor'
					&EstoqueStsHex = &StsHex
					&wwPedidosItem.StsHex = &EstoqueStsHex
				Else
					&wwPedidosItem.StsHex = &EstoqueStsHex
				Endif
				
				if &PedNovStsFinCod <> PedNovStsFinCod
					&PedNovStsFinCod = PedNovStsFinCod
					&StsCod = PedNovStsFinCod
					do 'getStatusCor'
					&FinanceiroStsFinHex = &StsHex
					&wwPedidosItem.StsFinHex = &FinanceiroStsFinHex
				Else
					&wwPedidosItem.StsFinHex = &FinanceiroStsFinHex
				Endif
				
			EndFor
		EndFor
	
	Endif


Else
	&wwPedidos.sts = 'E001'
	&wwPedidos.Obs = 'Acesso não Concedido!'
Endif

Sub 'getStatusCor'
	For Each Order EmpCod, StsCod
		Where EmpCod = &wwpContext.EmpCod
		Where StsCod = &StsCod
		
		&StsHex = StsHex
		&StsHex = &StsHex.ToLower()
		exit
	EndFor
EndSub
]]></Source>
