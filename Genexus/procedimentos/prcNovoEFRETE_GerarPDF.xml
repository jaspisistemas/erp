      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[// O conteúdo da tag Integrador deve ser uma CONSTANTE, pois é ela quem identifica seu sistema de gestão,
//Suporte e-FRETE:	Seguem credenciais para uso em ambiente de homologação:
//Integrador:		JASPI SISTEMAS DE INFORMÁTICA
//CNPJ:				21826923000177
//Usuário:			usuario@jaspi
//Senha:			usuario#jaspi
//Hash:				b754b48e-8c22-4cfc-bb0a-3524a76284c9

LoadWWPContext(&Context)
//Config do Servidor
HostWebServiceEfrete.Call(&EmpWebHost, &ExecuteUrl, '', '', &Hash)
&ExecuteUrl			+= 'Pef/ObterOperacaoTransportePdf'

&HttpClient.Host	= 	&EmpWebHost
&HttpClient.Secure	= 	1

//Header do Xml
&HttpClient.AddHeader(!'Content-Type', !'application/json')
&HttpClient.AddHeader(!'Accept-Encoding', !'gzip, deflate, br')

//Corpo do Xml
&XmlBody 	= 	'{'
&XmlBody	+=	'    "CodigoIdentificacaoOperacao": "'+ Trim(&OpeNroCiot)+'",'
If Not &Token.IsEmpty()
	&XmlBody	+=	'	 "Token": "' + Trim(&Token) + '",'
EndIf
&XmlBody	+=	'	 "Integrador": "'+ &Hash.Trim() +'",'
&XmlBody	+=	'	 "Versao": "1"'
&XmlBody	+=	'}'

//Realiza o Envio ao WebService
&HttpClient.AddString(Trim(&XmlBody))
&HttpClient.Execute('POST',&ExecuteUrl)

//Grava o Envio ao padrão usuário
padraoUsuario.Call('G', '#EFRETEGERARPDF', &Context.PesCod, &Context.EmpCod, &XmlBody, &PadDtaMod)

If &HttpClient.StatusCode = 200
	
	&XmlBody 		= &HttpClient.ToString()	
	&PosicaoSucesso = StrSearch(&XmlBody, '"Sucesso"')
	&PosicaoSucesso = &PosicaoSucesso + 11
	
	&Status 		= SubStr(&XmlBody, &PosicaoSucesso, 4)
	
	If &Status = 'true'
		&PosicaoSucesso = StrSearch(&XmlBody, '"Pdf"')
		&PosicaoSucesso = &PosicaoSucesso + 8
		
		&PosicaoFinal	= StrSearch(&XmlBody, '"Versao"')
		&PosicaoFinal	= &PosicaoFinal - &PosicaoSucesso - 6
		
		&ReceivePDF		= SubStr(&XmlBody, &PosicaoSucesso, &PosicaoFinal)
		Do 'GravaPDF'
		padraoUsuario.Call('G', '#EFRETEGERARPDFRESPOSTA', &Context.PesCod, &Context.EmpCod, &XmlBody, &PadDtaMod)
		
		RetornaConfiguracoesPastas.Call(&Context.EmpCod, &Context.FilCod, &SdtConfiguracoesPasta)
		&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempFis + 'CIOT' + Trim(SubStr(&OpeNroCiot,1, 12)) +'.pdf'
		&File.Source = &NomeArquivo
		If &File.Exists()
			&File.Delete()
		EndIf
		
		&File2.Source = &NomeArquivo
		If Not &File2.Exists()
			&File2.FromBase64String(&ReceivePDF)
			&File2.Create()
			&File2.Close()
		EndIf	
		
		&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempVir+ 'CIOT' + Trim(SubStr(&OpeNroCiot,1, 12))+'.pdf'

	Else
		
		&PosicaoSucesso = StrSearch(&XmlBody, '"Mensagem"')
		&PosicaoSucesso = &PosicaoSucesso + 13
		
		&PosicaoFinal	= StrSearch(&XmlBody, '"Codigo"')
		&PosicaoFinal	= &PosicaoFinal - &PosicaoSucesso - 8
		&Status			= SubStr(&XmlBody, &PosicaoSucesso, &PosicaoFinal)
		
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Obter-PDF!", 'Ocorreu um erro ao gerar o PDF. ERRO: '+ Trim(&Status), DVMessageType.error, "", DVMessageBoolean.True,""))
		padraoUsuario.Call('G', '#EFRETEGERARPDFRESPOSTA', &Context.PesCod, &Context.EmpCod, &Status, &PadDtaMod)	
	EndIf
	
Else
    msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Obter-PDF!!", &HttpClient.StatusCode.ToString() + ": " + &HttpClient.ErrDescription, DVMessageType.error, "", DVMessageBoolean.True,""))
EndIf

&HTTPStatus	= &HTtpClient.StatusCode

Sub 'GravaPDF'
	
	For Each Order EmpCod, FilCod, OpeCod
		Where EmpCod	= &Context.EmpCod
		Where FilCod	= &Context.FilCod
		Where OpeNroCiot= &OpeNroCiot
		
		OpeCiotPDF		= &ReceivePDF
		
		Commit
		Exit
	EndFor
	
EndSub
]]></Source>
