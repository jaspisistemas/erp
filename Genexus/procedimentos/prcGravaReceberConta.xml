      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//PEGA ULTIMO RECEBIMENTO DE PRODUTOS
&PedProPagDtaHor = serverNow()
For Each Order EmpCod, FilCod, PedCod, (PedProPagItm)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&PedProPagItm = PedProPagItm
	Exit
EndFor
&PedProPagItm += 1

//BAIXA ITENS DOS PEDIDOS
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	where PedItmPagIsSel = true
	
	&PedItmPagVlrSel = PedItmPagVlrSel
	&PedItmPagQtdSel = PedItmPagQtdSel
	PedItmPagVlrTot += &PedItmPagVlrSel
	PedItmPagVlrSel = 0
	PedItmPagQtdTot += &PedItmPagQtdSel
	PedItmPagQtdSel = 0
	PedItmPagIsSel = false
	&PedItmCod = PedItmCod
	do 'GravaPagamentoItem'

	Commit
EndFor


Sub 'GravaPagamentoItem'
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedItmCod = &PedItmCod
		PedProPagItm = &PedProPagItm
		PedProPagObs = '[PRODUTOS]'
		PedProPagVlr = &PedItmPagVlrSel	
		PedProPagQtd = &PedItmPagQtdSel
		PedProPagDtaHor = &PedProPagDtaHor
	EndNew
EndSub

]]></Source>
