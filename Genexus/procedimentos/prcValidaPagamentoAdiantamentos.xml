      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsErroAdiantamentos = false
&MensagemAdiantamentos = ''

For &sdtPagamentoFolhaAdiantamentosItem in &sdtPagamentoFolhaAdiantamentos
	&MovCod = &sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovCod
	&MovItmCod = &sdtPagamentoFolhaAdiantamentosItem.FPagAdiMovItmCod
	
	do 'verificaAberto'
	
	if &IsErroAdiantamentos = true
		Exit
	Endif
EndFor


sub 'verificaAberto'
	For each order EmpCod,MovCod,MovItmCod
		where EmpCod = &EmpCod
		where MovCod = &MovCod
		where MovItmCod = &MovItmCod
		
		if (MovSts = Status_Caixa.Cancelado) or (MovItmSts = Status_Caixa.Cancelado)
			&IsErroAdiantamentos = true
			&MensagemAdiantamentos = 'Adiantamentos: '+trim(Str(MovCod))+ ', selecionados com status de cancelado!'
			exit
		Endif
	
		Do CAse
			CAse MovFunSts = Status_AbertoFechado.Aberto
				Exit
			Case &FPagCod > 0
				do 'getPagamentoFolha'
			otherwise
				&IsErroAdiantamentos = true
				&MensagemAdiantamentos = 'Adiantamentos: '+trim(Str(MovCod))+ ', já selecionado em outro lançamento!'
			exit
		EndCase
		
		exit
	EndFor
EndSub


sub 'getPagamentoFolha'
	For Each Order EmpCod, FPagCod, FPagAdiMovCod, FPagAdiMovItmCod
		where EmpCod = &EmpCod
		Where FPagCod = &FPagCod
		Where FPagAdiMovCod = &MovCod
		Where FPagAdiMovItmCod = &MovItmCod
		Exit
	When None
		&IsErroAdiantamentos = true
		&MensagemAdiantamentos = 'Adiantamentos: '+trim(Str(&MovCod))+ ', já selecionado em outro lançamento!'
	EndFor
EndSub


]]></Source>
