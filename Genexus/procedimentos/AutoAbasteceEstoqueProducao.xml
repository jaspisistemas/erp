      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where ProAtuEst = true //AUTO ALIMENTAR ESTOQUE.
	//where PedQtd > EstQtd
	Exit
When none
	return
EndFor

&IsAchou = false
&IsModeloNovo = false

//CAPA ENTRADA PRODUÇÃO
For Each Order EmpCod, FilCod, PrdCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PrdDtaEnt = &PedDtaFat
	Where PrdObs = 'ENTRADA AUTOMATICA / VENDA DE KIT'	
	where PrdSts = Status_Pedido.FECHADO or PrdSts = Status_Pedido.ABERTO
	
	&PrdCod = PrdCod
	&PrdSts = PrdSts
	&IsAchou = true
	
	For Each Order EmpCod, FilCod, PrdCod, PrdKitPedCod 
		Where PrdKitPedCod = &PedCod
		if PrdKitPedItmCod > 0
			&IsModeloNovo = true	
		Endif
		Exit
	When None
		&IsModeloNovo = true	
	endFor

	Exit
when NONE
	UltimoCodigoEmpresa.Call(domParCod.ENTRADAPRODUCAO, &EmpCod, &FilCod, &PrdCod)
	
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		PrdCod = &PrdCod
		PrdDtaEnt = &PedDtaFat
		&PrdObs = 'ENTRADA AUTOMATICA / VENDA DE KIT'	
		PrdObs = &PrdObs
		
		PrdSts = Status_Pedido.ABERTO
	EndNew
EndFor

commit

If &IsAchou = true
	//AUTO ABASTECER
	if  &PrdSts = Status_Pedido.FECHADO
		if &IsModeloNovo = true //Precisa ser assim pois as receitas nao gravavam o pedido de origem.
			prcAbrirEntradaProducao_AutoAbastecer.Call(&EmpCod, &FilCod, &PrdCod, &PedCod, &PesCod)
		Else
			prcAbrirEntradaProducao.Call(&EmpCod, &FilCod, &PrdCod, &PesCod)
		Endif
	Endif

	//REMOVE ITENS DA ORDEM PRODUCAO
	For Each Order EmpCod, FilCod, PrdCod, PrdKitPedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PrdCod = &PrdCod
		Where PrdKitPedCod = &PedCod
		
		delete
	EndFor
	
	commit
Endif


//ADICIONAR OS KITS NA ENTRADA DA PRODUCAO
if &novoPedSts = Status_Pedido.FECHADO
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where ProAtuEst = true //AUTO ALIMENTAR ESTOQUE.
		Where ProEstTip <> TipoEstoque.NAO_ATUALIZA
		Where PedQtd > 0
		
		If EstQtd >= 0
			&PedQtd  = 0
		Else
			&estQtd = (EstQtd*-1)
			If &estQtd >= PedQtd
				&PedQtd = PedQtd
			Else
				&PedQtd = &estQtd
			EndIf
		Endif
		
		if &PedQtd > 0
			do 'localizaUltimoCodigo'
			
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				PrdCod = &PrdCod
				PrdItmCod = &PrdItmCod
				ProCod = ProCod
				ProGraCod = ProGraCod
				PrdItmQtd = &PedQtd
				PrdProEstQtd = EstQtd
				PrdProEstPrd = EstPrd
				PrdVlrUnt = PedVlrCus
				PrdKitPedCod = &PedCod
				if &IsModeloNovo = true
					PrdKitPedItmCod = PedItmCod
				Endif
			
			EndNEw
			
			commit
		Endif
		
	EndFor
Endif

//FECHA A ORDEM DE ENTRADA PRODUCAO
if &IsModeloNovo = true
	prcFechaEntradaProducao_AutoAbastecer.Call('',&EmpCod, &FilCod, &PrdCod, &PedCod, &PesCod, &PrdEntPedCod )
Else
	prcFechaEntradaProducao.Call('',&EmpCod, &FilCod, &PrdCod, &PesCod, &PrdEntPedCod)
Endif

sub 'localizaUltimoCodigo'
	&PrdItmCod = 0
	
	For Each Order EmpCod, FilCod, PrdCod, (PrdItmCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PrdCod = &PrdCod
		&PrdItmCod = PrdItmCod
		Exit
	EndFor
	
	&PrdItmCod += 1
EndSub
]]></Source>
