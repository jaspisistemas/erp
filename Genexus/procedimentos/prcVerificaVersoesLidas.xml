      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Numeric	= 0

For Each Order EmpCod, PesCod
	Where EmpCod	= &EmpCod
	Where PesCod	= &PesCod
	
	&PesIsLidVer	= PesIsLidVer
	
	Exit
EndFor

If &PesIsLidVer		= False
	For Each Order VerIsLid
		Where VerIsLid	= False
		
		&Numeric	   += 1
	EndFor
EndIf
]]></Source>
