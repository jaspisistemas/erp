      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 100
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
&Mensagem = ''
do 'Atualiza'


if &ExcluirImportar = 'N' //EXCLUIR TUDO
	For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where BalCod = &BalCod
		
		
		For Each Order EmpCod, FilCod, BalCod, ProCod, BalLotCod
			Delete
		EndFor

		Delete 
	EndFor
	
	Commit
Endif

&MensagemSucesso = ''

&ResultadoAbertura = DFROpen(&selectedURL, 400, '', '', 'ISO-8859-1')//Tenta abrir o arquivo								
If &ResultadoAbertura = 0
	Do while &ResultadoNext  = 0 
		&ResultadoLeitura    = DFRGTxt(&CampoUnico,400)
	
		If &ResultadoLeitura = 0
			
			&auxCount += 1
			if &auxCount = 200
				&CountPercent += 2
				If &CountPercent > 0
					&Percentual = round((&CountPercent / &Total) * 100, 0)
				EndIF
				If &Percentual >= 100
					&Percentual = 99
				EndIf
				do 'Atualiza'
				&auxCount = 0
			Endif
		
			//ENCONTROU INFORMACAO.
			&index = &CampoUnico.IndexOf(',', 1)
			&BalQtd = 0
			&ProRef.SetEmpty()
			&index -= 1
			&ProRef = Substr(&CampoUnico, 1, &index)
			&index += 2
			&valorQUantidade = Substr(&CampoUnico, &index, 20)
			RetornaSoNumeros.Call(&valorQUantidade, &valorQUantidade)
			&BalQtd = val(&valorQUantidade)
			
			if not &ProRef.IsEmpty() and &BalQtd > 0
				RetornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &proGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQTd, &ProBarQtd, &ErroMensagem)
				if &IsAchouProduto = true
					&Count += 1
					&QtdPecas += &BalQtd
					GravaProdutoBalanco.Call(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod, &BalQtd, &InseridoMensagem, &AtualizadoMensagem)
				Else
					&CountErro += 1
					&QtdPecasErro += &BalQtd
					&SdtProdutosItem = new()
					&SdtProdutosItem.ProNom = &ProRef
					&SdtProdutosItem.ProRef = trim(toformattedString(&BalQtd))
					&SdtProdutos.Add(&SdtProdutosItem)
				Endif
			Endif
		Endif
		
		&ResultadoNext =  DFRNext() 
	EndDo
Endif

if &CountErro > 0
	&MensagemErro = 'Não Localizado a quantia de: ' + trim(toformattedString(&CountErro)) + ' itens, num total de: ' + trim(toformattedString(&QtdPecasErro)) + ' quantidades'
EndiF

if &Count > 0
	&MensagemSucesso = 'Adicionado ao balanço a quantia de: ' + trim(toformattedString(&Count)) + ' itens, num total de: ' + trim(toformattedString(&QtdPecas)) + ' quantidades'
Endif


&Percentual = 100
&ProgressFin = serverNow()
&Mensagem = &SdtProdutos.ToJson()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &Mensagem
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &Mensagem
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
	
	for each Order ProgressId
		where ProgressId = 'ERRO'+&ProgressId
		ProgressLogXml = &MensagemErro
	When none
		new
			ProgressId = 'ERRO'+&ProgressId
			ProgressLogXml = &MensagemErro
		Endnew
	endfor
	
	commit
	
	for each Order ProgressId
		where ProgressId = 'SUCESSO'+&ProgressId
		ProgressLogXml = &MensagemSucesso
	When none
		new
			ProgressId = 'SUCESSO'+&ProgressId
			ProgressLogXml = &MensagemSucesso
		Endnew
	endfor
	
	commit
EndSub
]]></Source>
