      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizarTabelas, &wwpContext)

if &IsAcessoConcedido = true
	&sdtSetVersao.sts = 'J999'
	&sdtSetVersao.obs = 'Versão não localizada'
	
	//PRIMEIRA EMPRESA
	For Each Order EmpCod		
		&Varchar = RetornaSoNumeros.Udp(EmpVerSmartNew) //VERSAO LIBERADA
		&sdtSetVersao.versaoLib = &Varchar
		
		&Varchar = RetornaSoNumeros.Udp(EmpVerSmart) //VERSAO MINIMA LIBERADA
		&sdtSetVersao.versaoMin = &Varchar
		
		&sdtSetVersao.linkLocal = EmpSmartLink.Trim() //LINK GOOGLE PLAY OU LINK LOCAL
		
		&Varchar = retornaSoNumeros.Udp(EmpVerSmartNew) //Encrypt64(EmpVerSmartNew.Trim(), 'SY0J2OYM94HTM6LW0LFIC5AC28XHAUBQ')
		&sdtSetVersao.link =  'https://app2.jaspi.com.br/api_erp.build.aspx?'+trim(&Varchar)
		
		//			Case &OqueFazer = 'MESA'
		//				&sdtRetornoWbsEtc.sts = 'J200'
		//				&sdtRetornoWbsEtc.obs = ''
		//				&sdtRetornoWbsEtc.c1 = EmpVerMesas //VERSAO LIBERADA
		//				&sdtRetornoWbsEtc.c2 = EmpVerMesas //VERSAO MINIMA LIBERADA
		//				&sdtRetornoWbsEtc.c3 = EmpSmartLink.Trim() //LINK GOOGLE PLAY OU LINK LOCAL
		//				&sdtRetornoWbsEtc.c4 = format('https://app.jaspi.com.br/appjaspi/app/mesa/android_v%1.apk', EmpVerMesas.Trim())
		
		&sdtSetVersao.sts = 'J200'
		&sdtSetVersao.obs = 'Versão localizada'
	
		Exit
	EndFor
				
	//ATUALIZA TODOS OS DEVRANDON
	For Each Order DeviceId, DevRandon
		Where DevRandon = &DevRandon
		
		DevEmpCod = &wwpContext.EmpCod
		DevFilCod = &wwpContext.FilCod
		DevPesCod = &wwpContext.PesCod
		
		DevAppVerName = 'erp ' + &insdtSetVersao.appVerName
		DevAppBuildNumber = &insdtSetVersao.appBuildNumber
		DevAppVerApi = &insdtSetVersao.appVerApi
		
		if (&insdtSetVersao.devTipo > 0) 
			DeviceType = &insdtSetVersao.devTipo
		Endif
		
		if not &insdtSetVersao.devName.IsEmpty()
			PlatformName = &insdtSetVersao.devName
		ENdif
		
		if not &insdtSetVersao.devOSVersion.IsEmpty()
			DeviceOSVersion = &insdtSetVersao.devOSVersion
		Endif
		//DeviceInfo
	EndFor

	commit
Endif
]]></Source>
