      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&SaidaLongVarchar.SetEmpty()

for Each order EmpCod, PdvCod
	Where EmpCod = &EmpCod
	Where PdvRandon = &PdvRandon //PRA SABER SE É UM PDV VALIDO
	
	Exit
When none
	Return
EndFor


Do CAse
	CAse &PixMoeda <= 0
		&SdtRetornoPDV.Codigo = 401
		&SdtRetornoPDV.Mensagem = !"VALOR NAO INFORMADO"
		&SaidaLongVarchar = &SdtRetornoPDV.ToJson()
		Return
		
	CAse &CbrCod = 0 or &PedVenCod = 0 or &FilCod = 0 
		&SdtRetornoPDV.Codigo = 402
		&SdtRetornoPDV.Mensagem = !"ALGO ERRADO NAO ESTA CERTO"
		&SaidaLongVarchar = &SdtRetornoPDV.ToJson()
		Return
		
	Otherwise
	
		For Each Order EmpCod, FilCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			&FilFan = FilFan
			Exit
		EndFor
	
		
		//FAZER O OAUTH
		for Each Order EmpCod, CbrCod
			Where EmpCod = &EmpCod
			Where CbrCod = &CbrCod
			Where CbrCtaBanPixApi = 'P'
			Do CAse
				CAse CbrCtaBanBanCod = '077' //BANCO INTER
					
					&ContaCorrenteVarChar	= CbrNroCon.Trim() + CbrNroConDig.Trim()
					
					If CbrChaTraVct < ServerNow()
						prcOAuth_Inter.Call(EmpCod, &FilCod, &PedVenCod, &CbrCod, &AuxCbrChaTra, &OAuthMensagem )
						If &OAuthMensagem.IsEmpty()
						Else
							&SdtRetornoPDV.Codigo = 400
							&SdtRetornoPDV.Mensagem = !"Erro! " + &OAuthMensagem
							&SaidaLongVarchar = &SdtRetornoPDV.ToJson()
							Return
						EndIf
					Else
						&AuxCbrChaTra	= CbrChaTra		
					EndIf
					
					&PIX_Valor_VarChar										= Trim(ToFormattedString(&PixMoeda))
					&SdtEmitirCobrancaPIX_Inter.calendario.expiracao		= 28800
					&SdtEmitirCobrancaPIX_Inter.chave						= CbrCtaBanPix
					&SdtEmitirCobrancaPIX_Inter.valor.original				= StrReplace(&PIX_Valor_VarChar, ',', '.')
					&SdtEmitirCobrancaPIX_Inter.valor.modalidadeAlteracao	= 0
					&SdtEmitirCobrancaPIX_Inter.solicitacaoPagador			= &FilFan
					
					prcEmitirCobrancaPIX_Inter.Call(&EmpCod, &FilCod, &PedVenCod, &CbrCod, &AuxCbrChaTra, &ContaCorrenteVarChar, &SdtEmitirCobrancaPIX_Inter, &SdtEmitirCobrancaPIX_Inter_Response, &InterMensagem)
					
					If &InterMensagem.IsEmpty()
						&SdtRetornoPDV.Codigo = 200
						&SdtRetornoPDV.Mensagem = 'SUCESSO'
						&SdtRetornoPDV.Adicional1 = &SdtEmitirCobrancaPIX_Inter_Response.pixCopiaECola
						&SdtRetornoPDV.Adicional2 = &SdtEmitirCobrancaPIX_Inter_Response.txid
						&SaidaLongVarchar = &SdtRetornoPDV.ToJson()
					Else
						&SdtRetornoPDV.Codigo = 500
						&SdtRetornoPDV.Mensagem = !"Atenção! " + &InterMensagem
						&SaidaLongVarchar = &SdtRetornoPDV.ToJson()
						Return					
					EndIf			
			EndCase
		EndFor
Endcase
]]></Source>
