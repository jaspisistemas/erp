        <Source><![CDATA[

if &DestinoNfsCod > 0
	//APAGA ITENS DA NOTA Destino
	For Each Order EmpCod, NfsCod, NfsItmCod
		Where EmpCod = &EmpCod
		Where NfsCod = &DestinoNfsCod
		delete
	EndFor
	Commit
Endif


//GravaDadosCapa
For Each ORder EmpCod, NfsCod
	Where EmpCod = &EmpCod
	Where NfsCod = &OrigemNfsCod
	
	&NfsFilCod = NfsFilCod
	
	if &DestinoNfsCod = 0		
		&WizardData.Capa.NfsIntIs = NfsIntIs
		&WizardData.Capa.NfsIntCliCod = NfsIntCliCod
		&WizardData.Capa.NfsIntRaz = NfsIntRaz
		&WizardData.Capa.NfsIntFonNum = NfsIntFonNum
		&WizardData.Capa.NfsIntCNPJ = NfsIntCNPJ
		&WizardData.Capa.NfsIntCidCod = NfsIntCidCod
		&WizardData.Capa.NfsIntEml = NfsIntEml
		&WizardData.Capa.NfsCliCod = NfsCliCod
		&WizardData.Capa.NfsCliRaz = NfsCliRaz
		&WizardData.Capa.NfsCliFonNum = NfsCliFonNum
		&WizardData.Capa.NfsCliTipPes = NfsCliTipPes
		&WizardData.Capa.NfsCliCep = NfsCliCep
		&WizardData.Capa.NfsCliLog = NfsCliLog
		&WizardData.Capa.NfsCliNro = NfsCliNro
		&WizardData.Capa.NfsCliBai = NfsCliBai
		//		&WizardData.Capa.NfsCliCidCodNom = NfsCliCidCodNom
		&WizardData.Capa.NfsCliCidCod = NfsCliCidCod
		&WizardData.Capa.NfsCliCidIbge = NfsCliCidIbge
		&WizardData.Capa.NfsCliCidNom = NfsCliCidNom
		&WizardData.Capa.NfsCliCidUfCod = NfsCliCidUfCod
		&WizardData.Capa.NfsCliCpl = NfsCliCpl
		&WizardData.Capa.NfsCliEml = NfsCliEml
		&WizardData.Capa.NfsCliCnpj = NfsCliCnpj
		&WizardData.Capa.NfsCliInsEst = NfsCliInsEst
		&WizardData.Capa.NfsCliInsMun = NfsCliInsMun
		&WizardData.Capa.NfsCliCPF = NfsCliCPF
		&WizardData.Capa.NfsFilCod = NfsFilCod
		&WizardData.Capa.NfsDtaEms = serverDate()
		&WizardData.Capa.NfsHorEms = serverTime()
		&WizardData.Capa.NfsProTer = NfsProTer
		&WizardData.Capa.NfsNum = 0
		&WizardData.Capa.EmpCod = EmpCod
		&WizardData.Capa.NfsCod = 0
		&WizardData.Capa.NfsSer = ''
		&WizardData.Capa.NfsPedFilCod = 0
		&WizardData.Capa.NfsPedCod = 0
		&WizardData.Capa.NfsLctCod = NfsLctCod
		&WizardData.Capa.nfsTipEmi = TipoEmitenteNFSe.Prestador
		&WizardData.Capa.NfsTipNF = 'S'
		&WizardData.Capa.NfsPrsCidCod = NfsPrsCidCod
		
		prcGravaCApaNFSE.Call(&EmpCod, &DestinoNfsCod, &WizardData)
	Endif
	
	&WizardData.DadosNFSE.NfsNbs = NfsNbs
	&WizardData.DadosNFSE.NfsTribNac = NfsTribNac
	
	&WizardData.DadosNFSE.NfsDisSer = NfsDisSer
	&WizardData.DadosNFSE.NfsInfComp = NfsInfComp
	
	&WizardData.DadosNFSE.NfsItmValTot = NfsTotSer
	&WizardData.DadosNFSE.NfsTotDesc = NfsTotDesc
	
	For Each ORder EmpCod, NfsCod, NfsItmCod
		
		&WizardData.DadosNFSE.ProCod = NfsItmProCod
		&WizardData.DadosNFSE.ProGraCod = NfsItmProGraCod
		
		if &WizardData.DadosNFSE.NfsTribNac.IsEmpty()
			do 'GetProduto'
		Endif
		
		Exit
	EndFor
	
	prcGravaDadosNFSe.Call(&EmpCod, &DestinoNfsCod, &WizardData)
	
	Exit
EndFor

Sub 'GetProduto'
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &WizardData.DadosNFSE.ProCod
		
		&WizardData.DadosNFSE.NfsNbs = NcmCod
		&WizardData.DadosNFSE.NfsTribNac = ProTribNac
	
		Exit
	EndFor

EndSub

]]></Source>
