      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Mensagem = 'ADICIONADO MOTIVO: '
For Each Order EmpCod, CheCod
	Where EmpCod = &EmpCod
	Where CheCod = &CheCod
	
	if CheMot <> &CheMot
		&IsModificou = true
		CheMot = &CheMot
		
		&Mensagem += CheMot.EnumerationDescription()
		
		&CheCreCod = CheCreCod
		&CheCreFilCod = CheCreFilCod
	Endif

	Exit
EndFor


Commit

if &CheCreCod > 0 and &IsModificou = true
//	&Mensagem += ' ' 
	GravaCobranca.Call(&EmpCod, &CheCreFilCod, &CheCreCod, &Mensagem, 0, 0, &Data, &Hora, TipoObservacaoDuplicata.INTERNA)
Endif
]]></Source>
