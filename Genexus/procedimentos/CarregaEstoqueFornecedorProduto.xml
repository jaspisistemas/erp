      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&EstoqueFornecedor.Clear()

For Each	
	Order EmpCod, ProPadForCod, ProGraRefPadL when &Ordenar = 'C'
	Order EmpCod, ProPadForCod, ProNom when &Ordenar = 'N'	
	
	Where EmpCod = &EmpCod
	Where ProPadForCod  = &PesCod
	Where ProSetCod = &SetCod When not &SetCod.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &auxGrupHie when not &GrupHie.IsEmpty()
	Where ProTipDef = &ProTipDef when not &ProTipDef.IsEmpty()
	Where ProSts = &ProSts when not &ProSts.IsEmpty()
	where ProSts <> Status_Produto.EXCLUIDO when &ProSts.IsEmpty()
	
	&EstoqueFornecedorItm = new()
	&EstoqueFornecedorItm.EmpCod = EmpCod
	&EstoqueFornecedorItm.PesCod = ProPadForCod
	&EstoqueFornecedorItm.PesRaz = ProPadForRaz
	&EstoqueFornecedorItm.ProSetCod = ProSetCod
	&EstoqueFornecedorItm.GrupHie = GrupHie
	&EstoqueFornecedorItm.ProSts = iif(ProSts = Status_Produto.ATIVO, Status_AtivoInativo.ATIVO,Status_AtivoInativo.INATIVO)
	
	&EstAbc = ''
	&EstQtd = 0
	&EstCom = 0
	&EstVEn = 0
	&EstUltEnt.SetEmpty()
	&EstUltSai.SetEmpty()
	&EstSdo = 0
	&EstMIn = 0
	
	For Each Order EmpCod,ProCod,FilCod	
		Where FilCod = &FilCod
		&EstoqueFornecedorItm.ProGraRef = ProGraRef
		&EstoqueFornecedorItm.ProNomGra = ProNomGra
		&EstoqueFornecedorItm.ProCod = ProCod
		&EstoqueFornecedorItm.EstAbc_Ren = EstABC_Ren
		&EstoqueFornecedorItm.EstAbc_qtd = EstABC_Qtd
		&EstoqueFornecedorItm.EstQtd = EstQtd
		&EstoqueFornecedorItm.EstCom = EstCom
		&EstoqueFornecedorItm.EstVEn = EstVen
		If EstSug < 0
			&EstoqueFornecedorItm.EstSug = 0
		Else
			&EstoqueFornecedorItm.EstSug = EstSug
		EndIF
		&EstoqueFornecedorItm.EstSdo = (EstQtd + EstCom) - EstVen
		&EstoqueFornecedorItm.EstMIn = EstMin
		&EstoqueFornecedorItm.EstTotVen = EstMinVen
		If EstUltFab > EstUltEnt
			&EstoqueFornecedorItm.EstUltEnt = EstUltFab
		Else
			&EstoqueFornecedorItm.EstUltEnt = EstUltEnt
		EndIf
		&EstoqueFornecedorItm.EstUltSai = EstUltSai
		&EstQtd = EstQtd
		Exit
	EndFor
	If (&EstQtd > 0 and &ComEstoque = 'S' ) or (&EstQtd <= 0 and &ComEstoque = 'N' ) or &ComEstoque.IsEmpty()
		&EstoqueFornecedor.Add(&EstoqueFornecedorItm)
	EndIf
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
