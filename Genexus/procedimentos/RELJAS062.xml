      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&SdtPagamentoDuplicata.FromXml(&WebSession.Get('AnuenciaDP'))
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	&FilImg350_120 = FilImg_LogRel
	Exit
EndFor
&sdtCliente.Clear()
&SdtPagamentoDuplicata.Sort('CreCliCod')
For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata 
	&IsAchou = false
	If &TipoImpressao = 1  //1 - Agrupar 2 - individual
		For &sdtClienteItem in &sdtCliente
			If &sdtClienteItem.CreCliCod = &SdtPagamentoDuplicataItem.CreCliCod
				&IsAchou = true
				Exit
			EndIF
		EndFor
	EndIF
	
	If &IsAchou = false
		&sdtClienteItem = new()
		&sdtClienteItem.CreCliCod = &SdtPagamentoDuplicataItem.CreCliCod
		&sdtCliente.Add(&sdtClienteItem)
	EndIF	
EndFor

MB 4
MT 2

Header
	print Cabecalho
End
&Conteudo = ''
Do 'GetFilial'

For &sdtClienteItem in &sdtCliente
	&CreCliCod = &sdtClienteItem.CreCliCod
	Do 'getCliente'
	&titulo = 'OFICIAL DO CARTÓRIO DE PROTESTOS DA COMARCA DE ' + trim(&CidNom) + ' - ' + trim(&UfeCod)
	Print Titulo
	Do 'PrintConteudo'
	print TitDup
	
		
	For Each Order EmpCod, FilCod CreCod
		Where EmpCod = &EmpCod
		Where CreCod in &ColCreSeq
		
		&CreDupNro =  padL(trim(str(FilCod)),2, '0')+padl(trim(str(CreCod)),8, '0')
		
		print Duplicatas
	EndFor
	Print spacer
	&Conteudo2 = '          Declara, ainda, que nada tem a opor ao CANCELAMENTO do(s) protesto(s) de tal(is) título(s), conforme os termos da LEI 9.492 de 10.09.1997.'
	
	&AuxConteudo = GxGetMLi(&Conteudo2, 1, 80)
	print declaracao
	
	&AuxConteudo = GxGetMLi(&Conteudo2, 2, 85)
	print declaracao
	
	&AuxConteudo = GxGetMLi(&Conteudo2, 3, 85)
	print declaracao
	
	&Dtaporextenso = &FilcidNom.Trim()+ ', '+trim(str(day(&Today)))+' de '+ Cmonth(&Today)+ ' de '+trim(str(year(&Today)))
	&Dtaporextenso = &Dtaporextenso.ToUpper()
	Print assinatura
	Eject
EndFor

Sub 'GetFilial'
	For each Order EmpCod,FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &ImpFilCod
		
		&Conteudo = 'Pelo presente, a empresa ' + trim(FilRaz) + ', sediada à ' + trim(FilLog)
		&Conteudo += ', Nº ' +trim(FilNro) + ', cep ' + trim(FilCep) + ', na cidade de '+trim(FilCidNom)+', Estado do(a) '
		&Conteudo += trim(FilCidUfeNom) + ', inscrita no CNPJ Nº '+ trim(FilCpj) 
		
		If FilInsEst <> 'ISENTO'
			&Conteudo += ' e inscrição estadual nº ' +  trim(FilInsEst)
		EndIF
		&FilcidNom = FilCidNom
		&FilRaz = FilRaz
		&FilPesSoc = FilPesSoc
		Do 'SocioFilial'
		Exit		
	EndFor
EndSub

Sub 'getCliente'
	For Each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &CreCliCod
		&Conteudo += ', declara que dá plena e total quitação ao(s) débito(s) havido(s) contra a empresa'
		&Conteudo += ' ' + trim(PesRaz) + ' , sediada à '+ trim(PesCobLogNro.ToLower())
		+ ' bairro ' + trim(PesCobBai.ToLower()) + ' cep ' + trim(PesCobCep) + ' na cidade de ' +trim(PesCobCidNom) + ' Estado do(a) ' + trim(PesCobUfeCod) 
		
		If PesTip = 'J'
			&Conteudo += ' inscrita no CNPJ nº ' + trim(PesCnpj)
		Else
			&Conteudo += ' inscrita no CPF nº '  + trim(PesCpf)
		EndIF
		&Conteudo += ' representados pelo(s) título(s) protestado(s):'
		
		&CidNom = PesCobCidNom
		&UfeCod = PesCobUfeCod
		Exit
	EndFor
	
	&ColCreSeq.Clear()
	for &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
		If &SdtPagamentoDuplicataItem.CreCliCod = &CreCliCod
			&ColCreSeq.Add(&SdtPagamentoDuplicataItem.CreCod)
			
			If &TipoImpressao = 2
				&index = &SdtPagamentoDuplicata.IndexOf(&SdtPagamentoDuplicataItem)
				&SdtPagamentoDuplicata.Remove(&index)
				Exit
			EndIF
		EndiF
	EndFor
EndSub


Sub 'PrintConteudo'
	&AuxConteudo = '          ' + GxGetMLi(&Conteudo, 1,75)
	print conteudo
	
	&AuxConteudo =     GxGetMLi(&Conteudo,2,85)
	print conteudo
	
	&AuxConteudo = GxGetMLi(&Conteudo, 3, 85)
	print conteudo
	
	&AuxConteudo = GxGetMLi(&Conteudo, 4, 85)
	print conteudo
	
	&AuxConteudo = GxGetMLi(&Conteudo, 5, 85)
	print conteudo
	
	&AuxConteudo = GxGetMLi(&Conteudo, 6, 85)
	print conteudo
	
	&AuxConteudo = GxGetMLi(&Conteudo, 7, 85)
	print conteudo
	
	&AuxConteudo = GxGetMLi(&Conteudo, 8, 85)
	print conteudo
	
	&AuxConteudo = GxGetMLi(&Conteudo, 9, 85)
	print conteudo
EndSub

Sub 'SocioFilial'
	If &FilPesSoc > 0 
		For Each Order EmpCod,PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &FilPesSoc
			&Conteudo += ', representada pelo sócio '+trim(PesRaz)+', '
			if not PesRg.IsEmpty() and not PesRg.IsNull()
				&Conteudo += 'portador do RG nº ' +trim(PesRg)+ ' e CPF nº ' + trim(PesCpf)
			Else
				&Conteudo += 'portador do CPF nº ' + trim(PesCpf)
			endif
		
			
			Exit
		EndFor
	EndIf
EndSub
