      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//Carrega informações da sessão
LoadWWPContext.Call(&Context)

Do Case
	Case &Mode = 'INS' //modo de inserção 
		For Each Order EmpCod, FilCod, ViaCod, (ViaCarCod)
			Where EmpCod = &parmEmpCod //empresa
			Where FilCod = &parmFilCod //filial
			Where ViaCod = &parmViaCod //viagem
			
			&ViaCarCod = ViaCarCod //último código de carga da viagem utilizado
			
			Exit
		EndFor
		
		&ViaCarCod += 1 //acrescenta mais um ao último código 
		New
			EmpCod			= &parmEmpCod 			//empresa
			FilCod			= &parmFilCod 			//filial
			ViaCod			= &parmViaCod 			//viagem
			ViaCarCod		= &ViaCarCod 			//código da carga
			ViaCarCteDta	= ServerDate() 			//data adicionada
			ViaCarCteHor	= ServerTime()			//horário adicionado
			ViaCarTip		= &parmViaCarTip 		//se foi preenchido com informações do CT-e ou manualmente (C = 'CTE'; M = 'Manual')
			ViaCarSts		= 'T'					//Status de transporte da carga (T = 'Em Trânsito'; C = 'Cancelada'; E = 'Entregue')
			ViaCarCteChv	= &parmViaCarCteChv 	//Chave CT-e da carga
			ViaCarProPre	= &parmViaCarProPre 	//Produto predominante
			ViaCarVlrFreBrt	= &parmViaCarVlrFreBrt	//Valor bruto
			ViaCarVlrFreLiq	= &parmViaCarVlrFreLiq	//Valor Líquido 
			ViaCarCteVol	= &parmViaCarCteVol		//Quantidade em m³ da carga
			ViaCarCteQtd	= &parmViaCarCteQtd		//quantidade de itens na carga
			ViaCarCteTotPes	= &parmViaCarCteTotPes	//Quantidade em Kg da carga
			ViaCarUfeOri	= &parmViaCarUfeOri		//Uf de Origem
			ViaCarCidCodOri	= &parmViaCarCidCodOri	//Cidade de Origem
			ViaCarCteTomSer	= &parmViaCarCteTomSer	//Quem é o tomador
			ViaCarCteDstCod	= &parmViacarCteDstCod	//Código do Destinatário/Tomador da carga
			ViaCarUfeDst	= &parmViaCarUfeDst		//Uf de destino da Carga
			ViaCarCidCodDst	= &parmViaCarCidCodDst 	//Código IBGE da cidade de Destino da carga
			ViaCarFun		= &Context.PesCod		//Pessoa que adicionou a carga na viagem
		EndNew
	
		//Relaciona a viagem ao cte escolhido
		For Each Order EmpCod, FilCod, CteCod
			Where EmpCod 	= &parmEmpCod
			Where FilCod	= &parmFilCod
			Where CteChv	= &parmViaCarCteChv
			
			CteViaCod		= &parmViaCod
			
			Exit
		EndFor
		
		Commit
		
	Case &Mode = 'STS' //marcar como entregue
		For Each Order EmpCod, FilCod, ViaCod, ViaCarCod
			Where EmpCod 	= &parmEmpCod //empresa
			Where FilCod 	= &parmFilCod //filial
			Where ViaCod 	= &parmViaCod //viagem
			Where ViaCarCod	= &parmViaCarCod //carga
			
			ViaCarSts = 'E' //Carga Entregue
			ViaCarFun = &Context.PesCod //Funcionário que marcou como entregue
			
			Exit
		EndFor
		Commit
		
	Case &Mode = 'CAN' //cancelar carga
		For Each Order EmpCod, FilCod, ViaCod, ViaCarCod
			Where EmpCod 	= &parmEmpCod	//empresa
			Where FilCod 	= &parmFilCod	//filial
			Where ViaCod 	= &parmViaCod	//viagem
			Where ViaCarCod	= &parmViaCarCod //Carga
			
			ViaCarSts 		= 'C'	//Carga cancelada
			ViaCarMotCan	= &parmViaCarMotCan	//Motivo do Cancelamento 
			ViaCarFun		= &Context.PesCod	//Código da pessoa que cancelou 
			
			//Atribui uma chave cte, se o mesmo for vazio
			If &parmViaCarCteChv.IsEmpty() Or &parmViaCarCteChv = ''
				&parmViaCarCteChv = ViaCarCteChv
			EndIf
			
			Exit
		EndFor
		
		//desrelacionar viagem do cte
		For Each Order EmpCod, FilCod, CteCod
			Where EmpCod 	= &parmEmpCod
			Where FilCod	= &parmFilCod
			Where CteChv	= &parmViaCarCteChv
			
			CteViaCod = 0
			
			Exit
		EndFor
		Commit
		
EndCase
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
