      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&QtdVendida = 0

&TotalGeralVendas = 0
&TotalGeralFabricado = 0
&TotalEstoque = 0
&TotalGeralFaltas = 0

If &GrupHie <> ''
	&AuxGrupHie = &GrupHie.Trim() + '.'
EndIf

loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor


MB 4
MT 2

Header
	&titulo = 'Vendas X Produção no Período'
	print Cabecalho
	print tituloProduto
End



For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProSetCod = &ProSetCod when not &ProSetCod.IsEmpty()
	WHere ProSts = &ProSts when not &ProSts.IsEmpty()
	where ProSts <> Status_Produto.EXCLUIDO when &ProSts.IsEmpty()
	Where GrupHie = &GrupHie or GrupHie like &AuxGrupHie when &GrupHie <> ''
	Where ProTipDef = &ProTipDef when not &ProTipDef.IsEmpty()
	&QtdVendida = 0
	&QtdFabricada = 0
	&QtdFaltas = 0
	
	//QTD VENDIDA
	For Each Order EmpCod, FilCod, PedSts, ProCod
		Where FilCod = &FilCod
		Where LctAtuEst = Status_EntradaSaida.Saida
		Where LctGerFin = Status_SimNao.Sim
		Where PedSts = Status_Pedido.FECHADO
		Where PedDtaFat >= &iniPedDtaFat and PedDtaFat <= &FinPedDtaFat
		&QtdVendida += PedQtd
		&QtdFaltas += PedQtdCan
	EndFor
	
	&TotalGeralFaltas += &QtdFaltas
	&TotalGeralVendas += &QtdVendida

	//QTD FABRICADA
	For Each Order EmpCod, FilCod, PedSts, ProCod
		Where FilCod = &FilCod
		Where LctAtuPro = Status_EntradaSaida.Saida
		Where LctAtuEst = Status_EntradaSaida.Entrada
		Where PedSts = Status_Pedido.FECHADO
		Where PedDtaFat >= &iniPedDtaFat and PedDtaFat <= &FinPedDtaFat
		&QtdFabricada += PedQtd
		
	EndFor
	
	&TotalGeralFabricado += &QtdFabricada

	if &QtdVendida > 0 or &QtdFabricada > 0 or &QtdFaltas > 0
		&EstQtd = 0
		For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
			Where FilCod = &FilCod
			&EstQtd += EstQtd
		EndFor
		
		&sdtVendasProducaoItem = new()
		&sdtVendasProducaoItem.PrOCod = ProCod
		&sdtVendasProducaoItem.ProNom = ProNom
		&sdtVendasProducaoItem.ProQtdVen = &QtdVendida
		&sdtVendasProducaoItem.ProQtdFab = &QtdFabricada
		&sdtVendasProducaoItem.QtdCancelada = &QtdFaltas
		&AuxQtdSaldo = &QtdFabricada - &QtdVendida
		&sdtVendasProducaoItem.ProQtdSdo = &AuxQtdSaldo //iif(&AuxQtdSaldo < 0, &AuxQtdSaldo*-1, &AuxQtdSaldo)
		&sdtVendasProducaoItem.EstQtd = &EstQtd
		&sdtVendasProducao.Add(&sdtVendasProducaoItem)

		&TotalEstoque += &EstQtd
	EndIF
EndFor

do Case
	Case &Ordem = '1'
		&sdtVendasProducao.Sort('ProCod')
		
	Case &Ordem = '2'
		&sdtVendasProducao.Sort('[QtdCancelada]')
		
	Case &Ordem = '3'
		&sdtVendasProducao.Sort('[ProQtdVen]')
		
	Case &Ordem = '4'
		&sdtVendasProducao.Sort('[ProQtdFab]')
EndCase

For &sdtVendasProducaoItem in &sdtVendasProducao
	&ProCod = &sdtVendasProducaoItem.PrOCod
	&ProNom = &sdtVendasProducaoItem.PrONom
	&QtdFabricada = &sdtVendasProducaoItem.ProQtdFab
	&QtdVendida = &sdtVendasProducaoItem.ProQtdVen
	&QtdFaltas = &sdtVendasProducaoItem.QtdCancelada
	&EstQtd  = &sdtVendasProducaoItem.EstQtd
	print Produto
EndFor


print Totais


Footer
	print Rodape
End
]]></Source>
