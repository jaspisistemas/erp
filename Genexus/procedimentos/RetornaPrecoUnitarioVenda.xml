      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedVlrUnt = 0

For Each Order EmpCod, TabCod, ProCod, ProGraCod,TabColCod ,(TabAltCod)
	Where EmpCod = &EmpCod
	Where TabCod = &TabPrmCod //TABELA PROMOCAO
	Where ProCod = &ProCod
	Where TabColCod = &TabColCod
	Where ProGraCod = &ProGraCod
	Where (TabDtaIni <= &PedDtaEms or TabDtaIni.IsEmpty()) and (TabDtaFin >= &PedDtaEms or TabDtaFin.IsEmpty())
	Where (TabProDtaIni <= &PedDtaEms or TabProDtaIni.IsEmpty()) and (TabProDtaFin >= &PedDtaEms or TabProDtaFin.IsEmpty())
	
//	if TabIsAntAcr = true
//		&TabPerAcr = TabPerAcr
//		&TabPerAnt = TabPerAnt
//		&TabDtaVct = TabDtaVct
//	EndIf
	
	//Defined by TabDtaAlt
	
	Do Case
		Case &TabColCod = 1
			&PedVlrUnt = TabPrc1
		Case &TabColCod = 2
			&PedVlrUnt = TabPrc2	
		Case &TabColCod = 3
			&PedVlrUnt = TabPrc3
		Case &TabColCod = 4
			&PedVlrUnt = TabPrc4
		Case &TabColCod = 5
			&PedVlrUnt = TabPrc5
		Case &TabColCod = 6
			&PedVlrUnt = TabPrc6
		Case &TabColCod = 7
			&PedVlrUnt = TabPrc7
		Case &TabColCod = 8
			&PedVlrUnt = TabPrc8
		Otherwise
			&PedVlrUnt = TabPrc9
	EndCase
	
	Exit
When none
	For Each Order EmpCod, TabCod, ProCod, ProGraCod, TabColCod ,(TabAltCod)
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod //TABELA NORMAL
		Where ProCod = &ProCod
		Where TabColCod = &TabColCod
		Where ProGraCod = &ProGraCod
		Where (TabDtaIni <= &PedDtaEms or TabDtaIni.IsEmpty()) and (TabDtaFin >= &PedDtaEms or TabDtaFin.IsEmpty())
		Where (TabProDtaIni <= &PedDtaEms or TabProDtaIni.IsEmpty()) and (TabProDtaFin >= &PedDtaEms or TabProDtaFin.IsEmpty())
		
//		if TabIsAntAcr = true
//			&TabPerAcr = TabPerAcr
//			&TabPerAnt = TabPerAnt
//			&TabDtaVct = TabDtaVct
//		EndIf
	
		//Defined by TabDtaAlt
		
		Do Case
			Case &TabColCod = 1
				&PedVlrUnt = TabPrc1
			Case &TabColCod = 2
				&PedVlrUnt = TabPrc2	
			Case &TabColCod = 3
				&PedVlrUnt = TabPrc3
			Case &TabColCod = 4
				&PedVlrUnt = TabPrc4
			Case &TabColCod = 5
				&PedVlrUnt = TabPrc5
			Case &TabColCod = 6
				&PedVlrUnt = TabPrc6
			Case &TabColCod = 7
				&PedVlrUnt = TabPrc7
			Case &TabColCod = 8
				&PedVlrUnt = TabPrc8
			Otherwise
				&PedVlrUnt = TabPrc9
		EndCase
		
		Exit
	EndFor
EndFor

//if (&TabPerAcr > 0 and &TabPerAnt > 0) and &PedVlrUnt > 0 and (not &PedDtaVct.IsEmpty() and not &TabDtaVct.IsEmpty() and &PedDtaVct <> &TabDtaVct)
//	retornaUnitarioLiquidoAntecipado.Call(&TabPerAcr, &TabPerAnt,  &TabDtaVct, &PedDtaVct, &PedVlrUnt)
//Endif
]]></Source>
