&PadObs = ''
PadraoUsuario.Call('L','SDT_MOVIMENTOTRANSFERENCIA',&PesCod,&EmpCod,&PadObs,&Today)
&SDT_MovimentoTransferencia.FromJson(&PadObs)

&DataString = 'Período: ' + &MovDtaCon.ToFormattedString() + ' à ' + &MovDtaCon_To.ToFormattedString()
&Titulo = 'RELATÓRIO DE TRANSFERÊNCIAS ENTRE CONTAS'
Do 'GetFilial'
Do 'GetContaOrigem'
Do 'GetContaDestino'
Header
	Print Cabecalho
	Print TitulosColunas
End

&TotalCredito = 0
&TotalDebito = 0
&count = &SDT_MovimentoTransferencia.Count

For &SDT_MovimentoTransferenciaItem in &SDT_MovimentoTransferencia
	
	&CreMovCod = &SDT_MovimentoTransferenciaItem.DebMovCod
	&CreMovCtaBanNom = &SDT_MovimentoTransferenciaItem.DebMovCtaBanNom
	&CreMovDoc = &SDT_MovimentoTransferenciaItem.DebMovDoc	
	&CreMovVlr = &SDT_MovimentoTransferenciaItem.DebMovVlr
	&TotalCredito += &SDT_MovimentoTransferenciaItem.DebMovVlr
	
	&printMovDtaCon = &SDT_MovimentoTransferenciaItem.MovDtaCon //data
	
	&DebMovCod = &SDT_MovimentoTransferenciaItem.CreMovCod
	&DebMovCtaBanNom = &SDT_MovimentoTransferenciaItem.CreMovCtaBanNom
	&DebMovDoc = &SDT_MovimentoTransferenciaItem.CreMovDoc
	&DebMovVlr = &SDT_MovimentoTransferenciaItem.CreMovVlr
	&TotalDebito += &SDT_MovimentoTransferenciaItem.CreMovVlr
	Print Dados
	
EndFor

Print Total



Sub 'GetFilial'
	
	For each order EmpCod, FilCod
		where EmpCod = &EmpCod
		&FilFan = FilFan
		exit
	EndFor

EndSub

Sub 'GetContaOrigem'
	
	&OrigemCtaBanCodNom.SetEmpty()
	if &OrigemCtabanCod = 0
		&OrigemCtaBanCodNom = 'Conta Origem: TODAS'
	else
		For each order EmpCod, CtabanCod
			where EmpCod = &EmpCod
			where CtabanCod = &OrigemCtabanCod
			&OrigemCtaBanCodNom = 'Conta Origem: ' + CtaBanCodNom
			exit
		when none
			&OrigemCtaBanCodNom = 'Conta Origem: NÃO LOCALIZADA'
		EndFor
	EndIf
	
EndSub

Sub 'GetContaDestino'
	
	&DestinoCtabanCodNom.SetEmpty()
	if &DestinoCtabanCod = 0
		&DestinoCtabanCodNom = 'Conta Destino: TODAS'
	else
		For each order EmpCod, CtabanCod
			where EmpCod = &EmpCod
			where CtabanCod = &DestinoCtabanCod
			&DestinoCtabanCodNom = 'Conta Destino: ' + CtaBanCodNom
			exit
		when none
			&DestinoCtabanCodNom = 'Conta Destino: NÃO LOCALIZADA' 
		EndFor
	EndIf

EndSub
]]></Source>
