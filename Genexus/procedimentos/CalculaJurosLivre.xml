      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&VlrJur = 0 
&VlrMon = 0
&VlrCap = 0 
&VlrMlt = 0
&DtaIni = &CreDtaVct
&Hoje   = &DtaFimJur
&VlrMon = &CreVlrSdo
&VlrCap = &CreVlrSdo
&Dias   = 0
&QtdDias = 0

	
Do While &DtaIni < &Hoje
	&DtaFim = eom(&DtaIni)   // Ultimo Dia do Mês de Vcto
	//&DiasMes = day(&DtaFim)  // Qual o Ultimo Dia do Mês de Vcto? 28,29,30,31 
	&TxaDia = IIF(&JurTax > 0,round(&JurTax / 30, 2),0) // Calcula Juro Diário
	If &TxaDia > 0
		If &DtaFim > &Hoje       // verifica se ultimo dia do mes do vencimento é maior que o vencimento 
			&DtaFim = &Hoje      
		EndIf
		
		&Dias += (&DtaFim - &DtaIni)     // Soma Qtd de Dias Vencidos
		&VlrJur = round(((&VlrCap * (&TxaDia * &Dias))  / 100), 2)
		&VlrMon += &VlrJur
	EndIf
	&DtaIni = &DtaFim + 1
	&QtdDias += &Dias
	&Dias = 1
EndDo

If &TxaMlt > 0
	&VlrMlt = (&VlrCap * (&TxaMlt / 100))
	&VlrMon += &VlrMlt
EndIf

If &VlrJur > 0
    &VlrJur = (&VlrMon - &VlrCap - &VlrMlt)
Endif
]]></Source>
