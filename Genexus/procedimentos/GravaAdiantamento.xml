      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
UltimoCodigoEmpresa.Call(domParCod.MOVIMENTO, &EmpCod, 0, &MovCod)
New
	EmpCod    = &EmpCod
	MovCod    = &MovCod
	MovDta	  = SErverDate()
	MovDtaPgt = &MovDtaPgt
	MovHor    = ServerNow()
	MovDoc    = Iif(&MovDoc.Trim().IsEmpty(),trim(str(&MovCod)),&MovDoc.trim())
	MovTip    = TipoMovimento.Adiantamento
	MovIsCon  = Status_SimNao.Sim
	MovDtaCon = &MovDtaCon
	MovCreDeb = 'D'
	MovCtaBanCod = &MovCtaBanCod
	MovSts = Status_Caixa.Lancado
EndNew
commit

For &SdtAdiantamentoItem in &SdtAdiantamento
	&MovItmCod += 1
	New
		EmpCod    = &EmpCod
		MovCod    = &MovCod
		MovItmCod = &MovItmCod
		MovItmVlr = &SdtAdiantamentoItem.Valor
		PlanCod   = &SdtAdiantamentoItem.PlanCod 
		MovItmCpl = &MovItmCpl
		MovFunCod = &MovFunCod
		MovFunAno = &SdtAdiantamentoItem.Ano
		MovFunMes = &SdtAdiantamentoItem.Mes
		MovFunSts = Status_AbertoFechado.Aberto
	EndNew
EndFor

Commit

&DataVazia.SetEmpty()
For each Order EmpCod,MovCod
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	AtualizaSaldoConta.Call(TrnMode.Insert,EmpCod,MovCtaBanCod,MovDtaCon,MovCreDeb,MovVlr,&DataVazia,0,'')
	Exit
EndFor

commit

if &MovCod > 0
	PrcAtualizaMovimentoFinanceiro.Call(&EmpCod, &MovCod)
Endif
]]></Source>
