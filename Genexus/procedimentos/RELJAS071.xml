      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

If &DadosRemetente = Status_SimNao.Sim
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilRaz = gxGetMLi(FilRaz, 1, 23)
		&DoisFilRaz = gxGetMLi(FilRaz, 2, 23)
		&TresPesRaz = gxGetMLi(FilRaz, 3, 23)
		
		&FilImg146_50 = FilImg_LogRel
		
		&mensagem = 'END: ' + FilLogNro.Trim() + ' - ' + trim(FilBai)
		
		&Endereco = gxGetMLi(&mensagem, 1, 40)
		&Endereco2 = gxGetMLi(&mensagem, 2, 40)
		&Endereco3 = 'CEP: ' + trim(FilCep)
		&CidNom = trim(FilCidNom) + ' - ' + trim(FilCidUfeCod)
		
		if not FilFonNum.IsEmpty()
			&Telefone = 'FONE: ' + trim(FilFonNum)
		EndiF
	
		Exit
	EndFor

	print Remetente
EndIF

if not &PesFonNum.IsEmpty()
	&VarFonNum =  'FONE: ' + trim(&PesFonNum)
EndIF

&PesRaz = gxGetMLi(&inPesRaz, 1, 40)
&DoisPesRaz = gxGetMLi(&inPesRaz, 2, 40)

&mensagem = 'END: ' + &PesEntLogNro.Trim() + ' - ' + &PesEntBai.Trim()
&PesLog = gxGetMLi(&mensagem, 1, 40)
&PesLogAux = gxGetMLi(&mensagem, 2, 40)
&DoisPesLog = 'CEP: ' + trim(&PesEntCep)
&PesCidNom = &PesEntCidNom.Trim()

if not &PesRef.IsEmpty()
	&PesRef = 'REF.:' + trim(&PesRef)
	
	&UmPesRef = gxGetMLi(&PesRef, 1, 37)
	&DoisPesRef = gxGetMLi(&PesRef, 2, 37)
EndiF



print destinatario
	
]]></Source>
