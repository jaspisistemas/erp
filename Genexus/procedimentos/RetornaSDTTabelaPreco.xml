      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtTabelaPrecoProduto.Clear()
&Count = 0

For each 
	using DSwwTabelaPrecoProduto(&ProNom, &ProGraRef, &ProSts, &ProGraEstSdo,&TabCod, &TabUltAlt, &ProIsGra, &DynamicFiltersSelector1, &DynamicFiltersOperator1,&MarNom1, &ProBar1, &TabPrc11, &ProDtaCad1, &GrupCod1,&ProSetCod1,&DynamicFiltersEnabled2, &DynamicFiltersSelector2, &DynamicFiltersOperator2,&MarNom2, &ProBar2, &TabPrc12, &ProDtaCad2,&GrupCod2,&ProSetCod2, &DynamicFiltersEnabled3, &DynamicFiltersSelector3, &DynamicFiltersOperator3,&MarNom3, &ProBar3, &TabPrc13, &ProDtaCad3,&GrupCod3,&ProSetCod3)	
	defined by ProCod
	
	&IsAchou = false
	For &sdtTabelaPrecoProdutoItem in &sdtTabelaPrecoProduto
		if &sdtTabelaPrecoProdutoItem.C = ProCod and &sdtTabelaPrecoProdutoItem.G = ProGraCod
			&IsAchou = true
		EndIf
	EndFor
	
	if &IsAchou = false
		&sdtTabelaPrecoProdutoItem = new()
		&sdtTabelaPrecoProdutoItem.C = ProCod
		&sdtTabelaPrecoProdutoItem.G = ProGraCod
		&sdtTabelaPrecoProduto.Add(&sdtTabelaPrecoProdutoItem)
	EndIf
	&Count += 1
	if &Count >= 20000
		msg('Limite atingido: 20.000 produtos.')
		exit
	EndIf
		
EndFor

padraoUsuario.Call('G', 'SEL_WWTabelaPrecoProduto', &PesCod, &EmpCod, &sdtTabelaPrecoProduto.ToJson(), &Today)

]]></Source>
