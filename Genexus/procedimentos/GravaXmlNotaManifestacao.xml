      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ManXmlNfe = ''  // pega xml em uma variavel 

&XmlDFe.Open(&Arquivo_Nota)    
Do While  not &XmlDFe.EOF	
    &ManXmlNfe += &XmlDFe.ReadRawXML()
	&ManXmlNfe = &ManXmlNfe.Replace('  ', ' ')
	&ManXmlNfe = Trim(strreplace(&ManXmlNfe,Chr(10),' '))
	&ManXmlNfe = Trim(strreplace(&ManXmlNfe,Chr(13),' '))
	&ManXmlNfe = &ManXmlNfe.Trim()
	
    &XmlDFe.Read()
Enddo
&XmlDFe.Close()

&ManXmlNfe = &ManXmlNfe.ReplaceRegEx('\n+|\r+',' ')

if not &ManXmlNfe.IsEmpty()
	&XmlDFe.Close()
	For each order EmpCod,ManCha  //faz update
		Where EmpCod = &EmpCod
		Where ManCha = &ManCha
		ManXmlNfe = &ManXmlNfe
		exit
	EndFor
	
	commit
Endif

]]></Source>
