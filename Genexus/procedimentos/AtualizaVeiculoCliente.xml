      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//VEICULO
For Each Order EmpCod, VeiPla
	Where EmpCod = &EmpCod
	Where VeiPla = &PedVeiPla
	&VeiCod = VeiCod
	
	if VeiUltKm < &PedVeiKm and not &PedVeiKm.IsEmpty()
    	VeiUltKm = &PedVeiKm
	EndIF
EndFor

Commit

For Each Order EmpCod, PesCod, VeiCod
	Where EmpCod = &EmpCod
	Where VeiCod = &VeiCod
	
    VeiSts = Status_SimNao.Nao
EndFor

Commit

For Each Order EmpCod, PesCod, VeiCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where VeiCod = &VeiCod
	VeiSts = Status_SimNao.Sim
	Exit
When none
	
	New
		EmpCod = &EmpCod
		PesCod = &PesCod
		VeiCod = &VeiCod
		VeiSts = Status_SimNao.Sim
	EndNew
EndFOr

Commit
]]></Source>
