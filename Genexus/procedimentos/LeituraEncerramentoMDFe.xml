      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&conteudo_arquivo = ''

For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDFeCod
	&MDFeChv = MDFeChv
	Exit
EndFor

	
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + 'MDFe'+ trim(&MDFeChv)+'-eve.err' 
&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + 'MDFe' +trim(&MDFeChv) + '-eve.xml'

&File.Source = &Nome_retorno_erro
if &File.Exists() 
	&ResultadoAbertura =   DFROpen(&Nome_retorno_erro)    
	
	Do while dfrnext() = 0 
		&ResultadoAbertura = DFRGTxt(&CampoUnico)
		&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
	EndDo
	&ResultadoAbertura = DFRClose()
	
	&File.Delete()
	
	&Tentativa = 99
	&SolSts = Status_Solicitacao.Falha
	&SolMsg = &conteudo_arquivo
else
	&File.Source = &Nome_retorno_correto
	if &File.Exists()
		
		&retorno_xml.Open(&Nome_retorno_correto)    
		&retorno_xml.ReadType(1, 'infEvento')
		&retorno_xml.Read()  
		Do While (&retorno_xml.Name <> 'infEvento' and &retorno_xml.Name <> '')
			Do Case
				Case &retorno_xml.Name = 'cStat'
					&NfeAutSts = &retorno_xml.Value
				Case &retorno_xml.Name = 'dhRegEvento'
					&NfeAutDatHorRec = &retorno_xml.Value
				Case &retorno_xml.Name = 'xMotivo'
					&NfeAutMsg  = &retorno_xml.Value
				Case &retorno_xml.Name = 'nProt'
					&NfeAutNumPro  = &retorno_xml.Value
			EndCase
			&retorno_xml.Read()           
		EndDo
		&retorno_xml.close()
		
		if not &NfeAutSts.IsEmpty()
			Do Case
				Case &NfeAutSts in ('135', '136')
					&NfeAutSts = '132'					
					&mensagem = '132 - ENCERRAMENTO DE MDFE HOMOLOGADO'
					
					AtualizaNumeroProtocoloMDFe.Call('ENCERRA_MDFE', &EmpCod, &FilCod, &MDFeCod, &NfeAutSts, '', '', &NfeAutDatHorRec, &NfeAutMsg, &NfeAutNumPro, '', Status_MDFe.Encerrado, &SolPesCod)
					&SolSts = Status_Solicitacao.Finalizada
					
				Case &NfeAutSts in ('579', '577', '578')
					&mensagem = 'Falha na Comunicação, Fuso horário informado diverge dos servidores sefaz.'
					&SolSts = Status_Solicitacao.Falha
					
				Otherwise
					&mensagem = &NfeAutSts.Trim() + ' - ' + trim(&NfeAutMsg)
					&SolSts = Status_Solicitacao.Falha
			EndCase
			
			&Tentativa = 99
			&SolMsg = &mensagem
		EndIF
	EndIf
EndIf

if &SolSts <> Status_Solicitacao.Pendente
	&File.Source = &Nome_retorno_erro 
	If &File.Exists()
		&File.Delete()
	EndIF

	&File.Source = &Nome_retorno_correto 
	If &File.Exists()
		&File.Delete()
	EndIF
EndIF

]]></Source>
