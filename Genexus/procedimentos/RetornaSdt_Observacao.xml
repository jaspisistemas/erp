      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtObservacaoGrupo.Clear()

&sdtObservacaoGrupoItem = new()
&sdtObservacaoGrupoItem.OGrupCod = -1
&sdtObservacaoGrupoItem.OGrupNom = ''
&sdtObservacaoGrupo.Add(&sdtObservacaoGrupoItem)

For Each Order EmpCod, GrupCod, GrupObsComp, GrupObsOrd
	Where EmpCod = &EmpCod
	Where GrupCod = &GrupCod
	Where GrupObsComp = 'O'
	
	&sdtObservacaoGrupoItem = new()
	&sdtObservacaoGrupoItem.OGrupCod = GrupObsCod
	&OGrupCod = GrupObsCod
	do 'RetornaNomeObservacao'
//	if not &OGrupNom.IsEmpty()
		&sdtObservacaoGrupoItem.OGrupNom = &OGrupNom
		&sdtObservacaoGrupoItem.OGrupCodRef = ''
		
		&sdtObservacaoGrupo.Add(&sdtObservacaoGrupoItem)
//	Endif
EndFor


sub 'RetornaNomeObservacao'
	&OGrupNom = ''
	For Each ORder EmpCod , OGrupCod
		Where EmpCod = &EmpCod
		Where OGrupCod = &OGrupCod
		&OGrupNom= OGrupNom
		Exit
	EndFor
EndSub

]]></Source>
