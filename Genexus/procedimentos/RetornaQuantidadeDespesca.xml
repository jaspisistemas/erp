      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[RetornaUltimaBiometria.Call(&EmpCod,&DspAloCod,&BioDta,&BioPesMed) // pega o peso médio

&DspBioMas = 0 
&AloQtdDes = 0
For each Order EmpCod,DspAloCod // pega a biomassa despescada
	Where EmpCod = &EmpCod
	Where DspAloCod = &DspAloCod
	&DspBioMas += DspBioMas

EndFor

If &DspBioMas > 0 and &BioPesMed > 0 
	&AloQtdDes = (&DspBioMas / &BioPesMed)
EndIf
]]></Source>
