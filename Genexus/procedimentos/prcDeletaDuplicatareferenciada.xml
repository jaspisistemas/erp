      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//DUPLICATA REFERENCIADA
For Each Order EmpCod, FilCod, CreCod, CreRenCod
	Where EmpCod = &EmpCod
	Where CreRenFilCod = &CreRenFilCod
	Where CreRenCreCod = &CreRenCreCod
	
	&CreCod = CreCod
	&FilCod = FilCod
	Delete
	
	Commit
	
	AtualizaSaldoDuplicata.Call(&EmpCod, &CreCod, &FilCod)
EndFor
]]></Source>
