      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &Sinal = '+' //SOMAR
	&AuxEstTipQtd = &PedQtd
Else //DIMINUIR
	&AuxEstTipQtd = &PedQtd * -1
EndIF	

If not &PedDtaFat.IsEmpty()
	&EstTipAno = year(&PedDtaFat)
	&EstTipMes = month(&PedDtaFat)
Else
	&EstTipAno = year(Serverdate())
	&EstTipMes = month(Serverdate())
EndIF

//SE NAO TEM CADASTRADO TABELA ESTOQUE CADASTRA.
For Each Order EmpCod, FilCod ProCod, ProGraCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Exit
When None
    New   //ESTOQUE
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstLoc = ''
		EstABC_Ren = 'D'
		EstABC_Qtd = 'D'
		EstUltEnt = nullvalue(EstUltEnt)
		EstUltSai = nullvalue(EstUltSai)
		EstUltFab = nullvalue(EstUltFab)
		EstQtd = 0
		EstQtdFis = 0
		EstPrd = 0
		EstVen = 0
		EstCom = 0
		EstMin = 0
		EstFabMin = 0
		EstFab = 0
    EndNew
EndFor

&auxEstTipCus = 0 
&auxEstTipCus = (&EstTipCus * &PedQtd)

// ESTOQUE ANO.MES
For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstTipCod, EstTipAno, EstTipMes
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where EstTipCod = &EstTipCod
	Where EstTipAno = &EstTipAno
	Where EstTipMes = &EstTipMes
	
	EstTipQtd += &AuxEstTipQtd	
	EstTipCus += &auxEstTipCus //CUSTO MEDIO
	
	If EstTipCus < 0
		EstTipCus = 0
	EndIF

	Exit
When None
	do 'MES_ANTERIOR'
	
	New
		EmpCod = &EmPCod
		FilCod = &FilCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		EstTipCod = &EstTipCod
		EstTipAno = &EstTipAno
		EstTipMes = &EstTipMes
		EstTipQtd = &AntEstTipQtd + &AuxEstTipQtd
		EstTipCus = &AntEstTipCus + &auxEstTipCus
	EndNew
EndFor

commit

For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	
	Do Case 
		//Case &EstTipCod = 1 //EMPRESA
		//	EstQtd += &AuxEstTipQtd
		//Case &EstTipCod = 2 //PRODUCAO
		//	EstPrd += &AuxEstTipQtd
		Case &EstTipCod = 3 //FISCAL
			EstQtdFis += &AuxEstTipQtd
	EndCase
EndFor

commit



Sub 'MES_ANTERIOR'
    &AntEstTipQtd = 0
    &AntEstTipCus = 0
	
    For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstTipCod, (EstTipAno), (EstTipMes)
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
	    Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where EstTipCod = &EstTipCod
		
        &AntEstTipQtd = EstTipQtd
        &AntEstTipCus = EstTipCus
        exit
    EndFor
EndSub
]]></Source>
