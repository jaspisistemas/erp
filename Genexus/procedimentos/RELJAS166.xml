      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&QrImage.FromImage(&LongVarChar)
For Each Order EmpCod, FilCod
	Where EmpCod	= &EmpCod
	Where FilCod	= &FilCod
	
	&FilFan				= IIf(FilFan.IsEmpty(), FilRaz, FilFan)
	&EnderecoVarChar	= FilBai.Trim() + ' - ' + FilCidNom + ', ' + FilCidUfeCod
	&FilCnpj			= 'CNPJ: ' + FilCpj.Trim() + ' IE: ' + FilInsEst.Trim()
	
	Exit
EndFor
Print Ticket	
]]></Source>
