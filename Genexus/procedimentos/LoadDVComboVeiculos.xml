        <Source><![CDATA[
	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

LoadWWPContext.Call(&Context)

Do Case
	Case &ComboName = !'VeiUfeCod'
		Do 'LoadComboItems_VeiUfeCod'
	Case &ComboName = !'VeiCidCod'
		Do 'LoadComboItems_VeiCidCod'
	Case &ComboName = !'VeiMarCod'
		Do 'LoadComboItems_VeiMarCod'
	Case &ComboName = !'CorCod'
		Do 'LoadComboItems_CorCod'
EndCase

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */


Sub 'LoadComboItems_VeiUfeCod'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For Each
		Where EmpCod = &Context.EmpCod
		&Combo_DataItem = new()
		&Combo_DataItem.ID = UfeCod
		&Combo_DataItem.Title = UfeCod
		&Combo_Data.Add(&Combo_DataItem)
	EndFor
	If &TrnMode <> TrnMode.Insert
		For Each Veiculos
			Where EmpCod = &EmpCod
			Where VeiCod = &VeiCod

			&SelectedValue = VeiUfeCod
		EndFor
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

//	If &TrnMode = TrnMode.Insert
//		retorn

EndSub

Sub 'LoadComboItems_VeiCidCod'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For Each
		Where &Context.EmpCod = EmpCod Where &Cond_VeiUfeCod = UfeCod
		&Combo_DataItem = new()
		&Combo_DataItem.ID = CidCod.ToString().Trim()
		&Combo_DataItem.Title = CidNom
		&Combo_Data.Add(&Combo_DataItem)
	EndFor
	If &TrnMode <> TrnMode.Insert
		For Each Veiculos
			Where EmpCod = &EmpCod
			Where VeiCod = &VeiCod

			&SelectedValue = iif(VeiCidCod.IsEmpty(), '', VeiCidCod.ToString().Trim())
		EndFor
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &SelectedValue.IsEmpty()
		For &Combo_DataItem in &Combo_Data
			&SelectedValue = &Combo_DataItem.ID
			Exit
		EndFor
	
	Endif

EndSub

Sub 'LoadComboItems_VeiMarCod'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For Each
		Where EmpCod = &Context.EmpCod
		&Combo_DataItem = new()
		&Combo_DataItem.ID = VeiMarCod.ToString().Trim()
		&Combo_DataItem.Title = VeiMarNom
		&Combo_Data.Add(&Combo_DataItem)
	EndFor
	If &TrnMode <> TrnMode.Insert AND &TrnMode <> !'NEW'
		For Each Veiculos
			Where EmpCod = &EmpCod
			Where VeiCod = &VeiCod

			&SelectedValue = iif(VeiMarCod.IsEmpty(), '', VeiMarCod.ToString().Trim())
		EndFor
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

	if &SelectedValue.IsEmpty()
		For &Combo_DataItem in &Combo_Data
			&SelectedValue = &Combo_DataItem.ID
			Exit
		EndFor
	
	Endif

EndSub

Sub 'LoadComboItems_CorCod'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For Each
		Where EmpCod = &Context.EmpCod
		&Combo_DataItem = new()
		&Combo_DataItem.ID = CorCod.ToString().Trim()
		&Combo_DataItem.Title = CorNom
		&Combo_Data.Add(&Combo_DataItem)
	EndFor
	If &TrnMode <> TrnMode.Insert AND &TrnMode <> !'NEW'
		For Each Veiculos
			Where EmpCod = &EmpCod
			Where VeiCod = &VeiCod

			&SelectedValue = iif(CorCod.IsEmpty(), '', CorCod.ToString().Trim())
		EndFor
