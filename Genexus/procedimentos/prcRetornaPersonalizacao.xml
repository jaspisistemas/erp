      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtConfigEtiqueta.IsSolicita_EST_LOT = false
&sdtConfigEtiqueta.IsSolicita_PES = false
&sdtConfigEtiqueta.IsSolicita_PRO_QTDEMB = false
&sdtConfigEtiqueta.IsSolicita_PRO_CORNOM = false
&sdtConfigEtiqueta.IsSolicita_EST_LOTAV = false
&sdtConfigEtiqueta.IsSolicita_TAB_COL1 = false
&sdtConfigEtiqueta.IsSolicita_TAB_COL2 = false
&sdtConfigEtiqueta.IsSolicita_PRO_MAISCOD = false
&sdtConfigEtiqueta.TipEtqPadImpCod = 0


For Each ORder EmpCod, TipEtqCod
	Where EmpCod = &EmpCod
	WHere TipEtqCod = &TipEtqCod
	
	&sdtConfigEtiqueta.TipEtqModBas = TipEtqModBas
	
	&sdtConfigEtiqueta.TipEtqPadImpCod = TipEtqPadImpCod
	&sdtDesignerConfigItem.FromJson(TipEtqJson)
	
	&sdtConfigEtiqueta.ImagemBase64 = &sdtDesignerConfigItem.image
	
	Exit
EndFor


for &sdtDesignerConfigElements in &sdtDesignerConfigItem.elements
		
	Do CAse
		Case &sdtDesignerConfigElements.id = 'PRO_MAISCOD'
			&sdtConfigEtiqueta.IsSolicita_PRO_MAISCOD = true
		Case &sdtDesignerConfigElements.id = 'TAB_PRC1' or &sdtDesignerConfigElements.id = 'TAB_PRC1_TIT'
			&sdtConfigEtiqueta.IsSolicita_TAB_COL1 = true
		Case &sdtDesignerConfigElements.id = 'TAB_PRC2' or &sdtDesignerConfigElements.id = 'TAB_PRC2_TIT'
			&sdtConfigEtiqueta.IsSolicita_TAB_COL2 = true
		CAse &sdtDesignerConfigElements.id like '%PES_%'
			&sdtConfigEtiqueta.IsSolicita_PES = true					
		CAse &sdtDesignerConfigElements.id = 'EST_LOT'
			&sdtConfigEtiqueta.IsSolicita_EST_LOT = true
		Case &sdtDesignerConfigElements.id = 'EST_LOTAV'
			&sdtConfigEtiqueta.IsSolicita_EST_LOTAV = true
		CAse &sdtDesignerConfigElements.id = 'PRO_QTDEMB'
			&sdtConfigEtiqueta.IsSolicita_PRO_QTDEMB = true			
		Case &sdtDesignerConfigElements.id = 'PRO_CORNOM'
			&sdtConfigEtiqueta.IsSolicita_PRO_CORNOM = true
			
	EndCase
	
EndFor

]]></Source>
