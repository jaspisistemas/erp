      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For each order EmpCod,CImpTbFilCod,CImpLctCod,CImpOriUfeCod, CImpDstUfeCod, (CImpDtaIni)
	Where EmpCod = &EmpCod
	wHERE CImpTbFilCod = 1
	Where CImpLctCod = &copyImpLctCod //da onde vai copiar
	Where CImpOriUfeCod = 'PR'
	Where CImpDstUfeCod = 'PR'
	
	New
		EmpCod = EmpCod
		CImpTbFilCod = CImpTbFilCod
		CImpLctCod = &NovoImpLctCod
		CImpOriUfeCod = CImpOriUfeCod
		CImpDstUfeCod = CImpDstUfeCod
		CImpGruImpCod = CImpGruImpCod
		CImpCatCod = &ImpCatCod
		CImpCfoCod = &ImpCfoCod    //cfop
		CImpAlqMVA = CImpAlqMVA
		CImpAlqIcmInt  = CImpAlqIcmInt  //icms
		CImpRedAlqIcmInt = CImpRedAlqIcmInt
		CImpAlqIcmExt = CImpAlqIcmExt
		CImpRedAlqIcmExt = CImpRedAlqIcmExt
		CImpDif = CImpDif // deferimento 100%
		CImpCofins = CImpCofins
		CImpPis = CImpPis
		CImpIpi = CImpIpi
		CImpCstCod = CImpCstCod   //deferido
		CImpCstPisCofins = CImpCstPisCofins
		
		CImpCstIpi = CImpCstIpi
		CImpCBenef = &ImpCBenef
		CImpAlqIcmUFDest = CImpAlqIcmUFDest
		CImpPisRed = CImpPisRed
		CImpCofinsRed = CImpCofinsRed
		CImpIcmsMotDes = CImpIcmsMotDes
		CImpTaxFecop = CImpTaxFecop
		CImpDtaAlt = &Today
		CImpIcmsRet = CImpIcmsRet
		CImpObsInf = CImpObsInf
		CImpAlqIcmStUF = CImpAlqIcmStUF
		CImpExcPisCofins = CImpExcPisCofins
		CImpIncIPI = CImpIncIPI
		CImpIpiEnq = CImpIpiEnq
	EndNEW	
	cOMMIT
	
	
	//TabelaimpostoObs
	new
		EmpCod = &EmpCod
		CImpTbFilCod = 1
		CImpLctCod = &NovoImpLctCod
		CImpOriUfeCod = 'PR'
		CImpDstUfeCod = 'PR'
		CImpGruImpCod = 1
		CImpCatCod = &ImpCatCod
		ObsCod = &ObsCod
	EndNew	
	commit		
	
EndFor


]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
