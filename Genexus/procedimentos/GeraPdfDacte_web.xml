      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	&CteModCod = CteModCod
	&CteChv = CteChv
	
	Exit
EndFor

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtCOnfiguracoesPasta)

&URLFisico = &SdtCOnfiguracoesPasta.PastaNFpdf + &CteChv.Trim() + '.pdf'
&URLVirtual = &SdtCOnfiguracoesPasta.PastaNFpdfVir + &CteChv.Trim() + '.pdf'

&File.Source = &URLFisico
If &File.Exists()
	&File.Delete()
EndIf

If &CteModCod = '57'	
	RELJAS085_Print.Call(&EmpCod, &FilCod, &CteCod, &URLFisico)
Else
	RELJAS160_Print.Call(&EmpCod, &FilCod, &CteCod, &URLFisico)
EndIF

]]></Source>
