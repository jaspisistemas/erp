      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, TcpAno, TcpMes
	Where EmpCod = &EmpCod
	Where TcpAno = &TcpAno
	Where TcpMes = &TcpMes
	where TcpForCod = &TcpForCod
	TcpQtdFun = &TcpQtdFun
	TcpVlrCus = &TcpVlrCus
	TcpDias = &TcpDias
	Exit
When none
	For Each Order EmpCod, (TcpCod)
		Where EmpCod = &EmpCod
		&TcpCod = TcpCod
		Exit
	EndFor
	&TcpCod += 1
	
	new
		EmpCod = &EmpCod
		TcpCod = &TcpCod
		TcpAno = &TcpAno
		TcpMes = &TcpMes
		TcpForCod = &TcpForCod
		TcpQtdFun = &TcpQtdFun
		TcpVlrCus = &TcpVlrCus
		TcpDias = &TcpDias
	EndNew
EndFor

commit
]]></Source>
