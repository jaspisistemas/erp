      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&hoje = serverdate()    
&VersaoNF = RetornaVersaoNotas.Udp(VersaoNota.VersaoMDFe)
		
For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDFeCod
	&MDFeChv = MDFeChv
	&MDFeProt = MDFeProt
	
	&cUF = retornaCodigoSiglaEstado.Udp(0, FilCidUfeCod)
	
	&FilFusHor = RetornaFusoHorario.Udp(ServerDate(), FilCidUfeCod)
	
	&FilCpj = FilCpj
	&FilCidUfeIbge = FilCidUfeIbge
    Exit
EndFor

commit

GravaSolicitacao.Call(&EmpCod, &FilCod, &MDFeCod, 0, TipoSolicitacao.Cancelar_MDFe, &PesCod, &SolCod)

//GRAVA ARQUIVO CANCELAMENTO .XML
&ano = str(YEAR(&hoje))
&mes = str(MONTH(&hoje))
&dia = str(DAY(&hoje))
&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hojeHora))),2, '0') + ':00'

&id = 'ID110111' + &MDFeChv + '01' //“ID” + tpEvento + chave da NF-e + nSeqEvento

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + 'MDFe'+trim(&MDFeChv) + '-env-canc.xml'

&ArqNota.Open(&Nome_enviar) // Abrir o arquivo XML
&ArqNota.WriteStartDocument('UTF-8')

&ArqNota.WriteStartElement('eventoMDFe') //<eventoMDFe xmlns="http://www.portalfiscal.inf.br/mdfe" versao="1.00">
&ArqNota.WriteAttribute('xmlns', 'http://www.portalfiscal.inf.br/mdfe')
&ArqNota.WriteAttribute('versao',&VersaoNF)

&ArqNota.WriteStartElement('infEvento')//<infEvento Id="ID1101123512101014278500019058001000000001149128302901">
&ArqNota.WriteAttribute('Id', &id)

&soNumero = str(&FilCidUfeIbge)
&ArqNota.WriteElement('cOrgao',Substr(trim(&soNumero), 1, 2))//<cOrgao>35</cOrgao>
&ArqNota.WriteElement('tpAmb',&sdtConfiguracoesPasta.FilAmbEms)       //<tpAmb>2</tpAmb>

&soNumero = RetornaSonumeros.Udp(&FilCpj)
If &soNumero.Trim().Length() > 11
	&ArqNota.WriteElement('CNPJ', &soNumero) //<CNPJ>10142785000190</CNPJ>
Else
	&ArqNota.WriteElement('CPF', &soNumero) 
EndIf

&ArqNota.WriteElement('chMDFe',&MDFeChv) //<chMDFe>35121010142785000190580010000000011491283029</chMDFe>

&Hoje = serverdate()
&soNumero   = str(year(&Hoje),4,0) +'-'+padl(trim(str(month(&Hoje),2,0)),2,'0') +'-'+padl(trim(str(day(&Hoje),2,0)),2,'0') +'T'+&hora+'-'+&FilFusHor

&ArqNota.WriteElement('dhEvento',&soNumero) //<dhEvento>2012-10-07T03:20:28</dhEvento>
&ArqNota.WriteElement('tpEvento','110111') //<tpEvento>110112</tpEvento> CANCELAMENTO
&ArqNota.WriteElement('nSeqEvento','1') //<nSeqEvento>1</nSeqEvento>

&ArqNota.WriteStartElement('detEvento')  //<detEvento versaoEvento="1.00">
&ArqNota.WriteAttribute('versaoEvento', &VersaoNF) //&VersaoNF

&ArqNota.WriteStartElement('evCancMDFe')  //<evCancMDFe>
&ArqNota.WriteElement('descEvento', 'Cancelamento')// <descEvento>Encerramento</descEvento>
&ArqNota.WriteElement('nProt', &MDFeProt)// <nProt>935120000000020</nProt>
&ArqNota.WriteElement('xJust', &xJust)//xJust

&ArqNota.WriteEndElement() //</evCancMDFe>
&ArqNota.WriteEndElement() //</detEvento>
&ArqNota.WriteEndElement() //</infEvento>
&ArqNota.WriteEndElement() //eventoMDFe

&ArqNota.Close()
]]></Source>
