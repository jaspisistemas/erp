      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each order EmpCod, PesCod
	where EmpCod = &EmPCod
	where PesCod = &PesCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PESSOA'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(PesCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSit', trim(toformattedString(PesSit)), trim(toformattedString(&PesSit)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesPagFac', trim(toformattedString(PesPagFac)), trim(toformattedString(&PesPagFac)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TpcCod', trim(TpcCod.ToString()), trim(&TpcCod.ToString()), &LogErpRegGUID )
		
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesReg', trim(toformattedString(PesReg)), trim(toformattedString(&PesReg)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesPedProAlg', trim(toformattedString(PesPedProAlg)), trim(toformattedString(&PesPedProAlg)), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
	PesSit = &PesSit
	PesPagFac = &PesPagFac
	TpcCod = &TpcCod
	
	if PesReg <> &PesReg
		PesRegDtaAlt = serverNow()
	Endif

	PesReg = &PesReg
	PesPedProAlg = &PesPedProAlg
	
EndFor

Commit

]]></Source>
