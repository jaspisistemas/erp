      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&mensagem = ''

If &OqueFazer = 'ADD' //ADICIONAR-ALTERAR
	For Each Order EmpCod, ProCod, ProGraCod
		where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod when &ProGraCod > 1
		

	    For Each Order EmpCod, PesCod, EspProCod, EspProGraCod
		    Where EmpCod = &EmpCod
			Where PesCod = &PesCod
		    Where EspProCod = ProCod
			Where EspProGraCod  = ProGraCod
			
			&mode = TrnMode.Update
						
			EspDtaFin = &TabProDtaFin
			EspDtaIni = &TabProDtaIni
			
			EspPrc1 = &TabPrc1 
			EspPrc2 = &TabPrc2
			EspPrc3 = &TabPrc3
			EspPrc4 = &TabPrc4
			EspPrc5 = &TabPrc5
			EspPrc6 = &TabPrc6
			EspPrc7 = &TabPrc7
			EspPrc8 = &TabPrc8
			EspPrc9 = &TabPrc9
			
			&mensagem += NewLine() + 'Produto ' + trim(EspProRef)
			if EspProGraCod > 1
				&mensagem += ' ' + trim(EspProGraNom)
			EndIF
			&mensagem += ' alterado Com Sucesso!'
			
			Exit
	    When none
			&mode = TrnMode.Insert
	        new
				EmpCod = &EmpCod
				PesCod = &PesCod
		    	EspProCod = ProCod
				EspProGraCod  = ProGraCod
				EspDtaFin = &TabProDtaFin
				EspDtaIni = &TabProDtaIni	
				EspPrc1 = &TabPrc1 
				EspPrc2 = &TabPrc2
				EspPrc3 = &TabPrc3
				EspPrc4 = &TabPrc4
				EspPrc5 = &TabPrc5
				EspPrc6 = &TabPrc6
				EspPrc7 = &TabPrc7
				EspPrc8 = &TabPrc8
				EspPrc9 = &TabPrc9
	        EndNew
			
			&mensagem += NewLine() + 'Produto ' +trim(str(&ProCod))
			if ProGraCod > 1
				&mensagem += ' ' + trim(ProGraNom)
			EndIF
			&mensagem += ' alterado Com Sucesso!'
						
	    EndFor
		
	EndFor

Else //ELIMINAR
    &mode = TrnMode.Delete
	
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod when &ProGraCod > 1
		
		
	    For Each Order EmpCod, PesCod, EspProCod, EspProGraCod
		    Where EmpCod = &EmpCod
			Where PesCod = &PesCod
		    Where EspProCod = ProCod
			Where EspProGraCod  = ProGraCod
			
			&mensagem += NewLine() + 'Produto ' + trim(EspProRef) 
			If EspProGraCod > 1
				&mensagem += ' ' + trim(EspProGraNom)
			EndIF
			&mensagem += ' Eliminado Com Sucesso!'
			
	        delete
							
		When none
			&mensagem += NewLine() + 'Produto ' + trim(ProRef)
			If ProGraCod > 1
				&mensagem += ' ' + trim(ProGraNom)
			EndIF
			&mensagem += ' não Localizado na Tabela de Preço!'
	    EndFor
		
	EndFor

EndIF

commit


msg(&mensagem)
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
