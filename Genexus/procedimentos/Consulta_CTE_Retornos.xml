      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	&CteChv = CteChv
	&CteSer = CteSer
	&ModCod = CteModCod
	&CteNum = CteNum
	&PastaDanfeData = str(year(CteDtaEms),4,0)+padl(trim(str(month(CteDtaEms),2,0)),2,'0')
	
	Exit
EndFor

&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&CteChv)+'-sit.xml'
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&CteChv)+'-sit.err'

&File.Source = trim(&Nome_retorno_erro)
If &File.Exists()
	
	&ResultadoAbertura =   DFROpen(&Nome_retorno_erro)    
	Do while dfrnext() = 0 
		&ResultadoAbertura = DFRGTxt(&CampoUnico)
		&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
	EndDo
	&ResultadoAbertura = DFRClose()
	
	&File.Delete()
	
	&Tentativa = 99
	&SolSts = Status_Solicitacao.Falha
	&SolMsg = &conteudo_arquivo
else
	&File.Source = trim(&Nome_retorno_correto)
	If &File.Exists()
		
		&retorno_xml.Open(&Nome_retorno_correto)
		&retorno_xml.ReadType(1,'cStat')
		&CteAutSts = &retorno_xml.Value
		
		&retorno_xml.ReadType(1,'xMotivo')
		&CteAutMsg = &retorno_xml.Value
		
		&retorno_xml.ReadType(1,'dhRecbto')
		&CteAutDatHorRec = &retorno_xml.Value
		
		&retorno_xml.ReadType(1,'nProt')
		&CteAutNumPro = &retorno_xml.Value
		
		if not &CteAutSts.IsEmpty()
			&Tentativa = 99
			
			Do Case
				Case &CteAutSts  = '101' //CANCELADA
					&SolSts = Status_Solicitacao.Finalizada
					
					AtualizaNumeroProtocoloCTe.Call('CANCELA_CTE', &EmpCod, &FilCod, &CteCod, &CteAutSts, &CteAutNumLot, &CteAutNumRec, &CteAutDatHorRec, &CteAutMsg, &CteAutNumPro, &CteAutDigVal, Status_NFe.Cancelada, &SolPesCod)
					
					do 'ArquivoPronto'
					
				Case &CteAutSts = '100' //AUTORIZADA
					&SolSts = Status_Solicitacao.Finalizada
					
					AtualizaNumeroProtocoloCte.Call('AUTORIZA_CTE', &EmpCod, &FilCod, &CteCod, &CteAutSts, &CteAutNumLot, &CteAutNumRec, &CteAutDatHorRec, &CteAutMsg, &CteAutNumPro, &CteAutDigVal, Status_NFe.Autorizada, &SolPesCod)
					
					do 'ArquivoPronto'
					
				Case &CteAutSts = '206' //INUTILIZA
					&SolSts = Status_Solicitacao.Finalizada
					
					GravaInutilizacaoCte.Call(&EmpCod, &FilCod, &CteSer, &ModCod, &CteNum, &CteNum, &CteAutNumLot, &CteAutNumRec, &CteAutDatHorRec, &CteAutMsg, &CteAutNumPro)
														
				Case &CteAutSts in ('205','302', '301') //DENEGADA
					&SolSts = Status_Solicitacao.Finalizada
					
					AtualizaNumeroProtocoloCTe.Call('AUTORIZA_CTE', &EmpCod, &FilCod, &CteCod, &CteAutSts, &CteAutNumLot, &CteAutNumRec, &CteAutDatHorRec, &CteAutMsg, &CteAutNumPro, &CteAutDigVal, Status_NFe.Denegada, &SolPesCod)
					
					do 'ArquivoPronto'
				Otherwise
					&SolSts = Status_Solicitacao.Falha
			EndCase
			
		EndIf
		&SolMsg = &CteAutMsg
		&retorno_xml.close()
	EndIf
EndIF

if &SolSts <> Status_Solicitacao.Pendente
	if not &ArquivoPronto.IsEmpty()
		&file.Source = &ArquivoPronto.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

	if not &Nome_retorno_correto.IsEmpty()
		&file.Source = &Nome_retorno_correto.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

	if not &Nome_retorno_erro.IsEmpty()
		&file.Source = &Nome_retorno_erro.Trim()
		if &file.Exists()
			&File.Delete()
		EndIF
	EndIF

EndIF


sub 'ArquivoPronto'
	&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFenviado.Trim() +'/Autorizados/' + trim(&PastaDanfeData) +'/'+&CteChv.trim()+'-procCTe.xml'
       
	&file.Source = &ArquivoPronto
	if &file.Exists()
		GravaArquivoXmlCTE.Call(&EmpCod, &FilCod, &CteCod, &ArquivoPronto)
	EndIf
EndSub
]]></Source>
