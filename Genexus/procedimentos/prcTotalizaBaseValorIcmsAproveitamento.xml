      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	WHere FilCod = &FilCod
	Where NfeCod = &NFeCod
	
	FormataCFOP.Call(NfeCfoCod, &NfeCfoCod)
	
	&CfoEmpAprvCredIcmsPer = &TbLctApvIcms
	
	if &oldCfopCod <> &NfeCfoCod
		//verificaCFOP ENTRADA
		RetornaCfopEntrada.call(EmpCod, NfeLctCod, &NfeCfoCod, &CfoEmpAprvCredIcmsPer, &tmpEntCFOP)
		&oldCfopCod = &NfeCfoCod
	Endif		

	if &CfoEmpAprvCredIcmsPer > 0
		if &CfoEmpAprvCredIcmsPer = 100
			if NfeVlrTotIcms > 0 or NfeProVlrIcmsDes > 0 or NfeSitCod = '51'//JDF se for 51 tambem add
				&NfeProBasIcms = NfeProBasIcms
				&NfeProVlrIcms = NfeProVlrIcms
				&NfeProVlrDif = NfeProVlrDif
			Else
				&NfeProBasIcms = 0
				&NfeProVlrIcms = 0
				&NfeProVlrDif = 0
			Endif		
		Else
			if NfeProBasIcms > 0 or NfeSitCod = '51'//JDF se for 51 tambem add 
				&NfeProBasIcms = NfeProBasIcms * ((&CfoEmpAprvCredIcmsPer)/100)
			Else
				&NfeProBasIcms = 0
			EndIf
	
			if NfeProVlrIcms > 0
				&NfeProVlrIcms = NfeProVlrIcms * ((&CfoEmpAprvCredIcmsPer)/100)
			Else
				&NfeProVlrIcms = 0
			Endif
			
			if NfeProVlrDif > 0
				&NfeProVlrDif = NfeProVlrDif * ((&CfoEmpAprvCredIcmsPer)/100)
			Endif
		
		Endif
	Else
		&NfeProBasIcms = 0
		&NfeProVlrIcms = 0
		&NfeProVlrDif = 0
	Endif

	&NfeVlrTotBasIcms += &NfeProBasIcms
	&NfeVlrTotIcms += &NfeProVlrIcms	
	&NfeVlrTotVlrDif += &NfeProVlrDif
	
EndFor
]]></Source>
