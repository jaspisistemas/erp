      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//&IsAlgum101 = false
&TotalCredito = 0

For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
	Where EmpCod = &EmpCod
	where FilCod = &FilCod
	where NfeCod = &NfeCod
	
	if NfeLctPerCred = Status_SimNao.Sim and FilCrdIcm <> 0 and NfeEntSai = Status_EntradaSaida.Saida and NfeProTer = Nota_ProPriaTerceira.PROPRIA
		if NfeSitCod = '101' or NfeSitCod = '201'
			
			&valorMoeda = Round((NfeProVlrTot * FilCrdIcm) / 100, 2)
			&TotalCredito += &valorMoeda
			
//			&IsAlgum101 = true
		Endif
	Endif
endfor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
