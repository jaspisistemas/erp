      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

&SdtRetornoWbs.Sts = 'E999'

if &IsAcessoConcedido = true
	
	&NfeArqXml = RetornaXmlNota.udp(&wwpContext.EmpCod, &FilCod, &NfeCod)
	if &NfeArqXml.IsEmpty()
		GeraXmlNFeModelo55_4.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, 'N', &wwpContext.PesCod, 'E', &SolCod)
	EndIF
	
	GeraPdfDanfe.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &UrlPDF, &UrlFisico)
	
	&SdtRetornoWbs.Sts = 'J200'
	&SdtRetornoWbs.Obs = &UrlPDF
	
//	RCOOpenWindow1.LinkOpen = Link(&UrlPDF)
//	RCOOpenWindow1.OpenWindow(True, 500, 500, True, 0, 0, False)
		
Endif
]]></Source>
