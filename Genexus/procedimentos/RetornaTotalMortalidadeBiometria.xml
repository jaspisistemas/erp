        <Source><![CDATA[&MorQtd = 0
For each Order EmpCod,MorFilCod,MorAloCod
	Where EmpCod = &EmpCod
	Where MorFilCod = &FilCod
	Where MorAloCod = &AloCod
	Where MorDta < &MorDta
