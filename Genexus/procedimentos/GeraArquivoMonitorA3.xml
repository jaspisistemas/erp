      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[retornaConfiguracoesPastas.Call(&EmpCod, 1, &SdtConfiguracoesPasta)

&sdtConfJaspiEmpresa.Filiais.Clear()

for Each order EmpCod
	Where EmpCod = &EmpCod
	&sdtConfJaspiEmpresa.EmpCodSec = EmpCodSec
	&sdtConfJaspiEmpresa.EmpCpfCnpj = EmpCpfCnpj
	&sdtConfJaspiEmpresa.EmpDirFis = 'C:\JASPI\appjaspi\'
	&sdtConfJaspiEmpresa.EmpWebHost = 'wbsapp.jaspi.com.br'
	&sdtConfJaspiEmpresa.EmpWebPor = 80
	
	For Each Order EmpCod, FilCod
		&sdtConfJaspiEmpresaItem = new()
		&sdtConfJaspiEmpresaItem.ItmSolFilCod = FilCod
		&sdtConfJaspiEmpresaItem.pstEmpFil = 'E'+ trim(str(EmpCodPas)) + '/F'+ trim(Str(FilCodPas))
		&sdtConfJaspiEmpresa.Filiais.Add(&sdtConfJaspiEmpresaItem)
	EndFor
EndFor

&nomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'confJaspiEmpresa.xml'
//&nomeArquivoOut = &SdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'confJaspiEmpresa.xml'
&nomeArquivoVirtual = &SdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + 'confJaspiEmpresa.xml'

//&directory.Source = &Diretorio
//if not &directory.Exists()
//	&directory.Create()
//Endif

&File.Source = &nomeArquivo
if &File.Exists()
	&File.Delete()
endif
&File.Close()

//&File.Source = &nomeArquivoOut
//if &File.Exists()
//	&File.Delete()
//endif
//&File.Close()

&XmlWriter.Open(&nomeArquivo)
&XmlWriter.WriteRawText(&SdtConfJaspiEmpresa.ToXml())
&XmlWriter.Close()


//&ZipUtil.ZipFiles(&Diretorio, &nomeArquivoOut, '')

]]></Source>
