      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

prcMercadolivreRefreshToken.Call(&EmPCod, &MrkCod, &MrkSession, &IsSucesso)

if &IsSucesso = true
	
	&LongVarchar = '{ '
	&LongVarchar +=  ' "question_id": '+&MrkMenId+',  '
	&LongVarchar +=  '  "text":"'+trim(&MrkMenResp)+'"  '
	&LongVarchar +=  ' }'
	
	&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
	&httpClient.AddHeader(!"Content-Type", !"application/json")
	&httpClient.AddString(&LongVarchar)
	&HttpClient.Execute('POST', 'https://api.mercadolibre.com/answers')
	
//	&LongVarchar = "Status: " + &HttpClient.StatusCode.ToString()
//	&LongVarchar += " Erro: " + &HttpClient.ErrDescription
//	&LongVarchar += " Retorno: " + &HttpClient.ToString()
//	padraoUsuario.Call('G', 'TESTEanswers', 1, 1,&LongVarchar, &PAdDtaMod)
	
	If &HttpClient.StatusCode = 200
		
		&IsSucesso = true
		prcGravaQuestions.Call(&EmPCod, &MrkCod, &HttpClient.ToString())
	Else
		&LongVarchar = "Status: " + &HttpClient.StatusCode.ToString()
		&LongVarchar += " Erro: " + &HttpClient.ErrDescription
		&LongVarchar += " Retorno: " + &HttpClient.ToString()
		msg(&LongVarchar)
	Endif

Else
	msg('Falha no token')
	&IsSucesso = false
Endif

]]></Source>
