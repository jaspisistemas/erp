      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[Stub SetNotificationReadUnreadById(&WWPNotificationId)
	For Each WWPBaseObjects.Notifications.Common.WWP_Notification
		Where WWPNotificationId = &WWPNotificationId
		If WWPNotificationIsRead
			WWPNotificationIsRead = False
		Else
			WWPNotificationIsRead = True
		Endif
	EndFor
EndStub

Stub SetNotificationReadById(&WWPNotificationId)
	For Each WWPBaseObjects.Notifications.Common.WWP_Notification
		Where WWPNotificationId = &WWPNotificationId
			WWPNotificationIsRead = True
	EndFor
EndStub

Stub SetAllNotificationsOfLoggedUserRead()
	For Each WWPBaseObjects.Notifications.Common.WWP_Notification
		Where WWPUserExtendedId = WWP_GetLoggedUserId()
		WWPNotificationIsRead = true
	EndFor
EndStub
