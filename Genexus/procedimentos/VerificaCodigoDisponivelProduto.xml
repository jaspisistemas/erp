      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsDisponivel = true

If &NewProCod <= 0
	if &NewProCod < 0
		&IsDisponivel = false
	EndIF

	return
EndIF


For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &NewProCod
	&IsDisponivel = false
	Exit
EndFOr
]]></Source>
