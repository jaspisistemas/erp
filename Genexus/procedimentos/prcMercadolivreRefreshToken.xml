      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsSucesso = true
for Each Order EmpCod, MrkCod
	where EmpCod = &EmPCod
	where MrkCod = &MrkCod
	&MrkGuid = MrkGuid
	&MrkTok = MrkTok
	&MrkTokRef = MrkTokRef
	&MrkDtaVctTok = MrkDtaVctTok
	&MrkSession = MrkSession
	Exit
EndFor

&DataHora = serverNow()

//cabecalho
&HttpClient.AddHeader('content-type', 'application/x-www-form-urlencoded')
&HttpClient.AddHeader('accept', 'application/json')

//GET TOKEN
Do Case
	Case &MrkTokRef.IsEmpty() 
		&HttpClient.AddVariable('grant_type', 'authorization_code')
		&HttpClient.AddVariable('client_id', '7665836300727694') // criar campos
		&HttpClient.AddVariable('client_secret', '7HvKQs4irVwRl53hPGJUzcOfrG4242Xv') // criar campos
		&HttpClient.AddVariable('code', &MrkTok)
		&HttpClient.AddVariable('redirect_uri', 'https://adm.jaspi.com.br/loginsucessed.aspx')
	Case &MrkDtaVctTok < &DataHora
		//REFRESH TOKEN
		&HttpClient.AddVariable('grant_type', 'refresh_token')
		&HttpClient.AddVariable('client_id', '7665836300727694') // criar campos
		&HttpClient.AddVariable('client_secret', '7HvKQs4irVwRl53hPGJUzcOfrG4242Xv') // criar campos
		&HttpClient.AddVariable('refresh_token', &MrkTokRef) 
	otherwise
		return
EndCase

&HttpClient.Execute('POST', 'https://api.mercadolibre.com/oauth/token')

If &HttpClient.StatusCode = 200

	&sdtTokenML.FromJson(&HttpClient.toString())	
	&MrkSession = &sdtTokenML.access_token
	
	if not &sdtTokenML.refresh_token.IsEmpty() and not &sdtTokenML.access_token.IsEmpty()
		for Each Order EmpCod, MrkCod
			where EmpCod = &EmPCod
			where MrkCod = &MrkCod
			
			&Segundos.fromString(&SdtTokenML.expires_in)
			MrkSession = &sdtTokenML.access_token
			MrkTokRef = &sdtTokenML.refresh_token
			MrkDtaVctTok = &DataHora
			MrkDtaVctTok = MrkDtaVctTok.AddSeconds(&Segundos)
			MrkSellID = &sdtTokenML.user_id
			
			Exit
		EndFor
		
		Commit
	Endif
Else
	&IsSucesso = false
Endif
]]></Source>
