      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsModificou = false
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	//Ultima Compra
	valorUltimaCompraProduto_Novo.Call(EmpCod, ProCod, &ProVlrUltCmp, &ProPadForCod)
	if ProPadUltCmp = 'C' and &ProPadForCod > 0 and ProPadForCod <> &ProPadForCod
		&IsModificou = true
		ProPadForCod = &ProPadForCod
	EndiF
	&ProPadForCod = ProPadForCod
	
	if ProVlrUltCmp <> &ProVlrUltCmp
		&IsModificou = true
		ProVlrUltCmp = &ProVlrUltCmp
	Endif

	Exit
EndFor

if &IsModificou = true
	commit
Endif

&IsModificou = false
//JDF - FIZ 2 FOR POR CAUSA QUE NO PROCEDIMENTO ABAIXO NAO ESTAVA INDO O ProVlrUltCmp ATUALZIADO.
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&ProVlrCus = prcProVlrCus_FORMULA.Udp(EmpCod, ProCod, ProEstProCod, &ProPadForCod, ProTipCus)
	if &ProVlrCus <> ProVlrCus
		&IsModificou = true
		ProVlrCus = &ProVlrCus
	Endif

	Exit
EndFor

if &IsModificou = true
	commit
	
	ProVlrCus_Receita.Call(&EmpCod, &ProCod)
Endif
]]></Source>
