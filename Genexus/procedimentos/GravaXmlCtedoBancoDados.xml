      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\"
	&DiretorioDanfeBancoDeDados.Source   =  &PastaBancoDados
	If not &DiretorioDanfeBancoDeDados.Exists()
		&DiretorioDanfeBancoDeDados.Create()
	EndIf
	
	&NomArq = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + "BancoDeDados\" + CteChv.Trim() + '-jaspi.xml'
	&resultado = DFWOpen(&NomArq,'','',0,'')
	&resultado = DFWPTxt(CteArqXml)
	&ResultadoNext = dfwnext()
	&resultado = DFWClose()
	Exit
EndFor
]]></Source>
