      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//  LAT     ,     LON
//-24.285265, -54.036929
//###################################### LATITUDE ##############
&Index = 0
&Index = strSearch(&PrpTalGeo,',')
&Index -= 1 //tira virgula
&Latitude  = subStr(&PrpTalGeo,1,&Index) //-24.285265
&Latitude = retiraCaracteresEspeciais.Udp(&Latitude) //24.285265
&Graus = Substr(trim(&Latitude),1,2) // 24
&Latitude = strReplace(&Latitude,'.','') //24285265
&sobra = Substr(trim(padl(&Latitude,8,'0')),3,6) // 285265
&Valor = &sobra.Trim().ToNumeric()
&Valor = ((&Valor/1000000)*60)  //(285265 /1000000)*60 = 17,1159
&ValorCalculado = trim(toformattedString(&Valor)) // 17,1159
&Index = strSearch(&ValorCalculado,',') //17,1159
&Index-=1
&Minutos = Substr(trim(&ValorCalculado),1,&Index) // 17,1159
&Index+=2
&sobra = Substr(trim(&ValorCalculado),&Index,5)//17,1159
&Valor = &sobra.Trim().ToNumeric()
&Valor = ((&Valor/100000)*60)
&Segundos = retornaSoNumeros.Udp(trim(toformattedString(&Valor))) //1159 * 60

&Latitude = Padl(&Graus,2,'0')+Padl(&Minutos,2,'0')+substr(trim(&Segundos),1,3)


//###################################### LONGITUDE ##############
&Index = 0
&Index = strSearch(&PrpTalGeo,',')
&Index += 1 //depois da virgula
&IndexTotal = &PrpTalGeo.Length()
&Longitude  = subStr(&PrpTalGeo,&Index,&IndexTotal) //-54.036929


&Longitude = retiraCaracteresEspeciais.Udp(trim(&Longitude))
&Graus = Substr(trim(&Longitude),1,2) // 24
&Longitude = strReplace(&Longitude,'.','')

&sobra = Substr(trim(Padl(&Longitude,8,'0')),3,6)
&Valor = &sobra.Trim().ToNumeric()
&Valor = ((&Valor/1000000)*60)
&ValorCalculado = trim(toformattedString(&Valor)) //285265 * 60
&Index = strSearch(&ValorCalculado,',')
&Index-=1
&Minutos = Substr(trim(&ValorCalculado),1,&Index) // 24
&Index+=2
&sobra = Substr(trim(&ValorCalculado),&Index,5)
&Valor = &sobra.Trim().ToNumeric()
&Valor = ((&Valor/100000)*60)
&Segundos = retornaSoNumeros.Udp(trim(toformattedString(&Valor))) //1159 * 60

&Longitude = Padl(&Graus,2,'0')+Padl(&Minutos,2,'0')+substr(trim(&Segundos),1,3)
]]></Source>
