      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &FunPesCod
	&Operador = 'Operador: ' + trim(PesRaz)
	Exit
EndFor


For each Order, EmpCod, MovCod, MovItmCod
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
		
	&FiLCod = MovCtaBanFilCod
	do 'Filial'
	
	print Cabecalho
	
	&DataHoraLancamento = 'DATA: ' + trim(DtoC(MovDtaPgt)) + ' - ' + trim(ToformattedString(MovHor)) + ' DOC: ' + trim(MovDoc)
	&PlanoContas = PlanCodNom.Trim()
	print DataLancemtno
	
	if MovCreDeb = 'C' //CREDITO
		&Suprimento = 'SUPRIMENTO'
	Else
		&Suprimento = 'SANGRIA'
	EndIF
	print SuprimentoSangria
	
	&ValorLancamento = 'R$ ' + trim(ToformattedString(MovItmVlr))
	print ValorJustificativa
	
	&MEnsagem =  MovItmCpl.Trim()

	&QtdLinhas = gxMLines(&MEnsagem, 30)
	do while &linha <= &QtdLinhas
		&linha += 1
		&justificativa = gxGetMLi(&MEnsagem, &linha, 30)
		print Justifi
	EndDo
	
	print Assinatura
EndFor

sub 'Filial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FiLCod
		&QtdLinhas = gxMLines(FilRaz, 47)
		
		if &QtdLinhas > 47
			&UmFilRaz = gxGetMLi(FilRaz, 1, 47)
			&DoisFilRaz = gxGetMLi(FilRaz, 2, 47)
		Else
			&DoisFilRaz = gxGetMLi(FilRaz, 1, 47)
		EndiF 
		&UmFilRaz = UPPER(&UmFilRaz)
		&DoisFilRaz = UPPER(&DoisFilRaz)
		
		if not FilCpj.IsEmpty()
			&CnpjIeIm = 'CNPJ: ' + trim(FilCpj)
		EndIF
		
		If not FilInsEst.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IE: ' + trim(FilInsEst)
		EndIF
		
		If Not FilInsMun.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IM: ' + trim(FilInsMun)
		EndIF
		
		&Endereco = FilLog.Trim() + ', ' + trim(FilNro) + ' - ' + trim(FilBai)
		&Cidade = trim(FilCidNom) + ' - ' + trim(FilCidUfeCod)
		
		Exit
	EndFor
EndSUb
]]></Source>
