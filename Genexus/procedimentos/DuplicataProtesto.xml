      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[Do Case
	Case &Protesto = 'CARTORIO' //DATA CARTORIO
		For Each Order EmpCod,FilCod, CreCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CreCod = &CreCod
			CreDtaCrt = &Data
			Exit
		EndFor
		
	Case &Protesto = 'PROTESTO' //DATA PROTESTO
		For Each Order EmpCod,FilCod, CreCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CreCod = &CreCod
			
			&CreCliCod = CreCliCod
			CreDtaPrt = &Data
			Exit
		EndFor	
		
		DuplicataClienteProtesto.Call(&EmpCod,&CreCliCod)
		
EndCase

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
