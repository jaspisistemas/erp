      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilEnvEml = FilEnvEml
	Exit	
EndFor

Do CAse
	Case &OqueFazer = 'AUTORIZA_NFE' //AUTORIZA NFE
		For Each Order EmpCod, FilCod, MDFeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			Where MDFeSts <> &MDfeSts
			
			If not &MDfeProt.IsEmpty()
				MDFeProt = &MDfeProt
			EndIF
			
			MDFeSts = &MDfeSts
			
			Do  'CarregaEmail_CTE_NFE'
			
			//carrega e-mail do parâmetro
			RetornaConfSistema.Call(EmpCod, FilCod, domConfSistema.TCon162_EmailEnviarNotas, &TCon162_EmailEnviarNotas)
			
			if not &TCon162_EmailEnviarNotas.Trim().IsEmpty()
				&IsJahTem = false
				For &itemSdtEmail in &SdtEmail
					If &itemSdtEmail.EmlUrl = &TCon162_EmailEnviarNotas
						&IsJahTem = true
						Exit
					EndIF	
				EndFor
				
				If &IsJahTem = false
					&itemSdtEmail = new()
					&itemSdtEmail.EmlUrl = &TCon162_EmailEnviarNotas
					&SdtEmail.Add(&itemSdtEmail)
				EndIf
			EndIf
			
			If &SdtEmail.Count > 0			
				GravaEnvioEmail.Call(EmpCod, FilCod, MDFeCod, 0, TipoContaEmail.Email_Faturamento, &EmlAss, TipoSolicitacao.Envia_MDFe, &PesCod, '', &SdtEmail, &sdtBoleto)
			EndIf
		
			Exit
		EndFor
		
	Case &OqueFazer = 'CANCELA_NFE' //CANCELA NFE
		For Each Order EmpCod, FilCod, MDFeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			Where MDFeSts <> &MDfeSts
			
			If not &MDfeProt.IsEmpty()
				MDFeProt = &MDfeProt
			EndIF
			
			MDFeSts = &MDfeSts
			
			Exit
		EndFor
	Case &OqueFazer = 'ENCERRA_MDFE' //ENCERRA
		For Each Order EmpCod, FilCod, MDFeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			Where MDFeSts <> &MDfeSts
			
			If not &MDfeProt.IsEmpty()
				MDFeProt = &MDfeProt
			EndIF
			
			MDFeSts = &MDfeSts
			
			Exit
		EndFor
EndCase

commit

Sub 'CarregaEmail_CTE_NFE'
	//################################# BUSTA E-MAIL DO CTE #################
	&SdtEmail.Clear()
	For Each Order EmpCod, FilCod,MDFeCod, MDFeCteItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		&FilFonNum = FilFonNum		
		&MdfeNum = MDFeNum
		&EmlAss = 'MDF-e - Manifesto de Conhecimento de Transporte ' + trim(toformattedString(&MdfeNum)) + ' da ' + trim(FilFan)
		&PesRaz = FilRaz
		&MDFeCteCod = MDFeCteCod
		&MDFeCteFilCod = MDFeCteFilCod
		
		Do 'CarregaCte'
	EndFor
	
	//################################# BUSTA E-MAIL DO NFE #################
	For Each Order EmpCod, FilCod,MDFeCod,MDFeNFeItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MdfeCod
		&FilFonNum = FilFonNum		
		&MdfeNum = MDFeNum
		&EmlAss = 'MDF-e - Manifesto de Conhecimento de Transporte ' + trim(toformattedString(&MdfeNum)) + ' da ' + trim(FilFan)
		&PesRaz = FilRaz
		&MdfeNfeCod = MDFeNfeCod
		&MDFeNFeFilCod = MDFeNFeFilCod
		Do 'CarregaNfe'
	EndFor
EndSub

Sub 'carregacte'
	For each order EmpCod,FilCod,CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &MDFeCteFilCod
		Where CteCod = &MDFeCteCod
		
		Do Case
			Case &FilEnvEml = EmailEnvolvidosCte.SomenteRemetente
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.Somentedestinatario
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.SomenteTomador
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.RemetenteDestinatario
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
			Case &FilEnvEml = EmailEnvolvidosCte.RemetenteTomador
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.DestinatarioTomador
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)	
			Case &FilEnvEml = EmailEnvolvidosCte.Todos
				//REMETENTE
				RetornaEmailFaturamento.Call(EmpCod, CteRemCod, &SdtEmail)
				//DESTINATÁRIO
				RetornaEmailFaturamento.Call(EmpCod, CteDesCod, &SdtEmail)
				//TOMADOR
				RetornaEmailFaturamento.Call(EmpCod, CteTomCod, &SdtEmail)
		EndCase			
		
		Exit
	EndFor

EndSub


Sub 'CarregaNfe'

	For each order EmpCod,FilCod,NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &MDFeNFeFilCod
		Where NfeCod = &MdfeNfeCod
		RetornaEmailFaturamento.call(EmpCod, NfeCliCod, &SdtEmail)
		exit
	EndFor

EndSub

