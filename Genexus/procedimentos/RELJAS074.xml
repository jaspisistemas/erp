      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	print Cabecalho
End

&AuxProForCod = 0
&FiltroGrupHie = &GrupHie.Trim() + '.'
For Each
	Order EmpCod, ProSts, ProForCod, ProNom, ProForVlrCus When &Ordem = 'N' //NOME PRODUTO
	Order EmpCod, ProSts, ProForCod, ProRefPadL, ProForVlrCus When &Ordem = 'P' //CODIGO PRODUTO
	Order EmpCod, ProSts, ProForCod, ProForProCod, ProForVlrCus When &Ordem = 'C' //CODIGO DO FORNECEDOR
	Order EmpCod, ProSts, ProForCod, GrupHiePadL, ProNom, ProForVlrCus When &Ordem = 'G' //GRUPO
	
	
	Where EmpCod = &EmpCod
	Where ProSts = Status_Produto.ATIVO
	Where ProForCod = &ProForCod or &ProForCod = 0
	Where (ProForCod = ProPadForCod and &ImprimirSomentePadrao = 'S') or &ImprimirSomentePadrao <> 'S'
	Where ProTipDef in (Definicao.MATERIAPRIMA, Definicao.REVENDA, Definicao.SUBPRODUTO)
	Where ProTipCus <> TipoCusto.Receita
	Where ProForIs = true
	Where GrupHie like &FiltroGrupHie or GrupHie = &GrupHie when not &GrupHie.IsEmpty()
	
    &ProCod = ProCod
	&ProGracod = 1
	do 'BuscaEstoque'
	
	If (&EstSdo > 0 and &ImprimirTodosProdutos = 'C') or (&EstSdo <= 0 and &ImprimirTodosProdutos = 'S') or &ImprimirTodosProdutos = 'T'
		If &AuxProForCod <> ProForCod
			&PedCliCodRaz = trim(Str(ProForCod)) + ' - ' + trim(ProForRaz)
			
			if &IsCusto = true
				Print TituloSomenteCusto
			Else
				Print TituloCliente
			Endif
		
			&AuxProForCod = ProForCod
			&AuxGrupHie = ''
		Endif
	
		if &Ordem = 'G' //ORDEM GRUPOS
			if &AuxGrupHie <> GrupHie
				&AuxGrupHie = GrupHie
				
				&GrupCodNom = GrupCodNom
				print tituloGrupo
			Endif
		Endif

		&ProCod = ProCod
		&ProRef = ProRef
		&ProNom = ProNom
		&ProForProCod = ProForProCod
		&ProForVlrCus = ProForVlrCus
		&ProForVlrCusTot = ProForVlrCusTot
		&AuxProForCod = ProForCod
		
		if &IsCusto = true
			Print EstoqueSomenteCusto
		Else
			Print Estoque
		Endif
		
//		If &ImprimirConcorrentes = 'S'
//			do 'ImprimirConcorrentes'
//		Else
			noskip
			print Tracejado
//		EndIf
	Endif
	
EndFor

Footer
	print Rodape
End

