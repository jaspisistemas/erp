//	print Tracejado
//EndSub

Sub 'BuscaEstoque'
    &EstCom = 0
    &EstVen = 0 
    &EstSdo = 0
    &EstFab = 0

    For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
    Where FilCod = &FilCod
    Where ProCod = &ProCod
	Where ProGraCod = &ProGracod
	
		&EstCom = EstCom
		&EstVen = EstVen
		&EstSdo = EstSdo
		&EstFab = EstMin
		
		Exit
    EndFor

    &EstFab = &EstFab - &EstSdo
	
    
    &EstFab = round(&EstFab+0.49,0)
EndSub
