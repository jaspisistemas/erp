      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf
&PesRaz = &Context.PesRaz


For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 0
MT 0
padraoUsuario.Call('L', &NomePadraoUsuarioGrava, &Context.PesCod, &Context.EmpCod, &PadObs, &padDtaMod)
&sdtTipEtq.FromJson(&PadObs)
&Count = 1

For &sdtTipEtqitem in &sdtTipEtq
	&Count += 1
	&auxPesRaz = &sdtTipEtqitem.CD.Trim() + ' - ' + &sdtTipEtqitem.DES.Trim()
	
	&titulo = 'FICHA DE APONTAMENTOS CHÃO DE FÁBRICA'
	Print Menu
	&i = 0
	Do while &i <= 19
		Print Detalhe
		&i += 1
	EndDo
	
	Print Total
	
	if mod(&Count, 2) = 0
		Print Tesoura
	Endif
	
EndFor

if &Count = 1
	&titulo = 'FICHA DE APONTAMENTOS'
	Print Menu
	&i = 0
	Do while &i <= 19
		Print Detalhe
		&i += 1
	EndDo
	
	Print Total
	
	Print Tesoura
	
	&titulo = 'FICHA DE APONTAMENTOS'
	Print Menu
	&i = 0
	Do while &i <= 19
		Print Detalhe
		&i += 1
	EndDo
	
	Print Total

EndiF
]]></Source>
