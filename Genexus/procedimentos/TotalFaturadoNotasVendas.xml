      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TotalFaturadoMoeda = 0
For each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where NfeNum > 0
	Where NfeDtaEms >= &dataInicial and NfeDtaEms <= &DataFinal
	Where NfeFin = NotaFinalidade.EmissaoNormal
	Where NfeEntSai = Status_EntradaSaida.Saida
	Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
	Where NfeSts = Status_NFe.Autorizada or NfeSts = Status_Nfe.Digitando
	
	
	
	&TotalFaturadoMoeda += NfeVlrTot
EndFor
]]></Source>
