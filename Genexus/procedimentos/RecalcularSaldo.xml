      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,CtaBanSts,CtabanCod,SdoDta
	Where EmpCod = &EmpCod
	Where CtaBanSts = Status_AtivoInativo.ATIVO
	Delete
EndFor

For Each Order EmpCod,CtaBanSts,MovCtaBanCod,MovDtaCon
	Where EmpCod = &EmpCod
	Where not MovDtaCon.IsEmpty()
	Where MovSts <> Status_Caixa.Cancelado or MovSts.IsEmpty() or MovSts.IsNull()
	Where CtaBanSts = Status_AtivoInativo.ATIVO
	
	&x += 1
	If &x > 299
		&Count += 300
		&Percentual = round((&Count / &Total) * 100, 0)
		&x = 0
		do 'Atualiza'
	EndIF
	&AtuCtaBanCod = MovCtaBanCod
	&MovDtaCon    = MovDtaCon
	&MovCreDeb    = MovCreDeb
	&MovVlr       = MovVlr
	Do 'GravaSaldo'
EndFor
//Msg('Terminado!!!!')

Sub 'GravaSaldo'
	For Each Order EmpCod,CtabanCod,SdoDta
		Where EmpCod = &EmpCod
		Where CtabanCod = &AtuCtaBanCod
		where SdoDta = &MovDtaCon		
		If &MovCreDeb = 'D' 
			SdoSai += &MovVlr
		Else
			SdoEnt += &MovVlr
		EndIf		
		
	When none
		Do 'sdoAnt'
		new                   //inser o primeiro saldo do dia
			EmpCod    = &EmpCod
			CtabanCod = &AtuCtaBanCod
			SdoAnt    = &sdoDia
			SdoDta    = &MovDtaCon
			If &MovCreDeb = 'D'
				SdoSai = &MovVlr
				SdoEnt = 0
			Else
				SdoSai = 0
				SdoEnt = &MovVlr
			EndIf
		EndNew
		
		For Each Order EmpCod,CtabanCod,SdoDta    //Remove saldo anterior e recalcula
			Where EmpCod = &EmpCod
			Where CtabanCod = &AtuCtaBanCod
			where SdoDta > &MovDtaCon			
			
			If &MovCreDeb = 'C'
				SdoAnt += &MovVlr
			Else
				SdoAnt -= &MovVlr
			EndIf				
		EndFor
	EndFor
EndSub

Sub 'sdoAnt' // pega saldo anterior para o novo dia
	&sdoDia = 0
	For Each Order EmpCod,CtabanCod,(SdoDta)
		Where EmpCod = &EmpCod
		Where CtabanCod = &AtuCtaBanCod
		Where SdoDta < &MovDtaCon 
		&sdoDia = SdoAtu
		Exit
	EndFor
EndSub

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
		Endnew
	endfor

	commit
EndSub
]]></Source>
