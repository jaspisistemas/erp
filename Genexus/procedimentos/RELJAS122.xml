      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtTipolancamento.FromXml(&webSession.Get('SALVATIPOLANCAMENTO'))


For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&Titulo = 'VENDAS POR NCM PERÍODO: ' + trim(toformattedString(&iniPedDtaEms)) + ' À ' + trim(toformattedString(&fimPedDtaEms))

MB 4
MT 2

Header
	Print Cabecalho
	print TituloSintetico
End

&AuxLctCod.Clear()

&i = 0
If &sdtTipolancamento.Count > 0
	For &sdtTipolancamentoItem in &sdtTipolancamento
		&i += 1
		&AuxLctCod.Add(&sdtTipolancamentoItem.LctCod, &i)
	EndFor
Else
	For Each Order LctAtuSal, LctCod
		Where LctAtuSal = &LctAtuSal
		&i += 1
		&AuxLctCod.Add(LctCod, &i)
	EndFor
EndIF


For Each Order EmpCod, FilCod, PedCod, PedItmCod //SOMA O TOTAL GERAL
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where LctAtuSal = &LctAtuSal
	Where (LctCod in &AuxLctCod)
	Where ((PedDtaEms >= &iniPedDtaEms And PedDtaEms <= &fimPedDtaEms) and &PedSts <> Status_pedido.FECHADO ) or ((PedDtaFat >= &iniPedDtaEms And PedDtaFat <= &fimPedDtaEms) and &PedSts = Status_pedido.FECHADO)
	Where (PedSts = &PedSts) or (&PedSts.IsEmpty() and (PedSts = Status_pedido.ABERTO or PedSts = Status_pedido.FECHADO or PedSts = Status_pedido.SEPARANDO))
	Where ((LctGerFin = &LctGerFin) or (&LctIntFin.IsEmpty()))
	Where NcmCod = &NcmCod or &NcmCod = 0
	where ProSts <> Status_Produto.EXCLUIDO
	
	&AuxNcmCod = NcmCod
	&PedQtd = PedQtd
	&PedVlrUnt = PedVlrItmComDsc
	
	&TotalQuantidadeGeral += PedQtd 
	&TotalMoedaGeral += PedVlrItmComDsc
	do 'AddSDT'
EndFor


Do CAse
	Case &Ordem = 'A' //QUANTIDADE CRESCENTE
		&QuantidadeValor = 'Q'
		&sdtProdutos.Sort('PedQtd')
	Case &Ordem = 'B' //QUANTIDADE DECRESCENTE
		&sdtProdutos.Sort('[PedQtd]')
		&QuantidadeValor = 'Q'
	Case &Ordem = 'C' //VALOR CRESCENTE
		&sdtProdutos.Sort('PedVlrLiq')
		&QuantidadeValor = 'V'
	Case &Ordem = 'D' //VALOR DECRESCENTE
		&sdtProdutos.Sort('[PedVlrLiq]')
		&QuantidadeValor = 'V'
EndCAse


&Linha = 0
For &sdtProdutosItem in &sdtProdutos
	&Linha += 1
	&AuxNcmCod = &sdtProdutosItem.NcmCod
	&TotalMoeda = &sdtProdutosItem.pedVlrLiq
	&TotalQUantidade = &sdtProdutosItem.PedQtd
	
	if mod(&Linha , 2) = 0
		Print NCM
	Else
		Print NCM1
	EndIF
	NoSkip
	
	If &QuantidadeValor = 'Q' //QUANTIDADE
		&Percentual = 0
		If &TotalQuantidadeGeral <> 0 and &TotalQUantidade <> 0
			&Percentual = round(((&TotalQUantidade / &TotalQuantidadeGeral) * 100), 2)
		EndIF
	Else //VALOR
		&Percentual = 0
		If &TotalMoedaGeral <> 0 and &TotalMoeda <> 0
			&Percentual = round(((&TotalMoeda / &TotalMoedaGeral) * 100), 2)
		EndIF
	EndIF
	
	Print TotalPedido
EndFor


print TotalGEral


Sub 'AddSDT'
	&IsAchou = false
	For &sdtProdutosItem in &sdtProdutos
		If &sdtProdutosItem.NcmCod = &AuxNcmCod
			&sdtProdutosItem.PedQtd += &PedQtd
			&sdtProdutosItem.pedVlrLiq += &PedVlrUnt
			&IsAchou = true
			Exit
		EndIF
	EndFor
	
	If &IsAchou = false
		&sdtProdutosItem = new()
		&sdtProdutosItem.PedQtd = &PedQtd
		&sdtProdutosItem.NcmCod = &AuxNcmCod
		&sdtProdutosItem.pedVlrLiq = &PedVlrUnt
		&sdtProdutos.Add(&sdtProdutosItem)
	EndIF
EndSUb
]]></Source>
