        <Source><![CDATA[/*A operação POST “autenticacao” é responsável por criar uma chave criptografada, denominada
“chaveTransacao”, baseada na Chave Master. O formato de entrada e saída é JSON, considerando que a saída
sempre é composta da entidade a ser retornada e um código HTTP dentro de um Response.
Observação : deve ser respeitada a orientação da segurança da informação referente a expiração da Chave de
Transação, observando o parâmetro “dataExpiracao” de retorno do serviço (expira a cada 24 horas). Caso o
beneficiário possua mais de uma conta, cada conta terá que ter a sua própria Chave Master, podendo assim,
gerar a Chave de Transação para cada conta específica. Não há a possibilidade de renovar o token de transação
antes da expiração. Somente com a geração de outra Chave Master será possível gerar uma nova Chave de
Transação antes da expiração.
*/


//1.1 Recurso Autenticacão
//Post passando a chave master como Header "token" 
//https://cobrancaonline.sicredi.com.br/sicredi-cobranca-ws-ecomm-api/ecomm/v1/boleto/autenticacao

csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.SecurityProtocolType.Tls11 | System.Net.SecurityProtocolType.Tls;

HostWebServiceBoletoApi.Call('ECOMERCE',748, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor) // 748 = Sicredi
&HttpClient.Host = &EmpWebHost //servidor
&HttpClient.Secure = 1
&httpclient.AddHeader(!'Content-type',!'application/json')
&httpclient.AddHeader('token',trim(&CbrChaMas))
&String = '/sicredi-cobranca-ws-ecomm-api/ecomm/v1/boleto/autenticacao'

padraoUsuarioHora.Call('G', '#BOLETOAPIECOMMERCEPREV', &Context.PesCod, &Context.EmpCod, &HttpClient.toString(), &PadDtaMod,serverNow(),'T')  // Grava resultado do Post só como um LOG para Consulta

&HttpClient.Execute('POST',&String)

padraoUsuarioHora.Call('G', '#BOLETOAPIECOMMERCE', &Context.PesCod, &Context.EmpCod, &HttpClient.ToString(), &PadDtaMod,serverNow(),'T')  // Grava resultado do Post só como um LOG para Consulta


If &HttpClient.ErrCode = 0 //sem erro de comunicação
	&StdautenticacaoBoleto.fromJson(&HttpClient.toString())
	If not &StdautenticacaoBoleto.chaveTransacao.IsEmpty()
		Do 'GravaAutenticacaoLocalCobranca'
	EndIf
	&IschaveTransacao = True
Else
	&StdautenticacaoBoletoErro.fromJson(&HttpClient.toString())
	
	&properties.Set('Http', &HttpClient.ToString())
	&properties.Set('Erro Http', &HttpClient.ErrCode.ToString())
	&properties.Set('Msg Http', &HttpClient.ErrDescription)
	&properties.Set('Code', &StdautenticacaoBoletoErro.codigo.Trim())
	&properties.Set('Parametro', &StdautenticacaoBoletoErro.parametro.Trim())
	&properties.Set('Msg', &StdautenticacaoBoletoErro.mensagem.Trim())
	&MsgErro = &properties.ToJson()
	
	msg( DVMessageBasicNotification.Udp(!"Error!", &MsgErro,DVMessageType.error, "", DVMessageBoolean.True) )
	&IschaveTransacao = False
EndIf

commit

Sub 'GravaAutenticacaoLocalCobranca'
	For each Order EmpCod,CbrCod,CbrTipImp
		Where EmpCod = &EmpCod
		Where CbrCod = &CbrCod
		&CbrChaTra = &StdautenticacaoBoleto.chaveTransacao
		CbrChaTra = &StdautenticacaoBoleto.chaveTransacao
		&DataVarchar = &StdautenticacaoBoleto.dataExpiracao
		&dateTime = ymdhmstot(val(substr(&DataVarchar,1,4)),val(substr(&DataVarchar,6,2)),Val(substr(&DataVarchar,9,2)),Val(substr(&DataVarchar,12,2)),Val(substr(&DataVarchar,15,2)),Val(substr(&DataVarchar,18,2)))
		//"2019-08-29T08:20:21"
		CbrChaTraVct = &dateTime
		&CbrChaTraVct = &dateTime
		exit
	EndFor
	Commit
EndSub

]]></Source>
