      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&NfeProBasIcms = 0
&NfeProVlrIcms = 0
&NfeProTaxIcms = 0
&NfeVlrTot = 0

For Each Order EmpCod, FilCod, NfeCod, NfeCfoCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where NfeCod = &NfeCod
	Where NfeCfoCod = &NfeCfoCod
	
	&NfeVlrTot += (NfeProVlrTot + NfeProVlrImcsSt + NfeProVlrIpi + NfeProVlrFrt + NfeProVlrOutDsp) - NfeProVlrDsc
	
	if NfeProVlrImcsSt > 0
		&NfeProBasIcms += NfeProBasIcmsSt
		&NfeProVlrIcms += NfeProVlrImcsSt
	EndIF
EndFor

if &NfeProBasIcms > 0 and &NfeProVlrIcms > 0
	&NfeProTaxIcms = round((&NfeProVlrIcms * 100) / &NfeProBasIcms, 0)
EndIF
]]></Source>
