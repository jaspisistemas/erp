      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do While &IniFicBar <= &FinFicBar 
	
	UltimoCodigoEmpresa.Call(domParCod.FICHA, &EmpCod, 0, &FicCod)
	&RepetidoEanMensagem = ''
	&FicBar = &IniFicBar.ToString().Trim()
	VerificaCodigoUnicoFicha.Call(&EmpCod, &FicCod, &FicBar, &RepetidoEanMensagem)
	If &RepetidoEanMensagem = ''
		New
			EmpCod = &EmpCod
			FicCod = &FicCod
			FicBar = &IniFicBar.ToString().Trim()
			FicNom = &FicNom
		EndNEW
		&erro = 0
		Commit
	Else
		&erro = 1
		Msg(&RepetidoEanMensagem)
	EndIf

	&IniFicBar +=1
EndDo

If &erro = 0
	Msg('Sequência Gravada com sucesso!')
EndIf
]]></Source>
