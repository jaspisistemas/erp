      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each ORder EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &filcod
	Where MDFeCod = &mdfecod
	
	Do CAse		
		case &inSdtMdfe.sts = 'ADDCONTR'
			MdfeConCnpj = &inSdtMdfe.ConCnpj
			validaCpfCnpj.Call(MdfeConCnpj, &Numeric, 'S')
			MdfeConRaz = &inSdtMdfe.ConRaz
			
		Case &inSdtMdfe.sts = 'TIPPEDA'			
			For Each Order EmpCod, FilCod, MDFeCod,MdfePedCod
				Where MdfePedCod = 1
				
				MdfePedTip.FromString(&inSdtMdfe.PedTip)
				
				exit
			When none
				New
					EmpCod         = &EmpCod
					FilCod         = &FilCod
					MDFeCod        = &MDfeCod
					MdfePedCod     = 1
					MdfePedTip.FromString(&inSdtMdfe.PedTip)
				EndNew
			EndFor
			
		Case &inSdtMdfe.sts = 'DADOSPED'
			MdfeCatComVei.FromString(&inSdtMdfe.CatComVei)
			
			For Each Order EmpCod, FilCod, MDFeCod,MdfePedCod
				Where MdfePedCod = 1				
				MdfePedCnpjFor = &inSdtMdfe.PedCnpjFor
				MdfePedNroCom  = &inSdtMdfe.PedNroCom
				validaCpfCnpj.Call(MdfePedCnpjFor, &Numeric, 'S')
				
				MdfePedResPag  = &inSdtMdfe.PedResPag
				validaCpfCnpj.Call(MdfePedResPag, &Numeric, 'S')
				MdfePedVlr.FromString(&inSdtMdfe.PedVlrVar)
				exit
			When none
				New
					EmpCod         = &EmpCod
					FilCod         = &FilCod
					MDFeCod        = &MDfeCod
					MdfePedCod     = 1
					MdfePedCnpjFor = &inSdtMdfe.PedCnpjFor
					validaCpfCnpj.Call(MdfePedCnpjFor, &Numeric, 'S')
					MdfePedNroCom  = &inSdtMdfe.PedNroCom
					MdfePedResPag  = &inSdtMdfe.PedResPag
					validaCpfCnpj.Call(MdfePedResPag, &Numeric, 'S')
					MdfePedVlr.FromString(&inSdtMdfe.PedVlrVar)
					
				EndNew				
			EndFor
			
		CAse &inSdtMdfe.sts = 'RNTRC'
			MDFeRNTRC = &insdtMdfe.RNTRC
		
	EndCase
	
EndFor


commit

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
