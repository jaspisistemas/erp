        <Source><![CDATA[
For Each Order EmpCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where ProBarQtd = &ProQtdEmb
