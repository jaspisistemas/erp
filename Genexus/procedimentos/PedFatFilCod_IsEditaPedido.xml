      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//DUPLICATA PAGA. NAO EDITA MAIS FILIAL PEDIDO/NOTA
&IsEdita = true
if &PedCod > 0
	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CrePedCod = &PedCod
		Where CreSts <> Status_Duplicata.CANCELADA
		//Where (CreVlrSdo <> CreVlrDup) or (CreCbrImp = TipoImpressao.GerarBoleto) or (CreCbrImp = TipoImpressao.ImprimirBoleto)
		
		&Mensagem = 'DUPLICATA PARA O PEDIDO'
		&IsEdita = false	
		Exit
	EndFor
	
	
	if &IsEdita = true //NOTA EMITIDA. NAO EDITA MAIS FILIAL PEDIDO/DUPLICATA
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmpCod
			Where NfeFilCod = &FilCod
			Where NfePedCod = &PedCod
			Where (NfeSts = Status_NFe.Autorizada) or (NfeSts = Status_NFe.Digitando)
			
			&Mensagem = 'NFe AUT./DIG.: ' + trim(Str(NfeNum))
			
			&IsEdita = false
			Exit
		EndFor
	EndiF
Endif
]]></Source>
