      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProGUID.SetEmpty()
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	if ProGUID.IsEmpty() or ProGUID.IsNull()
		ProGUID = GUID.NewGuid()
		ProDtaHorUltMod = now()
	Endif

	&ProGUID = ProGUID
	
	Exit
EndFor


Commit
]]></Source>
