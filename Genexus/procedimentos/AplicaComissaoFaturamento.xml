      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TotaFaturadoMoeda = 0

//PEDIDOS EMITIDOS
For Each Order EmpCod, FilCod, PedVenCod, PedDtaEms
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedVenCod = &PedVenCod
	Where Year(PedDtaFat) = &Ano
	Where Month(PedDtaFat) = &Mes
	//Where LctGerFin = Status_SimNao.Sim 
	//Where LctAtuSal = Status_EntradaSaida.Saida // ATUALIZA SALDO
	where LctPagCom = Status_SimNao.Sim //PAGA COMISSAO
	Where PedSts = Status_pedido.FECHADO // or PedSts = Status_Pedido.SEPARANDO
	
	&TotaFaturadoMoeda += PedVlrLiq	
EndFor
]]></Source>
