      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ProVlrUltCmp = 0

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&ProVlrUltCmp = ProVlrUltCmp	
	&ProTipCusAcrRec = ProTipCusAcrRec 
	Exit
EndFor

CustoInformadoManualmente.Call(&EmpCod, &ProCod, &ProVlrUltCmpManual)
if &ProVlrUltCmpManual > 0
	&ProVlrUltCmp = &ProVlrUltCmpManual
Endif

if &ProVlrUltCmp <= 0
	&ProVlrUltCmp = RetornaCustoFixo.Udp(&EmpCod, &ProCod)
EndIF

if &ProTipCusAcrRec = true //Complementar Custo Receita
	RetornaCOMPLEMENTARRECEITA.Call(&EmpCod, &ProCod, &complementoReceita)
	&ProVlrUltCmp += &complementoReceita
Endif
]]></Source>
