      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAchou = False
//DELETA ITENS DOS PEDIDOS
For Each Order EmpCod, FilCod, PedCod, PedItmCod, PedProPagItm
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&IsAchou = true //achou algum pagto
	&PedItmCod = PedItmCod
	&PedProPagVlr = PedProPagVlr
	&PedProPagQtd = PedProPagQtd
	do 'DiminuiItem'

	delete	
EndFor

commit
If &IsAchou = true //achou algum pagto
	prcDividirConta.Call(&EmpCod, &FIlCOd, &PedCod, 0, true, 0)
EndIf

Sub 'DiminuiItem'
	//DELETA ITENS DOS PEDIDOS
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		where PedItmCod = &PedItmCod
		PedItmPagQtdTot -= &PedProPagQtd
		PedItmPagVlrTot -= &PedProPagVlr 
		if PedItmPagVlrTot < 0
			PedItmPagVlrTot = 0
		Endif
	
		If PedItmPagQtdTot < 0
			PedItmPagQtdTot = 0
		EndIf		
		Exit		
	EndFor
	
	commit
EndSub
]]></Source>
