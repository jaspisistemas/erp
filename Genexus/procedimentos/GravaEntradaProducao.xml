      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&MensagemAlterado = ''
&MensagemInserido = ''

For Each Order EmpCod, FilCod, PrdCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PrdCod = &PrdCod
	If PrdSts <> Status_Pedido.ABERTO
		WWEntradaProducao.Link()
	EndIF
	
EndFor

For Each Order EmpCod, ProCod
	WHere EmpCod = &EmPCod
	Where ProCod = &ProCod
	&PrdVlrUnt = ProVlrCus
EndFor

For Each Order EmpCod, FilCod, PrdCod,ProCod, ProGraCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PrdCod = &PrdCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	&PrdItmCod = PrdItmCod
	&OldPrdItmQtd = PrdItmQtd
	PrdItmQtd = &PrdItmQtd
	
	PrdProEstPrd = &PrdProEstPrd
	PrdProEstQtd = &PrdProEstQtd
	PrdVlrUnt = &PrdVlrUnt
	&MensagemAlterado = 'Produto: ' + trim(Str(&ProCod)) + ' ALTERADO com sucesso! Quantidade Anterior:' + trim(toformattedString(&OldPrdItmQtd))
	Exit
When None
	For Each Order EmpCod, FilCod, PrdCod, (PrdItmCod)
		Where EmpCod = &EmPCod
		Where FilCod = &FilCod
		Where PrdCod = &PrdCod
		&PrdItmCod = PrdItmCod
		Exit
	EndFor
	&PrdItmCod += 1
	
	new
		EmpCod = &EmPCod
		FilCod = &FilCod
		PrdCod = &PrdCod
		PrdItmCod = &PrdItmCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		PrdItmQtd = &PrdItmQtd
		PrdProEstPrd = &PrdProEstPrd
		PrdProEstQtd = &PrdProEstQtd
		PrdVlrUnt = &PrdVlrUnt
	EndNew
	
	&MensagemInserido = 'Produto: ' + trim(Str(&ProCod)) + ' ADICIONADO com sucesso!'
EndFor

Commit

//################################### LOTES ###########################################################################
if &sdtProdutoLote.Count > 0
	For Each Order EmpCod, FilCod, PrdCod, PrdItmCod, PrdProEstLotCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PrdCod = &PrdCod
		Where PrdItmCod = &PrdItmCod
		delete
		
	EndFor
	
	Commit
	
	For &sdtProdutoLoteItem in &sdtProdutoLote
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			PrdCod = &PrdCod
			PrdItmCod = &PrdItmCod
			if &sdtProdutoLoteItem.PedProEstLotCod.IsEmpty()
				PrdProEstLotCod = trim(toformattedString(&sdtProdutoLoteItem.PedProEstLotVct))
			Else
				PrdProEstLotCod = &sdtProdutoLoteItem.PedProEstLotCod
			Endif
			PrdProEstLotFab = &sdtProdutoLoteItem.PedProEstLotFab
			PrdProEstLotVct = &sdtProdutoLoteItem.PedProEstLotVct
			PrdProEstLotQtd = &sdtProdutoLoteItem.PedProEstLotQtd
		EndNew
	EndFor
	
	Commit
Endif
]]></Source>
