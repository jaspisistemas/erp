      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	Where NfeDupItmCod = &NfeDupItmCod	
	NfeDupCreSeq = &NfeDupCreSeq
	NfeDupFiLCod = &NfeDupFiLCod 
	
	NfeDupFrpPgtoCod = &NfeDupFrpPgtoCod
	
	NfeDupNro =  &CreDupNro
	
	NfeDupVlr = &NfeDupVlr
	NfeDupVct = &NfeDupVct
	
	NfeCbrCod = &CreCbrCod
	Exit
When none
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		NfeCod = &NfeCod
		NfeDupItmCod = &NfeDupItmCod	
		
		NfeDupCreSeq = &NfeDupCreSeq
		NfeDupFiLCod = &NfeDupFiLCod 
		
		NfeDupFrpPgtoCod = &NfeDupFrpPgtoCod
		
		NfeDupNro =  &CreDupNro
		
		NfeDupVlr = &NfeDupVlr
		NfeDupVct = &NfeDupVct
		
		NfeCbrCod = &CreCbrCod
	EndNew
EndFor


Commit

//ATUALIZA NA DUP
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &NfeDupFiLCod
	Where CreCod = &NfeDupCreSeq
	
	CreNfeCod = &NfeCod
	CreNfeFilCod = &FilCod
	
	Exit
EndFor

Commit

AtualizaSaldoDuplicata.Call(&EmpCod, &NfeDupCreSeq, &NfeDupFiLCod)
]]></Source>
