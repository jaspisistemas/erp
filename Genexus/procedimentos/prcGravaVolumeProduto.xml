      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&EtqVolItm = 0
For Each Order EmpCod, EtqVolFilCod, EtqVolPedCod, (EtqVolItm)
	Where EmpCod = &EmpCod
	Where EtqVolFilCod = &FilCod
	Where EtqVolPedCod = &PedCod
	&EtqVolItm = EtqVolItm
	Exit
EndFor
&EtqVolItm += 1

new
	EmpCod = &EmpCod
	EtqVolFilCod = &FilCod 
	EtqVolPedCod = &PedCod
	EtqVolItm = &EtqVolItm
	EtqVolRefCod = &ProRef
	EtqVolNovRefCod = &EtqVolNovRefCod
	EtqVolNovProNom = &EtqVolNovProNom
	EtqVolNro = &EtqVolNro
	EtqVolPedQtd = &EtqVolPedQtd
	EtqVolCodBar = &EtqVolCodBar
EndNew

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
