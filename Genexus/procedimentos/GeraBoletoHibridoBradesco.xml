<Object parentGuid="9f5af025-e9e6-469a-9837-2ee52db86dc1" user="LUIZ\LuiZ Henrique" versionDate="2024-09-30T12:10:14.0000000Z" lastUpdate="2024-09-30T11:46:23.0000000Z" checksum="c1f1af6a97bb59a9be179a2057fa61de" fullyQualifiedName="GeraBoletoHibridoBradesco" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="5b4ecfe6-0ad7-4e07-baf5-d16d74bac419" name="GeraBoletoHibridoBradesco" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Gera Boleto Hibrido Bradesco" parent="API_BoletoHibrido_Bradesco" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PREENCHIDO = 0
&IsErro = false
&Mensagem.SetEmpty()
LoadWWPContext.Call(&WWPContext)

For Each Order EmpCod, CreCod,CreRecPag,CreCrbRegAut
	Where EmpCod = &EmpCod
	Where CreCod = &CreCod
	Where CreRecPag = ReceberPagar.Receber
	Where CreDtaVct >= serverdate()
	Where CreCrbRegAut = Status_SimNao.Sim
	
	&CreCliCod = CreCliCod
	&CreDtaEms = CreDtaEms
	&CreDtaVct = CreDtaVct
	&CreCliRaz = RetiraCaracteresEspeciais.Udp(CreCliRaz)
	
	&CreCbrCod = CreCbrCod
	
	Do 'GetLocalCobraca'
	
	// ************* PREENCHENDO OS DADOS DO SDT ***************\\

	&BradescoRegistroBoleto_Request.registrarTitulo	= '1' //FIXO
	&BradescoRegistroBoleto_Request.codUsuario	= 'APISERVIC'	//FIXO
	
	&CbrCnpj = RetornaSoNumeros.Udp(&CbrCnpj)
	&nuCPFCNPJvar = Substr(&CbrCnpj, 1, 8)
	&BradescoRegistroBoleto_Request.nroCpfCnpjBenef	= IIf(&CbrCtaBanPixApi = 'P', &nuCPFCNPJvar, '68542653')//8 PRIMEIROS DÍGITOS DO CNPJ DO BENEFICIÁRIO
	&filialCPFCNPJvar = Substr(&CbrCnpj, 9, 4)	
	&BradescoRegistroBoleto_Request.filCpfCnpjBenef = IIf(&CbrCtaBanPixApi = 'P', &filialCPFCNPJvar, '1018')//FILIAL DO CNPJ
	&ctrlCPFCNPJvar = Substr(trim(&CbrCnpj),13,2)
	&BradescoRegistroBoleto_Request.digCpfCnpjBenef = IIf(&CbrCtaBanPixApi = 'P', &ctrlCPFCNPJvar, '38')//DIGITO VERIFICADOR DO CNPJ

	&BradescoRegistroBoleto_Request.tipoAcesso	= '2'	//FIXO
	&BradescoRegistroBoleto_Request.cpssoaJuridContr	= '2269651'	//FIXO
	&BradescoRegistroBoleto_Request.ctpoContrNegoc	= '48'	//FIXO
	&BradescoRegistroBoleto_Request.nseqContrNegoc	= '0'	//FIXO
	
	&BradescoRegistroBoleto_Request.cidtfdProdCobr	= PadL(&CbrCarCod.Trim(), 2, '0')	//CARTEIRA
	
	&Conta = padL(&CbrCtaBanCrt, 7, '0' )
	&nuNegociacao = PadL(&CbrCtaBanAgeCod,4, '0') + '0000000' + &Conta
	&BradescoRegistroBoleto_Request.cnegocCobr	= IIf(&CbrCtaBanPixApi = 'P', &nuNegociacao, '386100000000041000')//NEGOCIAÇÃO AGÊNCIA + CONTA. EX: AAAA0000000CCCCCCC
	
	&BradescoRegistroBoleto_Request.codigoBanco	= '237'	//FIXO
	&BradescoRegistroBoleto_Request.filler	= ''
	&BradescoRegistroBoleto_Request.eNseqContrNegoc	= '0'	//FIXO
	&BradescoRegistroBoleto_Request.tipoRegistro	= '001'	//001 = TÍTULO | 002 = TÍTULO COM INSTRUÇÃO DE PROTESTO | 003 = TÍTULO COM INSTRUÇÃO DE PROTESTO FALIMENTAR
	&BradescoRegistroBoleto_Request.cprodtServcOper	= '0'	//FIXO
	
	If CreBloNro.Trim().IsEmpty()
		&CtaBanNosNro += 1
		GerarNossoNumero.CALL(&CbrCtaBanBanCod, &CbrNroCon, &CtaBanNosNro, CreDtaEms, &AuxCreBloNro, &Erro)	
		If &Erro = 0
			CreBloNro = trim(&AuxCreBloNro)
			Do 'GravaNossoNumero'
		Else
			&Mensagem += 'ERRO:Numero Bloqueto'
			&IsErro = true
		EndIf
	EndIf

	&BradescoRegistroBoleto_Request.ctitloCobrCdent	= IIf(&CbrCtaBanPixApi = 'P', &AuxCreBloNro, '127605609')//NOSSO NÚMERO
	&BradescoRegistroBoleto_Request.ctitloCliCdent	= CreDupNro	//SEU NÚMERO
	
	&DataEms = RetornaSoNumeros.Udp(&CreDtaEms.ToString())
	&DataEms = Substr(&DataEms, 1, 2) + '.' + Substr(&DataEms, 3, 2) + '.' + Substr(&DataEms, 5, 4)
	&BradescoRegistroBoleto_Request.demisTitloCobr	= &DataEms	//DATA DE EMISSÃO, 01.01.2001 
	
	&DataVct = RetornaSoNumeros.Udp(&CreDtaVct.ToString())
	&DataVct = Substr(&DataVct,1,2) + '.' + Substr(&DataVct,3,2) + '.' + Substr(&DataVct,5,4)  
	&BradescoRegistroBoleto_Request.dvctoTitloCobr	= &DataVct	//DATA DE VENCIMENTO, 01.01.2001 - PARA GERAR QR CODE, DEVE SER IGUAL OU MAIOR QUE A DATA CORRENTE
	
	&BradescoRegistroBoleto_Request.cidtfdTpoVcto	= '0' //FIXO
	&BradescoRegistroBoleto_Request.cindcdEconmMoeda	= '00006' //FIXO
	
	&BradescoRegistroBoleto_Request.vnmnalTitloCobr	= PadL(Str((CreVlrDup * 100)), 17, '0')	//EX: R$ 2,00 = 00000000000000200 | R$ 0,05 = 00000000000000005
	&BradescoRegistroBoleto_Request.qmoedaNegocTitlo	= PadL(Str((CreVlrDup * 100)), 17, '0')
	&BradescoRegistroBoleto_Request.cespceTitloCobr	= '02' //02 = DUPLICATA MERCANTIL
	&BradescoRegistroBoleto_Request.cindcdAceitSacdo	= 'N' //FIXO
	
	&BradescoRegistroBoleto_Request.ctpoProteTitlo	= '0'
	&BradescoRegistroBoleto_Request.ctpoPrzProte	= '0'
	&BradescoRegistroBoleto_Request.ctpoProteDecurs	= '0'
	
	&BradescoRegistroBoleto_Request.ctpoPrzDecurs	= '00' //FIXO
	&BradescoRegistroBoleto_Request.cctrlPartcTitlo	= '0'
	&BradescoRegistroBoleto_Request.cformaEmisPplta	= '02'	//FIXO
	&BradescoRegistroBoleto_Request.cindcdPgtoParcial	= 'N'	//PAGAMENTO PARCIAL: S = SIM | N = NÃO - FIXO
	&BradescoRegistroBoleto_Request.qtdePgtoParcial	= '0' //SE PAGAMENTO PARCIAL FOR = SIM, PREENCHER DE 001 A 099
	&BradescoRegistroBoleto_Request.filler1	= ''
	
	if &JurTax <> 0 and not &JurTax.IsEmpty()
		&DiaVarChar.SetEmpty()
		&numericInteiro  = &JurTax * 100000 
		&percentualJuros = SubStr(padL(trim(str(&numericInteiro)), 7, '0') , 1, 7)
		&BradescoRegistroBoleto_Request.ptxJuroVcto	= &percentualJuros
		&BradescoRegistroBoleto_Request.vdiaJuroMora	= '0'
		&BradescoRegistroBoleto_Request.qdiaInicJuro	= '01'
	else
		&BradescoRegistroBoleto_Request.ptxJuroVcto	= '0'
		&BradescoRegistroBoleto_Request.vdiaJuroMora	= ''
		&BradescoRegistroBoleto_Request.qdiaInicJuro	= '0'
	EndIf

	if &CbrMltVlr <> 0 or not &CbrMltVlr.IsEmpty()
		&numericInteiro.SetEmpty()
		&numericInteiro = &CbrMltVlr * 100000 
		&percentualMulta  = SubStr(padL(trim(str(&numericInteiro)), 7, '0') , 1, 7)
		&BradescoRegistroBoleto_Request.pmultaAplicVcto	= &percentualMulta
		&BradescoRegistroBoleto_Request.vmultaAtrsoPgto	= '0'
		&BradescoRegistroBoleto_Request.qdiaInicMulta	= '001'
	else
		&BradescoRegistroBoleto_Request.pmultaAplicVcto	= '0'
		&BradescoRegistroBoleto_Request.vmultaAtrsoPgto	= ''
		&BradescoRegistroBoleto_Request.qdiaInicMulta	= '0'
	EndIf
	
	&numericInteiro.SetEmpty()
	&numericInteiro = &CbrDesDia * 100000
	&percentualDesconto1 = SubStr(padL(trim(str(&numericInteiro)), 7, '0') , 1, 7)
	&BradescoRegistroBoleto_Request.pdescBonifPgto01	= &percentualDesconto1
	&BradescoRegistroBoleto_Request.vdescBonifPgto01	= '0'
	If (&CreDtaVct - &CreDtaEms) > &CbrQtdDiaDesc  
		&Data.SetEmpty()
		&Data = &CreDtaVct.AddDays(-1 * &CbrQtdDiaDesc)
		&DataVct = RetornaSoNumeros.Udp(&Data.ToString())
		&DataVct = Substr(&DataVct, 1, 2) + '.' + Substr(&DataVct, 3, 2) + '.' + Substr(&DataVct, 5, 4)
	else
		&DataVct.SetEmpty()
	EndIf
	&BradescoRegistroBoleto_Request.dlimDescBonif1	= IIf(&CbrDesDia > 0 and not &DataVct.Trim().IsEmpty(), &DataVct, '')

	&BradescoRegistroBoleto_Request.pdescBonifPgto02	= '0'
	&BradescoRegistroBoleto_Request.vdescBonifPgto02	= '0'
	&BradescoRegistroBoleto_Request.dlimDescBonif2	= ''
	&BradescoRegistroBoleto_Request.pdescBonifPgto03	= '0'
	&BradescoRegistroBoleto_Request.vdescBonifPgto03	= '0'
	&BradescoRegistroBoleto_Request.dlimDescBonif3	= ''
	
	&BradescoRegistroBoleto_Request.ctpoPrzCobr	= '0' //1 = DIAS CORRIDOS | 2 = DIAS ÚTEIS
	&BradescoRegistroBoleto_Request.pdescBonifPgto	= '0'
	&BradescoRegistroBoleto_Request.vdescBonifPgto	= '0'
	&BradescoRegistroBoleto_Request.dlimBonifPgto	= ''
	&BradescoRegistroBoleto_Request.vabtmtTitloCobr	= '0'
	&BradescoRegistroBoleto_Request.viofPgtoTitlo	= '0'
	&BradescoRegistroBoleto_Request.filler2	= ''
					
	//SACADOR
	&BradescoRegistroBoleto_Request.isacdoTitloCobr	= Substr(Trim(CreCliRaz), 1, 70)
	&BradescoRegistroBoleto_Request.elogdrSacdoTitlo	= Substr(trim(CreCliCobLog), 1, 40)
	&BradescoRegistroBoleto_Request.enroLogdrSacdo	= CreCliCobNro
	&BradescoRegistroBoleto_Request.ecomplLogdrSacdo	= ''
	&cepPagador = Substr(CreCliCobCep, 1,5)
	&BradescoRegistroBoleto_Request.ccepSacdoTitlo	= &cepPagador
	&complementoCepPagador = Substr(CreCliCobCep, 7,3)
	&BradescoRegistroBoleto_Request.ccomplCepSacdo	= &complementoCepPagador
	&BradescoRegistroBoleto_Request.ebairoLogdrSacdo	= SubStr(Trim(CreCliCobBai), 1, 40)
	&BradescoRegistroBoleto_Request.imunSacdoTitlo	= SubStr(Trim(CreCliCobCidNom), 1, 30)
	&BradescoRegistroBoleto_Request.csglUfSacdo	= CreCliCobUfeCod
	if CreCliTip = 'F'
		&BradescoRegistroBoleto_Request.indCpfCnpjSacdo	= '1'	//1 = CPF | 2 = CNPJ
		&CreCliCpf = padL(trim(RetornaSoNumeros.Udp(CreCliCpf)), 11, '0')
		&BradescoRegistroBoleto_Request.nroCpfCnpjSacdo	= &CreCliCpf
	else
		&BradescoRegistroBoleto_Request.indCpfCnpjSacdo	= '2'	//1 = CPF | 2 = CNPJ
		&CreCliCnpj = RetornaSoNumeros.Udp(CreCliCnpj)
		&BradescoRegistroBoleto_Request.nroCpfCnpjSacdo	= &CreCliCnpj
	EndIf
	&BradescoRegistroBoleto_Request.renderEletrSacdo	= IIf(CreCliPrmEml.Length() <= 70, CreCliPrmEml, '')
	&BradescoRegistroBoleto_Request.cdddFoneSacdo	= '0'
	&BradescoRegistroBoleto_Request.cfoneSacdoTitlo	= '0'
	
	&BradescoRegistroBoleto_Request.bancoDeb	= '0'
	&BradescoRegistroBoleto_Request.agenciaDeb	= '0'
	&BradescoRegistroBoleto_Request.agenciaDebDv	= '0'
	&BradescoRegistroBoleto_Request.contaDeb	= '0'
	&BradescoRegistroBoleto_Request.bancoCentProt	= '0' //FIXO
	&BradescoRegistroBoleto_Request.agenciaDvCentPr	= '0'
	
	&BradescoRegistroBoleto_Request.isacdrAvalsTitlo	= ''
	&BradescoRegistroBoleto_Request.elogdrSacdrAvals	=  ''
	&BradescoRegistroBoleto_Request.enroLogdrSacdr	= '0'
	&BradescoRegistroBoleto_Request.ecomplLogdrSacdr	= ''
	&BradescoRegistroBoleto_Request.ccepSacdrTitlo	= '0'
	&BradescoRegistroBoleto_Request.ccomplCepSacdr	= '0'
	&BradescoRegistroBoleto_Request.ebairoLogdrSacdr	= ''
	&BradescoRegistroBoleto_Request.imunSacdrAvals	= ''
	&BradescoRegistroBoleto_Request.csglUfSacdr	= ''
	&BradescoRegistroBoleto_Request.indCpfCnpjSacdr	= '0'
	&BradescoRegistroBoleto_Request.nroCpfCnpjSacdr	= '0'
	&BradescoRegistroBoleto_Request.renderEletrSacdr	= ''
	&BradescoRegistroBoleto_Request.cdddFoneSacdr	= '0'
	&BradescoRegistroBoleto_Request.cfoneSacdrTitlo	= '0'
	
	&BradescoRegistroBoleto_Request.filler3	= ''
	&BradescoRegistroBoleto_Request.fase	= '1' //1 = REGISTRO DO TÍTULO E GERAÇÃO DO QR CODE | 2 = VINCULAÇÃO DO TÍTULO COM QR CODE - FIXO
	&BradescoRegistroBoleto_Request.cindcdCobrMisto	= 'S' //INDICADOR DO REGISTRO DE TÍTULO COM QR CODE: S = SIM | N = NÃO - FIXO
	
	&BradescoRegistroBoleto_Request.ialiasAdsaoCta	= ''
	&BradescoRegistroBoleto_Request.iconcPgtoSpi	= ''
	&BradescoRegistroBoleto_Request.caliasAdsaoCta	= ''
	&BradescoRegistroBoleto_Request.ilinkGeracQrcd	= ''
	&BradescoRegistroBoleto_Request.wqrcdPdraoMercd	= ''
	&BradescoRegistroBoleto_Request.validadeAposVencimento	= '0'
	&BradescoRegistroBoleto_Request.filler4	= ''	
	
	&PREENCHIDO = 1
	exit
when none
	&Mensagem = 'Impossível gerar Boleto para esta Duplicata!, a Mesma NÃO pode estar vencida, e deve ser do tipo RECEBER, e com boleto online no local de Cobrança!'
	&IsErro = true
EndFor

//#################################################################################################################################################

iF &PREENCHIDO = 1
	
	If &IsErro	= False
		prcRegistraBoletoHibridoBradesco.Call(&EmpCod, &PesCod, &CreCbrCod, &CbrCnpj, &CbrChaTra, &BradescoRegistroBoleto_Request.ToJson(), &IsErroRegistro, &BradescoRegistroBoleto_Response)
		If &IsErroRegistro	= False
			Do 'AtualizaDadosRetorno'
		EndIf
	Else
		If &ErroCobraca	= 1
			&Mensagem = 'Erro de Autenticação!'
		EndIf
	EndIf
	
Else
	&Mensagem = 'A estrutura não está prenchida para poder consumir os servidores! Chave de Transação não encontrada  ou chave master inválida!'
	&IsErro = true
EndIf

If &IsErro	= True
	msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &Mensagem, DVMessageType.error, "", DVMessageBoolean.True,""))
EndIf

//#################################################################################################################################################
Sub 'GetLocalCobraca'
	
	&ErroCobraca = 0
	For each Order EmpCod, CbrCod
		Where EmpCod = &EmpCod
		Where CbrCod = &CreCbrCod
		
		&CbrCtaBanAgeCod = CbrCtaBanAgeCod
		&CbrCtaBanAgeDig = CbrCtaBanAgeDig
		&CbrCtaBanCrt = CbrCtaBanCrt
		&CbrCtaBanBanCod = CbrCtaBanBanCod
		&CbrNroCon = CbrNroCon
		&CbrCarCod = CbrCarCod
		&CbrDesDia = CbrDesDia
		&CbrQtdDiaDesc = CbrQtdDiaDesc
		&CbrDesAnt  = CbrDesAnt
		&CbrInsBol1 = CbrInsBol1
		&CbrMltVlr  = CbrMltVlr
		&CtaBanNosNro = CtaBanNosNro     // Local Cobrança Nosso Número
		&CbrCnpj = CbrCnpj
		&CbrCtaBanFilCod	= CbrCtaBanFilCod
		&CbrCtaBanPixApi	= CbrCtaBanPixApi
		
		Do 'GetFilial'
		prcGetAcessToken.Call(&EmpCod, &CbrCtaBanFilCod, &FilCerNom, &FilCerPsw, &CreCbrCod, &ErroAccess, &CbrChaTra)
		If &ErroAccess = 1
			&ErroCobraca	= 1
			&IsErro			= True
		EndIf		
	
		&CbrChaTra 	= IIf(&CbrChaTra.IsEmpty(), CbrChaTra, &CbrChaTra)
		&CbrJurCod = CbrJurCod             // Local Cobrança Juros Código
		&JurTax = 0
		Do 'Juros'
		
		exit
	EndFor
	
EndSub

Sub 'GetFilial'
	
	For Each Order EmpCod, FilCod
		Where EmpCod	= &EmpCod
		Where FilCod	= &CbrCtaBanFilCod
		
		&FilCerNom	= FilCerNom
		&FilCerPsw	= FilCerPsw
		
		Exit
	EndFor
	
EndSub

Sub 'Juros'	
	
	For each Order EmpCod,JurCod,(JurAno),(JurMes)
		Where EmpCod = &EmpCod
		Where JurCod = &CbrJurCod
		
		&JurTax = JurTax  //JDF - BANCO QUER A TAXA MENSAL E NAO AO DIA.

		Exit
	EndFor

EndSub

Sub 'AtualizaDadosRetorno'
	
	For Each Order EmpCod,CreCod, CreRecPag, CreCrbRegAut
		Where EmpCod = &EmpCod
		Where CreCod = &CreCod
		Where CreRecPag = ReceberPagar.Receber
		Where CreCrbRegAut = Status_SimNao.Sim
		
		&DtRegistroVar = &BradescoRegistroBoleto_Response.dataReg10
		CreDtaRet = yMDtoD(val(substr(&DtRegistroVar,5,4)),val(substr(&DtRegistroVar,3,2)),val(substr(&DtRegistroVar,1,2)))
		CreCodBar 		= &BradescoRegistroBoleto_Response.codBarras10
		CreLinDig 		= &BradescoRegistroBoleto_Response.linhaDig10
		CreQrCode 		= &BradescoRegistroBoleto_Response.wqrcdPdraoMercd
		CreTxId 		= &BradescoRegistroBoleto_Response.iconcPgtoSpi
		CreSts = Status_Duplicata.EM_REMESSA
		CreArqRetApiEco = &BradescoRegistroBoleto_Response.ToJson()
		
		Exit
	EndFor
	Commit
	
EndSub

Sub 'GravaNossoNumero'
	
	For each Order EmpCod,CbrCod,CbrTipImp
		Where EmpCod = &EmpCod
		Where CbrCod = &CreCbrCod
		Where CbrTipImp = TipoImpressao.GerarBoleto
		
		CtaBanNosNro	= &CtaBanNosNro  
		
		Exit
	EndFor
	Commit
	
EndSub
]]></Source>
