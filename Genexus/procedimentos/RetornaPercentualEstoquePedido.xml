      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ComEstPedVlrBrt = 0
&SemEstPedVlrBrt = 0
&ComEstTaxa = 0
&PedVlrBrt = 0 

For Each Order EmpCod, FilCod, PedCod, PedItmCod
Where EmpCod = &EmpCod
Where FilCod = &Filcod
Where PedCod = &PedCod
Where PedQtd > 0

	Do Case
		Case EstQtd >= PedQtd //Estoque Maior que saldo
			&diferenca = PedQtd 
		Case EstQtd <= 0 
			&Diferenca  = 0
		Otherwise
			&diferenca = EstQtd
	EndCase
	
    &ComEstPedVlrBrt += (&diferenca * PedVlrUntComDsc)
    &PedVlrBrt += (PedQtd  * PedVlrUntComDsc)
EndFor

if &PedVlrBrt <> 0 
    &ComEstTaxa = ((&ComEstPedVlrBrt / &PedVlrBrt) * 100)
endif

&SemEstPedVlrBrt = (&PedVlrBrt - &ComEstPedVlrBrt)
]]></Source>
