      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TotalFaturadoMoeda = 0
For each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where PedDtaFat >= &dataInicial and PedDtaFat <= &DataFinal
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where LctGerFin = Status_SimNao.Sim
	Where LctAtuEst = Status_EntradaSaida.Saida
	Where PedSts = Status_Pedido.FECHADO
	Where PedStsFin = Status_Financeiro.FECHADO
	
	&TotalFaturadoMoeda += PedVlrLiq
EndFor
]]></Source>
