      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	EstLoc = &EstLoc
	
	Exit
When None
	IniciaEstoque.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod)
	
	For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		EstLoc = &EstLoc
		Exit
	EndFor

EndFor


commit


For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstLocExt
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Delete
EndFor

Commit

For &sdtLocacaoExtraItem in &sdtLocacaoExtra
	If not &sdtLocacaoExtraItem.EstLocExt.IsEmpty()
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
			EstLocExt = &sdtLocacaoExtraItem.EstLocExt
		EndNEw
	EndIF
EndFor


Commit
]]></Source>
