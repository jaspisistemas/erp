      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&PesCodRazSugg = ''
&IsErroCliente = false
&PedCliObs.SetEmpty()

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesIsCli = true
	
	&PesCodRazSugg = PesCodRazSugg
	
	&PedCliCidCod	= PesCidCod
	&PedCliCidAreCod = PesCidAreCod
	&PesVenAprz = PesVenAprz
	&PedCliObs = PesObs
	
	If PesSts <> Status_ativoInativo.ATIVO
		&Mensagem = 'Cliente INATIVADO!'
		&IsErroCliente = true
	Endif


	Exit
When none
	&IsErroCliente = true
	&Mensagem = 'Cliente não localizado!'
EndFor
]]></Source>
