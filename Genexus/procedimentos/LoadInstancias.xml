      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[for each order WinAppGUID,WinAppInsGUID
	where WinAppInsPID > 0
	where WinAppInsSts <> Status_Instancia.INATIVO
	&sdtInstanciaApp                    = new()
	&sdtInstanciaApp.WinAppGUID         = WinAppGUID
	&sdtInstanciaApp.WinAppInsGUID      = WinAppInsGUID
	&sdtInstanciaApp.WinAppNom          = WinAppNom
	&sdtInstanciaApp.WinAppNomFis       = WinAppNomFis
	&sdtInstanciaApp.WinAppPath         = WinAppPath
	&sdtInstanciaApp.WinAppIsHabilitado = WinAppIsHabilitado
	&sdtInstanciaApp.WinAppMaxIns       = WinAppMaxIns
	&sdtInstanciaApp.WinAppQtdInsAtv    = WinAppQtdInsAtv
	&sdtInstanciaApp.WinAppInsDtaUltExe = WinAppInsDtaUltExe
	&sdtInstanciaApp.WinAppInsPID       = WinAppInsPID
	&sdtInstanciaApp.WinAppInsLog       = WinAppInsLog
	&sdtInstanciaApp.WinAppInsSts       = WinAppInsSts
	&sdtInstanciaApps.Add(&sdtInstanciaApp)
endfor
]]></Source>
