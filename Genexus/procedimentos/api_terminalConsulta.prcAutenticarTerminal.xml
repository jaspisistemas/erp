      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if not &CodigoConfiguracao.IsEmpty()
	For Each Order TermCod
		Where TermCodAtiv = &CodigoConfiguracao
		Where not TermCodAtiv.IsEmpty() and not TermCodAtiv.IsNull()
		Where TermSts = Status_AtivoInativo.ATIVO
		
		&GUID = GUID.NewGuid()
		TermCodAtiv = &GUID.ToString()
		
		&GUID = GUID.NewGuid()
		&TermRandCom = &GUID.ToString()		
		
		TermRandCom = &TermRandCom
		
////		//DADOS DO CONTEXT
////		&wwpContext = new()		
////		&wwpContext.EmpCod = EmpCod
////		&wwpContext.EmpRaz = EmpRaz
////		&wwpContext.DeviceRandon = &TermRandCom
		
		//DADOS DO TERMINAL
		&SdtTerminal.EmpCod = EmpCod
		&SdtTerminal.TermRandCom = TermRandCom
		&SdtTerminal.TermNom = TermNom
		&SdtTerminal.TermSts = TermSts
		&SdtTerminal.TermTip = TermTip
		&SdtTerminal.TermMod = TermMod
		
		Commit
		
		EXIT
	EndFor

