      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//DUPLICATAS
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	Where CreSts <> Status_Duplicata.CANCELADA
	
	//PAGAMENTOS
	For Each Order EmpCod, FilCod, CreCod, CrePagCod
		Where CrePagSts <> Status_Caixa.Cancelado or CrePagSts.IsNull()
		
		RemoveFinanceiroDuplicata.Call(EmpCod, FilCod, CreCod, CreMovCod, CreMovItmCod,CrePagCod, &IsAchouPagamentos)
		CrePagSts = Status_Caixa.Cancelado
	EndFor
	
	//RENEGOCIACOES
	For Each Order EmpCod, FilCod, CreCod, CreRenCod
		delete
	EndFor
	
	prcDeletaDuplicatareferenciada.Call(EmpCod, FilCod, CreCod)
	
	//OBSERVACOES
	//For Each Order EmpCod, FilCod, CreCobCod
	//	delete
	//EndFor
	
	if CreRecPag = ReceberPagar.Receber //TERCEIROS
		if not CreCheCod.IsEmpty() //DELETA CHEQUE LANCADO
			RemoveChequeTerceiros.Call(EmpCod, CreCheCod)
		Endif
	Else //PROPRIO
		
	EndiF
	
	CreSts = Status_Duplicata.CANCELADA
EndFor

Commit
]]></Source>
