      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//Atualiza Todos para Principal = false
if &ProImgPri = true
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		ProDtaHorUltMod = now()
	EndFor
	
	For Each Order EmpCod, ProCod, ProImgCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProImgCod <> &ProImgCod
		where ProImgTip = &proImgTip 
		ProImgPri = false
	EndFor
	
	Commit
Else
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		ProDtaHorUltMod = now()
	EndFor

	For Each Order EmpCod, ProCod, ProImgPri //GRAVA A PRIMEIRA COMO PRINCIPAL
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		where ProImgTip = TipoImagemProduto.IMAGEM_PRODUCAO 
		Where ProImgPri = true
		Exit
	When none
		For Each Order EmpCod, ProCod, ProImgCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			where ProImgTip = TipoImagemProduto.IMAGEM_PRODUCAO  
			ProImgPri = true
			Exit
		EndFor
	EndFor

	Commit
	
	For Each Order EmpCod, ProCod, ProImgPri //GRAVA A PRIMEIRA COMO PRINCIPAL
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		where ProImgTip = TipoImagemProduto.IMAGEM_VENDA 
		Where ProImgPri = true
		Exit
	When none
		For Each Order EmpCod, ProCod, ProImgCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			where ProImgTip = TipoImagemProduto.IMAGEM_VENDA  
			ProImgPri = true
			Exit
		EndFor
	EndFor

	Commit
EndIF
]]></Source>
