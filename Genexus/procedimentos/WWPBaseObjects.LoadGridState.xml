//This is a procedure in which user has to define the behaviour of grid state.
//You can save the grid state in session, in database or whatever you want

//Example to save in Session
//&UserCustomValue = &Session.Get(&UserCustomKey)

loadWWPContext.Call(&Context)
padraoUsuarioHora.Call('L', &UserCustomKey, &Context.PesCod, &Context.EmpCod, &UserCustomValue, &PadDtaMod, &PadDtaHorMod, 'T')

if &PadDtaMod <> serverdate()
	&GridState.FromXml(&UserCustomValue)
	
	For &GridStateFilterValue in &GridState.FilterValues
		
		If &GridStateFilterValue.Name LIKE "%DTA" 
			&Index = &gridState.FilterValues.IndexOf(&GridStateFilterValue)
			&GridState.FilterValues.Remove(&Index)
		EndIF
	EndFor

	&UserCustomValue = &GridState.ToXml()
EndIF



