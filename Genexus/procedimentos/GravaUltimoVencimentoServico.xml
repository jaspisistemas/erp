      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each order EmpCod, SerItmCod
	where EmpCod = &EmpCod
	where SerItmCod = &SerItmCod
	&SerTipPlan = SerTipPlan
	&SerItmDtaInicio = SerItmDtaInicio
	&serItmDiaVct = SerItmDiaVct
	&SerItmDtaFim = SerItmDtaFim
	&SerItmQtdMes = SerItmQtdMes
	&SerItmTip = SerItmTip
	&SerItmSts = SerItmSts
	
	SerItmUltVct = &SerItmUltVct
	
	Do case
		case /*&SerItmTip = TipoLancamentoServico.SERVICO and*/ &SerItmSts = Status_AtivoInativo.ATIVO
		
			if &SerTipPlan = TipoPlano.ANUAL //só na tabela Servico
				if &SerItmDtaFim.IsEmpty() and not &SerItmUltVct.IsEmpty()
					&SerItmDtaFim = AddYr(&SerItmDtaInicio, 1)
					SerItmDtaFim = &SerItmDtaFim
				else
					//se habilitar abaixo ele atualiza o ult vct msm editando dup
					//&SerItmDtaFim = AddYr(&SerItmDtaFim, 1)
					//SerItmDtaFim = &SerItmDtaFim
				EndIf
				
			else //MENSAL
				if not &SerItmUltVct.IsEmpty() 
					&AuxSerItmUltVc = AddMth(&SerItmUltVct, 1)
					SerItmDtaFim = YmDtoD(&SerItmUltVct.Year(), 12, 31)
				EndIf
			EndIf
			
			
			
		case &SerItmTip = TipoLancamentoServico.PREVISAO and &SerItmSts = Status_AtivoInativo.ATIVO
			//nao faz nada alem de gravar ult vct
			
			
			
		case &SerItmTip = TipoLancamentoServico.CONTRATO
			//nao faz nada alem de gravar ult vct
				
	EndCase

	exit
EndFor
Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
