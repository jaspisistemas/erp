      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVA LOG
&TabelaVarchar = 'PEDIDOPRODUTO'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
if &LogErpTabIsLog = true
	&LogErpRegCod1 = trim(Str(&PedCod))
Endif

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&LCtAtuEst = LctAtuEst
	
	If PedSts <> Status_Pedido.ABERTO and PedSts <> Status_Pedido.SEPARANDO
		Return
	EndIF

	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		Where (PedItmCodRef = &PedItmCod or PedItmCod = &PedItmCod) when &PedItmCod > 0
		
		&ProCod = PedProEstProCod
		&ProGraCod = PedProEstProGraCod
		&Pedqtd = PedQtd
		
		//GRAVA LOG
		if &LogErpTabIsLog = true
			&LogErpRegCod2 = trim(toformattedString(PedItmCod))
			&LogErpRegTip = TrnMode.Delete
			&LogErpRegGUID.SetEmpty()
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProCod', trim(toformattedString(PedTraRedCod)), '', &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProGraCod', trim(toformattedString(ProGraCod)), '', &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedQtd', trim(toformattedString(PedQtd)), '', &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVlrUnt', trim(toformattedString(PedVlrUnt)), '', &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVlrItm', trim(toformattedString(PedVlrItm)), '', &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedItmCmp', trim(toformattedString(PedItmCmp)), '', &LogErpRegGUID )
		Endif
		//GRAVA LOG
		
		PedQtd = 0
		PedQtdEmb = 0
		PedQtdFat = 0
		
		//LOTES DO ITEM
		For Each Order EmpCod, FilCod, PedCod, PedItmCod, PedProEstLotCod
			delete
		EndFor
	
		//APAGA AS OBS.
		For Each Order EmpCod, FilCod, PedCod, PedItmCod, PedProOGrupCod
			delete
		EndFor
		Commit
		
		AtualizaEstoqueCompradoVendido.Call(EmpCod, FilCod, &ProCod, &ProGraCod, &Pedqtd, 0, &LCtAtuEst)
		Delete 
		commit
		
	EndFor

	Exit
EndFor

commit

//if &ProCod <> 0 //AQUI NAO FUNCIONA QUANDO DELETA TODOS OS ITENS //JDF
//	AtualizaEstoqueCompradoVendido.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &Pedqtd, 0, &LCtAtuEst)
//EndIF

AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')
]]></Source>
