      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,FilCod,CteDtaEms
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteSts = Status_NFe.Digitando
	Where CteDtaEms < &Today
	&Erro = 1
	&Count = Count(CteCod)
	
EndFor
]]></Source>
