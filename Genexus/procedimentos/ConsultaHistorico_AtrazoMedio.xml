        <Source><![CDATA[
&ContadorLInhas = 0
&Hoje = serverdate()
&TotVencido = 0
&TotDescont = 0
&TotAVencer = 0
&TotCreVlr  = 0
&SdtHistCliente.Clear()

If &IsVinculos = True
	RetornaVinculos.Call(&EmpCod,&CreCliCod,&sdtVinculos)
Else
	&sdtVinculos.Clear()
	&sdtVinculosItem = new()
	&sdtVinculosItem.PesCod = &CreCliCod
	&sdtVinculosItem.PesRaz = &CreCliRaz
	&sdtVinculosItem.PesIsMat = false //iif(pesVinCod = PesCod, true, false) //JDF NAO PRECISA IDENTIFICAR A MATRIZ CASO NAO TENHA FINCULOS
	&sdtVinculos.Add(&sdtVinculosItem)
EndIF


&collCreCliCod.clear()
For &sdtVinculosItem in &sdtVinculos        
	&collCreCliCod.Add(&sdtVinculosItem.PesCod)
EndFor

//&Total = 0
//For Each Order EmpCod, FilCod, CreCod
//	Where EmpCod = &EmpCod
//	where CreSts <> Status_Duplicata.CANCELADA
//	Where CreCliCod in &collCreCliCod
//	Where CreVlrSdo > 0 when &IsAbertos = true
//	&Total += 1
//EndFor

&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

For Each 
	Order EmpCod, CreDtaVct when &Ordem = 'C'
	Order EmpCod,(CreDtaVct) when &Ordem = 'D'
	Where EmpCod = &EmpCod
	where CreSts <> Status_Duplicata.CANCELADA
	Where CreCliCod in &collCreCliCod
	Where CreVlrSdo > 0 when &IsAbertos = true
	
//	&Calcula += 1
//	if &Calcula >= 500
//		&Count += &Calcula
//		If &Count > 0
//			&Percentual = round((&Count / &Total) * 100, 0)
//		EndIF
//		If &Percentual >= 100
//			&Percentual = 99
//		EndIf
//		do 'Atualiza'
//		&Calcula = 0
//	EndiF

	do 'limpaVariavel'
	&CreVlrDup = CreVlrDup
	&CreRecPag = CreRecPag
	&CreVlrSdo = CreVlrSdo
	&gridEmpCod		 = EmpCod   
	&gridFilCod		 = FilCod   
	&gridCreCod		 = CreCod   
	&gridCreCliCod   =  CreCliCod
	&gridCreCliRaz   =  CreCliRaz
	&gridCreRecPag   =  CreRecPag
	&gridCreDupNro   =  CreDupNro
	&gridCreVlrDup   =  CreVlrDup
	&gridCreVlrSdo   =  CreVlrSdo
	&gridCreDtaEms   =  CreDtaEms
	&gridCreDtaVct   =  CreDtaVct
	&gridCreCbrCod   =  CreCbrCod
	&gridCreCbrNom   =  CreCbrNom
	&gridCrePedCod   =  CrePedCod
	&gridCreVenCod   =  CreVenCod
	&gridCreDtaCrt   =  CreDtaCrt
	&gridCreDtaPrt   =  CreDtaPrt
//	Do Case
//		Case (CreCbrImp = TipoImpressao.GerarBoleto)
//			&IsBoleto = True
//		Case (CreCbrImp = TipoImpressao.ImprimirBoleto) and ((CreCbrBanEnv = 'S' and CreCbrTipCob = 'S' and CreBloNro <> '') or (CreCbrBanEnv <> 'S'))
//			&IsBoleto = True
//		Case CreCbrImp = TipoImpressao.ImprimirDuplicata
//			&IsBoleto = True
//		Otherwise
//		&IsBoleto = False
//	EndCase

	&CrePedCod = 0
	&CreDtaVct = CreDtaVct
	
	&CrePedCod = CrePedCod
	&FilCod = FilCod
		
	If CreRecPag = ReceberPagar.Receber
		If &IsAbertos = False
			&TotCreVlr += CreVlrDup
		Else
			&TotCreVlr += CreVlrSdo
		EndIf
		
//		Do 'Busca_Valor_Liquido'
		
		If CreVlrSdo > 0 
			Do Case 
				Case CreDtaVct < &Hoje
					&TotVencido += CreVlrSdo  // Total vencido
				Case CreSts = Status_Duplicata.DESCONTADA                     
					&TotDescont += CreVlrSdo   // Total Descontada/Negociada
				Otherwise
					&TotAVencer += CreVlrSdo   // Total a vencer
			EndCase
		EndIf	
	EndIf
	&CreDtaEms = CreDtaEms
	&CreDiaAtr = 0
	&ParcialTotal = 'T'
	
	For Each Order EmpCod,FilCod,CreCod, CrePagCod   
		Where CrePagSts <> Status_Caixa.Cancelado or CrePagSts.IsEmpty() or CrePagSts.IsNull()
		&CrePagDta = CrePagDta
		
		&gridCrePagDta    = &CrePagDta
		&gridCrePagVlrDsc = CrePagVlrDsc
		&gridCrePagVlrJur = CrePagVlrJur                
		&gridCrePagVlr = CrePagVlr
		
		If &CreRecPag = ReceberPagar.Receber
			&CreDiaAtr = (CrePagDta - &CreDtaVct)   // Qtd de Dias em atrazo
			&VlrTotPrzMed += (&CreDiaAtr *  CrePagVlr)
			&VlrBasPrzMed += CrePagVlr
			
			If &CreVlrSdo > 0
				&ParcialTotal = 'P'
			Else
				&ParcialTotal = 'T'
			EndIF
		Else
			&CreDiaAtr = 0 //(&CrePagDta - &CreDtaVct)   // Qtd de Dias em atrazo
		EndIf
		
		&CrePagTotItm += CrePagTotItm
		
		&gridQtdDiaAtz = &CreDiaAtr
		
//		If &CreDtaEms >= &DtaIni
//			do 'CarregaImpressao'
//		Endif
	When none
		If &CreDtaVct < &Hoje and &CreRecPag = ReceberPagar.Receber
			&CreDiaAtr = &Hoje - &CreDtaVct
			&VlrTotPrzMed += (&CreDiaAtr *  &CreVlrDup)
			&VlrBasPrzMed += &CreVlrDup
		Else
			&CreDiaAtr = 0 //(&Hoje - &CreDtaVct)   // Qtd de Dias em atrazo
		EndIf
		
		&gridQtdDiaAtz = &CreDiaAtr
		
//		If &CreDtaEms >= &DtaIni
//			do 'CarregaImpressao'
//		Endif
	EndFor
	
EndFor	

If &VlrTotPrzMed <> 0 and &VlrBasPrzMed <> 0
	&AtzMed = round(&VlrTotPrzMed / &VlrBasPrzMed, 0)
EndIf

//PROTESTOS
&Protesto = 0
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	where CreSts <> Status_Duplicata.CANCELADA
	Where CreCliCod in &collCreCliCod
	Where not CreDtaPrt.IsEmpty()
	&Protesto += 1
EndFor

&sdtHisCliente.Mensagem = &SdtHistCliente.ToJson()
&sdtHisCliente.TotalDuplicataMoeda = &TotCreVlr
&sdtHisCliente.TotalPagamentoMoeda = &CrePagTotItm
&sdtHisCliente.TotalVencerMoeda = &TotAVencer
&sdtHisCliente.TotalDescontoMoeda = &TotDescont
&sdtHisCliente.TotalVencidoMoeda = &TotVencido
&sdtHisCliente.AtrazoMedio = &AtzMed
&sdtHisCliente.ValorMedioMoeda = &ValorMedio
&SdtHisCliente.QtdPrt = &Protesto

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &sdtHisCliente.ToXml()
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &sdtHisCliente.ToXml()
		Endnew
	endfor
	
	commit	
EndSub

Sub 'LimpaVariavel'
	&gridEmpCod.SetEmpty()
	&gridFilCod.SetEmpty()
	&gridCreCod.SetEmpty()
	&gridCreCliCod.SetEmpty()
	&gridCreCliRaz.SetEmpty()
	&gridCreRecPag.SetEmpty()
	&gridCreDupNro.SetEmpty()
	&gridCreVlrDup.SetEmpty()
	&gridCreVlrSdo.SetEmpty()
	&gridCreDtaEms.SetEmpty()
	&gridCreDtaVct.SetEmpty()
	&gridCreCbrCod.SetEmpty()
	&gridCreCbrNom.SetEmpty()
	&gridCrePedCod.SetEmpty()
	&gridCreVenCod.SetEmpty()
	&gridCreDtaCrt.SetEmpty()
	&gridCreDtaPrt.SetEmpty()
	&gridCrePagDta.SetEmpty()
	&gridCrePagVlrDsc.SetEmpty()
	&gridCrePagVlrJur.SetEmpty()
	&gridCrePagVlr.SetEmpty()
	&gridQtdDiaAtz.SetEmpty()
	&gridPedVlrLiq.SetEmpty()

EndSub
]]></Source>
