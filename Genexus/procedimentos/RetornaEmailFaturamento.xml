      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern

For Each Order EmpCod, PesCod, PesEmlCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where PesEmlFat = true
	
	If not PesEml.IsEmpty() and (PesEml.IsMatch(&pattern) = true)
		&IsJahTem = false
		For &itemSdtEmail in &SdtEmail
			If &itemSdtEmail.EmlUrl = PesEml
				&IsJahTem = true
				Exit
			EndIF	
		EndFor
		
		If &IsJahTem = false
			&itemSdtEmail = new()
			&itemSdtEmail.EmlUrl = PesEml
			&SdtEmail.Add(&itemSdtEmail)
		EndIf
	EndIF
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
