      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//parm(in:&EmpCod, in:&FilCod, in:&PEdCod, in:&PedVlrLiq, out:&IsErro);

For Each ORder EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PEdCod
	&PedVlrLiq = PedVlrLiq
	&PedSts = PedSts
	&PedStsFin = PedStsFin
	Exit
EndFor

&IsErro = true
&TotalMoeda = 0
For Each ORder EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CrePedCod = &PEdCod
	Where CreSts <> Status_Duplicata.CANCELADA
	&TotalMoeda += CreVlrDup
EndFor

&diferencaMoeda = &PedVlrLiq-&TotalMoeda

Do CAse
	Case &TotalMoeda > 0 and &PedVlrLiq > 0 and (&diferencaMoeda < 2 or &diferencaMoeda > -2)
		if &PedSts = Status_Pedido.FECHADO and &PedStsFin = Status_Financeiro.FECHADO
			//JDF - caso o pdv de algum problema de arredondamento nao sendo maior que 2 reais e nem menor que -2 reais
			For Each ORder EmpCod, FilCod, PedCod
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod
				Where PedCod = &PEdCod
				PedVlrOut += &diferencaMoeda*-1
				PedVlrLiq += &diferencaMoeda*-1
				Exit
			EndFor
			
			Commit
			
			&IsErro = false	
		Endif
	Case &TotalMoeda = &PedVlrLiq
		&IsErro = false	
EndCase
]]></Source>
