      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//########### FAVORITOS DE ORIGEM #############
For Each Order EmpCod, PesCod, FavRotAutCod
	Where EmpCod = &EmpCod
	where PesCod = &OrigemPesCod
	&FavOrd = FavOrd
	&FavRotAutCod = FavRotAutCod
	&FavRotAutNom = FavRotAutNom
	
	DO 'GravaDestino'
EndFor

Sub 'GravaDestino'
	For Each Order EmpCod, PesCod, FavRotAutCod
		Where EmpCod = &EmpCod
		where PesCod = &DestinoPesCod
		Where FavRotAutCod = &FavRotAutCod
		Where FavWebSmart = 'W' or FavWebSmart.IsNull() or FavWebSmart.IsEmpty()
		
		FavOrd = &FavOrd
		FavRotAutNom = &FavRotAutNom
		FavWebSmart = 'W'
		exit
	When none
		
		new 
			EmpCod = &EmpCod
			PesCod = &DestinoPesCod
			FavRotAutCod = &FavRotAutCod
			FavOrd = &FavOrd
			FavRotAutNom = &FavRotAutNom
			FavWebSmart = 'W'
		EndNew
		Commit
	EndFor
	
EndSub



]]></Source>
