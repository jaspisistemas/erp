      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&SolDtaEms = Serverdate()
&SolDtaEms = &SolDtaEms.AddDays(-&Dias)

For Each Order SolEmpCod,SolTip, SolCod
	Where SolEmpCod = &SolEmpCod
	Where SolTip = &SolTip
	Where SolDtaEms < &SolDtaEms
	
	Delete
EndFor

Commit
]]></Source>
