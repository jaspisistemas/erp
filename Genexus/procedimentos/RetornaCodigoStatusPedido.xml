      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, StsNom
	Where EmpCod = &EmpCod
	Where StsNom = &StsNom
		&StsCod = StsCod
		
		if StsCrd.IsNull() or StsEst.IsNull() or StsPaiCod.IsNull() or StsPed.IsNull()
			do 'getTipoStatus'
			
			StsPed = &status_Pedido
			StsPaiCod = &StsPaiCod 
			StsCrd = &StsCrd
			StsEst = &StsEst
		EndIF

	Exit
When none
	
	Do 'getTipoStatus'
	
	If &isGrava = true
		UltimoCodigoEmpresa.Call(domParCod.STATUSPEDIDO, &EmpCod, 0, &StsCod)
		
		new
			EmpCod = &EmpCod
			StsCod = &StsCod
			StsNom = &StsNom
			StsWs = &StsWs
			StsPed = &status_Pedido
			StsOrd = &StsOrd
			StsPaiCod = &StsPaiCod 
			StsR = &StsR
			StsG = &StsG
			StsB = &StsB
			StsHex = &StsHex
			StsCrd = &StsCrd
			StsEst = &StsEst
		EndNEw
		
		commit
	EndIF

EndFor


Sub 'GetTipoStatus'
	&isGrava = true
	Do Case
		Case &StsNom = 'CONDICIONAL'
			&status_Pedido = Status_Pedido.ABERTO
			&StsOrd = 19
			&StsWs = Status_WsUsu.Usuario
			
			RetornaCodigoStatusPedido2.Call(&EmpCod, 'ABERTO', &StsPaiCod)
			
			&StsR = 5
			&StsG = 63
			&StsB = 255
			&StsHex = 'FF3F05'
			&StsCrd = false
			&StsEst = true
			
		Case &StsNom = 'ABERTO'
			&status_Pedido = Status_Pedido.ABERTO
			&StsOrd = 20
			&StsWs = Status_WsUsu.WebService
			&StsPaiCod = 0
			&StsR = 0
			&StsG = 0
			&StsB = 0
			&StsHex = '000000'
			&StsCrd = false
			&StsEst = true
			
		Otherwise
		
			&isGrava = false
	EndCase
EndSub
]]></Source>
