      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVA PAGAMENTO NA DUPLICATA
&CrePagCod = 0
For Each Order EmpCod, FilCod, CreCod, (CrePagCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	&CrePagCod = CrePagCod
	Exit
EndFor
&CrePagCod += 1

new
	EmpCod = &EmpCod
	FilCod = &FilCod
	CreCod = &CreCod
	CrePagCod = &CrePagCod
	CrePagDta = &CrePagDta
	CrePagVlr = &CrePagVlr
	CrePagVlrJur = &CrePagVlrJur
	CrePagVlrDsc = &CrePagVlrDsc
	CreMovCod = &MovCod
	CreMovItmCod = &MovItmCod
	CrePagTip = TipoDuplicataBaixa.Total
EndNew


commit

//ATUALIZA TOTAL DUPLICATA
AtualizaSaldoDuplicata.Call(&EmpCod,&CreCod,&FilCod)

commit
]]></Source>
