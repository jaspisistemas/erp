      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)


&ArquivoEnvio.Source = &sdtConfiguracoesPasta.PastaDiretorioTempFis + 'dpa_product_catalog_sample_feed_atom-cte.xml'
If &ArquivoEnvio.Exists()
	&ArquivoEnvio.Delete()
EndIf	
&Nome_enviar = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'dpa_product_catalog_sample_feed_atom-cte.xml'

	&ArqFace.Open(&Nome_enviar) // Abrir o arquivo XML
		&ArqFace.WriteStartElement('feed')	
		&ArqFace.WriteAttribute('xmlns:g',"http://base.google.com/ns/1.0")
		&ArqFace.WriteAttribute('xmlns',"http://www.w3.org/2005/Atom")
		&ArqFace.WriteElement('title',trim(EmpRaz))
		&ArqFace.WriteElement('link')
		&ArqFace.WriteAttribute('href',"http://www.jaspi.com.br")
		&ArqFace.WriteAttribute('rel',"self")
		&ArqFace.WriteStartElement('entry')	

For &sdtProdutosItem in &sdtProdutos
	
	For each order EmpCod,ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &sdtProdutosItem.ProCod
		
		
		&ArqFace.WriteElement('g:id',ProCod)
		&ArqFace.WriteElement('g:title',trim(ProNom))
		&ArqFace.WriteElement('g:description','')
		&ArqFace.WriteElement('g:link','')
		
		For each Order EmpCod,ProCod
			If ProImgPri = True
				&ArqFace.WriteElement('g:image_link',ProImgOriginal.ImageURI)
			Else
				&ArqFace.WriteElement('g:image_link','')
			EndIf
		EndFor
		
		&ArqFace.WriteElement('g:brand',trim(MarNom))
		
		If ProTip = 2 
			&ArqFace.WriteElement('g:condition','Usado')
		Else
			&ArqFace.WriteElement('g:condition','Novo')
		EndIf
		
		For Each Order EmpCod
			where FilCod = &FilCod
			
			If EstQtd > 0
				&ArqFace.WriteElement('g:availability','Em Estoque')
			Else
				&ArqFace.WriteElement('g:availability','Sob-Encomenda')
			EndIf
			Exit
		EndFor
		
		for Each Order EmpCod
			Where TabCod = &TabCod
			&ArqFace.WriteElement('g:price',TabPrc1.ToFormattedString())			
		endfor
		&ArqFace.WriteStartElement('g:shipping')	
		&ArqFace.WriteElement('g:country','BR')
		&ArqFace.WriteElement('g:service','Padrao')
		&ArqFace.WriteEndElement() //shipping
		&ArqFace.WriteElement('g:google_product_category','')
		
	EndFor
	
EndFor
	&ArqFace.WriteEndElement() //entry
	&ArqFace.WriteEndElement() //feed
	&ArqFace.Close()

	&Link = &sdtConfiguracoesPasta.pastaDiretorioTempVir+ 'dpa_product_catalog_sample_feed_atom-cte.xml'
	Link(&Link)
]]></Source>
