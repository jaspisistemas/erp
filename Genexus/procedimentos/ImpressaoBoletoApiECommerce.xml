<Object parentGuid="903b5e0b-c5a4-4fd1-b5e8-e7ab64057c44" user="SRVORDIG\Administrador" versionDate="2023-03-14T12:55:56.0000000Z" lastUpdate="2023-03-09T19:34:29.0000000Z" checksum="d04fbbc6b2f131316f5b1b0a2b4447e4" fullyQualifiedName="ImpressaoBoletoApiECommerce" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="253f5cc1-3398-4f49-bc98-28115797958a" name="ImpressaoBoletoApiECommerce" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Impressao Boleto Api ECommerce" parent="BoletoApiSicredi" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[HostWebServiceBoletoApi.Call('ECOMERCE',748, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor) // Sicredi = 748
&HttpClient.Host = &EmpWebHost //servidor
&HttpClient.Secure = 1
&httpclient.AddHeader(!'Content-type',!'application/json')

If 	&CbrChaTra.Trim().IsEmpty()
	For each Order EmpCod,CbrCod,CbrTipImp
		Where EmpCod = &EmpCod
		Where CbrCod = &CreCbrCod
		&CbrCtaBanAgeCod = CbrCtaBanAgeCod
		&CbrCtaBanAgeDig = CbrCtaBanAgeDig
		&CbrNroCon = CbrNroCon
		&CbrCtaBanCrt = CbrCtaBanCrt
		&CbrCtaBanBanCod = CbrCtaBanBanCod
		&CbrCarCod = CbrCarCod
		
		If not CbrChaMas.Trim().IsEmpty()  // chave master NÃO esta Vazia?
			&CbrChaMas = CbrChaMas                                                 
			If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow() //chave de Transação esta Vencida?
				&CbrChaTra = CbrChaTra
				&IschaveTransacao = true  // pega chave transação jah existente ou a nova no else.
				//"chaveTransacao":"14F671760619965B97FF5CEEB9BE10F4792A9F3BAB8DED900F23A633A4C9FEB5",
				//"dataExpiracao":"2017-04-26T20:15:28.685-03:00"
			Else
				 // If a Chave de Transação esta vencida a mais de 24 Horas tem que gerar Outra.
				AutenticaBoletoApiECommerce.Call(EmpCod,CbrCod,CbrChaMas,&IschaveTransacao,&CbrChaTra) 			
			EndIf
		Else
			&ErroCobraca = 1
			&Mensagem = 'Chave master inválida verifique!'
			&IsErro = true
		EndIF
		Exit
	EndFor
	
	&AuxCreBloNro = padL(substr(trim(&CbrCtaBanAgeCod),1,4),4,'0')+padL(substr(trim(&CbrCtaBanAgeDig),1,2),2,'0') + padL(trim(&CbrNroCon),5,'0')+padL(trim(&CreBloNro),8,'0')
	CalculaDigNosNro.Call(&CbrCtaBanBanCod,&CbrCarCod,2,&AuxCreBloNro)      // Calcula Dígito do Nosso Número
	&CreBloNro = padL(trim(&AuxCreBloNro),9,'0')
EndIf
	
If not &CbrChaTra.Trim().IsEmpty()
	&httpclient.AddHeader('token',trim(&CbrChaTra))
	&String = '/sicredi-cobranca-ws-ecomm-api/ecomm/v1/boleto/impressao?agencia='+padL(Substr(trim(&CbrCtaBanAgeCod),1,4),4,'0')+'&cedente='+padL(substr(trim(&CbrNroCon),1,5),5,'0')
	&String +='&nossoNumero='+padL(trim(&CreBloNro),9,'0') +'&posto='+padL(substr(trim(&CbrCtaBanAgeDig),1,2),2,'0')
	&HttpClient.Execute('GET',&String)
	
//	padraoUsuario.Call('G', '#BOLETOAPIECOMMERCEIMPRESSAO', &Context.PesCod, &Context.EmpCod, &HttpClient.toString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
 	//################################# sem erro de comunicação ################################################################################
	Do Case
		Case &HttpClient.ErrCode = 0 
			&SdtBoletoApiECommerceImpressao.fromJson(&HttpClient.toString())			
			
			For Each Order EmpCod,CreCod
				Where EmpCod = &EmpCod
				Where CreCod = &CreCod
				CrePdf64ApiEco = &SdtBoletoApiECommerceImpressao.arquivo
				exit
			EndFor			
			
			RetornaConfiguracoesPastas.Call(&Context.EmpCod,&Context.FilCod,&SdtConfiguracoesPasta)
			&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempFis+trim(&CreBloNro)+'.pdf'
			&File.Source = &NomeArquivo
			If &File.Exists()
				&File.Delete()
			EndIf			
			
			&File2.Source = &NomeArquivo
			If not &File2.Exists()
				&File2.Create()
				&File2.FromBase64String(&SdtBoletoApiECommerceImpressao.arquivo) 
				&File2.Close()
				
				&NomeArquivo = &SdtConfiguracoesPasta.PastaDiretorioTempVir+trim(&CreBloNro)+'.pdf'
				Link(&NomeArquivo)
			EndIf		
			
			
		Otherwise
			&StdautenticacaoBoletoErro.fromJson(&HttpClient.toString())
			msg('ERRO - '+trim(str(&HttpClient.ErrCode)) +': '+&StdautenticacaoBoletoErro.codigo.Trim()+' Msg: '+&StdautenticacaoBoletoErro.mensagem.Trim() +' Parametro: '+&StdautenticacaoBoletoErro.parametro.Trim())
	EndCase
EndIf


]]></Source>
