      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,RctCod,RctCodItm
	Where EmpCod = &EmpCod
	Where RctCod = &RctCod
	Where RctCodItm = &RctCodItm
	
	RctProCod = &RctProCod
	RctProGraRef = &varRctProCod
	RctProGraCod = &RctProGraCod
	
	RctProNom = &RctProNom
	RctProQtd = &RctProQtd
	RctProNroApl = &RctProNroApl
	RctProTlvCod = &RctProTlvCod
	RctProTlvAtv = &RctProTlvAtv
	RctProInfCod = &RctProInfCod
	RctProQtdAdq = &RctProQtdAdq
	RctProRcmModAplTip = &RctProRcmModAplTip
	RctProDos = &RctProDos
	RctProAreApl= &RctProAreApl
	RctProUniUsoCod = &RctProUniUsoCod
	RctProUniUso = &RctProUniUso
	RctProRcmDia = &RctProRcmDia
	RctProTraSem = &RctProTraSem
	RctProTraApl = &RctProTraApl
	RctProTraDta = &RctProTraDta
	If &RctProRcmModAplTip = 1
		RctProRcmModApl = &RctProRcmModApl
	Else
		RctProRcmModApl = &AereaRctProRcmModApl
	EndIf
	
	RctProRcmIntSeg = &RctProRcmIntSeg
	RctProRcmEpi = &RctProRcmEpi
	RctProRcmOriMan = &RctProRcmOriMan
	RctProRcmPreUso = &RctProRcmPreUso
	RctProRcmOutInf = &RctProRcmOutInf
	
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
