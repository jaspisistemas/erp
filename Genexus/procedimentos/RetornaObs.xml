      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedCliCod.Clear()
for &sdtVinculosItem in &sdtVinculos
	&PedCliCod.Add(&sdtVinculosItem.PesCod)
EndFor

For Each Order EmpCod, PesSacDta
	Where EmpCod = &EmpCod
	Where PesCod in &PedCliCod
	Where PesSacIsVen = true or PesSacVenCod = 1
	Where PesSacVenIntExt = Status_InternoExterno.INTERNO or PesSacVenCod = 1
//	Where PesSacVenDem.IsEmpty() or PesSacVenDem.IsNull()
	Where PesSacDta > &UltimoDiaData
	Where PesSacVenCod <> &NewPesCod and PesSacVenCod <> &OldPesVenCod
	where not PesSacPrxLig.IsEmpty()
	Where PesSacTipObs = 'I'
	
	&Obs = trim(toformattedString(PesSacDta)) + ' ; Dialogo: ' + PesSacDlg + ' ; ' + ' Editado por: ' + trim(PesSacVenCodNom)
	
	Exit
EndFor
]]></Source>
