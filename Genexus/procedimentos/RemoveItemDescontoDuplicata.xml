      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//REMOVE ITEM E ALTERA STS EM CRESTS
For each order EmpCod, DesCod, DesDupItmCod
	where EmpCod = &EmpCod
	where DesCod = &DesCod
	where DesDupItmCod = &DesDupItmCod
	&DesCreCod = DesCreCod
	&DesFilCod = DesFilCod
	CancelarDesconto.Call(EmpCod,&DesFilCod,&DesCreCod,&DesCod)
	Delete
	exit
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
