        <Source><![CDATA[//&ManRes = ''  
//&XmlDFe.Open(&Arquivo_Nota)    
//Do While  not &XmlDFe.EOF
//    &ManRes += &XmlDFe.ReadRawXML()
//    &XmlDFe.Read()
//Enddo
//&XmlDFe.Close()


For each order EmpCod,ManCha  //faz update
	Where EmpCod = &EmpCod
	Where ManCha = &ManCha
	Do Case
		Case &Evento = 210200
			ManSts = Status_Dfe.Confirmacao
		Case &Evento = 210210
			ManSts = Status_Dfe.Ciencia
		Case &Evento = 210220
			ManSts = Status_Dfe.desconhecido
		Case &Evento = 210240
			ManSts = Status_Dfe.naoRealizada
		Case &Evento = 110111
			ManSitNFe = Situacao_Nfe.CANCELADA
	EndCase
	exit
EndFor

commit


]]></Source>
