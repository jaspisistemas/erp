      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	&SdtEmail.Clear()
	&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
			   
	

	If not &sdtMDfe.c2.IsEmpty()  and (&sdtMDfe.c2.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtMDfe.c2
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtMDfe.c3.IsEmpty()  and (&sdtMDfe.c3.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtMDfe.c3
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtMDfe.c4.IsEmpty() and (&sdtMDfe.c4.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtMDfe.c4
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	
	If not &sdtMDfe.c5.IsEmpty() and (&sdtMDfe.c5.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtMDfe.c5
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtMDfe.c6.IsEmpty()  and (&sdtMDfe.c6.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtMDfe.c6
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtMDfe.c7.IsEmpty() and (&sdtMDfe.c7.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtMDfe.c7
		&SdtEmail.Add(&ItemSdtEmail)
	EndIf

	Do case
		case &SdtEmail.Count = 0
			
			&OutSdtMdfe.sts = 'E856'
			&OutSdtMdfe.obs = 'Nenhum Endereço de E-Mail foi informado!'
			
		case &EmlAss.IsEmpty()
			&OutSdtMdfe.sts = 'E857'
			&OutSdtMdfe.obs = 'Você deve informar o assunto!'
			
		otherwise
			&OutSdtMdfe.sts = 'J200'
			&OutSdtMdfe.obs = ""
			GravaEnvioEmail.Call( &EmpCod, &FilCod, &MDfeCod, 0, TipoContaEmail.Email_Faturamento, &sdtMDfe.c1, TipoSolicitacao.Envia_MDFe, &wwpContextPesCod, '', &SdtEmail, &sdtBoleto)
			
	EndCase
]]></Source>
