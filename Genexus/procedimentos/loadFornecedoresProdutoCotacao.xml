      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsSel = false
&IsNaCotacao = false

if &CotComProCod > 0
	//load Forneecedores do produto
	For Each Order EmpCod, ProCod, ProForCod
		Where EmpCod = &EmpCod
		Where ProCod = &CotComProCod
		Where ProForSts = Status_AtivoInativo.ATIVO
		Where ProForIs= true
		
		&PesCod = ProForCod
		&PesRaz = ProForRaz
		
		do 'getFoneEmail'
		do 'addSdt'
	EndFor

	//fornecedores na cotacao do produto
	For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComItmCod = &CotComItmCod
		&IsSel = true
		&IsNaCotacao = true	
		&PesCod = CotComProForCod
		RetornaNomePessoa.Call(EmpCod, CotComProForCod, &PesRaz)
		
		do 'getFoneEmail'
		do 'addSdt'
	EndFor
Endif

if &CotComItmCod = 0
	&IsSel = true
Else
	&IsSel = false
Endif
//fornecedores na cotacao
For Each Order EmpCod, CotComCod, CotComForCod
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	
	&IsNaCotacao = true	
	
	&PesCod = CotComForCod
	RetornaNomePessoa.Call(EmpCod, CotComForCod, &PesRaz)
	
	&PesEml = CotComForEmail
	&PesFonNum = CotComForNum		
	do 'addSdt'
EndFor

Sub 'addSdt'
	&IsAchou = false
	for &sdtCotacaoCompraFornecedoresItem in &sdtCotacaoCompraFornecedores
		if &sdtCotacaoCompraFornecedoresItem.PesCod = &PesCod
			if &IsSel = true
				&sdtCotacaoCompraFornecedoresItem.IsSel = true
			Endif			
			if &IsNaCotacao = true
				&sdtCotacaoCompraFornecedoresItem.IsNaCotacao = true
			Endif		
			&IsAchou = true
			exit
		Endif
	EndFor

	if &IsAchou = false
		&sdtCotacaoCompraFornecedoresItem = new()
		&sdtCotacaoCompraFornecedoresItem.IsSel = &IsSel
		&sdtCotacaoCompraFornecedoresItem.IsNaCotacao = &IsNaCotacao
		&sdtCotacaoCompraFornecedoresItem.PesCod = &PesCod
		&sdtCotacaoCompraFornecedoresItem.PesRaz = &PesRaz
		&sdtCotacaoCompraFornecedoresItem.PesEml = &PesEml
		&sdtCotacaoCompraFornecedoresItem.PesFonNum = &PesFonNum 
		&sdtCotacaoCompraFornecedores.Add(&sdtCotacaoCompraFornecedoresItem)
	Endif
EndSub


Sub 'getFoneEmail'
	&PesFonNum.SetEmpty()
	&PesEml.SetEmpty()
	
	//email
	For Each Order EmpCod, PesCod, PesEmlCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesEmlPed = true
		&PesEml = PesEml.Trim()
		Exit
	EndFor
	
	//fone
	For Each Order EmpCod, PesCod, PesFonCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where PesFonWhatsPed = true
		&PesFonNum = PesFonNum.Trim()
		Exit
	EndFor
EndSub
]]></Source>
