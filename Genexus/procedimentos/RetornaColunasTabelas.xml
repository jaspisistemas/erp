      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&TabPerCol1 = 0
&TabPerCol2 = 0 
&TabPerCol3 = 0 
&TabPerCol4 = 0 
&TabPerCol5 = 0 

&Tem1 = 0
&Tem2 = 0 
&Tem3 = 0 
&Tem4 = 0 
&Tem5 = 0 


For Each Order EmpCod, TabCod, TabColCod
	Where EmpCod = &EmpCod
	Where TabCod = &TabNum
	
	Do Case 
		Case TabColCod = 1
	        &TabPerCol1 = TabPerCol
			&Tem1 = 1
	    Case TabColCod = 2
	        &TabPerCol2 = TabPerCol
			&Tem2 = 1
	    Case TabColCod = 3
	        &TabPerCol3 = TabPerCol
			&Tem3 = 1
	    Case TabColCod = 4
	        &TabPerCol4 = TabPerCol
			&Tem4 = 1
	    Case TabColCod = 5
	        &TabPerCol5 = TabPerCol
			&Tem5 = 1
		Case TabColCod = 6
	        &TabPerCol6 = TabPerCol
			&Tem6 = 1
		Case TabColCod = 7
	        &TabPerCol7 = TabPerCol
			&Tem7 = 1
		Case TabColCod = 8
	        &TabPerCol8 = TabPerCol
			&Tem8 = 1
		Case TabColCod = 9
	        &TabPerCol9 = TabPerCol
			&Tem9 = 1
    EndCase
EndFor
]]></Source>
