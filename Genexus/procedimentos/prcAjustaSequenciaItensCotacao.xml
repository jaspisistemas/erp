      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Item = 1
For Each Order EmpCod, CotComCod
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	
	
	For Each Order EmpCod, CotComCod, CotComItmCod
		if CotComItmCod <> &Item
			new //add novo item
				EmpCod = EmpCod
				CotComCod = CotComCod
				CotComItmCod = &Item
			EndNew
			
			For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
				New //add fornecedor item
					EmpCod = EmpCod
					CotComCod = CotComCod
					CotComItmCod = &Item
					CotComProForCod = CotComProForCod
				EndNew
			EndFor
			
			&Item += 1
			delete			
		Else
			&Item += 1
		Endif		
	EndFor
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
