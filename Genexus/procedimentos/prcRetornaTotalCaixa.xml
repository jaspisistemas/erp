      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


for Each order EmpCod, CxPdvCod, CxCod, CxItmCod
	Where EmpCod = &EmpCod
	Where CxPdvCod = &CxPdvCod
	Where CxCod = &CxCod
	
	do CAse
		CAse CxItmTip = TipoLancamentoCaixa.RecebimentoCartao
			&CxUsuCar += CxItmVlrExt
			
		CAse CxItmTip = TipoLancamentoCaixa.RecebimentoTEF
			&CxUsuCarTEF += CxItmVlrExt	
			
		CAse CxItmTip = TipoLancamentoCaixa.RecebimentoPIX
			&CxUsuPIX += CxItmVlrExt	
			
		CAse CxItmTip = TipolancamentoCaixa.PIX_INTEGRADO
			&CxUsuPixIntegradoMoeda += CxItmVlrExt
			
		Case CxItmTip = TIpoLancamentoCaixa.RecebimentoCHEQUE
			&CxUsuChq += CxItmVlr
			
		Case CxItmTip = TIpoLancamentoCaixa.RecebimentoPDV and CxItmVlr > 0
			&CxUsuDin += CxItmVlr
			
		Case CxItmTip = TIpoLancamentoCaixa.ExtornoFechamento and CxItmVlr > 0
			&ExtornoDinheiroMoeda += CxItmVlr
			
		Case CxItmTip = TIpoLancamentoCaixa.ExtornoFechamento and CxItmVlrExt > 0
			&ExtornoExtraCaixaMoeda += CxItmVlrExt
			
		Case CxItmTip = TIpoLancamentoCaixa.RecebimentoPDV and CxItmVlrExt > 0	
			&CxUsuCre += CxItmVlrExt
			
		case CxItmTip = TipoLancamentoCaixa.SangriaCaixa
			&sangriaMoeda += CxItmVlr
			
		case CxItmTip = TipoLancamentoCaixa.SuprimentoCaixa
			&SuprimentoMoeda += CxItmVlr
			
	EndCase
	
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
