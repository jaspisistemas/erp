      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	&EmpCod = &wwpContext.EmpCod
	
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwGridGenericoPequeno.sts = 'J200'
	&wwGridGenericoPequeno.pA = '0'
	&wwGridGenericoPequeno.pT = '0'
	&wwGridGenericoPequeno.p1 = '0'
	&wwGridGenericoPequeno.p2 = '0'
	&wwGridGenericoPequeno.p3 = '0'
	&wwGridGenericoPequeno.p4 = '0'
	&wwGridGenericoPequeno.p5 = '0'
	&IsPaginaOk = false
	
	if not (&TipoVeiculo.IsEmpty())
		&VeiTip.FromString(&TipoVeiculo)
	Endif
	
	
	
	For Each Order EmpCod, VeiPla
		Where EmpCod = &EmpCod
		Where VeiTip = &VeiTip when not &VeiTip.IsEmpty()
		Where VeiPla like &NomeVeiculo or VeiMod like &NomeVeiculo when not &NomeVeiculo.IsEmpty()
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwGridGenericoPequeno.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				
				&wwGridGenericoPequenoItem = New()
				&wwGridGenericoPequenoItem.Cod = VeiCod
				&wwGridGenericoPequenoItem.Nom = VeiMod.Trim()
				&wwGridGenericoPequenoItem.Ob1 = VeiPla.Trim()
				&wwGridGenericoPequenoItem.Ob2 = VeiTip.EnumerationDescription()
				&wwGridGenericoPequenoItem.Ob3 = VeiTipCarr.ToFormattedString()
				&wwGridGenericoPequenoItem.Ob4 = VeiTipRod.ToFormattedString()
//				&wwGridGenericoPequenoItem.Ob5 = VeiTipRod.ToFormattedString()
				
				&wwGridGenericoPequeno.Item.Add(&wwGridGenericoPequenoItem)
			Endif		
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	When none
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwGridGenericoPequeno.pA = trim(str(&Pagina))
		&wwGridGenericoPequeno.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwGridGenericoPequeno.p1, &wwGridGenericoPequeno.p2, &wwGridGenericoPequeno.p3, &wwGridGenericoPequeno.p4, &wwGridGenericoPequeno.p5)
		
	Endif
Endif

]]></Source>
