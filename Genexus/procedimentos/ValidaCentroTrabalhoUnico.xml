      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem = ''

For Each order EmpCod, CTrNom
	Where EmpCod = &EmpCod
	Where CTrNom = &CTrNom
	Where CTrCod <> &CTrCod
	&Mensagem = 'Centro Trabalho Já cadastrado Código: ' + trim(str(CTrCod))
	Exit
EndFor
]]></Source>
