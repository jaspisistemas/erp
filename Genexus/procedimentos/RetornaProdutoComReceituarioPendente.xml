      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,FilCod,NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	If NfeProRctPen = Status_SimNao.Sim
		&NfeRctPen = Status_SimNao.Sim
		Exit //Achou algum produto que precisa Receituário
	Else
		&NfeRctPen = Status_SimNao.Nao
	EndIf

EndFor
]]></Source>
