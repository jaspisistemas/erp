      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)


if &IsAcessoConcedido = true //Acesso concedido
	&sdtRetornoWbsEtc.sts = 'J200'
	
	&PadPesCod = (&wwpContext.PesCod*100) + (&FilCod*3) + &AnoBase
	
	if &OqueFazer = 'VER'
		//ANALISAR A HORA DE ALTERACAO PARA PODER ATUALIZAR, E TAMBEM FILIAL LOGADA.
		&AuxPadDtaHorMod  = now()
		&AuxPadDtaHorMod  = &AuxPadDtaHorMod.AddMinutes(-10)
		padraoUsuarioHora.Call('L', '#WidGet_FaturamentoFiscalEntSai#', &PadPesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'T')
		
		if (&PadDtaHorMod < &AuxPadDtaHorMod or &PadObs.IsEmpty()) 
			prcTotalFaturadoNotasWidgets.Call(&wwpContext.EmpCod, &FilCod, &PadPesCod, &AnoBase, &PadDtaHorMod, &sdtNotasFiscais)
		else
			&sdtNotasFiscais.FromXml(&PadObs)
		Endif
	else
		prcTotalFaturadoNotasWidgets.Call(&wwpContext.EmpCod, &FilCod, &PadPesCod, &AnoBase, &PadDtaHorMod, &sdtNotasFiscais)
	Endif
	
	&sdtRetornoWbsEtc.obs = &PadDtaHorMod.ToFormattedString()
	&sdtRetornoWbsEtc.detalhes = &sdtNotasFiscais.ToJson()
EndIf
]]></Source>
