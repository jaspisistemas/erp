      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CartaoMoeda = 0
&DuplicataMoeda = 0
&DinheiroMoeda = 0
&ChequeTMoeda = 0
&PixMoeda = 0
&DepositoMoeda =0
&ChequePMoeda =0
&PedTmpDupTotJur= 0
&PedTmpDupTotDes = 0

For Each Order EmpCod, FilCod, PedCod, PedTmpDupCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	where PedTmpDupVlr > 0

	do Case
		CAse PedTmpFrpPgtoTip = TipoDuplicata.CARTAOD or PedTmpFrpPgtoTip = TipoDuplicata.CARTAOC
			&CartaoMoeda += PedTmpDupVlr
			
			&PedTmpDupTotJur += PedTmpDupCarJur
			&PedTmpDupTotDes += PedTmpDupCarDes
			
		CAse PedTmpFrpPgtoTip = TipoDuplicata.DUPLICATA
			&DuplicataMoeda += PedTmpDupVlr
			 
		CAse PedTmpFrpPgtoTip = TipoDuplicata.DINHEIRO
			&DinheiroMoeda += PedTmpDupVlr
			
		CAse PedTmpFrpPgtoTip = TipoDuplicata.CHEQUET
			&ChequeTMoeda += PedTmpDupVlr
			
		CAse PedTmpFrpPgtoTip = TipoDuplicata.PIX
			&PixMoeda += PedTmpDupVlr
			
		CAse PedTmpFrpPgtoTip = TipoDuplicata.DEPOSITO
			&DepositoMoeda += PedTmpDupVlr
			
		CAse PedTmpFrpPgtoTip = TipoDuplicata.CHEQUEP
			&ChequePMoeda += PedTmpDupVlr
	EndCAse
EndFor
]]></Source>
