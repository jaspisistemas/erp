      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&NomeTelaProduto.SetEmpty()
For Each Order EmpCod, RotCod
	Where EmpCod = &EmpCod
	Where upper(RotLin) like 'WWPRODUTO.ASPX'
	&NomeTelaProduto = 'WWPRODUTO'
	Exit
When none
	&NomeTelaProduto = 'WWIMPPRODUTO'
EndFor
]]></Source>
