      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso conced
	
	For Each ORder EmpCod, VenPedVenCod
		Where EmpCod = &WwpContext.EmpCod
		Where VenPedVenCod = &wwpContext.PesCod
		Where VenDta = serverdate()
		
		&sdtRetornoWbsEtc.c1 = trim(toformattedString(VenTot)) //total vendido
		&sdtRetornoWbsEtc.c2 = trim(toformattedString(VenMed)) //media
		&sdtRetornoWbsEtc.c3 = trim(toformattedString(VenQtd)) //qtd pedidos
		
		Exit
	EndFor

	&sdtRetornoWbsEtc.sts = 'J200'
	
Endif
]]></Source>
