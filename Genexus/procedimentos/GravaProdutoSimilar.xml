      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,SimCod,SimProCod,SimProCodVin
	Where EmpCod = &EmpCod
	Where SimCod = &SimCod
	Where SimProCod = &SimProCod
	Where SimProCodVin = &SimProCodVin
	
	
	exit
when none
	
	&auxSimCod = UltimoCodigoEmpresa.udp(domParCod.PRODUTOSIMILAR, &EmpCod, 0)
	New
		EmpCod = &EmpCod
		SimCod = &auxSimCod
		SimProCod = &SimProCod
		SimProCodVin = &SimProCodVin
	EndNew	
EndFor
commit

]]></Source>
