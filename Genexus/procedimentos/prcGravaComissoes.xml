      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//GRAVAR LOG
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&Context.EmpCod, 'VENDEDORCOMISSAO')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
	prcCarregaLog_VendedorComissao.Call(&EmpCod,  &PesCod, &SdtLogAtributosLevel)
	prcCarregaLog_VendedorComissaoDesconto.Call(&EmpCod, &PesCod, &Desconto_SdtLogAtributosLevel)
//	prcCarregaLog_VendedorComissaoFaturamento.Call(&EmpCod, &Context.FilCod, &PesCod, &Desconto_SdtLogAtributosLevel)
Endif

For Each Order EmpCod, PesCod, ComLctCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	Where ComLctCod = &LCtCod
	
	PesTipCom = &sdtComissaoVendedor.PesTipCom //Atualiza Tipo de Faturmaneto Comissao.
	if &sdtComissaoVendedor.PesTipCom = 'N'
		ComTabNor = &ComTabNor
		ComTabPrm = &ComTabPrm
	Else
		ComTabNor = 0
		ComTabPrm = 0
	Endif
	
	For Each Order EmpCod, PesCod, ComLctCod, ComDscItm //Vendedor Comissao Desconto
		delete
	EndFor
	
	For Each Order EmpCod, PesCod, ComLctCod, ComFatCod //Vendedor faturamento
		Delete
	EndFor
	
	Exit
When none
	new
		EmpCod = &EmpCod
	 	PesCod = &PesCod
		ComLctCod = &LCtCod
		PesTipCom = &sdtComissaoVendedor.PesTipCom
		
		if &sdtComissaoVendedor.PesTipCom = 'N'
			ComTabNor = &ComTabNor
			ComTabPrm = &ComTabPrm
		Else
			ComTabNor = 0
			ComTabPrm = 0
		Endif
	EndNew
EndFor

Commit

prcGravaLog_VendedorComissao.Call(&EmpCod, &Context.FilCod, &PesCod, &Pgmname, &Context.UserName, &SdtLogAtributosLevel)


do Case
	cAse &sdtComissaoVendedor.PesTipCom = 'D'
		&sdtComissaoVendedor.Item.Sort('ComPer')
		
		For &sdtComissaoVendedorItem in &sdtComissaoVendedor.Item //Grava comissaoDEsconto.
			if &sdtComissaoVendedorItem.Sts = 'S' and (&sdtComissaoVendedorItem.ComTabNor > 0 or &sdtComissaoVendedorItem.ComTabPrm > 0 or &sdtComissaoVendedorItem.ComPer <> 0)
				&ComDscItm += 1
				New
					EmpCod = &EmpCod
					PesCod = &PesCod
					ComLctCod = &LCtCod
					ComDscItm = &ComDscItm
					
					ComDscTax = &sdtComissaoVendedorItem.ComPer
					ComDscNor = &sdtComissaoVendedorItem.ComTabNor
					ComDscPrm = &sdtComissaoVendedorItem.ComTabPrm
					ComDscTabCod = &sdtComissaoVendedorItem.ComDscTabCod
					ComDscTabColCod = &sdtComissaoVendedorItem.ComDscTabColCod
				EndNew
				
				Commit
			Endif
		EndFor
		
	cAse &sdtComissaoVendedor.PesTipCom = 'S'
		&sdtComissaoVendedor.Item.Sort('ComValorFat')
		
		For &sdtComissaoVendedorItem in &sdtComissaoVendedor.Item //Grava comissaoDEsconto.
			if &sdtComissaoVendedorItem.Sts = 'S' and (&sdtComissaoVendedorItem.ComValorFat > 0 or &sdtComissaoVendedorItem.ComTabNor > 0 or &sdtComissaoVendedorItem.ComTabPrm > 0)
				&ComDscItm += 1
				New
					EmpCod = &EmpCod
					PesCod = &PesCod
					ComLctCod = &LCtCod
					ComFatCod = &ComDscItm
					
					ComFatVlr = &sdtComissaoVendedorItem.ComValorFat
					ComFatTabNor = &sdtComissaoVendedorItem.ComTabNor
					ComFatTabPrm = &sdtComissaoVendedorItem.ComTabPrm
				EndNew
				
				Commit
			Endif
		EndFor
EndCase


]]></Source>
