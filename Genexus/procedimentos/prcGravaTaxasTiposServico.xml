      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order TipSerCod
	Where TipSerCod = &TipSerCod
	Where TipSerEmpCod = &TipSerEmpCod
	Where TipSerFilCod = &TipSerFilCod
	Where TipSerLctCod = &TipSerLctCod
	
	TipSerEmpIsUse = true
	
	TipSerIssqnRet = &TipSerIssqnRet
	TipSerIssqnTax = &TipSerIssqnTax
	TipSerPisCofCst = &TipSerPisCofCst
	TipSerPisTax = &TipSerPisTax
	TipSerCofTax = &TipSerCofTax
	TipSerPisCofRet = &TipSerPisCofRet
	TipSerCpTax = &TipSerCpTax
	TipSerIrrfTax = &TipSerIrrfTax
	TipSerCsllTax = &TipSerCsllTax
	
	TipSerPerFed = &TipSerPerFed
	TipSerPerEst = &TipSerPerEst
	TipSerPerMun = &TipSerPerMun
	
	TipSerNbsPad = &TipSerNbsPad
	
	Exit
When none	
	For Each Order TipSerCod, (TipSerItmCod)
		Where TipSerCod = &TipSerCod
		&TipSerItmCod = TipSerItmCod
		Exit
	EndFor
	&TipSerItmCod += 1
	
	New
		TipSerCod = &TipSerCod
		TipSerItmCod = &TipSerItmCod
		TipSerEmpCod = &TipSerEmpCod
		TipSerFilCod = &TipSerFilCod
		TipSerLctCod = &TipSerLctCod
		TipSerEmpIsUse = true
		
		TipSerIssqnRet = &TipSerIssqnRet
		TipSerIssqnTax = &TipSerIssqnTax
		TipSerPisCofCst = &TipSerPisCofCst
		TipSerPisTax = &TipSerPisTax
		TipSerCofTax = &TipSerCofTax
		TipSerPisCofRet = &TipSerPisCofRet
		TipSerCpTax = &TipSerCpTax
		TipSerIrrfTax = &TipSerIrrfTax
		TipSerCsllTax = &TipSerCsllTax
		
		TipSerPerFed = &TipSerPerFed
		TipSerPerEst = &TipSerPerEst
		TipSerPerMun = &TipSerPerMun
		
		TipSerNbsPad = &TipSerNbsPad
	EndNew
EndFor

Commit
]]></Source>
