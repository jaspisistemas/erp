      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CreDtaEms = yMDtoD(&ano,&mes,&Dia)
For each Order EmpCod,CreRecPag,CreDtaEms
	Where EmpCod = &EmpCod
	Where CreRecPag = &CreRecPag
	Where Year(CreDtaEms) = &ano when &par = 'M' //Mensal
	Where Month(CreDtaEms) = &mes when &par = 'M' //Mensal
	Where CreDtaEms < &CreDtaEms when &par = 'A' //Anterior
	Where CreSts <> Status_Duplicata.CANCELADA
	
	&CreVlrDup += CreVlrDup
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
