      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProVlrUltCmp = 0

For Each Order EmpCod, ProCod, PedSts, (PedDtaFat), (PedHorFat)
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where PedSts = Status_Pedido.FECHADO
	Where LctTip = TipoLancamento.EntradaMercadoria
	Where LctAtuFor = Status_SimNao.Sim
	
//	if PedVlrCus > 0 //ENTRADA VAI SER OS VALORES INFORMADOS.
//		&PedVlrCus = PedVlrCus
//		if ProDedIpi = true and PedItmVlrIpi > 0
//			&PedVlrCus = &PedVlrCus - PedItmVlrIpi
//			&PedItmVlrIpi = PedItmVlrIpi
//		Endif
//		if ProDedIcms = true and PedItmVlrIpi > 0
//			&PedVlrCus = &PedVlrCus - PedItmVlrIcm
//			&PedItmVlrIpi = PedItmVlrIcm
//		Endif
//		
//		do case 
//			CAse PedProEmbQtd > 0 and PedVlrCus > 0
//				&ProVlrUltCmp = round(&PedVlrCus / PedProEmbQtd, 5)
//			CAse PedProEmbQtd < 0
//				&ProVlrUltCmp = &PedVlrCus * (PedProEmbQtd*-1)
//			Otherwise
//				&ProVlrUltCmp = &PedVlrCus
//		EndCase
//	Else
		&PedVlrCus = PedVlrUntDsc
		if ProDedIpi = true and PedItmVlrIpi > 0
			&PedVlrCus = &PedVlrCus - PedItmVlrIpi
			&PedItmVlrIpi = PedItmVlrIpi
		Endif
		if ProDedIcms = true and PedItmVlrIpi > 0
			&PedVlrCus = &PedVlrCus - PedItmVlrIcm
			&PedItmVlrIcm = PedItmVlrIcm
		Endif
		
		do case 
			CAse PedProEmbQtd > 0 and &PedVlrCus > 0
				&AuxProVlrUltCmp = round(PedVlrUntDsc / PedProEmbQtd, 5)
				&ProVlrUltCmp = round(&PedVlrCus / PedProEmbQtd, 5)
			CAse PedProEmbQtd < 0
				&AuxProVlrUltCmp = PedVlrUntDsc * (PedProEmbQtd*-1)
				&ProVlrUltCmp = &PedVlrCus * (PedProEmbQtd*-1)
			Otherwise
				&AuxProVlrUltCmp = PedVlrUntDsc
				&ProVlrUltCmp = &PedVlrCus
		EndCase
	
	//PedVlrCus = &ProVlrUltCmp
//	EndiF

	if &ProVlrUltCmp < 0
		&ProVlrUltCmp = 0
	Endif
	
	Exit
EndFor

&Varchar = trim(toformattedString(&AuxProVlrUltCmp))
RetiraZerosDepoisVirgulaDuasCasas.Call(&Varchar, &Varchar )
	
&Mensagem = 'Ult.Cmp.: R$'+ &Varchar.Trim()

if &PedItmVlrIpi > 0 or  &PedItmVlrIcm > 0
	if &PedItmVlrIpi > 0
		&Varchar = trim(toformattedString(&PedItmVlrIpi))
		RetiraZerosDepoisVirgulaDuasCasas.Call(&Varchar, &Varchar )
		
		if &PedItmVlrIpi > 0
			&IpiMensagem = ' [IPI: R$'+ &Varchar.Trim()
		Endif
	EndiF
	
	if &PedItmVlrIcm > 0
		&Varchar = trim(toformattedString(&PedItmVlrIcm))
		RetiraZerosDepoisVirgulaDuasCasas.Call(&Varchar, &Varchar )
		
		if &PedItmVlrIpi > 0
			&IpiMensagem += ' ICMS: R$'+ &Varchar.Trim() + ']'
		Else
			&IpiMensagem = '[ICMS: R$'+ &Varchar.Trim() + ']'
		Endif
	Else
		&IpiMensagem += ']'
	EndiF
Endif

]]></Source>
