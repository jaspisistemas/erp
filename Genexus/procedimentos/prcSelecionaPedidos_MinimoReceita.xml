      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtPedidoProduto.Clear()
&QtdNecessaria.SetEmpty()

//FILTRAR PEDIDOS 
for Each Order EmpCod, ProCod, RecProCod
	Where EmpCod = &EmpCod
	Where ProSts = Status_Produto.ATIVO
	Where RecProCod = &ProCod
	
	RetornaTotalPedidos.Call(&EmpCod, &FIlCod, ProCod, &sdtPedidoProduto)
EndFor

for &sdtPedidoProdutoItem in &sdtPedidoProduto
	&AuxProCod = &sdtPedidoProdutoItem.ProCod
	&EstFab = &sdtPedidoProdutoItem.EstFab
	
	//VERIFICAR MATERIA PRIMA NECESSARIA PARA OS PRODUTOS ACIMA
	MateriaPrimaUtilizada1.Call(0, 0, &EmpCod, &FilCod, &AuxProCod, &EstFab, 1, &sdtMateriaPrima)
	
EndFor	

For &sdtMateriaPrimaItem in &sdtMateriaPrima
	if &sdtMateriaPrimaItem.ProCod = &ProCod
		&QtdNecessaria += (&sdtMateriaPrimaItem.QuantidadeInicial - &sdtMateriaPrimaItem.QuantiaUtilizada)
	Endif
EndFor
]]></Source>
