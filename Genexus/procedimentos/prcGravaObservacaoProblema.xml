      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PblCod, (PblObsItm)
	Where EmpCod = &EmpCod
	Where PblCod = &PblCod
	
	&PblObsItm = PblObsItm
	
	Exit
EndFor

&PblObsItm += 1
	
new
	EmpCod = &EmpCod
	PblCod = &PblCod
	PblObsItm = &PblObsItm
	PblObsCmp = &PblObsCmp
	PblObsDta = serverdate()
	PblObsHor = ServerTime()
	PblObsFunCod = &Pescod
	PblObsArqAnx = &PblObsArqAnx
EndNew

Commit
]]></Source>
