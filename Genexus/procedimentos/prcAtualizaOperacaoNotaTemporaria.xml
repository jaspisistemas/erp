      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&tmpLctCod = &LctCod
&tmpFilCod = &FilCod
&tmpNfeFatFilCod = &FatFiLCod

For Each ORder tmpNFeCod
	Where tmpNFeCod = &tmpNFeCod
	
	
	if &tmpLctCod > 0
		tmpLctCod = &tmpLctCod
	Else		
		&tmpLctCod = tmpLctCod
	EndIf
	
	IF &tmpFilCod > 0 //Faltou atualizar a filial
		tmpFilCod = &tmpFilCod //Filial da importação filial logada/ filial de lançamento
	Else
		&tmpFilCod = tmpFilCod
	Endif

	If &tmpNfeFatFilCod > 0
		tmpNfeFatFilCod = &tmpNfeFatFilCod //Filial da faturamento ou selecionada na tela.
	Else
		&tmpNfeFatFilCod = tmpNfeFatFilCod
	EndIf

	If &TmpPedNum > 0
		tmpPedNum = &TmpPedNum
	EndIf

EndFor

Commit


//captura cst pis e cofins padrao da filial e ou tipo lancamento
&CstPisCofins = retornaPisCofinsPadrao.Udp(&EmpCod, &tmpNfeFatFilCod, &tmpLctCod)

//Altera tipo de lancamento, cst pis cofins, 
AtualizaCfopEntrada.Call(&EmpCod, &tmpLctCod, &tmpNFeCod, &CstPisCofins)
]]></Source>
