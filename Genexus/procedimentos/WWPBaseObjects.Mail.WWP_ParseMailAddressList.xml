      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[WWPBaseObjects.WWP_Logger.Debug(&Pgmname, !"Begin parsing mail address list")

&AddressList.Clear()

&TrimmedAddresses = &AddressString.Trim()
If &TrimmedAddresses.IsEmpty()
	WWPBaseObjects.WWP_Logger.Error(&Pgmname, !"Address list is empty")
	return
EndIf

&ValidationRegex = !"\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*"
&SeparatorRegex = !"\s*,\s*"
&SplittedAddresses = &TrimmedAddresses.SplitRegEx(&SeparatorRegex)

For &Address in &SplittedAddresses
	&Address = &Address.Trim()
	If not &Address.IsMatch(&ValidationRegex)
		WWPBaseObjects.WWP_Logger.Error(&Pgmname, !"Address is incorrect: " + &Address)
		&AddressList.Clear()
		return
	Else
		&AddressList.Add(&Address)
	EndIf
EndFor

WWPBaseObjects.WWP_Logger.Debug(&Pgmname, !"Parsing address completed")
]]></Source>
