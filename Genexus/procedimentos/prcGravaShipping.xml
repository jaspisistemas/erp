      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&sdtShipping.FromJson(&Longvarchar)

For Each Order EmpCod, MrkCod, MrkShipSku
	Where EmpCod = &EmpCod
	Where MrkCod = &MrkCod
	Where MrkShipSku = &sdtShipping.id.ToString()
		MrkShipLong = &Longvarchar
		
		MrkShipBai = &sdtShipping.receiver_address.neighborhood.name
		MrkShipLog = &sdtShipping.receiver_address.street_name
		MrkShipNro = &sdtShipping.receiver_address.street_number
		MrkShipCid = &sdtShipping.receiver_address.city.name
		MrkShipPai = &sdtShipping.receiver_address.country.name
		MrkShipUF = &sdtShipping.receiver_address.state.id
		
		MrkShipFrt = &sdtShipping.base_cost

	Exit
When none
	New
		EmpCod = &EmpCod
		MrkCod = &MrkCod
		MrkShipSku = &sdtShipping.id.ToString()
		
		MrkShipBai = &sdtShipping.receiver_address.neighborhood.name
		MrkShipLog = &sdtShipping.receiver_address.street_name
		MrkShipNro = &sdtShipping.receiver_address.street_number
		MrkShipCid = &sdtShipping.receiver_address.city.name
		MrkShipPai = &sdtShipping.receiver_address.country.name
		MrkShipUF = &sdtShipping.receiver_address.state.id
		
		MrkShipFrt = &sdtShipping.base_cost

		MrkShipLong = &Longvarchar
	EndNew	
EndFor

commit


For Each Order EmpCod, MrkCod, MrkPedShipSku
	Where EmpCod = &EmpCod
	Where MrkCod = &MrkCod
	Where MrkPedShipSku = &sdtShipping.id.ToString()
	
	MrkPedVlrFrt = &sdtShipping.base_cost
EndFor

commit


prcBillingInfoMercadoLivre.Call(&EmPCod, &MrkCod, &sdtShipping.id.ToString())
]]></Source>
