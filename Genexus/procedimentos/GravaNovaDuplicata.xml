&CreDupNro = &inCreDupNro

//###################### Lança a duplicata para o adiantamento #############################################
RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon075_ValidaNroDuplicata, &TCon075_ValidaNroDuplicata)

Do 'GetFilialPgto'	
	
UltimoCodigoEmpresa.Call(domParCod.DUPLICATA,&EmpCod, &FilCod,&AuxCreCod)
Do 'Duplicata'
commit

//Agora lança uma duplicata sem pgto para ficar de crédito
Do 'DuplicataCredito'
commit


Sub 'Duplicata'
	
	//Retorna a forma padrão de "Dinheiro" no &padFrpPgtoCod
	RetornaFormasPagamento.Call(&EmpCod, &CreRecPag, '', &PesCod, &TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	
	
	if &CreDupNro.IsEmpty()
		&NroCod = str(10000 * Random())
		&NroCod = trim(&NroCod)
		&CreDupNro = &NroCod
	Endif

	If &TCon075_ValidaNroDuplicata <> 'S' //Aceita Repetido? S=SIM N=NAO
		ValidaNumeroDuplicataRepetido2.Call(&EmpCod,&FilCod,0,&CreCliCod,&CreRecPag,&CreDupNro,&IsErro,&Messagem)
	EndIf
	
	If &IsErro = False
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CreCod = &AuxCreCod
			if &CreFilPgt.IsEmpty()
				CreFilPgt = 1
			Else
				CreFilPgt = &CreFilPgt
			Endif
			//		CreNovCliRaz = &CreNovCliRaz
			CreDupNro = &CreDupNro
			CreDtaEms = ServerDate() 
			CreDtaVct = &CreDtaVct
			CreFrpPgtoCod = &padFrpPgtoCod
			CreVlrDup = &CreVlrDup
			CreVlrSdo = &CreVlrDup
			CreCliCod = &CreCliCod
			CreVenCod = &PesCod
			CreRecPag = &CreRecPag
			CreCbrCod = 1
			CreCodBar = ''
			CreSts    = Status_Duplicata.ATIVO
			CreOriDup = OrigemDuplicata.AdiantamentoPedido
			CrePlanCod = &CrePlanCod
			
			
			CreIsPer = False		
			CreDtaCrt.SetEmpty()
			CreDtaPrt.SetEmpty()
			CreDtaAdv.SetEmpty()
			CreCodBar = ''
			CreNumConGNRE = ''
		EndNew
		
		Commit
		&CreCobObs  = ''
		
		If &MovItmCpl.Trim().IsEmpty()
			&CreCobObs = 'Lançamento realizado por adiantamento de pedidos.'
		Else
			&CreCobObs = 'Lançamento realizado por adiantamento de pedidos. Obs do financeiro: ' + &MovItmCpl
		EndIf
		
		GravaCobranca.call(&EmpCod,&FilCod,&AuxCreCod,&CreCobObs,0,0,&CrePrmPag, '00:00:00', TipoObservacaoDuplicata.INTERNA)
		
		//###################### Lança o pgto da duplicata para o adiantamento #####################################
		
		Do 'GravaPgtoDuplicata'
	Else
		Msg(&Messagem)
	EndIf

EndSub



Sub 'GravaPgtoDuplicata'
	// Pega Ultimo Código
	For Each Order EmpCod FilCod,CreCod
		Where EmpCod  = &EmpCod
		Where FilCod  = &FilCod
		Where CreCod  = &auxCreCod		
		&CreMaxPagCod = CreMaxPagCod
		Exit
	EndFor
	
	&CreMaxPagCod += 1
	
	//Pega ultimo Item
	Do 'UltimoCodigoMovimentoItem'
	
	//Grava o pgto da duplicata
	New
		EmpCod       = &EmpCod
		FilCod       = &FilCod
		CreCod       = &AuxCreCod		    
		CrePagCod    = &CreMaxPagCod
		CrePagDta    = &MovDtaPgt		
		CrePagVlr    = &CreVlrDup	
		CrePagTip    = TipoDuplicataBaixa.Total
		CrePagSts    = Status_Caixa.Lancado
		CrePagVlrJur = 0
		CrePagVlrDsc = 0
		CreMovCod    = &MovCod
		CreMovItmCod = &MovMaxItm
	EndNew
	commit
	
	
	AtualizaSaldoDuplicata.call(&EmpCod, &AuxCreCod, &FilCod)
	
	//Lança o item do movimento
	Do 'LancaMovimentoItem'
	
EndSub

sub 'UltimoCodigoMovimentoItem'
	For Each Order EmpCod,MovCod
		Where EmpCod  = &EmpCod
		Where MovCod  = &MovCod
		&MovMaxItm = MovMaxItm
		Exit
	EndFor
	
	&MovMaxItm += 1
EndSub


Sub 'LancaMovimentoItem'
	
	New
		EmpCod    = &EmpCod
		MovCod    = &MovCod
		MovItmCod = &MovMaxItm
		MovItmVlr = &CrevlrDup
		PlanCod   = &CrePlanCod
		MovFunCod = 0
		MovItmCpl = 'ADTO Á '+&PesRaz.Trim()+' Ref. '+trim(&MovItmCpl)
		MovFunAno = 0
		MovFunMes = 0
		MovFunSts = Status_AbertoFechado.Aberto
		MovCreFilCod = &FilCod
		MovCreCod    = &AuxCreCod 
		MovCrePagCod = &CreMaxPagCod
    EndNew
	
	commit	
	PrcAtualizaMovimentoFinanceiro.Call(&EmpCod, &AdtMovCod)
EndSub

Sub 'GetFilialPgto'
	For Each Order EmpCod,CtabanCod
		Where EmpCod = &EmpCod
		Where CtabanCod = &MovCtaBanCod
		&CreFilPgt = CtaBanFilCod
		exit
	EndFor
EndSub


Sub 'DuplicataCredito'
	
//	
//	//Retorna a forma padrão de "DUPLICIATA" no &padFrpPgtoCod
//	RetornaFormasPagamento.Call(&EmpCod,&CreRecPag, '', &PesCod, &TipoPerfil, &padFrpPgtoCod, &sdtFormasPagamento)
	
	
	&CreDupNro = 'CREDITO'// +TRIM(STR(&AuxCreCod))
	
	If &TCon075_ValidaNroDuplicata <> 'S' //Aceita Repetido? S=SIM N=NAO
		ValidaNumeroDuplicataRepetido2.Call(&EmpCod,&FilCod,0,&CreCliCod,&CreRecPag,&CreDupNro,&IsErro,&Messagem)
	EndIf
	
	
	UltimoCodigoEmpresa.Call(domParCod.DUPLICATA,&EmpCod, &FilCod,&ADTCreCod)
	If &IsErro = False
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CreCod = &ADTCreCod
			if &CreFilPgt.IsEmpty()
				CreFilPgt = 1
			Else
				CreFilPgt = &CreFilPgt
			Endif
			
			CreDupNro = &CreDupNro
			CreDtaEms = ServerDate() 
			CreDtaVct = &CreDtaVct
			CreFrpPgtoCod = 1
			CreVlrDup = &CreVlrDup
			CreVlrSdo = &CreVlrDup
			CreCliCod = &CreCliCod
			CreVenCod = &PesCod
			
			If &CreRecPag = ReceberPagar.Pagar
				CreRecPag = ReceberPagar.Receber// Grava o contrario pois ele é um crédito do adiantamento
			Else
				CreRecPag = ReceberPagar.Pagar
			EndIf
			
			CreCbrCod = 1
			CreCodBar = ''
			CreSts    = Status_Duplicata.ATIVO
			CreOriDup = OrigemDuplicata.AdiantamentoPedido
			CrePlanCod = &CrePlanCod
			CreAdtCreCod = &AuxCreCod //duplicata que gerou movimento no caixa, vinculo para exclusão
			
			CreIsPer = False		
			CreDtaCrt.SetEmpty()
			CreDtaPrt.SetEmpty()
			CreDtaAdv.SetEmpty()
			CreCodBar = ''
			CreNumConGNRE = ''
		EndNew
		
		Commit
		&CreCobObs  = ''
		
		If &MovItmCpl.Trim().IsEmpty()
			&CreCobObs = 'Lançamento realizado por adiantamento de pedidos.'
		Else
			&CreCobObs = 'Lançamento realizado por adiantamento de pedidos. Obs do financeiro: ' + &MovItmCpl
		EndIf
		
		GravaCobranca.call(&EmpCod,&FilCod,&ADTCreCod,&CreCobObs,0,0,&CrePrmPag, '00:00:00', TipoObservacaoDuplicata.INTERNA)
		
	Else
		Msg(&Messagem)
	EndIf

EndSub
