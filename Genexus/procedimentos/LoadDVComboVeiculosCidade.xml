      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each
	Where &EmpCod = EmpCod 
	Where &UfeCod = UfeCod
	&Combo_DataItem = new()
	&Combo_DataItem.ID = CidCod.ToString().Trim()
	&Combo_DataItem.Title = CidCodNomUfe
	&Combo_Data.Add(&Combo_DataItem)
EndFor

If &TrnMode <> TrnMode.Insert
	For Each Veiculos
		Where EmpCod = &EmpCod
		Where VeiCod = &VeiCod

		&SelectedValue = iif(VeiCidCod.IsEmpty(), '', VeiCidCod.ToString().Trim())
	EndFor
EndIf

if &SelectedValue.IsEmpty() //and &IsDynamicCall = true
	For &Combo_DataItem in &Combo_Data
		&SelectedValue = &Combo_DataItem.ID
//			&SelectedText = &Combo_DataItem.Title
		Exit
	EndFor	
Endif
]]></Source>
