        <Source><![CDATA[

loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'LAÇAMENTO DE PAGAMENTOS FÉRIAS/RESCISÃO'
	print Cabecalho
End

&FPagTip.SetEmpty()
For Each ORder EmpCod, FPagTip, FPagPesCod
	Where EmpCod = &EmpCod
	Where FPagCod = &parFPagCod when Not &parFPagCod.IsEmpty()
	Where FPagAno = &Ano
	Where FPagPesCod = &PesFunCod when not &PesFunCod.IsEmpty()
	Where FPagFunFilCod = &PesFilCod when not &PesFilCod.IsEmpty()
	Where (FPagTip = TipoPagamentoFolha.Ferias and &TipoPagamento = 'F') or (FPagTip = TipoPagamentoFolha.Rescisao and &TipoPagamento = 'R') or (&TipoPagamento = 'T' and (FPagTip = TipoPagamentoFolha.Ferias or FPagTip = TipoPagamentoFolha.Rescisao))
	Where FPagLibPgt = true //Liberado para pagamento
	Where FPagSts <> Status_Folha.Pago //Somente Folhas Abertas
	
	&FPagAno = FPagAno
	&FPagPesCod = FPagPesCod
	&FPagPesExtCod = FPagPesExtCod
	&PesRaz = FPagPesRaz
	
	if &FPagTip <> FPagTip
		if &TotCreVlrDup > 0
			&IsTotalGeral = true
			&GeralCreVlrDup += &TotCreVlrDup
			print TotalItem
			&TotCreVlrDup = 0
		Endif
		
		&FPagTip = FPagTip
		
		If FPagTip = TipoPagamentoFolha.Ferias
			&TipoBoleto = 'PAGAMENTO DE FERIAS'	
		Else
			&TipoBoleto = 'RESCISÕES'
		Endif
		
		print tipoBoleto
		print itemTitulo
	Endif
	
	&CreCliCod = FPagPesCod
	
	//Gera Pagamento Conta Pagar.
	For Each Order EmpCod, FPagCod, FPagDupCod
		Where FPagDupCreCod.IsEmpty()
		&IsFgts = false
		if FPagTip = TipoPagamentoFolha.Rescisao
			if FPagDupCod = 1
				&Informacao = '[R$ RESCISÓRIO]'
			Else
				&Informacao = '[R$ FGTS]'
				&IsFgts = true
			Endif		
		Endif
	
		if FPagDupVlr.IsEmpty()
			FPagDupVlr = FPagTotVlr
		Endif
		
		&CreVlrDup = FPagDupVlr
		&FPagDupVlr = FPagDupVlr 
		if FPagDupVct < serverdate()
			FPagDupVct = serverdate()
		Endif
		
		&FPagDupVct = FPagDupVct
		&CreDtaVct = FPagDupVct
		&FPagDupPlanCod = FPagDupPlanCod
		&TotCreVlrDup += FPagDupVlr	
		
		//		if &CreVlrDup > 0 //jdf comentei porque se caso nao tiver valor, nao iria gerar duplicata, mas ai teria que fazer uma opcao para cancelar o fechamento, assim cancela quando cancela a duplicata.
		UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &FilCod, &AuxCreCod)
		FPagDupCreCod = &AuxCreCod
		FPagDupFilCod = &FilCod
		
		do 'addDuplicata'
		
		print Item
	EndFor
	
	&FPagIsBloUsu = FPagIsBloUsu
	&FpagIsRemFun = FPagIsRemFun
	if FPagTip = TipoPagamentoFolha.Rescisao
		If &FpagIsRemFun = True
			prcInativaFuncionarioAoDemitir.Call(&EmpCod, &Context.FilCod, &FPagPesCod, &Context.UserName)
		Endif
	
		if &FPagIsBloUsu = True and &FPagPesExtCod <> 0
			do 'getUsuariosGAM'
		Endif
	
		do 'getUltimoRecrutamento'
		if not FPagDtaDem.IsEmpty() and not FPagDtaDem.IsNull() and &PesRecCod > 0
			
			&Obs = 'LANCAMENTO FOLHA PAGAMENTO, REGISTRO DE RESCISAO: ' + trim(Str(FPagCod))
			GravaRecrutamento.Call(TrnMode.Update,&EmpCod,&FPagPesCod,&PesRecCod,&PesRecCodMax,&PesRecDtaAdm,&PesRecDtaReg,&PesRecDtaDem,&Obs, &Context.PesCod)
			AtualizaEnderecoCliente.Call(&EmpCod, &FPagPesCod)
		Endif
	Endif

	FPagSts = Status_Folha.Pago	
	Commit
	
EndFor


if &TotCreVlrDup > 0
	&GeralCreVlrDup += &TotCreVlrDup
	print TotalItem
	
	if &IsTotalGeral = true
		print TotalGeral
	Endif

	&TotCreVlrDup = 0
Endif


Footer
	print Rodape
End


SUB 'getUltimoRecrutamento'
	&PesRecCod.SetEmpty()
	&PesRecDtaAdm.SetEmpty()
	&PesRecDtaReg.SetEmpty()
	&PesRecDtaDem.SetEmpty()
	
	For each Order EmpCod,PesCod // 1
		Where EmpCod = &EmpCod
		Where PesCod = &FPagPesCod
		
		&PesRecCodMax = PesRecCodMax + 1
		
		For each Order EmpCod,PesCod,(PesRecCod)
			Where PesRecSts = Status_AtivoInativo.ATIVO or PesRecSts.IsEmpty() or PesRecSts.IsNull()
			
			&PesRecCod = PesRecCod
			&PesRecDtaAdm = PesRecDtaAdm		
			&PesRecDtaReg = PesRecDtaReg
			&PesRecDtaDem = PesRecDtaDem
			
			Exit
		EndFor
	
		Exit
	EndFor
EndSub


Sub 'getUsuariosGAM'	
	&GAMUserFilter.AuthenticationTypeName	= ''
	&GAMUserFilter.ReturnAnonymousUser 	= false
	&GAMUserFilter.ExternalId = trim(str(&FPagPesExtCod))
	
	For &User in GAMRepository.GetUsersOrderBy(&GAMUserFilter, GAMUserListOrder.None, &Errors)
		&gridGUID = &User.GUID
		Exit
	EndFor

	if not &GridGUID.IsEmpty()
		&User.Load(&GridGUID)
		&User.IsActive = False
		&User.IsBlocked = true
		&User.Save()
		If &User.Success()
			commit
		Endif
	EndIf
EndSub

Sub 'addDuplicata'
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CreCod = &AuxCreCod
		CreFilPgt = &PesFilCod
		CreDtaVct = &FPagDupVct
		
		CreSts    = Status_Duplicata.ATIVO
		CreCliCod = &CreCliCod
		CreVenCod = &Context.PesCod
		CreRecPag = ReceberPagar.Pagar
		CreCbrCod = 1
		
		CreVlrDup = &FPagDupVlr 
		CreVlrSdo = &FPagDupVlr 
		CrePlanCod = &FPagDupPlanCod
	
		CreNovCliRaz = ''
		
		CreDtaEms = serverdate()
		CreFrpPgtoCod = 1
		
		CreCodBar.SetEmpty()
		
		if &FPagTip = TipoPagamentoFolha.Ferias
			CreOriDup = OrigemDuplicata.PagamentoFerias
			CreDupNro = 'FERIAS.'+trim(Str(&FPagAno))+'/'+ trim(Str(&FPagPesCod))
		Else
			CreOriDup = OrigemDuplicata.PagamentoRescisao
			if &IsFgts = true
				CreDupNro = 'FGTS.'+trim(Str(&FPagAno))+'/'+ trim(Str(&FPagPesCod))
			Else
				CreDupNro = 'RESCISÃO.'+trim(Str(&FPagAno))+'/'+ trim(Str(&FPagPesCod))
			Endif
		Endif
	
		CrePlanCod = &FPagDupPlanCod
		CreIsPer.SetEmpty()

		CreDtaCrt.SetEmpty()
		CreDtaPrt.SetEmpty()
		CreDtaAdv.SetEmpty()
		CreCodBar.SetEmpty()
		CreNumConGNRE.SetEmpty()
	EndNew

	Commit
EndSub
