// RECRIEI PARA VER SE FUNCIONAVA E FUNCIONOU // LHF //
&urlString 			= 'viacep.com.br/ws/' + Trim(&SoNumero) + '/json/'
&httpClient.Host	= 'viacep.com.br'
&httpClient.Secure	= True
&httpClient.Execute('GET', &urlString)

If &httpClient.StatusCode	= 200
	&Varchar		= &httpClient.ToString()
	
	&Posicao 		= StrSearch(&Varchar, 'uf')
	&Posicao		+= 6
	&OpeOriCidUfe	= SubStr(&Varchar, &Posicao, 2)
	
	&Posicao		= StrSearch(&Varchar, 'ibge')
	&Posicao		+= 8
	&OpeOriCidIBGE	= Val(SubStr(&Varchar, &Posicao, 8))
EndIf
