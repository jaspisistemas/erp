      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TalCtaBanAge = trim(Str(&CheAgeCod))

For Each Order EmpCod, CheBanCod, CheAgeCod, CheCon, CheNro
	Where EmpCod = &EmpCod
	Where TalCtaBanBanCod = &CheBanCod
	Where TalCtaBanAge = &TalCtaBanAge
	Where TalCtaBanCrt = &CheCon
	Where CheNro = &CheNro
	Where CheTip = TipoCheque.Proprio
	
	&CtaBanAbv = TalCtaBanAbv
	&CheCod = CheCod
	
	Exit
EndFor
]]></Source>
