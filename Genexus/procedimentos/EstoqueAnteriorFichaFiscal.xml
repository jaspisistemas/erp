      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&EstTipQtd = 0
For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &PRoGraCod when &PRoGraCod > 1
	&EstTipQtd += EstQtdFis
EndFor

For Each Order EmpCod, FilCod, NfeProCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeProCod = &ProCod
	Where NfeProGraCod = &PRoGraCod when &PRoGraCod > 1
	Where NfeSts = Status_NFe.Autorizada or (NfeProTer = Nota_ProPriaTerceira.TERCEIROS and (NfeSts = Status_NFe.Autorizada or NfeSts = Status_Nfe.Digitando))
	Where (NfeDtaFat >= &PedDtaFat and  NfeDtaFat <= &PedDtaFat_to) 
	Where NfeLctAtuEstFis = Status_EntradaSaida.Entrada or NfeLctAtuEstFis = Status_EntradaSaida.Saida
	
	if NfeLctAtuEstFis = Status_EntradaSaida.Saida
		&EstTipQtd += NfeProQtd
	else
		&EstTipQtd -= NfeProQtd
	endif    
EndFor
]]></Source>
