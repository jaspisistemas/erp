&LogGUID = GUID.NewGuid()

//csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.ServicePointManager.SecurityProtocol;

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoespasta)

//#################### CALCULA % PROGRESSO ###########
&TotalPercentual = 0
For Each Order EmpCod,PesEml,PesCod
	Where EmpCod = &EmpCod
	Where PesEml in &ColPesEml
	&TotalPercentual += 1
EndFor
Do 'Percentual'
&Count = 0  
//####################################################


//############### ADICIONA TODOS OS CLIENTES QUE PERTENCEM AO E-MAIL SELECIONADO QUE ESTA VINDO POR PARÂMENTRO NUMA COLLECTION  ###################
&ColPesCod.Clear() //zera os clientes
&Index = 0

For Each Order EmpCod,PesEml,PesCod
	Where EmpCod = &EmpCod
	Where PesEml in &ColPesEml

	&Index +=1 
	If &PesEml <> PesEml and &Index > 1 // Se trocou o e-mail Chama o envio, 
		Do 'BUSCANOTASDOSCLIENTES'
		&ColPesCod.Clear() 
	EndIf
	
	&PesEml = PesEml
	&ColPesCod.Add(PesCod)
	
EndFor

//esta fora pos se tiver so um email ou ultimo email nao entra na regra do if
Do 'BUSCANOTASDOSCLIENTES'
//##############################

&ProgressLogXml = 'E-mail enviado com Sucesso!'
&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'



Sub 'BUSCANOTASDOSCLIENTES'
	Msg('Buscando clientes',Status)
	&ProgressLogXml = 'Contabilizou'
	&Count += 1
	
	Do 'Percentual'
	
	&IniNfeDtaEms = YMDtoD(&Ano,&Mes,1)
	&FinNfeDtaEms = YMDtoD(&Ano,&Mes,Day(Eom(&IniNfeDtaEms)))
	
	DO Case
		Case &TipoNota = 'P'
			&NfsProTer = Nota_ProPriaTerceira.PROPRIA
		Case &TipoNota = 'T'
			&NfsProTer = Nota_ProPriaTerceira.TERCEIROS
		OtherWise
			&NfsProTer.SetEmpty()
	EndCase	
	&IsExistDiretorio = false
	
	CopiaXmlAutorizadosNfse.Call('EMAILAGRUPADO',&EmpCod,&FilCod,&IniNfeDtaEms,&FinNfeDtaEms,&SomenteNotasAutorizadas,&sdtConfiguracoesPasta,&destinoPasta,&EnviaPdfNota,&ColPesCod,&CountNfse)
	
	&Attachments.Clear()
	&Destinatarios.Clear()
	do 'EnviarEmail'
EndSub



Sub 'EnviarEmail'
	&DestinoPesEml = &PesEml //esse vem la do For
	For Each Order EmpCod,FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilRaz = FilRaz
		Exit
	EndFor
	
	msg('Enviar para o e-mail ' +&DestinoPesEml,status)
	
	If not &DestinoPesEml.Trim().isEmpty()
		
		For Each Order EmpCod, EmpEmlCod
			Where EmpCod = &EmpCod
			Where EmpEmlTip = TipoContaEmail.Email_Faturamento
			
			If EmpEml = 'nao_responda@jaspi.com.br' or EmpEml = 'nao.responda.jaspi@gmail.com' //adiciona a mensagem dados do remetente
				&EmpEmlCod = EmpEmlCod
				do 'EmailPadrao'
			Else
				&AddressVarchar = EmpEml
				//&FilRaz
				&AuthenticationNumeric = EmpEmlAut
				&SecureNumeric 		= EmpEmlSec
				&TimeoutNumeric        = 600
				&HostVarchar 			= EmpEmlHos
				&UserNameVarchar 		= EmpEmlUsr
				&EmpEmlSen 		= DecryptSenhaEmail.Udp(EmpCod, EmpEmlCod, EmpEml)
				&PortNumeric 			= EmpEmlPor
				&imapHost = EmpEmlImapHos
				&imapPort = EmpEmlImapPor
				&imapSsl = EmpEmlImapSsl
			EndIF
			
			&EmlAss = 'Notas Serviço Mês:' + trim(PadL(str(&mes), 2, '0')) + '/' +trim(str(&Ano)) + ' da empresa ' + trim(&FilRaz)
			
			//Destinatário de email
			&Destinatarios.Add(&DestinoPesEml)
			
			do 'PreencheHTML'
			
			If not &destinoPasta.IsEmpty() //add xml NFE
				&File.Source = &destinoPasta
				If &File.Exists()
					//=====Adiciona Anexo a partir de um caminho do servidor=====
					&Attachments.Add(&destinoPasta)
				EndIF
				&File.Close()
			EndiF
			
			&Result = &JASPI_enviaEmail.SendEmailSafeJson(&HostVarchar, &PortNumeric, &UserNameVarchar, &EmpEmlSen, &imapHost, &imapPort, &imapSsl, &FilRaz, &AddressVarchar, &FunEmailContato, &FilRaz, &Destinatarios, &EmlAss, &Obs, &Attachments, true)	
			&EmailResult.FromJson(&Result)				
			If &EmailResult.Success = true
				// Marca como enviado
				&ProgressLogXml = 'Enviado com Sucesso!'
				&EmlSts = Status_Solicitacao.Finalizada
				&IsExecutou = true
			Else
				&ProgressLogXml = &EmailResult.ErrorCode + " - " + &EmailResult.Message					
				&EmlSts = Status_Solicitacao.Falha
			EndIf
			
		When none
			msg('ATENÇÃO! Não foi encontrado e-mail de faturamento',status)
		EndFor
	Else
		msg('ATENÇÃO! nenhum e-mail destino preenchido',status)
	EndIf
EndSub


Sub 'PreencheHTML'
	&Obs =  ' </head> '
	
	&Obs +=  ' <body> '
	&Obs += '<p>Notas Serviço do Mês:' + trim(PadL(str(&mes), 2, '0')) + '/' +trim(str(&Ano)) + ' da empresa ' + trim(&FilRaz)
	
	if (&CountNfse > 0)
		&Obs += '<p>Encontra-se Anexados nesse Email os seguintes Arquivos.'
		
		If not &destinoPasta.IsEmpty()
			&Obs += ' <li><em># xmlsDasNfs.zip</em></li>'
		EndiF
//		If not &ZipXMLS1.IsEmpty()
//			&Obs += ' <li><em># xmlsDasNfeTerceiros.zip</em></li>'
//		EndiF
		
//		If  not &ZipXMLSCte.IsEmpty()
//			&Obs += ' <li><em># xmlsDosCTe.zip</em></li>'
//		EndIf
//		
//		if not &NomeArquivoSintegraProPrio.IsEmpty()
//			&Obs += ' <li><em># SintegraProprias.txt</em></li>'
//		EndiF
//		
//		if not &NomeArquivoSintegraTerceiros.IsEmpty()
//			&Obs += ' <li><em># SintegraPropriasTerceiros.txt</em></li>'
//		EndiF
//		
//		if not &NomeArquivoRelatorio.IsEmpty()
//			&Obs += ' <li><em># RelatorioNotasEmitidas.pdf</em></li>'
//		EndIF
	
//		if &EnviaRelatorioProdutos = true and not &NomeArquivoRelatorioProdutos.IsEmpty()
//			&Obs += ' <li><em># RelatorioProdutos.pdf</em></li>'
//		EndIF
//	
//		if not &NomeArquivoRelatorioCte.IsEmpty()
//			&Obs += ' <li><em># RelatorioCtesEmitidos.pdf</em></li>'
//		EndIF
//		
//		if not &NomeArquivoRelatorioCtePrestacao.IsEmpty()
//			&Obs += ' <li><em># RelatorioCtesAgrupadosPrestacao.pdf</em></li>'
//		EndIF
	Else
		&Obs += '<p>Nenhuma Nota emitida/localizada para o Mês informado.'
	endif

	&Obs += '<p>'
	&Obs += '<p>Erros/dúvidas/elogios entre em contato conosco.'
	&Obs += '<p>E-mail: contato@jaspi.com.br.'
	&Obs += '<p>Fone: (44) 9-9753-8680 / (45) 9-9998-3031'

	&Obs +=  ' </body> '
	&Obs +=  ' </html> '
EndSUb

sub 'EmailPadrao'
	EmailPadrao.call(&AddressVarchar, &AuthenticationNumeric, &SecureNumeric, &TimeoutNumeric, &HostVarchar, &UserNameVarchar, &PortNumeric, &imapHost, &imapPort, &ImapSSl)
	&EmpEmlSen = DecryptSenhaEmail.Udp(&EmpCod, &EmpEmlCod, &AddressVarchar)
EndSub


sub 'Percentual'
	If &Count > 0
		&Percentual = round((&Count / &TotalPercentual) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
EndSub

Sub 'Atualiza'
	
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &ProgressLogXml
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressLogXml = &ProgressLogXml
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub



Sub 'Exception_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXexceptionType',&GXexceptionType)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionDetails',&GXExceptionDetails)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionStack',&GXExceptionStack)
Endsub

Sub 'Error_handler'
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &Err',&Err.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBErr',&gxDBErr.ToFormattedString())
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &GxDbSqlState',&GxDbSqlState)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBTxt',&gxDBTxt)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxOper',&gxOper)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrTbl',&gxErrTbl)
	GravaLogDevNew(&SolEmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrOpt',&gxErrOpt.ToFormattedString())
Endsub
