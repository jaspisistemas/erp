      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//pega o total da nfe
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	&NfeVlrTot = NfeVlrTot
	&SaldoNfeVlrTot = NfeVlrTot
	
	//deleta as duplicatas da nota
	For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		delete 
	EndFor

	Exit
EndFor

commit

For Each Order EmpCod, FilCod, CreDtaVct
	Where EmpCod = &EmpCod
	Where CreFilPgt = &FilCod
    Where FilCod = &NfeFilCod
    Where CrePedCod = &NfePedCod
	Where CreSts <> Status_Duplicata.CANCELADA
	
	&NfeDupCreSeq = CreCod
	&NfeDupFiLCod = FilCod
	&NfeDupVlr = CreVlrDup
	&NfeDupVct = CreDtaVct
	
	&CreCbrCod = CreCbrCod
	
	if CreFrpPgtoTip in (TipoDuplicata.PIX, TipoDuplicata.DINHEIRO, TipoDuplicata.DUPLICATA, TipoDuplicata.CARTAOC, TipoDUplicata.CARTAOD)
		&NfeDupFrpPgtoCod = CreFrpPgtoCod
	Else
		&NfeDupFrpPgtoCod = 1 //TipoDuplicata.DUPLICATA
	Endif

	&Parcela += 1
	
	if &SaldoNfeVlrTot >= &NfeDupVlr
		do 'add'
		&SaldoNfeVlrTot -= &NfeDupVlr
	Else
		&NfeDupVlr = &SaldoNfeVlrTot
		do 'add'
		&SaldoNfeVlrTot = 0
	Endif

	
EndFor

Commit

sub 'add'
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		NfeCod = &NfeCod
		NfeDupItmCod = &Parcela	
		
		NfeDupCreSeq = &NfeDupCreSeq
		NfeDupFiLCod = &NfeDupFiLCod 
		
		NfeDupFrpPgtoCod = &NfeDupFrpPgtoCod
		
		NfeDupNro =  trim(str(&Parcela))
		
		NfeDupVlr = &NfeDupVlr
		NfeDupVct = &NfeDupVct
		
		NfeCbrCod = &CreCbrCod
		
		
	EndNew
EndSub
]]></Source>
