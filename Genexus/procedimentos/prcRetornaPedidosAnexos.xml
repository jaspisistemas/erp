      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For each Order EmpCod, FilCod, NfeCod, NfeSelPedCod
	Where EmpCod  = &EmpCod
	Where FilCod = &FiLCod
	Where NfeCod = &NfeCod
	
	&NfeSelPedCod = NfeSelPedCod
	do 'addPedido'
	
	
EndFor

Sub 'addPedido'
	For each Order EmpCod, FilCod, PedCod
		Where EmpCod  = &EmpCod
		Where FilCod = &FiLCod
		Where PedCod = &NfeSelPedCod
		
		&SdtPedidosItem = new()
		&SdtPedidosItem.EmPCod = EmpCod
		&SdtPedidosItem.FiLCod = FilCod
		&SdtPedidosItem.PedCliCod = PedCliCod
		&SdtPedidosItem.PedCod = PedCod
		&SdtPedidosItem.PedCliCodRaz = PedCliCodRaz
		&SdtPedidosItem.PedNovStsFinNom = PedNovStsFinNom
		&SdtPedidosItem.PedNovStsNom = PedNovStsNom
		&SdtPedidosItem.PedDtaEms = PedDtaEms
		&SdtPedidosItem.PedNum = PedNum
		&SdtPedidosItem.PedDtaFat = PedDtaFat
		&SdtPedidosItem.PedVlrLiq = PedVlrLiq
		&SdtPedidosItem.Localizado = 'S'
		&SdtPedidos.Add(&SdtPedidosItem)
		Exit
	EndFor

EndSub

]]></Source>
