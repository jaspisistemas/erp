<Object parentGuid="d7b266f9-5422-4e24-977c-b51d9c740a73" user="WINJEAN\jeanfae" versionDate="2025-09-10T19:49:30.0000000Z" lastUpdate="2025-09-09T18:29:14.0000000Z" checksum="0608e5b70027800279bb3911fb3d8aaa" fullyQualifiedName="api_pdv.setTef" moduleGuid="8b5aceb8-b5bf-411a-a16f-531f05b3723e" guid="71f459be-a12e-4c00-8fc5-c152a62d4e64" name="setTef" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="set Tef" parent="api_pdv.Sincronizacao" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
for Each order EmpCod, PdvCod
	Where PdvRandon = &PdvRandon //PRA SABER SE É UM PDV VALIDO
	
	&EmpCod = EmpCod
	&FilCod = PdvFilCod
	&PdvCod = PdvCod
	&PDvId = PdvId
	&OriCtaBanCod = PdvCtaBanCod
	&PdvCtaBanCodCofre = PdvCtaBanCodCofre
 	
	Exit
When none
	Return
EndFor

&LogGUID = GUID.NewGuid()
//GravaLogDev.Call(&EmpCod, 0, &LogGUID, &Pgmname, '&sdtGetTEF', &sdtGetTEF.ToXml())

&DataHora = timestampToDateTime.Udp(&sdtGetTEF.TefDtaSolTmp)
&TefDtaSol = YMDtoD(&DataHora.Year(), &DataHora.Month(), &DataHora.Day())
&TefHorSol = padL(trim(str(&DataHora.Hour())),2,'0') + ':' + padL(trim(str(&DataHora.Minute())),2,'0') + ':' + padL(trim(str(&DataHora.Second())),2,'0')


For Each Order EmpCod, TefCod
	Where EmpCod = &EmpCod
	Where TefGUID = &sdtGetTEF.TefGuiD
	
	&TefCod = TefCod
	TefFilCod = &sdtGetTEF.TefFilCod
	TefPedCod = &sdtGetTEF.TefPedCod 
	TefBanCarCod = &sdtGetTEF.TefBanCarCod
	TefBand = &sdtGetTEF.TefBand
	
	
	TefDtaSol = &TefDtaSol
	TefHorSol = &TefHorSol
	
	TefSts = &sdtGetTEF.TefSts 
	TefCreDebVou = &sdtGetTEF.TefCreDebVou 
	TefCrePar = &sdtGetTEF.TefCrePar 
	TefID = &sdtGetTEF.TefID 
	TefIdAut = &sdtGetTEF.TefIdAut
	TefStsSyncServ = 'S'
	TefVlr = &sdtGetTEF.TEfVlr
	TefBandCod = &sdtGetTEF.TefBandCod 
	TefBandCnpj = &sdtGetTEF.TefBandCnpj.Trim()
	TefCardNom = &sdtGetTEF.TefCardNom.Trim()

	exit
When none
	UltimoCodigoEmpresa.Call(domParCOD.TEF, &EmpCod, 0, &TefCod)
	new
		EmpCod = &EmpCod
		TefCod = &TefCod
		TefFilCod = &sdtGetTEF.TefFilCod
		TefPedCod = &sdtGetTEF.TefPedCod 
		TefBanCarCod = &sdtGetTEF.TefBanCarCod
		TefBand = &sdtGetTEF.TefBand
		TefDtaSol = &TefDtaSol
	TefHorSol = &TefHorSol
		TefSts = &sdtGetTEF.TefSts 
		TefCreDebVou = &sdtGetTEF.TefCreDebVou 
		TefCrePar = &sdtGetTEF.TefCrePar 
		TefID = &sdtGetTEF.TefID 
		TefStsSyncServ = 'S'
		TefVlr = &sdtGetTEF.TEfVlr
		TefGUID = &sdtGetTEF.TefGuiD
		TefBandCod = &sdtGetTEF.TefBandCod 
		TefBandCnpj = &sdtGetTEF.TefBandCnpj.Trim()
		TefCardNom = &sdtGetTEF.TefCardNom.Trim()
	endnew
EndFor

Commit

//GravaLogDev.Call(&EmpCod, 0, &LogGUID, &Pgmname, 'TEF Commit', '')

For &sdtGetTEFHistorico in &sdtGetTEF.Historico
	For Each Order EmpCod, TefCod, TefItmID
		Where EmpCod = &EmpCod
		Where TefCod = &TefCod
		Where TefItmID = &sdtGetTEFHistorico.TefItmID
		
		TefItmSts = &sdtGetTEFHistorico.TefItmSts
		TefMsg = &sdtGetTEFHistorico.TefMsg
		TefItmStsSyncServ = 'S'
		TefItmDtaHor = serverNow()
		Exit
	When None
	
		NEw
			EmpCod = &EmpCod
			TefCod = &TefCod
			TefItmID = &sdtGetTEFHistorico.TefItmID
			TefItmSts = &sdtGetTEFHistorico.TefItmSts
			TefItmDtaHor = serverNow()
			TefMsg = &sdtGetTEFHistorico.TefMsg
			TefItmStsSyncServ = 'S'
		EndNEw
	
	EndFor
	
	Commit
EndFor

//RETORNA STATUS GRAVADO COM SUCESSO
&SdtRetornoPDV.Codigo = 1
&SdtRetornoPDV.Mensagem = 'TEF LANCADA SERVIDOR'
return

Sub 'subException_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subException_handler',&sdtTEFLongVarchar)
	
EndSub

Sub 'subError_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subError_handler',&sdtTEFLongVarchar)
	
EndSub
]]></Source>
