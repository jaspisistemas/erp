      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &PedCliCod <> 0
	&sdtVinculos = RetornaVinculos.UDP(&EmpCod, &PedCliCod)
	
	For &sdtVinculosItem in &sdtVinculos
		For Each Order EmpCod, PesCod
			Where EmpCod = &EmpCod
			Where PesCod = &sdtVinculosItem.PesCod
			Where PesCod <> &PedCliCod
			
			If &NovPesIntVenCod > 0
				PesIntVenCod = &NovPesIntVenCod
			EndiF
		
			If &NovPesExtVenCod > 0
				PesExtVenCod = &NovPesExtVenCod
			EndIF
		
			&Count += 1
		EndFor
	EndFor	
EndIF


Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
