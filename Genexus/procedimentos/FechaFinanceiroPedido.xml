      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&TotalDuplicataMoeda = 0
&TotalCredito = 0 
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod 
	Where PedCod = &PedCod
		
	PedStsFinIsPar = false
	PedStsFin = Status_Financeiro.FECHADO
	
	RetornaTotalDuplicatasDoPedido.Call(EmpCod, FilCod, PedCod, &TotalDuplicataMoeda)
	RetornaTotalCreditoDoPedido.Call(EmpCod, FilCod, PedCod, &TotalCredito)//isso busca e utiliza somente nas ordem de carregamento 
	&TotalDuplicataMoeda = &TotalCredito+&TotalDuplicataMoeda
	if &TotalDuplicataMoeda <> PedVlrFin and &TotalDuplicataMoeda > 0
		PedStsFin = Status_Financeiro.ABERTO
		PedStsFinIsPar = true
	Endif

	
	Exit
EndFor

Commit
]]></Source>
