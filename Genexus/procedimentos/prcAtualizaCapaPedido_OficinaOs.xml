      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PEdCod
		
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpRegGUID.SetEmpty()
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	&LogErpRegCod1 = trim(Str(PedCod))
	&LogErpRegTip = TrnMode.Update
	if &LogErpTabIsLog = true
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVeiPla', trim(toformattedString(PedVeiPla)), trim(toformattedString(&PedVeiPla)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVeiKm', trim(toformattedString(PedVeiKm)), trim(toformattedString(&PedVeiKm)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedObsInf', trim(toformattedString(PedObsInf)), trim(toformattedString(&PedObsInf)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedEqpNom', trim(toformattedString(PedEqpNom)), trim(toformattedString(&PedEqpNom)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedEqpMar', trim(toformattedString(PedEqpMar)), trim(toformattedString(&PedEqpMar)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedEqpSer', trim(toformattedString(PedEqpSer)), trim(toformattedString(&PedEqpSer)), &LogErpRegGUID )	
		
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedEqpObs', trim(toformattedString(PedEqpObs)), trim(toformattedString(&PedEqpObs)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedObsGer', trim(toformattedString(PedObsGer)), trim(toformattedString(&PedObsGer)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedObsEst', trim(toformattedString(PedObsEst)), trim(toformattedString(&PedObsEst)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedObsFin', trim(toformattedString(PedObsFin)), trim(toformattedString(&PedObsFin)), &LogErpRegGUID )	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedObsNfe', trim(toformattedString(PedObsNfe)), trim(toformattedString(&PedObsNfe)), &LogErpRegGUID )	
	Endif
	//GRAVA LOG
	
	PedVeiPla = &PedVeiPla
	PedVeiKm = &PedVeiKm
	
	PedObsInf = &PedObsInf
	PedEqpNom = &PedEqpNom
	PedEqpMar = &PedEqpMar
	PedEqpSer = &PedEqpSer
	PedEqpObs = &PedEqpObs
	
	PedObsGer = &PedObsGer
	PedObsEst = &PedObsEst
	PedObsFin = &PedObsFin
	PedObsNfe = &PedObsNfe
	
	
	Exit
EndFor

Commit
]]></Source>
