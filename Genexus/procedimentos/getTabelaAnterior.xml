      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&valorRetornadoMoeda = 0
For each Order EmpCod,TabCod,ProCod,TabAltCod
	Where EmpCod = &EmpCod
	Where TabCod = &CtlTabAnt
	Where ProCod = &ProCod
	Where TabAltCod = TabUltAlt
	
	Do Case
		CAse &ComparativoTabColCod = 5
			&valorRetornadoMoeda = TabPrc5
			
		CAse &ComparativoTabColCod = 4
			&valorRetornadoMoeda = TabPrc4
			
		CAse &ComparativoTabColCod = 3
			&valorRetornadoMoeda = TabPrc3
			
		CAse &ComparativoTabColCod = 2
			&valorRetornadoMoeda = TabPrc2
			
		CAse &ComparativoTabColCod = 1
			&valorRetornadoMoeda = TabPrc1
	EndCAse

EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
