      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//CARREGA COMPROVANTES.
For each ORder EmpCod, FilCod, PedCod, PedItmCod, PedProPagItm
	Where EmpCod = &EmpCod
	Where FilCod = &FIlCOd
	Where PedCod = &PedCod
	Where PedProPagItm = &PedProPagItm
	Where not PedProPagAdi.IsEmpty() and not PedProPagAdi.IsNull()
	&SdtDividirContaDuplicatas.FromXml(PedProPagAdi)
EndFor


MT 0
MB 0


For each ORder EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FIlCOd
	Where PedCod = &PedCod
	
	&FilRaz = FilRaz
	print TituloFilial
//	&DataHoraLancamento = 'DATA: ' + trim(DtoC(MovDtaPgt)) + ' - ' + trim(ToformattedString(MovHor)) + ' DOC: ' + trim(MovDoc)
	
EndFor


print tituloPRodutos
//IMPRIME PRODUTOS
For each ORder EmpCod, FilCod, PedCod, PedItmCod, PedProPagItm
	Where EmpCod = &EmpCod
	Where FilCod = &FIlCOd
	Where PedCod = &PedCod
	Where PedProPagItm = &PedProPagItm
	Where PedProPagVlr > 0
	
	//PRODUTOS
	&ProGraRef = '--'
	&ProGraNom = 'PRODUTO NAO LOCALIZADO'
	&PedVlrItm = PedProPagVlr
	
	&ProGraRef = ProGraRef + PedProNom
	&ProGraNom = ProGraRef + PedProNom
	
	print itemProduto
EndFor

print Branco

print tituloPagamntos
//IMPRIME PAGAMENTOS
for &SdtDividirContaDuplicatasItem in &SdtDividirContaDuplicatas
	For Each ORder EmpCod, FilCod, PedCod, PedTmpDupCod
		Where EmpCod = &SdtDividirContaDuplicatasItem.EmpCod
		Where FilCod = &SdtDividirContaDuplicatasItem.FIlCOd
		Where PedTmpCreCod = &SdtDividirContaDuplicatasItem.CreCod
		
		&grid2CreDupNro = PedTmpDupNro
		&grid2CreVlrDup = PedTmpDupVlr
//		&grid2CreDtaVct = PedTmpDupVct
//		&grid2CreCod = PedTmpCreCod
//		&grid2PlanCod = PedTmpPlanCod
//		&grid2IsPaga = PedTmpSts
//		&grid2CreCbrCod = PedTmpDupCbrCod
		
		print itemPagamento
	EndFor
EndFor

]]></Source>
