      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProRef.SetEmpty()

For Each Order EmpCod, FilCod, NfeCod, NfeProCod, NfeProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	Where NfeItmCod = &NfeItmCod when not &NfeItmCod.IsEmpty()
	Where NfeProCod = &PrOCod when Not &PrOCod.IsEmpty()
	Where NfeProGraCod = &ProGraCod when Not &ProGracod.IsEmpty()
	
	&ProRef = NfeProGraRef
	Exit
When None
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &PrOCod
		Where ProGraCod = &ProGraCod
		&ProRef = ProGraRef
		Exit
	EndFor

EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
