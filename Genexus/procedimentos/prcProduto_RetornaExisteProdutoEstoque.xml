      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//parm(in:&EmpCod, in:&ProCod, out:&Mensagem);
&Mensagem.SetEmpty()
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod <> ProEstProCod
	Where ProEstProCod = &ProCod
	&Mensagem = 'Produto é alimentado Estoque Através de outro(s) Produto(s).'
	Exit
EndFor
]]></Source>
