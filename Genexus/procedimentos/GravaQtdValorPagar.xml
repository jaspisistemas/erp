      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AuxPedItmPagVlrSel = &PedItmPagVlrSel
&auxPedItmPagQtdSel = &PedItmPagQtdSel
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where (PedItmCodRef = &PedItmCod and PedItmCodRef <> PedItmCod and not PedItmCodRef.IsEmpty() and not PedItmCodRef.IsNull()) or (PedItmCod = &PedItmCod) when &PedItmCod <> 0
	
	&PedVlrItm = round(PedVlrItm + (PedVlrItm * PedProTaxAcrGerItm* 0.01) - (PedVlrItm * PedProTaxDscGerItm * 0.01),2)
	&PedQtd = PedQtd	
	Do case
		Case &PedItmPagIsSel = true and &PedItmCod > 0
			PedItmPagIsSel  = true
			Do Case
				CAse &AuxPedItmPagVlrSel > (&PedVlrItm - PedItmPagVlrTot) or &auxPedItmPagQtdSel > (&PedQtd - PedItmPagQtdTot)  //maior que valor ou qtde disponínel ai iguala ao do pedido, menos oque ja foi pago
					PedItmPagVlrSel = &PedVlrItm - PedItmPagVlrTot
					&AuxPedItmPagVlrSel -= &PedVlrItm - PedItmPagVlrTot
					
					PedItmPagQtdSel = &PedQtd - PedItmPagQtdTot
					&auxPedItmPagQtdSel -= &PedQtd - PedItmPagQtdTot
					
				Case &AuxPedItmPagVlrSel > 0 and &auxPedItmPagQtdSel > 0
					PedItmPagQtdSel = &auxPedItmPagQtdSel
					PedItmPagVlrSel = &AuxPedItmPagVlrSel
					&AuxPedItmPagVlrSel = 0
					&auxPedItmPagQtdSel = 0
					
				Case &PedItmPagVlrSel = 0 or &PedItmPagQtdSel = 0
					PedItmPagVlrSel = &PedVlrItm - PedItmPagVlrTot
					PedItmPagQtdSel = &PedQtd - PedItmPagQtdTot
				Otherwise
					//PedItmPagVlrSel = &PedVlrItm - PedItmPagVlrTot
					PedItmPagVlrSel = 0
			EndCase
	
			
		Case &PedItmPagIsSel = true
			PedItmPagIsSel  = true
			PedItmPagVlrSel = &PedVlrItm - PedItmPagVlrTot
			PedItmPagQtdSel = &PedQtd - PedItmPagQtdTot
			
		Otherwise
			PedItmPagIsSel = false
			PedItmPagVlrSel = 0
			PedItmPagQtdSel = 0
	EndCAse
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
