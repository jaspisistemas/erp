      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, TrsCod
	Where EmpCod = &EmpCod
	Where TrsCod = &trsCod
	
	if TrsSts = Status_Pedido.ABERTO
		TrsSts = Status_Pedido.CANCELADO
	Else
		TrsSts = Status_Pedido.ABERTO
	Endif

	Exit
EndFor

Commit
]]></Source>
