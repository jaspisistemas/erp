      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Mensagem.SetEmpty()
For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	
	if PesSenfun.IsEmpty() or PesSenfun.IsNull() or (PesSenfun = &AtualSenha or &OqueFazer = 'SETAR')
		PesSenfun = &PesSenfun
		PesSenCon = &PesSenCon
		if not &PesSenChvCmp.IsEmpty()
			PesSenChvCmp = &PesSenChvCmp
		Endif
	
	Else
		&Mensagem = 'Senha Atual não corresponde, Mudança de senha não permitida!'
	Endif

	PesDtaHorAlt = now()
	Exit
EndFor
Commit
]]></Source>
