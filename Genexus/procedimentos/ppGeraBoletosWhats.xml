      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&EmpCod = 8
&FilCod = 1
&dataVencimento = now()
&dataVencimento = &dataVencimento.AddDays(3)

&max = &pmax

if &max = 0
	&max = 10
	msg('max não informado. Gerando: ' + trim(str(&max)), status)
endif

for &index = 1 to &max
	new
		UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &FilCod,&CreCod)
		EmpCod          = &EmpCod
		FilCod          = &FilCod
		CreCod          = &CreCod
		CreSts          = Status_Duplicata.ATIVO
		CreDupNro       = '123456' + &index.ToString().Trim()
		CreDtaVct       = &dataVencimento
		CreVlrDup       = &index + 1168.60
		CreVlrSdo       = CreVlrDup
		CreCbrCod       = 2 // BRADESCO
		CreCliCod       = 15466 // FINAN ITALO
		CreRecPag       = ReceberPagar.Receber
		CreFrpPgtoCod   = 1 //TipoDuplicata.DUPLICATA
		CreStsFilaEnv   = Status_FilaWhats.PENDENTE
		CreAbvDup       = 'AVULSA'
		CreOriDup       = OrigemDuplicata.LancamentoManual
		CrePlanCod      = 65 
	endnew
	msg(&index.ToString().Trim() + ' de ' + &max.ToString().Trim() + '. ' + trim(str(&CreCod)), status)
endfor

commit
]]></Source>
