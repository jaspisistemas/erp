      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


&IsNaoAchouPagamentos = false

For Each Order EmpCod, MovCod //MOVIMENTO
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	
	For Each Order EmpCod, MovCod, MovCreFilCod, MovCreCod, MovCrePagCod, MovItmCod //ITEM MOVIMENTO
		Where MovItmCod = &MovItmCod
		Where MovCreCod = &MovCreCod
		Where MovCreFilCod = &MovCreFilCod
		Where MovCrePagCod = &MovCrePagCod
		Where MovItmSts <> Status_Caixa.Cancelado or MovItmSts.IsNull()
		
		AtualizaSaldoConta.Call(TrnMode.Delete, EmpCod, MovCtaBanCod, MovDtaCon, MovCreDeb, MovItmVlr, MovDtaCon, MovItmVlr, MovCreDeb)
		
		MovItmSts = Status_Caixa.Cancelado //REMOVE O ITEM DO PAGAMENTO DO CAIXA
		
		commit
	EndFor

	Exit
When none
	&IsNaoAchouPagamentos = true
EndFor


Commit




For Each Order EmpCod, MovCod //MOVIMENTO
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	
	
	if MovVlr.IsEmpty()
		MovSts = Status_Caixa.Cancelado //DELETA MOVIMENTO CASO SEJA 0
	Endif
EndFor

Commit
]]></Source>
