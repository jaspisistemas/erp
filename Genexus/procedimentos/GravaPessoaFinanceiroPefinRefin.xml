      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each ORder EmpCod, PesCod, PesDebTip
	Where EmpCod = &EmpCod
	Where PesCod = &PEsCod
	Where PesDebTip = &PEsDebTip
	&Quantidade += PesDebQtd
	&Moeda += PesDebVlr
EndFor


For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PEsCod
	
	Do Case
		Case &PEsDebTip = TIpoDivida.PEFIN
			PesPefQtd = &Quantidade
			PesPefVlr = &Moeda
			
		Case &PEsDebTip = TIpoDivida.REFIN
			PesRefQtd = &Quantidade
			PesRefVlr = &Moeda
			
		Case &PEsDebTip = TipoDivida.PROTESTOS
			PesPrtQtd = &Quantidade
			PesPrtVlr = &Moeda
			
			if &Quantidade > 0
				PesProAtv = Status_SimNao.Sim
			Else
				PesProAtv = Status_SimNao.Nao
			Endif
			
	EndCase
	
	Exit
EndFor

Commit
	
]]></Source>
