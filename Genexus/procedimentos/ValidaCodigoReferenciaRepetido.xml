      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&outProGraRef = &ProGraRef.Trim()

&RepetidoReferenciaMensagem = ''

For Each Order EmpCod, ProGraBar
	Where EmpCod = &EmpCod
	Where (ProGraRef = &outProGraRef or (ProGraBar = &outProGraRef)) and (ProSts <> STatus_Produto.EXCLUIDO)
	Where ProCod <> &ProCod or ProGraCod <> &ProGraCod
	
	if ProGraRef = &outProGraRef
	    &RepetidoReferenciaMensagem = 'Código já utilizado como Cód.Ref no produto : '+ trim(ProNomGra)
	Else //(ProBar = &outProGraRef)
		&RepetidoReferenciaMensagem = 'Código já utilizado como Cód.Barras no produto : '+ trim(ProNomGra)
	Endif

    exit
EndFor

if &RepetidoReferenciaMensagem.IsEmpty()
	For Each Order EmpCod, ProCod, ProGraCod, ProBarRef
		Where EmpCod = &EmpCod
		Where ProBarRef = &outProGraRef and ProSts <> STatus_Produto.EXCLUIDO
		Where ProCod <> &ProCod or ProGraCod <> &ProGraCod
		
		&RepetidoReferenciaMensagem = 'Código utilizado no produto : ' + trim(ProGraRef) + ' - ' + trim(ProNomGra)
		
	    exit
	EndFor
Endif
]]></Source>
