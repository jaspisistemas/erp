      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AuxForCnpj = RetornaSoNumeros.Udp(&ForCNPJ)
&ForProCod = &tmpForProRef
&AuxtmpNfeProBar = RetornaSoNumeros.Udp(&tmpNfeProBar)

if not &AuxtmpNfeProBar.IsEmpty()//Codigo Barras Fornecedor
	&ForProCod = &tmpForProRef.Trim() + '-'+&AuxtmpNfeProBar.Trim()
Endif

	
//if not &AuxForCnpj.IsEmpty() //ESTUDAR A UNIFICACAO DAS TABELAS JDF
	//TABELA FORNECEDORPRODUTO
	For Each Order EmpCod, ForCNPJ, ForProCod
		Where EmpCod = &EmpCod
		Where ForCNPJ = &AuxForCnpj
		Where ForProCod = &ForProCod
		ForErpProRef = &ForErpProRef
		Exit
	When None
		New
			EmpCod = &EmpCod
			ForCNPJ = &AuxForCnpj
			ForProCod = &ForProCod
			ForErpProRef = &ForErpProRef
		EndNEw
	EndFor
	
	Commit
//Endif

	if &tmpEmixCod <> 0 and &ProCod <> 0
		//TABELA ProdutoFornecedor
		For Each Order EmpCod, ForCNPJ, ForProCod
			Where EmpCod = &EmpCod
			Where ProForCod = &tmpEmixCod
			Where ProCod = &ProCod
			ProForProCod = &tmpForProRef
			ProForProBar = &AuxtmpNfeProBar
			Exit
		When None
			New
				EmpCod = &EmpCod
				ProForCod = &tmpEmixCod
				ProCod = &ProCod
				ProForProCod = &tmpForProRef
				ProForProBar = &AuxtmpNfeProBar
			EndNEw
		EndFor
		
		Commit
	Endif

	
	Notatemporaria_AtualizaProdutosCodBarras.Call(&EmpCod, &NomeTemporario, &AuxForCnpj, &tmpForProRef, &tmpNfeProBar, &ForErpProRef, &tmpCFOP,&tmpEntCFOP, &tmpProQtdCmpEmb)
//EndIF
]]></Source>
