      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[if &LogGUID.IsEmpty()
	&LogGUID = GUID.newGuid()
endif

for each
	order EmpCod, LogDataHora, LogCod
	where EmpCod  = &EmpCod
	where LogGUID = &LogGUID
	&LogCod = LogCod
	
	new
		LogItemCod      = (max(LogItemCod, EmpCod = &EmpCod and LogCod = &LogCod ) + 1)
		LogItemConteudo = &LogItemConteudo
		LogItemTela     = &LogItemTela
		LogItemNome     = &LogItemNome
		LogItemDataHora = DateTime.Now()
	endnew
	
	exit
when none
	for each
		order EmpCod, (LogCod)
		where EmpCod = &EmpCod
		&LogCod = (LogCod + 1)
		
		new
			EmpCod      = &EmpCod
			LogCod      = &LogCod
			LogGUID     = &LogGUID
			LogNom      = ''
			LogDataHora = DateTime.Now()
			
			new
				LogItemCod      = 1
				LogItemConteudo = &LogItemConteudo
				LogItemTela     = &LogItemTela
				LogItemNome     = &LogItemNome
				LogItemDataHora = DateTime.Now()
			endnew
		endnew
		exit
	when none
		new
			EmpCod      = &EmpCod
			LogCod      = 1
			LogGUID     = &LogGUID
			LogNom      = ''
			LogDataHora = DateTime.Now()
			
			new
				LogItemCod      = 1
				LogItemConteudo = &LogItemConteudo
				LogItemTela     = &LogItemTela
				LogItemNome     = &LogItemNome
				LogItemDataHora = DateTime.Now()
			endnew
		endnew
	endfor
endfor

commit
]]></Source>
