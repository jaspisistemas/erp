      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PedItmCmpLot.SetEmpty()
&sdtProdutoLote.Clear()
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedItmCod = &PedItmCod
	
	&PedItmCmpLot = PedItmCmpLot
	
	For Each Order EmpCod, FilCod, PedCod, PedItmCod, PedProEstLotCod
		&sdtProdutoLoteItem = new()
		&sdtProdutoLoteItem.PedProEstLotCod = PedProEstLotCod
		&sdtProdutoLoteItem.PedProEstLotVct = PedProEstLotVct
		&sdtProdutoLoteItem.PedProEstLotFab = PedProEstLotFab
		&sdtProdutoLoteItem.PedProEstLotQtd = PedProEstLotQtd
		&sdtProdutoLoteItem.PedProEstLotPur = PedProEstLotPur 
		&sdtProdutoLoteItem.PedProEstLotPms = PedProEstLotPms
		&sdtProdutoLoteItem.PedProEstLotRen = PedProEstLotRen
		&sdtProdutoLoteItem.PedProEstLotPen = PedProEstLotPen
		&sdtProdutoLoteItem.PedProEstLotGer = PedProEstLotGer
		&sdtProdutoLote.Add(&sdtProdutoLoteItem)
	EndFor
	
	Exit
EndFor

]]></Source>
