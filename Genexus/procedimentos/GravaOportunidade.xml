      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsEncontrou = False
For each Order EmpCod,OptCod
	Where EmpCod = 1
	Where OptCnpj = &WizardData.Dadospessoais.OptCnpj
	
	&IsEncontrou = True
	Exit
EndFor

UltimoCodigoEmpresa.Call(domParCod.OPORTUNIDADE, 1, 0, &OptCod)

New 
	EmpCod = 1
	OptCod = &OptCod
	OptRaz = &WizardData.Dadospessoais.OptRaz
	OptCnpj = &WizardData.Dadospessoais.OptCnpj
	Optcep = &WizardData.Dadospessoais.Optcep
	OptLog = &WizardData.Dadospessoais.OptLog
	OptNro = &WizardData.Dadospessoais.OptNro
	OptBai = &WizardData.Dadospessoais.OptBai
	OptCpl = &WizardData.Dadospessoais.OptCpl
	OptCidCod = &WizardData.Dadospessoais.OptCidCod
	OptSerCod = &WizardData.DadosHospedagem.OptSerCod
	OptMail = &WizardData.Dadospessoais.OptMail
	OptFone = &WizardData.Dadospessoais.OptFone
	OptCon = &WizardData.Dadospessoais.OptCon
	OptDom = &WizardData.DadosHospedagem.OptDom
	OptVctDom = &WizardData.DadosHospedagem.OptVctDom
	OptEnvEml = True
	If &IsEncontrou = true
		OptSts = Status_oPortunidade.Repetido
	Else
		OptSts = Status_oPortunidade.Novo
	EndIf
EndNew

Commit
]]></Source>
