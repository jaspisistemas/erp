      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[ 
&CreDtaEms = serverdate()

RetornaVencimentosParcela.Call(&EmpCod, 0, &PedPraParNom, ReceberPagar.Receber, &CreDtaEms, &sdtVencimentos, &Mensagem)
&sdtVencimentos.Sort('CreDtaVct')

For &sdtVencimentosItem in &sdtVencimentos
	&Dias = &sdtVencimentosItem.CreDtaVct - &CreDtaEms
	&Count += 1
	&ParcelasDias.Add(&Dias, &Count)
EndFor

if &Count <> &qtdPArcelas
	&ParcelasDias.Clear()
	&Dias = 0
	 
	For &MaisParcelas = 1 to &qtdPArcelas
		&Dias += 30
		&ParcelasDias.Add(&Dias, &MaisParcelas)
	EndFor
Endif

&PedPraParNom = ''
for &ParcelasDiasItem in &ParcelasDias
	if not &ParcelasDiasItem.IsEmpty()
		&PedPraParNom = trim(&PedPraParNom) + ' ' + padL(trim(Str(&ParcelasDiasItem)), 3, '0')
	Endif
EndFor

if &PedPraParNom.IsEmpty()
	&PedPraParNom = '001'
Endif

]]></Source>
