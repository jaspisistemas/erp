      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProVlrUltCmp = 0
&PedClICod = 0

For Each Order EmpCod, ProCod, PedSts, (PedDtaFat), (PedHorFat)
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where PedSts = Status_Pedido.FECHADO
	Where LctTip = TipoLancamento.EntradaMercadoria
	Where LctAtuFor = Status_SimNao.Sim
	
	&PedClICod = PedCliCod
	
	if PedVlrCus > 0
		&PedVlrCus = PedVlrCus
		if ProDedIpi = true
			&PedVlrCus = &PedVlrCus - PedItmVlrIpi
		Endif
		if ProDedIcms = true
			&PedVlrCus = &PedVlrCus - PedItmVlrIcm
		Endif
		
		do case 
			CAse PedProEmbQtd > 0 and PedVlrCus > 0
				&ProVlrUltCmp = round(&PedVlrCus / PedProEmbQtd, 5)
			CAse PedProEmbQtd < 0
				&ProVlrUltCmp = &PedVlrCus * (PedProEmbQtd*-1)
			Otherwise
				&ProVlrUltCmp = &PedVlrCus
		EndCase
	Else
		&PedVlrCus = PedVlrUntDsc
		if ProDedIpi = true
			&PedVlrCus = &PedVlrCus - PedItmVlrIpi
		Endif
		if ProDedIcms = true
			&PedVlrCus = &PedVlrCus - PedItmVlrIcm
		Endif
		
		do case 
			CAse PedProEmbQtd > 0 and &PedVlrCus > 0
				&ProVlrUltCmp = round(&PedVlrCus / PedProEmbQtd, 5)
			CAse PedProEmbQtd < 0
				&ProVlrUltCmp = &PedVlrCus * (PedProEmbQtd*-1)
			Otherwise
				&ProVlrUltCmp = &PedVlrCus
		EndCase
	EndiF

	if &ProVlrUltCmp < 0
		&ProVlrUltCmp = 0
	Endif
	
	Exit
EndFor
]]></Source>
