        <Source><![CDATA[


if &OqueFazer = 'DEL' or &OqueFazer = 'TUDO'
	//------------------  ------------------  ------------------
	&File.Source = !"AuditPlusReorgParms.json"
	if not &File.Exists()
		&OutputFile.Source = !"AuditPlusReorgParms.json"
		&OutputFile.WriteAllText("")
		&OutputFile.Close()
	Endif
	&File.Close()
	
	//DELETANDO SCRIPTS
	&NomeArquivo  = 'aauditplusreorg.exe'
	&Exe = shell(&NomeArquivo, 1)
Endif

if &OqueFazer = 'CRIA' or &OqueFazer = 'TUDO'
	&File.Source = !"AuditPlusReorgParms.json"
	if &File.Exists()
		&File.Delete()
	Endif
	&File.Close()
	
	//CRIANDO SCRIPTS
	&NomeArquivo  = 'aauditplusreorg.exe'
	&Exe = shell(&NomeArquivo, 1)
	//------------------  ------------------  ------------------
Endif

]]></Source>
