      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If not &NomePaizao.IsEmpty()
	&PlanNomCmp = trim(&NomePaizao) + ' | ' + trim(&PlanNom)
Else
	&PlanNomCmp = trim(&PlanNom)
EndIF

if &PlanNomCmp.Length() > 100
	&PlanNomCmp = Substr(&PlanNomCmp,1, 97) + '...'
EndIf

&auxPlanHie = &PlanHie.Trim() + '.'

PlanoCategoriaPaiHierarquico.call(&EmpCod, &PlanCod, &PlanHie, &NewPlanHie, &AuxPlanNomCmp, &PlanPaiCod, &planPaiHie, &IsErroHierarquia, &AntPlanCatTip)
PlanHiePadL_Formata.Call(&PlanHie, &PlanHiePadL)
RetornaCodigoComVirgula.Call(&PlanHie, &PlanHieVirg)

//GRAVAR LOG
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, 'PLANOCONTAS')
if &LogErpTabIsLog = true //SE GRAVAR CARREGA ARQUIVOS
	&LogErpRegTip = iif(&PlanCod = 0, Trnmode.Insert, Trnmode.Update)
	prcCarregaLog_PlanoContas.Call(&EmpCod, &PlanCod, &SdtLogAtributos)
Endif

For Each Order EmpCod, PlanCod
	Where EmpCod = &EmpCod
	Where PlanCod = &PlanCod
	PlanNom = &PlanNom
	PlanNomCmp = &PlanNomCmp
	PlanAnaSin = &PlanAnaSin
	PlanCatTip = &PlanCatTip
	PlanUtiTra = &PlanUtiTra
	PlanGrpDre = &PlanGrpDre
	PlanHiePadL = &PlanHiePadL
	PlanHieVirg = &PlanHieVirg
	
	PlanCodNomVir = &PlanHie.Trim() + ' ' + &PlanNomCmp.trim() + ' ' + &PlanHieVirg
	
	PlanPaiCod = &PlanPaiCod
	PlanPaiHie = &planPaiHie
	&NewPlanCod = &PlanCod
	Exit
When none
	UltimoCodigoEmpresa.Call(domParCod.PLANO, &EmpCod, 0, &NewPlanCod)
	New
		EmpCod = &EmpCod
		PlanCod = &NewPlanCod
		PlanNom = &PlanNom
		PlanNomCmp = &PlanNomCmp
		PlanHie = &PlanHie
		PlanAnaSin = &PlanAnaSin
		PlanCatTip = &PlanCatTip
		PlanUtiTra = &PlanUtiTra
		PlanGrpDre = &PlanGrpDre
		PlanHiePadL = &PlanHiePadL
		PlanHieVirg = &PlanHieVirg
		
		PlanCodNomVir = &PlanHie.Trim() + ' ' + &PlanNomCmp.trim() + ' ' + &PlanHieVirg
		
		PlanPaiCod = &PlanPaiCod
		PlanPaiHie = &planPaiHie
		
	EndNew
EndFor

Commit

if &LogErpTabIsLog = true //GRAVA LOG
	prcGravaLog_PlanoContas.Call(&LogErpRegTip, &EmpCod, &FilCod, &NewPlanCod, &Pgmname, &wwpContextUserName, &SdtLogAtributos)
Endif

if &PlanCod > 0
	GravaPlanoContasSubGrupos.Call(&EmpCod, &PlanHie, &PlanCod)
Endif


]]></Source>
