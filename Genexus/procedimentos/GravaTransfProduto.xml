      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&newTrsItmCod = &TrsItmCod
if &newTrsItmCod <> 0
	For Each Order EmpCod, TrsCod, TrsItmCod
		Where EmpCod = &EmpCod
		Where TrsCod = &TrsCod
		Where TrsItmCod = &newTrsItmCod
		TrsEntProCod = &TrsEntProCod
		TrsEntPedQtd = &TrsEntPedQtd
		TrsEntProGraCod = &TrsEntProGraCod
		
		TrsSaiProCod = &TrsSaiProCod
		TrsSaiPedQtd = &TrsSaiPedQtd
		TrsSaiProGraCod = &TrsSaiProGraCod
		Exit
	when None
		do 'insert'
	EndFor
Else
	do 'insert'
EndIF

commit

sub 'insert'
	For Each Order EmpCod, TrsCod, (TrsItmCod)
		Where EmpCod = &EmpCod
		Where TrsCod = &TrsCod
		&newTrsItmCod = TrsItmCod
		Exit
	EndFor
	&newTrsItmCod += 1
	
	new
		EmpCod = &EmpCod
		TrsCod = &TrsCod
		TrsItmCod = &newTrsItmCod
		TrsEntProCod = &TrsEntProCod
		TrsEntPedQtd = &TrsEntPedQtd
		TrsEntProGraCod = &TrsEntProGraCod
		
		TrsSaiProCod = &TrsSaiProCod
		TrsSaiPedQtd = &TrsSaiPedQtd
		TrsSaiProGraCod = &TrsSaiProGraCod
	EndNew
Endsub

	
]]></Source>
