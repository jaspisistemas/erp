      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order tmpNFeCod
	Where tmpNFeCod = &tmpNfeCod
	
	
	tmpNroNfp = &tmpNroNfp
	tmpEmsNfp = &tmpEmsNfp
	tmpNfeEspVol = &tmpNfeEspVol
	tmpNfePesLiq = &tmpNfePesLiq
	tmpNfePesBrt = &tmpNfePesBrt
	tmpNfeQtdVol = &tmpNfeQtdVol
	tmpNfeEnvEml = &tmpNfeEnvEml
	tmpNfeChvRef = &tmpNfeChvRef
	tmpExpCidCod = &tmpExpCidCod
	tmpManNfeDadAdi = &ObservacoesManuais
	
	If &tmpNfePesLiq <> 0 and &tmpNfePesBrt = 0
		tmpNfePesBrt = &tmpNfePesLiq
	EndIF

	tmpMrkCnpj = &tmpMrkCnpj
	tmpMrkUser = &tmpMrkUser

	Exit
EndFor


commit
]]></Source>
