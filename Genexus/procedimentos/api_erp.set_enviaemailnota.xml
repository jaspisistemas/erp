      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtEmail.FromJson(&dadosEntradaEmail)
 
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
	   
	If not &sdtEmail.Eml1.IsEmpty() and (&sdtEmail.Eml1.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEmail.Eml1
		&listaSdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtEmail.Eml2.IsEmpty()  and (&sdtEmail.Eml2.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEmail.Eml2
		&listaSdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtEmail.Eml3.IsEmpty()  and (&sdtEmail.Eml3.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEmail.Eml3
		&listaSdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtEmail.Eml4.IsEmpty() and (&sdtEmail.Eml4.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEmail.Eml4
		&listaSdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	
	If not &sdtEmail.Eml5.IsEmpty() and (&sdtEmail.Eml5.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEmail.Eml5
		&listaSdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	If not &sdtEmail.Eml6.IsEmpty()  and (&sdtEmail.Eml6.IsMatch(&pattern) = true)
		&ItemSdtEmail = new()
		&ItemSdtEmail.EmlUrl = &sdtEmail.Eml6
		&listaSdtEmail.Add(&ItemSdtEmail)
	EndIf
	
	Do case
		case &listaSdtEmail.Count = 0
			&sdtRetornowbs.Obs = 'Nenhum Endereço de E-Mail foi informado!'
			&sdtRetornowbs.Sts = 'E001'
			
		case &sdtEmail.Ass.IsEmpty()
			&sdtRetornowbs.Obs = 'Você deve informar o assunto!'
			&sdtRetornowbs.Sts = 'E002'
			
		otherwise
			GravaEnvioEmail.Call( &wwpContext.EmpCod, &FilCod, &NfeCod, 0, TipoContaEmail.Email_Faturamento, &sdtEmail.Ass, TipoSolicitacao.Envia_NFE, &wwpContext.PesCod, &Mensagem, &listaSdtEmail, &sdtBoleto)
			&sdtRetornowbs.Obs = 'sucesso'
			&sdtRetornowbs.Sts = 'J200'
	EndCase
	
Endif
]]></Source>
