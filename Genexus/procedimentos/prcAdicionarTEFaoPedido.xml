<Object parentGuid="a3be529e-3058-45c0-82b5-ecf9e218a1af" user="WIN-JEAN\jean.fae" versionDate="2024-06-20T11:05:28.0000000Z" lastUpdate="2024-06-19T18:09:16.0000000Z" checksum="0ebc2f4c8c7d29df04e1686b6320a358" fullyQualifiedName="prcAdicionarTEFaoPedido" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="77018a8d-0443-4e05-a973-d514d68533a7" name="prcAdicionarTEFaoPedido" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Adicionar TEFao Pedido" parent="PedPrc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, TefCod
	Where EmpCod = &EmpCod
	Where TefFilCod = &FilCod
	Where TefPedCod = &PedCod
	
	&TefCod = TefCod
	
	For Each Order EmpCod, TefCod, (TefItmID)
		Where TefItmSts = 'S'
		
		&TEfCrePar = TefCrePar
		&TefBanCarCod = TefBanCarCod
		&TefDtaSol = TefDtaSol
		
		if TefCreDebVou = 'C' //CREDITO
			&CarForPag = 2
		Else
			&CarForPag = 1			
		Endif
		
		do 'ForPedido'
		
	EndFor
EndFor	
	
	
Sub 'ForPedido'	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon107_PlanoRecCartao, &TCon107_PlanoRecCartao)
	&PlanCodTCon107_PlanoRecCartao = RetornaCodigoPlanoContas.Udp(&EmpCod, &TCon107_PlanoRecCartao) //PLanContasDebito
	
	For Each Order EmpCod, FilCod, PedCod, PedFrpItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedFrpIsTefCod = &TefCod
		
		if &CarForPag = 1 //DEBITO
			&sdtPgto  = new()
			&sdtPgto.FrpPgtoCod = 5
			&sdtPgto.FrpPgtoTip = TipoDuplicata.CARTAOD
			&sdtPgto.CreDtaEms = &TefDtaSol
			
			&sdtPgto.CreDtaVct = &TefDtaSol
			&sdtPgto.creVlrDup = PedTipVlr
			&sdtPgto.PlanCod = &PlanCodTCon107_PlanoRecCartao
			
			//Cartao
			&sdtPgto.CreCarArqc = &CreCarArqc
			&sdtPgto.CreCarNroAut = PedFrpAutCrt
			&sdtPgto.CarParQtd = &TEfCrePar
			&sdtPgto.BanCarCod = &TefBanCarCod
			&sdtPgto.CarForPag = &CarForPag
			
			do 'GravaFormaSelecionada'
			
		Else
			&sdtPgto  = new()
			&sdtPgto.FrpPgtoCod = 8
			&sdtPgto.FrpPgtoTip = TipoDuplicata.CARTAOC
			&sdtPgto.CreDtaEms = &TefDtaSol
			
			&sdtPgto.CreDtaVct = &TefDtaSol
			&sdtPgto.creVlrDup = PedTipVlr
			&sdtPgto.PlanCod = &PlanCodTCon107_PlanoRecCartao
			
			//Cartao
			&sdtPgto.CreCarArqc = &CreCarArqc
			&sdtPgto.CreCarNroAut = PedFrpAutCrt
			&sdtPgto.CarParQtd = &TEfCrePar
			&sdtPgto.BanCarCod = &TefBanCarCod
			&sdtPgto.CarForPag = &CarForPag
			
			do 'GravaFormaSelecionada'
		Endif
	
		Exit
	EndFor	
EndSub

Sub 'GravaFormaSelecionada'

	MontaDuplicatasPedidoVenda01_JDF.Call('ADD', &EmpCod, &FilCod, &PedCod, &sdtPgto)

EndSub
]]></Source>
