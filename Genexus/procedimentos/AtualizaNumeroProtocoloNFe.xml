      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAtualizaEstoque = false

Do CAse
	Case &OqueFazer = 'AUTORIZA_NFE' //AUTORIZA NFE
	
		RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon162_EmailEnviarNotas, &TCon162_EmailEnviarNotas)
		
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeSts <> &NfeSts
			
			NfeStsSyncServ = 'N'
			
			NfeAutNumLot = &NfeAutNumLot
			NfeAutDatHorRec = &NfeAutDatHorRec
			NfeAutNumRec = &NfeAutNumRec
			NfeAutNumPro = &NfeAutNumPro
			NfeAutDigVal = &NfeAutDigVal
			NfeAutSts = &NfeAutSts
			NfeAutMsg = &NfeAutMsg
			
			&IsAtualizaEstoque = true
			NfeSts = &NfeSts
			
			if NfeEnvEml = NfeEnvEml.Pendente
				&SdtEmail.Clear()
				RetornaEmailFaturamento.Call(EmpCod, NfeCliCod, &SdtEmail)
				If not NfeCliEml.IsEmpty() and not NfeCliEml.IsNull()
					&IsJahTem = false
					For &itemSdtEmail in &SdtEmail
						If &itemSdtEmail.EmlUrl = NfeCliEml
							&IsJahTem = true
							Exit
						EndIF	
					EndFor
					
					If &IsJahTem = false
						&itemSdtEmail = new()
						&itemSdtEmail.EmlUrl = NfeCliEml
						&SdtEmail.Add(&itemSdtEmail)
					EndIf
				EndIF
			
				if NfeTipFrt <> TipoFrete.SemFrete
					RetornaEmailFaturamento.Call(EmpCod, NfeTraCod, &SdtEmail)
					If not NfeTraEml.IsEmpty() and not NfeTraEml.IsNull()
						&IsJahTem = false
						For &itemSdtEmail in &SdtEmail
							If &itemSdtEmail.EmlUrl = NfeTraEml
								&IsJahTem = true
								Exit
							EndIF	
						EndFor
						
						If &IsJahTem = false
							&itemSdtEmail = new()
							&itemSdtEmail.EmlUrl = NfeTraEml
							&SdtEmail.Add(&itemSdtEmail)
						EndIf	
					EndIF
				Endif
				
				if not &TCon162_EmailEnviarNotas.IsEmpty()
					&IsJahTem = false
					For &itemSdtEmail in &SdtEmail
						If &itemSdtEmail.EmlUrl = &TCon162_EmailEnviarNotas
							&IsJahTem = true
							Exit
						EndIF	
					EndFor
					
					If &IsJahTem = false
						&itemSdtEmail = new()
						&itemSdtEmail.EmlUrl = &TCon162_EmailEnviarNotas
						&SdtEmail.Add(&itemSdtEmail)
					EndIf
				EndIf
			
				If &SdtEmail.Count > 0
					
					prcRetornaPlacaPedido.call(EmpCod, NfeFilCod, NfePedCod, &PedVeiPla)

					&NfeNum = NfeNum
					if &PedVeiPla.Length() = 8
						&EmlAss = format('Nota Fiscal %1 da %2, Placa: %3', trim(toformattedString(&NfeNum)), trim(FilFan), &PedVeiPla)
					Else
						&EmlAss = 'Nota Fiscal ' + trim(toformattedString(&NfeNum)) + ' da ' + trim(FilFan)
					Endif
									
					GravaEnvioEmail.Call(EmpCod, FilCod, NfeCod, 0, TipoContaEmail.Email_Faturamento, &EmlAss, TipoSolicitacao.Envia_NFE, &PesCod, '', &SdtEmail, &sdtBoleto)
				EndIF
				
				NfeEnvEml = NfeEnvEml.Enviado
			EndIF
			
			Exit
		EndFor
	
		If &IsAtualizaEstoque = true //SAIDA ESTOQUE
			AtualizaEstoqueFiscal.Call(&EmpCod, &FilCod, &NfeCod, &NfeSts)
		EndIf
		
	Case &OqueFazer = 'CANCELA_NFE' //CANCELA NFE
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeSts <> &NfeSts
			
			NfeStsSyncServ = 'N'
			
			NfeAutDatHorRec = &NfeAutDatHorRec
			NfeAutNumPro = &NfeAutNumPro
			NfeAutSts = &NfeAutSts
			NfeAutMsg = &NfeAutMsg
			NfeSts = &NfeSts
			
			&IsAtualizaEstoque = true //SAIDA ESTOQUE
			
			If NfeEnvEml = NfeEnvEml.Pendente
				&SdtEmail.Clear()
				If NfeCliEml.IsEmpty() or NfeCliEml.IsNull()
					RetornaEmailFaturamento.Call(EmpCod, NfeCliCod, &SdtEmail)
				Else
					&itemSdtEmail = new()
					&itemSdtEmail.EmlUrl = NfeCliEml
					&SdtEmail.Add(&itemSdtEmail)
				EndIF
				
				If NfeTraEml.IsEmpty() or NfeTraEml.IsNull()
					RetornaEmailFaturamento.Call(EmpCod, NfeTraCod, &SdtEmail)
				Else
					&itemSdtEmail = new()
					&itemSdtEmail.EmlUrl = NfeTraEml
					&SdtEmail.Add(&itemSdtEmail)
				EndIf
				
				If &SdtEmail.Count > 0
					&NfeNum = NfeNum
					&EmlAss = 'Cancelamento Nota Fiscal ' + trim(toformattedString(&NfeNum)) + ' da ' + trim(FilRaz)
					GravaEnvioEmail.Call(EmpCod, FilCod, NfeCod, 0, TipoContaEmail.Email_Faturamento, &EmlAss, TipoSolicitacao.Envia_NFE, &PesCod, '', &SdtEmail, &sdtBoleto)
				EndIF
				
				NfeEnvEml = NfeEnvEml.Enviado
			EndIF
			
			If NfeCanDup = True //Cancela duplicatas ao cancelar NF-e
				
				CancelaStatusFinanceiroPedido.Call(EmpCod, FilCod, NfePedCod, 'Duplicata Cancelada via cancelamento da NF-e', &PesCod)
				NfeCanDup = False
			EndIf			
			Exit
		EndFor
	
		If &IsAtualizaEstoque = true //SAIDA ESTOQUE
			AtualizaEstoqueFiscal.Call(&EmpCod, &FilCod, &NfeCod, &NfeSts)
		Endif		
	
	Case &OqueFazer = 'INUTILIZA_NFE' //INUTILIZA NFE
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeSts <> &NfeSts
			
			NfeStsSyncServ = 'N'
			
			NfeAutDatHorRec = &NfeAutDatHorRec
			NfeAutNumPro = &NfeAutNumPro
			NfeAutSts = &NfeAutSts
			NfeAutMsg = &NfeAutMsg
			NfeSts = &NfeSts
						
			Exit
		EndFor
EndCase

commit
]]></Source>
