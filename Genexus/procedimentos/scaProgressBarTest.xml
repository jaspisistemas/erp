        <Source><![CDATA[&total = 20


/***** EXAMPLE **********/
/*
For &i = 0 to &total
	&completed = ((&i * 100) / &total)
	for each
		where ProgressId = &processId
		ProgressValue = &completed.ToString()
	when none
		new
			ProgressId = &processId
			ProgressValue = &completed.ToString()
		endnew
	endfor
	commit
	&var = Sleep(1)
Endfor
*/

]]></Source>
