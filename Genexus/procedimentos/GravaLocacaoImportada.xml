      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If not &EstLoc.Trim().IsEmpty()// Se não for vazia atualiza ou cria
	For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		EstLoc = &EstLoc
		
		Exit
	When None
		IniciaEstoque.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod)
		
		For Each Estoque Order EmpCod, FilCod, ProCod, ProGraCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			EstLoc = &EstLoc
			Exit
		EndFor
		
	EndFor
EndIf


commit

If not &EstLocExt.Trim().IsEmpty()
	For Each Order EmpCod, FilCod, ProCod, ProGraCod, EstLocExt
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		Where EstLocExt = &EstLocExt
		//se achou Locação igual não faz nd
	When none
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
			EstLocExt = &EstLocExt
		EndNEw
	EndFor
EndIf

Commit
]]></Source>
