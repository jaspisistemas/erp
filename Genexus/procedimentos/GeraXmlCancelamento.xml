<Object parentGuid="3da02edb-1b7b-48ed-b7ed-63881a7bef92" user="WIN-JEAN\jean.fae" versionDate="2024-04-05T14:57:49.0000000Z" lastUpdate="2024-04-02T14:26:50.0000000Z" checksum="99dd4af365a405cca11ffd7886feef27" fullyQualifiedName="GeraXmlCancelamento" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="e9b9828b-9029-455e-8674-a56b7bd85a3b" name="GeraXmlCancelamento" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Gera Xml Cancelamento" parent="NfePrc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&hoje = serverdate()    
&VersaoNF = '1.00'
		
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	&NfeChv = NfeChv
	&NfeAutNumPro = NfeAutNumPro
	&FilCpj = retornaSoNumeros.Udp(FilCpj)
	&cUF = retornaCodigoSiglaEstado.Udp(0, FilCidUfeCod)
	
	&FilFusHor = FilFusHor
	
	If &tmpNfeEnvEml = true
		NfeEnvEml = NfeEnvEml.Pendente
	EndIF

	If &tmpCancelarDuplicatas = true
		NfeCanDup = true
	Else
		NfeCanDup = false
	EndIf
    Exit
EndFor

commit

GravaSolicitacao.Call(&EmpCod, &FilCod, &NfeCod, 0, TipoSolicitacao.Cancelar_NFE, &PesCod, &SolCod)

//CANCELA ARQUIVOS RETORNOS
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim()+ trim(&NfeChv)+'-env-canc.err'    
&File.Source = &Nome_retorno_erro
If &File.Exists()
    &File.Delete()
EndIf

&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim()+ trim(&NfeChv)+'-env-canc.xml'
&File.source = &Nome_retorno_correto
IF &File.Exists()
    &File.Delete()
EndIf

//GRAVA ARQUIVO CANCELAMENTO .XML
&ano = str(YEAR(&hoje))
&mes = str(MONTH(&hoje))
&dia = str(DAY(&hoje))
//&hojeHora = servernow()
&NfeHorEms = ServerTime()
//&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hojeHora))),2, '0') + ':00'

&id = 'ID110111' + &NfeChv + '01' //“ID” + tpEvento + chave da NF-e + nSeqEvento

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + trim(&NfeChv) + '-env-canc.xml'

&ArqNota.Open(&Nome_enviar) //ABRE DOC xml
&ArqNota.WriteStartDocument('UTF-8') //START DOC xml

&ArqNota.WriteStartElement('envEvento')
&ArqNota.WriteAttribute('versao',&VersaoNF) //Versão do leiaute
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')

&ArqNota.WriteElement('idLote', '01') //Identificador de controle do Lote de envio do Evento.

&ArqNota.WriteStartElement('evento') //Evento, um lote pode conter até 20 eventos
&ArqNota.WriteAttribute('versao', &VersaoNF) //Versão do leiaute do evento

&ArqNota.WriteStartElement('infEvento') //Grupo de informações do registro do Evento
&ArqNota.WriteAttribute('Id', &ID) //Identificador da TAG a ser assinada, a regra de formação do Id é: “ID” + tpEvento + chave da NF-e + nSeqEvento
&ArqNota.WriteElement('cOrgao', &cUF) //Código do órgão de recepção do Evento. Utilizar a Tabela do IBGE, utilizar 91 para identificar o Ambiente Nacional.
&ArqNota.WriteElement('tpAmb',&sdtConfiguracoesPasta.FilAmbEms) //Identificação do Ambiente: 1=Produção /2=Homologação

If &FilCpj.Length() > 11
	&ArqNota.WriteElement('CNPJ', &FilCpj) //Informar o CNPJ ou o CPF do autor do Evento
Else
	&ArqNota.WriteElement('CPF', &FilCpj) //Informar o CNPJ ou o CPF do autor do Evento
EndIf
&ArqNota.WriteElement('chNFe', &NfeChv) //Chave de Acesso da NF-e vinculada ao Evento   

&ArqNota.WriteElement('dhEvento',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' + &NfeHorEms + '-' + trim(&FilFusHor)) //Data e hora do evento no formato AAAA-MM-DDThh:mm:ssTZD 
&ArqNota.WriteElement('tpEvento', '110111') //Código do evento = 110111
&ArqNota.WriteElement('nSeqEvento','1') //Sequencial do evento para o mesmo tipo de evento. Para maioria
&ArqNota.WriteElement('verEvento', &VersaoNF) //Versão do detalhe do evento (grupo detEvento – HP17),

&ArqNota.WriteStartElement('detEvento')
&ArqNota.WriteAttribute('versao', &VersaoNF) 
&ArqNota.WriteElement('descEvento', 'Cancelamento') //Cancelamento
&ArqNota.WriteElement('nProt', &NfeAutNumPro)
&ArqNota.WriteElement('xJust', &xJust.Trim())

&ArqNota.WriteEndElement()
&ArqNota.WriteEndElement()
&ArqNota.Close()
]]></Source>
