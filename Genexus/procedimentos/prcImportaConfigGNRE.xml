      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PosicaoInicial =  StrSearchRev(&selectedURL, '.', &selectedURL.Trim().Length())
&PosicaoInicial += 1
&Extensao 		=  SubStr(&selectedURL, &PosicaoInicial, 5)


	//INICIA O PROCESSO
	&Total 			= 0
	Do 'ContaRegistros'
	
	&Count 			= 0
	&Percentual 	= 0
	&ResultadoNext 	= 0
	&ProgressIni 	= ServerNow()
	
	//ATUALIZA O PROGRESSO
	Do 'Atualiza'
	
	//INICIA A LEITURA DO ARQUIVO
	Do 'LeituraArquivo'
	
	&Percentual 	= 100
	&ProgressFin	= ServerNow()
	Do 'Atualiza'

Sub 'ContaRegistros'
	
	//ABRE ARQUIVO RECEBIDO COMO PARÂMETRO
	&ResultadoAbertura = dfrOpen(&SelectedUrl, , ';', '"', 'UTF-8')
	
	//CONTA A QUANTIDADE DE LINHAS
	Do While dfrNext() = 0
		&Total += 1
	EndDo
	
	//FECHA O ARQUIVO
	&ResultadoAbertura = dfrClose()
	Msg('Total de itens: '+ &Total.ToFormattedString())
	
EndSub

Sub 'Atualiza'
		
	For Each Order ProgressId
		Where ProgressId 	= &ProgressId
		
		ProgressValue 		= &Percentual
	  	ProgressFin 		= &ProgressFin
		ProgressIni 		= &Progressini
		  
	When none
		
		New
			ProgressId 		= &ProgressId
			ProgressValue 	= &Percentual
			ProgressLogXml 	= &Mensagem
			ProgressFin 	= &ProgressFin
			ProgressIni 	= &Progressini
		EndNew
		
	EndFor
	
	Commit	
	
EndSub

Sub 'LeituraArquivo'
	
	//ABRE ARQUIVO RECEBIDO COMO PARÂMETRO
	&ResultadoAbertura = dfrOpen(&SelectedUrl, , ';', '"', 'UTF-8')
	
	//LÊ TODAS AS LINHAS
	Do While dfrNext() = 0
		&Count += 1
		
		//ATUALIZA PROGRESS
		If Mod(&Count, 100) = 0
			&Percentual 	=  Round((&Count/&Total)*100, 0)
			If &Percentual 	>= 100
				&Percentual =  99
			EndIf
			Do 'Atualiza'
		EndIf
		
		&ResultadoAbertura = dfrGTxt(&UfeCod)
		If &Tipo <> 'REC'
			&ResultadoAbertura = dfrGNum(&GnreConRecCod)
		EndIf
	
		&ResultadoAbertura = dfrGNum(&Codigo)
		&ResultadoAbertura = dfrGTxt(&Descricao)
		
		prcGravaConfigGNRE.Call(&parmEmpCod, &parmFilCod, &UfeCod, &GnreConRecCod, &Codigo, &Descricao, &Tipo)
	EndDo
	&ResultadoAbertura = dfrClose()
EndSub
]]></Source>
