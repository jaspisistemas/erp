      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&atualizarDatas = 'N'
Do Case
	Case &PedSts = Status_Pedido.FECHADO or &PedSts = Status_Pedido.SEPARANDO //FECHAR/SEPARAR PEDIDO	
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			&LctAtuEst = LctAtuEst
			&LctAtuSal = LctAtuSal

			&LctTip = LctTip
			&LctGerFin = LctGerFin
			
			If PedDtaFat.IsEmpty() or PedDtaFat.IsNull()
				&PedDtaFat = PedDtaSep
			Else
				&PedDtaFat = PedDtaFat
			EndIF

			For Each Order EmpCod, FilCod, PedCod, PedItmCod
				&ProCod = PedProEstProCod
				If ProGraCod = 0 OR PedProEstProGraCod = 0
					ProGraCod = 1 
					PedProEstProGraCod = 1
				EndIF
				
				&PedQtd = PedQtd
				&ProGraCod = PedProEstProGraCod
				&PedVlrCus = PedVlrCus				
				
				If ProEstTip <> TipoEstoque.NAO_ATUALIZA
					do 'FechaEstoque'
				EndiF				
			EndFor
		EndFor
		
	Case &PedSts = Status_Pedido.CANCELADO //CANCELA PEDIDO				
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
						
			For Each Order EmpCod, FilCod, PedCod, PedItmCod
				If ProGraCod = 0 OR PedProEstProGraCod = 0
					ProGraCod = 1 
					PedProEstProGraCod = 1
					
					Commit
				EndIF				
				
				AtualizaEstoqueFormulas.Call(EmpCod, FilCod, PedProEstProCod, PedProEstProGraCod)
				if PedProEstProGraCod > 1
					AtualizaEstoqueFormulas.Call(EmpCod, FilCod, PedProEstProCod, 1)
				Endif
			EndFor
		EndFor
		
	Case &PedSts = Status_Pedido.ABERTO //ABRE PEDIDO
		For Each Order EmpCod, FilCod, PedCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			
			&PedDtaFat = PedDtaFat
			
			&LctAtuEst = LctAtuEst
			&LctAtuSal = LctAtuSal
			
			&LctTip = LctTip
			&LctGerFin = LctGerFin
			
			For Each Order EmpCod, FilCod, PedCod, PedItmCod
				&ProCod = PedProEstProCod
				
				If ProGraCod = 0 OR PedProEstProGraCod = 0
					ProGraCod = 1 
					PedProEstProGraCod = 1
				EndIF
				
				&PedQtd = PedQtd
				
				&ProGraCod = PedProEstProGraCod
				&PedVlrCus = PedVlrCus
				
				do 'AbreEstoque'
			EndFor
		EndFor		
		
EndCase

commit

Sub 'AbreEstoque'
	//ATUALIZA ESTOQUE
	Do CAse
		CAse &LctAtuEst = Status_EntradaSaida.Entrada //EMPRESA ENTRADA
			If &ProGraCod > 1
				AtualizaEstoqueEntradaSaida1_PDV.Call( &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod,1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '-', &atualizarDatas)
			EndIF
			AtualizaEstoqueEntradaSaida1_PDV.Call( &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod,&ProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '-', &atualizarDatas)
			
		CAse &LctAtuEst = Status_EntradaSaida.Saida //EMPRESA SAIDA
			If &ProGraCod > 1
				AtualizaEstoqueEntradaSaida1_PDV.Call( &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod,1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '+', &atualizarDatas)
			EndIF
			AtualizaEstoqueEntradaSaida1_PDV.Call( &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod,&ProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '+', &atualizarDatas)
	EndCAse
EndSub


Sub 'FechaEstoque'
	//ATUALIZA ESTOQUE
	Do CAse
		CAse &LctAtuEst = Status_EntradaSaida.Entrada //EMPRESA ENTRADA
			If &ProGraCod > 1
				Call(AtualizaEstoqueEntradaSaida1_PDV, &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, 1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '+', &atualizarDatas)
			EndIF
			Call(AtualizaEstoqueEntradaSaida1_PDV, &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, &ProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '+', &atualizarDatas)
			
		CAse &LctAtuEst = Status_EntradaSaida.Saida //EMPRESA SAIDA
			if &ProGraCod > 1
				Call(AtualizaEstoqueEntradaSaida1_PDV, &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, 1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '-', &atualizarDatas)
			EndIf
			Call(AtualizaEstoqueEntradaSaida1_PDV, &EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, &ProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '-', &atualizarDatas)
	EndCase
EndSub
]]></Source>
