      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CreSerItmCod, CreOriDup, CreSts, (CreDtaVct)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreSerItmCod = &SerItmCod
	Where CreOriDup = OrigemDuplicata.MensalidadeServico
	Where CreSts = Status_Duplicata.ATIVO
	&UltDtaVct = CreDtaVct
	exit
EndFor

	GravaUltimoVencimentoServico.Call(&EmpCod, &SerItmCod, &UltDtaVct)
]]></Source>
