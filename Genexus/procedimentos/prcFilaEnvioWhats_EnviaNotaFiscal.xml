      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&LogGUID = GUID.NewGuid()

if &RespPesCod <> 0
	&Dias = 1
	&DataLimite = &Today.AddDays(&Dias)
	do 'Init'
	
	// Pesquisa boletos próximo ao vencimento ainda não enviados, ou marcados como pendente
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		&NfeNum = NfeNum		
		&FilRaz = RetornaNomeCadFilial.Udp(EmpCod, FilCod)
		&FilArt = FilArt
		&PedVlrLiq = NfeVlrTot
	EndFor

	do 'Match'
endif

Sub 'Init'
	RetornaTemplatePadraoWhatsPorTipo(&EmpCod,TipoTemplateWhatsapp.NOTAFISCAL,&tempatePedido)
	
	do 'BuscaInformacoesResponsavel'
EndSub

// Match!
Sub 'Match'
	// tudo certo para continuar			
	if not &tempatePedido.IsEmpty()
		&txtFomatado = &tempatePedido
		do 'Mustache'
		&tempatePedido = &txtFomatado
				
		do 'New'
	endif
EndSub

Sub 'BuscaInformacoesResponsavel'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&RespPesFonNum = FilFonNum.Trim()
		&RespPesRaz = RetornaNomeCadFilial.Udp(EmpCod, FilCod)
		Exit
	EndFor

	// NOME E TELEFONE
	For each Order EmpCod,PesCod
		where EmpCod = &EmpCod
		where PesCod = &RespPesCod
		
		&RespPesRaz = PesRaz
		if &RespPesFonNum.IsEmpty()
			For Each Order EmpCod, PesCod, PesFonCod
				&RespPesFonNum = PesFonNum
				exit
			EndFor
		EndIf
	
		exit		
	EndFor
EndSub

Sub 'Mustache'
	msg('boleto : fazendo match!', status)
	mustache(&txtFomatado,'Artigo',&FilArt,&txtFomatado)
	mustache(&txtFomatado,'NomeFilial',&FilRaz,&txtFomatado)
	mustache(&txtFomatado,'NumeroPedido',trim(toformattedString(&NfeNum)),&txtFomatado)
	mustache(&txtFomatado,'ValorPedido',&PedVlrLiq.ToString().Trim(),&txtFomatado)
	mustache(&txtFomatado,'FoneContato',&RespPesFonNum,&txtFomatado)
	mustache(&txtFomatado,'NomeContato',&RespPesRaz,&txtFomatado)
EndSub

Sub 'New'
	msg('boleto : gravando', status)
	&FilaWhatsMsgOrd = 0
	New
		EmpCod                 = &EmpCod
		FilaWhatsGUID          = GUID.NewGuid()
		FilaWhatsFilCod        = &FilCod
		FilaWhatsRespPesCod    = &RespPesCod
		FilaWhatsDestPesCod    = &PedCliCod
		FilaWhatsDestPesFonCod = 0
		FilaWhatsDtaEms        = now()
		FilaWhatsDtaLim        = &DataLimite
		FilaWhatsSts           = Status_FilaWhats.PENDENTE
		FilaWhatsTip           = TipoFilaEnvioWhats.NOTAFISCAL
		FilaWaGuid			   = &WaGUID
		
		if Substr(&FilaWhatsDestPesFonNum,1,1) <> '+'
			FilaWhatsDestPesFonNum = '55' + retornasoNumeros.Udp(&FilaWhatsDestPesFonNum)
		Else	
			FilaWhatsDestPesFonNum = retornasoNumeros.Udp(&FilaWhatsDestPesFonNum)
		Endif	
		
		//NOTA FISCAL 
		&FilaWhatsMsgOrd        += 1
		New
			FilaWhatsMsgGUID         = GUID.NewGuid()
			FilaWhatsMsgTxt          = &tempatePedido
			FilaWhatsMsgOrd          = &FilaWhatsMsgOrd
			FilaWhatsMsgTip          = TipoMensagemWhats.Texto
			FilaWhatsMsgSts          = Status_FilaWhats.PENDENTE
			FilaWhatsMsgPedCod = &PedCod
		EndNew
	
		&FilaWhatsMsgOrd        += 1
		New
			FilaWhatsMsgGUID         = GUID.NewGuid()
			FilaWhatsMsgArqNom       = 'NotaFiscal_'+trim(str(&NfeNum))+'.pdf'
			FilaWhatsMsgTxt          = ''
			FilaWhatsMsgTip          = TipoMensagemWhats.Documento
			FilaWhatsMsgarqDirFis    = &URlFisico
			FilaWhatsMsgArqDirFisVir = &AuxUrlVirtual
			FilaWhatsMsgOrd          = &FilaWhatsMsgOrd
			FilaWhatsMsgSts          = Status_FilaWhats.PENDENTE
			FilaWhatsMsgPedCod 		 = 0
			FilaWhatsMsgCreCod       = 0
			FilaWhatsMsgNfeCod 		 = &NfeCod
		EndNew
	EndNew
	
	Commit
EndSub


Sub 'subException_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subException_handler','subException_handler')
	
EndSub

Sub 'subError_handler'
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'subError_handler','subError_handler')
	
EndSub

]]></Source>
