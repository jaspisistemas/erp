      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[// POPULA UM BOLETO
&sdtBoleto.Clear()
&sdtBoletoItem = new()
&sdtBoletoItem.CreEmpCod = &EmpCod
&sdtBoletoItem.CreFilCod = &FilCod
&sdtBoletoItem.CreCod    = &CreCod
&sdtBoleto.Add(&sdtBoletoItem)


// GERA O BOLETO EM SI
GerarBoleto.Call(&sdtBoleto, false, &IsErro, &ImprimeSdtBoleto)
//GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Boleto gerado: ImprimeSDTBoleto',&ImprimeSdtBoleto.ToJson())
//GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Boleto gerado: erro?',&IsErro.ToString())

If not &IsErro
	if &ImprimeSdtBoleto.Count > 0
		&sdtConfiguracoesPasta = RetornaConfiguracoesPastas.Udp(&EmpCod, &FilCod)
		&nomeUnico = GUID.NewGuid().ToString().Trim()
		
		&DirFis = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'whatsapp\'
		
		&Directory.Source = &DirFis
		if not &Directory.Exists()
			&Directory.Create()
		endif
	
		&DirFis = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'whatsapp\boletos\'
		&Directory.Source = &DirFis
		if not &Directory.Exists()
			&Directory.Create()
		endif
		
		&DirFis = &DirFis + &nomeUnico + '.pdf'
		
		RELJAS045_toFile.Call(&EmpCod, &FilCod, &ImprimeSdtBoleto, &DirFis)
		
		&File.Source = &DirFis
		If &File.Exists()
			for &ImprimeSdtBoletoItem in &ImprimeSdtBoleto
				&CreCodBar = &ImprimeSdtBoletoItem.BolLinDig
				&DirFisVir = &sdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + 'whatsapp/boletos/' + &nomeUnico + '.pdf'
				&ArqNom = 'Boleto Nº' + trim(&CreDupNro) + '.pdf'
//				GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Caminho físico',&DirFis)
//				GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'Caminho virtual',&DirFisVir)
			EndFor
		EndIf
		&File.Close()
	endIf
endif
]]></Source>
