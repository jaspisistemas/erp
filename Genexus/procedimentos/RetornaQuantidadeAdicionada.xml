      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PEdQtd.SetEmpty()
For Each Order EmpCod, FilCod, PedCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	WHere PedCod = &PedCod
	Where ProCod = &Procod
	Where ProGraCod = &ProGraCod
	Where PedItmSts.IsEmpty() or PedItmSts.IsNull()
	
	&PEdQtd += PedQtd
	
EndFor
]]></Source>
