      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,FilCod,CteCod,CtePreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteNomPreCom = &CteNomPreCom
	CteVlrPreCom = &CteVlrPreCom
	exit
When none
	do 'Pegasequencia'
	&auxCtePreCod+=1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CteCod = &CteCod
		CtePreCod = &auxCtePreCod
		CteNomPreCom = 'PARADA ADICIONAL'
		CteVlrPreCom = &CteVlrPreCom
	EndNew

EndFor

Sub 'Pegasequencia'
	&auxCtePreCod= 0
	For each Order EmpCod,FilCod,CteCod,(CtePreCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		
		&auxCtePreCod = CtePreCod
		Exit
	EndFor
EndSub

]]></Source>
