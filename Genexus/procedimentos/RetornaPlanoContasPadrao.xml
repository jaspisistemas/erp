      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PlanCodNomVir.SetEmpty()

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon027_PlanoContasFornecedor, &CfgVlr)
For Each Order EmpCod, PlanCod
	Where EmpCod = &EmpCod
	Where PlanHie = &CfgVlr
	&PedPlanCod = PlanCod
	Exit
EndFor
	
For Each Order EmpCod, FilCod, PedCliCod, (PedDtaFat)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCliCod = &PEsCod
	Where PedSts = Status_Pedido.FECHADO
	Where LctTip = TipoLancamento.EntradaMercadoria or LctTip = TipoLancamento.OrcamentoCompra
	
	if not PedPlanCod.IsEmpty() and not PedPlanCod.IsNull()
		&PedPlanCod = PedPlanCod
	Endif

	Exit
EndFor


For Each Order EmpCod, PlanCod
	Where EmpCod = &EmpCod
	Where PlanCod = &PedPlanCod
	&PlanCodNomVir = PlanCodNomVir
	Exit
EndFor
]]></Source>
