      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//VERIFICA VERSAO EXCLUSIVO APP ERP.
&IsAtualizarTabelas = false
&IsAcessoConcedido = false

&AuxDevRandonUltSync = serverNow() 
&AuxDevRandonUltSync = &AuxDevRandonUltSync.AddHours(-6)

//verifica acesso sessao
For Each Order DeviceId, DevRandon //CONEXAO
	Where DevRandon = &DevRandon
	
	if DevSts = status_AtivoInativo.ATIVO
		&IsAtualizarTabelas = DevAtu
		
		&IsAcessoConcedido = true
		&WwpContext.FromJson(DevWwpContext)		
		
		if DevRandonUltSync < &AuxDevRandonUltSync
			DevRandonUltSync = &AuxDevRandonUltSync //Atualiza ultima conexao
			
			Commit
		Endif	
		
		if DeviceId = 'UNIQUEID'
			do 'addNovoDeviceID'
		Else
			do 'updateDEVICE'
		Endif
	
	Else
		&IsAcessoConcedido = false
	Endif

EndFor

sub 'updateDEVICE'
	For Each Order DeviceId
		Where DeviceId = &DevRandon
		
		DeviceUltimaSync = &AuxDevRandonUltSync //Atualiza ultima conexao
		
		Exit
	EndFor

	commit
	
EndSub

Sub 'addNovoDeviceID'
	For Each Order DeviceId
		Where DeviceId = 'UNIQUEID'
			
		new //GRAVA DEVICE
			DeviceId= &DevRandon
			DeviceUltimaSync = &AuxDevRandonUltSync //Atualiza ultima conexao
		EndNew
	
		For Each Order DeviceId, DevRandon
			Where DevRandon = &DevRandon
			
			New //GRAVA DEVICE RANDON
				DeviceId= &DevRandon
				DevRandon= &DevRandon
			EndNew			
		EndFor
		
		For Each Order DeviceId, DevRandon, DevTabCod
			New //GRAVA DEVICE SinC
				DeviceId= &DevRandon
				DevRandon= &DevRandon
				DevTabCod = DevTabCod
			EndNew
		EndFor
		
	EndFor

	Commit
	
	For Each Order DeviceId
		Where DeviceId = 'UNIQUEID'
		
		For Each Order DeviceId, DevRandon
			Where DevRandon = &DevRandon
			delete
		EndFor
		
		For Each Order DeviceId, DevRandon, DevTabCod
			Where DevRandon = &DevRandon
			delete
		EndFor
	EndFor
	
	commit
			

EndSub


]]></Source>
