      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNFeCod
	Where tmpNfeItmCod = &tmpNfeItmCod
	
	tmpImpNfeSitCod = trim(str(&NewtmpNfeSitCod))
	if tmpImpNfeSitCod = '0' //JDF pois esta gravando 0 
		tmpImpNfeSitCod = '00'
	Endif

	tmpImpNfeBasPis = &NewNfeProBasCofins
	tmpImpCstPis = &NewNfeCstCofins
	tmpImpTaxPis = &NewNfeProTaxPIS
	tmpImpVlrPis = &NewNfeProVlrPIS
	tmpImpTaxCofins = &NewNfeProTaxCofins
	tmpImpVlrCofins = &NewNfeproVlrCofins
	
	Exit
EndFor


Commit
]]></Source>
