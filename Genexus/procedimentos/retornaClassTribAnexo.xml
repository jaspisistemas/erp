      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order AnxCod, AnxEmpCod
	Where AnxCod = &AnxCod
	Where AnxEmpCod = &EmpCod
	Where AnxEmpIsUse = true
	
	if AnxEmpCst.IsEmpty() or AnxEmpCst.IsNull() or AnxEmpClassTrib.IsEmpty() or AnxEmpClassTrib.IsNull()
		&AnxCst = AnxCst
		&AnxClassTrib = AnxClassTrib
	Else
		&AnxCst = AnxEmpCst
		&AnxClassTrib = AnxEmpClassTrib
	Endif

	Exit
EndFor
]]></Source>
