      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[



//ADICIONA AS FILIAIS
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &MatrizFilCod
	
	&FilTip = FilTip
	
	//21.826.923/0001-77
	&FilCpj = Substr(FilCpj, 1, 10) //com pontos
	
	&sdtFiliaisItem = new()
	&sdtFiliaisItem.FilCod = FilCod
	&sdtFiliaisItem.FilCpj = FilCpj	
	&sdtFiliaisItem.FilNom = FilNom
	&sdtFiliaisItem.FilTip = FilTip
	
	&sdtFiliais.Add(&sdtFiliaisItem)
	Exit	
EndFor


//ADICIONA AS FILIAIS
if &FilTip = FIlialTipo.MATRIZ or &FilTip.IsEmpty()
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCpj like '%'+&FilCpj //Localizar todos que possuem mesma base e sao FILIAIS
		Where FilTip = 'F' //FILIAL
		
		&sdtFiliaisItem = new()
		&sdtFiliaisItem.FilCod = FilCod
		&sdtFiliaisItem.FilCpj = FilCpj	
		&sdtFiliaisItem.FilNom = FilNom
		&sdtFiliaisItem.FilTip = FilTip
		
		&sdtFiliais.Add(&sdtFiliaisItem)
		
	EndFor
Endif

]]></Source>
