      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&PesMetVlrAno = 0
&PesMetVlrMes = 0

For Each Order EmpCod, PesCod, PesMetAno
	Where EmpCod = &EmpCod
	Where PesCod = &PedVenCod when not &PedVenCod.IsEmpty()
	Where PesVenIntExt = &PesVenIntExt when &PedVenCod.IsEmpty()
	Where PesDtaDem.IsEmpty() or PesDtaDem.IsNull() when &RegistradoTodos = 'S' and &PedVenCod.IsEmpty()
	Where PesMetAno = &PesMetAno
	
	&PesMetVlrAno += PesMetVlr
	
//	if PesMetMes = &PesMetMes
//		&PesMetMes = PesMetMes
//	Endif
	
EndFor

If not &PesMetVlrAno.IsEmpty()
	&PesMetVlrMes = &PesMetVlrAno / 12
	&PesMetVlrDia = &PesMetVlrAno / 365
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
