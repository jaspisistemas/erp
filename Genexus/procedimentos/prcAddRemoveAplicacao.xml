      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&AplCod = &parAplCod

Do Case
	
	CAse &OqueFazer = 'ADD' //Adiciona / Alterar
		
		For Each Order EmpCod, AplNom //GRAVA APLICACAO
			Where EmpCod = &EmPCod
			Where AplNom = &AplNom
			&AplCod = AplCod
			Exit
		When none
			UltimoCodigoEmpresa.Call(domParCod.APLICACAO, &EmpCod, 0, &AplCod)
			
			New
				EmpCod = &EmpCod
				AplCod = &AplCod
				AplNom = &AplNom
			EndNEw			
			
			Commit
		EndFor
	
		
		For Each Order EmpCod, ProCod, AplCod //GRAVA APLICACAO PRODUTO
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			Where AplCod = &AplCod
			
			ProAplOrd = &ProAplOrd
			
			Exit
		When none
			New
				EmpCod = &EmpCod
				ProCod = &ProCod
				AplCod = &AplCod
				ProAplOrd = &ProAplOrd
			EndNEw
		EndFor
	
		Commit 
		
	Case &OqueFazer = 'DEL' //DELETAR		
		For Each Order EmpCod, ProCod, AplCod
			Where EmpCod = &EmpCod
			Where ProCod = &ProCod
			Where AplCod = &AplCod
			delete
			
			Exit
		EndFor
		
		Commit		
EndCase


&ProNomApl = ''
//CONCATENA APLICACCOES
For Each Order EmpCod, ProCod, ProAplOrd, AplNom //GRAVA APLICACAO PRODUTO
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	if &ProNomApl.IsEmpty()
		&ProNomApl += AplNom.Trim()
	Else
		&ProNomApl += '; ' + AplNom.Trim()
	Endif
EndFor	

//ATUALIZACADASTRO PRODUTO
For Each Order EmpCod, ProCod //GRAVA APLICACAO PRODUTO
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	ProNomApl = &ProNomApl
	Exit
EndFor

Commit
]]></Source>
