      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProForNumCpfCpnj = retornaSoNumeros.Udp(&ParProForNumCpfCpnj)
&sdtProdutosOutrasEmpresas.Clear()

loadWWPContext.Call(&wwpContext)

for &wwpContextEmpresaAcesso in &wwpContext.EmpresaAcesso
	&EmPCodColl.Add(&wwpContextEmpresaAcesso.PesAceEmpCod) 
Endfor


RetornaProdutoReferencia.Call(&wwpContext.EmpCod, &ProForProCod, &OrigemProCod, &OrigemProGraCod, &OrigemProNom, &IsAchou, &ProReqVlr, &ProReqQtd, &ProBarqtd, &EroMensagem)

For Each Order EmpCod
	where EmpCod in &EmPCodColl
	
	&ProCod = 0
	&EmPCod = EmpCod
	
	For Each Order EmpCod, ProForCod, ProCod
		Where ProForSts = Status_AtivoInativo.ATIVO
		Where ProForNumCpfCpnj = &ProForNumCpfCpnj
		Where ProForProCod = &ProForProCod
		
		&ProCod = ProCod
		
		do 'addEstoques'
		//Exit
	When none
		prcAutoVinculoEmpresa.Call(&wwpContext.EmpCod, &OrigemProCod, &ProForProCod, &EmPCod, &ProCod)
		if &ProCod > 0
			do 'addEstoques'
		Else
			&sdtProdutosOutrasEmpresasItem = new()
			&sdtProdutosOutrasEmpresasItem.EmpCod = EmpCod
			&sdtProdutosOutrasEmpresasItem.FiLRaz = EmpRaz
			
			&sdtProdutosOutrasEmpresas.Add(&sdtProdutosOutrasEmpresasItem)
		EndIf
	
	EndFor

EndFor


Sub 'addEstoques'
	For Each Order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmPCod
		Where ProCod = &ProCod
		
		&sdtProdutosOutrasEmpresasItem = new()
		RetornaValorUnitarioProduto_Colunas.Call(EmpCod, FilTabCod, ProCod, ProGraCod, &sdtProdutosOutrasEmpresasItem.TabPrc1, &sdtProdutosOutrasEmpresasItem.TabPrc2, &sdtProdutosOutrasEmpresasItem.TabPrc3, &sdtProdutosOutrasEmpresasItem.TabPrc4, &sdtProdutosOutrasEmpresasItem.TabPrc5, &sdtProdutosOutrasEmpresasItem.TabPrc6, &sdtProdutosOutrasEmpresasItem.TabPrc7, &sdtProdutosOutrasEmpresasItem.TabPrc8, &sdtProdutosOutrasEmpresasItem.TabPrc9)
		
		&sdtProdutosOutrasEmpresasItem.EmpCod = EmpCod
		
		&sdtProdutosOutrasEmpresasItem.FilCod = FilCod
		&sdtProdutosOutrasEmpresasItem.FiLRaz = EmpRaz
		
		&sdtProdutosOutrasEmpresasItem.ProGraRef = ProGraRef
		&sdtProdutosOutrasEmpresasItem.ProNomGra = ProNomGra
		
		&sdtProdutosOutrasEmpresasItem.EstQtd = EstQtd
		&sdtProdutosOutrasEmpresasItem.EstSdo = EstSdo //Saldo
		
		//		&sdtProdutosOutrasEmpresasItem.EstSdo = EstSdo //Preco Venda
		&sdtProdutosOutrasEmpresasItem.EstLoc = EstLoc //Locacao
		
		//
		
		&sdtProdutosOutrasEmpresas.Add(&sdtProdutosOutrasEmpresasItem)
	EndFor
EndSub
]]></Source>
