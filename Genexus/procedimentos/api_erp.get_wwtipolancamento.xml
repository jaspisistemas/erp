      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)


if &IsAcessoConcedido = true //Acesso concedido
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwTipoLancamento.pA = '0'
	&wwTipoLancamento.pT = '0'
	&wwTipoLancamento.p1 = '0'
	&wwTipoLancamento.p2 = '0'
	&wwTipoLancamento.p3 = '0'
	&wwTipoLancamento.p4 = '0'
	&wwTipoLancamento.p5 = '0'
	&IsPaginaOk = false
	
	&wwTipoLancamento.sts = 'J200'
	
	for Each Order EmpCod, LctCod
		Where EmpCod = &wwpContext.EmpCod
		Where LctNom like &LctNom when not &LctNom.IsEmpty()
		Where LctAtuSal = &LctAtuSal when not &LctAtuSal.IsEmpty()
		where LctTip = &LctTip when not &LctTip.IsEmpty()
		Where (LctTip = TipoLancamento.DevolucaoCompra or LctTip = TipoLancamento.DevolucaoVenda) When (&NfeFin = NotaFinalidade.EmissaoDevolucao and not &NfeFin.IsEmpty())
		Where (LctTip <> TipoLancamento.DevolucaoCompra and LctTip <> TipoLancamento.DevolucaoVenda) When (&NfeFin <> NotaFinalidade.EmissaoDevolucao and not &NfeFin.IsEmpty())
		Where (LctTip = TipoLancamento.OrcamentoCompra or LctTip = TipoLancamento.DevolucaoVenda or LctTip = TipoLancamento.EntradaMercadoria or LctTip = TipoLancamento.MovimentacaoValores or LctTip = TipoLancamento.RemessaEntrada) When &NfeEntSai = Status_EntradaSaida.Entrada
		Where (LctTip = TipoLancamento.OrcamentoVenda or LctTip = TipoLancamento.DevolucaoCompra or LctTip = TipoLancamento.SaidaMercadoria or LctTip = TipoLancamento.AmostraGratis or LctTip = TipoLancamento.OutrasSaidas or LctTip = TipoLancamento.RemessaSaida or LctTip = TipoLancamento.MovimentacaoValores) When &NfeEntSai = Status_EntradaSaida.Saida
		
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwTipoLancamento.Operacoes.Clear()
					&wwTipoLancamento.qtd = 0
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				&wwTipoLancamento.qtd += 1
				
				&wwTipoLancamentoItem = new()
				&wwTipoLancamentoItem.LctCod = LctCod
				&wwTipoLancamentoItem.LctNom = LctNom
				&wwTipoLancamentoItem.LctNfeIndPres = iif(LctNfeIndPres.IsEmpty() or LctNfeIndPres.IsNull(), 'X', LctNfeIndPres)
				&wwTipoLancamento.Operacoes.Add(&wwTipoLancamentoItem)
			Endif
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
	EndFor
	
	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwTipoLancamento.pA = trim(str(&Pagina))
		&wwTipoLancamento.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwTipoLancamento.p1, &wwTipoLancamento.p2, &wwTipoLancamento.p3, &wwTipoLancamento.p4, &wwTipoLancamento.p5)
		
	Endif
	
EndIf

]]></Source>
