      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CteCarQtd = 0
For each Order EmpCod ,FilCod,CteCod,CteCarUnd
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	Where CteCarUnd = UnidadeMedidaCte.KG
	Where CteCarTip = 'PESO BRUTO'
	&CteCarQtd = CteCarQtd
	exit
When none
	For each Order EmpCod ,FilCod,CteCod,CteCarUnd
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteCarUnd = UnidadeMedidaCte.KG
		Where  CteCarTip = 'PESO LIQUIDO'
		&CteCarQtd = CteCarQtd
		exit
	EndFor
EndFor
]]></Source>
