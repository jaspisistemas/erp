      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtBandeirasAdquirencias.Clear()

For Each ORder EmpCod, BanCarCod, BanItemNom
	Where EmpCod = &EmpCod
	wHERE BanCarCod = &BanCarCod
	Where BanItemCredDeb = &BanItemCredDeb
	&sdtBandeirasAdquirenciasItem = new()
	&sdtBandeirasAdquirenciasItem.BanItemNom = BanItemNom
	&sdtBandeirasAdquirencias.Add(&sdtBandeirasAdquirenciasItem)
EndFor
]]></Source>
