      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//DELETA ORDENS NAO GERADAS MENOR QUE DIA ATUAL
For Each Order EmpCod, FilCod, OrdCod //Deleta pedidos selecionados
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdSts = Status_Producao.Aguardando
	
	For Each Order EmpCod, FilCod, OrdCod, OrdPedItmCod //DELETA PEDIDOS
		delete
	EndFor

	For Each Order EmpCod, FilCod, OrdCod, OrdMatItmCod //DELETA MATERIA PRIMA
		delete
	EndFor

	For Each Order EmpCod, FilCod, OrdCod, OrdItmCod //DELETA MATERIA PRIMA
		delete
	EndFor

	if OrdDta < serverdate()
		delete
	EndIf
EndFor

commit
]]></Source>
