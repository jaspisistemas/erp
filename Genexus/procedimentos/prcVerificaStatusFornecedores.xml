      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, CotComCod, CotComForCod		
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	
	&CotComProForCod = CotComForCod
	&IsTudoCerto = true
	do 'testaprodutos'
	If &IsTudoCerto = true
			CotComForSts = StatusCotacaoFornecedor.FINALIZADA
	Endif
	
EndFor

Commit


For Each Order EmpCod, CotComCod		
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	
	&IsTudoCerto = true 
	For Each Order EmpCod, CotComCod, CotComForCod
		Where CotComForSts.IsEmpty() or CotComForSts.IsNull() or (CotComForSts = StatusCotacaoFornecedor.LIBERADO or CotComForSts = StatusCotacaoFornecedor.BLOQUEADO)
		&IsTudoCerto = false
		Exit
	EndFor
	if &IsTudoCerto = true or &OqueFazer = 'F'
		CotComSts = StatusCotacao.Finalizada
	Endif
	
EndFor

Commit


//Grava MenorFornecedor Preco
For Each Order EmpCod, CotComCod, CotComItmCod
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	
	&CotComProForCod = 0
	&CotComProForVlr = 0
	&IsEmpate = false
	For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
		Where CotComProForSts = StatusProdutoCotado.COTADO
		
		Do Case
			Case CotComProForVlrFin < &CotComProForVlr or &CotComProForVlr.IsEmpty()
				&CotComProForVlr = CotComProForVlrFin
				&CotComProForCod = CotComProForCod
				&IsEmpate = false
			CAse CotComProForVlrFin = &CotComProForVlr
				&IsEmpate = true
		EndCase
	EndFor
	
	if &IsEmpate = false
		CotComProMenForCod = &CotComProForCod
	Else
		CotComProMenForCod = -999
	Endif
EndFor

commit


Sub 'testaprodutos'
	
	For Each Order EmpCod, CotComCod, CotComItmCod, CotComProForCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		Where CotComProForCod = &CotComProForCod
		Where CotComProForSts.IsEmpty() or CotComProForSts.IsNull() or CotComProForSts = StatusProdutoCotado.PENDENTE

		&IsTudoCerto = false
		
		Exit
	EndFor
EndSub
]]></Source>
