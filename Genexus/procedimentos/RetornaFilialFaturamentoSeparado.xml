      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &PedFatFilCod 
	&FilRaz = FilRaz
	&FiLCidNom = FilCidNom.Trim() 
	&FilCidUfeCod = trim(FilCidUfeCod)
	&FilLog = trim(FilLog) + ', ' + trim(FilNro) 
	&FilBai = trim(FilBai)
	&FilCpl = trim(FilCpl)
	&FilCidNom = trim(FilCidNom) 
	&FilCidUfeCod =  trim(FilCidUfeCod) 
	&FilCep =  trim(FilCep)
	
	If not FilCpj.IsEmpty()
		&FilCpj = trim(FilCpj) 
	EndIF

	if not FilInsEst.IsEmpty() and FilInsEst <> 'ISENTO'
		&FilInsEst =trim(FilInsEst)
	EndIF	
	
	If not FilFonNum.IsEmpty()
		&FilFonNum = trim(FilFonNum)
	EndiF

	if Not FilEml.IsEmpty()
		&EMAIL = trim(FilEml)
	EndiF
	
	if FilImg_LogRel.IsEmpty()
		&FilImg146_50.FromImage(FilialSemImagem)
	Else
		&FilImg146_50 = FilImg_LogRel
	EndIF
	
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
