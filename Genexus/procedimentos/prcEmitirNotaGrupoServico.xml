Sub 'getProduto'
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &PadGrupProCod
		Where ProGraCod = &PadGrupProGraCod
		
		&AuxNfeProNom  =''
		if ProNomNF.IsEmpty() or ProNomNF.IsNull()
			&AuxNfeProNom = ProNomGra
		Else
			&AuxNfeProNom = ProNomNF
			IF ProGraCod > 1
				&AuxNfeProNom += ' | ' +trim(ProGraNom)
			Endif
		Endif
		
		&NfeEmbUnd = ProEmbUnd
		&NfeProDadAdi = ProDetNfe
		
		&NfsTribNac = ProTribNac
		&NfsNbs = NcmCod
		
		&NfsCnaeSer = trim(str(NcmCod))
		&NfeNcmCest = trim(Str(ProNcmCest))
		&ProCatCod = ProCatCod
		&ProOriTriCod = ProOriTriCod
		
		Exit
	EndFor
EndSub


sub 'GetCliente'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PadGrupPesCod
		
		&NfeCliEnd = PesEntLog
		&NfeCliEndNro = PesEntNro
		&NfeCliBai = PesEntBai
		&NfeCliCep = PesEntCep		
		&NfeCliCpl = PesEntCpl
		&NfeCliCidCod = PesEntCidCod
		&NfeCliCidUF = PesEntUfeCod		
		&NfeCliCnpj = PesCnpj
		&NfsCliInsMun = PesInsMun
		
		&NfsCliCidIbge = PesEntCidIbge
		&NfsCliCidNom = PesEntCidNom
		If PesTip = TipoPessoa.JURIDICA
			&AuxNfeCliIns = PesInsEst
		Else
			&AuxNfeCliIns = PesCadPro
		EndIF
	
		&NfeCliSuf = PesSuf		

		&NfeCliEntCEP = PesEntCep
		&NfeCliEntBai = PesEntBai
		
		&NfeCliEntCidCod = PesEntCidCod
		&NfeCliEntCmp = PesEntCpl
		&NfeCliEntLog = PesEntLog
		&NfeCliEntLogNro = PesEntNro
		
		&PedCliCidUfeCod = PesEntUfeCod
		&PedCliGruImpCod = PesGruImpCod
		
		if PesRazNf.IsEmpty() or PesRazNf.IsNull()
			&NfeCliRaz = PesRaz
		Else
			&NfeCliRaz = PesRazNf
		Endif
		
		&NfeCliFon = PesPrmFon
		&NfeCliTipPes = PesTip
		&NfeCliCpf = PesCpf	
		
		For Each Order EmpCod, PesCod, PesEmlCod
			Where PesEmlFat = true
			&NfeCliEml = PesEml
			Exit
		When none
			&NfeCliEml = ''
		EndFor
		
		Exit
	EndFor
EndSub
