&Hoje = serverdate()
&Dia = &hoje.day()
&Mes = &Hoje.Month()
&Ano = &Hoje.Year()

//&MesNota = &Mes
//&AnoNota = &Ano

&DataPeriodoNota = &Hoje
&DataPeriodoNota = &Hoje.AddMonths(-1)
&MesNota = &DataPeriodoNota.Month()
&AnoNota = &DataPeriodoNota.Year()

//LOCALIZAR CLIENTES PARA EMITIR, ANTES DO VENCIMENTO.
For Each Order EmpCod, PadGrupCod, padGrupItmCod
	Where EmpCod = &EmpCod
	Where PadGrupIsSel = true
	Where PadGrupNfeNfs = 'NS' //NOTA SERVICO
	Where PadGrupNfeVlr > 0
	Where PadGrupDia = &Dia
	
	do 'limpaVariaveis'
	&DestinoNfsCod = 0
	&FilCod = PadGrupFilCod
	
	&PadGrupPesCod = PadGrupNfePesCod
	do 'getCliente'	
	
	//ACHAMOS o CLIENTE, AGORA LOCALIZAR A DUPLICATA
	&NfsDtaEms = yMDtoD(&Ano, &Mes, PadGrupDia)
	retornaExisteNfeEmitida.Call(EmpCod, PadGrupNfePesCod, &NfsDtaEms, PadGrupNfeVlr, &IsExiste)
	If &IsExiste = false
		
		//GRAVA CAPA
		&WizardData.Capa.NfsIntIs = false
		&WizardData.Capa.NfsIntCliCod = 0
		&WizardData.Capa.NfsIntRaz = ''
		&WizardData.Capa.NfsIntFonNum = ''
		&WizardData.Capa.NfsIntCNPJ = ''
		&WizardData.Capa.NfsIntCidCod = 0
		&WizardData.Capa.NfsIntEml = ''
		&WizardData.Capa.NfsCliCod = &PadGrupPesCod
		&WizardData.Capa.NfsCliRaz = &NfeCliRaz
		&WizardData.Capa.NfsCliFonNum = &NfeCliFon
		&WizardData.Capa.NfsCliTipPes = &NfeCliTipPes
		&WizardData.Capa.NfsCliCep = &NfeCliEntCEP
		&WizardData.Capa.NfsCliLog = &NfeCliEntLog
		&WizardData.Capa.NfsCliNro = &NfeCliEntLogNro
		&WizardData.Capa.NfsCliBai = &NfeCliEntBai
		
		&WizardData.Capa.NfsCliCidCod = &NfeCliEntCidCod
		&WizardData.Capa.NfsCliCidIbge = &NfsCliCidIbge
		&WizardData.Capa.NfsCliCidNom = &NfsCliCidNom
		&WizardData.Capa.NfsCliCidUfCod = &NfeCliCidUF
		&WizardData.Capa.NfsCliCpl = &NfeCliEntCmp
		&WizardData.Capa.NfsCliEml = &NfeCliEml
		&WizardData.Capa.NfsCliCnpj = &NfeCliCnpj
		&WizardData.Capa.NfsCliInsEst = &AuxNfeCliIns
		&WizardData.Capa.NfsCliInsMun = &NfsCliInsMun
		&WizardData.Capa.NfsCliCPF = &NfeCliCpf
		&WizardData.Capa.NfsFilCod = &FilCod
		&WizardData.Capa.NfsDtaEms = serverDate()
		&WizardData.Capa.NfsHorEms = ServerTime()
		&WizardData.Capa.NfsProTer = Nota_proPriaTerceira.PROPRIA
		&WizardData.Capa.NfsNum = 0
		&WizardData.Capa.EmpCod = EmpCod
		&WizardData.Capa.NfsCod = 0
		&WizardData.Capa.NfsSer = ''
		&WizardData.Capa.NfsPedFilCod = 0
		&WizardData.Capa.NfsPedCod = 0	
		&WizardData.Capa.NfsLctCod = PadGrupLctCod
				
		&WizardData.Capa.nfsPrsCidCod = &NfeCliEntCidCod
		&WizardData.Capa.NfsTipEmi = TipoEmitenteNFSe.Prestador
	
		&WizardData.Capa.NfsTipNF = 'S'
		&NfsTipNF = 'S'
	
		prcGravaCApaNFSE.Call(EmpCod, &DestinoNfsCod, &WizardData)	
		
		&PadGrupProCod = PadGrupProCod
		&PadGrupProGraCod = PadGrupProGraCod
		do 'GetProduto'
		
		//GRAVA DADOS NFSE		
		
		&WizardData.DadosNFSE.ProCod = PadGrupProCod
		&WizardData.DadosNFSE.ProGraCod = PadGrupProGraCod
		
		if &NfsTipNF = 'S'
			&WizardData.DadosNFSE.NfsTribNac = &NfsTribNac 
			&WizardData.DadosNFSE.NfsNbs = &NfsNbs 
		Else
			do 'GetCNAE'
			&WizardData.DadosNFSE.CnaeDesc = &CnaeDesc
			&WizardData.DadosNFSE.CnaeItmDesc = &CnaeItmDesc
			&WizardData.DadosNFSE.CnaeItmTax = &CnaeItmTax
			&WizardData.DadosNFSE.NfsCnaeSer = &NfsCnaeSer
			&WizardData.DadosNFSE.NfsCNAE = &NfsCNAE
		Endif
	
		&NfsDisSer = &AuxNfeProNom +' '+ PadGrupCpl.Trim()		
			
		&MesAno = padL(trim(str(&MesNota)), 2, '0') + '/' + trim(str(&AnoNota))
		&NfsDisSer = &NfsDisSer.Replace('[-MM/AAAA]', &MesAno)
	
		&MesAno = padL(trim(str(&Mes)), 2, '0') + '/' + trim(str(&Ano))
		&NfsDisSer = &NfsDisSer.Replace('[MM/AAAA]', &MesAno)
		
		if not PadGrupNfePesCpl.IsEmpty() and not PadGrupNfePesCpl.IsNull()
			&NfsDisSer += ' ' + PadGrupNfePesCpl.Trim()
		Endif
		&NfsDisSer = &NfsDisSer.Trim()
		
		&WizardData.DadosNFSE.NfsItmValTot = PadGrupNfeVlr
		&WizardData.DadosNFSE.NfsDisSer = &NfsDisSer			
		prcGravaDadosNFSe.Call(&EmpCod, &DestinoNfsCod, &WizardData)
		
		if &NfsTipNF <> 'S'
			//GRAVA PRODUTO NFSE
			&WizardData.Itens.NfsItmProCod = &PadGrupProCod
			&WizardData.Itens.NfsItmProGraCod = &PadGrupProGraCod
			&WizardData.Itens.NfsItmValTot = PadGrupNfeVlr
			//	&WizardData.Itens.NfsItmEmbUnd = NfsItmEmbUnd
			&WizardData.Itens.NfsItmValUnt = PadGrupNfeVlr
			&WizardData.Itens.NfsItmQtd = 1
			&WizardData.Itens.NfsItmProNom = &AuxNfeProNom
			
			&WizardData.Itens.ProRef = &ProRef
			&WizardData.Itens.NfsItmCod = 0
			
			prcGravaItemNFSe.Call(&EmpCod, &DestinoNfsCod, &WizardData)
		Endif
	
		//GRAVA SOLICITACAO
		GeraXmlNFSe.Call(EmpCod, &FilCod, &DestinoNfsCod, 'S', -1, &SolCod)
	Endif
EndFor
	

Sub 'GetCNAE'
	
	For Each ORder EmpCod, CnaeCod, CnaeItmCod
		Where EmpCod = &EmpCod
//		Where CnaeCod = &NfsCNAE
		Where CnaeFilCod = &FilCod
		Where CnaeItmCod = &NfsCnaeSer
		Where CnaeSts = status_AtivoInativo.ATIVO
		
		&NfsCNAE = CnaeCod
		&CnaeDesc = CnaeDesc
		If CnaeSts <> status_AtivoInativo.ATIVO
			&CnaeItmDesc =  'INATIVO '
		EndIf
		&CnaeItmDesc +=  CnaeItmDesc
		&CnaeItmTax = CnaeItmTax
		
		Exit
	EndFor
EndSUb

Sub 'limpaVariaveis'
	&DestinoNfsCod = 0
	&NfeCliRaz.SetEmpty()
	&NfeCliFon.SetEmpty()
	&NfeCliTipPes.SetEmpty()
	&NfeCliEntCEP.SetEmpty()
	&NfeCliEntLog.SetEmpty()
	&NfeCliEntLogNro.SetEmpty()
	&NfeCliEntBai.SetEmpty()

	&NfeCliEntCidCod.SetEmpty()
	&NfsCliCidIbge.SetEmpty()
	&NfsCliCidNom.SetEmpty()
	&NfeCliCidUF.SetEmpty()
	&NfeCliEntCmp.SetEmpty()
	&NfeCliEml.SetEmpty()
	&NfeCliCnpj.SetEmpty()
	&AuxNfeCliIns.SetEmpty()
	&NfsCliInsMun.SetEmpty()
	&NfeCliCpf.SetEmpty()
	&FilCod.SetEmpty()
EndSub

