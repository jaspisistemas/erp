      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SdtVencimentos = &inSdtVencimentos

prcCarregaLog_PedidoVencimentos.Call(&EmpCod, &FIlCod, &PedCod, &SdtLogAtributosLevel)

For Each Order EmpCod, FilCod, PedCod, PedVctCod
	Where EmpCod = &EmpCod
	Where FilCod = &FIlCod
	Where PedCod = &PedCod
	Delete
EndFor

&SdtVencimentos.Sort('CreDtaVct')
&PedVctCod = 0
For &sdtVencimentosItem in &SdtVencimentos
	&PedVctCod += 1
	new
		EmpCod = &EmpCod
		FilCod = &FIlCod
		PedCod = &PedCod
		PedVctCod = &PedVctCod
		PedVctDta = &sdtVencimentosItem.CreDtaVct
	EndNew

EndFor

Commit

prcGravaLog_PedidoVencimentos.Call(&EmpCod, &FIlCod, &PedCod, &Pgmname, &wwpContextUserName, &SdtLogAtributosLevel)
]]></Source>
