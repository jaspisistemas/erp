      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&EstQtd = 0
//&EstPrd = 0
//&EstSdo = 0
//&EstCom = 0
//&EstVen = 0
//&EstSug = 0
//&EstQtdFis = 0
For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGraCod > 1
	Where ProGraCod > 0
	
//	&EstQtdFis += EstQtdFis
	&EstQtd += EstQtd
//	&EstPrd += EstPrd
//	&EstSdo += EstSdo
//	
//	&EstCom += EstCom
//	&EstVen += EstVen
//	&EstSug += EstSug
	&EstLoc = EstLoc
When none
	iniciaEstoque.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod)
EndFor
]]></Source>
