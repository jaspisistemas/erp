//Sub 'GravaAgendador'
	For Each ORder EmpCod, AgdExeFilCod, AgdCod
		Where EmpCod = &EmpCod 
		Where AgdExeFilCod = &FilCod
		Where AgdTip = TipoAgendamento.EnviarXmlEscritorio
		Exit
	When none
		UltimoCodigoEmpresa.Call(domParCod.AGENDADOR, &EmpCod, 0, &AgdCod)
		new
			EmpCod = &EmpCod
			AgdCod = &AgdCod
			AgdExeFilCod = &FilCod
			AgdSts = &AgdSts
			AgdTip = TipoAgendamento.EnviarXmlEscritorio
			AgdUltDta = &AgdUltDta
			AgdUltHor = &AgdUltHor
			AgdFiltro = &AgdFiltro
		EndNEw
	
		Commit
	Endfor	
//EndSub
]]></Source>
