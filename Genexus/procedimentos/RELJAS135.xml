      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//TICKET -IMPRESSAO RECIBO CARTAO - WWDUPLICATASCARTAO
MB 0
MT 0
&Titulo = 'RECIBO CARTÃO'
Do 'Filial'
Do 'loadCartao'
Print Cabecalho
Print CabPagamento
Print Assinatura

//######################### SUBS ######################\\

Sub 'loadCartao'
	For each order EmpCod,FilCod,CreCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where CreCod = &CreCod
		where CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC //'5'
		where CreRecPag = ReceberPagar.Receber //'R'
		where CreSts <> Status_Duplicata.CANCELADA //'C'
		&CreSts = CreSts
		&CreDtaVct = CreDtaVct
		&CreDtaEms = CreDtaEms
		&CreVlrDup = CreVlrDup
		&CreCarBanNom = CreCarBanNom.ToUpper()
		&CreCarCreDeb = CreCarCreDeb
		&CreCliCodRaz = CreCliCodRaz //perde mto espaço com o cód cliente - apesar disso CreCliRaz não funciona
		&CpfCnpj = Iif(CreCliTip = 'J',CreCliCnpj,CreCliCpf)
		if &CreCarBanNom.IsEmpty()
			&CreditoDebito = ''
			if &CreCarCreDeb = 1
				&CreCarBanNom = 'NÃO INFORMADO (DÉBITO)'
			else
				&CreCarBanNom = 'NÃO INFORMADO (CRÉDITO)'
			EndIf
		else
			if &CreCarCreDeb = 1
				&CreditoDebito = ' DÉBITO'
			else //0 = Crédito
				&CreditoDebito = ' CRÉDITO'
			EndIf
		EndIf
		exit
	EndFor
EndSub

Sub 'Filial' //copy
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		&FilRaz = FilRaz
		if not FilFan.IsNull() and not FilFan.IsEmpty()
			&FilRaz = FilFan
		Endif
		&QtdLinhas = gxMLines(&FilRaz, 47)
		
		if &QtdLinhas > 47
			&UmFilRaz = gxGetMLi(&FilRaz, 1, 47)
			&DoisFilRaz = gxGetMLi(&FilRaz, 2, 47)
		Else
			&DoisFilRaz = gxGetMLi(&FilRaz, 1, 47)
		EndiF 

		&UmFilRaz = UPPER(&UmFilRaz)
		&DoisFilRaz = UPPER(&DoisFilRaz)
		
		if not FilCpj.IsEmpty()
			&CnpjIeIm = 'CNPJ: ' + trim(FilCpj)
		EndIF
		&FilCpj = FilCpj
		If not FilInsEst.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IE: ' + trim(FilInsEst)
		EndIF
		
		If Not FilInsMun.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IM: ' + trim(FilInsMun)
		EndIF
		
		&Endereco = FilLog.Trim() + ', ' + trim(FilNro) + ' - ' + trim(FilBai)
		&Cidade = trim(FilCidNom) + ' - ' + trim(FilCidUfeCod)
		&Operador = &FilRaz
		Exit
	EndFor
EndSub
]]></Source>
