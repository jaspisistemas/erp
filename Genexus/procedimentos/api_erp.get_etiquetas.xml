      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true	
	do 'PreencheTiposEtiquetas'
	PadraoUsuario.Call('L', '#TPETIQUETA_PRODUTO#', 0, &wwpContext.EmpCod, &PadObs, &PadDtaMod)
	
	//RETORNASDTSELECIONADO
	&SdtTipEtq_SELECIONAD_TRUE.FromJson(&PadObs)
	If &SdtTipEtq_SELECIONAD_TRUE.Count > 0
		
		For &SdtTipEtq_SELECIONAD_Item in &SdtTipEtq_SELECIONAD //Todos
			For &SdtTipEtq_SELECIONAD_TRUE_Item in &SdtTipEtq_SELECIONAD_TRUE //Selecionado
				if &SdtTipEtq_SELECIONAD_TRUE_Item.CD = &SdtTipEtq_SELECIONAD_Item.CD
					if not &SdtTipEtq_SELECIONAD_TRUE_Item.NWD.IsEmpty()
						&Mensagem = &SdtTipEtq_SELECIONAD_Item.NWD + &SdtTipEtq_SELECIONAD_TRUE_Item.NWD
						
						&sdtImpressorasimpressao = new()
						&sdtImpressorasimpressao.Cod = &SdtTipEtq_SELECIONAD_Item.CD
						&sdtImpressorasimpressao.Nom = &Mensagem
						&sdtImpressoras.impressao.Add(&sdtImpressorasimpressao)
					Else
						&sdtImpressorasimpressao = new()
						&sdtImpressorasimpressao.Cod = &SdtTipEtq_SELECIONAD_Item.CD
						&sdtImpressorasimpressao.Nom = &SdtTipEtq_SELECIONAD_Item.dES
						&sdtImpressoras.impressao.Add(&sdtImpressorasimpressao)
					EndIF
				EndiF
			EndFor
		EndFor
	Else
		For &SdtTipEtq_SELECIONAD_Item in &SdtTipEtq_SELECIONAD
			&sdtImpressorasimpressao = new()
			&sdtImpressorasimpressao.Cod = &SdtTipEtq_SELECIONAD_Item.CD
			&sdtImpressorasimpressao.Nom = &SdtTipEtq_SELECIONAD_Item.dES
			&sdtImpressoras.impressao.Add(&sdtImpressorasimpressao)
		EndFor
	EndIF	
	
	//Impressoras
	For Each Order EmpCod, EmpImpCod
		where EmpCod = &wwpContext.EmpCod
		Where EmpImpFilCod = &wwpContext.FilCod or EmpImpFilCod.IsEmpty() or EmpImpFilCod.IsNull()
		Where EmpImpTip = domTipoImpressora.ETIQUETA1 or EmpImpTip = domTipoImpressora.ETIQUETA2 or EmpImpTip = domTipoImpressora.ETIQUETA3
				
		&sdtImpressorasimpressora = new()
		&sdtImpressorasimpressora.Cod = trim(str(EmpImpCod))
		&Mensagem = format('[%1] - %2', EmpImpPC.Trim(), EmpImpNom.Trim())
		&sdtImpressorasimpressora.Nom = &Mensagem
		&sdtImpressoras.impressora.Add(&sdtImpressorasimpressora)
	EndFor

	&sdtImpressoras.qtdImpressao = &sdtImpressoras.impressao.Count
	&sdtImpressoras.qtdImpressora = &sdtImpressoras.impressora.Count
	
Endif


Sub 'preencheTiposEtiquetas'

	//RIBON
	&SdtTipEtq_SELECIONAD.Clear()
	
	&SdtTipEtq_SELECIONAD_Item = New() //MERCADO
	&SdtTipEtq_SELECIONAD_Item.SEL = false
	&SdtTipEtq_SELECIONAD_Item.CD = 'R05'
	&SdtTipEtq_SELECIONAD_Item.DES = '[MOD_R05] Ribon | 1 Col. | Gôndolas Mercado | 8.00 X 3.0'
	&SdtTipEtq_SELECIONAD_Item.NWD = '[MOD_R05] Ribon | 1 Col. | '
	&SdtTipEtq_SELECIONAD.Add(&SdtTipEtq_SELECIONAD_Item)	


EndSub
]]></Source>
