      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErro = true

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	Do Case
		Case PedVlrAgr < 0 //AGRUPAMENTO DE VALORES - NAO PODE< SOMENTE PRINCIPAL
			&Mensagem = 'AGRUPAMENTO DE VALORES'
			&ErroMensagem = 'PARA DESAGRUPAR INFORME O PEDIDO PRINCIPAL DO AGRUPAMENTO: ' + trim(str(PedCodAgr))
			
		Case PedVlrAgr > 0 //AGRUPAMENTO DE VALORES - PEDIDO PRINCIPAL
			&IsErro = false
			&Mensagem = 'AGRUPAMENTO DE VALORES'
			
			If PedStsFin <> Status_Financeiro.ABERTO //FINANCEIRO FECHADO
				&IsErro = true
				&ErroMensagem = 'PEDIDO PRINCIPAL É PRECISO ESTAR COM FINANCEIRO ABERTO PARA DESAGRUPAR.'
			Endif
			
		Otherwise
			&ErroMensagem = 'NÃO IDENTIFICADO TIPO DE AGRUPAMENTO, OU DESAGRUPAMENTO INDISPONIVEL!'
	EndCase
when none
	&ErroMensagem = 'PEDIDO NÃO LOCALIZADO'
EndFor
]]></Source>
