      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	For Each Order EmpCod, NfsCod
		Where EmpCod = &EmpCod
		Where NfsCod = &NfeCod 
		
		&PastaBancoDados =  &sdtConfiguracoesPasta.PastaNFSenviado.Trim() + "BancoDeDados\"
		&DiretorioDanfeBancoDeDados.Source   =  &PastaBancoDados
		if not &DiretorioDanfeBancoDeDados.Exists()
			&DiretorioDanfeBancoDeDados.Create()
		EndIf
		
		&NomArq = &sdtConfiguracoesPasta.PastaNFSenviado.Trim() + "BancoDeDados\" + NfsChv.Trim() + '-nfse.xml'	
		&resultado = DFWOpen(&NomArq,'','',0,'')
		&resultado = DFWPTxt(NfsArqXml)
		&ResultadoNext = dfwnext()
		&resultado = DFWClose()
		
		Exit
	EndFor


]]></Source>
