      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &proCod
	
	&treeNode.Id = ProCod.ToString()
	&treeNode.Name = trim(toformattedString(ProQtdPro)) + ' '+ ProEmbUnd.Trim() + ' | '+ ProNom
	&treeNode.Expanded = true
	&treeNodeCollectionData.Add(&treeNode)	
	
	&Mensagem = ''
	For Each Order EmpCod, ProCod, RecProCod
		&Item2 += 1
		&MEnsagem = testeerroMateriaPrima.udp(EmpCod, ProCod, RecProCod)
		
		&treeNode = new()
		&treeNode.Id = RecProCod.ToString()
		&treeNode.Name = trim(toformattedString(RecProQtd)) + ' '+ RecEmbUnd.Trim() + ' | '+ RecProNom
		&treeNode.Expanded = true
		&parent = &treeNodeCollectionData.Item(&Item)
		&parent.Nodes.Add(&treeNode)
		
		if &Mensagem.IsEmpty()
			prcMontaArvore1.Call(EmpCod, &Item, &Item2, RecProCod, &treeNodeCollectionData)
		EndIF
	EndFOr
EndFOr
]]></Source>
