      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PesAnxTipCod = 0
For Each ORder EmpCod, TpaNom, TpaOrd
	Where EmpCod = &EmpCod
	Where TpaNom = &PesAnxTipNom	
	&PesAnxTipCod = TpaCod
	Exit
when none
	
	do 'cadastra'
	
endFor


sub 'cadastra'
	Do Case
		Case &PesAnxTipNom = '#IMAGEM_PESSOA#'		
			UltimoCodigoEmpresa.Call(domParCod.TIPOANEXOS, &EmpCod, 0, &PesAnxTipCod)	
			new
				EmpCod = &EmpCod
				TpaCod = &PesAnxTipCod
				TpaNom = &PesAnxTipNom
				TpaOrd = 0
				TpaPed = false
				TpaPes = false
			EndNew
			
			Commit
			
		Case &PesAnxTipNom like '%#LOGO_ETIQUETA%'
			UltimoCodigoEmpresa.Call(domParCod.TIPOANEXOS, &EmpCod, 0, &PesAnxTipCod)	
			new
				EmpCod = &EmpCod
				TpaCod = &PesAnxTipCod
				TpaNom = &PesAnxTipNom
				TpaOrd = 0
				TpaPed = false
				TpaPes = true
			EndNew
			
			Commit
		
		Otherwise
			
	EndCase
EndSub

]]></Source>
