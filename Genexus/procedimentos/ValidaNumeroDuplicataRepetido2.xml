      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsErrro = False

For Each Order EmpCod, FilCod, CreCliCod, CreDupNro
	Where EmpCod = &EmpCod
//	Where FilCod = &FilCod
	Where CreFilPgt = &FilCod
	Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
	Where CreCliCod = &CreCliCod when &CreRecPag = ReceberPagar.Pagar
	Where CreDupNro = &CreDupNro
	Where CreSts <> Status_Duplicata.CANCELADA
	Where CreCod <> &CreCod
	Where CreRecPag = &CreRecPag //Tipo receber ou pagar
	
	
	&IsErrro = true
	If CreRecPag = ReceberPagar.Pagar
		&Mensagem = 'Já Existe uma duplicata para esse cliente cadastrada com o Número: ' + trim(CreDupNro) + ' Sequência:' + trim(Str(CreCod))
	Else
		&Mensagem = 'Já Existe uma duplicata cadastrada com o Número: ' + trim(CreDupNro) + ' Sequência:' + trim(Str(CreCod))
	EndIf
	Exit
EndFor
]]></Source>
