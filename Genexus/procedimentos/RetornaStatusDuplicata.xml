        <Source><![CDATA[
&NfePedTmpSts = Status_SimNao.Nao

For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where CreCod = &CreCod
	
	if CreVlrDup <> CreVlrSdo
		&NfePedTmpSts = Status_SimNao.Sim
	EndIf
	Exit
EndFor

]]></Source>
