      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order CfoCod, CfoEmpCod
	Where CfoCod = &CfoCod
	Where CfoEmpCod = &CfoEmpCod
	Where CfoLctCod = &CfoLctCod 
	
	Exit
	
When none
	
	New
		CfoCod = &CfoCod
		CfoEmpCod = &CfoEmpCod
		CfoLctCod = &CfoLctCod 
		CfoEmpEntCod = &CfoEmpEntCod
		CfoEmpInvCod = &CfoEmpInvCod
	EndNew
	Commit
EndFor


]]></Source>
