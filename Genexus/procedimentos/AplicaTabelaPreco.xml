      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Total = 10
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where TabCod = &TabCod or TabPrmCod = &TabCod
	Where PedStsFin <> Status_Financeiro.FECHADO
	Where LctInfPrc <> Status_SimNao.Sim
	Where LctAtuSal = Status_EntradaSaida.Saida
	Where PedDtaEms >= &IniPedDtaEms and PedDtaEms <= &FinPedDtaEms
	&Total += 1
EndFor
do 'Atualiza'

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where TabCod = &TabCod or TabPrmCod = &TabCod
	Where PedStsFin <> Status_Financeiro.FECHADO
	Where LctInfPrc <> Status_SimNao.Sim
	Where LctAtuSal = Status_EntradaSaida.Saida
	Where PedDtaEms >= &IniPedDtaEms and PedDtaEms <= &FinPedDtaEms
	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	//GRAVA PREÇOS UNITARIOS CONFORME ALTERACAO NOS CAMPOS /COLUNA / TABELA
	AtualizaPrecosPedidoVenda.Call(EmpCod, FilCod, PedCod, true)
	
EndFor


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub


]]></Source>
