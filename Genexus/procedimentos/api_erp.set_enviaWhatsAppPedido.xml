      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)


if &IsAcessoConcedido = true //Acesso concedido
	&WaDtaEms = serverdate()
	&Ano = year(&WaDtaEms)
	&Mes = month(&WaDtaEms)
	&WaAnoMes = trim(str(&Ano)) + padL(trim(str(&mes)),2,'0')
	
	&IsPodeEnviar = false
	&IsPrimeiraVez = false
	
	//Verificar se o numero ja foi enviado hoje
	prcWhatsApp_VerificaJaEnviado.Call(&wwpContext.EmpCod, &WaAnoMes, &WaDtaEms, &WaFonDest, &IsPrimeiraVez)
	If &IsPrimeiraVez = true
		//se nao foi enviado verificar se pode enviar
		
		prcWhatsApp_verificaQtdEnviadaAnoMes.Call(&wwpContext.EmpCod, &WaAnoMes, &WaAnoMesQtd, &EmpQtdWhatsMsg)
		if &EmpQtdWhatsMsg > &WaAnoMesQtd
			&IsPodeEnviar = true
		Endif
	
	Else
		&IsPodeEnviar = true
	Endif

	if &IsPodeEnviar = true
		//grava envio
		
		&WaMensagem = '' //PREENCHER MENSAGEM
		prcWhatsApp_GravaEnvio.Call(&wwpContext.EmpCod, &WaAnoMes, &WaDtaEms, &WaFonDest, &IsPrimeiraVez, &WaMensagem, &PedCod, &wwpContext.FilCod, 0, 0, &wwpContext.PesCod, &WaGUID)
		
		//GERA O PDF DO PEDIDO
		RetornaCaminhoPedido.call(&wwpContext.DeviceRandon, &wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &URLDESTINO, &UrlVirtual)
	
		Do Case //&TipoPedido mesmo codigo do envia email.
			Case &TipoPedido = '3' //PEDIDO VENDA COM LOGOMARCA
				RELJAS078_toFile.Call('SR', &wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &wwpContext.PesCod, &URLDESTINO, &OrdemImpressao, false)
			Case  &TipoPedido = '2' //PEDIDO VENDA COM LOGOMARCA
				RELJAS078_toFile.Call('', &wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &wwpContext.PesCod, &URLDESTINO, &OrdemImpressao, false)
			Case  &TipoPedido = '4' //PEDIDO VENDA COM LOGOMARCA - IMG PRODUTO
				RELJAS137_toFile.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &wwpContext.PesCod, &URLDESTINO, &OrdemImpressao, false)
			Otherwise
				RELJAS002_toFile.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &URLDESTINO, &OrdemImpressao, false)
		EndCase
		
		//&FilaWhatsEnvAdc
		
		//GRAVA FILA DE ENVIO
		prcFilaEnvioWhats_EnviaPedidoVenda.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &PedCod, &wwpContext.PesCod, &URLDESTINO, &UrlVirtual, 0, &PesFonNum, &WaGUID, &IsEnviarFaltas)
		
		&sdtRetornoWbs.Sts = 'J200'
		&sdtRetornoWbs.Obs = 'Envio registrado.'
	Else
		&sdtRetornoWbs.Sts = 'E001'
		&sdtRetornoWbs.Obs = 'Pacote de Mensagens WhatsApp atingido, para envio de Mais mensagens entre em contato com o suporte.'
	Endif

	
//	EmpCod
//	EmpQtdWhatsMsg
//	WaGuid
//	WaDtaEms
//	WaDtaHorEms
//	WaFonDest
//	WaMensagem
Endif
]]></Source>
