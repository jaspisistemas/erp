      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCodOciRef = &PedCodOciRef
	Where PedStsGer = Pedido_Gerado.TrocaMercadorias
	Where LctTip = TipoLancamento.DevolucaoVenda
	Where PedSts = Status_Pedido.ABERTO
	
	&DevPedCod = PedCod
	
	Exit
When none
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon113_TipoLancamentoDevolucaoVenda, &TCon113_TipoLancamentoDevolucao)
	&LctCod = val(&TCon113_TipoLancamentoDevolucao)
	
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctCod = &LctCod //when &LctCod <> 0
		Where LctTip = TipoLancamento.DevolucaoVenda
		Where LctGerFin = Status_SimNao.Sim
		Where LctAtuEst = Status_EntradaSaida.Entrada
		
		CarregaSdtPedidoVenda.Call(&EmpCod, &FilCod, &PedCodOciRef, &sdtGravaPedido)
		&sdtGravaPedido.PedStsGer = Pedido_Gerado.TrocaMercadorias
		
		//ZERA PARA GRAVAR NOVO
		&sdtGravaPedido.PedCod = 0			
		&sdtGravaPedido.LctCod = LctCod
		&sdtGravaPedido.PedDtaEms = Serverdate()
		
		//&sdtGravaPedido.PedDtaPrv = Serverdate()
		//&sdtGravaPedido.TabCod = TabCod
		//&sdtGravaPedido.TabPrmCod = TabPrmCod
		//&sdtGravaPedido.TabColCod = TabColCod
		//&sdtGravaPedido.PedNum = PedNum	
		//&sdtGravaPedido.PedVenCod = PedVenCod
		
		//FINANCEIRO
		//&sdtGravaPedido.PedPraCod = &PedPraCod
		//&sdtGravaPedido.PedFrpTip = &PedFrpTip
		//&sdtGravaPedido.PedPraParNom = &PedPraParNom
		
		//TRANSPORTE
		//&sdtGravaPedido.PedTraRedCod = &PedTraRedCod
		//&sdtGravaPedido.PedTipFrt = &PedTipFrt	
		//&sdtGravaPedido.PedTraSaiCod = &PedTraSaiCod
		//&sdtGravaPedido.PedTipSaiFrt = &PedTipSaiFrt
		
		&sdtGravaPedido.PedObsEst = ''
		&sdtGravaPedido.PedObsFin = ''
		&sdtGravaPedido.PedObsGer = ''
		&sdtGravaPedido.PedObsNfe = ''
		
		//&sdtGravaPedido.PedTpcCod = PedTpcCod
		//&sdtGravaPedido.PedFatFilCod = &PedFatFilCod
		
		&sdtGravaPedido.PedVlrDscGlb = 0
		&sdtGravaPedido.PedVlrOutCus = 0
		&sdtGravaPedido.PedVlrGnre = 0
		&sdtGravaPedido.PedVlrOut = 0
		&sdtGravaPedido.PedPerFrt = 0
		&sdtGravaPedido.PedFrtFix = 0
		&sdtGravaPedido.PedPerSpm1 = 0
		&sdtGravaPedido.PedPerSpm2 = 0
		&sdtGravaPedido.PedPerPrm1 = 0
		&sdtGravaPedido.PedPerPrm2 = 0
		
		//&sdtGravaPedido.PedPrpCod = PedPrpCod
		//&sdtGravaPedido.PedBlq = Status_SimNao.Sim
		
		&sdtGravaPedido.PedCodOciRef = &PedCodOciRef
		
		GravaPedidoVenda.Call(TrnMode.Insert, &EmpCod, &FilCod, &DevPedCod, &sdtGravaPedido, &ContextPesCod, &ContextUserName)
	
		Exit
	when none
		&Mensagem = 'Tipo de Lançamento Devolução de venda não Localizado! [TCon113]'
	EndFor
EndFor
]]></Source>
