      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true	
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwCidades.pA = '0'
	&wwCidades.pT = '0'
	&wwCidades.p1 = '0'
	&wwCidades.p2 = '0'
	&wwCidades.p3 = '0'
	&wwCidades.p4 = '0'
	&wwCidades.p5 = '0'
	&IsPaginaOk = false
	
	&wwCidades.sts = 'J200'
	
	For Each 
		ORder EmpCod, CidNom  when &UfeCod.IsEmpty() or &UfeCod = 'TD'
		Order EmpCod, UfeCod, CidNom when not &UfeCod.IsEmpty() and not &UfeCod = 'TD'
		Where EmpCod = &wwpContext.EmpCod
		Where CidNom like &CidNom when not &CidNom.IsEmpty()
		Where UfeCod like &UfeCod when not &UfeCod.IsEmpty() and not &UfeCod = 'TD'
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwCidades.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				&wwCidadesItem = New()
				&wwCidadesItem.Cod = CidCod
				&wwCidadesItem.Nom = CidNom
				&wwCidadesItem.Ufe = UfeCod
				&wwCidadesItem.UfeNom = UfeNom
				&wwCidadesItem.Ibge = CidIBGE
				&wwCidades.Item.Add(&wwCidadesItem)
			Endif
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	EndFor
	
	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwCidades.pA = trim(str(&Pagina))
		&wwCidades.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwCidades.p1, &wwCidades.p2, &wwCidades.p3, &wwCidades.p4, &wwCidades.p5)
		
	Endif
Else
	&wwCidades.sts = 'E999'
	&wwCidades.msg = 'Nada a fazer aqui!'
Endif

]]></Source>
