      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each ORder EmpCod, TipEtqCod
	Where EmpCod = &EmpCod
	Where TipEtqCod = &TiPEtqCod
	
	TipEtqJson = &TipEtqJson
	TipEtqAlt = &TipETqAlt
	TipEtqLar = &TiPEtqLar
	Exit
EndFor

Commit


&sdtDesignerConfig.FromJson(&TipEtqJson)

For &sdtDesignerConfigElements in &sdtDesignerConfig.elements
	if &sdtDesignerConfigElements.id = 'FIL_LOG' or &sdtDesignerConfigElements.id = 'PES_LOGIMG'
		&PesAnxTipNom = format('#LOGO_ETIQUETA%1#', trim(Str(&TiPEtqCod)))
		RetornaTipoAnexo.Call(&EmpCod, &PesAnxTipNom, &AnxTipCod)
	Endif		
EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
