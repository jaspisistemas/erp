      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&QtdItens = 0
&QtdPecas = 0
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedQtd > 0
	
	&QtdItens += 1
	
	If ProTipDef <> Definicao.SERVICO
		&QtdPecas += PedQtd
	EndIF
EndFor
]]></Source>
