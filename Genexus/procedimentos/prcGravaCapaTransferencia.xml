      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TrsCod = &ParTrsCod
Do Case
	CAse &OqueFazer = 'INS'
		UltimoCodigoEmpresa.Call(domParCod.TRANSPEDIDO, &EmpCod, 0, &TrsCod)
		
		New
			EmpCod = &EmpCod
			TrsCod = &TrsCod
			TrsDtaEms = &TrsDtaEms
			
			TrsSaiFilCod = &TrsSaiFilCod			
			TrsSaiPedCod = 0
			TrsSaiNfeCod = 0
			TrsSaiTipLct = 0
			
			TrsSts = Status_Pedido.ABERTO
			
			TrsEntFiLCod = &TrsEntFiLCod			
			TrsEntPedCod = 0
			TrsEntNfeCod = 0
			TrsEntTipLct = 0
			TrsTip = &TrsTip
		EndNEw
		
		Commit
		
	Case &OqueFazer = 'UPD'
		For Each Order EmpCod, TrsCod
			Where EmpCod = &EmpCod
			Where TrsCod = &TrsCod
			
			TrsDtaEms = &TrsDtaEms
			
			TrsSaiFilCod = &TrsSaiFilCod
			TrsEntFiLCod = &TrsEntFiLCod
			TrsTip = &TrsTip
			
			Exit
		EndFor
		
		Commit
EndCase
]]></Source>
