      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//carrega Fornecedores SDT.
loadFornecedoresProdutoCotacao.Call(&EmpCod, &CotComCod, 0, 0, &sdtCotacaoCompraFornecedores)

if &sdtCotacaoCompraFornecedores.Count > 0
	//navega Produtos sem Fornecedor
	
	For Each ORder EmpCod, CotComCod, CotComItmCod
		Where EmpCod = &EmpCod
		Where CotComCod = &CotComCod
		
		&CotComItmCod = CotComItmCod
		&IsTemFornecedor = false
		For Each ORder EmpCod, CotComCod, CotComItmCod, CotComProForCod
			&IsTemFornecedor = true	
			Exit
		EndFor
		
		if &IsTemFornecedor = false
			do 'gravaFornecedores'
		Endif
		
	EndFor
Endif



Sub 'gravaFornecedores'
	For &sdtCotacaoCompraFornecedoresItem in &sdtCotacaoCompraFornecedores
		if &sdtCotacaoCompraFornecedoresItem.IsSel = true
			new
				EmpCod = &EmpCod
				CotComCod = &CotComCod
				CotComItmCod = &CotComItmCod
				CotComProForCod = &sdtCotacaoCompraFornecedoresItem.PesCod
			EndNew
		Endif
	EndFor
	
	Commit
	
EndSub

]]></Source>
