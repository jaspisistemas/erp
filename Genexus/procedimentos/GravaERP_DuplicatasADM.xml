      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For &SdtDuplicatasItem in &SdtDuplicatas
	For Each ORder DupTmpEmpCod
		Where DupTmpEmpCod = &EmpCod
		Where DupTmpFilCod = &FilCod
		Where DupTmpPesCod = -2
		Where DupTmpCreCod = &SdtDuplicatasItem.CreCod
		
		if DupTmpCreCliCod <> 0
			&CreAdmCod = DupTmpCreCod 
			&CreDupNro = DupTmpCreDupNro
			&CreDtaVct = DupTmpCreDtaVct
			&CreVlrDup = DupTmpCreVlrDup
			&CreCliCod = DupTmpCreCliCod
			&CreVenCod = DupTmpCreVenCod
			&CreCbrCod = DupTmpCreCbrCod
			&PlanCod = DupTmpCrePlanCod
			&DupTmpCreCod = DupTmpCreCod
			do 'GravaDuplicata'	
		Endif
	EndFor
EndFor


///ENVIA WEB ADM JASPI.
//RETORNAR OK GRAVA A PORRA TODA
if &ppJASPI_DuplicatasERP_ADM_insdtDuplicatas.Duplicatas.Items.Count > 0
	&Location = GetLocation('ppJASPI_DuplicatasERP_ADM_in')
	&Location.Secure = false //false 
	&Location.CancelOnError = 2 //tratar exceção do WS 
	&ppJASPI_DuplicatasERP_ADM_in.Execute(&ppJASPI_DuplicatasERP_ADM_insdtDuplicatas)
	
	If GetSOAPErr()= 0 
		commit
	Else
		&Mensagem = 'CÓDIGO ERRO:' +str(GetSOAPErr())+'. ' 
		&Mensagem += 'DESC. ERRO:'+GetSOAPErrMsg()+'. ' 
		Msg(&Mensagem) 
	Endif

Endif



Sub 'GravaDuplicata'
	UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &FilCod, &CreCod)

	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		CreCod = &CreCod
		CreFilPgt = &FilCod
		
		CreDupNro = &CreDupNro
		CreDtaEms = serverdate() 
		CreDtaVct = &CreDtaVct
		
		CreFrpPgtoCod = 1 //DUPLICATA
		CreVlrDup = &CreVlrDup
		CreVlrSdo = &CreVlrDup
		
		CreCliCod = &CreCliCod
		CreVenCod = &CreVenCod
		CreRecPag = ReceberPagar.Receber
		CreCbrCod = &CreCbrCod
		CreBloNro = ''
		CreCodBar = ''
		CreSts    = Status_Duplicata.ATIVO
		CreOriDup = OrigemDuplicata.WebService
		CrePlanCod = &PlanCod
		CrePerComCbr = 0
		CreAdmCod = &CreAdmCod
		CreAdmLib = ''
	EndNew

	//ADD AO SDT PARA SYNCRONIZAR NO ADM JASPI
	&ppJASPI_DuplicatasERP_ADM_insdtDuplicatas_Item = new()
	&ppJASPI_DuplicatasERP_ADM_insdtDuplicatas_Item.CreCod = &DupTmpCreCod
	&ppJASPI_DuplicatasERP_ADM_insdtDuplicatas_Item.CreSync = trim(str(&CreCod))
	&ppJASPI_DuplicatasERP_ADM_insdtDuplicatas.Duplicatas.Items.Add(&ppJASPI_DuplicatasERP_ADM_insdtDuplicatas_Item)
	
//	if not &CreCobObs.IsEmpty()
//		GravaCobranca.call(&EmpCod,&FilCod,&CreCod,'DUPLICATA ORIGINARIA DO ADM JASPI',0,0,&CrePrmPag, '00:00:00')
//	EndiF
EndSub

]]></Source>
