      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon031_TipoLctoBalanco, &CfgVlr)

&balLctCod = val(&CfgVlr)

 &IsEstaEmAlgumaReceita = false
 &IsPossuiPedidos = false
 
 if &ProGraCod = 1
	//Verifica se eh Utilizado em Receitas
	For Each Order EmpCod, ProCod, RecProCod
		Where EmpCod = &EmpCod
		Where RecProCod = &ProCod
		&IsEstaEmAlgumaReceita = true
		Exit
	EndFor
EndIF

For Each Order EmpCod, PedCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod When &ProGraCod <> 1
	Where LctCod <> &balLctCod
	&IsPossuiPedidos = true
	Exit
EndFor

if &IsPossuiPedidos = false //VE SE TEM NOTA
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &EmpCod
		Where NfeProCod = &ProCod
		Where NfeProGraCod = &ProGraCod When &ProGraCod <> 1
		&IsPossuiPedidos = true
		Exit
	EndFor
Endif
]]></Source>
