      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Pega ultima nota autorizada do pedido

For Each ORder EmpCod, FilCod, (NfeDtaFat), (NfeCod)
	Where EmpCod = &EmpCod
	Where NfePedCod = &NfePedCod
	Where NfeFilCod = &NfeFilCod
	Where NfeSts = Status_Nfe.Autorizada
	
	&NFeCod = NfeCod
	&FilCod = FilCod
	Exit
EndFor

//atualiza
For Each Order EmpCod, MrkCod, MrkPedCod
	Where EmpCod = &EmpCod
	Where MrkPedFilCod = &NfeFilCod
	Where MrkPedCod = &NfePedCod
	
	
	MrkNfeFilCod = &FilCod
	MrkNfeCod = &NFeCod
	
	&MrkPedSku = MrkPedSku
	&MrkCod = MrkCod
	
	Exit
EndFor

Commit


prcAtualizaStatusInterno.Call(&EmpCod, &MrkCod, &MrkPedSku)
]]></Source>
