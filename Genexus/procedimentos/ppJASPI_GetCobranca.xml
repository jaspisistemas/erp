      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&SaidaLongVarchar.SetEmpty()

for Each order EmpCod, PdvCod 
	Where EmpCod = &EmpCod
	Where PdvRandon = &PdvRandon //PRA SABER SE É UM PDV VALIDO
	
	Exit
When none 
	Return
EndFor
  
 For Each Order EmpCod, PesCod
	 Where EmpCod = &EmpCod
	 Where PesCod = &PesCod
	 
	 &sdtGetCobrancaPDV.CliCod = PesCod
	 &sdtGetCobrancaPDV.VlrCrd = PesCliCrd
	 &sdtGetCobrancaPDV.DtaUltDow = ServerNow()
	 Exit
	 
 EndFor

For Each Order EmpCod, FilCod, CreDtaEms
	Where EmpCod = &EmpCod
	Where CreCliCod = &PesCod
	Where CreVlrSdo > 0
	Where CreRecPag = ReceberPagar.Receber
	Where CreSts <> Status_Duplicata.CANCELADA
	Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
	
	&sdtGetCobrancaPDVDupItem = new()
	&sdtGetCobrancaPDVDupItem.DtaEms = CreDtaEms
	&sdtGetCobrancaPDVDupItem.DtaVct = CreDtaVct
	&sdtGetCobrancaPDVDupItem.DupNro = CreDupNro
	&sdtGetCobrancaPDVDupItem.PedCod = CrePedCod
	
	&CreFilPgt = FilCod
	&PedCod = CrePedCod
	do 'GetNfe'
	&sdtGetCobrancaPDVDupItem.NroNfe = &NfeNum
	&sdtGetCobrancaPDVDupItem.SerNfe = &NfeSer
	
	&sdtGetCobrancaPDVDupItem.VlrSdo = CreVlrSdo
	
	if CreDtaVct < serverdate()
		&sdtGetCobrancaPDV.VlrDupVcd += CreVlrSdo
	EndIf
	&sdtGetCobrancaPDV.VlrDupTot += CreVlrSdo
	
	&sdtGetCobrancaPDV.Dup.Add(&sdtGetCobrancaPDVDupItem)
EndFor

&SaidaLongVarchar = &sdtGetCobrancaPDV.ToXml()

Sub 'GetNfe'
	
	&NfeNum.SetEmpty()
	&NfeSer.SetEmpty()
	For Each ORder EmpCod, FilCod, NfePedCod, NfeCod
		Where EmpCod = &EmpCod
		Where NfeFilCod = &CreFilPgt
		Where NfePedCod = &PedCod
		Where NfeSts = status_NFe.Digitando or NfeSts = Status_Nfe.Autorizada
		
		&NfeNum = NfeNum
	 	&NfeSer = NfeSer
		Exit
	EndFor
EndSUb
]]></Source>
