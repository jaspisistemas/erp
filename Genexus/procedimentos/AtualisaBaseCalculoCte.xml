      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CteImpVbc = 0
&IsAchou = False
For each Order EmpCod,FilCod,CteCod,CtePreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod 
	Where CteDesIcmsCom = True
	&CteImpVbc += CteVlrPreCom
	&IsAchou = True
EndFor


For each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod

		If (CteImpCst <> ClassificacaoCst.Isento and CteImpCst <> ClassificacaoCst.NaoTributada and CteImpCst <> ClassificacaoCst.Deferido)
			Do Case
				Case &IsAchou = False and CteFinEms <> FinalidadeCte.Complemento			
					CteImpVbc = CteVlrTotPreSer
					CteImpVbcRet = CteVlrTotPreSer
					CteImpVlr = (CteVlrTotPreSer * (CteImpAli*0.01))
				Case &IsAchou = True
					CteImpVbc = &CteImpVbc
					CteImpVbcRet = &CteImpVbc
					CteImpVlr = (&CteImpVbc * (CteImpAli*0.01))
					
				Case &IsAchou = False and CteFinEms = FinalidadeCte.Complemento and CteVlrTotPreSer > 0
					CteImpVbc = CteVlrTotPreSer
					CteImpVbcRet = CteVlrTotPreSer
					CteImpVlr = (CteVlrTotPreSer * (CteImpAli*0.01))
			EndCase
		Else
			CteImpVbc = 0
		EndIf
	Exit
EndFor


commit

]]></Source>
