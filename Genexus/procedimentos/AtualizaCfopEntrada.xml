      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each ORder tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNFeCod
	
	
	RetornaCfopEntrada.Call(&EmpCod, &LctCod, tmpCFOP, &CfoEmpAprvCredIcmsPer, &tmpEntCFOP)
	tmpEntCFOP = &tmpEntCFOP
	
	//So Atualiza se tiver padrao cadastrado no tipo de lancamento ou filial
	if not &CstPisCofins.IsEmpty()		
		tmpImpCstPis.FromString(&CstPisCofins)
	Endif

EndFor

Commit
 
