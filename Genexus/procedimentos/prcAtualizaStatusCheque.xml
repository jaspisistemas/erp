      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each order EmpCod, FilCod, CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	
	if CreVlrSdo > 0 and CreCheCod > 0
		RetornaMotivoCheque.call(EmpCod, CreCheCod, &CheMot)
		if &CheMot = MotivoCheque.COMPENSADO
			//SE TIVER ALTERA PARA PENDENTE
			ChequeTerceiros_AlteraStatus.Call(EmpCod, CreCheCod, MotivoCheque.EMITIDO)
		Endif
	Endif
EndFor
]]></Source>
