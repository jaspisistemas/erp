      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&FecCod = 0
For Each Order EmpCod, CtabanCod, (FecCod)  // pega ultimo cógo do fechamento
	Where EmpCod = &EmpCod
	Where CtabanCod = &CtaBanCod
	&FecCod = FecCod
	Exit
EndFor

&FecCod += 1
										//garava um novo fechamento
new
	EmpCod = &EmpCod
	CtabanCod = &CtaBanCod
	FecCod = &FecCod
	FecDta = &FecHor.ToDate()
	FecHor = &FecHor
	FecSts = &FecSts
	FecPesCod = &FecPesCod
	FecStsLct = &FecSts
EndNew

Commit
	
For Each Order EmpCod, CtabanCod //ATUALIZA DATA DA CAPA
	Where EmpCod = &EmpCod
	Where CtabanCod = &CtaBanCod
	CtaFecDta = &FecHor.ToDate()
	Exit
EndFor

Commit

if &FecSts = FechaAbre.FECHARNOVO
//	Do 'AtualizaMovimento'
Else
	do 'AbreTUDO'
Endif
Commit

Sub 'AbreTUDO'
	For Each Order 	EmpCod, CtabanCod, FecDta
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		Where FecDta > &FecDta
		
		&AuxFecCod = FecCod
		FecStsLct = FechaAbre.ABERTURA
		
		Do 'AtualizaMovimentoFEchado'
	EndFor	
EndSub


Sub 'AtualizaMovimentoFEchado'          // grava o código do log(fechamento) quando o status é fechamento
	For Each Order EmpCod, MovCtaBanCod
		Where EmpCod = &EmpCod
		Where MovCtaBanCod = &CtaBanCod
		Where MovFecCod = &AuxFecCod
		
		MovFecCod = 0
	EndFor
EndSub

