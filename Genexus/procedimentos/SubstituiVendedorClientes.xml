      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Total = 0
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

For Each Order EmpCod
	Where EmpCod = &EmpCod
	Where PesIntVenCod = &AntPesCod or PesExtVenCod = &AntPesCod when &AntPesCod > 0
	Where PesCod = &CliPesCod or &CliPesCod = 0
	Where PesIsCli = true
	&Total += 1
EndFor


For Each Order EmpCod
	Where EmpCod = &EmpCod
	Where PesIntVenCod = &AntPesCod or PesExtVenCod = &AntPesCod when &AntPesCod > 0
	Where PesCod = &CliPesCod or &CliPesCod = 0
	Where PesIsCli = true
	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	if &NovPesIntVenCod > 0
		&PesSacDlg = '#JASPI# Transferido do Televendas:' + trim(str(PesIntVenCod)) + ' Para Televendas:' + trim(Str(&NovPesIntVenCod))
		GravaLigacaoTelevendas.Call(EmpCod, PesCod, &NovPesIntVenCod, true, Status_InternoExterno.INTERNO, &PesSacDlg,  serverdate(), 'I', &ContextPesCod)
	EndIF

	if &NovPesExtVenCod > 0
		&PesSacDlg = '#JASPI# Transferido do Vendedor:' + trim(str(PesExtVenCod)) + ' Para Vendedor:' + trim(Str(&NovPesExtVenCod))
		GravaLigacaoTelevendas.Call(EmpCod, PesCod, &NovPesExtVenCod, true, Status_InternoExterno.ExTERNO, &PesSacDlg, serverdate(), 'E', &ContextPesCod)
	EndIF
	
	SubstituiVendedorVinculos.Call(&EmpCod, &CliPesCod, &NovPesExtVenCod, &NovPesIntVenCod, &Count)
	
	&Count += 1
EndFor


Commit


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit

EndSub



]]></Source>
