      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[MT 1
MB 1

If &PedCod <> 0
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		&PesRaz = substr(PedCliRaz,1,40)
		&FiLRaz = gxGetMLi(FilRaz, 1, 25)
		&AuxFiLRaz = gxGetMLi(FilRaz, 2, 25)
		
		&TipoFrete = 'FRETE:' + UPPER(Trim(PedTipFrt.EnumerationDescription()))
		
		//ENDEREÇO ENTREGA
		&PesEnd = trim(PedCliEntLogNro)
		&PesCidUfeCod = PedCliEntUfeCod
		&PesCep = 'CEP: ' + trim(FormataCEP.Udp(PedCliEntCep))
		&PesBai = substr(trim(PedCliEntBai), 1, 33)
		&PesCidNom = substr(trim(PedCliEntCidNom), 1, 33)
		if not PedCliRef.IsEmpty()
			&PesRef = 'REF: '+ PedCliRef.Trim()
		EndiF
	
		//NOTA E PEDIDO
	
		&Nota = ''
		If &NfeNUm <> 0
			&Nota = trim(str(&NfeNUm))
		Else
			&Nota = '      '
		EndIf
		
		If &PedCod <> 0
			&PedidoNota = 'PED: ' + trim(Str(PedCod))
		Else
			&PedidoNota = 'PED:       '
		EndIF
		
		&PedidoNota += ' / NF: ' + trim(&Nota) 		
		
		//TRANPORTADORA 
		&PedTraRedRaz = PedTraRedRaz.Trim()
		&PesFonNum = RetornaPrimeiroTelefone.Udp(EmpCod, PedTraRedCod)
		If not &PesFonNum.IsEmpty()
			&PesFonNum =  FormataFONE.Udp(&PesFonNum)
			&FoneTransportadora = 'FONE: ' + trim(&PesFonNum)
		EndIF
		
		//DADOS REMETENTE
		&FilLog = FilLog.Trim() 
		If not FilNro.IsEmpty()
			&FilLog += ', ' + trim(FilNro)
		Else
			&FilLog += ', S/N'
		EndiF
		&FilBai = FilBai.Trim()
		&FiLCidNom = 'CEP: ' + trim(FilCep)
		
		Exit
	EndFor
Else
	//CLIENTE
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedCliCod
		
		&PesRaz = substr(PesRaz,1,40)
		
		//&TipoFrete = 'FRETE:' + UPPER(Trim(PedTipFrt.EnumerationDescription()))
		
		//ENDEREÇO ENTREGA
		&PesEnd = trim(PesEntLogNro)
		&PesCidUfeCod = PesEntUfeCod
		&PesCep = 'CEP: ' + trim(FormataCEP.Udp(PesEntCep))
		&PesBai = substr(trim(PesEntBai), 1, 33)
		&PesCidNom = substr(trim(PesEntCidNom), 1, 33)
		if not PesRef.IsEmpty()
			&PesRef = 'REF: '+PesRef.Trim()
		EndIF

		Exit
	EndFor
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PedTraSaiCod
		
		&Nota = '      '
		
		&PedidoNota = 'PED:       '
		
		&PedidoNota += ' / NF: ' + trim(&Nota) 

		//TRANPORTADORA 
		&PedTraRedRaz = PesRaz.Trim()
		&PesFonNum = RetornaPrimeiroTelefone.Udp(EmpCod, PesCod)
		If not &PesFonNum.IsEmpty()
			&PesFonNum =  FormataFONE.Udp(&PesFonNum)
			&FoneTransportadora = 'FONE: ' + trim(&PesFonNum)
		EndIF
		
		Exit
	EndFor

	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		//DADOS REMETENTE
		
		&FiLRaz = gxGetMLi(FilRaz, 1, 25)
		&AuxFiLRaz = gxGetMLi(FilRaz, 2, 25)
		
		&FilLog = FilLog.Trim() 
		If not FilNro.IsEmpty()
			&FilLog += ', ' + trim(FilNro)
		Else
			&FilLog += ', S/N'
		EndiF
		&FilBai = FilBai.Trim()
		&FiLCidNom = 'CEP: ' + trim(FilCep)
	EndFor
EndIF

//VOLUME
&FinDigitos = trim(Str(&FinPedQtdVol))
&QtdDigitos = &FinDigitos.Length()
If &QtdDigitos = 1
	&QtdDigitos = 2
EndIF


&Etiqueta = &FinPedQtdVol
Do While &Etiqueta >= &IniPedQtdVol
	
	&Volume = 'VOL: ' + padL(trim(str(&Etiqueta)), &QtdDigitos, '0') + '/' + padL(trim(Str(&FinPedQtdVol)), &QtdDigitos, '0')
	
	if &ModeloEtiqueta = 'C'
		print EtiquetaModelo1opcaoA	
	Else
		print OpcaoB
	EndIF

	&Etiqueta -= 1
EndDo

]]></Source>
