      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &SDTNotificationsData.Count > 0
	&HTMLNotificationsData = Format('<div class="%1"><div class="%2">%3</div>', ThemeClass:NotificationContent, ThemeClass:NotificationTitle, Format("You have %1 new notifications", &SDTNotificationsData.Count.ToString().Trim()))
	For &SDTNotificationsDataItem in &SDTNotificationsData
		&HTMLNotificationsData += Format('<a href="' + &SDTNotificationsDataItem.NotificationLink +'"><div class="%9"><i class="%1"></i><div class="%2"><span class="%3">%4</span><span class="%5">%6</span> <span class="%7">%8</span></div></div>', &SDTNotificationsDataItem.NotificationIconClass,ThemeClass:NotificationItemRight, ThemeClass:NotificationItemTitle,&SDTNotificationsDataItem.NotificationTitle,ThemeClass:NotificationItemDescription, &SDTNotificationsDataItem.NotificationDescription, ThemeClass:NotificationItemDatetime, &SDTNotificationsDataItem.NotificationDatetime.ToFormattedString(), ThemeClass:NotificationItemContent)
	EndFor
	&HTMLNotificationsData += "</div>"
Else
	&HTMLNotificationsData = Format('<div class="%1"><div class="%2">%3</div></div>', ThemeClass:NotificationContent, ThemeClass:NotificationTitle, "No new notifications")
Endif
]]></Source>
