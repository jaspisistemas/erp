      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Abreviacao = ''
For Each Order EmpCod, FilCod, CreCod
	Where EmpCod = &Empcod
	Where FilCod = &FilCod
	Where CreCod = &CreCod
	
	Do CAse
		Case CrePedCod > 0
			&CrePedCod = CrePedCod
			do 'GetPedido'
			
		Case CreRenDstCod > 0
			&Abreviacao = 'REN.' + trim(str(CreRenDstCod))
			
		Case CreFrtCod > 0
			&Abreviacao = 'FT.' + trim(str(CreFrtCod))
			
		Case CreNfeCod > 0
			&CreNfeFilCod = CreNfeFilCod
			&CreNfeCod = CreNfeCod
			do 'GetNFE'
			
			if &NfeNum.IsEmpty()
				&Abreviacao = 'NF.' + trim(str(CreNfeCod))
			Else
				&Abreviacao = 'NF.' + trim(str(&NfeNum))
			Endif
		Case CreCteCod > 0 	
			&Abreviacao = 'CT.' + trim(str(CreCteCod))
			
			
		Case CreAdmCod > 0
			&Abreviacao = 'ADM.' + trim(str(CreAdmCod))
			
		Case CreOriDup = OrigemDuplicata.AdiantamentoPedido
			If CreAdtCreCod > 0
				&Abreviacao = 'ADT.' + trim(str(CreAdtCreCod))
			Else
				&Abreviacao = 'ADT'
			EndIf
		Otherwise 
			&Abreviacao = 'AVULSA'
			
			Do Case
				Case Not CreNumConGNRE.IsEmpty() and Not CreNumConGNRE.IsNull()
					&Abreviacao = 'GNRE.' + Trim(CreNumConGNRE)
					
			EndCase
			
	EndCase


	Exit
EndFor
	

Sub 'GetNFE'
	&NfeNum.SetEmpty()
	For Each Order EmpCod, FilCod, NfeCod
		where EmpCod = &Empcod
		Where FilCod = &CreNfeFilCod
		Where NfeCod = &CreNfeCod
		&NfeNum = NfeNum
		Exit
	EndFor
EndSub

Sub 'GetPedido'	
	For Each Order EmpCod, FilCod, PedCod
		where EmpCod = &Empcod
		Where FilCod = &FilCod
		Where PedCod = &CrePedCod
		
		if PedStsGer = Pedido_Gerado.OrdemCarregamento
			&Abreviacao = 'OC'
		Else
			RetornaAbreviacaoTipoLancamento.Call(LctTip, &Abreviacao)
		Endif
		
		&Abreviacao += '.' + trim(str(PedCod))
		
		Exit
	When none
		&Abreviacao += 'PED.' + trim(str(&CrePedCod))
	Endfor
EndSub
	
	
]]></Source>
