      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem.SetEmpty()
&CountErro.SetEmpty()
if &RenCod.IsEmpty()
	return
Endif

	
//CANCELAR todas duplicatas com essa renegociação
For Each order EmpCod, FilCod, CreCod //Duplicatas
	Where EmpCod = &EmpCod
	Where CreRenDstCod = &RenCod
	CreSts = Status_Duplicata.CANCELADA
	&FilCod = FilCod
	&CreCod = CreCod
	Do 'VerificaRenegociacao'
	
	if &CountErro.IsEmpty()
		if CreVlrSdo <> CreVlrDup
			For Each order EmpCod, FilCod, CreCod, CrePagCod //DuplicatasPagamento
				Where EmpCod = &EmpCod
				where FilCod = &FilCod
				where CreCod = &CreCod
				
				&CreMovCod = CreMovCod
				Do 'Movimento'
				if &CountErro > 0
					exit
				else
					if &IsCaixaFechado = false and &IsCaixaFechadoEmissao = false
						&IsEliminaTransferencia = true
						&IsEliminaPgtoDP = true
						&IsEliminaFolhaPgto = true
						DeletaMovimentoComDependencias.Call(&EmpCod,&CreMovCod,&IsEliminaTransferencia,&IsEliminaFolhaPgto,&IsEliminaPgtoDP,false) //atualiza tbm saldo das contas
					EndIf
				EndIf
			EndFor
		else
			prcCancelarRenegociacaoReceber.Call(&EmpCod,&RenCod)
		EndIf
	else
		&Mensagem += 'Existe uma duplicata renegociada que gerou outra renegociação e não pode ser cancelada.'
	EndIf
	
EndFor

//CANCELAR PAGAMENTO RENEGOCIADO
For Each order EmpCod, FilCod, CreCod, CreRenCod //DuplicatasRenegociacao
	Where EmpCod = &EmpCod
	Where CreRenOriCod = &RenCod
	
	&sdtDuplicatasItem = New()
	&sdtDuplicatasItem.CreCod = CreCod
	&sdtDuplicatasItem.FilCod = FilCod
	&sdtDuplicatas.Add(&sdtDuplicatasItem)
	
	Delete
EndFor

Commit

For &sdtDuplicatasItem in &sdtDuplicatas
	AtualizaSaldoDuplicata.Call(&EmpCod, &sdtDuplicatasItem.CreCod, &sdtDuplicatasItem.FilCod)	
EndFor

if &CountErro.IsEmpty()
	&Mensagem.SetEmpty()
	commit
else 
	&IsOk = false
	return
EndIf


Sub 'Movimento'
	
	&IsErro = true
	For Each Order EmpCod, MovCod //Movimento
		Where EmpCod = &EmpCod
		Where MovCod = &CreMovCod
		PrcValidaCaixaAberto.Call(EmpCod, MovCtaBanCod, MovDtaCon, &IsCaixaFechado, &Mensagem)
		PrcValidaCaixaAberto.Call(EmpCod, MovCtaBanCod, MovDta, &IsCaixaFechadoEmissao, &MensagemEmissao)
		Do Case
			Case &IsCaixaFechado = true
				Msg(&Mensagem)
				
			CAse &IsCaixaFechadoEmissao = true
				&Mensagem = &MensagemEmissao
			Case not MovFecCod.IsNull() and not MovFecCod.IsEmpty()
				&Mensagem = 'Movimento já fechado pelo PDV'
				&IsCaixaFechado = TRUE
			case MovTip = TipoMovimento.DescontoDuplicataCheque
				&Mensagem = 'Não é possível excluir movimentos de duplicatas e/ou cheques descontados.'
			otherwise 
				&IsErro = false
		EndCase
		Exit		
	EndFor
	
	if &IsErro = true
		&CountErro += 1
	EndIF
	
EndSub

Sub 'VerificaRenegociacao'
	
	//PERTENCE A OUTRA RENEGOCIACAO JA
	//verifica se esta duplicata é mãe de outra renegociação
	For Each order EmpCod, FilCod, CreCod, CreRenCod //DuplicatasRenegociacao
		Where EmpCod = &EmpCod
		where FilCod = &FilCod
		where CreCod = &CreCod
		where CreRenOriCod > 0
		&CountErro += 1 //msg logo depois que chama essa sub pelo count erro
		exit
	EndFor
	
EndSub
]]></Source>
