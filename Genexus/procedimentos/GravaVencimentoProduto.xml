      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&ProVctCod = &parProVctCod



if &ProVctCod = 0
	For Each ORder EmpCod, FilCod, ProCod, ProGraCod, ProVctCod 
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &Procod
		Where ProGraCod = &ProGraCod
		Where ProVctDta = &ProVctDta
		Where ProVctSts <> 'N'
		&ProVctCod = ProVctCod
	EndFor	
EndIF

	
If &ProVctCod = 0
	For Each ORder EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &Procod
		Where ProGraCod = &ProGraCod
		
		EstUltVctCod = EstUltVctCod + 1
		Commit
		
		&ProVctCod = EstUltVctCod
		Exit
	EndFor
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		ProCod = &Procod
		ProGraCod = &ProGraCod
		ProVctCod = &ProVctCod
		ProVctDtaReg = serverdate()
		ProVctDta = &ProVctDta
		ProVctQtd = &ProVctQtd
		ProVctLot = &ProVctLot
		//	ProVctSts
	EndNew
	
	Commit
Else
	For Each ORder EmpCod, FilCod, ProCod, ProGraCod, ProVctCod 
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &Procod
		Where ProGraCod = &ProGraCod
		Where ProVctCod = &ProVctCod
		
		ProVctDtaReg = serverdate()
		ProVctDta = &ProVctDta
		ProVctQtd = &ProVctQtd
		ProVctLot = &ProVctLot
		//	ProVctSts
		Exit
	EndFor

	Commit
Endif
]]></Source>
