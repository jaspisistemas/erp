      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaSoNumeros.Call(&PraParNom, &AuxPraParNom)
&ParSaida = ''
&PosIni  = 1

Do While &Posicao <= 300
    &Dias = val(substr(&AuxPraParNom,&PosIni,3))
 
    if &Dias > 0
		&ParSaida += padL(Substr(&AuxPraParNom,&PosIni,3), 3, '0') + ' '       
    endif
	
    &Posicao += 1
	&PosIni += 3
EndDo

&ParSaida = trim(&ParSaida)
]]></Source>
