      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[for each order EmpCod, LayNom, LayCod
	where EmpCod = &EmpCod
	where LaySeq = 0
	where LayTip = Tipo_Layout.MAQUININHA_A
	where LayNom like '%' + &LayNom + '%'
	
	&sdtLayoutItem = new()
	&sdtLayoutItem.Campo.FromJson(LayArq)
	&sdtLayoutItem.sdtLayCod = LayCod
	&sdtLayoutItem.sdtLayNom = LayNom
	&sdtLayoutItem.sdtLaySeq = LaySeq
	&sdtLayoutItem.sdtLayTip = LayTip
	&sdtLayout.Add(&sdtLayoutItem)
EndFor
]]></Source>
