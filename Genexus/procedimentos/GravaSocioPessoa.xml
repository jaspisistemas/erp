      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, PesCod
	where EmpCod = &EmpCod
	where PesCod = &PesCod
	&PesRaz = PesRaz
	&PesPrmEml = PesPrmEml
	&PesPrmFon = PesPrmFon
		
	Exit
EndFor


RetornaSoNumeros.Call(&PesSocCpf,&PesSocNumCpfCnpj)
Do case 
	case &OqueFazer = 'INS' //New PessoaSocios, e atualiza Pessoa
		Do 'New'
		
	case &OqueFazer = 'UPD' //Atualiza PessoaSocios e Pessoa
		Do 'Update'
		
EndCase

Do 'UpdatePessoa'

Commit

&AuxPesRaz = Substr(&PesRaz, 1, 15) + ' [SOCIO:'+ &PesSocNom.Trim() +']'
prcAtualizaAniversariantes.Call('ADD', &Empcod, &AuxPesRaz, TipoAniversario.Socio, Status_SimNao.Sim, 0, '', &PesSocDtaNas, &PesCod, &PesSocCod, &PesPrmFon, &PesPrmEml)


Sub 'New'
	&TabelaVarchar = 'PESSOASOCIOS'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	
	if &PesSocCod = 0 
		For Each Order EmpCod, PesCod, (PesSocCod)
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			&PesSocCod = PesSocCod
			Exit
		Endfor
		&PesSocCod += 1
	EndIf
	New
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesSocCod = &PesSocCod
		PesSocCpf = &PesSocCpf
		PesSocNumCpfCnpj = &PesSocNumCpfCnpj
		PesSocNom = &PesSocNom
		PesSocDtaNas = &PesSocDtaNas
		PesSocSts  = &PesSocSts
		PesSocAdm = &PesSocAdm
	EndNew
	
	commit
	
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&PesCod))
		&LogErpRegCod2 = trim(str(&PesSocCod))
		&LogErpRegTip = TrnMode.Insert
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocCpf', '', trim(toformattedString(&PesSocCpf)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocNumCpfCnpj', '', trim(toformattedString(&PesSocNumCpfCnpj)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocNom', '', trim(toformattedString(&PesSocNom)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocDtaNas', '', trim(toformattedString(&PesSocDtaNas)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocSts', '', trim(toformattedString(&PesSocSts)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocAdm', '', trim(toformattedString(&PesSocAdm)), &LogErpRegGUID )
	Endif
	//GRAVA LOG
	
EndSub


Sub 'Update'	
	
	&TabelaVarchar = 'PESSOASOCIOS'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)

	For each order EmpCod,PesCod,PesSocCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		where PesSocCod = &PesSocCod
		
		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(Str(PesCod))
			&LogErpRegCod2 = trim(str(PesSocCod))
			&LogErpRegTip = TrnMode.Update
			&LogErpRegGUID.SetEmpty()
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocCpf', trim(toformattedString(PesSocCpf)), trim(toformattedString(&PesSocCpf)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocNumCpfCnpj', trim(toformattedString(PesSocNumCpfCnpj)), trim(toformattedString(&PesSocNumCpfCnpj)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocNom', trim(toformattedString(PesSocNom)), trim(toformattedString(&PesSocNom)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocDtaNas', trim(toformattedString(PesSocDtaNas)), trim(toformattedString(&PesSocDtaNas)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocSts', trim(toformattedString(PesSocSts)), trim(toformattedString(&PesSocSts)), &LogErpRegGUID )
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, &LogErpRegCod2, '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PesSocAdm', trim(toformattedString(PesSocAdm)), trim(toformattedString(&PesSocAdm)), &LogErpRegGUID )
		Endif
		//GRAVA LOG
		
		PesSocCpf = &PesSocCpf
		PesSocNumCpfCnpj = &PesSocNumCpfCnpj
		PesSocNom = &PesSocNom
		PesSocDtaNas = &PesSocDtaNas
		PesSocSts  = &PesSocSts
		PesSocAdm = &PesSocAdm
		exit
	EndFor

	commit
EndSub


Sub 'UpdatePessoa' //Sempre entra nessa sub
	
	For each order EmpCod,PesCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		PesAviCer = &PesAviCer
		PesDtaVctCer = &PesDtaVctCer
		PesEscCtbCod = &PesEscCtbCod
		PesObs = &PesObs
		exit
	EndFor
	
	commit
EndSub
]]></Source>
