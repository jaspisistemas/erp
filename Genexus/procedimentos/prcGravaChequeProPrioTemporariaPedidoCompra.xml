      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedTmpDupCod = &parPedTmpDupCod

Do Case
	Case &OqueFazer = 'ADD' //Adiciona/Altera
		
		For Each Order EmpCod, FilCod, PedCod, PedTmpDupCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod 
			Where PedCod = &pedCod
			Where PedTmpDupCod = &PedTmpDupCod  
			
			PedTmpDtaEms = &CheDtaEmi
			PedTmpDupNro = trim(str(&CheNro))
			PedTmpFrpPgtoCod = &PedTmpFrpPgtoCod
			
			PedTmpDupVct = &CheDtaVct			
			PedTmpSem = &CheMot.ToString() //&PedTmpSem USADO PARA O MOTIVO PADRAO
			
			PedTmpPrz = 0
			IF (not &CheDtaVct.IsEmpty()) and (not &CheDtaEmi.IsEmpty())
				PedTmpPrz = (&CheDtaVct - &CheDtaEmi) 
			EndIf
			
			PedTmpDupVlr = &CheVlr			
			PedTmpDupCbrCod = 1
			
			PedTmpPlanCod = &PedTmpPlanCod
			PedTmpBanCod = &CheBanCod
			PedTmpAgeCod = &CheAgeCod
			PedTmpConCod = &CheCon
			PedTmpTitNom = &CheTitNom
			PedTmpTitCpf = &CheTitCpf
			PedTmpTitRg = &CheTitRg
			PedTmpTitFon = &CheTel
			PedTmpObs = &CheObs
			PedTmpCtaBanCod = &PedTmpCtaBanCod
			
			Exit
		When none
			
			&PedTmpDupCod = 0
			For Each Order EmpCod, FilCod, PedCod, (PedTmpDupCod)
				Where EmpCod = &EmpCod
				Where FilCod = &FilCod 
				Where PedCod = &pedCod
				&PedTmpDupCod = PedTmpDupCod
				Exit
			EndFor
			&PedTmpDupCod += 1
			
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				PedCod = &pedCod
				PedTmpDupCod = &PedTmpDupCod
				PedTmpDtaEms = &CheDtaEmi
				//PedTmpCreCod
				PedTmpDupNro = trim(str(&CheNro))
				PedTmpFrpPgtoCod = &PedTmpFrpPgtoCod
				PedTmpDupVct = &CheDtaVct
				
				PedTmpSem = &CheMot.ToString() // &PedTmpSem //USAR PARA O MOTIVO PADRAO
				
				PedTmpPrz = 0
				IF (not &CheDtaVct.IsEmpty()) and (not &CheDtaEmi.IsEmpty())
					PedTmpPrz = (&CheDtaVct - &CheDtaEmi) 
				EndIf
				
				PedTmpDupVlr = &CheVlr				
				PedTmpDupCbrCod = 1
				
				//PedTmpDtaPag
				PedTmpPlanCod = &PedTmpPlanCod
				//PedTmpCreCliCod
				PedTmpBanCod = &CheBanCod
				PedTmpAgeCod = &CheAgeCod
				PedTmpConCod = &CheCon
				PedTmpTitNom = &CheTitNom
				PedTmpTitCpf = &CheTitCpf
				PedTmpTitRg = &CheTitRg
				PedTmpTitFon = &CheTel
				PedTmpObs = &CheObs
				PedTmpCtaBanCod = &PedTmpCtaBanCod
				
				PedTmpSts = Status_SimNao.Nao
			EndNEw
			
		EndFor
		
		commit
	Case &OqueFazer = 'DEL' //ELIMINAR TEMPORARIA
		
		For Each Order EmpCod, FilCod, PedCod, PedTmpDupCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod 
			Where PedCod = &pedCod
			Where PedTmpDupCod = &PedTmpDupCod 
			
			if PedTmpSts = Status_SimNao.Nao 
				if PedTmpCreCod = 0
					delete
				else
					PedTmpBanCod.SetEmpty()
					PedTmpAgeCod.SetEmpty()
					PedTmpConCod.SetEmpty()
					PedTmpDupNro.SetEmpty()
					PedTmpDupVlr.SetEmpty()
					PedTmpDupDtaFat.SetEmpty()
					PedTmpDupVct.SetEmpty()
					PedTmpTitNom.SetEmpty()
					PedTmpTitCpf.SetEmpty()
					PedTmpTitRg.SetEmpty()
					PedTmpTitFon.SetEmpty()
					PedTmpObs.SetEmpty()
					PedTmpCtaBanCod.SetEmpty()
					PedTmpDtaEms.SetEmpty()
				EndIf		
			EndIF			
		EndFor
		
		Commit
EndCase
]]></Source>
