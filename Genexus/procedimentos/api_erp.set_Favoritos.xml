      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	&sdtRetornowbs.Sts = 'J200'
	
	&FavRotAutCod = '#JDF:SD#'+ &parFavRotAutCod.Trim()
	
	&FavOrd = &parFavOrd
	
	Do Case
		Case &OqueFazer = 'ADD'		
			For Each ORder EmpCod, PesCod, FavRotAutCod //altera
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				where FavWebSmart = 'S' //SMART
				Where FavRotAutCod = &FavRotAutCod 
				
				FavRotAutNom = &FavRotAutNom
				FavOrd = &FavOrd
				
			When None
				new //insere
					EmpCod = &wwpContext.EmpCod
					PesCod = &wwpContext.PesCod
					FavRotAutCod = &FavRotAutCod 
					
					FavWebSmart = 'S' //SMART
					FavRotAutNom = &FavRotAutNom
					FavOrd = &FavOrd
				EndNEw
			EndFor
			
			Commit
			
			&sdtRetornowbs.Sts = 'J200'
			&sdtRetornowbs.Obs = 'Favorito adicionado com sucesso!'
			
		Case &OqueFazer = 'SOB'
			
			&FavOrd = 2
			For Each ORder EmpCod, PesCod, FavOrd //altera
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				where FavWebSmart = 'S' //SMART
							
				FavOrd = &FavOrd
				if FavRotAutCod = &FavRotAutCod 
					FavOrd -= 1
					&FavOrd -= 2
				Endif
			
				&FavOrd += 2
			EndFor
		
			Commit
			
			&sdtRetornowbs.Sts = 'J200'
			&sdtRetornowbs.Obs = 'Favorito alterado com sucesso!'
			
		Case &OqueFazer = 'DSC'		
			&FavOrd = 2
			For Each ORder EmpCod, PesCod, FavOrd //altera
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				where FavWebSmart = 'S' //SMART
				
				FavOrd = &FavOrd
				if FavRotAutCod = &FavRotAutCod 
					FavOrd += 1
					&FavOrd -= 2
				Endif
			
				&FavOrd += 2
			EndFor
			
			Commit
			
			&sdtRetornowbs.Sts = 'J200'
			&sdtRetornowbs.Obs = 'Favorito alterado com sucesso!'
			
		Otherwise
			For Each ORder EmpCod, PesCod, FavRotAutCod
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				where FavWebSmart = 'S' //SMART
				Where FavRotAutCod = &FavRotAutCod 
				delete
			EndFor
			
			Commit
			
			&sdtRetornowbs.Sts = 'J200'
			&sdtRetornowbs.Obs = 'Favorito removido com sucesso!'			
	EndCAse

Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
