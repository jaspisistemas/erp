      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'CÁLCULO DE JUROS LIVRE'
	&CreCliRaz = trim(Str(&CreCliCod)) +' - '+&CreCliRaz
	print Cabecalho
	Print Cliente
	Print Menu
End

For Each Order EmpCod,FunCod,TmpJurCliCod,(TmpJurCod)
	Where EmpCod = &EmpCod
	Where FunCod = &FunCod
	Where TmpJurCliCod = &CreCliCod
	Where TmpJurDia > 0
	&CreDupNro = TmpJurCreDup
	&DtaIni = TmpJurDtaIni
	&DtaFim = TmpJurDtaFim 
	&Dias   = TmpJurDia
	&TxtJur = TmpJurTxaJur 
	&TxaMlt = TmpJurTxaMlt
	&VlrTit = TmpJurVlrTit
	&OtrVlr = TmpJurOutVlr
	&VlrJur = TmpJurVlrJur
	&VlrMlt = TmpJurVlrMlt
	&VlrSdo = TmpJurVlrTot
	
	&TotDias += &Dias
	&TotOtrVlr += &OtrVlr
	&TotVlrJur += &VlrJur
	&TotVlrSdo += &VlrSdo
	&TotVlrMlt += &VlrMlt
	Print Dados
EndFor
Print Total

Footer
	print Rodape
End
]]></Source>
