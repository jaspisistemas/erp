      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&PedDtaFAt.SetEmpty()
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	Do CAse
		Case PedSts = Status_Pedido.FECHADO
			&PedDtaFAt = PedDtaFat
		Case PedSts <> Status_Pedido.CANCELADO
			&PedDtaFic = PedDtaFic					
	EndCase

	Exit
EndFor

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon154_NaoGravarDataEmissao, &TCon154_NaoGravarDataEmissao)

if &TCon154_NaoGravarDataEmissao <> 'N' 
	Do CAse
		CAse not &PedDtaFic.IsEmpty() and &PedDtaFAt.IsEmpty()
			&PedDtaFAt = &PedDtaFic		
		Case &PedDtaFAt.IsEmpty() and not &NFeDtaEms.IsEmpty()
			&PedDtaFAt = &NFeDtaEms
	EndCase
Endif

]]></Source>
