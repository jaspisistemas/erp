      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

if &Tipo <> 2 //LANCAMENTO
	&PeriodoAdiantamento = 'REFERÊNCIA: ' + padL(trim(str(&MovFunMes)), 2, '0') + '/'+ trim(str(&MovFunAno))
Else
	&PeriodoAdiantamento = 'Lançamento: ' + trim(toformattedString(&DtaIni)) + ' à '+ trim(toformattedString(&DtaFin))
Endif

Header
	&titulo = 'ADIANTAMENTOS DO PERÍODO'
	print Cabecalho
	If &IsSintetico =  false //ANALÍTICO
		Print Menu
	Else
		Print MenuSintetico
	EndIf
End

&TotMovVlr = 0
If &IsSintetico =  false //ANALÍTICO
	For each Order EmpCod,MovTip,MovFunCod,MovDtaCon
		Where EmpCod = &EmpCod
		Where MovDtaCon >= &DtaIni and MovDtaCon <= &DtaFin when &tipo = 2
		Where MovFunMes = &MovFunMes when &Tipo = 1
		Where MovFunAno = &MovFunAno when &Tipo = 1
		Where MovFunCod = &MovFunCod when not &MovFunCod.IsEmpty()
		Where MovTip = TipoMovimento.Adiantamento
		Where MovFunSts = &MovFunSts when not &MovFunSts.IsEmpty()
		Where MovSts.IsEmpty() or MovSts.IsNull() or MovSts <> Status_Caixa.Cancelado
		Where MovItmSts.IsEmpty() or MovItmSts.IsNull() or MovItmSts <> Status_Caixa.Cancelado
		
		&MovCod = MovCod
		&MovDtaCon = MovDtaCon
		&AuxMovFunCod = MovFunCod
		Do 'NomeFuncionario'
		&MovHor = MovHor
		&MovVlr = MovVlr
		&GridMovFunAno = MovFunAno		
		&GridMovFunMes = Upper(CMonth(yMDtoD(year(&Today),MovFunMes,1)))
		&GridMovItmVlr = MovItmVlr
		
		If MovFunSts = Status_AbertoFechado.Aberto
			&GridStatus = 'Aberto'
		Else
			&GridStatus = 'Fechado'
		EndIf
	
		&TotMovVlr += MovItmVlr
		Print Dados
		
		If &MostrarObs = Status_SimNao.Sim
			Print ObsLcto
		EndIf		
	EndFor
	
	Print TotalAna	
Else //SINTÉTICO
	&AuxMovFunCod = 0
	For each Order EmpCod,MovTip,MovFunCod,MovDtaCon
		Where EmpCod = &EmpCod
		Where MovDtaCon >= &DtaIni and MovDtaCon <= &DtaFin when &tipo = 2
		Where MovFunMes = &MovFunMes when &Tipo = 1
		Where MovFunAno = &MovFunAno when &Tipo = 1
		Where MovFunCod = &MovFunCod when not &MovFunCod.IsEmpty()
		Where MovTip = TipoMovimento.Adiantamento
		Where MovFunSts = &MovFunSts when not &MovFunSts.IsEmpty()
		Where MovSts.IsEmpty() or MovSts.IsNull() or MovSts <> Status_Caixa.Cancelado
		Where MovItmSts.IsEmpty() or MovItmSts.IsNull() or MovItmSts <> Status_Caixa.Cancelado
		
		IF &AuxMovFunCod <> MovFunCod
			If not &AuxMovFunCod.IsEmpty()
				Do 'NomeFuncionario'				
				Print DadosSintetico
				&MovVlr = 0
			EndIf
		EndIf
		&MovVlr    += MovItmVlr
		&TotMovVlr += MovItmVlr
		&AuxMovFunCod = MovFunCod
	EndFor
	Do 'NomeFuncionario'				
	Print DadosSintetico
	Print Total	
EndIf


Footer
	print Rodape
End

Sub 'NomeFuncionario'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &AuxMovFunCod
		&MovFunNom = PesCodRaz
		exit
	EndFor
EndSub 
]]></Source>
