        <Source><![CDATA[
Do 'UltimoCodigo'

&CreDupNro = 'REN'
&PedCliCbrCod = 1

&PedPraParNom = '001'
RetornaVencimentosParcela.Call(&EmpCod, 0, '001', ReceberPagar.Receber, &PedDtaFat, &sdtVencimentos, &DscPar)
For &sdtVencimentosItem in &sdtVencimentos
	&Parcela += 1
	&CreDtaVct(&Parcela) = &sdtVencimentosItem.CreDtaVct 
EndFor		

Do 'DadosCartao'

commit


Sub 'UltimoCodigo'
	&PedTmpDupCod = 0
	For Each Order EmpCod, FilCod, PedCod, (PedTmpDupCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		&PedTmpDupCod = PedTmpDupCod
		Exit
	EndFor
	&PedTmpDupCod += 1
EndSub



Sub 'DadosCartao'
	For each order EmpCod,BanCarCod
		Where EmpCod = &EmpCod
		Where BanCarCod = &BanCarCod
		
		Do Case
			Case &CarForPag = 2 and &CarParQtd > 1   // Crédito Parcelado
				&Taxa = 0
				&BanCarDiaCrePraDms = BanCarDiaCrePraDms
				For each order EmpCod,BanCarCod,BanCarCrePar
					Where BanCarCrePar = &CarParQtd
					
					&BanCarVlrJurPar = (BanCarVlrJurPar / 100)
					&Taxa = BanCarPerCrePra
					Exit
				EndFor
				
				//PEGA DA FORMA NOVA DA BANDEIRA CADASTRADA NA ADQUIRENCIA
				if not &PedTmpTitNom.IsEmpty()
					For Each Order EmpCod, BanCarCod, BanItemNom, BanItemCredDeb, BanItemPar
						Where BanItemNom.ToUpper() = &PedTmpTitNom.ToUpper()
						Where BanItemCredDeb = 'C'
						Where BanItemPar = &CarParQtd
						
						&Taxa = BanItemTax
						Exit
					EndFor
					//PEGA DA FORMA NOVA DA BANDEIRA CADASTRADA NA ADQUIRENCIA
				Endif
				
				&montante = &CarMovVlr + (&CarMovVlr * &BanCarVlrJurPar)
				//&PedTmpDupCarJur = 0
				&PrimeiraParcelaSemJuros = round(&CarMovVlr / &CarParQtd,2)
				&PrimeiraParcela = round(&montante / &CarParQtd,2)
				//-33,33
				
				&resto = &CarMovVlr - (&PrimeiraParcelaSemJuros * &CarParQtd)
				&DemaisParcelasSemJuros = &PrimeiraParcelaSemJuros
				&PrimeiraParcelaSemJuros += &resto
				
				&resto = &montante - (&PrimeiraParcela * &CarParQtd)
				&DemaisParcelas = &PrimeiraParcela
				&PrimeiraParcela += &resto
				//				If &resto > 0
				//					&PedTmpDupCarJur = &resto
				//				Else
				//					&PedTmpDupCarDes = &resto
				//				EndIf
				
				&PedTmpDupCarJur = &PrimeiraParcela - &PrimeiraParcelaSemJuros
				//&DemaisParcelas = &PrimeiraParcela + (&PrimeiraParcela * &BanCarVlrJurPar)
				&CreVlrDup      = &PrimeiraParcela                       //valor da primeira parcela para gravar
				&AuxCreDtaVct   = &CarCreDtaVct + BanCarDiaCrePraPri //Primeiro Vcto parcela para gravar
				If DoW(&AuxCreDtaVct) = 7
					&AuxCreDtaVct += 2
				Else
					If DoW(&AuxCreDtaVct) = 1
						&AuxCreDtaVct += 1
					EndIF
				EndIf
				
				&AuxPar = 1
				Do 'AddCartao'
				
				&AuxPar+=1
				
				Do While &AuxPar <= &CarParQtd 
					&PedTmpDupCarJur = (&DemaisParcelas - &DemaisParcelasSemJuros)
					&CreVlrDup  = &DemaisParcelas
					&AuxCreDtaVct += &BanCarDiaCrePraDms
					If DoW(&AuxCreDtaVct) = 7
						&AuxCreDtaVct += 2
					Else
						If DoW(&AuxCreDtaVct) = 1
							&AuxCreDtaVct += 1
						EndIF
					EndIf
					&AuxPar+=1
					Do 'AddCartao'
				EndDo				
				
			Case &CarForPag = 2 and &CarParQtd = 1   //Crédito a Vista
				&Taxa = BanCarPerCreVis
				&AuxCreDtaVct = &CarCreDtaVct + BanCarDiaCreVis
				
				//PEGA DA FORMA NOVA DA BANDEIRA CADASTRADA NA ADQUIRENCIA
				if not &PedTmpTitNom.IsEmpty()
					For Each Order EmpCod, BanCarCod, BanItemNom, BanItemCredDeb, BanItemPar
						Where BanItemNom.ToUpper() = &PedTmpTitNom.ToUpper()
						Where BanItemCredDeb = 'C'
						Where BanItemPar = 1
						
						&Taxa = BanItemTax
						Exit
					EndFor
					//PEGA DA FORMA NOVA DA BANDEIRA CADASTRADA NA ADQUIRENCIA
				Endif
				
				&CreVlrDup = &CarMovVlr
				If DoW(&AuxCreDtaVct) = 7
					&AuxCreDtaVct += 2
				Else
					If DoW(&AuxCreDtaVct) = 1
						&AuxCreDtaVct += 1
					EndIF
				EndIf
				Do 'AddCartao'
				
			Case &CarForPag = 1                      // Débito
				&Taxa = BanCarPerDeb
				&AuxCreDtaVct = &CarCreDtaVct + BanCarDiaDeb
				//PEGA DA FORMA NOVA DA BANDEIRA CADASTRADA NA ADQUIRENCIA
				if not &PedTmpTitNom.IsEmpty()
					For Each Order EmpCod, BanCarCod, BanItemNom, BanItemCredDeb, BanItemPar
						Where BanItemNom.ToUpper() = &PedTmpTitNom.ToUpper()
						Where BanItemCredDeb = 'D'
						//Where BanItemPar = 1
						
						&Taxa = BanItemTax
						Exit
					EndFor
					//PEGA DA FORMA NOVA DA BANDEIRA CADASTRADA NA ADQUIRENCIA
				Endif
				
				
				&CreVlrDup = &CarMovVlr
				If DoW(&AuxCreDtaVct) = 7
					&AuxCreDtaVct += 2
				Else
					If DoW(&AuxCreDtaVct) = 1
						&AuxCreDtaVct += 1
					EndIF
				EndIf
				Do 'AddCartao'
		EndCase
		Exit
	EndFor
EndSub



Sub 'AddCartao'
	
	Do 'UltimoCodigo'
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedTmpDupCod = &PedTmpDupCod
		PedTmpCreCod = 0
		PedTmpFrpPgtoCod = &PedTmpFrpPgtoCod
		&AuxCreDupNro = trim(&CreDupNro) +'-'+ltrim(str(&PedTmpDupCod))
		PedTmpDupNro =  trim(&AuxCreDupNro)
		PedTmpDupVlr = &CreVlrDup
		PedTmpDupVct = &AuxCreDtaVct
		PedTmpDupCarJur = &PedTmpDupCarJur
		PedTmpDupCarDes = &PedTmpDupCarDes
		&PedTmpSem = substr(cdow(&AuxCreDtaVct), 1, 3)
		PedTmpSem = &PedTmpSem
		
		&PedTmpPrz = (&AuxCreDtaVct - &CarCreDtaVct) 
		PedTmpPrz = &PedTmpPrz
		PedTmpDupTxa = &Taxa
		PedTmpDupBanCarCod = &BanCarCod
		PedTmpDupCreDeb = &CarForPag
		PedTmpTitNom = &PedTmpTitNom
		if &CarPlanCod.IsEmpty()
			RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon044_PlanoRecCliente, &TCon044_PlanoRecCliente)
			RetornaCodigoPlanoCOntas.Call(&EmpCod, &TCon044_PlanoRecCliente, &PlanCod)
		Else
			&PlanCod = &CarPlanCod
		EndiF
		PedTmpPlanCod = &PlanCod
		PedTmpCreCliCod = &PedTmpCreCliCod
		PedTmpDupCarArqc = &CreCarArqc
		PedTmpDupCarNroAut = &CreCarNroAut
	    do Case
			Case &CreCbrCod <> 0
				PedTmpDupCbrCod = &CreCbrCod
			Case &PedCliCbrCod = 0
		        PedTmpDupCbrCod = 1
		    Otherwise
		        PedTmpDupCbrCod = &PedCliCbrCod
	    EndCase
		
		PedTmpSts = Status_SimNao.Nao
	EndNew
	Commit
EndSub
]]></Source>
