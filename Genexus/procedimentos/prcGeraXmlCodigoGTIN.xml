      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)					//## Retorna o caminho dos diretórios da Empresa/Filial informada ##\\

&NomeXmlRetorno = &SdtConfiguracoesPasta.PastaNFretorno+ trim(&ProBar)+ '-ret-consGTIN.xml'	//## Define o nome do caminho para a busca do arquivo ##\\
&File.Source = &NomeXmlRetorno																//## Busca um arquivo.xml de retorno ##\\
If &File.Exists()																			//## Se o arquivo existir, o mesmo é excluido ##\\
    &File.Delete()
EndIf

&Nome_enviar = &SdtConfiguracoesPasta.PastaNFenvio+ trim(&ProBar)+ '-consGTIN.xml'			//## Define o nome e o caminho do arquivo.xml ##\\

&XMLWriter.Open(&Nome_enviar)																//## Abre o arquivo ##\\
&XMLWriter.WriteStartDocument('utf-8')														//## Define o encoding do arquivo ##\\

&XMLWriter.WriteStartElement('consGTIN')													//## Define um elemento composto ##\\

	&XMLWriter.WriteAttribute('versao','1.00')												//## Define um atributo ao elemento composto acima ##\\
	&XMLWriter.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')					//## Define um atributo ao elemento composto acima ##\\

		&XMLWriter.WriteElement('GTIN',&ProBar)												//## Define um elemento simples. Esta TAG se encontra dentro do elemento composto ##\\
		&XMLWriter.WriteEndElement()														//## Fecha o elemento simples ##\\
	
&XMLWriter.WriteEndElement()																//## Fecha o elemento composto ##\\

&XMLWriter.Close()																			//## Fecha o arquivo ##\\
]]></Source>
