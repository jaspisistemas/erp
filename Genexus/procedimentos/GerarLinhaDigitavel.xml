      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[Do 'CalculoLinhaDigitavel'

Sub 'CalculoLinhaDigitavel'
	&PriCampo = substr(&CodigoBarras,1,4)+substr(&CodigoBarras,20,5) // código de Banco, código da moeda, as cinco primeiras posições do campo livre e o dígito verificador deste campo
	Do 'CalculaDigitoDAC_1' 
	&SegCampo = substr(&CodigoBarras,25,10)
	Do 'CalculaDigitoDAC_2' 
	&TerCampo = substr(&CodigoBarras,35,10)
	Do 'CalculaDigitoDAC_3' 
	&QuaCampo = substr(&CodigoBarras,5,1)
	&QuiCampo = substr(&CodigoBarras,6,14)
	
	&linhadig = trim(&PriCampo)+trim(&SegCampo)+trim(&TerCampo)+trim(&QuaCampo)+trim(&QuiCampo)
	&linhadig = TRIM(&linhadig)
	&linhadig = substr(&linhadig,1,5)+'.'+substr(&linhadig,6,5)+' '+substr(&linhadig,11,5)+'.'+substr(&linhadig,16,6)+' '+substr(&linhadig,22,5)+'.'+substr(&linhadig,27,6)+' '+substr(&CodigoBarras,5,1)+' '+substr(&linhadig,34,16)
	&linhadig = TRIM(&linhadig)
EndSub

//################################################### CALCULO DO DAC 1,2,3 ######################################
Sub 'CalculaDigitoDAC_1' 
	&Posicao = 9
    &Referencia = 2
    &TotDig = 0
	&AUXResto = 0 
    Do While &Posicao >= 1
        &Numero = val(substr(trim(&PriCampo),&Posicao,1))
        &Res = &Numero * &Referencia
		If &Res > 9
			&X = val(SubStr(Trim(&Res.ToFormattedString()),1,1))
			&y = val(SubStr(trim(&Res.ToFormattedString()),2,1))
			&z = &X+&y
			&TotDig += &z
		Else
			&TotDig += &Res
		EndIf
		
        &Posicao -= 1
        &Referencia += 1
        if &Referencia = 3
            &Referencia = 1
        Endif
    EndDo
	&Resto = &TotDig
	Do while &Resto > 0
		&Resto -= 10
	EndDo
	&AUXResto = (&Resto * (-1))
	&PriCampo = Trim(&PriCampo)+trim(str(&AUXResto))
EndSub

Sub 'CalculaDigitoDAC_2' 
	&Posicao = 10
    &Referencia = 2
    &TotDig = 0
	
    Do While &Posicao >= 1
        &Numero = val(substr(trim(&SegCampo),&Posicao,1))
        &Res = &Numero * &Referencia
		If &Res > 9
			&X = val(SubStr(trim(str(&Res)),1,1))
			&y = val(SubStr(trim(str(&Res)),2,1))
			&z = &X+&y
			&TotDig += &z
		Else
			&TotDig += &Res
		EndIf
		
        &Posicao -= 1
        &Referencia += 1
        if &Referencia = 3
            &Referencia = 1
        Endif
    EndDo
	&Resto = &TotDig
	Do while &Resto > 0
		&Resto  -= 10
	EndDo
	&Resto = &Resto*(-1)
	&SegCampo = &SegCampo+trim(str(&Resto))
EndSub

Sub 'CalculaDigitoDAC_3' 
	&Posicao = 10
    &Referencia = 2
    &TotDig = 0
	
    Do While &Posicao >= 1
        &Numero = val(substr(trim(&TerCampo),&Posicao,1))
        &Res = &Numero * &Referencia
		If &Res > 9
			&X = val(SubStr(trim(str(&Res)),1,1))
			&y = val(SubStr(trim(str(&Res)),2,1))
			&z = &X+&y
			&TotDig += &z
		Else
			&TotDig += &Res
		EndIf
		
        &Posicao -= 1
        &Referencia += 1
        if &Referencia = 3
            &Referencia = 1
        Endif
    EndDo
	&Resto = &TotDig
	Do while &Resto > 0
		&Resto  -= 10
	EndDo
	&Resto = &Resto*(-1)
	&TerCampo = &TerCampo+trim(str(&Resto))
EndSub
//###########################################################################################
]]></Source>
