      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For &sdtNcmItem in &sdtNcm
	If &sdtNcmItem.IsSelect = true
		UltimoCodigoEmpresa.Call(domParCod.DECLARAPRODUTO, &EmpCod, 0, &DecCod)
		
		new
			EmpCod = &EmpCod
			DecCod = &DecCod
			DecDta = &DecDta
			DecPedFiLCod = &FilCod
			DecPedCod = &DecPedCod
			DecFilCod = &DecFilCod
			DecDolMin = &DecDolMin
			DecDolMax = &DecDolMax
			DecProcProd = &DecProcProd
			DecPrcProCod = &sdtNcmItem.PrcProCod
			DecFunCod = &DecFunCod
		EndNew
		Commit
		
		&DecNcmItmCod = 0
		For Each Order EmpCod, FilCod, PedCod, NcmCod,PrcProCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &DecPedCod
			Where NcmCod = &sdtNcmItem.NcmCod
			Where PrcProCod = &sdtNcmItem.PrcProCod when &sdtNcmItem.PrcProCod <> 0
			
			&DecNcmItmCod += 1
			new
				EmpCod = &EmpCod
				DecCod = &DecCod
				DecProCod = ProCod
				DecProVlr = PedVlrUntComDsc
			EndNEw
		EndFor
		Commit
		
		&PrcProCod = PrcProCod
		If PrcProCod <> 0
			Do 'BuscaElementosdoProcessoProdutivo'
		EndIf
	
		&DecNcmItmCod = 0
		for &sdtElementoItem in &sdtElemento
			if &sdtElementoItem.DecNcmCod <> 0 or &sdtElementoItem.DecNcmVlr <> 0 or &sdtElementoItem.DecNcmDes <> ''
				&DecNcmItmCod += 1
				new
					EmpCod = &EmpCod
					DecCod = &DecCod
					DecNcmItmCod = &DecNcmItmCod
					DecNcmCod = &sdtElementoItem.DecNcmCod
					DecNcmDes = &sdtElementoItem.DecNcmDes
					DecNcmVlr = &sdtElementoItem.DecNcmVlr
				EndNew
				Commit
			EndIF
		EndFOr
	EndiF
EndFor


Sub 'BuscaElementosdoProcessoProdutivo'
	&sdtElemento.Clear()
	For Each ORder EmpCod, PrcProCod,PrcProNcmCod
		Where EmpCod = &EmpCod
		Where PrcProCod = &PrcProCod
		&sdtElementoItem = new()
		&sdtElementoItem.DecNcmCod = PrcProNcmCod
		&sdtElementoItem.DecNcmDes = PrcProMatNom
		&sdtElementoItem.DecNcmVlr = PrcProMatVlr
		&sdtElemento.Add(&sdtElementoItem)
	endFor
EndSub

]]></Source>
