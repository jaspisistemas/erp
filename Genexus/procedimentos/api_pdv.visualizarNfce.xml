      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&NfeGuid = &parNfeGuid

if &NfeGuid.IsEmpty() or &NfeGuid = '00000000-0000-0000-0000-000000000000'
	Link('www.jaspi.com.br')
Else
	
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		Where NfeDeviceRandon = &NfeGuid
		
		&NomeArquivo = NfeChv.Trim() + '.pdf'
		RelJas057_ToSreen.Call(EmpCod, FilCod, NfeCod, &NomeArquivo)
		
		Exit
	EndFor
	
Endif
]]></Source>
