      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	
		if PesTip = TipOPessoa.FISICA
			ValidaCpfCnpj.Call(PesCpf, &Errado, 'S')
		Else
			ValidaCpfCnpj.Call(PesCnpj, &Errado, 'S')
		Endif
	
		Do CAse
			Case &Errado = 1
				&Mesagem = 'CPF/CNPJ Inválido.'
			Case PesBai.IsEmpty()
				&Mesagem = 'Bairro Inválido.'
			Case PesLog.IsEmpty()
				&Mesagem = 'Logradouro Inválido.'
			Case PesNro.IsEmpty()
				&Mesagem = 'N° Endereço Inválido.'
			Case PesCidNom.IsEmpty()
				&Mesagem = 'CEP Inválido.'
			Case PesCep.IsEmpty()
				&Mesagem = 'CEP Inválido.'
		EndCase
	
	Exit
EndFor

	
if not &Mesagem.IsEmpty()
	&IsErro = true
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
