      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&NfeArqXml = ''
&xmlCTe.Open(&CaminhoArquivoXml)    
Do While  not &xmlCTe.EOF
    &NfeArqXml += &xmlCTe.ReadRawXML()
    &xmlCTe.Read()
Enddo
&xmlCTe.Close()

LeituraXmlDanfe.Call(&NfeArqXml,&TNFeProc)


&CteModCod = &TNFeProc.NFe.infNFe.ide.mod //modelo da nota
//&NfeSer = val(&TNFeProc.NFe.infNFe.ide.serie)// serie
&NfeNum = val(&TNFeProc.NFe.infNFe.ide.nNF) //numero
If &TNFeProc.NFe.infNFe.ide.tpAmb = '1' //ambiente produção 1
	&FilAmbEms = TAmb.Producao
EndIf
&NfeChv = &TNFeProc.protNFe.infProt.chNFe //chave cte	
&cStat  = &TNFeProc.protNFe.infProt.cStat
&NfeVlrTot = val(&TNFeProc.NFe.infNFe.total.ICMSTot.vNF)

For &Vol in &TNFeProc.NFe.infNFe.transp.vols
	//	&PesoLiquido = Val(&vol.pesoL)
	&CteDocPes = val(&vol.pesoB)
	
EndFor
&vProd = 0
For &Dets in &TNFeProc.NFe.infNFe.dets
	
	If Val(&Dets.prod.vProd) > &vProd
		&vProd = Val(&Dets.prod.vProd)
		&ProNom = &Dets.prod.xProd
		&CteDocNcmPre = &Dets.prod.NCM
	EndIf

EndFor


If not &NfeNum.IsEmpty() and &CteModCod = '55' and &FilAmbEms = TAmb.Producao and &cStat.Trim() = '100'
	
	For each Order EmpCod,FilCod,CteCod,CteChv,(CteDocCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		Where CteDocChvNfe = &NfeChv
		CteDocVlrTotNtf = &NfeVlrTot
	When none
		For each Order EmpCod,FilCod,CteCod,(CteDocCod)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CteCod = &CteCod			
			&ForCteDocCod = CteDocCod
			exit
		EndFor
		&CteDocCod = &ForCteDocCod+1
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CteCod = &CteCod
			CteDocCod = &CteDocCod
			CteDocTip = TipoDocumentoCte.Nfe
			CteDocTotPso = &CteDocPes
			CteDocChvNfe = trim(&NfeChv)
			CteDocVlrTotNtf = &NfeVlrTot
			CteDocNro = substr(trim(&NfeChv),26,9)
			CteDocNcmPre = &CteDocNcmPre
		EndNew
		
	EndFor
Else
	Do case
		Case &cStat.Trim() <> '100'
			&mensagem = 'Nota não autorizada'
		Case &FilAmbEms = TAmb.Producao
			&mensagem = 'Nota em homologação'
		Otherwise
			&mensagem = 'Nota Inválida: ' + &NfeChv
	EndCase
EndIf

]]></Source>
