      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	&AuxPadObs = &PadObs
	
	if &OqueFazer = 'G'
		PadraoUsuarioHora.Call('G', &PadRotLin, &wwpContext.PesCod, &wwpContext.EmpCod, &AuxPadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	Else
		PadraoUsuarioHora.Call('L', &PadRotLin, &wwpContext.PesCod, &wwpContext.EmpCod, &AuxPadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	Endif
	
	&sdtRetornoWbsEtc.sts = 'J200'
	&sdtRetornoWbsEtc.obs = 'sucesso'
	
	&sdtRetornoWbsEtc.c1 = &AuxPadObs
Endif

//parm(in:&DevRandon, in:&PadRotLin, in:&OqueFazer, in:&PadObs, out:&sdtRetornoWbsEtc);
]]></Source>
