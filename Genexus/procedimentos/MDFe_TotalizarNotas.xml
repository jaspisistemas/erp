      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&MDFePsoBrt = 0
&MDFeVlrTot = 0
&CountNfe = 0
&CountCte = 0
&CountTot = 0

For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDFeCod
	
	if MDFeTipEmt = MDFe_TipoEmitente.NaoPrestador
		For Each Order EmpCod, FilCod, MDFeCod, MDFeNFeItm
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			
			&MDFePsoBrt += MDfeNfePso
			&MDFeVlrTot += MDFeNfeVlrTot
			&CountNfe += 1
			
		EndFor
	Else
		For Each Order EmpCod, FilCod, MDFeCod, MDFeCteItm
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			
			&MDFePsoBrt += MDfeCtePso
			&MDFeVlrTot += MDFeCteVlrTot
			&CountCte += 1
		EndFor
	EndIf
EndFor

For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDFeCod
	MDFeTotCTe = &CountCte
	MDFeTotNF = &CountNfe
	If &MDFePsoBrt <> 0
		MDFePsoBrt = &MDFePsoBrt
	Else
		&MDFePsoBrt = MDFePsoBrt
	EndIf
		
	If &MDFeVlrTot <> 0 
		MDFeVlrTot = &MDFeVlrTot
	Else
		&MDFeVlrTot = MDFeVlrTot
	EndIf
EndFor
&CountTot = &CountCte + &CountNfe
Commit
]]></Source>
