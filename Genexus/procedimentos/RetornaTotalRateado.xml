      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&FinVlr = 0

For Each Order EmpCod, PlanCod, FinAno, FinMes//, FinForCod
	Where EmpCod = &EmpCod
	Where PlanCatTip = 'D'
	Where FinAno = &FinAno
	Where FinMes = &FinMes
	
	if FinForCod1 = &FinForCod
		&FinVlr += FinForCal1
	EndiF

	if FinForCod2 = &FinForCod
		&FinVlr += FinForCal2
	EndiF

	if FinForCod3 = &FinForCod
		&FinVlr += FinForCal3
	EndiF

	if FinForCod4 = &FinForCod
		&FinVlr += FinForCal4
	EndiF
EndFor

]]></Source>
