      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ValorCredito = 0

For Each Order EmpCod, CreCliCod, CreRecPag
	Where EmpCod = &EmpCod
	
	Where CreRecPag = &CreRecPag
	Where CreCliCod = &PedCliCod
	Where CreVlrSdo > 0
	Where not CreSts = Status_Duplicata.CANCELADA
	Where CreFrpPgtoTip <> TipoDuplicata.CARTAOD and CreFrpPgtoTip <> TipoDuplicata.CARTAOC
	
	&ValorCredito += CreVlrSdo
EndFor

If &ValorCredito > 0
	if &CreRecPag = ReceberPagar.Pagar
		&CreditoMensagem = 'Crédito no contas a Pagar! R$ ' + trim(toformattedString(&ValorCredito))
	else
		&CreditoMensagem = 'Crédito no contas a Receber! R$ ' + trim(toformattedString(&ValorCredito))
	endif
EndIF

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
