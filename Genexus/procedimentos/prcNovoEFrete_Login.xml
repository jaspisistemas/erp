      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[// O conteúdo da tag Integrador deve ser uma CONSTANTE, pois é ela quem identifica seu sistema de gestão,
//Suporte e-FRETE:	Seguem credenciais para uso em ambiente de homologação:
//Integrador:		JASPI SISTEMAS DE INFORMÁTICA
//CNPJ:				21826923000177
//Usuário:			usuario@jaspi
//Senha:			usuario#jaspi
//Hash:				b754b48e-8c22-4cfc-bb0a-3524a76284c9

LoadWWPContext(&Context)
//Config do Servidor
HostWebServiceEfrete.Call(&EmpWebHost, &ExecuteUrl, &Usuario, &Senha, &Hash)
&ExecuteUrl			+= 'Logon/Login'

&HttpClient.Host	= 	&EmpWebHost
&HttpClient.Secure	= 	1

//Header do JSON
&HttpClient.AddHeader(!'Content-Type', !'application/json')
&HttpClient.AddHeader(!'Accept-Encoding', !'gzip, deflate, br')

//Corpo do Xml
&XmlBody 	= 	'{'
&XmlBody	+=	'	"Integrador": "'+ &Hash.Trim() +'",'
&XmlBody	+=	'	"Usuario": "'+ &Usuario.Trim() +'",'
&XmlBody	+=	'	"Senha": "'+ &Senha.Trim() +'",'
&XmlBody	+=	'	"Versao": "1"'
&XmlBody	+=	'}'

//Realiza o Envio ao WebService
&HttpClient.AddString(Trim(&XmlBody))
&HttpClient.Execute('POST',&ExecuteUrl)

//Grava o Envio ao padrão usuário
padraoUsuario.Call('G', '#EFRETELOGIN', &Context.PesCod, &Context.EmpCod, &XmlBody, &PadDtaMod)

If &HttpClient.StatusCode = 200
	
	&XmlBody = &HttpClient.ToString()
	&PosicaoSucesso = StrSearch(&XmlBody, '"Sucesso"')

	&PosicaoSucesso = &PosicaoSucesso + 11
	&Status 		= SubStr(&XmlBody, &PosicaoSucesso, 4)
	
	If &Status = 'true'
		&PosicaoProtocoloServico	= StrSearch(&XmlBody, '"Token"')
		&PosicaoProtocoloServico	= &PosicaoProtocoloServico + 8
		&ProtocoloServico			= SubStr(&XmlBody, &PosicaoProtocoloServico, 4)
				
		&Token						= SubStr(&XmlBody, 16, 59)
		&Erro 						= 200
	Else
		&PosicaoSucesso = StrSearch(&XmlBody, '"Mensagem"')
		&PosicaoSucesso = &PosicaoSucesso + 13
		
		&PosicaoFinal	= StrSearch(&XmlBody, '"Codigo"')
		&PosicaoFinal	= &PosicaoFinal - &PosicaoSucesso - 8
		&Status			= SubStr(&XmlBody, &PosicaoSucesso, &PosicaoFinal)
		
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro LogIn!",'Ocorreu um erro ao realizar o LogIn. ERRO: '+ Trim(&Status), DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf
	
	padraoUsuario.Call('G', '#EFRETELOGINRESPOSTA', &Context.PesCod, &Context.EmpCod, &XmlBody, &PadDtaMod)

Else
    msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro LogIn!", &HttpClient.StatusCode.ToString() + ": " + &HttpClient.ErrDescription, DVMessageType.error, "", DVMessageBoolean.True,""))
EndIf
]]></Source>
