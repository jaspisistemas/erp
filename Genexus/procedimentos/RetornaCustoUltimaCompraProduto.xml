      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProForIcmSt = 0
&ProForIcmStPob = 0
&ProForIcm = 0
&ProForIpi  = 0
&ProForAcr = 0
&ProForDsc = 0
&PedVlrCus = 0
&ProForRatDsc = 0
&ProForRatAcr = 0
	
For Each Order EmpCod, FilCod, PedSts, ProCod,LctTip, (PedDtaFat)
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where PedSts = Status_Pedido.FECHADO //PEDIDO FECHADO
	WHere LctTip = TipoLancamento.EntradaMercadoria //COMPRAS
	Where ProCod = &ProCod
	Where PedCliCod = &PedCliCod or &PedCliCod = 0
	
	&ProForIcmSt = PedItmIcmSt
	&ProForIcmStPob = PedItmIcmStPob
	&ProForIcm = PedItmIcm
	&ProForIpi  = PedItmIpi
	&ProForAcr = PedItmAcr
	&ProForDsc = PedItmDsc
	&ProForRatDsc = PedProTaxDscGerItm
	&ProForRatAcr = PedProTaxAcrGerItm
	
//	if PedVlrCus > 0 //na compra nao pode voltar o PedVlrCus
//		&PedVlrCus = PedVlrCus
//	Else
		&PedVlrCus = PedVlrUnt
//	EndIF

	Exit
EndFor
]]></Source>
