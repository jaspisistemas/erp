      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&ErroCobraca	= 0
&IsErro	= False
&IschaveTransacao	= False
&auxUrl	= &url
prcGetWebhookBoleto_Sicredi.Call(&EmpCod, &CbrCod, &CbrCtaBanAgeCod, &CbrCtaBanAgeDig, &CbrCtaBanCrt, &auxUrl, &IsWebhookCadastrado, &contrato)

If &IsWebhookCadastrado = False
	&auxUrl	= &url
	&SdtCadastrarWebhook_Sicredi.idContrato	= ''
	&SdtCadastrarWebhook_Sicredi.cooperativa	= &CbrCtaBanAgeCod
	&SdtCadastrarWebhook_Sicredi.posto	= &CbrCtaBanAgeDig
	&SdtCadastrarWebhook_Sicredi.codBeneficiario	= &CbrCtaBanCrt
	&SdtCadastrarWebhook_Sicredi.eventos.Add('LIQUIDACAO')
	&SdtCadastrarWebhook_Sicredi.url	= &auxUrl
	&SdtCadastrarWebhook_Sicredi.urlStatus	= 'ATIVO'
	&SdtCadastrarWebhook_Sicredi.contratoStatus	= 'ATIVO'
	&SdtCadastrarWebhook_Sicredi.nomeResponsavel	= &nomeResponsavel
	&SdtCadastrarWebhook_Sicredi.email	= &emailResponsavel
	&SdtCadastrarWebhook_Sicredi.telefone	= &telefoneResponsavel
	&LongVarChar	= Trim(&SdtCadastrarWebhook_Sicredi.ToJson())
	
	Do 'GetLocalCobranca'
	
	Do Case
		Case &IsErro	= True
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", &Mensagem, DVMessageType.regular, "", DVMessageBoolean.True,"") )
			
		Case &IsChaveTransacao	= False
			//Vai dar a mensagem no autenticar

		OtherWise
			&HttpClient.AddHeader('Authorization', 'Bearer ' + &CbrChaTra)
			&HttpClient.AddHeader('Content-Type', 'application/json')
			&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
			&HttpClient.AddHeader('Connection', 'keep-alive')
			&HttpClient.AddHeader('x-api-key', &CbrApiKey)
			&HttpClient.AddString(&LongVarChar)
			
			&HttpClient.Execute('POST', 'https://api-parceiro.sicredi.com.br/cobranca/boleto/v1/webhook/contrato/')
			If &HttpClient.ErrCode	= 0
				&IsWebhookCadastrado	= True
				Do 'AtualizaWebhook'
			Else
				&IsWebhookCadastrado	= False
				&Mensagem	= Trim(Str(&HttpClient.ErrCode)) + ' - ' + Trim(&HttpClient.ErrDescription) + newLine() + &HttpClient.ToString()
				PadraoUsuario.Call('G', 'SICREDI_CADASTRARWEBHOOK_ERRO', &PesCod, &EmpCod, &Mensagem, &PadDtaMod)
				msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!", &Mensagem, DVMessageType.error, "", DVMessageBoolean.True, ""))
			EndIf
	EndCase
	
Else
	&IsWebhookCadastrado	= True
	Do 'AtualizaWebhook'
EndIf	

Sub 'GetLocalCobranca'
	
	For each Order EmpCod, CbrCod
		Where EmpCod = &EmpCod
		Where CbrCod = &CbrCod
		
		&CbrApiKey	= CbrApiKey
		If not CbrChaMas.Trim().IsEmpty()
			&CbrChaMas = CbrChaMas                                                 
			If not CbrChaTra.Trim().IsEmpty() and not CbrChaTraVct.IsEmpty() and  CbrChaTraVct > ServerNow()
				&CbrChaTra = CbrChaTra
				&IschaveTransacao = true
			Else
				AutenticaBoletoSicredi.Call(EmpCod, CbrCod, CbrChaMas, CbrApiKey, CbrCtaBanAgeCod, CbrNroCon, &IschaveTransacao, &CbrChaTra) 			
			EndIf
		Else
			&ErroCobraca = 1
			&Mensagem = 'Chave master inválida. Verifique!'
			&IsErro = true
		EndIF
		
		Exit
	EndFor
	
EndSub

Sub 'AtualizaWebhook'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		CbrWebhook		= &auxUrl
		
		Exit
	EndFor
	Commit

EndSub
]]></Source>
