			NfeIpiEnq = &sdtCadastroTabelaImpostoCbs.CImpIpiEnq
			
			&Numeric = val(&sdtCadastroTabelaImpostoCbs.CImpCstIpi)
			&Varchar = Substr(&sdtCadastroTabelaImpostoCbs.CImpcfoCod, 1, 1)
			
