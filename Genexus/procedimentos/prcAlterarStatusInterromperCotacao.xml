<Object parentGuid="672f4ed4-5393-4ab0-9814-1f9d2a3f972a" user="WINJEAN\jeanfae" versionDate="2026-01-21T14:58:39.0000000Z" lastUpdate="2026-01-21T14:38:02.0000000Z" checksum="d239b58c82252e4d713634118fde975a" fullyQualifiedName="prcAlterarStatusInterromperCotacao" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="a49e9931-d042-4c02-8e59-31a651feec11" name="prcAlterarStatusInterromperCotacao" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Alterar Status Interromper Cotacao" parent="prcCotacao" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

For Each ORder EmpCod
	Where EmpCod = &EmpCod
	&EmpCodSec = EmpCodSec 
	Exit
endFor


For Each Order EmpCod, CotComCod
	Where EmpCod = &EmpCod
	Where CotComCod = &CotComCod
	
	&CotComKey = CotComKey
	&CotComVer = CotComVer
	
	&FilCod = CotComFilCod
	do 'getFilial'
	
	Do CAse
		CAse &OqueFazer = 'E'
			if CotComSts = statusCotacao.Encerrada
				CotComSts = statusCotacao.Finalizada
			Else
				CotComSts = statusCotacao.Encerrada
			Endif
			&SdtWbsRetorno.sts = 'J200'
			&ProgressLogXml = &SdtWbsRetorno.ToJson()
			
		Case &OqueFazer = 'C' //CANCELAR		
			CotComSts = StatusCotacao.Cancelada
			&SdtWbsRetorno.sts = 'J200'
			&ProgressLogXml = &SdtWbsRetorno.ToJson()
			
		Otherwise
			HostWebServiceJaspiADM.Call(EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
			
			&sdtDadosCotacao.CotComCod = CotComCod
			&sdtDadosCotacao.CotComVer = &CotComVer
			&sdtDadosCotacao.CotComCliCodSync = &EmpCodSec
			&sdtDadosCotacao.CotComFilCnpj = &FilCpj
			&sdtDadosCotacao.CotComFilRaz = &FilRaz
			&sdtDadosCotacao.CotComDtaLim = CotComDtaLim
			&sdtDadosCotacao.CotComDtaEms = CotComDtaEms
			&sdtDadosCotacao.CotComObs = CotComObs
			&sdtDadosCotacao.CotComKey = CotComKey
			&sdtDadosCotacao.CotComPrzDia = CotComPrzDia
			&sdtDadosCotacao.CotComSts = CotComSts
			
			For each ORder EmpCod, CotComCod, CotComForCod
				where CotComForCod = &CotComForCod
				
				&CotComForSenAce = CotComForSenAce
				
				if &OqueFazer = 'L' or &OqueFazer = 'N'
					&Guid = GUID.NewGuid()
					&CotComForSenAce = &Guid.ToString() //Grava GUID para acesso.
				Endif
				
				&sdtDadosCotacaoFornecedor = new()
				&sdtDadosCotacaoFornecedor.CotComForCod = CotComForCod
				&sdtDadosCotacaoFornecedor.CotComForNom = CotComForRaz
				&sdtDadosCotacaoFornecedor.CotComForAcess = &CotComForSenAce
				&sdtDadosCotacaoFornecedor.CotComForDtaLim = CotComForDtaLim
				
				&sdtDadosCotacaoFornecedor.CotComForSts = &OqueFazer
				
				&sdtDadosCotacao.Fornecedores.Add(&sdtDadosCotacaoFornecedor)
			EndFor
			
			do 'enviaPost'
	EndCase

	
	Exit
EndFor

commit

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

sub 'enviaPost'
	if &IsAbortaTudo = false
		&cotacaocompleta = &sdtDadosCotacao.ToJson()
		&cotacaocompleta = &cotacaocompleta.Replace('"', '\"')
		&LongVarChar		= '{ "chaveacesso": "' + Trim(&EmpCodSec) + '", "cotacaocompleta": "' + Trim(&cotacaocompleta) + '" }'
		&HttpClient.AddHeader('Accept', 'application/json')
		&HttpClient.AddHeader('Connection', 'keep-alive')
		&HttpClient.AddHeader('Content-Type', 'application/json')
		&HttpClient.AddString(&LongVarChar)
		
		&HttpClient.Execute('POST', 'https://'+&EmpWebHost+'/cotacaocompra/Bloquear')
		
		If &HttpClient.StatusCode = 200
			&ProgressLogXml =  &HttpClient.ToString()
			&ProgressLogXml = &ProgressLogXml.Replace('{"retornosolicitacao":"', '')
			&ProgressLogXml = &ProgressLogXml.Replace('}\"}"}', '}"}')
			&ProgressLogXml = &ProgressLogXml.Replace('\"', '"')
			&ProgressLogXml = &ProgressLogXml.Replace('\\', "\")
			
			&SdtWbsRetorno.FromJson(&ProgressLogXml)
			
			if &SdtWbsRetorno.sts <> 'J200'
				&IsAbortaTudo = true
			Else
				For each ORder EmpCod, CotComCod
					Where EmpCod = &EmpCod
					Where CotComCod = &CotComCod
					
					if &OqueFazer = 'B'
						CotComSts = statusCotacao.Bloqueada
					
						//Atualiza Fornecedors
						For each ORder EmpCod, CotComCod, CotComForCod
							CotComForSts = StatusCotacaoFornecedor.BLOQUEADO
						EndFor
						
						For Each ORder EmpCod, CotComCod, CotComItmCod
							CotComProMenForCod = 0
							CotComProSelForCod = 0
							
							For Each ORder EmpCod, CotComCod, CotComItmCod, CotComProForCod
								CotComProForSts = StatusProdutoCotado.PENDENTE
								CotComProForVlr.SetEmpty()
								CotComProForVlrFin.SetEmpty()
								CotComProForVlrIcms.SetEmpty()
								CotComProForVlrIcmsSt.SetEmpty()
								CotComProForVlrIpi.SetEmpty()
							EndFor
						EndFor
					Else
						CotComSts = statusCotacao.Cancelada
					Endif
				EndFor
				
				commit
				
			Endif
		
		
		else
			&SdtWbsRetorno.sts = 'F999'
			&SdtWbsRetorno.obs = 'Não foi Possível fazer a sincronização com servidor cotações. Erro: ' + trim(&HttpClient.StatusCode.ToString()) + ' - ' + &HttpClient.ErrDescription
			&ProgressLogXml = &SdtWbsRetorno.ToJson()
			&IsAbortaTudo = true
		Endif
				
		&sdtDadosCotacao.Produtos.Clear()
		&sdtDadosCotacao.Fornecedores.Clear()
	Endif
EndSub

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub


Sub 'getFilial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilRaz = FilRaz
		&FilCpj = FilCpj
		Exit
	endFor
EndSub
]]></Source>
