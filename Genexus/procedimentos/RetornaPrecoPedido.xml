        <Source><![CDATA[&PedVlrUnt = 0
&PedItmPrm = domPedItmPrm.NORMAL


For Each Order EmpCod, FilCod, PedCod, (PedItmCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where PedCod = &PedCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	&PedVlrUnt = PedVlrUnt
	&PedItmPrm = PedItmPrm
	
	Exit
EndFor
]]></Source>
