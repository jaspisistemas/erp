      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&FinForCod1 = 0
&FinForCod2 = 0
&FinForCod3 = 0
&FinForCod4 = 0
For Each Order EmpCod, FinAno, FinMes 
	where EmpCod = &EmpCod
	Where FinAno = &FinAno
	Where FinMes = &FinMes
	Where PlanCatTip = 'C'
	
	&FinForCod1 = FinForCod1
	&FinForCod2 = FinForCod2
	&FinForCod3 = FinForCod3
	&FinForCod4 = FinForCod4
	Exit
EndFor
]]></Source>
