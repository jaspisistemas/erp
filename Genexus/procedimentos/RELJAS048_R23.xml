      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
MT 0
MB 0

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

if &CliPesCod > 0
	For Each Order EmpCod, PesCod, PesAnxCod
		Where EmpCod = &EmpCod
		Where PesCod = &CliPesCod
		Where PesAnxTipNom = '#LOGO_ETIQUETA_R23#'
		
		if not PesAnxArq.IsEmpty() and not PesAnxArq.IsNull()
			&PesAnxArq = PesAnxArq		
			&AuxArquivoTemporario = pathToUrl(PesAnxArq)
			
			&index = &AuxArquivoTemporario.IndexOf('PublicTem')
			&AuxArquivoTemporario = substr(&AuxArquivoTemporario, &index, 900)
			
			&File.Source = 'jaspi_QrCode_dll'
			&ArquivoTemporario = trim(&File.GetPath()) +'/'+ &AuxArquivoTemporario
			&File.Close()
			&ArquivoTemporario = &ArquivoTemporario.Replace('/', '\')
		Else
			retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta )			
			&ArquivoTemporario = &SdtConfiguracoesPasta.PastaDiretoriovirtual.Trim() +'appjaspi\anexos\'+ trim(str(EmpCod)) + '\' + trim(PesAnxGuidNom)+'_'+trim(PesAnxGuid.ToString()) +'.'+ trim(PesAnxGuidExt)
		EndIf
		
		Exit
	EndFor

	&LogoEtiqueta.FromURL(&AuxArquivoTemporario)
Endif

if &LogoEtiqueta.IsEmpty()
	&LogoEtiqueta.FromImage(Logo_etiqueta_r23)
Endif

//For Each Order EmpCod, FilCod
//	Where EmpCod = &EmpCod
//	Where FilCod = &FilCod
//	&CNPJEMPRESA = trim(toformattedString(FilCpj))
//	Exit
//EndFor

//&IsColuna1 = true
For Each Order EtqCod, EtqItmCod
	Where EtqCod = &EtqCod
	
	&EtqQtd = EtqQtd
	&ProCod = EtqProCod

	&EtqQtd = EtqQtd
	If EtqNovProCod.IsEmpty() or EtqNovProCod.IsNull()
		&CodigoProduto = trim(str(EtqProCod))
	Else
		&CodigoProduto = trim(EtqNovProCod)
	EndIF

	&CodigoVarchar = ''
//	if &ImprimirCodigoBarrasInterno = true
		&EtqProBar = EtqProBar.Trim()
		&CodigoVarchar = EtqProBar.Trim()
//	Else
//		&EtqProBar = &CodigoProduto.Trim()
//	Endif

	&EtqProNom = EtqProNom.Trim()
	if not EtqProGraNom.IsEmpty()
		&EtqProNom += ' | ' + trim(EtqProGraNom)
	EndIF

	&NomeProduto  = GxGetMLi(&EtqProNom, 1, 35)
	&NomeProduto1 = GxGetMLi(&EtqProNom, 2, 35)
	
	Do CAse
		CAse &EtqProBar.Length() = 13
			&TipoCodigoBarras = TipoCodigoBarras.EAN13//_40X110
		CAse &EtqProBar.Length() = 14
			&TipoCodigoBarras = TipoCodigoBarras.EAN14//_40X110
		Otherwise
			&TipoCodigoBarras = TipoCodigoBarras.CODE128C//_40X110
	EndCAse

	&CodigoBarrasImagem.SetEmpty()
	//CODIGO BARRAS
	&NomeImagem = &sdtConfiguracoesPasta.PastaDiretorioTempFis + trim(&TipoCodigoBarras) + trim(&EtqProBar) + '.jpg'
	If not &EtqProBar.IsEmpty()
		&File.Source = &NomeImagem
		if not &File.Exists()
			ExeCodigoBarrasWinWeb_qrCode.Call(&sdtConfiguracoesPasta, &TipoCodigoBarras, &EtqProBar, &EtqProBar)
		EndIF
		If &File.Exists()
			&CodigoBarrasImagem.FromURL(&NomeImagem)
		EndIF
	EndIf
	
	do 'printEtiquetas'
EndFor

sub 'printEtiquetas'	
	For &i = 1 to &EtqQtd step 1
//		If &IsColuna1 = true
//			if &IsImprimirCNPJ = true
//				print EtiquetaModelo001Col1_CNPJ
//			Else
				print EtiquetaModelo001Col1
//			Endif

//			&IsColuna1 = false
//		Else
//			noSkip
//			if &IsImprimirCNPJ = true
//				print EtiquetaModelo001Col2_CNPJ
//			Else
//				print EtiquetaModelo001Col2
//			Endif
//			&IsColuna1 = true
//		EndIF
	EndFor
EndSub
]]></Source>
