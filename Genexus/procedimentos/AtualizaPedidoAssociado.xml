      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod,FilCod,PedCod,PedAssCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedAssCod = &PedAssCod
	PedAssNroNfp = &PedAssNroNfp
	PedAssEmsNfp = &PedAssEmsNfp
	
EndFor

&tmpNFeCod = trim(str(&EmpCod)) + trim(Str(&FilCod)) + trim(str(&PedCod))+Trim(str(&PedAssCod))
For Each Order tmpNFeCod //CAPA NOTA TEMPORARIA
	Where tmpNFeCod = &tmpNFeCod
	
	tmpNroNfp = &PedAssNroNfp
	tmpEmsNfp = &PedAssEmsNfp
	Exit
EndFor

Commit

]]></Source>
