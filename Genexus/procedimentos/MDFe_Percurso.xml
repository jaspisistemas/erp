      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &OqueFazer = 'ADD'
	For Each Order EmpCod, FilCod, MDFeCod, MDFePerCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFePerUfeCod = &MDFePerUfeCod
		
		If &MDFePerUfeCod = 'GO'
			Do 'AdicionaUF'
		Else
			Exit
		EndIf
	
	When none
		
		Do 'AdicionaUF'
	EndFor
Else
	For Each Order EmpCod, FilCod, MDFeCod, MDFePerCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFePerCod = &parMdfePerCod
		Delete
		Exit
	EndFor
EndIF

Commit

Sub 'AdicionaUF'
	For Each Order EmpCod, FilCod, MDFeCod, (MDFePerCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		&MDFePerCod = MDFePerCod
		Exit
	EndFor
	&MDFePerCod += 1
	
	NEw
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDFeCod
		MDFePerCod = &MDFePerCod
		MDFePerUfeCod = &MDFePerUfeCod
	EndNEw
EndSub



]]></Source>
