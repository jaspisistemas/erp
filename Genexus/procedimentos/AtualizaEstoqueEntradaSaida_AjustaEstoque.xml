      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&PedCLiCod = PedCliCod
	
	&LctAtuEst = LctAtuEst
	&LctAtuSal = LctAtuSal
	&LctAtuPro = LctAtuPro
	&LctTip = LctTip
	&LctGerFin = LctGerFin
	
	If PedDtaFat.IsEmpty() or PedDtaFat.IsNull()
		&PedDtaFat = PedDtaSep
	Else
		&PedDtaFat = PedDtaFat
	EndIF
	
	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		where PedItmCod = &PedItmCod
		
		&ProCod = PedProEstProCod
		&ProGraCod = PedProEstProGraCod
		If ProGraCod = 0 OR PedProEstProGraCod = 0
			&ProGraCod = 1
			prcAtualizaProGraCodZero.Call(&EmPCod, &FiLCod, &PedCod)
		EndIF
		
		&PedQtd = PedQtd
		&PedVlrCus = PedVlrCus				
		
		If ProEstTip <> TipoEstoque.NAO_ATUALIZA
			do 'FechaEstoque'
		EndiF		
	EndFor
EndFor

commit

Sub 'FechaEstoque'		
	//ATUALIZA ESTOQUE
	Do CAse
		CAse &LctAtuEst = Status_EntradaSaida.Entrada //EMPRESA ENTRADA
			If &ProGraCod > 1
				AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, 1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip, '+', '')
			EndIF
			AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, &ProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip,'+', '')
			
		CAse &LctAtuEst = Status_EntradaSaida.Saida //EMPRESA SAIDA
			if &ProGraCod > 1
				AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, 1, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip,'-', '')
			EndIf
			AtualizaEstoqueEmpresa_EntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 1, &PedDtaFat, &ProCod, &ProGraCod, &PedQtd, &PedVlrCus, &LctAtuEst, &LctTip,'-', '')
	EndCase
	
	Do CAse
		CAse &LctAtuPro  = Status_EntradaSaida.Entrada //PRODUCAO ENTRADA
			If &ProGraCod > 1
				AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &ProCod, 1, &PedQtd, &PedVlrCus, &LctAtuPro, '+')
			EndIF
			AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &ProCod, &ProGraCod, &PedQtd, &PedVlrCus, &LctAtuPro, '+')
			
		CAse &LctAtuPro  = Status_EntradaSaida.Saida //PRODUCAO SAIDA
			if &ProGraCod > 1
				AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &ProCod, 1, &PedQtd, &PedVlrCus, &LctAtuPro, '-')
			EndIF
			AtualizaProducaoEntradaSaida.Call(&EmPCod, &FilCod, &PedCod, 2, &PedDtaFat, &ProCod, &ProGraCod, &PedQtd, &PedVlrCus, &LctAtuPro, '-')
	EndCase	
EndSub
]]></Source>
