      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	//FAZ UM POST no ADM
	HostWebServiceJaspiADM.Call(&EmpCod, &EmpWebHost, &EmpWebBaseUrl, &EmpWebPor)
	
	&Mensagem.SetEmpty()
	&LongVarChar			= '{ "MrkGUID": "'+trim(&MrkGuid)+'"}'
	
	&HttpClient.AddHeader('Content-Type', 'application/json')
	&HttpClient.AddHeader('Accept', 'application/json')
	&HttpClient.AddString(&LongVarChar)	
	&HttpClient.Execute('POST', 'https://'+&EmpWebHost+'/mercadolivre/credentials')
	
	If &HttpClient.StatusCode = 200
		
		
		&SdtTokenResult.FromJson(&HttpClient.ToString())
		
		if not &SdtTokenResult.access_token.IsEmpty()
			for Each Order EmpCod, MrkCod
				where EmpCod = &EmPCod
				Where MrkGuid = &MrkGuid
				
				MrkStsInt = StatusMarketplace.Integrada
				MrkTok = &SdtTokenResult.access_token
				
				&MrkCod = MrkCod
				Exit
			EndFor
			
			commit
			
			if not &MrkCod.IsEmpty()
				prcMercadolivreRefreshToken.Call(&EmPCod, &MrkCod, &MrkSession, &IsSucesso)
			Endif
		
			
			&ProgressLogXml = 'Sucesso'
		Endif
	Else
		&ProgressLogXml = 'Falha catastrofica'
	Endif
]]></Source>
