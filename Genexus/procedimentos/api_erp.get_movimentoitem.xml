      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	
	For Each Order EmpCod, MovCod
		Where EmpCod = &wwpContext.EmpCod
		Where MovCod = &MovCod
		
		&sdtMovimento.sts = 'J200'
		
		&sdtMovimento.movCod = MovCod
		&sdtMovimento.movDta = trim(MovDta.ToFormattedString())
		
		&sdtMovimento.movDoc = MovDoc
		&sdtMovimento.movCreDeb = MovCreDeb
		&sdtMovimento.movTip = MovTip
		&sdtMovimento.movDtaPgt = trim(MovDtaPgt.ToFormattedString())
		datetoTimestamp.Call(MovDtaPgt, &sdtMovimento.movDtaPgtTmp)
		
		&sdtMovimento.movDtaCon = trim(MovDtaCon.ToFormattedString())
		datetoTimestamp.Call(MovDtaCon, &sdtMovimento.movDtaConTmp)
		
		&sdtMovimento.movCplMan = MovCplMan
		&sdtMovimento.movSts = MovSts
		
		&sdtMovimento.movCtaBanCod = MovCtaBanCod
		&sdtMovimento.movCtaBanNom = MovCtaBanNom
		
		&sdtMovimento.movCplMan = MovCplMan
		&moeda = MovVlr
		&sdtMovimento.movVlr = trim(&moeda.ToFormattedString())
		
		for Each Order EmpCod, MovCod, MovItmCod
			
			&GridMovCreCod = MovCreCod
			&GridMovCreFilCod = MovCreFilCod
			&GridMovCrePagCod = MovCrePagCod
			do  'GetDuplicata'
			&sdtMovimentoItem = new()
			
			&sdtMovimentoItem.movItmCod = MovItmCod
			&sdtMovimentoItem.planCod = PlanCod
			&sdtMovimentoItem.planNom = PlanNom
			&sdtMovimentoItem.planHie = PlanHie
			&sdtMovimentoItem.movItmVlr = MovItmVlr
			&sdtMovimentoItem.movItmSts = MovItmSts
			&sdtMovimentoItem.movItmCpl = MovItmCpl
			&sdtMovimentoItem.movItmAdi = &DadosDuplicata
			
			&sdtMovimento.item.Add(&sdtMovimentoItem)
			
			&sdtMovimento.movUltCod = MovItmCod
		EndFor
		
	EndFor
	
Endif


Sub 'GetDuplicata'

	&DadosDuplicata.SetEmpty()
	For Each Order EmpCod, FilCod, CreCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &GridMovCreFilCod
		Where CreCod = &GridMovCreCod
		&DadosDuplicata = CreDupNro.Trim() + ' ' + trim(toformattedString(CreDtaVct)) + ' - R$' + trim(ToformattedString(CreVlrDup))
		Exit
	EndFor

EndSub



]]></Source>
