      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For &sdtPedidosItem In &sdtPedidos //Busca as infos das CT-e salvas
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod //Empresa
		Where FilCod = &FilCod //Filial
		Where CteCod = &SdtPedidosItem.PedCod //Código da CT-e
		
		CteStsFin = Status_Financeiro.Fechado //Fecha o Financeiro da CT-e
		
		Exit
		
	EndFor
	
	UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &FilCod, &CreCod) //Busca o Último código das duplicatas
	
	New
		EmpCod 			= &EmpCod //Empresa
		FilCod			= &FilCod //Filial
		
		//Comentei pq se estiver definido, não será possível cancelar a Duplicata\\
		//		CreFrtCod		= &sdtPedidosItem.PedCod
		//		CreFrtFilCod	= &sdtPedidosItem.FiLCod
		
		CreCod 			= &CreCod //Código da Duplicata
		CreDupNro		= Trim(&sdtPedidosItem.FrtDoc) //Número da CT-e
		CreVlrDup		= &sdtPedidosItem.PedVlrLiq //Valor da CT-e
		CreVlrSdo		= &sdtPedidosItem.PedVlrLiq //Valor da CT-e
		CreDtaEms		= &sdtPedidosItem.PedDtaFat //Data de Emissão = Dia de Hoje
		CreDtaVct		= &PedDtaVct //Data de Vencimento 
		
		CreCliCod		= &SdtPedidosItem.PedTraRedCod //Código do Tomador da CT-e
		
		CreCbrCod		= &CreCbrCod //Local de Cobrança
		CrePlanCod 		= &PlanCod //Plano de Contas
		
		CreVenCod 		= &PesVenCod //Código do Funcionário/Vendedor
		
		CreRecPag 		= ReceberPagar.Pagar //Conta a Pagar
		CreSts 			= Status_Duplicata.ATIVO //Duplicata Ativa
		CreOriDup 		= OrigemDuplicata.FechamentoFinanceiroCte //Origem da Duplicata 
		CreAbvDup		= 'CT-e.'+Trim(&sdtPedidosItem.FrtDoc) //Abreviação Da origem + Núemro da CT-e
		
		CreBloNro 		= ' '
		
		CreFrpPgtoCod 	= 1 //Forma de Pagamento / 1 = Duplicata / 2 = Dinheiro / 3 = Cheque próprio  / 4 = Cheque Terceiros / 5 = Debito / 6 = PIX / 7 = DOC/TED / 8 = Crédito
		
		CreFilPgt 		= &sdtPedidosItem.FiLCod //Filial de Pagamento
	EndNew
	
EndFor
Commit
]]></Source>
