      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsAchouProduto = false
&Mensagemerro = 'Produto não Localizado!'

if not &ProGraRef.IsEmpty()
	For Each Order EmpCod, ProBarRef //Codigo Barras Diversos
		Where EmpCod = &EmpCod
		Where ProBarRef = &ProGraRef
		
		&ProGraCod = ProGraCod		
		&ProCod = ProCod
		&ProNom = ProNomGra		
		&ProReqQtd = ProReqQtd
		&ProReqVlr = ProReqVlr
		&ProBarTip = ProBarTip
		if ProBarQtd > 0 and not ProBarQtd.IsNull()
			&ProBarQtd = ProBarQtd
		Else
			&ProBarQtd = ProQtdEmb
		EndIf
	
		&IsAchouProduto = true		
		&Mensagemerro = ''
		
		Exit
	When none
		For Each Order EmpCod, ProGraRef //Codigo Barras 
			Where EmpCod = &EmpCod
			Where ProGraRef = &ProGraRef
			
			&ProGraCod = ProGraCod			
			&ProCod = ProCod
			&ProNom = ProNomGra			
			&ProReqQtd = ProReqQtd
			&ProReqVlr = ProReqVlr
			&IsAchouProduto = true			
			&Mensagemerro = ''
			&ProBarQtd = ProQtdEmb
			
			GravaCodigoProdutoRefBarras.Call(EmpCod, ProCod, ProGraCod, ProGraRef, 'R') //REFERENCIA
			GravaCodigoProdutoRefBarras.Call(EmpCod, ProCod, ProGraCod, ProGraBar, 'B') //BARRAS
			
			Exit
		When none
			For Each Order EmpCod, ProGraBar //Codigo Barras 
				Where EmpCod = &EmpCod
				Where ProGraBar = &ProGraRef
				
				&ProGraCod = ProGraCod				
				&ProCod = ProCod
				&ProNom = ProNomGra				
				&ProReqQtd = ProReqQtd
				&ProReqVlr = ProReqVlr
				&IsAchouProduto = true				
				&Mensagemerro = ''
				&ProBarQtd = ProQtdEmb
				
				GravaCodigoProdutoRefBarras.Call(EmpCod, ProCod, ProGraCod, ProGraRef, 'R') //REFERENCIA
				GravaCodigoProdutoRefBarras.Call(EmpCod, ProCod, ProGraCod, ProGraBar, 'B') //BARRAS
			
				Exit				
			EndFor
		EndFor
	EndFor
EndIF
]]></Source>
