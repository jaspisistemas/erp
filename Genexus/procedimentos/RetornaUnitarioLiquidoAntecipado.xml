<Object parentGuid="21e15c47-a3e3-482b-9c7a-4147ea7dbb76" user="SRVORDIG\Administrador" versionDate="2023-11-23T20:25:42.0000000Z" lastUpdate="2023-11-23T13:08:38.0000000Z" checksum="732ee3c4f32e16fea0aa31efd74b43f0" fullyQualifiedName="RetornaUnitarioLiquidoAntecipado" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="40311b13-2cc2-45fc-a6c6-12af178ff1c1" name="RetornaUnitarioLiquidoAntecipado" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Retorna Unitario Liquido Antecipado" parent="TelevendasPrc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&inPedVlrUnt = &PedVlrUnt

If &TabDtaVct.IsEmpty() //Se o Vencimento da Tabela for Vazio, então vai mudar a base de vencimento para calcular os juros apartir da data especifica.
	If not  &PedDtaEms.IsEmpty()	// Se for um pedido pega como base de Vencimento a data de emissão  do pedido, para não ficar recalculando pedidos abertos e digitados.
		&TabDtaVct = &PedDtaEms
	Else		
		&TabDtaVct = serverDate() //em ultimo caso pega a data de hoje como base de Vencimento para calcular os juros apartir desta data.
	EndIf
EndIf

Do Case
	Case &PedDtaVct > &TabDtaVct  and not &PedDtaVct.IsEmpty() and not &TabDtaVct.IsEmpty() // CALCULA JUROS com a data base de vancimento que pode ser hj ou data especifica.
		
		&MaximoDeDias = &PedDtaVct - &TabDtaVct
		if &MaximoDeDias > 365 
			&PagamentoData = &TabDtaVct.AddDays(365) //Vencimento Maximo
		Else
			&PagamentoData = &PedDtaVct //Vencimento Pedido
		EndIf
	
		&VencimentoData = &TabDtaVct
		&DtaIni = &VencimentoData
		
		&TxaDia = round(((&TabPerAcr / 30)/100), 12)
		&Dias = 0
		
		Do While &DtaIni < &PagamentoData

			&DtaFim = eom(&DtaIni)   // Ultimo Dia do Mês de Vcto
			
			If &TxaDia > 0
				if &DtaFim > &PagamentoData       // verifica se ultimo dia do mes do vencimento é maior que o vencimento 
					&DtaFim = &PagamentoData      
				Endif
				
				&Dias += (&DtaFim - &DtaIni)     // Soma Qtd de Dias Vencidos
				If &Dias <0
					&Dias = 1
				EndIf
		
				&VlrJur = &inPedVlrUnt * &TxaDia
				&inPedVlrUnt += &VlrJur * &Dias
			EndIf
						
			&DtaIni = &DtaFim + 1
			&Dias = 1
		EndDo

		&PedVlrUnt = round(&inPedVlrUnt, 2)
		
	Case &PedDtaVct < &TabDtaVct and not &PedDtaVct.IsEmpty() and not &TabDtaVct.IsEmpty()// CALCULA ANTECIPAÇÃO
		
		&MaximoDeDias = &TabDtaVct - &PedDtaVct
		if &MaximoDeDias > 365
			&VencimentoData = &TabDtaVct.AddDays(-365)
		Else
			&VencimentoData = &PedDtaVct
		EndIf
	
		&PagamentoData = &TabDtaVct
		&DtaIni = &VencimentoData
		
		&TxaDia = round(((&TabPerAnt / 30)/100), 12)
		&Dias = 0
		
		Do While &DtaIni < &PagamentoData

			&DtaFim = eom(&DtaIni)   // Ultimo Dia do Mês de Vcto
			
			If &TxaDia > 0
				if &DtaFim > &PagamentoData       // verifica se ultimo dia do mes do vencimento é maior que o vencimento 
					&DtaFim = &PagamentoData      
				Endif
				
				&Dias += (&DtaFim - &DtaIni)     // Soma Qtd de Dias Vencidos
				If &Dias < 0
					&Dias = 1
				EndIf
		
				&VlrJur = &inPedVlrUnt * &TxaDia
				&inPedVlrUnt -= &VlrJur * &Dias
			EndIf
						
			&DtaIni = &DtaFim + 1
			&Dias = 1
		EndDo

		&PedVlrUnt = round(&inPedVlrUnt, 2)
		
EndCase


]]></Source>
