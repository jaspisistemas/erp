        <Source><![CDATA[For Each WWP_Entity
	Where WWPEntityName = &WWPEntityName
	&WWPEntityId = WWPEntityId
	Exit
When None
	&WWP_Entity = New()
	&WWP_Entity.WWPEntityName = &WWPEntityName
