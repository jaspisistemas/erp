      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Varchar = &CfoCod
RetornaSoNumeros.Call(&Varchar, &Varchar)
&CfoCod = &Varchar
if not &Varchar.IsEmpty()
	&CfoCod = Substr(&Varchar, 1, 1) + '.' + Substr(&Varchar, 2, 3)
Endif

&Mensagem = ''
&IsErroCFOP = false
For Each Order CfoCod
	Where CfoCod = &CfoCod
	&Mensagem = CfoDesCpl
	Exit
When none
	&Mensagem = 'CFOP inválido!'
	&IsErroCFOP = true
EndFor
]]></Source>
