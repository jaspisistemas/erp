      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

	For each Order EmpCod,FilCod,MDFeCod,MdfeEveCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeEveCod = &MdfeEveCod
		MdfeDta = Serverdate()
		MdfeEveCarUf = &MdfeEveCarUf
		MdfeEveCarCid = &MdfeEveCarCid
		&MdfeEveDesCodMax = MdfeEveDesCodMax
		Do 'GravaDescarregamento'  //Se Achou um Evento, Cria os Descarregamento
		Exit
	When none
		Do 'PegaUltimoEvento' //sequencial da tabela Evento
		Do 'SequencialEvento' //sequencial do Evento 110115
		Do 'NewEvento'  //Grava Novo Evento
	EndFor

Sub 'SequencialEvento'	
	For each Order EmpCod,FilCod,MDFeCod,MdfeEveNro,(MdfeEveDfeCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MdfeEveNro = '110115'// ultimo sequencial desse evento pois a tabela serve pra outros eentos.
		
		&MdfeEveDfeCod = MdfeEveDfeCod
		Exit
	EndFor
EndSub

Sub 'NewEvento'
	//Criar Evento
	&MdfeEveCod +=1
	&MdfeEveDfeCod += 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDFeCod
		MdfeEveCod = &MdfeEveCod
		MdfeDta = Serverdate()
		MdfeEveNro = '110115'  //incusao DFE	
		MdfeEveDfeCod= &MdfeEveDfeCod
		MdfeEveCarUf = &MdfeEveCarUf
		MdfeEveCarCid = &MdfeEveCarCid
		MdfeEveSts = Status_Mdfe.Digitando
	EndNew
	Commit
	//SE Criou o 1º Event vAI Criar o Primeiro Descarregamento desse evento
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDFeCod
		MdfeEveCod = &MdfeEveCod
		MdfeEveDesCod = 1
		MdfeEveDesUf = &MdfeEveDesUf
		MdfeEveDesCid = &MdfeEveDesCid
		MdfeEveDesChv = &MDFeEveDesChv
	EndNew
	Commit
EndSub

Sub 'GravaDescarregamento'
	&MdfeEveDesCodMax+=1 
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDFeCod
		MdfeEveCod = &MdfeEveCod
		MdfeEveDesCod = &MdfeEveDesCodMax
		MdfeEveDesUf = &MdfeEveDesUf
		MdfeEveDesCid = &MdfeEveDesCid
		MdfeEveDesChv = &MDFeEveDesChv
	EndNew
	Commit
EndSub



Sub 'PegaUltimoEvento'
	For each Order EmpCod,FilCod,MDFeCod,MdfeEveCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		&MdfeEveCod = MdfeEveCod
		Exit
	EndFor
EndSub
]]></Source>
