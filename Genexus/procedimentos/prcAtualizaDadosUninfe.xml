      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsCriar = &parIsCriar

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	
	&FilRaz = FilRaz +' '+ trim(Str(FilCodPas))
	&FilCpj = retornaSoNumeros.Udp(FilCpj)
	&FilCidUfeCod = FilCidUfeCod
	
	&FilVctCer = FilVctCer
	
	&FilAmbEms = FilAmbEms
	&FilTipEms = FilTipEms
	
	&FilCerNom = FilCerNom
	&FiLCerPsw = FilCerPsw
	
	&FilIdQrCode = FilIdQrCode
	&FilSenQrCode = FilSenQrCode
	
	&FilCerA1A3 = FilCerA1A3
			
	Exit
EndFor

if &IsCriar = true //CASO SEJA EMRPESA NOVA
	//para pegar a primeira empresa configurada no uninfe.
	prcRetornaPrimeiraFilialCertificado.Call(&PrimeiraEmpresaSdtConfiguracoesPasta)
Else
	&Directory.Source = &sdtConfiguracoesPasta.PastaNFprocessamento
	if not &Directory.Exists()		
		&IsCriar = true 
		//para pegar a primeira empresa configurada no uninfe.
		prcRetornaPrimeiraFilialCertificado.Call(&PrimeiraEmpresaSdtConfiguracoesPasta)
	Else
		RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &PrimeiraEmpresaSdtConfiguracoesPasta)
	Endif
Endif

if &FilCerA1A3 = 'A1' and not &FiLCerPsw.IsEmpty() and not &FilCerNom.IsEmpty() and &FilVctCer > serverdate() //A3 NAO DISPONIVEL
	
	//GERA ARQUIVO FISICO NA PRIMEIRA PASTA DO UNINFE, PARA CRIAR EMPRESA SE NAO TEM
	&CaminhoCertificado = format('%1%2', &SdtConfiguracoesPasta.PastaDiretorioCertificado , trim(&FilCerNom))
	
	&Nome_enviar = &PrimeiraEmpresaSdtConfiguracoesPasta.PastaNFenvio+ 'uninfe-alt-con.xml'
	
	&XMLWriter.Open(&Nome_enviar) // Abrir o arquivo XML
	&XMLWriter.WriteStartDocument('UTF-8')
	&XMLWriter.WriteStartElement('altConfUniNFe')
	
	if &IsCriar = true //CASO SEJA EMPRESA NOVA
		&XMLWriter.WriteStartElement('DadosEmpresa')
		&XMLWriter.WriteAttribute('Servico', '0')
		&XMLWriter.WriteAttribute('CNPJ', &FilCpj)
		&XMLWriter.WriteElement('Nome', &FilRaz.Trim())
		&XMLWriter.WriteEndElement() //DadosEmpresa
		&XMLWriter.WriteElement('Nome', &FilRaz.Trim())
	Endif

	&XMLWriter.WriteElement('PastaXmlEnvio', &SdtConfiguracoesPasta.PastaNFenvio)
	&XMLWriter.WriteElement('PastaXmlRetorno', &SdtConfiguracoesPasta.PastaNFretorno)
	&XMLWriter.WriteElement('PastaXmlEnviado', &SdtConfiguracoesPasta.PastaNFEnviado)
	&XMLWriter.WriteElement('PastaXmlErro', &SdtConfiguracoesPasta.PastaNFerro)
	
	&Mensagem = &sdtConfiguracoesPasta.PastaNFenvio
	&Mensagem = &Mensagem.Replace('envio', 'backup')
	&XMLWriter.WriteElement('PastaBackup', &Mensagem)
	
	&Mensagem = &sdtConfiguracoesPasta.PastaNFenvio
	&Mensagem = &Mensagem.Replace('envio', 'EnvioEmLote')
	&XMLWriter.WriteElement('PastaXmlEmLote', &Mensagem)
	
	&Mensagem = &sdtConfiguracoesPasta.PastaNFenvio
	&Mensagem = &Mensagem.Replace('envio', 'Validar')
	&XMLWriter.WriteElement('PastaValidar', &Mensagem)
	
	&Mensagem = &sdtConfiguracoesPasta.PastaNFenvio
	&Mensagem = &Mensagem.Replace('envio', 'DownloadNFe')
	&XMLWriter.WriteElement('PastaDownloadNFeDest', &Mensagem)
	
	&XMLWriter.WriteElement('UnidadeFederativaCodigo', RetornaCodigoSiglaEstado.Udp(0, &FilCidUfeCod) )
	
	&XMLWriter.WriteElement('AmbienteCodigo', iif(&FilAmbEms = TAmb.Producao, '1', '2') )
	//&FilTipEms
	
	&XMLWriter.WriteElement('UsaCertificado','true')
	&XMLWriter.WriteElement('CertificadoInstalado','false')
	
	if not &FiLCerPsw.IsEmpty()
		&XMLWriter.WriteElement('CertificadoArquivo', &CaminhoCertificado.Trim())
		&XMLWriter.WriteElement('CertificadoSenha', &FiLCerPsw.Trim())
	Endif
	
	&XMLWriter.WriteElement('DiasLimpeza', '15')
	&XMLWriter.WriteElement('TempoConsulta', '2')
	
	&XMLWriter.WriteElement('ArqNSU', 'True')
	
	if not &FilSenQrCode.IsEmpty() and not &FilIdQrCode.IsEmpty()
		&XMLWriter.WriteElement('IdentificadorCSC', &FilSenQrCode)
		&XMLWriter.WriteElement('TokenCSC', padl(trim(str(&FilIdQrCode)), 6, '0'))
	Endif

	&XMLWriter.WriteEndElement()//altConfUniNFe	
	&XMLWriter.Close()
Endif
]]></Source>
