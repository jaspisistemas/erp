      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do Case 
	CAse &PadGrupNfeNfs = 'NS'
		For Each Order EmpCod, NfsFilCod, NfsCliCod, (NfsDtaEms)
			Where EmpCod = &EmpCod
			Where NfsFilCod = &FilCod
			Where NfsCliCod = &NfsCliCod
			Where NfsSts = Status_NFe.Autorizada or NfsSts = Status_NFe.Digitando
			&NfsDtaEms = NfsDtaEms
			&nfsNum = NfsNum
			&UltimaNotaVarchar =  trim(toformattedString(&NfsDtaEms)) + 'N: ' + trim(str(&nfsNum)) + ' R$: '+ trim(toformattedString(NfsVlrTot))
			Exit
		EndFor
	Case &PadGrupNfeNfs = '55'
		For Each Order EmpCod, FilCod, NfeCliCod, (NfeDtaEms)
			Where EmpCod = &EmpCod
			Where NfeFilCod = &FilCod
			Where NfeCliCod = &NfsCliCod
			Where NfeSts = Status_NFe.Autorizada or NfeSts = Status_NFe.Digitando
			//Where NfeDtaEms > &NfsDtaEms
			&NfsDtaEms = NfeDtaEms
			&nfsNum = NfeNum
			&UltimaNotaVarchar = trim(toformattedString(&NfsDtaEms)) + ' N: ' + trim(str(&nfsNum)) + ' R$: '+ trim(toformattedString(NfeVlrTot)) 
			Exit
		EndFor
EndCase


]]></Source>
