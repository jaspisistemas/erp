      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&OutDias = 0
For Each Order EmpCod, CidCod
	Where EmpCod = &EmpCod
	Where CidCod = &CidCod
	&UfeCod = UfeCod
	&paiCod = PaiCod
	Exit
EndFor

&CreDtaVct = &Vencimento
&ForDias = &Pagamento - &Vencimento
&ForDias += 1
For &Count = 1 to &ForDias
	
	do 'IsSomaNaoUtil'
	
	if &IsUtil = true
		&Dias += 1
	Else // Nao Uteis
		&NaoDias += 1
	EndIF

	&CreDtaVct += 1
EndFOr

if &S_Util = 'S'  
	&OutDias = &Dias
Else
	&OutDias = &NaoDias
EndIF


sub 'IsSomaNaoUtil'
	&IsUtil = true
	Do Case
		Case dow(&CreDtaVct) = 7  //Se Vencimento For Sabado, Muda Vencimento para Segunda;
			&IsUtil = false
			
		Case dow(&CreDtaVct) = 1  //Se Vencimento For Domingo, Muda Vencimento para Segunda;
			&IsUtil = false
			
		Otherwise
			&EmpFrdDia = Substr(trim(toformattedString(&CreDtaVct)), 1, 5)
			For Each Order EmpCod, EmpFrdDta
				Where EmpCod = &EmpCod
				Where (EmpFrdDta = &CreDtaVct and EmpFrdFix = Status_SimNao.Nao)
				or (EmpFrdDia = &EmpFrdDia and EmpFrdFix = Status_SimNao.Sim)
				
				Do Case
					Case EmpFrdNac = TipoRegiao.Nacional
						If EmpFrdPaiCod = &paiCod or EmpFrdPaiCod.IsEmpty()
							&IsUtil = false
							Exit
						EndIF
						
					Case EmpFrdNac = TipoRegiao.Estadual
						If EmpFrdUfeCod = &UfeCod and EmpFrdPaiCod = &paiCod
							&IsUtil = false
							Exit
						EndIF
						
					Case EmpFrdNac = TipoRegiao.Municipal
						If EmpFrdCidCod = &CidCod
							&IsUtil = false
							Exit
						EndIF
				EndCAse
			EndFor
			
	EndCase
EndSub
]]></Source>
