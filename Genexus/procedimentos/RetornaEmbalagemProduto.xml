      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	where ProSts <> Status_Produto.EXCLUIDO
	
	
	&ProTipDef = ProTipDef
	&ProEmbCod = ProEmbCod
	&ProEmbNom = ProEmbNom.Trim()
	
	&GrupSpedNatRec = GrupSpedNatRec
	Exit
EndFor
]]></Source>
