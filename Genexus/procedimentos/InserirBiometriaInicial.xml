      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod,AloCod
	Where EmpCod = &EmpCod
	Where AloCod = &AloCod
	&AloDtaIni = AloDtaIni
	exit
EndFor


For Each Order EmpCod,LotCod
	Where EmpCod = &EmpCod
	Where LotCod = &AloLotCod
	&LotIniKgs = LotIniKgs
	&LotFilCod = LotFilCod
	do 'Gravabiometria'
	Exit
EndFor

commit

AtualizaBiometria.Call(&EmpCod,&auxBioCod )

Sub 'Gravabiometria'
	UltimoCodigoEmpresa.Call(domParCod.BIOMETRIA,&EmpCod,0,&auxBioCod)
	New
		EmpCod = &EmpCod
		BioCod = &auxBioCod
		BioFilCod = &LotFilCod
		BioAloLin = &AloLin
		BioQtdAmo = 1
		BioTotPeso = &LotIniKgs
		BioAloCod = &AloCod 
		BioObs = 'Inicio Alojamento'
		BioDta = &AloDtaIni
		BioHor = ServerNow()
		BioDtaHor = serverNow()
	EndNew	
EndSub


]]></Source>
