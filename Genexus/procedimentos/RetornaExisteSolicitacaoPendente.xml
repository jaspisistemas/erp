      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsPendente = false
&DataHoraAtual = serverNow()
&SolDtaHorIni = &DataHoraAtual.AddMinutes(-2)

For Each order SolTip, SolEmpCod, SolFilCod, SolNfeCod, SolSts
	where SolEmpCod = &EmpCod when &EmpCod > 0
	where SolFilCod = &FilCod when &FilCod > 0
	where SolSts = Status_solicitacao.Pendente or SolSts = Status_solicitacao.Executando
	where SolTip = &SolTip
	Where SolNfeCod = &SolNfeCod when &SolNfeCod > 0
	Where SolItmCod = &SolItmCod when &SolItmCod > 0
	Where SolDtaHorIni > &SolDtaHorIni
	
	&IsPendente = true
	&SolCod = SolCod
	
	Exit
EndFor


