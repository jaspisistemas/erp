      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&NovComItmCod = &ComItmCod
&AlteradoMensagem = ''
&InseridoMensagem = ''

if &OqueFazer <> 'DEL'
	For Each Order EmpCod, PesCod, ComDta, ComItmCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where ComDta = &ComDta
		Where ComItmCod = &NovComItmCod
		
		ComObs = &ComObs
		ComTotVlr = &ComTotVlr
		
		&AlteradoMensagem = 'Lançamento de Crédito/Débito ALTERADO com Sucesso!'
		Exit
	When None
		&NovComItmCod = 0
		
		For Each Order EmpCod, PesCod, ComDta
			Where EmpCod = &EmpCod
			Where PesCod = &PesCod
			Where ComDta = &ComDta
			&NovComItmCod = ComUltItmCod
			Exit
		When none
			New
				EmpCod = &EmpCod
				PesCod = &PesCod
				ComDta = &ComDta
			EndNew
			
			Commit
		EndFor
		
		&NovComItmCod += 1
		
		new
			EmpCod = &EmpCod
			PesCod = &PesCod
			ComDta = &ComDta
			ComItmCod = &NovComItmCod
			ComObs = &ComObs
			ComTotVlr = &ComTotVlr
		EndNEw
		
		&InseridoMensagem = 'Lançamento de Crédito/Débito INSERIDO com Sucesso!'
	EndFor
Else
	For Each Order EmpCod, PesCod, ComDta, ComItmCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where ComDta = &ComDta
		Where ComItmCod = &NovComItmCod
		Delete
	EndFor
EndIf

Commit
]]></Source>
