      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,PesEml,PesCod
	Where EmpCod = &EmpCod
	
	
	&PesCod = PesCod
	&PesEml = PesEml
	Do 'AdicionaEmail'
EndFor

Sub 'AdicionaEmail'
	&IsAdicioando = false
	For &SdtEmailAgrupadosItem in &SdtEmailAgrupados	
		If &SdtEmailAgrupadosItem.PesEml  = &PesEml //verifica o email
			&SdtEmailAgrupadosItem.PesQtd += 1
			&IsAdicioando = true
			do 'VerificaCliente'			
		EndIf
		
	EndFor

	If &IsAdicioando = false
		&SdtEmailAgrupadosItem = new()
		&SdtEmailAgrupadosItem.PesEml = &PesEml	
		&SdtEmailAgrupadosItem.PesQtd = 1
		&SdtEmailAgrupadosItem.PesEnvia = False
		
	
		&SdtEmailAgrupadosClienteItem = new()
		&SdtEmailAgrupadosClienteItem.PesCod = &PesCod
		&SdtEmailAgrupadosItem.Clientes.Add(&SdtEmailAgrupadosClienteItem)
		
		&SdtEmailAgrupados.Add(&SdtEmailAgrupadosItem)
	EndIf
	
EndSub

Sub 'VerificaCliente'
	&IsAdicioandoCliente = false
	For &SdtEmailAgrupadosClienteItem in &SdtEmailAgrupadosItem.Clientes
		
		If &SdtEmailAgrupadosClienteItem.PesCod = &PesCod //verifica o cliente
			&IsAdicioandoCliente = true
		EndIf
	EndFor
	
	If &IsAdicioandoCliente = false
		&SdtEmailAgrupadosClienteItem = new()
		&SdtEmailAgrupadosClienteItem.PesCod = &PesCod
		&SdtEmailAgrupadosItem.Clientes.Add(&SdtEmailAgrupadosClienteItem)
	EndIf
	
EndSub
]]></Source>
