<Object parentGuid="2029c88d-bc03-4d0a-89d8-cf9907782d43" user="WINJEAN\jeanfae" versionDate="2025-03-03T21:12:34.0000000Z" lastUpdate="2025-02-28T12:48:13.0000000Z" checksum="db3602f52488a8ccf4a4327682442cf0" fullyQualifiedName="api_erp.get_wwmovimentos" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="9ec4f843-c21d-427a-aaf8-c2cb282ba867" name="get_wwmovimentos" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_wwmovimentos" parent="api_erp.Financeiro" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	&sdtMovimentos.sts = 'J200'
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	
	&sdtMovimentos.pA = '0'
	&sdtMovimentos.pT = '0'
	&sdtMovimentos.p1 = '0'
	&sdtMovimentos.p2 = '0'
	&sdtMovimentos.p3 = '0'
	&sdtMovimentos.p4 = '0'
	&sdtMovimentos.p5 = '0'
	&IsPaginaOk = false
	
	if &DtaInicialTmp > 0
		timestampToDate.Call(&DtaInicialTmp, &MovDtaCon)
	Endif
	if &DtaFinalTmp > 0
		timestampToDate.Call(&DtaFinalTmp, &MovDtaCon_To)
	Endif
	
	&SoNumeros = retornaSoNumeros.Udp(&localizar)
	&LocalizarCodigo = val(&SoNumeros)
	
	
	For Each 
		Order EmpCod, MovCtaBanCod, (MovDtaCon), (MovCod) when &Ordem = 'D' or &Ordem.IsEmpty()
		Order EmpCod, MovCtaBanCod, MovDtaCon, MovCod when &Ordem = 'C'
		Where EmpCod = &wwpContext.EmpCod
		Where MovCtaBanCod = &MovCtaBanCod
		Where MovCplTot like &localizar or MovDoc like &localizar or MovCod = &LocalizarCodigo when not &localizar.IsEmpty()
		Where MovDtaCon >= &MovDtaCon WHEN not &MovDtaCon.isempty()
		Where MovDtaCon <= &MovDtaCon_To WHEN not &MovDtaCon_To.isempty()
		Where MovSts.isempty() or MovSts.isnull() or MovSts <> Status_Caixa.Cancelado WHEN &IsCancelado <> TRUE
		
		&sdtMovimentos.obs = MovCtaBanNom
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&sdtMovimentos.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				
				&sdtMovimentosItem = new()
				&sdtMovimentosItem.movCod = MovCod
				
				if not MovCplTot.IsEmpty() and not MovCplTot.IsNull()
					&sdtMovimentosItem.movCpl = MovCplTot
				Else
					&sdtMovimentosItem.movCpl = 'LANÇAMENTO: ' + iif(MovCreDeb = 'D', 'DÉBITO', 'CRÉDITO')
				Endif
				
				&sdtMovimentosItem.movCreDeb = MovCreDeb
				&sdtMovimentosItem.movDoc = MovDoc
				&sdtMovimentosItem.movSts = MovSts
				&sdtMovimentosItem.movDtaCon = trim(MovDtaCon.ToFormattedString())
				&sdtMovimentosItem.movDtaConTmp = datetotimestamp(MovDtaCon)
				&sdtMovimentosItem.movDtaPgtTmp = datetotimestamp(MovDtaPgt)
				&sdtMovimentosItem.movDtaPgt = trim(MovDtaPgt.ToFormattedString())
				&sdtMovimentosItem.movTip = MovTip
				&sdtMovimentosItem.movTipDesc = MovTip.EnumerationDescription()
				if MovSts = 'C' //CANCELADO
					&MovVlr = 0
					For Each Order EmpCod, MovCod, MovItmCod
						Where MovItmSts <> Status_Caixa.Cancelado or MovItmSts.isempty() or MovItmSts.isnull()
						&MovVlr += MovItmVlr
					EndFor
				
					&sdtMovimentosItem.movVlr = trim(&MovVlr.ToFormattedString())
				Else
					&sdtMovimentosItem.movVlr = trim(MovVlr.ToFormattedString())
				EndIf
				
				&sdtMovimentos.item.Add(&sdtMovimentosItem)
				
			Endif		
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
	When none
		For Each Order EmpCod, CtabanCod
			Where EmpCod = &wwpContext.EmpCod
			Where CtabanCod = &MovCtaBanCod
			&sdtMovimentos.obs = CtaBanNom
			Exit
		EndFor
	
	EndFor
	
	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&sdtMovimentos.pA = trim(str(&Pagina))
		&sdtMovimentos.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &sdtMovimentos.p1, &sdtMovimentos.p2, &sdtMovimentos.p3, &sdtMovimentos.p4, &sdtMovimentos.p5)
		
	Endif
	
Endif
]]></Source>
