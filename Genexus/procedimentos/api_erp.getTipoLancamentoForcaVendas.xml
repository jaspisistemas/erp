      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, AppCod
	Where EmpCod = &EmpCod
	Where AppCod = TipoAplicativo.FORCAVENDAS
	&AppCon005 = AppCon005
	&AppCon006 = AppCon006
	&AppCon009 = AppCon009
	Exit
EndFor

if &AppCon005.IsEmpty() //orcamento
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctTip = TipoLancamento.OrcamentoVenda
		&AppCon005 = LctCod
		Exit
	EndFor
Endif

if &AppCon006.IsEmpty() //TIpo Lancamento Venda
	For Each Order EmpCod, LctCod
		Where EmpCod = &EmpCod
		Where LctTip = TipoLancamento.SaidaMercadoria
		Where LctGerFin = Status_SimNao.Sim
		&AppCon006 = LctCod
		Exit
	EndFor
Endif


if &AppCon009.IsEmpty() //Cliente Consumidor
	retornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon020_ClientePadraoVista, &TCon020_ClientePadraoVista)
	&AppCon009 = val(&TCon020_ClientePadraoVista)
Endif


]]></Source>
