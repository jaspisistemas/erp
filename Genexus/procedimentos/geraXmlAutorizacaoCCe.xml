<Object parentGuid="d5f687c3-2181-4efd-94e2-024651619340" user="" versionDate="2022-06-28T23:50:51.0000000Z" lastUpdate="2021-09-22T13:45:41.0000000Z" checksum="47cb195cdda647bedb856b486f9283fe" fullyQualifiedName="geraXmlAutorizacaoCCe" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="ddb48a29-fac8-47a1-9276-f6fadcc9de0c" name="geraXmlAutorizacaoCCe" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="gera Xml Autorizacao CCe" parent="prccce" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
LoadWWPContext.Call(&Context)
&PesCod = &Context.PesCod

retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&Hoje = serverdate()
&VersaoNF = '1.00'

GravaSolicitacao.Call(&EmpCod, &FilCod, &NfeCod, &NfeCceCod, TipoSolicitacao.Autoriza_CCe, &PesCod, &SolCod)

//Pega Ultima Evento de Carta Autorizada
For each Order EmpCod, FilCod, NfeCod, (NfeCCeEvtCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	Where NfeCCeSts = Status_NFe.Autorizada
    &NfeCCeEvtCod = NfeCCeEvtCod
	Exit
EndFor
&NfeCCeEvtCod += 1
	
//dados da NFe
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	&cUF = substr(str(FilCidUfeIbge,7,0),1,2)
	&FilFusHor = FilFusHor
	&FilAmbEms = FilAmbEms
	&FilCpj = RetornaSoNumeros.Udp(FilCpj)
	&NfeChv = NfeChv
	
	For each Order EmpCod, FilCod, NfeCod, NfeCCeCod
		Where NfeCCeCod = &NfeCceCod
		
		If not NfeCCeCor.IsEmpty()
			&NfeCCeCor = RetiraCaracteresEspeciais.Udp(NfeCCeCor)
			//replace  genexus para retirar ENTER das descrições
			&NfeCCeCor = Trim(strreplace(&NfeCCeCor,Chr(10),';'))
			&NfeCCeCor = Trim(strreplace(&NfeCCeCor,Chr(13),';'))
			&NfeCCeCor = &NfeCCeCor.Trim()
		EndIf
		Exit
		
	EndFor	
    Exit
EndFor

&nomeArquivo 	= &NfeChv.Trim() + '-' + padL(trim(str(&NfeCCeEvtCod)),2,'0') 
&ID 			= 'ID110110' + &NfeChv + padL(trim(str(&NfeCCeEvtCod)),2,'0')
&IdLote 		= trim(str(&FilCod)) + trim(str(&NfeCod)) + trim(str(&NfeCceCod))

&ano = str(YEAR(&hoje))
&mes = str(MONTH(&hoje))
&dia = str(DAY(&hoje))
&hojeHora = TAdd(servernow(), -100)

&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hojeHora))),2, '0') + ':00'

&CondicoesUso = 'A Carta de Correcao e disciplinada pelo paragrafo 1o-A do art. 7o do Convenio S/N, de 15 de dezembro de 1970 e pode ser utilizada para regularizacao de erro ocorrido na emissao de documento fiscal, desde que o erro nao esteja relacionado com: I - as variaveis que determinam o valor do imposto tais como: base de calculo, aliquota, diferenca de preco, quantidade, valor da operacao ou da prestacao; II - a correcao de dados cadastrais que implique mudanca do remetente ou do destinatario; III - a data de emissao ou de saida.'

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + trim(&nomeArquivo) + '-env-cce.xml'

&ArqNota.Open(&Nome_enviar)

// START DOC xml
&ArqNota.WriteStartDocument(Encoding.UTF_8)

&ArqNota.WriteStartElement('envEvento')

&ArqNota.WriteAttribute('versao',&VersaoNF)
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')

&ArqNota.WriteElement('idLote', &IdLote)

&ArqNota.WriteStartElement('evento')
&ArqNota.WriteAttribute('versao', &VersaoNF)
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/nfe')

&ArqNota.WriteStartElement('infEvento')
&ArqNota.WriteAttribute('Id', &ID)

&ArqNota.WriteElement('cOrgao', &cUF)
&ArqNota.WriteElement('tpAmb',&FilAmbEms)

If &FilCpj.Length() > 11
	&ArqNota.WriteElement('CNPJ', &FilCpj)
Else
	&ArqNota.WriteElement('CPF', &FilCpj)
EndIf
&ArqNota.WriteElement('chNFe', &NfeChv)

&ArqNota.WriteElement('dhEvento',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' + &hora + '-' + trim(&FilFusHor))
&ArqNota.WriteElement('tpEvento', '110110')
&ArqNota.WriteElement('nSeqEvento',trim(str(&NfeCCeEvtCod)))
&ArqNota.WriteElement('verEvento', &VersaoNF)

&ArqNota.WriteStartElement('detEvento')
&ArqNota.WriteAttribute('versao', &VersaoNF) 
&ArqNota.WriteElement('descEvento', 'Carta de Correcao')
&ArqNota.WriteElement('xCorrecao', &NfeCCeCor.Trim())
&ArqNota.WriteElement('xCondUso', &CondicoesUso.Trim())

&ArqNota.WriteEndElement()
&ArqNota.WriteEndElement()
&ArqNota.Close()

wpAutorizaCCeRecepcao.Link(&DeOndeVem, &EmpCod, &FilCod, &NfeCod, &NfeCceCod, &SolCod)
]]></Source>
