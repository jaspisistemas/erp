      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Total = 100
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
&Mensagem = ''
do 'Atualiza'

&HojeData = serverdate()
&AuxFim = &HojeData.AddDays(1)

RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon031_TipoLctoBalanco, &CfgVlr)
&LctCod = iif(&CfgVlr.IsEmpty(), 0, Val(&CfgVlr))

&PedItmCod = 0

For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	&PedCliCod = 1
	if FilPesCod > 0 
		&PedCliCod = FilPesCod
	EndiF

	&BalDta = BalDta
	&FilTabCod = FilTabCod
	
	if BalSts <> Status_Pedido.ABERTO or BalStsPrc <> AtualizandoEstoquePedido.Aberto
		Return
	EndIF

    BalSts = Status_Pedido.FECHADO
	BalStsPrc = AtualizandoEstoquePedido.Fechando
	
	&PedCod = BalPedCod
	if BalPedCod = 0
		UltimoCodigoEmpresa.Call(domParCod.PEDIDO, &EmpCod, &FilCod, &PedCod)
		BalPedCod = &PedCod
	EndIF
	&DataBaseBalDta = BalDta.AddDays(1)
	
    do 'addCapaPedido'
	
	&PedItmCod = 0
	For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
		
		&auxCount += 1
		if &auxCount = 200
			&CountPercent += 2
			If &CountPercent > 0
				&Percentual = round((&CountPercent / &Total) * 100, 0)
			EndIF
			If &Percentual >= 100
				&Percentual = 99
			EndIf
			do 'Atualiza'
			&auxCount = 0
		Endif
	
		&ProCod = ProCod
		&ProGraCod = ProGraCod
		&BalQtd = BalQtd
		&ProVlrCus = ProVlrCus
		
		if BalDta <> &HojeData
			EstoqueAnteriorFicha.Call(EmpCod,FilCod,ProCod,ProGraCod, 1, &DataBaseBalDta, &AuxFim, &BalQtdAnt)
		Else
			RetornaEstoquePedido.Call(EmpCod,FilCod,ProCod,ProGraCod, Status_Pedido.ABERTO, &EstLoc, &BalQtdAnt,&EstSdo, &Mensagem)
		Endif
	
		BalQtdAnt = &BalQtdAnt
		
						
		do 'InsereItem'
		
		For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod, BalLotCod
			
			&PedProEstLotCod = BalLotCod
			&PedProEstLotVct = BalLotVct
			&PedProEstLotFab = BalLotFab
			&PedProEstLotQtd = BalLotQtd
			&EstLotQtd = BalLotEstQtd
			
			do 'InsereItemLotes'
		EndFor
	
    EndFor
EndFor

commit
 
//AtualizaTotaisPedido
AtualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, 'C')
AtualizaEstoqueEntradaSaida.Call( &EmpCod, &FilCod, &PedCod, Status_Pedido.FECHADO)

For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	EstProStsBal = retornaProdutoBalanco.Udp(EmpCod, FilCod, ProCod, ProGraCod)
EndFor

commit

For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	BalStsPrc = AtualizandoEstoquePedido.Fechado
	
	Exit
EndFor
commit

&Percentual = 100
&ProgressFin = serverNow()
//&Mensagem = &SdtProdutos.ToJson()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &Mensagem
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &Mensagem
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub

Sub 'InsereItem'
	&PedItmCod += 1
    &Diferenca = (&BalQtd - &BalQtdAnt)
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedItmCod = &PedItmCod
		ProCod = &ProCod
		ProGraCod = &ProGraCod
		
		PedQtdCan = 0
		PedQtdEmb = &Diferenca
		PedQtd    = &Diferenca
		PedVlrUnt = &ProVlrCus
		
		PedProEstProCod = &ProCod
		PedProEstProGraCod = &ProGraCod
	EndNew
EndSub

Sub 'InsereItemLotes'
	&Diferenca = (&PedProEstLotQtd - &EstLotQtd)
	
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		PedItmCod = &PedItmCod
		PedProEstLotCod = &PedProEstLotCod
		PedProEstLotVct = &PedProEstLotVct
		PedProEstLotFab = &PedProEstLotFab  
		PedProEstLotQtd = &Diferenca
	EndNew

EndSub

Sub 'addCapaPedido'
	for Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
			
			PedDtaEms = &BalDta
			PedHorEms = serverTime()
			
			PedBlq = Status_SimNao.Sim
			PedStsGer = Pedido_Gerado.Interno
			PedStsFin = Status_Financeiro.FECHADO
			
			PedCliCod = &PedCliCod
			LctCod = &LctCod
			
			//PedTraCodSai = 1
			//PedTraCodDsp = 1
			
			PedSts = Status_Pedido.FECHADO
			PedDtaFat = &BalDta
			PedHorFat = serverNow()
			PedDtaFic = &BalDta //DATA FATURAMENTO
			TabCod = &FilTabCod
			TabColCod = 1
			
			PedTipFrt = TipoFrete.SemFrete
			PedPraCod = 1
			
			for Each Order EmpCod, FilCod, PedCod, PedItmCod				
				For Each Order EmpCod, FilCod, PedCod, PedItmCod, PedProEstLotCod
					Delete
				EndFor
			
				Delete
			EndFor
		Exit
	When none
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			
		    PedDtaEms = &BalDta
			PedHorEms = serverTime()
			
			PedBlq = Status_SimNao.Sim
			PedStsGer = Pedido_Gerado.Interno
			PedStsFin = Status_Financeiro.FECHADO
			
			PedCliCod = &PedCliCod
			LctCod = &LctCod
			
			//PedTraCodSai = 1
			//PedTraCodDsp = 1
			
			PedSts = Status_Pedido.FECHADO
			PedDtaFat = &BalDta
			PedHorFat = serverNow()
			PedDtaFic = &BalDta //DATA FATURAMENTO
			TabCod = &FilTabCod
			TabColCod = 1
			
			PedTipFrt = TipoFrete.SemFrete
			PedPraCod = 1
		EndNew	
		
		commit
	EndFOr

EndSub
]]></Source>
