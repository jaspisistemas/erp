      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, CteCod,CteEveCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &NfeCod
	Where CteEveCod = &NfeEveCod
	
	
	CteEveSts = &NfeSts
	CteEvePro = &NfeAutNumPro
	CteEveNro = '610110'
//	CteEvedtaEnt = &NfeAutDatHorRec
	
	Exit
EndFor




commit
]]></Source>
