      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&MensagemErro.SetEmpty()
&ProCod.SetEmpty()
RetornaProdutoReferencia.Call(&EmpCod,&ProGraRef,&ProCod,&ProGraCod,&ProNom,&IsAchouProduto,&ProReqVlr,&ProReqQtd,&ProBarQtd, &MensagemErro)

&PedCod.SetEmpty()
&PedItmCod.SetEmpty()

if &IsAchouProduto = true
	For each order EmpCod,FilCod,ProCod,PedCliCod,PedSts,(PedCod),PedItmCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where PedSts = Status_Pedido.FECHADO
		where LctAtuEst = Status_EntradaSaida.Saida
		where PedStsGer <> Pedido_Gerado.AgruparFaturar and PedStsGer <> Pedido_Gerado.DevolucaoCompra and PedStsGer <> Pedido_Gerado.Interno
		where ProCod = &ProCod
		where PedCliCod = &PedCliCod
		&PedCod = PedCod
		&PedItmCod = PedItmCod
		RetornaQtdDisponivelDevolucao.Call(&EmpCod,&FilCod,&ProCod,&ProGraCod,&DevPedCod,&PedCod,&PedItmCod,&PedCliCod,&QtdDisponivel)
		if (&QtdDisponivel + PedQtdDev_FORMULA - PedQtd) <> 0 //Qtd vendida - Qtd devolvida //se for zero é pq ja ta na devolucao
			&PedQtd = PedQtd - PedQtdDev_FORMULA
			exit
		EndIf
	when none
		&MensagemErro = "Não localizado nenhum Pedido 'FECHADO' com este produto. "
	EndFor
EndIF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
