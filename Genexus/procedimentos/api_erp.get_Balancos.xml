      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwBalanco.qtd = 0
	
	if &parBalSts.IsEmpty() or &parBalSts = 'T'
		&BalSts.SetEmpty()
	Else
		&BalSts.FromString(&parBalSts)
	Endif
	
	if &BalDtaIniTmp > 0
		&BaldtaIni = TimestampToDate.Udp(&BalDtaIniTmp)
	Endif
	&BaldtaFin = TimestampToDate.Udp(&BalDtaFinTmp)
	
	&wwBalanco.pA = '0'
	&wwBalanco.pT = '0'
	&wwBalanco.p1 = '0'
	&wwBalanco.p2 = '0'
	&wwBalanco.p3 = '0'
	&wwBalanco.p4 = '0'
	&wwBalanco.p5 = '0'
	&IsPaginaOk = false
	
	retornaAutorizacaoApi.Call('EDITARBALANCOOUTROS', &wwpContext, &AutGrpCod, &OutroVendedor_AutNiv)
	
	For Each Order EmpCod, (BalCod)
		Where EmpCod = &wwpContext.EmpCod
		Where BalCod = &balCod when not &balCod.IsEmpty()
		Where BalSts = &BalSts when (not &parBalSts.IsEmpty() and not &parBalSts = 'T')
		Where BalSts = Status_Pedido.ABERTO or BalSts = Status_Pedido.FECHADO when (&parBalSts.IsEmpty() or &parBalSts = 'T')
		Where BalFunCod = &wwpContext.PesCod when &OutroVendedor_AutNiv < 1
		Where (BalDta >= &BaldtaIni or &BaldtaIni.IsEmpty()) and BalDta <= &BaldtaFin
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwBalanco.qtd = 0
					&wwBalanco.Balanco.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				&wwBalanco.qtd += 1
				
				&wwBalancoItem = new()
				&wwBalancoItem.cod = BalCod
				&wwBalancoItem.dta = BalDta.ToFormattedString()
				&wwBalancoItem.obs = BalObs
				&wwBalancoItem.sts = BalSts
				&wwBalancoItem.stsN = BalSts.EnumerationDescription()
				&wwBalancoItem.pesC = BalFunCod
				&wwBalancoItem.fil = FilCod
				&wwBalancoItem.ped = BalPedCod
				&wwBalanco.Balanco.Add(&wwBalancoItem)
			Endif	
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
	When none
		&wwBalanco.qtd = 0
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwBalanco.pA = trim(str(&Pagina))
		&wwBalanco.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwBalanco.p1, &wwBalanco.p2, &wwBalanco.p3, &wwBalanco.p4, &wwBalanco.p5)
	Endif

	&wwBalanco.sts = 'J200'
EndIf

]]></Source>
