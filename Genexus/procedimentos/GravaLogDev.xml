      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&pLogNom = &LogNom
if &LogGUID.IsEmpty()
	&LogGUID = GUID.newGuid()
	&pLogNom = '[AUTOGUID] ' + &pLogNom
endif

for each
	order EmpCod, LogDataHora, LogCod
	where EmpCod  = &EmpCod
	where LogGUID = &LogGUID
	&LogCod = LogCod
	
	new
		LogItemCod      = (max(LogItemCod, LogCod = &LogCod ) + 1)
		LogItemNome     = &LogItemNome
		LogItemConteudo = &LogItemConteudo
		LogItemDataHora = DateTime.Now()
	endnew
	
	exit
when none
	for each
		order (LogCod), EmpCod
		where EmpCod = &EmpCod
		&LogCod = (LogCod + 1)
		
		new
			EmpCod      = &EmpCod
			LogCod      = &LogCod
			FilCod      = &FilCod
			LogNom      = &pLogNom
			LogGUID     = &LogGUID
			LogDataHora = DateTime.Now()
			
			new
				LogItemCod      = 1
				LogItemNome     = &LogItemNome
				LogItemConteudo = &LogItemConteudo
				LogItemDataHora = DateTime.Now()
			endnew
		endnew
		exit
	when none
		new
			EmpCod      = &EmpCod
			LogCod      = 1
			LogNom      = &pLogNom
			LogGUID     = &LogGUID
			LogDataHora = DateTime.Now()
			
			new
				LogItemCod      = 1
				LogItemNome     = &LogItemNome
				LogItemConteudo = &LogItemConteudo
				LogItemDataHora = DateTime.Now()
			endnew
		endnew
	endfor
endfor

commit
]]></Source>
