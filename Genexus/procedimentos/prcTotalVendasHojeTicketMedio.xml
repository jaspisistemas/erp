      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod,FilCod,LctTip,LctGerFin,LctAtuSal,PedSts	
	Where EmpCod = &EmpCod
	where FilCod = &FilCod
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where LctGerFin = Status_SimNao.Sim
	Where LctAtuSal = Status_EntradaSaida.Saida
	Where PedSts = Status_Pedido.FECHADO
	Where PedDtaFat >= &PedDtaFat and PedDtaFat <= &PedDtaFat_Go
	Where LctAtuGra = Status_SimNao.Sim Or LctAtuGra.IsNull()
	Where PedBlq = Status_SimNao.Nao
	
	
	if PedDtaFat = &PedDtaFat_Go
		&HojePedVlrLiq += PedVlrLiq
	Endif

	&Count += 1
	&PedVlrLiq += PedVlrLiq
EndFor


If &Count > 0 and &PedVlrLiq > 0
	&MediaMensalMoeda = &PedVlrLiq/&Count
EndIf
]]></Source>
