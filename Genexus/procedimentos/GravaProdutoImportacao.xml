<Object parentGuid="69276173-76cd-45fd-9f52-1af9cde0578d" user="WIN-JEAN\jean.fae" versionDate="2024-06-20T13:36:36.0000000Z" lastUpdate="2024-06-20T11:17:29.0000000Z" checksum="14e7ae9575e11d64954448f340b26282" fullyQualifiedName="GravaProdutoImportacao" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="7d227da8-ba79-41b2-a2b3-2d5bddb1113a" name="GravaProdutoImportacao" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Grava Produto Importacao" parent="ProPrc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


If &Mode = TrnMode.Insert
	
	&ProCod = &sdtGravaProduto.ProCod
	if &ProCod.IsEmpty()
		////SENAO LOCALIZA UM DISPONIVEL
		UltimoCodigoEspecial.Call(domParCod.PRODUTO, &EmpCod, 0, &ProCod)		
	Endif
	
	New
		EmpCod = &EmpCod
		ProCod = &ProCod
		ProRef = &sdtGravaProduto.ProRef
		ProBar = &sdtGravaProduto.ProBar
		ProNom = &sdtGravaProduto.ProNom
		ProSts = iif(&sdtGravaProduto.Prosts = Status_AtivoInativo.ATIVO, Status_Produto.ATIVO, Status_Produto.INATIVO)
		ProEmbCod = &sdtGravaProduto.ProEmbCod
		MarCod = &sdtGravaProduto.MarCod
		ProSetCod = &sdtGravaProduto.ProSetCod
		GrupCod = &sdtGravaProduto.GrupCod
		NcmCod = &sdtGravaProduto.ProNcmCod
		ProNcmCest = &sdtGravaProduto.ProNcmCest
		ProCatCod = &sdtGravaProduto.ProCatCod
		ProTipDef = &sdtGravaProduto.ProTipDef
		
		ProPadForCod = &sdtGravaProduto.ProPadForCod
		ProTipCus = &sdtGravaProduto.ProTipCus
		ProPadUltCmp = &sdtGravaProduto.ProPadUltCmp
		ProVlrCusFix = &sdtGravaProduto.ProVlrCusFix
		ProIMCTot = &sdtGravaProduto.ProIMCTot
		ProIMC = &sdtGravaProduto.ProIMC
		ProDet = &sdtGravaProduto.ProDet
		ProPesLiq = &sdtGravaProduto.ProPesLiq
		ProDesMax = &sdtGravaProduto.ProDesMax
		ProQtdEmb = &sdtGravaProduto.ProQtdEmb
		ProInfCmp = &sdtGravaProduto.ProInfCmp
		ProReqVen = &sdtGravaProduto.ProReqVen
		ProReqQtd = &sdtGravaProduto.ProReqQtd
		ProRepItm = &sdtGravaProduto.ProRepItm
		ProEstTip = &sdtGravaProduto.proEstTip
		ProTip = &sdtGravaProduto.ProTip
		ProSolLot = &sdtGravaProduto.ProSolLot
		ProObrAnp = &sdtGravaProduto.ProObrAnp
		ProQtdCmpEmb = &sdtGravaProduto.ProQtdCmpEmb	
		
		ProNomNF = &sdtGravaProduto.ProNomNF
		ProDesEtq1 = &sdtGravaProduto.ProDesEtq1
		ProDesEtq2 = &sdtGravaProduto.ProDesEtq2
		ProDesEtq3 = &sdtGravaProduto.ProDesEtq3 
		ProOriCod = &sdtGravaProduto.ProOriCod
		ProOriTriCod = &sdtGravaProduto.ProOriTriCod

		ProDtaCad = serverdate()
	EndNEw

	Commit
	
	
	ProVlrCus_Produto.Call( &EmpCod, &ProCod)	
	if &sdtGravaProduto.ProBar.IsEmpty()
		if &sdtGravaProduto.ProTipDef <> Definicao.SERVICO
			GeraEANproduto.Call(&EmpCod, &ProCod)
		Else
			GeraEANservico.Call(&EmpCod, &ProCod)
		EndIF
	EndIF
	
	GravaGradeProduto.call(&EmpCod, &ProCod, &NcmCod)
	
	iniciaEstoque.Call( &EmpCod, &FilCod, &ProCod, 1)
	
	RetornaConfSistema.Call(&EmPCod, &FilCod, domConfSistema.TCon083_Markup, &TCon083_Markup)
	
	GravaIMCPRODUTO.Call(&EmpCod, &ProCod, &ProVlrCusFix, &TCon083_Markup)
		
	&TabPrc1 = &sdtGravaProduto.TabPrc1
	&TabCod = RetornaTabelaFilial.Udp(&EmpCod, &FilCod)
	
	For Each Order EmpCod, TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		
		RetornaColunasTabelas.Call(EmpCod, TabCod, &TabPerCol, &TabPerCol2, &TabPerCol3,&TabPerCol4,&TabPerCol5,&TabPerCol6,&TabPerCol7,&TabPerCol8,&TabPerCol9,&tem1,&tem2,&tem3,&tem4,&tem5,&tem6,&tem7,&tem8,&tem9)
		
		If TabIsPerCol1 = true
	        
			if &TabPerCol2 <> 0 
	            &TabPrc2 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol2/100),2)
			Else
				&TabPrc2 = &TabPrc1
	        EndIF
			
	        if &TabPerCol3 <> 0 
	            &TabPrc3 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol3/100),2)
			Else
				&TabPrc3 = &TabPrc1
	        EndIF
			
	        if &TabPerCol4 <> 0 
	            &TabPrc4 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol4/100),2)
			Else
				&TabPrc4 = &TabPrc1
	        EndIF
			
	        if &TabPerCol5 <> 0 
	            &TabPrc5 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol5/100),2)
			Else
				&TabPrc5 = &TabPrc1
	        EndIF
			
	        if &TabPerCol6 <> 0 
	            &TabPrc6 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol6/100),2)
			Else
				&TabPrc6 = &TabPrc1
	        EndIF
			
	        if &TabPerCol7 <> 0 
	            &TabPrc7 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol7/100),2)
			Else
				&TabPrc7 = &TabPrc1
	        EndIF
			
	        if &TabPerCol8 <> 0 
	            &TabPrc8 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol8/100),2)
			Else
				&TabPrc8 = &TabPrc1
	        EndIF
			
	        if &TabPerCol9 <> 0 
	            &TabPrc9 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol9/100),2)
			Else
				&TabPrc9 = &TabPrc1
	        EndIF
	    Else
	        if &TabPerCol2 <> 0 
	            &TabPrc2 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol2/100),2)
			Else
				&TabPrc2 = &TabPrc1
	        EndIF
			
	        if &TabPerCol3 <> 0 
	            &TabPrc3 = round(&TabPrc2 + (&TabPrc2 * &TabPerCol3/100),2)
			Else
				&TabPrc3 = &TabPrc2
	        EndIF
			
	        if &TabPerCol4 <> 0 
	            &TabPrc4 = round(&TabPrc3 + (&TabPrc3 * &TabPerCol4/100),2)
			Else
				&TabPrc4 = &TabPrc3
	        EndIF
			
	        if &TabPerCol5 <> 0 
	            &TabPrc5 = round(&TabPrc4 + (&TabPrc4 * &TabPerCol5/100),2)
			Else
				&TabPrc5 = &TabPrc4
	        EndIF
			
	        if &TabPerCol6 <> 0 
	            &TabPrc6 = round(&TabPrc5 + (&TabPrc5 * &TabPerCol6/100),2)
			Else
				&TabPrc6 = &TabPrc5
	        EndIF
			
	        if &TabPerCol7 <> 0 
	            &TabPrc7 = round(&TabPrc6 + (&TabPrc6 * &TabPerCol7/100),2)
			Else
				&TabPrc7 = &TabPrc6
	        EndIF
			
	        if &TabPerCol8 <> 0 
	            &TabPrc8 = round(&TabPrc7 + (&TabPrc7 * &TabPerCol8/100),2)
			Else
				&TabPrc8 = &TabPrc7
	        EndIF
			
	        if &TabPerCol9 <> 0 
	            &TabPrc9 = round(&TabPrc8 + (&TabPrc8 * &TabPerCol9/100),2)
			Else
				&TabPrc9 = &TabPrc8
	        EndIF
	    EndIF				
		
		GravaProdutoNaTabela.Call(EmpCod, TabCod, TabUltAlt, &ProCod, 1, 'ADDI', &Data, &Data, &TabPrc1, &TabPrc2, &TabPrc3, &TabPrc4, &TabPrc5, &TabPrc6, &TabPrc7,&TabPrc8,&TabPrc9,&wwpContextUserName)
		Exit
	EndFor
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&outProCod = ProCod
		&outProRef = ProRef
		Exit
	EndFor
EndIf

]]></Source>
