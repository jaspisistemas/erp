      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	print Cabecalho
	Print Titulo
End

For Each Order EmpCod, FilCod, GrupHiePadL, ProGraRefPadL
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PrdDtaEnt >= &iniPedDtaEms and PrdDtaEnt <= &finPrdDtaEnt 
	
	if &AuxProCod <>  ProCod or &AuxProGraCod <> ProGraCod
		if &PrdItmQtd > 0
			&sdtProdutosItem = new()
			&sdtProdutosItem.ProRef 	= &ProGraRef
			&sdtProdutosItem.ProNom 	= &ProNom
			&sdtProdutosItem.PedQtd 	= &PrdItmQtd
			&sdtProdutosItem.GrupHie 	= &GrupHie
			&sdtProdutosItem.GrupNomComp = &GrupNomComp
			&sdtProdutos.Add(&sdtProdutosItem)
		EndiF
		&PrdItmQtd = 0
	Endif
	
	&PrdItmQtd += PrdItmQtd
	
	&GrupHie = GrupHie
	&AuxProCod = ProCod
	&AuxProGraCod = ProGraCod
	&ProGraRef = ProGraRef
	&ProNom = ProNomGra	
	&GrupNomComp = GrupNomCmp
	
EndFor

if &PrdItmQtd > 0	
	&sdtProdutosItem = new()
	&sdtProdutosItem.ProRef  = &ProGraRef
	&sdtProdutosItem.ProNom  = &ProNom
	&sdtProdutosItem.PedQtd  = &PrdItmQtd
	&sdtProdutosItem.GrupHie = &GrupHie
	&sdtProdutosItem.GrupNomComp = &GrupNomComp
	&sdtProdutos.Add(&sdtProdutosItem)
Endif

&GrupHie.SetEmpty()

For &sdtProdutosItem in &sdtProdutos
	
	if &GrupHie <> &sdtProdutosItem.GrupHie
		&grupNomCmp = &sdtProdutosItem.GrupNomComp
		print GrupoProdutos
	Endif
	&GrupHie = &sdtProdutosItem.GrupHie
	&ProGraRef = &sdtProdutosItem.ProRef
	&ProNom = &sdtProdutosItem.ProNom	
	&PrdItmQtd = &sdtProdutosItem.PedQtd
	print printProduto
EndFor

]]></Source>
