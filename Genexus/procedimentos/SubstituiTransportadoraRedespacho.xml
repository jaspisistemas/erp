      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	//GRAVA LOG
	
	if &OqueFazer = 'S'
		//GRAVA LOG	
		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(Str(&PedCod))
			&LogErpRegTip = TrnMode.Update
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedTraSaiCod', trim(str(PedTraSaiCod)), trim(str(&PedTraRedCod)), &LogErpRegGUID )
		Endif
		//GRAVA LOG
		
		PedTraSaiCod = &PedTraRedCod	
	Else
		//GRAVA LOG
		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(Str(&PedCod))
			&LogErpRegTip = TrnMode.Update
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedTraRedCod', trim(toformattedString(PedTraRedCod)), trim(toformattedString(&PedTraRedCod)), &LogErpRegGUID )	
		Endif
		//GRAVA LOG
		
		PedTraRedCod = &PedTraRedCod
	EndiF
	
	Exit
EndFor

Commit
]]></Source>
