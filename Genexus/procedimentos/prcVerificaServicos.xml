      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each ORder EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod 		= &parmEmpCod
	Where FilCod 		= &parmFilCod
	Where PedCod 		= &parmPedCod
	Where PedItmVenCod.IsEmpty() or PedItmVenCod = 0
	
	&IsObrigatorioTecnico = ProTipDef = Definicao.SERVICO
	
EndFor
]]></Source>
