      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	&wwNotas.qtdNfe = 0
	
	&Pagina = &UltNfeCod
	&QtdRegistros = &QtdNotas
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif

	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif

	&wwNotas.pA = '0'
	&wwNotas.pT = '0'
	&wwNotas.p1 = '0'
	&wwNotas.p2 = '0'
	&wwNotas.p3 = '0'
	&wwNotas.p4 = '0'
	&wwNotas.p5 = '0'
	&IsPaginaOk = false
	
	
	
	//	&PadObs = format('num:%1,ini:%2,fin:%3, sts:%4 mod:%5, cliente:%6', trim(toformattedString(&NfeNum)), trim(&varNfeDtaIni), trim(&varNfeDtaFin), trim(&varNfeSts.ToString()), trim(&ModCod), trim(&NfeCliRaz))
	//	&PadObs += ' rando: '+ &DevRandon
	//	padraousuario.Call('G', 'set_cliente', 1, 1, &PadObs, &PadDtaMod)
	
	if not &varNfeSts.IsEmpty() and &varNfeSts <> 'T'
		&NfeSts.FromString(&varNfeSts)
	Endif

	if not &notapropriaterceiros.IsEmpty()
		&NfeProTer.FromString(&notapropriaterceiros)
	Endif

	
	if not &varNfeDtaFin.IsEmpty()
		&dia = val(substr(&varNfeDtaFin, 1, 2)) //DIA
		&mes = val(substr(&varNfeDtaFin, 4, 2)) //MES
		&Ano = val(substr(&varNfeDtaFin, 7, 4)) //ANO
		&finNfeDtaEms = ymDtoD(&Ano, &mes, &Dia)
	Else
		&finNfeDtaEms = serverdate()
		
		&IniNfeDtaEms = &finNfeDtaEms
		&IniNfeDtaEms = &IniNfeDtaEms.AddDays(-7)
	Endif

	if not &varNfeDtaIni.IsEmpty()
		&dia = val(substr(&varNfeDtaIni, 1, 2)) //DIA
		&mes = val(substr(&varNfeDtaIni, 4, 2)) //MES
		&Ano = val(substr(&varNfeDtaIni, 7, 4)) //ANO
		&IniNfeDtaEms = ymDtoD(&Ano, &mes, &Dia)
	Endif


	if &filCod <= 0 
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAceNiv > 0
				&collFilCod.add(PesFilAce)
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif
	Else
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAce = &filCod
				Where PesFilAceNiv > 0
				&collFilCod.add(PesFilAce)			
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &filCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif	
	EndIf
	
	//	&PadObs = format('num:%1,ini:%2,fin:%3, sts:%4', trim(toformattedString(&NfeNum)), trim(&IniNfeDtaEms.ToFormattedString()), trim(&finNfeDtaEms.ToFormattedString()), trim(&varNfeSts.ToString()))
	//	padraousuario.Call('G', 'set_cliente1', 1, 1, &PadObs, &PadDtaMod)
		
		//ordem  DC Data Crescente
		//ordem  DD Data Crescente
		
	&varchar = RetornaSoNumeros.Udp(&NfeCliRaz)
	&AuxNfeNum.FromString(&varchar)
		
	For Each 
		Order EmpCod, (NfeDtaFat), (NfeNum) when &Ordem = 'DD' //DD Data DeCrescente
		Order EmpCod, NfeDtaFat, NfeNum when &Ordem = 'DC' //DC Data Crescente
		
		Where EmpCod = &wwpContext.EmpCod
		Where NfeProTer = &NfeProTer when not &notapropriaterceiros.IsEmpty()
		Where FilCod in &collFilCod
		Where ModCod = &ModCod when not &ModCod.IsEmpty() 
		Where NfeNum = &NfeNum when not &NfeNum.IsEmpty()
		Where NfeSts = &NfeSts when not &varNfeSts.IsEmpty() and &varNfeSts <> 'T'
		Where (NfeDtaEms >= &IniNfeDtaEms or &IniNfeDtaEms.IsEmpty()) and NfeDtaEms <= &finNfeDtaEms
		where NfeCliRaz like &NfeCliRaz or NfeNum = &AuxNfeNum when not &NfeCliRaz.IsEmpty()
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwNotas.qtdNfe = 0
					&wwNotas.Nfe.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				&wwNotas.qtdNfe += 1
				
				&wwNotasItem = new()
				
				&wwNotasItem.Cod = NfeCod
				&wwNotasItem.Fil = FilCod
				&wwNotasItem.Num = NfeNum
				&wwNotasItem.Ser = NfeSer
				&wwNotasItem.Ems = trim(NfeDtaEms.ToFormattedString())
				
				&wwNotasItem.VlrTot = NfeVlrTot
				&wwNotasItem.Sts = NfeSts
				&wwNotasItem.Raz = trim(NfeCliCodRaz)
				&wwNotas.Nfe.Add(&wwNotasItem)
			Endif
		Endif
	
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
	
	When none
		&wwNotas.qtdNfe = 0
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwNotas.pA = trim(str(&Pagina))
		&wwNotas.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwNotas.p1, &wwNotas.p2, &wwNotas.p3, &wwNotas.p4, &wwNotas.p5)
		
	Endif
	//	padraousuario.Call('G', 'set_cliente2', 1, 1, &wwNotas.ToJson(), &PadDtaMod)
Endif
]]></Source>
