Sub 'Cidade'
	
	For each Order EmpCod,CidCod
		Where EmpCod = &wwpContext.EmpCod
		Where CidCod = &AuxPesCidCod
		&sdtCliente.CidUf = UfeCod.Trim() + ' - ' + trim(CidNom)
		&sdtCliente.CidC = CidCod
		Exit
	EndFor	
EndSub
