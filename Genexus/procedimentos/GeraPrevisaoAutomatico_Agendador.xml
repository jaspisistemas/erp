      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//procedimento que gera as duplicatas a pagar para todas previsões ativas


//pega todas previsoes ativas da tabela ServicoCliente
For each order EmpCod, SerItmTip,SerItmSts,SerItmCod
	Where EmpCod = &EmpCod
	where SerItmTip = TipoLancamentoServico.PREVISAO
	where SerItmSts = Status_AtivoInativo.ATIVO
	&SerItmCod = SerItmCod
	&SerFilCod = SerFilCod
	&SerCliCod = SerCliCod
	//&SerCod  = 0
	&SerItmTipPlan = SerItmTipPlan
	&SerItmDesc = SerItmDesc
	&SerItmDiaVct = SerItmDiaVct
	&SerItmUltVct = SerItmUltVct
	&SerItmDtaInicio = SerItmDtaInicio
	&SerItmDtaFim = SerItmDtaFim
	&SerItmVlr = SerItmVlr
	&SerItmTip = SerItmTip
	&SerItmQtdMes = SerItmQtdMes
	&SerItmAbv = SerItmAbv
	&SerItmPlanCod = SerItmPlanCod
	&SerItmRecPag = SerItmRecPag
	if SerItmRecPag = ReceberPagar.Receber
		&SerItmCbrCod = SerItmCbrCod
	else
		&SerItmCbrCod = 0
	EndIf
	&SerCliNom = SerCliNom
//******************************************************************
//	&DataVencimento = &SerItmUltVct.AddMonths(1)
//	&DataAux = EoM(&DataVencimento)
//	&UltDiaMes = &DataAux.Day()
//	&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
	
//**********************************************************************************************	
	if &SerItmUltVct.IsEmpty()
		if &SerItmDiaVct >= &SerItmDtaInicio.Day() // se dia vct for menor vai pro prox mes
			&DataVencimento = YmDToD(&SerItmDtaInicio.Year(), &SerItmDtaInicio.Month(), 1)
			&DataAux = EoM(&DataVencimento)
			&DataVencimento = YmDToD(&SerItmDtaInicio.Year(), &SerItmDtaInicio.Month(), &SerItmDiaVct)
		else
			
			&DataVencimento = YmDToD(&SerItmDtaInicio.Year(), &SerItmDtaInicio.Month(), 1)
			&DataVencimento = &DataVencimento.AddMonths(1)
			&DataAux = EoM(&DataVencimento)
			&DataVencimento = YmDToD(&SerItmDtaInicio.Year(), &SerItmDtaInicio.Month(), &SerItmDiaVct)
		EndIf
	else
		&DataVencimento = &SerItmUltVct.AddMonths(1)
		&DataAux = EoM(&DataVencimento)
		&UltDiaMes = &DataAux.Day()
		&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
	EndIf
//**************************************************************************************************		
	IF  &DataVencimento.IsEmpty()
		&DataVencimento = &DataAux // dataAux ja ta com EoM 
	EndIf


	Do case
		case &SerItmTipPlan = TipoPlano.MENSAL
		
			&DataFinal = &Today.AddMonths(&SerItmQtdMes)
			&DataFinal = EoM(&DataFinal)
			
			For &Count = 1 TO 999 //&SerItmQtdMes
				//					msg(&DataVencimento.ToFormattedString())
				
				if &DataVencimento <= &DataFinal
					&CreDupNro = 'P.' + &SerItmAbv + ' - ' + trim(str(&DataVencimento.Year())) + '/' + trim(str(&DataVencimento.Month()))
					For each order EmpCod, FilCod, CreCliCod,CreSerItmCod,CreCod
						where EmpCod = &EmpCod
						where FilCod = &FilCod
						where CreCliCod = &SerCliCod
						where CreSerItmCod = &SerItmCod
						where CreDtaVct.Month() = &DataVencimento.Month() and CreDtaVct.Year() = &DataVencimento.Year() 
						where CreSts <> Status_Duplicata.CANCELADA
						exit //nao faz nda se ja tiver
					when  none
						Do 'GravaDuplicata'
					EndFor
				else
					exit
					msg('ERRO! Datas incorretas')
				EndIf
				
				
				
				
				
				&AuxDataVencimento = &DataVencimento
				//					&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), 1) //pra nao ter erro
				&DataVencimento = &DataVencimento.AddMonths(1)
				&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
				
				if &DataVencimento.IsEmpty()
					&AuxDataVencimento = YmDToD(&AuxDataVencimento.Year(), &AuxDataVencimento.Month(), 1)
					&AuxDataVencimento = &AuxDataVencimento.AddMonths(1)
					&AuxData = EoM(&AuxDataVencimento)
					&UltDiaMes = &AuxData.Day()
					&DataVencimento = YmDToD(&AuxDataVencimento.Year(), &AuxDataVencimento.Month(), &UltDiaMes)
				EndIf
			EndFor
			
			
			
			
			
		case &SerItmTipPlan = TipoPlano.ANUAL
			&QtdAnos = &SerItmQtdMes / 12
			
			&DataFinal = &Today.AddYears(&QtdAnos)
			&DataFinal = EoM(&DataFinal) 
			
			For &Count = 1 to 999 //&QtdAnos
				
				if &DataVencimento <= &DataFinal
					&CreDupNro = 'P.' + &SerItmAbv +  ' - ' + trim(str(&DataVencimento.Year()))
					For each order EmpCod, FilCod,CreCliCod, CreSerItmCod,CreCod
						where EmpCod = &EmpCod
						where FilCod = &FilCod
						where CreCliCod = &SerCliCod
						where CreSerItmCod = &SerItmCod
						where /*CreDtaVct.Month() = &DataVencimento.Month() and */ CreDtaVct.Year() = &DataVencimento.Year() 
						where CreSts <> Status_Duplicata.CANCELADA
						exit //nao faz nda se ja tiver
					when  none
						Do 'GravaDuplicata'
					EndFor
				else
					exit
					msg('ERRO! Datas incorretas')
				EndIf
				
				
				
				&AuxDataVencimento = &DataVencimento
				&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), 1) //pra nao ter erro
				&DataVencimento = &DataVencimento.AddYears(1)
				&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
				
				if &DataVencimento.IsEmpty()
					&AuxDataVencimento = YmDToD(&AuxDataVencimento.Year(), &AuxDataVencimento.Month(), 1)
					&AuxData = EoM(&AuxDataVencimento)
					&UltDiaMes = &AuxData.Day()
					&DataVencimento = YmDToD(&AuxDataVencimento.Year() + 1, &AuxDataVencimento.Month(), &UltDiaMes)
				EndIf	
			EndFor
	EndCase

RetornaUltimoVencimentoDuplicata.Call(&EmpCod, &FilCod ,&SerItmCod, &SerItmUltVct)
EndFor

Commit



sub 'GravaDuplicata'
	&CreCod.SetEmpty()
	UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &FilCod, &CreCod)
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CreCod = &CreCod
			CreSerItmCod = &SerItmCod
			CreDupNro = &CreDupNro
			CreDtaVct = &DataVencimento
			CreVlrDup = &SerItmVlr
			CreDtaEms = &Today
			CreVlrSdo = &SerItmVlr
			CreCliCod = &SerCliCod
			CreCbrCod = &SerItmCbrCod
			CreRecPag = &SerItmRecPag
			CreBloNro = ''
			CreSts = Status_Duplicata.ATIVO
			CreFrpPgtoCod = 1// duplicata
			CreOriDup = OrigemDuplicata.MensalidadeServico
			CrePlanCod = &SerItmPlanCod
			CreFilPgt = &FilCod
			CreAbvDup = 'AVULSA' //RetornaTipoOrigemDuplicata.udp(EmpCod, FilCod, CrePedCod, CreRenDstCod, CreFrtCod, CreNfeCod)
			CreNovCliRaz = &SerCliNom
			CreVenCod = 1
		EndNew
	
EndSub

]]></Source>
