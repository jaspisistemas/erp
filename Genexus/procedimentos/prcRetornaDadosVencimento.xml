        <Source><![CDATA[
For Each Order EmpCod, FilCod, ProCod, ProGraCod, ProVctCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &PRoGraCod
	Where ProVctCod = &ProVctCod
	
	&ProRef = ProGraRef
	&ProNom = ProNomGra
	&ProVctDta = ProVctDta
	&ProVctQtd = ProVctQtd 
	
	Exit
EndFor
]]></Source>
