      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,ManFilCod,ManCod
	Where EmpCod = &EmpCod
	Where ManFilCod = &FilCod
	Where ManCod = &NfeCod
	
	Do case
		Case &NfeSts = Status_NFe.Autorizada
			ManSitNFe = Situacao_Nfe.AUTORIZADO	
		Case &NfeSts = Status_NFe.Cancelada
			ManSitNFe = Situacao_Nfe.CANCELADA			
		Case &NfeSts = Status_NFe.Denegada
			ManSitNFe = Situacao_Nfe.dENEGADA
			
	EndCase
	exit
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
