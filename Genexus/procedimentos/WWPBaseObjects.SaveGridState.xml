        <Source><![CDATA[
&auxUserCustomValue = &UserCustomValue
//This is a procedure in which user has to define the behaviour of grid state.
//You can save the grid state in session, in database or whatever you want

//Example to save in Session
//&Session.Set(&UserCustomKey, &auxUserCustomValue)

loadWWPContext.Call(&Context)

&FiltroKey = 'FLT#'+&UserCustomKey.Trim()//WWPedidoBalcaoColumnsSelector'
padraoUsuarioHora.Call('L',&FiltroKey, &Context.PesCod, &Context.EmpCod, &UmZero, &PadDtaMod, &PadDtaHorMod, 'T')

Do CAse
	Case &UmZero = '2'
		&SalvarFiltro = false
	Case &UmZero = '1'		
		&SalvarFiltro = true
	Otherwise
		RetornaConfUsuario.Call(&Context.EmpCod, &Context.PesCod, domConfUsuario.Uconf001_PadraoFiltro, &UmZero)
		if &UmZero = '2'
			&SalvarFiltro = false
		Else
			&SalvarFiltro = true
		EndiF		
EndCase

if &SalvarFiltro = true
	&GridState.FromXml(&auxUserCustomValue)
	if &GridState.PageSize.Trim() = '0' or  &GridState.PageSize.IsEmpty()
		&GridState.PageSize = '10'
	Endif
	&auxUserCustomValue = &GridState.ToXml()
	padraoUsuarioHora.Call('G',&UserCustomKey, &Context.PesCod, &Context.EmpCod, &auxUserCustomValue, &PadDtaMod, &PadDtaHorMod, 'T')
Endif

	
