      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&ProBar = trim(str(ProCod))
	ValidaCodigoReferenciaRepetido.Call(EmpCod, ProCod, 1, &ProBar, &ErroEan13Mensagem)
	do While Not &ErroEan13Mensagem.IsEmpty()
		&Codigo8 = Random() * 10000
		&ProBar =  trim(str(&Codigo8))
		ValidaCodigoReferenciaRepetido.Call(EmpCod, ProCod, 1, &ProBar, &ErroEan13Mensagem)
	EndDo
	
	
	ProBar = &ProBar
	
	Exit
EndFor

Commit
]]></Source>
