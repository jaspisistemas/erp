      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&Linha = &PrimeiraLinha
&Excel.Open(&selectedURL)
If &Excel.ErrCode <> 0
	msg(&Excel.ErrDescription)
Else
	Do While &Fim < 50
		
		Do 'LimpaCampos'
		&ProRef    = trim(&Excel.Cells(&Linha,&ColProCod).Text) // Código do Produto
		&ProForProCod = trim(&Excel.Cells(&Linha,&ColCodProFornecedor).text) // Codigo do produto no fornecedor
		&ProForProNom = Substr(trim(&Excel.Cells(&Linha,&ColCodDescricao).text), 1, 80) // Codigo do produto no fornecedor
		
		If &IsCustoUnt = True
			&ProVlrCus    = &Excel.Cells(&Linha,&ColvlrCus).Number
		EndIf
		If &IsQtdEmb = True
			&ProQtdEmb    = &Excel.Cells(&Linha,&ColQtdEmb).Number
		EndIf
		If &IsDesconto = True
			&ProForDsc = &Excel.Cells(&Linha,&ColPerDes).Number
		EndIf
		If &IsAcrescimo = True
			&ProForAcr =  &Excel.Cells(&Linha,&ColPerAcr).Number
		EndIf
		If &IsNewDesconto = True
			&ProForRatDsc = &Excel.Cells(&Linha,&ColPerRatDes).Number
		EndIf
		If &IsNewAcrescimo = True
			&ProForRatAcr =  &Excel.Cells(&Linha,&ColPerRatAcr).Number
		EndIf
		If &IsSt = True
			 &ProForIcmSt = &Excel.Cells(&Linha,&ColPerSt).Number
		EndIf
		If &IsIpi = True
			&ProForIpi =  &Excel.Cells(&Linha,&ColPerIpi).Number
		EndIf		
		
		If &ProRef.IsEmpty() and &ProForProCod.IsEmpty()
			&Fim += 1
		Else			
			Do 'GetProduto'
			Do 'GravaSdt'			
			&Fim = 0
		EndIf
		&Linha += 1
	EndDo
EndIf


&WebSession.Set('LISTWPPRODUTFORNECEDOR', &SdtProdutoFornecedor.ToJson())
&WebSession.Set('LISTWPPRODUTFORNECEDOR_OK', &SdtProdutoFornecedorOk.ToJson())

sub 'GravaSdt'
	if not &ProRef.IsEmpty()
		For &SdtProdutoFornecedorItem in &SdtProdutoFornecedor
			if &SdtProdutoFornecedorItem.ProRef = &ProRef
				&IsErro = 'S'	
				&Mensagem = 'DUPLICIDADE: Produto do fornecedor:' +&SdtProdutoFornecedorItem.ProForProCod.Trim() + ' já Adicionado!'
				Exit
			EndIF	
		EndFor
	Else
		&IsErro = 'S'	
		&Mensagem = 'Produto:' + trim(&ProRef) + ' não localizado!'
	EndiF

	If &ProForProCod.Trim().IsEmpty()
		&IsErro = 'S'	
		&Mensagem = 'CÓDIGO PRODUTO DO FORNECEDOR: Vazio!'
	EndIf

	if &IsErro = 'S' //com erro
		&SdtProdutoFornecedorItem = new()		
		&SdtProdutoFornecedorItem.EmpCod       = &EmpCod
		&SdtProdutoFornecedorItem.ProCod       = &ProCod
		&SdtProdutoFornecedorItem.ProRef       = &ProRef
		&SdtProdutoFornecedorItem.ProRefPadL   = &ProRefPadL
		
		&SdtProdutoFornecedorItem.ProNom       = &ProNom
		&SdtProdutoFornecedorItem.ProForProCod = &ProForProCod
		&SdtProdutoFornecedorItem.ProForProNom = &ProForProNom
		&SdtProdutoFornecedorItem.ProForVlrCus = &ProVlrCus
		&SdtProdutoFornecedorItem.ProForQtdEmb = &ProQtdEmb
		&SdtProdutoFornecedorItem.ProForDsc    = &ProForDsc
		&SdtProdutoFornecedorItem.ProForAcr    = &ProForAcr
		&SdtProdutoFornecedorItem.ProForRatDsc    = &ProForRatDsc
		&SdtProdutoFornecedorItem.ProForRatAcr    = &ProForRatAcr
		&SdtProdutoFornecedorItem.ProForIcmSt  = &ProForIcmSt
		&SdtProdutoFornecedorItem.ProForIpi    = &ProForIpi
		&SdtProdutoFornecedorItem.Mensagem     = &Mensagem
		&SdtProdutoFornecedorItem.Erro         = &IsErro
		&SdtProdutoFornecedor.Add(&SdtProdutoFornecedorItem)
	Else
		&SdtProdutoFornecedorOKItem = new()		
		&SdtProdutoFornecedorOKItem.EmpCod       = &EmpCod
		&SdtProdutoFornecedorOKItem.ProCod       = &ProCod
		&SdtProdutoFornecedorOKItem.ProRef       = &ProRef
		&SdtProdutoFornecedorOKItem.ProRefPadL   = &ProRefPadL
		
		&SdtProdutoFornecedorOKItem.ProNom       = &ProNom
		&SdtProdutoFornecedorOKItem.ProForProCod = &ProForProCod
		&SdtProdutoFornecedorOKItem.ProForProNom = &ProForProNom
		&SdtProdutoFornecedorOKItem.ProForVlrCus = &ProVlrCus
		&SdtProdutoFornecedorOKItem.ProForQtdEmb = &ProQtdEmb
		&SdtProdutoFornecedorOKItem.ProForDsc    = &ProForDsc
		&SdtProdutoFornecedorOKItem.ProForAcr    = &ProForAcr
		&SdtProdutoFornecedorOKItem.ProForRatDsc    = &ProForRatDsc
		&SdtProdutoFornecedorOKItem.ProForRatAcr    = &ProForRatAcr
		&SdtProdutoFornecedorOKItem.ProForIcmSt  = &ProForIcmSt
		&SdtProdutoFornecedorOKItem.ProForIpi    = &ProForIpi
		&SdtProdutoFornecedorOKItem.Mensagem     = &Mensagem
		&SdtProdutoFornecedorOKItem.Erro         = &IsErro
		&SdtProdutoFornecedorOK.Add(&SdtProdutoFornecedorOKItem)
	EndIF

EndSub

Sub 'LimpaCampos'
	&Mensagem = ''
	&IsErro = 'N'
	&ProForProCod = ''
	&ProForProNom.SetEmpty()
	&ProCod = 0
	&ProVlrCus = 0
	&ProQtdEmb = 0
	&ProForDsc = 0
	&ProForAcr = 0
	&ProForRatDsc = 0
	&ProForRatAcr = 0
	&ProForIcmSt = 0
	&ProForIpi = 0
	&ProRef.SetEmpty()
	&ProRefPadL.SetEmpty()
EndSub

Sub 'GetProduto'
	If not &ProRef.IsEmpty()
	    For Each Order EmpCod, ProRef, ProCod
			Where EmpCod = &EmpCod
		    Where ProRef = &ProRef
			where ProSts <> Status_Produto.EXCLUIDO
			
			&ProNom = ProNom 
			&ProCod = ProCod
			&ProRefPadL = ProRefPadL
			
			If ProSts = Status_Produto.INATIVO
				&Mensagem = 'Produto código: '+trim(ProRef)+' Inativo!'
				&IsErro = 'S'
			EndIf
			
		    Exit
		When none
			&ProNom = 'Produto código:' + trim(&ProRef) + ' não localizado!'
			&IsErro = 'S'
			
			If not &ProRef.IsEmpty()
	           &Mensagem = 'Produto código: ' +trim(&ProRef) + ' não localizado!'
	        EndIF
	    EndFor
	
		For Each Order EmpCod,ProForCod, ProForProCod
			Where EmpCod = &EmpCod
			Where ProForCod = &PesCod
			Where ProRef <> &ProRef
			Where ProForProCod = &ProForProCod
			&ProNom = 'Cód.Fornecedor já adicionado ao Produto: ' + trim(ProRef)
			&IsErro = 'S'
			Exit
		EndFor
	
	Else
		For Each Order EmpCod,ProForCod, ProForProCod
			Where EmpCod = &EmpCod
			Where ProForCod = &PesCod
			Where ProForProCod = &ProForProCod
			&ProNom = ProNom 
			&ProCod = ProCod
			&ProRef = ProRef
			&ProRefPadL = ProRefPadL
			
			If ProSts = Status_Produto.INATIVO
				&Mensagem = 'Produto código: '+trim(ProRef)+' Inativo!'
				&IsErro = 'S'
			EndIf
			
		    Exit
		When none
			&ProNom = 'Produto do Fornecedor: ' + trim(&ProForProCod) + ' não vínculado no Sistema!'
			&IsErro = 'S'
			&Mensagem = &ProNom
	    EndFor
	EndIf
EndSub
]]></Source>
