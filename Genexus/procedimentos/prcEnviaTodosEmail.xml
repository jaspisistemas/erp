      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = &sdtPedidos.Count
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&WaDtaEms = serverdate()
&Ano = year(&WaDtaEms)
&Mes = month(&WaDtaEms)
&WaAnoMes = trim(str(&Ano)) + padL(trim(str(&mes)),2,'0')

For &sdtPedidosItem in &sdtPedidos
	
	&EmpCod = &sdtPedidosItem.EmPCod
	&FilCod = &sdtPedidosItem.FiLCod
	&PedCod = &sdtPedidosItem.PedCod
	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	if &sdtPedidosItem.isMarcar = true
		
		//ENVIAR EMAIL
		if &IsEnviarEmail = true
			&SdtEmail.Clear()
			&AuxSdtEmail.Clear()
			//Carrega os Email.
			RetornaEmailFinanceiro.call(&sdtPedidosItem.EmPCod, &sdtPedidosItem.PedCliCod, &AuxSdtEmail)
			
			//Carrega Emails
			For &AuxSdtEmailItem in &AuxSdtEmail
				
				&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
			   
			   	&EmailVarchar = &AuxSdtEmailItem.EmlUrl
				If not &EmailVarchar.IsEmpty() and (&EmailVarchar.IsMatch(&pattern) = true)
					&SdtEmailItem = new()
					&SdtEmailItem.EmlUrl = &AuxSdtEmailItem.EmlUrl
					&SdtEmail.Add(&SdtEmailItem)
					
					if &EnviarTodosEmail = 'A' //ENVIAR PARA O PRIMEIRO EMAIL
						Exit
					Endif
				Endif
			EndFor
			
			
			if &SdtEmail.Count > 0
				&sdtBoleto.Clear()
				
				//verifica boleto
				RetornaSDTboletosPedido.Call(&sdtPedidosItem.EmPCod, &sdtPedidosItem.FilCod, &sdtPedidosItem.PedCod, &sdtBoleto)
				
				//GRAVA O ENVIO DO EMAIL
				GravaEnvioEmailPedido.Call(&sdtPedidosItem.EmPCod, &sdtPedidosItem.FiLCod, &sdtPedidosItem.PedCod, 0, TipoContaEmail.Email_Financeiro, &EmlAss, TipoSolicitacao.Envia_Mensalidade, &WwpContextPesCod, &Mensagem, &SdtEmail, &sdtBoleto, Status_SiMNao.Sim, false, false, '0', false, false)
			Endif
		Endif
	
		//ENVIAR WHATS
		if &IsEnviarWhats = true			
			&AuxSDT_PessoaTelefones.Clear()
			&SDT_PessoaTelefones.Clear()
			RetornaPessoaTelefones.Call(&sdtPedidosItem.EmpCod, &sdtPedidosItem.PedCliCod, &AuxSDT_PessoaTelefones)
			
			if &AuxSDT_PessoaTelefones.Count > 0
				For &AuxSDT_PessoaTelefonesItem in &AuxSDT_PessoaTelefones
					if &AuxSDT_PessoaTelefonesItem.PesFonWhatsBol = true
						&PesFonNum = &AuxSDT_PessoaTelefonesItem.PesFonNum
						FormataFone.Call(&PesFonNum, &PesFonNum)
						if not &PesFonNum.IsEmpty()
							&SDT_PessoaTelefonesItem = new()
							&SDT_PessoaTelefonesItem.PesFonNum = &PesFonNum
							&SDT_PessoaTelefones.Add(&SDT_PessoaTelefonesItem)
							
							if &EnviarTodosWhats = 'A' //ENVIAR PARA O PRIMEIRO EMAIL
								Exit
							Endif
						Endif
					Endif		
				EndFor
				
				&IsGerouPDF = false
				
				&IsPodeEnviar = true
				if &IsPodeEnviar = true and &SDT_PessoaTelefones.Count > 0
					For &SDT_PessoaTelefonesItem in &SDT_PessoaTelefones
						if &IsPodeEnviar = true
							&WaFonDest = &SDT_PessoaTelefonesItem.PesFonNum
							
							do 'GravaEnvio'						
						Endif
					EndFor
				Endif
			Endif
		Endif	
	Endif
EndFor

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub


Sub 'GravaEnvio'

	&IsPodeEnviar = false
	&IsJaEnviado = false
	&IsPrimeiraVez = false
	//Verificar se o numero ja foi enviado hoje
	prcWhatsApp_VerificaJaEnviado.Call(&EmpCod, &WaAnoMes, &WaDtaEms, &WaFonDest, &IsJaEnviado)
	If &IsJaEnviado = false
		//se nao foi enviado verificar se pode enviar
		
		prcWhatsApp_verificaQtdEnviadaAnoMes.Call(&EmpCod, &WaAnoMes, &WaAnoMesQtd, &EmpQtdWhatsMsg)
		if &EmpQtdWhatsMsg > &WaAnoMesQtd
			&IsPodeEnviar = true
			&IsPrimeiraVez = true
		Endif
		
	Else
		&IsPodeEnviar = true
	Endif
	
	if &IsPodeEnviar = true
		//grava envio
		
		&WaMensagem = 'Envio de mensalidade: ' + trim(Str(&PedCod)) //PREENCHER MENSAGEM
		prcWhatsApp_GravaEnvio.Call(&EmpCod, &WaAnoMes, &WaDtaEms, &WaFonDest, &IsPrimeiraVez, &WaMensagem, &PedCod, &FilCod, 0, 0, &WwpContextPesCod, &WaGUID)
		
		//GRAVA FILA DE ENVIO
		prcFilaEnvioWhats_EnviaMensalidade.Call(&EmpCod, &FilCod, &PedCod, &WwpContextPesCod, 0, &WaFonDest, &WaGUID, true, true, &MesAno)
	Endif

EndSub
]]></Source>
