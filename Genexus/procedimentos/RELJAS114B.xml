      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
&SdtRecibo.FromXml(&webSession.Get('ReciboImp'))

MB 0
MT 0

&TipoTitulos = 'TITULOS PAGOS'
&SdtRecibo.Sort('RcbMovCod')

&PesRaz = &Context.PesRaz
&Cont = 0	
For &SdtReciboItem In &SdtRecibo
	&isCabecalho = true
	&moeda = 0
	For each Order EmpCod,RcbMovCod
		Where EmpCod 		= &SdtReciboItem.EmpCod
		Where RcbMovCod 	= &SdtReciboItem.RcbMovCod //when &deondevem = 'MOVIMENTO'
		&RcbVlr    = RcbVlr
		&RcbCod    = RcbCod
		&RcbEmpCod = EmpCod
		
		if not RcbFilCod.IsEmpty() and not RcbFilCod.IsNull()
			&RcbFilCod = RcbFilCod
		Else
			&RcbFilCod = &Context.FilCod
		EndiF
		
		&RcbDta    = RcbDta
		&RcbDoc    = RcbDoc
		&RcbDstCod = RcbDstCod
		
		Do 'Pessoa'
		Do 'Filial'
		
		&RcbCreCod = RcbCreCod
		&RcbCrePagCod = RcbCrePagCod
		&RcbObs = ''
		
		Do 'ValidaDuplicata'
		
		if &isCabecalho = true
			print cabecalho
			Print CabPagamento
			&isCabecalho = false
		Endif
		
		&Cont += 1
		&moeda += &CreVlrDup
		&Total += &moeda
		Print ImprimeTicket
		
	EndFor
	&TotalPago = &moeda.ToFormattedString()
	print TotTitulosPagos
	&Cont = 0
	&TotalPago.SetEmpty()
EndFor

Print Total
LoadWWPContext.Call(&wwpContext)
&Operador = &wwpContext.PesRaz
Print Assinatura


Sub 'Filial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &RcbEmpCod
		Where FilCod = &RcbFilCod
		
		&FilRaz = FilRaz
		if not FilFan.IsNull() and not FilFan.IsEmpty()
			&FilRaz = FilFan
		Endif
		&QtdLinhas = gxMLines(&FilRaz, 47)
		
		if &QtdLinhas > 47
			&UmFilRaz = gxGetMLi(&FilRaz, 1, 47)
			&DoisFilRaz = gxGetMLi(&FilRaz, 2, 47)
		Else
			&DoisFilRaz = gxGetMLi(&FilRaz, 1, 47)
		EndiF 
	
	
		&UmFilRaz = UPPER(&UmFilRaz)
		&DoisFilRaz = UPPER(&DoisFilRaz)
		
		if not FilCpj.IsEmpty()
			&CnpjIeIm = 'CNPJ: ' + trim(FilCpj)
		EndIF
		
		If not FilInsEst.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IE: ' + trim(FilInsEst)
		EndIF
		
		If Not FilInsMun.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IM: ' + trim(FilInsMun)
		EndIF
		
		&Endereco = FilLog.Trim() + ', ' + trim(FilNro) + ' - ' + trim(FilBai)
		&Cidade = trim(FilCidNom) + ' - ' + trim(FilCidUfeCod)
		
		&PedCliCodRaz = PedCliCodRaz_Nov
		&PesLog = PedCliEntLog.Trim() + ', '+ trim(PedCliEntNro) + ' - ' + trim(PedCliEntBai)
		
		Exit
	EndFor
EndSub

Sub 'Pessoa'
	For each Order EmpCod, PesCod
		Where EmpCod = &RcbEmpCod
		Where PesCod = &RcbDstCod
		If PesTip = TipoPessoa.FISICA
			&PesCnpj = PesCpf
		Else
			&PesCnpj = PesCnpj
		EndIf
		Exit
	EndFor
EndSub

Sub 'ValidaDuplicata'
	&CreDtaEms.SetEmpty()
	&CreDupNro.SetEmpty()
	&CreVlrDup.SetEmpty()
	&PesRaz.SetEmpty()
	&PesCod.SetEmpty()
	For each Order EmpCod,FilCod,CreCod,CrePagCod
		Where EmpCod = &RcbEmpCod
		Where FilCod = &RcbFilCod
		Where CreCod = &RcbCreCod
		Where CrePagCod = &RcbCrePagCod
		&PesCod = CreCliCod
		&PesRaz = trim(CreNovCliRaz_Formula)
		&CreDupNro = CreDupNro
		&CreDtaEms = CreDtaEms
		&CreVlrDup = CrePagVlr
		exit
	EndFor
EndSub

		
