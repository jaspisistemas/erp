      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CreditoMoeda = 0
&TotMovVlr = 0
&DebitoMoeda = 0
Do 'LoadGridState'

Do 'WriteData'


Sub 'WriteData'

	For each
		order EmpCod MovCtaBanCod MovDtaCon MovCod 
		using DSWWMovimento(&MovCreDeb, &MovTip, &MovDtaCon, &MovDtaCon_To, &MovSts, &MovCtaBanCod, &DynamicFiltersSelector1, &DynamicFiltersOperator1, &MovDoc1
					, &MovCod1, &MovVlr1, &MovCplTot1, &DynamicFiltersEnabled2, &DynamicFiltersSelector2, &DynamicFiltersOperator2
					, &MovDoc2, &MovCod2, &MovVlr2, &MovCplTot2, &DynamicFiltersEnabled3, &DynamicFiltersSelector3
					, &DynamicFiltersOperator3, &MovDoc3, &MovCod3, &MovVlr3, &MovCplTot3)

		If MovCreDeb = 'C'
			&CreditoMoeda += MovVlr
			&TotMovVlr += MovVlr
		Else
			&DebitoMoeda += MovVlr
			&TotMovVlr -= MovVlr
		Endif
			
	Endfor

EndSub

Sub 'LoadGridState'
	If &Session.Get(!"WWMovimentoGridState") = !""
		&GridState.FromXml(LoadGridState.Udp(!"WWMovimentoGridState"))
	Else
		&GridState.FromXml(&Session.Get(!"WWMovimentoGridState"))
	Endif	

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"MOVCREDEB"
				&MovCreDeb.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"MOVTIP"
				&MovTip.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"MOVDTACON"
				&MovDtaCon.FromString(&GridStateFilterValue.Value)
				&MovDtaCon_To.FromString(&GridStateFilterValue.ValueTo)
			Case &GridStateFilterValue.Name = !"MOVSTS"
				&MovSts.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"MOVCTABANCOD"
				&MovCtaBanCod.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor
EndSub
]]></Source>
