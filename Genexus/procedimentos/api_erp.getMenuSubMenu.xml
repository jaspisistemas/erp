      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//TRATAR A VERSAO DO APPP
//vApi
//vApiNew
//linkBaixaApp


&LogGUID = guid.NewGuid()
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	if &wwpContext.Old_Perfil = 3 //adm
		prcajustaLinkSmart.Call()
	Endif
	
	//&IsFuncoesSuporte = false
	//If upper(&UserName) = 'SUPORTE.JASPI'
	//	&IsFuncoesSuporte = true
	//EndIF
	CarregaSdtPerfil_api.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &AutGrpCod, &AutGrpNom)
	
	&sdtMenu.isOkLicenca = '0'
	For Each ORder EmpCod
		Where EmpCod = &wwpContext.EmpCod
		VerificaLicenca_smart.Call(EmpCod, EmpChv, EmpCodSec, '', &IsOkLicenca)
		&sdtMenu.isOkLicenca = &IsOkLicenca
		Exit 
	EndFor
	
	
	For Each Order EmpCod, RotSts, MenOrd, MenNom, SubMenOrd, SubMenNom, RotOrd, RotNom
		Where EmpCod = &wwpContext.EmpCod
		Where RotSts = Status_AtivoInativo.ATIVO
		Where not RotLinSmart.IsEmpty()	//not RotLin.IsEmpty() or 
		
		if &wwpContext.tipoPerfil <> 3
			If not RotAutCod.IsEmpty()
				RetornaAutorizacaoApi.Call(RotAutCod.Trim(), &wwpContext, &AutGrpCod, &AutNiv)
			Else
				&AutNiv = 1
			EndIF
		Else
			&AutNiv = 4
		Endif
		
		If (&AutNiv > 0 and &AutNiv >= RotNivReq and RotNivReq < 4) or &AutNiv = 4
			if MenNom = 'Força de Vendas'
				&IsTemForcaVendas = true
			Else
				
				If &OldMenCod <> MenCod
					if &OldMenCod <> 0
						&sdtMenu.Menu.Add(&SdtMenuItem)
						&sdtMenu.qtdMenus += 1
					EndIf					
					
					&SdtMenuItem = new()
					&SdtMenuItem.MenCod = MenCod
					&SdtMenuItem.menNom = MenNom
					&SdtMenuItem.MenSubTit = MenSubTit
					&IsFechaMenu = true
					//&DVelop_MenuItem.iconClass = "menu-icon fa fa-tasks"
				EndIF				
				
				If &OldMenCod <> MenCod or &OldSubMenCod <> SubMenCod
					if &OldSubMenCod <> 0 //and &OldMenCod = MenCod
						&sdtMenu.SubMenu.Add(&sdtMenuSubItem)
						&sdtMenu.qtdSubMenu += 1
					Endif		
					
					&sdtMenuSubItem = new()
					&sdtMenuSubItem.MenCod = MenCod
					&sdtMenuSubItem.SubMenCod = SubMenCod
					&sdtMenuSubItem.SubMenNom = SubMenNom
				EndIF
				
				&sdtMenuRotinaItem = new()
				&sdtMenuRotinaItem.RotMencod = MenCod
				&sdtMenuRotinaItem.RotSubMenCod = SubMenCod
				&sdtMenuRotinaItem.RotCod = RotCod
				&sdtMenuRotinaItem.RotNom = RotNom
				
				&sdtMenuRotinaItem.RotLink = RotLinSmart.ToUpper()
				&sdtMenu.Rotinas.Add(&sdtMenuRotinaItem)
				&sdtMenu.qtdRot += 1
				
				&OldSubMenCod = SubMenCod
				&OldMenCod = MenCod
			Endif
		EndIF
	EndFor
	
	&sdtMenu.SubMenu.Add(&sdtMenuSubItem)
	&sdtMenu.qtdSubMenu += 1
	
	&sdtMenu.Menu.Add(&SdtMenuItem)
	&sdtMenu.qtdMenus += 1
	
	//	if &IsTemForcaVendas = true //Aqui vai ficar o forcavendas
	
	//	Endif
	
EndIf


Sub 'subException_handler'
	
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'subException_handler','subException_handler')
	
EndSub

Sub 'subError_handler'
	
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'subError_handler','subError_handler')
	
EndSub
]]></Source>
