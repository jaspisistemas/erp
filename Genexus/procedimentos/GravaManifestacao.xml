      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ManRes = ''  // pega xml em uma variavel 
&XmlDFe.Open(&ArquivoPronto)    
Do While  not &XmlDFe.EOF
    &ManRes += &XmlDFe.ReadRawXML()
    &XmlDFe.Read()
Enddo
&XmlDFe.Close()

For each order EmpCod,ManCha  //faz update
	Where EmpCod = &EmpCod
	Where ManCha = &ManCha or (ManNsu = &NroNSU and ManNfCte = &ManNfCte)
	
	ManRes = &ManRes
	ManRaz = &ManRaz
	ManCpfCnpj = &ManCpfCnpj
	ManInsEst = &ManInsEst
	ManDtaIni = &ManDtaIni
	If &ManTip = 1
		ManTip = EntradaSaida.Saida
	Else
		ManTip = EntradaSaida.Entrada
	EndIf
	ManVal = &ManVal
	ManDtaRcb = &ManDtaRcb
	ManProt = &ManProt
When none // se não achou grava um novo
	
	UltimoCodigoEmpresa.Call(domParCod.MANIFESTACAO,&EmpCod,1,&ManCod)
	
	New
		EmpCod = &EmpCod
		ManCod = &ManCod
		ManFilCod = &FilCod
		ManCpfCnpj = &ManCpfCnpj
		ManRes = &ManRes
		ManCha = &ManCha
		ManRes = &ManRes
		ManRaz = &ManRaz
		ManInsEst = &ManInsEst
		ManDtaIni = &ManDtaIni
		ManDta = &ManDtaIni.ToDate()
		If &ManTip = 1
			ManTip = EntradaSaida.Saida
		Else
			ManTip = EntradaSaida.Entrada
		EndIf
		
		ManVal = &ManVal
		ManDtaRcb = &ManDtaRcb
		ManProt = &ManProt
		Do Case
			Case &cSitNFe = 1
				ManSitNFe = Situacao_Nfe.AUTORIZADO
			Case &cSitNFe = 2
				ManSitNFe = Situacao_Nfe.DENEGADA
			Case &cSitNFe = 3
				ManSitNFe = Situacao_Nfe.CANCELADA
		EndCase
		ManSts = Status_Dfe.NaoManifestado
		ManNsu = &NroNSU
		ManNfCte = &ManNfCte
	EndNew
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
