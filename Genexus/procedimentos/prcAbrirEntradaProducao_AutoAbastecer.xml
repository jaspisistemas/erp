      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//ALTERA STATUS DA ENTRADA PRODUCAO ABERTO
For Each Order EmpCod, FilCod, PrdCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PrdCod = &PrdCod
	
	//PrdSts = Status_Pedido.ABERTO
	&PrdDtaEnt = PrdDtaEnt
	&PrdEntPedCod = PrdEntPedCod
	
	&PrdSaiPedCod = PrdSaiPedCod
	
	Exit
EndFor
	
Commit


prcAbrirEntradaProducao_RemoveItens.Call(&EmpCod, &FilCod, &PrdEntPedCod, &PedCodKit, &PesCod)

if &PrdSaiPedCod > 0
	prcAbrirEntradaProducao_RemoveItens.Call(&EmpCod, &FilCod, &PrdSaiPedCod, &PedCodKit, &PesCod)
Endif
]]></Source>
