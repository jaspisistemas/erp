      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[MB 4
MT 2

RetornaFilialFaturamento.Call(&parmEmpCod, &parmFilCod, '', '', '', '', '', &FilImg_LogRel, &FilFan) //Endereçamento
padraousuario.Call('L', 'FUNCIONARIO_ANIVERSARIO', &parmPesCod, &parmEmpCod, &OpcaoAniversario, &PadDtaMod)

Header
	Print Cabecalho
End

Footer
	Print Rodape
End

Do Case 
	Case &OpcaoAniversario = 'H' or &OpcaoAniversario.IsEmpty()
		&OpcaoVisualizacao = 'HOJE'
	Case &OpcaoAniversario = 'S'
		&OpcaoVisualizacao = 'NA SEMANA'
	Case &OpcaoAniversario = 'M'
		&OpcaoVisualizacao = 'NO MÊS'
	Case &OpcaoAniversario = 'P'
		&OpcaoVisualizacao = '2 DIAS ANTES E 5 DEPOIS'
	Case &OpcaoAniversario = 'A'
		&OpcaoVisualizacao = 'PRÓX. 30 DIAS'
EndCase
Print Titulo

&SDT_PessoaAniversario.FromXml(&WebSession.Get(!"FuncionariosAniversario"))
For &SDT_PessoaAniversarioItem In &SDT_PessoaAniversario
	
	&DiaMes 	= &SDT_PessoaAniversarioItem.DiaMes
	
	&PesCod 	= Trim(ToFormattedString(&SDT_PessoaAniversarioItem.PesCod))
	
	If &SDT_PessoaAniversarioItem.PesRaz.Length() <= 30
		&PesRaz		= &SDT_PessoaAniversarioItem.PesRaz
	Else
		&PesRaz		= SubStr(&SDT_PessoaAniversarioItem.PesRaz, 1, 30) + '...'
		&PesRaz 	= &PesRaz.Trim()
	EndIf
	
	&PesDtaNas 	= Trim(ToFormattedString(&SDT_PessoaAniversarioItem.PesDtaNas))
	
	If Not &SDT_PessoaAniversarioItem.PesFonNum.IsEmpty()
		&PesFonNum	= Trim(ToFormattedString(&SDT_PessoaAniversarioItem.PesFonNum))
	Else
		&PesFonNum 	= 'N/A'
	EndIf
	
	If Not &SDT_PessoaAniversarioItem.PesEml.IsEmpty()
		&PesEml		= Trim(ToFormattedString(&SDT_PessoaAniversarioItem.PesEml))
	Else
		&PesEml		= 'NÃO INFORMADO'
	EndIf
	
	If Trim(&DiaMes) = 'HOJE'
		Print AniversarioHoje
		NoSkip
		Print Dados
	Else
		Print Dados
	EndIf
	
EndFor

Print LinhaFinal
]]></Source>
