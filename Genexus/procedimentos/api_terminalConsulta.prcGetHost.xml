      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


//PRIMEIRO LOCALIZA TERMINAL
For Each Order EmpCod, TermCod
	Where EmpCod = &EmPCod
	Where TermRandCom = &TermRandCom 
	
	&ProNom = 'OK'
	if TermSts = status_AtivoInativo.INATIVO
		&ProNom = '#JASPIENCERRAR#' //ENCERRA E DESLOGA CASO INATIVADO
	Endif
	
	TermUltDtaHor = now()
	Exit
When none
	&ProNom = '#CETADOIDO#' //NAO ENCERRAR
EndFor


if &ProNom = 'OK'
	padraousuarioHora.Call('L', '#URLTERMINALACESSO#', 1, &EmPCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	&sdtUrlTerminal.FromJson(&PadObs)
Endif
]]></Source>
