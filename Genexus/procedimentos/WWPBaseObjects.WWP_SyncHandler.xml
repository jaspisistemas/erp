      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[WWP_Logger.Debug(Format(!"GAMEvents: %1 - %2, inJson: %3", &GAMEvents, GAMEvents.EnumerationDescription(&GAMEvents), &inJson), &Pgmname)
do case
	case &GAMEvents = GAMEvents.User_Insert
		&GAMUser.FromJsonString(&inJson)
		&Messages = udp(WWP_UserSync, TrnMode.Insert, &GAMUser)
	case &GAMEvents = GAMEvents.User_Update
		&GAMUser.FromJsonString(&inJson)
		&Messages = udp(WWP_UserSync, TrnMode.Update, &GAMUser)
	case &GAMEvents = GAMEvents.User_Delete
		&GAMUser.FromJsonString(&inJson)
		&Messages = udp(WWP_UserSync, TrnMode.Delete, &GAMUser)
	otherwise
		WWP_Logger.Debug(Format(!"GAMEvents: %1 - %2, inJson: %3, Not Implemented", &GAMEvents, GAMEvents.EnumerationDescription(&GAMEvents), &inJson), &Pgmname)
endcase
&outJson = &Messages.ToJson()
WWP_Logger.Debug(Format(!"GAMEvents: %1 - %2, outJson: %3", &GAMEvents, GAMEvents.EnumerationDescription(&GAMEvents), &outJson), &Pgmname)
]]></Source>
