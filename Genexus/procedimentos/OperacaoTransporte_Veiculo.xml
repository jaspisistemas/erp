      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

If &OqueFAzer = 'ADD'
	For Each Order EmpCod, VeiCod
		Where EmpCod = &EmpCod
		Where VeiPla = &OpeVeiPla
		Where VeiTip = VeiculoTipo.Tracao
		&OpeVeiUF 		 = VeiUfeCod
		&OpeVeiTar		 = VeiTar
		&OpeVeiCap		 = VeiCap
		&OpeVeiCapM3	 = VeiCapM3
		&OpeVeiTipCar	 = VeiTipCarr
		&OpeVeiTipRod	 = VeiTipRod
		&OpeVeiRen 	     = VeiRen
		
		If VeiPro <> PropriedadeVeiculo.Proprio
			&OpeVeiRNTRC    = VeiProRNTRC
			&OpeVeiProCnpj 	= VeiProCnpj
			&OpeVeiProIe 	= VeiProIe
			&OpeVeiProRaz 	= VeiProRaz
			&OpeVeiProTip 	= VeiPro
			&OpeVeiProUf 	= VeiProUf
		Else
			&OpeVeiRNTRC 	= ''
			&OpeVeiProCnpj 	= ''
			&OpeVeiProIe 	= ''
			&OpeVeiProRaz 	= ''
			&OpeVeiProTip 	= PropriedadeVeiculo.Proprio
			&OpeVeiProUf 	= ''
		EndIf
		
		Exit
	When none 
		msg('Veículo de Tração, não localizado!')
		Return
	EndFor
	
	For Each Order EmpCod, FilCod, OpeCod, (OpeVeiCod)
		Where EmpCod 	= &EmpCod
		WHere FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		
		&NewOpeVeiCod 	= OpeVeiCod
		
		Exit
	EndFor
	&NewOpeVeiCod += 1
	
	NEw
		EmpCod 			= &EmpCod
		FilCod 			= &FilCod
		OpeCod 			= &OpeCod
		OpeVeiCod 		= &NewOpeVEiCod
		OpeVeiPla		= &OpeVeiPla
		OpeVeiUF 		= &OpeVeiUF
		OpeVeiTipCar	= &OpeVeiTipCar
		
	EndNEw
	
Else //DELETAR	
	For Each Order EmpCod, FilCod, OpeCod, OpeVeiCod
		Where EmpCod	= &EmpCod
		WHere FilCod 	= &FilCod
		Where OpeCod 	= &OpeCod
		Where OpeVeiCod = &OpeVEiCod
		
		Delete
		Exit
	EndFor	
EndIF


Commit

]]></Source>
