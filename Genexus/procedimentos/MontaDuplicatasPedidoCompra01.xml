      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	&Parcela = 0
	If PedDtaFat.IsEmpty() 
		&PedDtaFat = PedTmpDupDtaFat
	Else
		&PedDtaFat = PedDtaFat
	EndIF
	
	For Each Order EmpCod, FilCod, CreCod	
		Where CreSts <> Status_Duplicata.CANCELADA
		&Parcela += 1
		do case
			case CreFrpPgtoTip = TipoDuplicata.CHEQUEP
				&CheCod = CreCheCod
				do 'getDadosChequeProprio'
		EndCase
		
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			PedTmpDupCod = &Parcela
			PedTmpCreCod = CreCod
			
			PedTmpDupNro =  CreDupNro
			PedTmpDupVlr = CreVlrDup
			PedTmpDupVct = CreDtaVct

			PedTmpFrpPgtoCod = CreFrpPgtoCod
			
			&PedTmpSem = substr(cdow(CreDtaVct), 1, 3)
			PedTmpSem = &PedTmpSem
			
			PedTmpPrz = 0
			IF (not CreDtaVct.IsEmpty()) and (not &PedDtaFat.IsEmpty())
				&PedTmpPrz = (CreDtaVct - &PedDtaFat) 
			EndIf
			
			PedTmpPrz = &PedTmpPrz
			
	        PedTmpDupCbrCod = CreCbrCod
			PedTmpPlanCod = CrePlanCod
			If CreVlrDup <> CreVlrSdo				
				PedTmpSts = Status_SimNao.Sim
			Else
				PedTmpSts = Status_SimNao.Nao
			EndIF
			
			PedTmpBanCod = &CheBanCod
			PedTmpAgeCod = &CheAgeCod
			PedTmpConCod = &CheCon
			
		EndNEw
	EndFor
EndFor

commit

Sub 'getDadosChequeProprio'
	&CheBanCod.SetEmpty()
	&CheAgeCod.SetEmpty()
	&CheCon.SetEmpty()
	&CheNro.SetEmpty()
	&CheDtaEmi.SetEmpty()
	&CheDtaVct.SetEmpty()
	
	For Each Order EmpCod, CheCod
		Where EmpCod = &EmpCod
		Where CheCod = &CheCod
		Where CheTip = TipoCheque.Proprio
		
		&CheBanCod = CheBanCod
		&CheAgeCod = CheAgeCod
		&CheCon = CheCon
		&CheNro = CheNro
		&CheDtaEmi = CheDtaEmi
		&CheDtaVct = CheDtaVct
		
		Exit
	EndFor
EndSub
]]></Source>
