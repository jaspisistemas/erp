      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod, BalCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	&PedCod = BalPedCod
	do 'atualizaPedido'
	
	if BalSts = Status_Pedido.ABERTO and BalStsPrc = AtualizandoEstoquePedido.Aberto
		BalSts = Status_Pedido.CANCELADO
	Endif

	Exit
EndFor

commit


For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	
	EstProStsBal = retornaProdutoBalanco.Udp(EmpCod, FilCod, ProCod, ProGraCod)
EndFor

commit


Sub 'atualizaPedido'
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
				
		PedBlq = Status_SimNao.Sim
		PedStsGer = Pedido_Gerado.Interno
		PedStsFin = Status_Financeiro.CANCELADO
		
		PedSts = Status_Pedido.CANCELADO
		
		
		Exit
	EndFor
	
	commit
	
	PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &PedCod)
	
	AtualizaEstoqueEntradaSaida.call(&EmpCod, &FilCod, &PedCod, Status_Pedido.CANCELADO)
EndSub
]]></Source>
