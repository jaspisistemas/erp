sub 'printEtiquetas'
	For &i = 1 to &EtqQtd step 1
		
		Do CAse
			CAse &IsColuna1 = 1
				If &AuxLInha >= 9
					eject
					print Cabeca
					&AuxLInha = 0
				EndiF
			
				print EtiquetaModelo001Col1
				&IsColuna1 = 2
				
			CAse &IsColuna1 = 2
				noSkip
				print EtiquetaModelo001Col2
				&IsColuna1 = 3
				
			Case &IsColuna1 = 3
				noSkip
				print EtiquetaModelo001Col3
				&IsColuna1 = 1
				&AuxLInha += 1
		EndCAse
	EndFor
EndSub
