      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&TabCod = RetornaTabelaFilial.Udp(&EmpCod, &FilCod)

For Each Order EmpCod, TabCod
	
	Where EmpCod = &EmpCod
	Where TabCod = &TabCod
	
	if &TabPrc1.IsEmpty()
		wpadicionaprodutotabela.Link(&DeOndeVem, &ProCod, TabCod, TabUltAlt, &IsProdutoComGrade)
	Else
		RetornaColunasTabelas.Call(EmpCod, TabCod, &TabPerCol, &TabPerCol2, &TabPerCol3,&TabPerCol4,&TabPerCol5,&TabPerCol6,&TabPerCol7,&TabPerCol8,&TabPerCol9,&tem1,&tem2,&tem3,&tem4,&tem5,&tem6,&tem7,&tem8,&tem9)
		
		If TabIsPerCol1 = true
			if &TabPerCol2 <> 0 
	            &TabPrc2 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol2/100),2)
			Else
				&TabPrc2 = &TabPrc1
	        EndIF
			
	        if &TabPerCol3 <> 0 
	            &TabPrc3 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol3/100),2)
			Else
				&TabPrc3 = &TabPrc1
	        EndIF
			
	        if &TabPerCol4 <> 0 
	            &TabPrc4 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol4/100),2)
			Else
				&TabPrc4 = &TabPrc1
	        EndIF
			
	        if &TabPerCol5 <> 0 
	            &TabPrc5 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol5/100),2)
			Else
				&TabPrc5 = &TabPrc1
	        EndIF
			
	        if &TabPerCol6 <> 0 
	            &TabPrc6 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol6/100),2)
			Else
				&TabPrc6 = &TabPrc1
	        EndIF
			
	        if &TabPerCol7 <> 0 
	            &TabPrc7 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol7/100),2)
			Else
				&TabPrc7 = &TabPrc1
	        EndIF
			
	        if &TabPerCol8 <> 0 
	            &TabPrc8 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol8/100),2)
			Else
				&TabPrc8 = &TabPrc1
	        EndIF
			
	        if &TabPerCol9 <> 0 
	            &TabPrc9 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol9/100),2)
			Else
				&TabPrc9 = &TabPrc1
	        EndIF
	    Else
	        if &TabPerCol2 <> 0 
	            &TabPrc2 = round(&TabPrc1 + (&TabPrc1 * &TabPerCol2/100),2)
			Else
				&TabPrc2 = &TabPrc1
	        EndIF
			
	        if &TabPerCol3 <> 0 
	            &TabPrc3 = round(&TabPrc2 + (&TabPrc2 * &TabPerCol3/100),2)
			Else
				&TabPrc3 = &TabPrc2
	        EndIF
			
	        if &TabPerCol4 <> 0 
	            &TabPrc4 = round(&TabPrc3 + (&TabPrc3 * &TabPerCol4/100),2)
			Else
				&TabPrc4 = &TabPrc3
	        EndIF
			
	        if &TabPerCol5 <> 0 
	            &TabPrc5 = round(&TabPrc4 + (&TabPrc4 * &TabPerCol5/100),2)
			Else
				&TabPrc5 = &TabPrc4
	        EndIF 
			
	        if &TabPerCol6 <> 0 
	            &TabPrc6 = round(&TabPrc5 + (&TabPrc5 * &TabPerCol6/100),2)
			Else
				&TabPrc6 = &TabPrc5
	        EndIF
			
	        if &TabPerCol7 <> 0 
	            &TabPrc7 = round(&TabPrc6 + (&TabPrc6 * &TabPerCol7/100),2)
			Else
				&TabPrc7 = &TabPrc6
	        EndIF
			
	        if &TabPerCol8 <> 0 
	            &TabPrc8 = round(&TabPrc7 + (&TabPrc7 * &TabPerCol8/100),2)
			Else
				&TabPrc8 = &TabPrc7
	        EndIF
			
	        if &TabPerCol9 <> 0 
	            &TabPrc9 = round(&TabPrc8 + (&TabPrc8 * &TabPerCol9/100),2)
			Else
				&TabPrc9 = &TabPrc8
	        EndIF
	    EndIF				
		
		GravaProdutoNaTabela.Call(EmpCod, TabCod, TabUltAlt, &ProCod, 1, 'ADD', &TabProDtaIni, &TabProDtaFin, &TabPrc1, &TabPrc2, &TabPrc3, &TabPrc4, &TabPrc5, &TabPrc6, &TabPrc7,&TabPrc8,&TabPrc9,&wwpContextUserName)
				
		if &IsProdutoComGrade = true
			wpeditagrade.Call(&EmpCod, &ProCod, &DeOndeVem)
		Else
			Do Case
				CAse &DeOndeVem = 'ImpProduto'
					ImpProduto.Link(TrnMode.Insert, &EmpCod, 0)
				Otherwise
					Produtos.Link('WWPRODUTO', TrnMode.Insert, &EmpCod, 0, '')
			EndcAse		
		EndiF		
	EndIF
	Exit
EndFor
]]></Source>
