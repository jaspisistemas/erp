      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
LoadWWPContext.Call(&Context)
&EmpWebBaseUrl 	= "/services/"
&Hash			= "b754b48e-8c22-4cfc-bb0a-3524a76284c9"

For each Order EmpCod,FilCod
	Where EmpCod 	= &Context.EmpCod
	Where FilCod 	= &Context.FilCod
		
	If FilFrtAmb 	= Tamb.Homologacao
		&EmpWebHost = "dev.efrete.com.br"
		&Usuario	= "usuario@jaspi"
		&Senha		= "usuario#jaspi"
	Else
		&EmpWebHost = "sistema.efrete.com.br"
		&Usuario 	= FilFrtUsu
		&Senha 		= FilFrtSen
	EndIf
	
	Exit
When none
	
	&EmpWebHost 	= "dev.efrete.com.br"
	&Usuario		= "usuario@jaspi"
	&Senha			= "usuario#jaspi"

EndFor
]]></Source>
