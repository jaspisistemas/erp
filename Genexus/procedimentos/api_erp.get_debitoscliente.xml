      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
	&CreDtaVct = serverdate()
	&sdtDuplicatas.sts = 'J200'
	
	if &PedCliCod.IsEmpty()
		&sdtDuplicatas.sts = 'J988'
		&sdtDuplicatas.obs = 'Cliente não informado'
		return
	endif

	//Duplicatas vencidas
	For Each Order EmpCod, CreCliCod
		Where EmpCod = &wwpContext.EmpCod
		Where CreCliCod = &PedCliCod
		Where CreVlrSdo > 0
		Where CreDtaVct <= &CreDtaVct
		Where CreRecPag = ReceberPagar.Receber
		Where CreFrpPgtoTip <> TipoDuplicata.CARTAOD and CreFrpPgtoTip <> TipoDuplicata.CARTAOC
		Where CreSts <> Status_Duplicata.CANCELADA
		
		
		&sdtDuplicatasVencidos = new()
		&sdtDuplicatasVencidos.Cod = CreCod
			
		&sdtDuplicatasVencidos.DiasVcd = &CreDtaVct - CreDtaVct
		&sdtDuplicatasVencidos.EmsTmp = DateToTimestamp.Udp(CreDtaEms)
		&sdtDuplicatasVencidos.VctTmp = DateTotimestamp.Udp(CreDtaVct)
		&sdtDuplicatasVencidos.Nro = CreDupNro
		&sdtDuplicatasVencidos.Ped = CrePedCod
		&sdtDuplicatasVencidos.Sdo = trim(toformattedString(CreVlrSdo))
		&sdtDuplicatasVencidos.Vlr = trim(toformattedString(CreVlrDup))
		
		&sdtDuplicatas.vencidas.Add(&sdtDuplicatasVencidos)
	EndFor

Else
	&sdtDuplicatas.sts = 'E999'
		&sdtDuplicatas.obs = 'Not conected'
		return
Endif
]]></Source>
