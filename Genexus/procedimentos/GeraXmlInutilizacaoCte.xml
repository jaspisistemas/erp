      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&HojeData = serverdate()
&Ano = substr(str(year(&HojeData),4,0),3,2) 

Do 'getCte'

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&CNPJ = RetornaSoNumeros.Udp(FilCpj)
	&FilCidUfeCod = RetornaCodigoSiglaEstado.UDP(0, FilCidUfeCod)
	Exit
EndFor

GravaInutilizacao.Call(&EmpCod, &FilCod,&CteCod ,&FilInuCod, &Ano, &FilInuNroIni, &FilInuNroFin, &ModCod, &CteSer, '', '', &PesCod, Status_NFe.Digitando)

GravaSolicitacao.Call(&EmpCod, &FilCod, &CteCod, 0, TipoSolicitacao.Inutilizar_CTE, &PesCod, &SolCod)

RetornaVersaoNotas.Call(VersaoNota.VersaoCTe, &VersaoNF)

&id = &FilCidUfeCod + PadL(TRIM(&CNPJ), 14, '0') + &ModCod + padl(trim(str(&CteSer)),3,'0') + padl(trim(str(&FilInuNroIni,9,0)),9,'0')+padl(trim(str(&FilInuNroFin,9,0)),9,'0')

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() +trim(&id)+'-ped-inu.xml'
&Chave = 'ID'+ &id.Trim()

//Abrir o arquivo XML
&XmlWriter.Open(&Nome_enviar)

//Start no Documento
&XmlWriter.WriteStartDocument('UTF-8')

&XmlWriter.WriteStartElement('inutCTe')
&XmlWriter.WriteAttribute('versao',&VersaoNF) //versao 3.00 dava 99 erro nao catalogado // voltado versão 3.00 tts 01/02/18
&XmlWriter.WriteAttribute('xmlns', 'http://www.portalfiscal.inf.br/cte')

&XmlWriter.WriteStartElement('infInut')
&XmlWriter.WriteAttribute('Id',&Chave)

&XmlWriter.WriteElement('tpAmb',&sdtConfiguracoesPasta.FilAmbEms)
&XmlWriter.WriteElement('xServ','INUTILIZAR')
&XmlWriter.WriteElement('cUF',&FilCidUfeCod)
&XmlWriter.WriteElement('ano',&Ano)
If &CNPJ.Trim().Length() > 11
	&XmlWriter.WriteElement('CNPJ',&CNPJ)
Else
	&XmlWriter.WriteElement('CPF',&CNPJ)
EndIf
&XmlWriter.WriteElement('mod',&ModCod)
&XmlWriter.WriteElement('serie',&cteSer)

&XmlWriter.WriteElement('nCTIni',&FilInuNroIni)
&XmlWriter.WriteElement('nCTFin',&FilInuNroFin)

&XmlWriter.WriteElement('xJust',&xJust.Trim())

&XmlWriter.WriteEndElement()
&XmlWriter.WriteEndElement()
&XmlWriter.Close()

wpInutilizaNumeroRecepcaoCte.Link(&DeOndeVem, &EmpCod, &FilCod, &FilInuCod, &SolCod)


Sub 'getCte'
	For Each Order EmpCod, FilCod, CteCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where CteCod = &CteCod
		If &IsCancelarDuplicatas = true
			CteCanDup = True
		EndiF
	EndFor

	commit
EndSub

]]></Source>
