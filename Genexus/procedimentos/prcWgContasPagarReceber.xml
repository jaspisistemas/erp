      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtGraficoContaPagarReceber.Clear()

For Each ORder EmpCod, FilCod, CreDtaVct
	Where EmpCod = &EmpCod
	//Where FilCod = &FilCod //ANALISAR
	Where CreSts <> Status_Duplicata.CANCELADA and CreSts <> Status_Duplicata.PERDA and CreSts <> Status_Duplicata.DESCONTADA
	Where CreVlrSdo > 0
	Where CreDtaVct >= &IniCreDtaVct and CreDtaVct <= &FinCreDtaVct
	
	if &CreDtaVct <> CreDtaVct or CreRecPag <> &CreRecPag and not &CreDtaVct.IsEmpty()
		do 'AddSdt'
	EndIf
	
	&CreDtaVct = CreDtaVct
	&CreRecPag = CreRecPag
	&CreVlrSdo += CreVlrSdo
	
EndFor

if &CreVlrSdo > 0
	do 'AddSdt'
Endif

padraoUsuarioHora.Call('G', '#WGContasPagarReceber#', &PesCod, &EmpCod, &sdtGraficoContaPagarReceber.ToXml(), &PadDtaMod, &PadDtaHorMod, 'T')

Sub 'AddSdt'
	&isAChou = false
	For &sdtGraficoContaPagarReceberItem in &sdtGraficoContaPagarReceber
		if &sdtGraficoContaPagarReceberItem.CreDtaVct = &CreDtaVct
			if &CreRecPag = ReceberPagar.Receber
				&sdtGraficoContaPagarReceberItem.CreVlrSdoRec += &CreVlrSdo
			Else
				&sdtGraficoContaPagarReceberItem.CreVlrSdoPag += &CreVlrSdo
			EndIf
			&isAChou = true
			Exit
		Endif
	EndFor

	If &isAChou = false
		&sdtGraficoContaPagarReceberItem = new()
		&sdtGraficoContaPagarReceberItem.CreDtaVct = &CreDtaVct
		if &CreRecPag = ReceberPagar.Receber
			&sdtGraficoContaPagarReceberItem.CreVlrSdoRec += &CreVlrSdo
		Else
			&sdtGraficoContaPagarReceberItem.CreVlrSdoPag += &CreVlrSdo
		EndIf
		&sdtGraficoContaPagarReceber.Add(&sdtGraficoContaPagarReceberItem)
	Endif

	&CreVlrSdo = 0
EndSub
]]></Source>
