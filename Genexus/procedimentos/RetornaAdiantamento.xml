      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&MovItmVlr = 0
For each Order EmpCod,MovFunCod,MovFunSts
	Where EmpCod    = &EmpCod
	Where MovFunCod = &MovFunCod
	Where MovTip = TipoMovimento.Adiantamento
	Where MovCreDeb = 'D'
	Where MovFunAno <= &FPagAno or &FPagAno.IsEmpty()
	Where MovFunMes <= &FPagMes or &FPagMes.IsEmpty()
	Where MovFunSts = Status_AbertoFechado.Aberto
	Where MovSts.IsEmpty() or MovSts.IsNull() or MovSts <> Status_Caixa.Cancelado
	Where MovItmSts.IsEmpty() or MovItmSts.IsNull() or MovItmSts <> Status_Caixa.Cancelado
		
	&MovItmVlr += MovItmVlr
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
