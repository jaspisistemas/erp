      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//Grava Capa do movimento referente ao adiantamento realizdo 
UltimoCodigoEmpresa.Call(domParCod.MOVIMENTO, &EmpCod, 0,&MovCod)

New  // Grava Movimento		
	EmpCod = &EmpCod
	MovCod = &MovCod
	MovDta = SErverDate()
	MovDtaPgt = &MovDtaPgt
	MovHor = ServerNow()
	MovCtaBanCod = &MovCtaBanCod
	
	If not &MovDoc.Trim().IsEmpty()
		MovDoc = trim(&MovDoc)
	Else
		MovDoc = trim(str(&MovCod))
	EndIf
	
	If &CreRecPag = 'R'
		MovCreDeb = 'C'
	Else
		MovCreDeb = 'D'
	EndIf
	
	MovTip = TipoMovimento.adiantamentoPedido
	MovDtaCon = &MovDtaCon
	MovCplMan = &MovItmCpl
	MovSts = Status_Caixa.Lancado
	When duplicate
		msg('ATENÇÃO, A  chave do lançamento já existe, não possível gravar o lançamento! verifique os parâmetros, ou contate a equipe jaspi!')
	Return
EndNew


//Gera duplicata a receber ou a pagar com valor do adiantamento
For &SdtAdiantamentoItem in &SdtAdiantamento	
	GravaNovaDuplicata.call(&EmpCod,&FilCod,&MovCod,&MovCtaBanCod,&CreRecPag,&MovDtaPgt,&MovDtaCon,&MovDoc,&MovPesCod,&MovItmCpl,&SdtAdiantamentoItem.DtaVct,&SdtAdiantamentoItem.PlanCod,&SdtAdiantamentoItem.Valor,&PesCod,&TipoPerfil)
EndFor

For each Order EmpCod,MovCod
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	AtualizaSaldoConta.Call(TrnMode.Insert,EmpCod,MovCtaBanCod,MovDtaCon,MovCreDeb,MovVlr,&DataVazia,0,'')
	Exit
EndFor

commit

if &MovCod > 0
	PrcAtualizaMovimentoFinanceiro.Call(&EmpCod, &MovCod)
Endif
]]></Source>
