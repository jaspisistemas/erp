      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each ORder tmpNFeCod, tmpNfeItmCod
	Where tmpNFeCod = &tmpNFeCod
	Where tmpNfeItmCod = &tmpNfeItmCod
	
	if not &tmpProRef.IsEmpty()
		do 'getProduto'
	Endif

	tmpProForCod = &AuxtmpProForCod
	tmpProCod = &ProCod
	tmpProGraCod = &ProGraCod
	tmpProRef = &tmpProRef	
	tmpProNomERP = &ProNom
	tmpProBar = &tmpProBar 
	tmpProNcmCod = &tmpProNcmCod
	
	If &tmpProQtdCmpEmb > 0
		tmpProQtdCmpEmb = &tmpProQtdCmpEmb
	Else
		tmpProQtdCmpEmb = 1
	EndIf
	Exit
EndFor


commit



Sub 'GetProduto'
	
	RetornaProdutoReferencia.Call(&EmpCod, &tmpProRef, &ProCod, &ProGraCod, &ProNom, &IsAchou, &ProReqVlr, &ProReqQTd, &ProBarQtd, &ErroMensagem)
	For Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		
		&ProCod = ProCod
		&ProGraCod = ProGraCod
		&ProNom = ProNomGra
		&tmpProQtdCmpEmb = ProQtdCmpEmb
		&tmpProNcmCod =  NcmCod
		&tmpProBar = ProBar
		
		Exit
	EndFor
EndSub
]]></Source>
