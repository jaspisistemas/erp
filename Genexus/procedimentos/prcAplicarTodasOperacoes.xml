      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//atualiza dentro uf
For Each ORder CfoCod	
	&Caractere = Substr(CfoCod, 1, 1) 
	&CfoCod = CfoCod
	Do Case
		CAse &Caractere = '5'
			&CfoEmpEntCod = &CfoCodDentro
			do 'AddCfopEntrada'
		CAse &Caractere = '6'
			&CfoEmpEntCod = &CfoCodFora
			do 'AddCfopEntrada'
	Endcase	
EndFor


//atualiza fora uf


sub 'AddCfopEntrada'
	For Each Order CfoCod, CfoEmpCod, CfoLctCod
		Where CfoCod = &CfoCod
		Where CfoEmpCod = &EmpCod
		Where CfoLctCod = &LctCod
		CfoEmpEntCod = &CfoEmpEntCod 
		Exit
		
	When none
		new
			CfoCod = &CfoCod
			CfoEmpCod = &EmpCod
			CfoLctCod = &LctCod
			CfoEmpEntCod = &CfoEmpEntCod 
			CfoEmpInvCod = ''
		EndNew
	EndFor

	Commit
EndSub
]]></Source>
