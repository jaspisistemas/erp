      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

RetornaTabelaFilial.Call(&EmpCod, &FilCod, &TabCod)

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

if &OqueFazer = 'P'
	&titulo = 'PRODUTOS SEM PREÇO NA TABELA'
Else
	&titulo = 'PRODUTOS SEM CÓDIGO ORIGEM'
EndIf

Header
	
	print Cabecalho
	print Titulo
End

if &OqueFazer = 'P'
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
	    &ProCod = ProCod
	    &ProOriCod = ProOriCod
		&ProNom = ProNom
	    do 'tabela'
	EndFor
Else	
	For Each Order EmpCod, ProOriCod, ProCod
		Where EmpCod = &EmpCod
		Where ProOriCod = 0 or ProOriCod = ProCod
		
		&ProCod = ProCod
		&ProNom = ProNom
		
	    print produto
	EndFor
	
EndIF



Footer
	print Rodape
End

Sub 'tabela'
    For Each Order EmpCod, TabCod, ProCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
	    Where ProCod = &ProCod
	    exit
    When none
        print produto
    EndFor
EndSub
]]></Source>
