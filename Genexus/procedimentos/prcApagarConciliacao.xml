      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica se tem lancamento posterior ao periodo
&IsTemLancamento = false
For Each
	Where EmpCod = &EmpCod
	Where CtabanCod = &CtaBanCod
	where ((LanBanData.day() > &Dia and LanBanData.Month() = &MEs) or (LanBanData.day() >= &Dia and LanBanData.Month() > &MEs)) and LanBanData.year() >= &Ano when not &Dia.IsEmpty()
	where LanBanData.Month() > &MEs and LanBanData.year() >= &Ano when &Dia.IsEmpty()
	
	&IsTemLancamento = true
	&ProgressLogXml = 'Existe lançamentos Bancários posteriores à : '
	if &Dia > 0
		&ProgressLogXml += trim(padL(str(&Dia), 2, '0'))+ '/'
	Endif

	&ProgressLogXml += trim(padL(str(&Mes), 2, '0'))+ '/' + trim(str(&Ano))
	
	&ProgressLogXml +=', com isso não será possivel apagar o periodo selecionado!'

	
	Exit	
EndFor

if &IsTemLancamento = false
	For Each Order EmpCod, CtabanCod, LanBanData
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		where LanBanData.Month() = &MEs
		where LanBanData.year() = &Ano
		where LanBanData.day() = &Dia when not &Dia.IsEmpty()
		
		&Total += 1
		
	EndFor
	
	&Count = 0
	&Percentual = 0
	&ProgressIni = serverNow()
	do 'Atualiza'	
	
	For Each Order EmpCod, CtabanCod, LanBanData
		Where EmpCod = &EmpCod
		Where CtabanCod = &CtaBanCod
		where LanBanData.Month() = &MEs
		where LanBanData.year() = &Ano
		where LanBanData.day() = &Dia when not &Dia.IsEmpty()
		
		&Qtd += 1
		if &Qtd = 5
			&Count += &Qtd
			If &Count > 0
				&Percentual = round((&Count / &Total) * 100, 0)
			EndIF
			If &Percentual >= 100
				&Percentual = 99
			EndIf
			do 'Atualiza'
			&Qtd = 0
		Endif
	
		//Atualiza Itens do movimento para nao conciliado
		For Each Order EmpCod, CtabanCod, MovItmDoc
			where MovItmDoc = LanBanDoc
			
			MovItmDoc.SetEmpty()
			MovItmIsCon = Status_SimNao.Nao
			MovItmConDesc.SetEmpty()
			MovItmDtaCon.SetEmpty()
		EndFor
		
		delete  //Apaga os lancamentos
		
		Commit
		
	EndFor
EndIf


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &ProgressLogXml
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &ProgressLogXml
		Endnew
	endfor
	
	commit	
EndSub
]]></Source>
