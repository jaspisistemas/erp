      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Compilacao.Call(true, &Compilacao, &IsExecutaUpdate, &DisEmpVer, &DisEmpCmp)
if &IsExecutaUpdate = true
	msg('Inicializando Reorgs', status)
	JaspiReorg.Call('UpdateSistema', false, &Compilacao)
EndIf

&WinAppGUID = GUID.FromString('784189df-359a-4c0e-8e1c-dd442cd0eb21')
&WinAppGUIDAppJaspi = GUID.FromString('3c982730-aa2b-4745-826f-c666c8141449')
&WinAppPathAppJaspi = ''
&WinAppNomFisAppJaspi = ''
&LogGUID = GUID.NewGuid()

if &ProcessManager.IsCurrentProcessAdmin()
	msg('Bem-vindo, adm', status)
else
	msg('Permissão insuficiente. Inicie como administrador.', status)
	do 'EncerrandoEm5s'
endif

Do 'InsereDadosIniciais'

Do 'LogAtivos'

SyncronizaInstanciaAtual(&LogGUID,'AppJaspi',&WinAppGUID,&WinAppInsLog,&WinAppInsGUID,&isContinuar)

Do 'LogAtivos'

if not &isContinuar
	do 'EncerrandoEm5s'
endif

&count = 0
do while true
	do 'SyncronizaAppJaspi'
	
	for each order WinAppGUID
		where WinAppGUID = &WinAppGUIDAppJaspi
		where WinAppInsSts = Status_Instancia.ATIVO
			or WinAppInsSts = Status_Instancia.DESLIGAR
		msg(WinAppNom + ' tudo certo já . . . ', status)
	when none
		msg('AppJaspiMaster, iniciando AppJaspi . . . ', status)
		&ProcessManager.StartProcess(&WinAppPathAppJaspi,'"Iniciado via AppMaster"')
		GravaLogDevNew(0,&LogGUID,&Pgmname,'Iniciando', 'AppJaspi')
	endfor
	
	msg('Dormingo ' + trim(str(&count)) + ' . . . ', status)
	&sleep = sleep(5)
	&count += 1
	
	do 'DoAppContinuaAtivo'
	
enddo

Sub 'InsereDadosIniciais'

	&path = &ProcessManager.GetCurrentLocation()
	msg('-----------------------------------', status)
	msg('Local: ' + &path, status)

	if not &path.IsEmpty()
		for &sdtWinAppItem in dpWindowsAppDados(&path)
			for each Order WinAppGUID
				where WinAppGUID = &sdtWinAppItem.WinAppGUID
				msg('Já cadastrado: ' + WinAppNom, status)
				exit
			when none
				msg('Cadastrando ' + &sdtWinAppItem.WinAppNom, status)
				New
					WinAppGUID         = &sdtWinAppItem.WinAppGUID         //
					WinAppNom          = &sdtWinAppItem.WinAppNom          //
					WinAppNomFis       = &sdtWinAppItem.WinAppNomFis       //
					WinAppPath         = &sdtWinAppItem.WinAppPath         //
					WinAppIsHabilitado = &sdtWinAppItem.WinAppIsHabilitado //
					WinAppMaxIns       = &sdtWinAppItem.WinAppMaxIns       //
				EndNew
			endfor
		
			if &sdtWinAppItem.WinAppGUID = &WinAppGUIDAppJaspi
				&WinAppPathAppJaspi = &sdtWinAppItem.WinAppPath
				&WinAppNomFisAppJaspi = &sdtWinAppItem.WinAppNomFis
			endif
		endfor
		commit
		msg('-----------------------------------', status)
	else
		msg('Local atual veio incorreto', status)
		msg('-----------------------------------', status)
		do 'EncerrandoEm5s'
	endif

EndSub

Sub 'SyncronizaAppJaspi'
	&now = now()
	&segundos = &now.Difference(&ultSyncProcessos)
	
	if &segundos < 0
		&segundos *= -1
	endif
	
	if &segundos > 30 // 10 minutos = 300 segundos
		msg('Syncronizando AppJaspi', status)
		SyncronizaInativaInstancia(&LogGUID,&WinAppGUIDAppJaspi,'AppJaspiMaster')
		msg('Syncronizando AppJaspi: tudo pronto', status)
		&ultSyncProcessos = now()
	endif
EndSub

Sub 'DoAppContinuaAtivo'
	AppContinuaAtivo(&WinAppGUID,&WinAppInsGUID,&IsContinuar)
	
	if not &IsContinuar
		msg('Instância não mais ativa', status)
		do 'EncerrandoEm5s'
	endif
Endsub

Sub 'EncerrandoEm5s'
	msg('Encerrando em 5s', status)
	&sleep = sleep(5)
	return
EndSub

Sub 'LogAtivos'
	GravaLogDevNew(0,&LogGUID,&Pgmname,'LogAtivos', 'Iniciando')
	for each order WinAppGUID, WinAppInsGUID
		where WinAppInsSts = Status_Instancia.ATIVO
		GravaLogDevNew(0,&LogGUID,&Pgmname,'Instância ativa', WinAppNom + ' | ' + trim(str(WinAppInsPID)))
	endfor
	GravaLogDevNew(0,&LogGUID,&Pgmname,'LogAtivos', 'Finalizado')
EndSub

Sub 'subException_handler'
	
	&WinAppLog = '[EXCEPTION] Finalizado pelo ' + &Pgmname
	msg(&WinAppInsLog, status)
	
EndSub

Sub 'subError_handler'
	
	&WinAppLog = '[ERROR] Finalizado pelo ' + &Pgmname
	msg(&WinAppInsLog, status)
	
EndSub
]]></Source>
