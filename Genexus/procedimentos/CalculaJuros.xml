      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&VlrJur = 0 
&VlrMon = 0
&VlrCap = 0 
&DtaIni = &CreDtaVct
&Hoje   = &DtaFimJur
&VlrMon = &CreVlrSdo
&VlrCap = &CreVlrSdo
&Dias = 0 

Do While &DtaIni < &Hoje
	&JurAno = year(&DtaIni)  // Ano Vcto 2015       30/10/2015
	&JurMes = month(&DtaIni) // Mês Vcto 10
	
	Do 'Taxa'                // Pega ultima Taxa mensal Cadastrada
	&DtaFim = eom(&DtaIni)   // Ultimo Dia do Mês de Vcto
	
	If &TxaDia > 0
		
		Do Case
			Case &JurTip = jurotipo.SimplesDiario
				if &DtaFim > &Hoje       // verifica se ultimo dia do mes do vencimento é maior que o vencimento 
					&DtaFim = &Hoje      
				Endif
				
				&Dias += (&DtaFim - &DtaIni)     // Soma Qtd de Dias Vencidos
				&VlrJur = round((&VlrCap * &TxaDia),2)
				&VlrMon += &VlrJur * &Dias
			Case &JurTip = jurotipo.CompostoDiario
				If &DtaFim > &Hoje       // verifica se ultimo dia do mes do vencimento é maior que o vencimento 
					&DtaFim = &Hoje      
				EndIf
				
				&Dias += (&DtaFim - &DtaIni)     // Soma Qtd de Dias Vencidos
				&VlrJur = round((&VlrMon * &TxaDia),2)
				&VlrMon += &VlrJur * &Dias
		EndCase
		
	EndIf
	
	&DtaIni = &DtaFim + 1
	&Dias = 1
EndDo

if &VlrJur > 0
    &VlrJur = (&VlrMon - &VlrCap)
Endif

If &CreCbrMltVlr > 0
	&Multa = (&VlrCap * (&CreCbrMltVlr / 100))
	//&VlrMon += &VlrMlt
EndIf

Sub 'Taxa'
	
	&TxaDia = 0
	&IsExite = true	
	For Each Order EmpCod,JurCod,(JurAno),(JurMes)
		Where EmpCod = &EmpCod
		Where JurCod = &JurCod
		Where JurAno <= &JurAno
		Where JurMes <= &JurMes
		&JurTip = JurTip 
		&NovJurAno = JurAno
		&NovJurMes = JurMes
		&JurTax = JurTax
		&TxaDia = JurTaxDia
		Exit
	EndFor
EndSub
]]></Source>
