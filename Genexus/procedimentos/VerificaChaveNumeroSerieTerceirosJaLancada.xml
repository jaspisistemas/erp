      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsErroLancada = false
&Mensagem = ''
	
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod <> &CteCod
	
	Where CteNum = &CteNum
	Where CteSer = &CteSer
	Where CteTomCod = &CteTomCod
	
	Where CteProTer = Nota_ProPriaTerceira.TERCEIROS
	
	&IsErroLancada = true
	&Mensagem = 'NUMERO E SERIE JA LANÇADA NO CTE SEQUÊNCIA: ' + trim(str(CteCod))
	Exit
EndFor
]]></Source>
