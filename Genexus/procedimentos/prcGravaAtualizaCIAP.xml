      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&CiapCod = &parCiapCod
if &CiapCod.IsEmpty()
	For Each Order EmpCod, FilCod, CiapCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&CiapCod = CiapCod
		Exit
	EndFor
Endif



Do CAse
	CAse &OqueFazer = 'ADD'
		For Each Order EmpCod, FilCod, CiapAno, CiapMes, CiapNfeCod, CiapNfeItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CiapAno = &CiapAno
			Where CiapMes = &CiapMes
			Where CiapNfeCod = &CiapNfeCod
			Where CiapNfeItmCod = &CiapNfeItmCod
			
			CiapSts = &CiapSts
			CiapBasIcms = &CiapBasIcms
			CiapVlrIcms = &CiapVlrIcms
			CiapNFNum = &CiapNFNum
			CiapDtaEms = &CiapDtaEms
			CiapCod = &CiapCod
			Exit
		When none
			new
				EmpCod = &EmpCod
				FilCod = &FilCod
				CiapAno = &CiapAno
				CiapMes = &CiapMes
				CiapNfeCod = &CiapNfeCod
				CiapNfeItmCod = &CiapNfeItmCod
				CiapSts = Status_AtivoInativo.ATIVO
				CiapBasIcms = &CiapBasIcms
				CiapVlrIcms = &CiapVlrIcms
				CiapNFNum = &CiapNFNum
				CiapDtaEms = &CiapDtaEms
				CiapCod = &CiapCod
			EndNew	
		
			&ano = &CiapAno
			&Mes = &CiapMes
			&CiapParVlr = round((&CiapVlrIcms/48), 2)
			
			For &Count = 1 to 48
				
				New
					EmpCod = &EmpCod
					FilCod = &FilCod
					CiapAno = &CiapAno
					CiapMes = &CiapMes
					CiapNfeCod = &CiapNfeCod
					CiapNfeItmCod = &CiapNfeItmCod
					CiapPar = &Count
					CiapParAno = &ano
					CiapParMes = &Mes
					CiapParDes = format('ICMS %1/48 AVOS DE %2 NF %3 DO DIA %4', padL(trim(str(&count)), 2, '0'), trim(toformattedString(&CiapVlrIcms)), trim(toformattedString(&CiapNFNum)), trim(toformattedString(&CiapDtaEms)) )
					CiapParVlr = &CiapParVlr
				EndNew
				
				if &Mes = 12
					&mes = 0
					&ano += 1
				EndIf
			
				&Mes += 1	
			EndFor
		EndFor
		
	CAse &OqueFazer = 'INA'
		For Each Order  EmpCod, FilCod, CiapAno, CiapMes, CiapNfeCod, CiapNfeItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where CiapAno = &CiapAno
			Where CiapMes = &CiapMes
			CiapSts = Status_AtivoInativo.INATIVO
		EndFor
EndCAse

Commit

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
