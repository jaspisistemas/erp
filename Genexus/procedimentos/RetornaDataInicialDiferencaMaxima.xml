      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &PedDtaFat.IsEmpty()
	&PedDtaFat = &PedDtaFat_to
	&PedDtaFat = &PedDtaFat.AddYears(-&AnoMaximo)
Else		
	&idade = age(&PedDtaFat, &PedDtaFat_to)
	if &idade > &AnoMaximo
		&PedDtaFat = &PedDtaFat_to
		&PedDtaFat = &PedDtaFat.AddYears(-&AnoMaximo)
	Endif
EndIf
]]></Source>
