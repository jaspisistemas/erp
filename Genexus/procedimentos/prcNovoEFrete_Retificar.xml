      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[// O conteúdo da tag Integrador deve ser uma CONSTANTE, pois é ela quem identifica seu sistema de gestão,
//Suporte e-FRETE:	Seguem credenciais para uso em ambiente de homologação:
//Integrador:		JASPI SISTEMAS DE INFORMÁTICA
//CNPJ:				21826923000177
//Usuário:			usuario@jaspi
//Senha:			usuario#jaspi
//Hash:				b754b48e-8c22-4cfc-bb0a-3524a76284c9

LoadWWPContext(&Context)
//Config do Servidor
HostWebServiceEfrete.Call(&EmpWebHost, &ExecuteUrl, '', '', &Hash)
&ExecuteUrl			+= 'Pef/RetificarOperacaoTransporte'

&HttpClient.Host	= 	&EmpWebHost
&HttpClient.Secure	= 	1
		
//Header do Xml
&HttpClient.AddHeader(!'Content-Type', !'application/json')
&HttpClient.AddHeader(!'Accept-Encoding', !'gzip, deflate, br')

//Realiza o Envio ao WebService
&WizardData.FromJson(&WebSession.Get(&WebSessionKey))

// CORPO JSON \\
&JSONBody	=	'{'
&JSONBody	+=	'	"CodigoIdentificacaoOperacao": "'+ Trim(&WizardData.Retificar.OpeNroCiot) +'",'
If &WizardData.Retificar.GridVeiculo.Count >= 1
	&JSONBody	+=	'	"Veiculos": ['
	For &WizardDataItem In &WizardData.Retificar.GridVeiculo
		&Placa		= SubStr(&WizardDataItem.gridOpeVeiPla, 1, 3) + SubStr(&WizardDataItem.gridOpeVeiPla, 5, 4)
		&JSONBody	+=	'{		"Placa": "'+Trim(&Placa)+'"'
		&QtdPlacas 	+= 1
		If &QtdPlacas < &WizardData.Retificar.GridVeiculo.Count
			&JSONBody 	+=	'	},'
		Else
			&JSONBody	+=	'	}'
		EndIf
	EndFor
	&JSONBody	+=	'	],'
EndIf
If Not &Token.IsEmpty()
	&JSONBody	+=	'  "Token": "'+	Trim(&Token) +'",'
EndIf
&JSONBody	+=	'  "Integrador": "'+ &Hash.Trim() +'",'
&JSONBody	+=	'  "Versao": "3"'
&JSONBody	+=	'}'


&HttpClient.AddString(Trim(&JSONBody))
&HttpClient.Execute('POST',&ExecuteUrl)
		
padraoUsuarioHora.Call('G', '#EFRETERETIFICARROPERACAO', &Context.PesCod, &Context.EmpCod, &JSONBody, &PadDtaMod, &PadDtaHorMod, 'T')

If &HttpClient.StatusCode = 200
	&JSONBody 		= &HttpClient.ToString()
	&PosicaoSucesso = StrSearch(&JSONBody, '"Sucesso"')
	&PosicaoSucesso = &PosicaoSucesso + 11
	
	&Status = SubStr(&JSONBody, &PosicaoSucesso, 4)
	
	If &Status = 'true'
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", 'Operacao retificada com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))
		&StatusCode = 200
	Else	
		&PosicaoSucesso = StrSearch(&JSONBody, '"Mensagem"')
		&PosicaoSucesso = &PosicaoSucesso + 13
		
		&PosicaoFinal	= StrSearch(&JSONBody, '"Codigo"')
		&PosicaoFinal	= &PosicaoFinal - &PosicaoSucesso - 8
		&Status			= SubStr(&JSONBody, &PosicaoSucesso, &PosicaoFinal)
		
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Retificar!", 'Ocorreu um erro ao tentar retificar a operação. ERRO: '+ Trim(&Status), DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf
	padraoUsuarioHora.Call('G', '#EFRETERETIFICAROPERACAORESPOSTA', &Context.PesCod, &Context.EmpCod, &JSONBody, &PadDtaMod, &PadDtaHorMod, 'T')
Else
	Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Retificar!", &HttpClient.StatusCode.ToString() + ":" + &HttpClient.ErrDescription, DVMessageType.error, "", DVMessageBoolean.True,""))
EndIf
]]></Source>
