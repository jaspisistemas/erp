      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[ 
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	NfeVlrTotDsc = &NfeVlrTotDsc
	NfeVlrTotPdg = &NfeVlrTotPdg
	NfeVlrTotOutDsp = &NfeVlrTotOutDsp
	NfeVlrTotSeg = &NfeVlrTotSeg
	NfeVlrTotFrt = &NfeVlrTotFrt
	
	&NfeVlrTotPro = NfeVlrTotPro
	Exit
EndFor

Commit

&valorGlobalFrete = 0 
if &NfeVlrTotFrt <> 0 and &NfeVlrTotPro <> 0
	&valorGlobalFrete = &NfeVlrTotFrt/&NfeVlrTotPro
Endif

&DescontoUnitarioGlobal = 0 
if &NfeVlrTotDsc <> 0 and &NfeVlrTotPro <> 0
	&DescontoUnitarioGlobal = &NfeVlrTotDsc/&NfeVlrTotPro
Endif


&outrasDespesas = 0 
if &NfeVlrTotOutDsp <> 0 and &NfeVlrTotPro <> 0
	&outrasDespesas = &NfeVlrTotOutDsp/&NfeVlrTotPro
Endif

&Seguro = 0 
if &NfeVlrTotSeg <> 0 and &NfeVlrTotPro <> 0
	&Seguro = &NfeVlrTotSeg/&NfeVlrTotPro
Endif

&AuxNfeProVlrFrt = 0
&AuxNfeProVlrDsc = 0
&AuxNfeProVlrOutDsp = 0
&AuxNfeProVlrSeg =  0
For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
			
	&NfeProVlrFrt =  (NfeProVlrUnt * &valorGlobalFrete)
	NfeProVlrFrt = round(&NfeProVlrFrt * NfeProQtd, 2)
	&AuxNfeProVlrFrt += NfeProVlrFrt
	
	&NfeProVlrDsc =  (NfeProVlrUnt * &DescontoUnitarioGlobal)
	NfeProVlrDsc = round(&NfeProVlrDsc * NfeProQtd, 2)
	&AuxNfeProVlrDsc += NfeProVlrDsc
	
	&NfeProVlrOutDsp =  (NfeProVlrUnt * &outrasDespesas)
	NfeProVlrOutDsp = round(&NfeProVlrOutDsp * NfeProQtd, 2)
	&AuxNfeProVlrOutDsp += NfeProVlrOutDsp
	
	&NfeProVlrSeg =  (NfeProVlrUnt * &Seguro)
	NfeProVlrSeg = round(&NfeProVlrSeg * NfeProQtd, 2)
	&AuxNfeProVlrSeg += NfeProVlrSeg
	
EndFor

Commit

if &AuxNfeProVlrFrt <> &NfeVlrTotFrt
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeProVlrFrt > 0
		NfeProVlrFrt = NfeProVlrFrt + (&NfeVlrTotFrt -&AuxNfeProVlrFrt)
		Exit
	EndFor
EndIF

if &NfeVlrTotDsc <> &AuxNfeProVlrDsc
	
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeProVlrDsc > 0
		
		NfeProVlrDsc = NfeProVlrDsc + (&NfeVlrTotDsc -&AuxNfeProVlrDsc)
		
		Exit
	When none
		For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			
			NfeProVlrDsc = NfeProVlrDsc + (&NfeVlrTotDsc -&AuxNfeProVlrDsc)
			
			Exit
		EndFor
	EndFor

EndiF

if &NfeVlrTotOutDsp <> &AuxNfeProVlrOutDsp
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeProVlrOutDsp > 0
		
		NfeProVlrOutDsp = NfeProVlrOutDsp + (&NfeVlrTotOutDsp - &AuxNfeProVlrOutDsp)
		
		Exit
	EndFor
EndIf


if &NfeVlrTotSeg <> &AuxNfeProVlrSeg
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeProVlrSeg > 0
		
		NfeProVlrSeg = NfeProVlrSeg + (&NfeVlrTotSeg - &AuxNfeProVlrSeg)
		
		Exit
	EndFor
EndIf


Commit


AtualizaTotaisNFe.Call(&EmpCod, &FilCod, &NfeCod, 0)
commit
]]></Source>
