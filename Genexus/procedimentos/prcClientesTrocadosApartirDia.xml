      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = 1
&Count = 0
&Percentual = 10
&ProgressIni = serverNow()
do 'Atualiza'


For Each ORder EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesSts = Status_AtivoInativo.ATIVO
	Where PesIsCli = true
	Where PesIntVenCod <> &OldPesVenCod and (PesIntVenCod <> &NewPesCod or &NewPesCod = 0) 
	Where PesVinCod = PesCod or PesVinCod.IsEmpty() or PesVinCod.IsNull()
	
	&IntPesVenCod = 0
	RetornaVinculos.Call(EmpCod, PesCod, &sdtVinculos)
	VerificaVendedorAnterior.call(EmpCod, &sdtVinculos, &DataBase, &IntPesVenCod, &inPesUltVenDta )
	
	if &OldPesVenCod = &IntPesVenCod and (PesIntVenCod <> &NewPesCod or &NewPesCod = 0)
		&sdtPessoaItem = new()
		&sdtPessoaItem.PesCod = PesCod
		&sdtPessoaItem.pesRaz = PesRaz
		&sdtPessoaItem.PesIntVenCod = PesIntVenCod
		&sdtPessoa.Add(&sdtPessoaItem)
	EndIf
	
EndFor

padraoUsuario.Call('G', 'PRCCLIENTESTROCADOSAPARTIRDIA', &EmpCod, 1, &sdtPessoa.ToJson(), &PaddtaMod)

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


	
Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub
]]></Source>
