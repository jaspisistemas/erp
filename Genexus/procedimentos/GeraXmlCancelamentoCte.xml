      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
retornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

&hoje = serverdate()    
&VersaoNF = RetornaVersaoNotas.Udp(VersaoNota.VersaoCTe)
		
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	&CteChv = CteChv
	&CteAutNumPro = trim(CteAutNumPro)
	&FilCpj = FilCpj
	&cUF = retornaCodigoSiglaEstado.Udp(0, FilCidUfeCod)
	
	&FilFusHor = FilFusHor
	
	If &tmpNfeEnvEml = true
		CteEnvEml = NfeEnvEml.Pendente
	EndIF
	
	If &tmpCancelarDuplicatas = true
		CteCanDup = True
	EndiF

    Exit
EndFor

commit

GravaSolicitacao.Call(&EmpCod, &FilCod, &CteCod, 0, TipoSolicitacao.Cancelar_CTE, &PesCod, &SolCod)

//CANCELA ARQUIVOS RETORNOS
&Nome_retorno_erro = &sdtConfiguracoesPasta.PastaNFretorno.Trim()+ trim(&CteChv)+'-env-canc.err'    
&File.Source = &Nome_retorno_erro
If &File.Exists()
    &File.Delete()
EndIf

&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim()+ trim(&CteChv)+'-env-canc.xml'
&File.source = &Nome_retorno_correto
IF &File.Exists()
    &File.Delete()
EndIf

//GRAVA ARQUIVO CANCELAMENTO .XML
&ano = str(YEAR(&hoje))
&mes = str(MONTH(&hoje))
&dia = str(DAY(&hoje))
&hojeHora = servernow()
&hora = PadL(trim(str(Hour(&hojeHora))),2, '0') + ':' + PadL(trim(str(Minute(&hojeHora))),2, '0') + ':00'

&id = 'ID110111' + &CteChv + '01' //“ID” + tpEvento + chave da NF-e + nSeqEvento

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() + trim(&CteChv) + '-env-canc.xml'

&ArqNota.Open(&Nome_enviar) //ABRE DOC xml
&ArqNota.WriteStartDocument('UTF-8') //START DOC xml

&ArqNota.WriteStartElement('eventoCTe')
&ArqNota.WriteAttribute('versao',&VersaoNF) //Versão do leiaute
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/cte')

&ArqNota.WriteStartElement('infEvento') //Grupo de informações do registro do Evento
&ArqNota.WriteAttribute('Id', &ID) //Identificador da TAG a ser assinada, a regra de formação do Id é: “ID” + tpEvento + chave da NF-e + nSeqEvento
&ArqNota.WriteElement('cOrgao', &cUF) //Código do órgão de recepção do Evento. Utilizar a Tabela do IBGE, utilizar 91 para identificar o Ambiente Nacional.
&ArqNota.WriteElement('tpAmb',&sdtConfiguracoesPasta.FilAmbEms) //Identificação do Ambiente: 1=Produção /2=Homologação

&FilCpj = RetornaSoNumeros.Udp(&FilCpj)
If &FilCpj.Trim().Length() > 11
	&ArqNota.WriteElement('CNPJ', &FilCpj) //Informar o CNPJ ou o CPF do autor do Evento
Else
	&ArqNota.WriteElement('CPF', &FilCpj)
EndIf


&ArqNota.WriteElement('chCTe', &CteChv) //Chave de Acesso da NF-e vinculada ao Evento   

&ArqNota.WriteElement('dhEvento',trim(&ano) +'-'+ PadL(trim(&mes),2,'0') +'-'+ PadL(trim(&dia),2,'0') + 'T' +&hora+'-'+&FilFusHor ) //Data e hora do evento no formato AAAA-MM-DDThh:mm:ssTZD 
&ArqNota.WriteElement('tpEvento', '110111') //Código do evento = 110111
&ArqNota.WriteElement('nSeqEvento','1') //Sequencial do evento para o mesmo tipo de evento. Para maioria

&ArqNota.WriteStartElement('detEvento')
&ArqNota.WriteAttribute('versaoEvento', &VersaoNF) 
&ArqNota.WriteStartElement('evCancCTe')
&ArqNota.WriteElement('descEvento', 'Cancelamento') //Cancelamento
&ArqNota.WriteElement('nProt', &CteAutNumPro)
&ArqNota.WriteElement('xJust', &xJust.Trim())
&ArqNota.WriteEndElement()//evCancCTe
&ArqNota.WriteEndElement()//detEvento
&ArqNota.WriteEndElement()
&ArqNota.Close()
]]></Source>
