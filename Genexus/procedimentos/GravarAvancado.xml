      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For each Order EmpCod,FilCod,CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	
	&CteVlrTotPreSer = CteVlrTotPreSer
	
	if CteModCod = '57'
		CteModRodRNTRC = &sdtCte.CteModRodRNTRC
		CteVlrAva.FromString(&sdtCte.CteVlrAvaVar)
		CteVlrAce.FromString(&sdtCte.CteVlrAceVar)
		CteVlrCon.FromString(&sdtCte.CteVlrConVar)
		CteAveRam = &sdtCte.CteAveRam
		CteAveCodLim = &sdtCte.CteAveCodLim
		CteCiotNro = &sdtCte.CteCiotNro
		CteDocTra = &sdtCte.CteDocTra
		CteNroCon = &sdtCte.CteNroCon
	Else
		if CteIniUfe = CteTerUfe
			CteModRodNroRegEst = &sdtCte.CteModRodRNTRC
		Else
			CteModRodTaf = &sdtCte.CteModRodRNTRC
		Endif
		
		&Segcod = &sdtCte.CteSegRef
		do 'getSeguradora'
	
		//############################################ SEGURO	
		For each Order EmpCod,FilCod,CteCod,CteSegCod
			Where CteSegCod = &sdtCte.CteSegCod
			
			CteSegRef = &sdtCte.CteSegRef
			CteSegNom = &CteSegNom
			CteSegApl = &sdtCte.CteSegApl
			CteSeqVlrCar = &CteVlrTotPreSer
			Exit
		When none
			For each Order EmpCod,FilCod,CteCod,CteSegCod
				Delete
			EndFor
		
			New
				EmpCod = &EmpCod
				FilCod = &FilCod
				CteCod = &CteCod
				CteSegCod = &sdtCte.CteSegCod
				CteSegRef = &sdtCte.CteSegRef
				CteSegNom = &CteSegNom
				CteSegApl = &sdtCte.CteSegApl
				CteSeqVlrCar = &CteVlrTotPreSer
			EndNew
		EndFor
	EndIf

	CteCpfMot = &sdtCte.CteCpfMot
	CteNomMot = &sdtCte.CteNomMot
	
	CteObsGer = &sdtCte.CteObsGer
	
	CtePlc = &sdtCte.CtePla
	CtePlcTra = &sdtCte.CtePlaTra
	
	Exit
EndFor

commit


sub 'getSeguradora'
	For Each Order EmpCod, SegCod
		Where EmpCod = &EmpCod
		Where SegCod = &Segcod
		
		&CteSegNom = SegNom
		Exit
	EndFor
EndSub
]]></Source>
