      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, AppCod
	Where EmpCod = &EmpCod
	Where AppCod = TipoAplicativo.MESAS
	
	Do Case 
		CAse &domConfSistemaMESAS = domConfSistemaMESAS.AppCon007
			&OutValor = AppCon007.ToString()
		CAse &domConfSistemaMESAS = domConfSistemaMESAS.AppCon008
			&OutValor = trim(str(AppCon008))
	EndCAse
	Exit
When none
	new
		EmpCod = &EmpCod
		AppCod = TipoAplicativo.MESAS
	EndNew

	Commit
EndFor
]]></Source>
