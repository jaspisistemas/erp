      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	&Pagina = &parpagina
	&QtdRegistros = &parQtdRegistros
	
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwGridGenericoPequeno.sts = 'J200'
	&wwGridGenericoPequeno.pA = '0'
	&wwGridGenericoPequeno.pT = '0'
	&wwGridGenericoPequeno.p1 = '0'
	&wwGridGenericoPequeno.p2 = '0'
	&wwGridGenericoPequeno.p3 = '0'
	&wwGridGenericoPequeno.p4 = '0'
	&wwGridGenericoPequeno.p5 = '0'
	&IsPaginaOk = false
	
//	if not (&VarCatSts.IsEmpty() or &VarCatSts = 'T')
//		&CatSts.FromString(&VarCatSts)
//	Endif
	&SoNumerosVarchar = RetornaSoNumeros.Udp(&CtaBanNom)
	&FiltroCtaBanCod.FromString(&SoNumerosVarchar)
	
	For Each //Order EmpCod, ctabanCod
		Where EmpCod = &wwpContext.EmpCod
		Where CtabanCod = &CtabanCod when not &CtabanCod.IsEmpty()
//		Where CatSts = &CatSts when not (&VarCatSts.IsEmpty() or &VarCatSts = 'T')
		Where CtaBanNom like &CtaBanNom or (CtabanCod = &FiltroCtaBanCod) when not &CtaBanNom.IsEmpty()
		
		&IsAutorizado = false
		Do CAse
			Case &ExigeAcesso = 'N' or &ExigeAcesso.IsEmpty() or &wwpContext.TipoPerfil = 3 //administrador
				&IsAutorizado = true
			CAse &ExigeAcesso <> 'N' //exige acesso
				For Each Order EmpCod, CtabanCod, CtaFunCod
					where CtaFunCod = &wwpContext.PesCod 
					
					if CtaFunIsRec = Status_SimNao.Sim and &ExigeAcesso = 'R' //RECEBER
						&IsAutorizado = true
					Endif
					
					if CtaFunIsPag = Status_SimNao.Sim and &ExigeAcesso = 'P' //RECEBER
						&IsAutorizado = true
					Endif
					if CtaFunIsCx = Status_SimNao.Sim and &ExigeAcesso = 'C' //RECEBER
						&IsAutorizado = true
					Endif
					
					Exit			
				Endfor
		EndCase
	
	
		if &IsAutorizado = true
			if &IsPaginaOk = false
				if &IsTestaPagina = true
					if &QtdPaginas = &Pagina
						
						&IsPaginaOk = true
					Else
						&wwGridGenericoPequeno.Item.Clear()
						&IsTestaPagina = false
					Endif
				Endif
				
				if &IsPaginaOk = false
					
					&wwGridGenericoPequenoItem = New()
					&wwGridGenericoPequenoItem.Cod = CtabanCod
					&wwGridGenericoPequenoItem.Nom = CtaBanNom.Trim()
					
					&wwGridGenericoPequeno.Item.Add(&wwGridGenericoPequenoItem)
				Endif		
			Endif
			
			&QtdLInhasPagina += 1
			if (&QtdLinhasPagina = &QtdRegistros)
				&QtdPaginas += 1
				&IsTestaPagina = true
				&QtdLInhasPagina = 0
			Endif
		Endif
	When none
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwGridGenericoPequeno.pA = trim(str(&Pagina))
		&wwGridGenericoPequeno.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwGridGenericoPequeno.p1, &wwGridGenericoPequeno.p2, &wwGridGenericoPequeno.p3, &wwGridGenericoPequeno.p4, &wwGridGenericoPequeno.p5)
		
	Endif

Endif

]]></Source>
