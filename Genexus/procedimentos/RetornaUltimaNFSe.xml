      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, (NfsCod)
	Where EmpCod = &EmpCod
	Where NfsCod < &NfsCod
	Where NfsSts = Status_Nfe.Autorizada
	Where NfsCliCod = &NfsCliCod
	
	&OrigemNfsCod = NfsCod
	
	Exit
EndFor
]]></Source>
