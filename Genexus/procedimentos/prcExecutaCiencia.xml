      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where FilAmbEms = TAmb.Producao
	Where FilVctCer > serverdate() or FilVctCer.IsEmpty()
	
	&IsPodeExecutar = true
	Exit
EndFor

if &IsPodeExecutar = true
	&verManDta = serverdate()
	&verManDta = &verManDta.AddDays(-10)
	
	For Each Order EmpCod, ManCod
		Where EmpCod = &EmpCod
		Where ManFilCod  = &FilCod
		Where ManDta > &verManDta
		Where ManEveSol = 0 or ManEveSol.IsNull()
		Where ManSitNFe <> Situacao_Nfe.CANCELADA and ManSitNFe <> Situacao_Nfe.DENEGADA
		
		RetornaExisteSolicitacaoPendente.call(EmpCod, ManFilCod, ManCod, 0, TipoSolicitacao.Manifestar_DFe, &IsPendente, &AuxSoLCod)
		if &IsPendente <> true
			GeraXmlManifestacao.Call(EmpCod, ManFilCod,'S', ManCha, ManNsu, 210210, '', ManCod, &AuxSoLCod)
			&IsCiencia = true
		Endif
		
	EndFor
Endif

]]></Source>
