        <Source><![CDATA[

&ProgressLogXml = ''
&Percentual = 0
&ProgressIni = serverNow()
&PerCount = 0
&PercentualTotal = 100

do 'Atualiza'

For Each Order IpPro 
	where IpPro = &ProgressId
	
	For Each Order IpPro, IpProItm
		delete
	EndFor
When none
	new
		IpPro = &ProgressId
		IpDtaHor = serverdate()
	EndNew
EndFor

Commit
	
&Linha = &sdtCamposImportacao.PrimeiraLinha
&Excel.Open(&selectedURL)
If &Excel.ErrCode <> 0
	msg(&Excel.ErrDescription)
Else
	Do While &Fim < 10
		
		Do 'LimpaCampos'
		
		&ProRef    = iif(&sdtCamposImportacao.ColProCod > 0, trim(&Excel.Cells(&Linha,&sdtCamposImportacao.ColProCod).Text), '') // Código do Produto
		&ProNom = iif(&sdtCamposImportacao.ColDescricao > 0,trim(Substr(trim(&Excel.Cells(&Linha,&sdtCamposImportacao.ColDescricao).text), 1, 100)),'') // NOME do produto no fornecedor		
		
		&ProVlrCus  = iif(&sdtCamposImportacao.ColvlrCus > 0, &Excel.Cells(&Linha,&sdtCamposImportacao.ColvlrCus).Number, 0)
		&TabPrc1    = iif(&sdtCamposImportacao.ColValorVenda > 0, &Excel.Cells(&Linha,&sdtCamposImportacao.ColValorVenda).Number, 0)
		
		If &sdtCamposImportacao.ColNCM > 0
			&Varchar = &Excel.Cells(&Linha,&sdtCamposImportacao.ColNCM).Text
			retornaSoNumeros.Call(&Varchar, &Varchar)
			&NcmCod = val(&Varchar)
		else
			&NcmCod = 0
		EndIf
	
		If &sdtCamposImportacao.ColCEST > 0
			&Varchar =  &Excel.Cells(&Linha,&sdtCamposImportacao.ColCEST).Text
			retornaSoNumeros.Call(&Varchar, &Varchar)
			&ProNcmCest =  val(&Varchar)
		Else
			&ProNcmCest = 0
		EndIf
	
		if &sdtCamposImportacao.ColCatCod > 0
			&CatCod = &Excel.Cells(&Linha,&sdtCamposImportacao.ColCatCod).Number
		EndIf

		if &sdtCamposImportacao.ColEmbalagem > 0
			&EmbCod =  &Excel.Cells(&Linha,&sdtCamposImportacao.ColEmbalagem).Number
		Endif
		
		if &sdtCamposImportacao.ColGRUPO > 0
			&Grupcod = &Excel.Cells(&Linha,&sdtCamposImportacao.ColGRUPO).Number
		Endif
		
		if &sdtCamposImportacao.ColMarca > 0
			&MarCod =  &Excel.Cells(&Linha,&sdtCamposImportacao.ColMarca).Number
		EndIf
		
		if &sdtCamposImportacao.ColGTIN > 0
			&ProBar =   trim(&Excel.Cells(&Linha,&sdtCamposImportacao.ColGTIN).Text)
		Endif
	
		if &sdtCamposImportacao.ColEstoque > 0
			&EstQtd =   &Excel.Cells(&Linha,&sdtCamposImportacao.ColEstoque).Number
		Endif
	
		if &sdtCamposImportacao.Collocacao > 0
			&EstLoc =   &Excel.Cells(&Linha,&sdtCamposImportacao.Collocacao).Text
		Endif
	
		if &sdtCamposImportacao.CollocacaoExt > 0
			&EstLocExt =   &Excel.Cells(&Linha,&sdtCamposImportacao.CollocacaoExt).Text
		Endif
	
		If &sdtCamposImportacao.ColMarcaNome > 0 
			&MarNom = Trim(&Excel.Cells(&Linha,&sdtCamposImportacao.ColMarcaNome).Text)
			Do 'ProcuraMarca'
		Endif
		
		If &ProRef.IsEmpty() and &ProNom.IsEmpty()
			&Fim += 1
		Else			
			Do 'GetProduto'
			Do CASE//1 todos ,3  somente nao cadatrados, 2 somente ja cadastrados
				Case &IsAchou = false and &sdtCamposImportacao.Mostrar = 2 // somente os não cadastrados
					Do 'GravaSdt'
				Case &IsAchou = true and &sdtCamposImportacao.Mostrar = 3 //somente os cadastrados
					Do 'GravaSdt'
				Otherwise
					Do 'GravaSdt'
			EndCase
		
			
			&Fim = 0
		EndIf
		&Linha += 1
		
		&AuxCount += 1
		if &AuxCount > 500
			&PerCount += 1
			Do 'Percentual'
			&AuxCount = 0
		Endif
	EndDo

EndIf

&Percentual = 100
&ProgressFin = serverNow()
//&ProgressLogXml = &sdtProdutosXls.ToJson()
do 'Atualiza'
	
	
//&WebSession.Set('LISTWWIMPORTAXLS', &sdtProdutosXls.ToJson())

sub 'GravaSdt'
	
	
	&IpProItm += 1
	new
		IpPro = &ProgressId
		IpProItm = &IpProItm		
		IpEmpCod     = &EmpCod
		IpProCod     = &ProCod
		IpProRef     = &ProRef
		IpProNom     = &ProNom
		IpProVlrCus  = &ProVlrCus
		IpTabPrc1    = &TabPrc1
		IpNcmCod     = &NcmCod
		IpProNcmCest = &ProNcmCest
		IpCatCod     = &CatCod
		IpEmbCod     = &EmbCod
		IpGrupCod    = &Grupcod
		IpMarCod     = &MarCod
		IpMensagem   = &Mensagem
		IpIsAchou    = &IsAchou
		IpProBar 	 = &ProBar
		IpProEstQtd  = &EstQtd
		IpProEstLoc = &EstLoc
		IpProEstLocExt = &EstLocExt
	EndNEw

	commit

//	&sdtProdutosXlsItem = new()		
//	&sdtProdutosXlsItem.EmpCod     = &EmpCod
//	&sdtProdutosXlsItem.ProCod     = &ProCod
//	&sdtProdutosXlsItem.ProRef     = &ProRef
//	&sdtProdutosXlsItem.ProNom     = &ProNom
//	&sdtProdutosXlsItem.ProVlrCus  = &ProVlrCus
//	&sdtProdutosXlsItem.TabPrc1    = &TabPrc1
//	&sdtProdutosXlsItem.NcmCod     = &NcmCod
//	&sdtProdutosXlsItem.ProNcmCest = &ProNcmCest
//	&sdtProdutosXlsItem.CatCod     = &CatCod
//	&sdtProdutosXlsItem.EmbCod     = &EmbCod
//	&sdtProdutosXlsItem.GrupCod    = &Grupcod
//	&sdtProdutosXlsItem.MarCod     = &MarCod
//	&sdtProdutosXlsItem.Mensagem   = &Mensagem
//	&sdtProdutosXlsItem.IsAchou    = &IsAchou
//	&sdtProdutosXls.Add(&sdtProdutosXlsItem)
EndSub


sub 'Percentual'
	&PerCount += 1
	If &PerCount > 0
		&Percentual = round((&PerCount / &PercentualTotal) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
EndSub


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &ProgressLogXml 
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &ProgressLogXml 
		Endnew
	endfor

	commit
EndSub

Sub 'LimpaCampos'
	&Mensagem = ''
	&IsErro = 'N'	
	&ProCod = 0
	&ProRef.SetEmpty()
	&ProNom.SetEmpty()	
	&ProVlrCus.SetEmpty()	
	&TabPrc1.SetEmpty()	
	&NcmCod.SetEmpty()	
	&ProNcmCest.SetEmpty()	
	&CatCod.SetEmpty()	
	&EmbCod.SetEmpty()	
	&Grupcod.SetEmpty()
	&MarCod.SetEmpty()	
	&ProBar.SetEmpty()
	&EstQtd.SetEmpty()
	&EstLoc.SetEmpty()
	&EstLocExt.SetEmpty()
EndSub

Sub 'GetProduto'
	&IsAchou = false
	If not &ProRef.IsEmpty()
	    For Each Order EmpCod, ProRef, ProCod
			Where EmpCod = &EmpCod
		    Where ProRef = &ProRef when &ProBar.IsEmpty()
			Where ProBar = &ProBar when not &ProBar.IsEmpty()
			
			&IsAchou = true
			&ProCod = ProCod
			If &ProNom.Trim().IsEmpty()
				&ProNom = ProNom
			else
				//se nao pega o que esta na planilha
			EndIF
			Exit
		EndFor
	EndIf
EndSub

Sub 'ProcuraMarca'
	For Each Order EmpCod, MarNom
		Where EmpCod = &EmpCod
		Where MarNom = &MarNom
		&MarCod = MarCod
		Exit
	When none
		
		UltimoCodigoEmpresa.Call(domParCod.MARCA, &EmpCod,  0, &auxMarCod)
		
		New
			EmpCod = &EmpCod
			MarCod = &auxMarCod
			MarNom = trim(&MarNom)
			MarCodNom = trim(str(&auxMarCod)) + ' - ' + trim(&MarNom)
			MarDtaHorUltMod = now()
		EndNew
		commit
		&MarCod = &auxMarCod
	EndFor
EndSub

