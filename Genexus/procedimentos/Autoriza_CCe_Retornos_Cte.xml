      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&conteudo_arquivo = ''

//For Each Order EmpCod, FilCod, CteCod, CteCCeSts, (CteCCeCod) //SICNFS3
//	Where EmpCod = &EmpCod
//	Where FilCod = &FilCod
//	Where CteCod = &CteCod
//	Where CteCCeSts = Status_NFe.Autorizada
//    &CteCCeCod = CteCCeCod
//	Exit
//EndFor
//
//&CteCCeCod += 1

For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	&CteChv = CteChv
	&PastaDanfeNota = str(year(CteDtaEms),4,0)+padl(trim(str(month(CteDtaEms),2,0)),2,'0')
		
	For Each Order EmpCod, FilCod, CteCod, CteCCeCod
		Where CteCCeCod = &CteCCeCod
		&PastaDanfeCCe = str(year(CteCCeDta),4,0)+padl(trim(str(month(CteCCeDta),2,0)),2,'0')	
		Exit
	EndFor
	Exit
EndFor

&nomeArquivo = &CteChv.Trim() + '-' + padL(trim(str(&CteCCeCod)),2,'0') 

&Nome_retorno_erro    = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&nomeArquivo)+'-eve.err'
&Nome_retorno_correto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() + trim(&nomeArquivo) + '-eve.xml'
//41240332779890000178570010000005361000005366-01-eve.xml
//41240332779890000178570010000005361000005366_110110_001-procEventoCTe.xml
&File.Source = &Nome_retorno_erro
if &File.Exists() 
	&ResultadoAbertura =   DFROpen(&Nome_retorno_erro)    
	
	Do while dfrnext() = 0 
		&ResultadoAbertura = DFRGTxt(&CampoUnico)
		&conteudo_arquivo += NewLine() + &CampoUnico.Trim()
	EndDo
	&ResultadoAbertura = DFRClose()
	
	&File.Delete()
	
	&Tentativa = 99
	&SolSts = Status_Solicitacao.Falha
	&SolMsg = &conteudo_arquivo
else
	&File.Source = &Nome_retorno_correto
	if &File.Exists()
		
		&retorno_xml.Open(&Nome_retorno_correto)    
		&retorno_xml.ReadType(1, 'infEvento')
		&retorno_xml.Read()  
		Do While (&retorno_xml.Name <> 'infEvento' and &retorno_xml.Name <> '')
			Do Case
				Case &retorno_xml.Name = 'cStat'
					&CteCCecStat = &retorno_xml.Value
				Case &retorno_xml.Name = 'dhRegEvento'
					&CteAutDatHorRec = &retorno_xml.Value
				Case &retorno_xml.Name = 'xMotivo'
					&CteCCexMotivo  = &retorno_xml.Value
				Case &retorno_xml.Name = 'nProt'
					&CteCCeProt  = &retorno_xml.Value
			EndCase
			&retorno_xml.Read()           
		EndDo
		&retorno_xml.close()


	If &CteCCecStat <> '' or &CteCCexMotivo <> ''
			Do Case
				Case &CteCCecStat = '573' //Duplicidade de Cte //carta autorizada mas sem o retorno da sefaz
					&Mensagem = trim(&CteCCecStat) + ' - ' + trim(&CteCCexMotivo)
					&Mensagem += NewLine() +'ATENÇÃO: Não foi obtido o retorno da Cte, problema com a comunicação à Sefaz ou fechamento inesperado da Comunicação.'
					&Mensagem += NewLine() + 'O QUE FAZER: Emita outra carta de correção.'
					&Mensagem += NEwLIne() + 'Se o Problema persistir contacte o suporte.'
					GravaRetornoCCeCte.Call(&EmpCod, &FilCod, &CteCod, &CteCceCod, &CteCCecStat, &CteCCexMotivo, &CteCCeProt)
					&SolSts = Status_Solicitacao.Falha
					
				Case &CteCcecStat in ('135', '136', '631') //631 duplicidade
					//&NfeAutSts = '101'
					If &CteCCecStat = '631' and &CteCCeProt.Trim().IsEmpty()
						&i = StrSearch(&CteCCexMotivo,'nProt:',1)//Duplicidade de evento. [nProt:141240000000792][dhRegEvento:2024-01-09T14:50:31-03:00]
						&i+=6
						&CteCCeProt  = substr(&CteCCexMotivo,&i,15)
						
					EndIf
				
					&mensagem = &CteCCecStat.Trim() + ' - ' + &CteCCexMotivo.Trim()
					
					GravaRetornoCCeCte.Call(&EmpCod, &FilCod, &CteCod, &CteCceCod, &CteCCecStat, &CteCCexMotivo, &CteCCeProt)					
					
					&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFenviado.Trim() +'/Autorizados/' + trim(&PastaDanfeCCe) +'/'+&CteChv.Trim() + '_110110_' + padL(str(&CteCCeCod),3,'0') + '-procEventoCTe.xml'
		            &file.Source = &ArquivoPronto
		            if &file.Exists()
		                GravaArquivoXmlCCeCte.Call(&EmpCod, &FilCod, &CteCod, &CteCCeCod, &ArquivoPronto)
						&SolSts = Status_Solicitacao.Finalizada
//					Else
//						&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFenviado.Trim() +'/Autorizados/' + trim(&PastaDanfeNota) +'/'+&CteChv.Trim() + '_110110_' + padL(str(&CteCCeCod),3,'0') + '-procEventoCTe.xml'
//		            	&file.Source = &ArquivoPronto
//						if &file.Exists()
//							GravaArquivoXmlCCeCte.Call(&EmpCod, &FilCod, &CteCod, &CteCCeCod, &ArquivoPronto)
//							&SolSts = Status_Solicitacao.Finalizada
//						EndIF
		            EndIf
					
				Case &CteCCecStat in ('579', '577', '578')
					&mensagem = 'Falha na Comunicação, Fuso horário informado diverge dos servidores sefaz.'
					&SolSts = Status_Solicitacao.Falha
					
				Otherwise
					&mensagem = &CteCCecStat.Trim() + ' - ' + trim(&CteCCexMotivo)
					&SolSts = Status_Solicitacao.Falha
			EndCase

			&Tentativa = 99
			&SolMsg = &mensagem
		EndIF
	EndIf
EndIf
]]></Source>
