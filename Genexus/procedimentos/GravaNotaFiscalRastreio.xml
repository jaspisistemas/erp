      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If  not &NfeProMedAnv.Trim().IsEmpty()
	Do 'AtualizaMedicamentos'
EndIf
 

if &sdtProdutoLote.Count > 0
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod, NfeProLotCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeItmCod = &NfeItmCod
		delete
		
	EndFor

	Commit

	For &sdtProdutoLoteItem in &sdtProdutoLote
		NEw
			EmpCod = &EmpCod
			FilCod = &FilCod
			NfeCod = &NfeCod
			NfeItmCod = &NfeItmCod
			if &sdtProdutoLoteItem.PedProEstLotCod.IsEmpty()
				NfeProLotCod = '#SEM_LOTE'
			Else
				NfeProLotCod = &sdtProdutoLoteItem.PedProEstLotCod
			Endif			
			
			NfeProLotFab = &sdtProdutoLoteItem.PedProEstLotFab
			NfeProLotVct = &sdtProdutoLoteItem.PedProEstLotVct
			
			if (not &sdtProdutoLoteItem.PedProEstLotFab.IsEmpty() and not &sdtProdutoLoteItem.PedProEstLotVct.IsEmpty()) and &sdtProdutoLoteItem.PedProEstLotFab > &sdtProdutoLoteItem.PedProEstLotVct
				NfeProLotVct = &sdtProdutoLoteItem.PedProEstLotFab
				NfeProLotFab = &sdtProdutoLoteItem.PedProEstLotVct
				
			Endif	
			
			NfeProLotQtd = &sdtProdutoLoteItem.PedProEstLotQtd
			NfeProLotGer = &sdtProdutoLoteItem.PedProEstLotGer
			NfeProLotPen = &sdtProdutoLoteItem.PedProEstLotPen
			NfeProLotRen = &sdtProdutoLoteItem.PedProEstLotRen
			NfeProLotPms = &sdtProdutoLoteItem.PedProEstLotPms
			NfeProLotPur = &sdtProdutoLoteItem.PedProEstLotPur
			
		EndNew
	EndFor

	Commit
Endif


Sub 'AtualizaMedicamentos'
	For Each Order EmpCod, FilCod, NfeCod, NfeItmCod, NfeProLotCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		Where NfeItmCod = &NfeItmCod
		NfeProMedAnv = &NfeProMedAnv
		NfeProMedMot = &NfeProMedMot
		NfeProMedVlrMax =&NfeProMedVlrMax
		
		Exit		
	EndFor
EndSub


]]></Source>
