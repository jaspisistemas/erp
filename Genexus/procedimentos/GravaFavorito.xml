      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&mensagem = ''

If Not &FavRotAutCod in ('', 'MeusFavoritos')
	For Each Order EmpCod, PesCod, FavRotAutCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		Where FavRotAutCod = &FavRotAutCod
		Where FavWebSmart = 'W' or FavWebSmart.IsNull() or FavWebSmart.IsEmpty()
		if &OqueFazer = 'ADD'
			FavRotAutNom = &FavRotAutNom
			
			if not &FavOrd.IsEmpty()
				FavOrd = &FavOrd
			Endif
		
		Else
			delete
		Endif
	
		Exit
	When none
		For Each Order EmpCod, RotAutCod, RotCod
			Where EmpCod = &EmpCod
			Where RotAutCod = &FavRotAutCod or RotLin = &FavRotAutCod.Trim() + '.aspx'
			where not RotLin.IsEmpty()
			
			if RotNomFav.IsEmpty() or RotNomFav.IsNull()
				&RotNom = RotNom
			Else
				&RotNom = RotNomFav
			EndIF
		
			Exit
		EndFor
		
		If &RotNom <> ''
			new 
				EmpCod = &EmpCod
				PesCod = &PesCod
				FavRotAutCod = &FavRotAutCod
				
				if &FavRotAutNom.IsEmpty()
					FavRotAutNom = Substr(&RotNom, 1, 40)
				Else
					FavRotAutNom = &FavRotAutNom
				EndIf
			
				if &FavOrd.IsEmpty()
					FavOrd = 1
				Else
					FavOrd = &FavOrd
				Endif
			
				FavWebSmart = 'W'
			EndNew
		Else
			&mensagem = 'Página não Disponível para Favorito!'
		EndIF
	EndFor
	
	commit
	
	//novoLateral.Call(&EmpCod, &PesCod)
	//CarregaSdtFavorito.Call(&EmpCod, &PesCod)
EndIF
]]></Source>
