        <Source><![CDATA[
//ANALISAR ICMS DESONERADO

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	PedVlrGnre = &PedVlrGnre
	PedVlrIpi = &PedVlrIpi
	
	Exit
EndFor


commit

atualizaTotaisPedido.Call(&EmpCod, &FilCod, &PedCod, 0, '')
]]></Source>
