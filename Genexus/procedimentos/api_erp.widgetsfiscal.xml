      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)


if &IsAcessoConcedido = true //Acesso conced
	
	&auxFilCod = &parFilCod
	if &auxFilCod < 0
		&auxFilCod = 0
	Endif	
	
	
	if &wwpContext.TipoPerfil <> 3 //verifica se eu posso ver vendas de todos os vendedores
		CarregaSdtPerfil_api.Call(&wwpContext.EmpCod, &wwpContext.PesCod, &AutGrpCod, &AutGrpNom)
		
		retornaautorizacaoApi.Call('WD_FATURAMENTOFISCAL', &wwpContext, &parAutGrpCod, &WD_FATURAMENTOFISCALAutNiv)	
		retornaautorizacaoApi.Call('WD_FATURAMENTOFISCALCTE', &wwpContext, &parAutGrpCod, &WD_FATURAMENTOFISCALCTEAutNiv)
	Else
		&WD_FATURAMENTOFISCALAutNiv = 4
		&WD_FATURAMENTOFISCALCTEAutNiv = 4
	Endif
	
	if &auxFilCod <= 0
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAceNiv > 0
				&collFilCod.add(PesFilAce)
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif
	Else
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAce = &auxFilCod
				Where PesFilAceNiv > 0
				&collFilCod.add(PesFilAce)			
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &auxFilCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif	
	EndIf
	
	if &collFilCod.Count = 0
		&sdtRetornoWbsEtc.sts = 'E998'	
		&sdtRetornoWbsEtc.obs = 'Não autorizado a acessar dados fiscais nessa Filial!'
	Else
		
		
		prcFaturamentoFiscal.Call(&wwpContext.EmpCod, &collFilCod, &Mes, &Ano, &WD_FATURAMENTOFISCALAutNiv, &WD_FATURAMENTOFISCALCTEAutNiv, &sdtRetornoWbsEtc)
		
		&sdtRetornoWbsEtc.sts = 'J200'
	Endif
	
	if &collFilCod.Count = 1
		For &FilCod in &collFilCod
			&sdtRetornoWbsEtc.c7 = trim(toformattedString(&FilCod))
		Endfor
	Else
		&sdtRetornoWbsEtc.c7 = '0'
	Endif
	
	
	//	&sdtRetornoWbsEtc.c7 = &inicioPedDtaFat.ToFormattedString()
	//	&sdtRetornoWbsEtc.c8 = &finalPedDtaFat.ToFormattedString()
	
Endif

]]></Source>
