        <Source><![CDATA[if &EmpCod.IsEmpty()
	msg('Informe o código da empresa', status)
else
	For Each order EmpCod,AgdSts,AgdUltDta,AgdCod
		where EmpCod = &EmpCod
		Where AgdSts = Status_Tarefa.TarefaAtiva
		where AgdTip = TipoAgendamento.WhatsBoleto
		prcFilaEnvioWhats_AddBoletoProximoVencimento(EmpCod, AgdFiltro)
		exit
	EndFor
endif
]]></Source>
