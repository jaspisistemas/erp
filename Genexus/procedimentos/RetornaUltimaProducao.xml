      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


&ProducaoMensagem.SetEmpty()
For Each Order EmpCod, FilCod, (OrdDtaFinPrd)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OrdSetCod = &SetCod
	
	&ProducaoMensagem = 'INI: ' + trim(toformattedString(OrdDtaPrd))  + ' HOR:' + trim(OrdHorPrd)
	
	&ProducaoMensagem += ' / FIN: ' + trim(toformattedString(OrdDtaFinPrd))  + ' HOR:' + trim(OrdHorFinPrd)	
	Exit
EndFor
]]></Source>
