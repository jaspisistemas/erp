      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do While &UniProIni <= &UniProFim 
	
	New
		EmpCod = &EmpCod
		UniProCod = UltimoCodigoEmpresa.udp(domParCod.UNIDADEPRODUTORA,&EmpCod,0)
		UniProNom = &UniProIni
		UniProMed = &UniProMed
		UniProQtd = &UniProQtd
		UniProTip = &UniProTip	
		UniProSts = StatusUnidadeProdutora.Disponivel
	EndNew
	&UniProIni +=1 
	Commit
Enddo

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
