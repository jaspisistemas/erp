      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[



For Each Order InvEmpCod, InvFilCod, InvAno, InvMes, InvProCod, InvProGraCod
	Where InvEmpCod = &InvEmpCOd
	Where InvFilCod = &InvFilCod
	Where InvAno = &InvAno
	Where InvMes = &InvMes
	Where InvProCod = &ProCod
	Where InvProGraCod = &ProGraCod
	
	InvProQtd = &InvProQtd
	InvProQtdAtu = &InvProQtdAtu
	InvProVlrCus = &InvProVlrCus
	
	Exit
when none
	New
		InvEmpCod = &InvEmpCOd
		InvFilCod = &InvFilCod
		InvAno = &InvAno
		InvMes = &InvMes
		InvProCod = &ProCod
		InvProGraCod = &ProGraCod
		InvProQtd = &InvProQtd
		InvProQtdAtu = &InvProQtdAtu
		InvProVlrCus = &InvProVlrCus
	EndNEw

EndFor

Commit
]]></Source>
