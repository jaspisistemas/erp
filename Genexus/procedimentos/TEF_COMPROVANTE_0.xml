//&ObservacaoLimiteCredito = &sdtRELJAS_XXX_Nfe.imgCodBarras
//&XmlWriter.Open('teste0.xml')
//&XmlWriter.WriteRawText(&XmlIMprimir)
//&XmlWriter.Close()

//&XmlWriter.Open('teste1.xml')
//&XmlWriter.WriteRawText(&sdtComprovante.ToXml())
//&XmlWriter.Close()

&XmlIMprimirLongVarchar = &XmlIMprimir.Replace('metadata:{},', '')
&sdtComprovante.FromJson(&XmlIMprimirLongVarchar)

//&XmlWriter.Open('teste2.xml')
//&XmlWriter.WriteRawText(&sdtComprovante.ToXml())
//&XmlWriter.Close()

MT 0
MB 0

print ViaCliente

Do Case
	CAse UPPER(&sdtComprovante.payment_type) = 'CREDIT'
		&Mensagem = 'CREDITO - ' + &sdtComprovante.payment_method.card_brand
	CAse UPPER(&sdtComprovante.payment_type) = 'DEBIT'
		&Mensagem = 'DEBITO - ' + &sdtComprovante.payment_method.card_brand
	Otherwise
		&Mensagem = &sdtComprovante.payment_method.card_brand
EndCase


&Mensagem = upper(&Mensagem)
print centralizado

print traco

&UmFilRaz = &sdtComprovante.statement_descriptor
print tituloA
print cabecalho

&Mensagem = ''
print centralizado
&Mensagem = 'CV: '+&sdtComprovante.payment_authorization.authorizer_id //CV
print Autorizacao
&Mensagem = 'AUTO: '+&sdtComprovante.payment_authorization.authorization_code + ' ARQC: '+&sdtComprovante.arpc//ARQC//AUTORIZACAO
print Autorizacao

print traco

&Mensagem = &sdtComprovante.payment_method.holder_name//NOME CLIENTE
print DadosCliente

&Mensagem = '************' + &sdtComprovante.payment_method.last4_digits //NUMERO CARTAO
print DadosCliente

//Credito
//VENDA A CREDITO

 
&DataVarchar = Substr(&sdtComprovante.created_at, 9,2 ) + '/'+Substr(&sdtComprovante.created_at, 6,2 )+ '/'+ Substr(&sdtComprovante.created_at, 1,4)//DATA E HORA
&HoraVarchar = Substr(&sdtComprovante.created_at, 12,8)
&varPedVlrBrt = 'R$ ' + trim(&sdtComprovante.amount) //VALOR APROVADO
print DataValor

print Traco
&Mensagem = 'Obrigado pela preferência!'
print centralizado

&IsImprimiu = true
]]></Source>
