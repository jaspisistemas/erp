      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 15
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	&wwGridGenericoPequeno.sts = 'J200'
	&wwGridGenericoPequeno.pA = '0'
	&wwGridGenericoPequeno.pT = '0'
	&wwGridGenericoPequeno.p1 = '0'
	&wwGridGenericoPequeno.p2 = '0'
	&wwGridGenericoPequeno.p3 = '0'
	&wwGridGenericoPequeno.p4 = '0'
	&wwGridGenericoPequeno.p5 = '0'
	&IsPaginaOk = false
	
	For Each Order SolEmpCod, SolFilCod, SolNfeCod, (SolCod)
		Where SolEmpCod = &wwpContext.EmpCod
		Where SolFilCod = &SolFilCod
		Where SolNfeCod = &SolNfeCod
		Where SolTip in (TipOSolicitacao.Autorizar_CTE, TipOSolicitacao.Cancelar_CTE, TipOSolicitacao.Consultar_CTE, TipOSolicitacao.Inutilizar_CTE) when &OqueFazer = 'CTE'
		Where SolTip in (TipOSolicitacao.Autorizar_NFE, TipOSolicitacao.Cancelar_NFE, TipOSolicitacao.Consulta_SEFAZ, TipOSolicitacao.Inutilizar_NFE) when &OqueFazer = 'NOTA'
		Where SolTip in (TipOSolicitacao.Autorizar_MDFe, TipOSolicitacao.Cancelar_MDFe, TipOSolicitacao.Consultar_MDFe, TipOSolicitacao.Encerrar_MDFe) when &OqueFazer = 'MDFE'
		Where SolTip in (TipOSolicitacao.Autorizar_NFSE, TipOSolicitacao.Consulta_NFSE, TipOSolicitacao.Cancelar_NFSE) when &OqueFazer = 'NFSE'
		
		if &IsPaginaOk = false
			if &IsTestaPagina = true
				if &QtdPaginas = &Pagina
					
					&IsPaginaOk = true
				Else
					&wwGridGenericoPequeno.Item.Clear()
					&IsTestaPagina = false
				Endif
			Endif
			
			if &IsPaginaOk = false
				
				&wwGridGenericoPequenoItem = New()
				&wwGridGenericoPequenoItem.Cod = SolCod
				&wwGridGenericoPequenoItem.Nom = SolTip.EnumerationDescription()
				&wwGridGenericoPequenoItem.Ob1 = trim(toformattedString(SolDtaEms)) + '-' + SolDtaEmsHor
				&wwGridGenericoPequenoItem.Ob2 = SolMsg
				&wwGridGenericoPequenoItem.Ob3 = SolSts
				
				&wwGridGenericoPequeno.Item.Add(&wwGridGenericoPequenoItem)
			Endif		
		Endif
		
		&QtdLInhasPagina += 1
		if (&QtdLinhasPagina = &QtdRegistros)
			&QtdPaginas += 1
			&IsTestaPagina = true
			&QtdLInhasPagina = 0
		Endif
		
		
When none
		&Pagina = 0
	EndFor

	if &QtdLInhasPagina > 0 or &QtdPaginas > 0
		if &QtdLInhasPagina > 0
			&QtdPaginas += 1
			&QtdLInhasPagina = 0
		Endif
		
		if &Pagina > &QtdPaginas
			&Pagina = &QtdPaginas
		Endif
		
		&wwGridGenericoPequeno.pA = trim(str(&Pagina))
		&wwGridGenericoPequeno.pT = trim(str(&QtdPaginas))
		retornaPaginasGrid.Call(&Pagina, &QtdPaginas, &wwGridGenericoPequeno.p1, &wwGridGenericoPequeno.p2, &wwGridGenericoPequeno.p3, &wwGridGenericoPequeno.p4, &wwGridGenericoPequeno.p5)
		
	Endif
Endif
]]></Source>
