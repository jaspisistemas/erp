      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, NfsFilCod, NfsPedCod, NfsSts
	Where EmpCod = &EmpCod
	Where NfsFilCod = &FilCod
	Where NfsPedCod = &PedCod
	Where NfsSts = Status_NFe.Autorizada or (NfsSts = Status_NFe.Digitando and NfsNumLote > 0)
	Where NfsCod <> &NfsCod
	&Mensagem = 'ATENÇÃO. Esse pedido já possui uma nota Fiscal! Número: ' + trim(str(NfsNum)) + ' Filial :' + trim(str(NfsFilCod))
	Exit
EndFor
]]></Source>
