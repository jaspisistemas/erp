      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&UpperLogErpTabCod = &LogErpTabCod.ToUpper()
&UpperLogErpTabAtrCod = &LogErpTabAtrCod.ToUpper()


//Grava o Atributo
For each order LogErpTabAtrCod
	where LogErpTabAtrCod = &UpperLogErpTabAtrCod
	if not &LogErpTabAtrNom.IsEmpty()
		LogErpTabAtrNom = &LogErpTabAtrNom
	Endif
	Exit
when none
	New
		LogErpTabAtrCod = &UpperLogErpTabAtrCod
		LogErpTabAtrNom = &LogErpTabAtrNom
	EndNew
endfor

Commit

//Grava Vinculo com tabela
For each order LogErpTabCod, LogErpTabAtrCod
	where LogErpTabCod = &UpperLogErpTabCod
	where LogErpTabAtrCod = &UpperLogErpTabAtrCod
	Exit
when none
	New
		LogErpTabCod = &UpperLogErpTabCod
		LogErpTabAtrCod = &UpperLogErpTabAtrCod
	EndNew
endfor

Commit
]]></Source>
