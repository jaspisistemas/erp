      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Produto
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	new //CAPA PRODUTO
		EmpCod = EmpCod
		ProCod = &NewProCod
		//ProDet = 'PRODUTO CLONADO.' + trim(Str(&ProCod))
		ProBar = ''
		ProRef = &NewProRef
		ProRefPadL = ''
//		ProFab = ''
		ProOriCod = &NewProCod
		If &IsClonarReceitas = false
			ProVlrCus = 0
		EndIf
	
		ProDtaCad = serverdate()
		ProEstTip = TipoEstoque.ATUALIZAR_ESTOQUE
		ProEstProCod = &NewProCod

	EndNEw
EndFor

Commit

//imagens
if &IsClonarImagens = true
	For Each Order EmpCod, ProCod, ProImgCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		New
			EmpCod = EmpCod
			ProCod = &NewProCod
			ProImgCod = ProImgCod
			ProImgOriginal = ProImgOriginal
			ProImg1024 = ProImg1024
			ProImg180 = ProImg180
			ProImg325 = ProImg325
			ProImgDtaUltMod = now()
		EndNew
		
	EndFor
	Commit
EndIF

if &IsClonarReceitas = true
	For Each Order EmpCod, ProCod, RecItmCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		New
			EmpCod = EmpCod
			ProCod = &NewProCod
			RecItmCod = RecItmCod
		EndNew
		
	EndFor
	Commit
	
	For Each Order EmpCod, ProCod, PreItmCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		New
			EmpCod = EmpCod
			ProCod = &NewProCod
			PreItmCod = PreItmCod
		EndNew
	EndFor
	Commit
	
	For Each Order EmpCod, ProCod, ProForCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		
		New
			EmpCod = EmpCod
			ProCod = &NewProCod
			ProForCod = ProForCod
		EndNew
	EndFor
	Commit
EndIf

GravaGradeProduto.Call(&EmpCod, &NewProCod, &NcmCod)

//Estoque
iniciaEstoque.Call(&EmpCod, &FilCod, &NewProCod, 1)

For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &NewProCod
	&outProRef = ProRef
	Exit
EndFor
]]></Source>
