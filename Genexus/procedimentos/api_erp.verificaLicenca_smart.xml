      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&IsOkLicenca = '0'
	
if &Cryptografado.IsEmpty()
	do 'vencido'
Else
	GetVencimento.call(&EmpCod, &Cryptografado, &Jaspi, &AuxData, &EmpCodSec, &QtdDias)
	
	Do CAse
		Case &Jaspi <> 'JASPI'
			do 'vencido'
			
		Case upper(&EmpCodSec) <> upper(&CodigoACesso)
			do 'vencido'

		Case &QtdDias > 10
			do 'vencido'
			
		Case &QtdDias > 0
			&Mensagem = 'Atenção! Sistema vencido à ' +trim(str(&QtdDias)) + ' dias. Você possui pendências, verifique!'
			do 'getLicenca'
			do 'licenciado'
			
		Case &QtdDias >= -2
			do 'getLicenca'
			do 'licenciado'
			
		Otherwise
			do 'licenciado'
	EndCase
EndIF


sub 'getLicenca'
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		If EmpQtdSol <> &QtdDias and EmpLicAut = Status_SimNao.Sim
			EmpQtdSol = &QtdDias
			commit
			
			getLicenca.Call(&EmpCod, &LicencaMensagem)
		EndIF
		Exit
	EndFor
EndSub

sub 'licenciado'
	&WebSession.Set('#semsinal', 'licenciado')
	&IsOkLicenca = '1'
EndSub

Sub 'vencido'
	if &UserNick = 'SUPORTE.JASPI'
		do 'licenciado'
	Else
		//vencido
		//SistemaVencido.Link(&EmpCod)
	Endif
EndSub
]]></Source>
