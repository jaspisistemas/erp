      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &OqueFazer = 'ADD'
	For Each Order EmpCod, AnvTip
		where EmpCod = &EmpCod
		Where AnvTip = &AnvTip
		Where AnvID1 = &AnvID1
		Where AnvID2 = &AnvID2 
		
		if not &AnvDtaNas.IsEmpty()
			AnvNom = &AnvNom
			AnvTod = &AnvTod
			AnvUsuCod = &AnvUsuCod
			AnvObs = &AnvObs
			AnvDia = day(&AnvDtaNas)
			AnvMes = month(&AnvDtaNas)
			AnvDtaNas = &AnvDtaNas
			AnvTel = &AnvTel
			AnvEml = &AnvEml
			AnvDtaOrd = padL(trim(str(month(&AnvDtaNas))), 2, '0') + padL(trim(str(day(&AnvDtaNas))), 2, '0')
		else
			delete
		Endif
		
		Exit
	When none
		if not &AnvDtaNas.IsEmpty()
			For Each Order EmpCod, (AnvCod)
				where EmpCod = &EmpCod
				&AnvCod = AnvCod
				Exit
			EndFor
			&AnvCod += 1
			
			New
				EmpCod = &EmpCod
				AnvCod = &AnvCod
				AnvNom = &AnvNom
				AnvTip = &AnvTip
				AnvTod = &AnvTod
				AnvUsuCod = &AnvUsuCod
				AnvObs = &AnvObs
				AnvDia = day(&AnvDtaNas)
				AnvMes = month(&AnvDtaNas)
				AnvDtaNas = &AnvDtaNas
				AnvID1 = &AnvID1
				AnvID2 = &AnvID2
				AnvTel = &AnvTel
				AnvEml = &AnvEml
				
				AnvDtaOrd = padL(trim(str(month(&AnvDtaNas))), 2, '0') + padL(trim(str(day(&AnvDtaNas))), 2, '0')
			EndNew
		Endif
	EndFor
	
	Commit
Endif

	
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
