      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Hexa = &Hexa.Replace('#', '')
&Hexa = &Hexa.Trim()
&Hexa = UPPER(padL(&Hexa, 6, '0'))


//R
&HexaNumber = Substr(&Hexa, 1, 1)
do 'valor'
&PrimeiroValor = &numeric
&HexaNumber = Substr(&Hexa, 2, 1)
do 'valor'
&SegundoValor = &numeric
do 'Calcula'
&R = &ValorTotal

//G
&HexaNumber = Substr(&Hexa, 3, 1)
do 'valor'
&PrimeiroValor = &numeric
&HexaNumber = Substr(&Hexa, 4, 1)
do 'valor'
&SegundoValor = &numeric
do 'Calcula'
&G = &ValorTotal

//B
&HexaNumber = Substr(&Hexa, 5, 1)
do 'valor'
&PrimeiroValor = &numeric
&HexaNumber = Substr(&Hexa, 6, 1)
do 'valor'
&SegundoValor = &numeric
do 'Calcula'
&B = &ValorTotal

sub 'Calcula'
	&ValorTotal = (&PrimeiroValor * 16) + &SegundoValor

EndSub


sub 'valor'
	Do case
		Case &HexaNumber = 'A'
			&numeric = 10
		Case &HexaNumber = 'B'
			&numeric = 11
		Case &HexaNumber = 'C'
			&numeric = 12
		Case &HexaNumber = 'D'
			&numeric = 13
		Case &HexaNumber = 'E'
			&numeric = 14
		Case &HexaNumber = 'F'
			&numeric = 15
		Otherwise
			&HexaNumber = RetornaSoNumeros.Udp(&HexaNumber)
			&numeric = val(&HexaNumber)
	EndCase

EndSUb
]]></Source>
