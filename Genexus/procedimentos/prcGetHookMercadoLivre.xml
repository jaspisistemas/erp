      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsSucesso = false
if &MrkhookTop <> 'orders_v2' and &MrkhookTop <> 'questions' and &MrkhookTop <> 'items' and &MrkhookTop <> 'shipments'
	return
endif


for Each Order EmpCod, MrkCod
	where EmpCod = &EmPCod
	where MrkCod = &MrkCod
	
	prcMercadolivreRefreshToken.Call(EmpCod, MrkCod, &MrkSession, &IsSucesso)
	
	Exit
EndFor

if &IsSucesso = true
	&HttpClient.AddHeader('Content-Type', 'application/json')
	&HttpClient.AddHeader('Accept', 'application/json')
	&httpClient.AddHeader(!"Authorization", !"Bearer " + &MrkSession.Trim())
	
	&HttpClient.Execute('GET', 'https://api.mercadolibre.com'+&MrkhookRes)
	
	If &HttpClient.StatusCode = 200
		&IsSucesso = true
		
		Do Case
			CAse &MrkhookTop = 'orders_v2'
				prcGravaPedidosImportados.Call(&EmPCod, &MrkCod, &HttpClient.ToString())
				
			Case &MrkhookTop = 'questions'
				prcGravaQuestions.Call(&EmPCod, &MrkCod, &HttpClient.ToString())
				
			Case &MrkhookTop = 'items'
				&sdtDadosProduto.FromJson(&HttpClient.ToString())
				&MrkItmCod = &sdtDadosProduto.id
				prcGravaProdutosImportadosCompleto.Call(&EmPCod, &MrkCod, &MrkItmCod, &HttpClient.ToString())
				
			case &MrkhookTop = 'shipments'
				prcGravaShipping.Call(&EmPCod, &MrkCod, &HttpClient.ToString())
							
//			messages

		EndCase
	
		
		
	Else
		&IsSucesso = false
		msg('Falha catastrófica! ' + &HttpClient.StatusCode.ToString())
	Endif
endif
]]></Source>
