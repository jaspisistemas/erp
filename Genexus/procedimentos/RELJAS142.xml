      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&wwpContext)
If &wwpContext.PesCod = 0
	Return
EndIf

&PesRaz = &wwpContext.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &wwpContext.EmpCod
	Where FilCod = &wwpContext.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'IMPRESSÃO DE COTAÇÃO'
	print Cabecalho
End



For Each ORder EmpCod, CotCod
	Where EmpCod = &EmpCod
	Where CotCod = &CotCod
	
	
	print DadosCotacao
	
	&TotLin  =  GxMlines(CotObs, 100)
	&NumLin  =  1
	Do While &NumLin <= &TotLin
		&CotObs = GxGetMLi(CotObs, &NumLin, 100)
		print Observacao		
		&NumLin += 1
	EndDo		
	
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
