      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//RECIBO AVULSO TICKET

loadWWPContext.Call(&Context)
&FilCod = &Context.FilCod

&TipoTitulos = 'RECIBO N° ' + &RcbCod.ToFormattedString()

MB 0
MT 0

For each order EmpCod,RcbCod
	where EmpCod = &EmpCod
	where RcbCod = &RcbCod
	&RcbTip = RcbTip
	&RcbFilCod = RcbFilCod
	Do 'Filial'
	&RcbDstCod = RcbDstCod
	&RcbDstNom = RcbDstNom
	&RcbDoc = RcbDoc
	&RcbDta = RcbDta
	&RcbVlr = RcbVlr
	&RcbObs = RcbObs
	exit
EndFor

if &RcbTip = 'R' //Receber //Se for Receber quem assina é o FilRaz, se for pagar quem assina é o DstNom	
	&Operador = &FilRaz
else //&RcbTip = 'P'
	&Operador = &RcbDstNom
	&RcbDstNom = &FilRaz + ' (CNPJ: ' +  &FilCpj + ')'
EndIf

Print Cabecalho
Print CabPagamento

if not &RcbObs.IsEmpty()
	Print Obs
EndIf

Print Assinatura

Sub 'Filial' //copy
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &RcbFilCod when not &RcbFilCod.IsEmpty()
		where FilCod = &FilCod when &RcbFilCod.IsEmpty()
		
		&FilRaz = FilRaz
		if not FilFan.IsNull() and not FilFan.IsEmpty()
			&FilRaz = FilFan
		Endif
		&QtdLinhas = gxMLines(&FilRaz, 47)
		
		if &QtdLinhas > 47
			&UmFilRaz = gxGetMLi(&FilRaz, 1, 47)
			&DoisFilRaz = gxGetMLi(&FilRaz, 2, 47)
		Else
			&DoisFilRaz = gxGetMLi(&FilRaz, 1, 47)
		EndiF 

		&UmFilRaz = UPPER(&UmFilRaz)
		&DoisFilRaz = UPPER(&DoisFilRaz)
		
		if not FilCpj.IsEmpty()
			&CnpjIeIm = 'CNPJ: ' + trim(FilCpj)
		EndIF
		&FilCpj = FilCpj
		If not FilInsEst.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IE: ' + trim(FilInsEst)
		EndIF
		
		If Not FilInsMun.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IM: ' + trim(FilInsMun)
		EndIF
		
		&Endereco = FilLog.Trim() + ', ' + trim(FilNro) + ' - ' + trim(FilBai)
		&Cidade = trim(FilCidNom) + ' - ' + trim(FilCidUfeCod)
		
		Exit
	EndFor
EndSub
]]></Source>
