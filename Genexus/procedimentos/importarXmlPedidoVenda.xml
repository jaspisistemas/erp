        <Source><![CDATA[do 'loadPedido'

&Linha = &PrimeiraLinha
//&Excel.ReadOnly = 1 
&Excel.Open(&selectedURL)
If &Excel.ErrCode <> 0
	msg(&Excel.ErrDescription)
Else
	Do While &Fim < 500
		
		Do 'LimpaCampos'
		
		&ProRef = &Excel.Cells(&Linha,&ColunaProduto).Text
		&ProRef = &ProRef.Trim().ToUpper()
		&PedQtd = val(&Excel.Cells(&Linha,&ColunaQtd).Text)
		if &ProRef.IsEmpty()
			&Fim += 1
		Else
			if &PedQtd > 0
				&PedItmCod = 0
				Do 'GetProduto'
				
				if &IsErro <> 'S'
					do 'GetPreco'
				EndIF
				
				if &IsErro <> 'S'
					do 'validaQTD'
				EndIF
				
				if &IsErro <> 'S'
					Do 'GetDesconto'
				EndIF
					
				if &IsErro <> 'S'
					Do 'GetTotal'
				EndIF
			
				if &IsErro <> 'S'
					Do 'DescontoMaximo'
				EndIF
			
				do 'GravaSdt'
			EndiF

			&Fim = 0
		EndIF
		
		&Linha += 1
	
	EndDo
EndIf

sub 'GravaSdt'
	
//	If &ErroInativo = 1 and &PedQtd <> 0
//		&Mensagem = 'Produto inativo e sem estoque!'
//	EndIF
	
	if &ProCod <> 0
		If &PedVlrUnt = 0 and &PedVlrTab = 0
			&Mensagem = 'Produto: ' + trim(str(&ProCod)) + ' Valor unitário menor ou igual a Zero!'
			&IsErro = 'S'
		EndIF
		
		For &sdtPedidoProdutoitem in &sdtPedidoProduto
			if &sdtPedidoProdutoitem.ProCod = &ProCod and &sdtPedidoProdutoItem.ProGraCod = &ProGraCod
				&IsErro = 'S'	
				&Mensagem = 'DUPLICIDADE: Produto já Adicionado!'
				Exit
			EndIF
		EndFor
	Endif

	//If &IsAchou = false
		&sdtPedidoProdutoitem = new()		
		&sdtPedidoProdutoitem.EmpCod = &EmpCod
		&sdtPedidoProdutoitem.FiLCod = &FilCod
		&sdtPedidoProdutoitem.PedCod = &PedCod
		&sdtPedidoProdutoitem.ProCod = &ProCod
		&sdtPedidoProdutoitem.ProGraRef = &ProRef
		&sdtPedidoProdutoitem.PedItmProRefDig = &PedItmProRefDig
		&sdtPedidoProdutoitem.ProNom = &ProNom
		&sdtPedidoProdutoitem.PedQtd = &PedQtd
		&sdtPedidoProdutoitem.PedVlrUnt = &PedVlrUnt
		&sdtPedidoProdutoitem.PedVlrItm = &PedVlrItm
		&sdtPedidoProdutoitem.Mensagem = &Mensagem
		&sdtPedidoProdutoItem.Erro = &IsErro
		&sdtPedidoProdutoItem.ProGraCod = &ProGraCod
		&sdtPedidoProdutoItem.PedQtdCan = &PedQtdCan
		&sdtPedidoProdutoItem.PedVlrTab = &PedVlrTab
		&sdtPedidoProdutoItem.PedItmDsc = &PedItmDsc
		&sdtPedidoProduto.Add(&sdtPedidoProdutoitem)
	//EndIf
EndSub


Sub 'LimpaCampos'
	&Mensagem = ''
	&IsErro = 'N'
	&NoPedItmDsc = 0
	&PedItmDsc = 0
    &PedQtd    = 0 
	&OldPedQtd = 0
    &PedQtdCan = 0
    &PedVlrItm = 0
	&PedVlrTab = 0
    &PedVlrUnt = 0
    &PedVlrUntDsc = 0
    &ProNom = ''
EndSub

Sub 'GetProduto'
	&ProCod = 0
	&ProGraCod = 0
	&PedItmProRefDig = ''
	&ErroMensagem = ''
	&ProNom = ''
	retornaProdutoReferencia.Call(&EmpCod, &ProRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &ErroMensagem)
    For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
	    Where ProCod = &ProCod
		where ProSts <> Status_Produto.EXCLUIDO
		
		&PedItmProRefDig = &ProRef
		&ProRef = ProRef
		
		&ProNom = ProNom 
		&ProVlrCus = ProVlrCus
		&ProQtdEmb = ProQtdEmb
		
		//DESCONTO
		&ProDesMax = ProDesMax
		&GrupDscMax = GrupDscMax
		
		Do 'GetEstoque'
		
		If ProSts = Status_Produto.INATIVO and &EstQtd <= 0
			&Mensagem = 'Produto Inativo com Estoque Zero! Produto:' + trim(str(ProCod))
			&IsErro = 'S'
		EndIf
		
	    Exit
	When none
		&ProNom = 'PRODUTO NAO LOCALIZADO'
		&IsErro = 'S'
		
		If not &ProCod.IsEmpty()
            &Mensagem = 'Produto código: ' +trim(str(&ProCod)) + ' não localizado!'
        EndIF
    EndFor

	RetornaTotalAutorizado.Call(&EmpCod, &FilCod, &PedCod, &ProCod, &ProGraCod, &PedLibAutPedQtd, &PedLIbAutPedVlr, &PedLibAutPedDesc)
EndSub


Sub 'GetEstoque'
	
	For Each Order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
        
        &EstQtd = EstQtd
		&EstSdo = EstSdo
		
		if (&PedSts = Status_Pedido.FECHADO or &PedSts = Status_Pedido.SEPARANDO) and EstProStsBal = Status_SimNao.Sim
			&Mensagem = 'Produto em Balanço, não pode ser Alterado!'
			&IsErro = 'S'
		EndIF
		
	    Exit
	When None
		&EstQtd = 0
		IniciaEstoque.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod)
    EndFor
	
EndSub

Sub 'validaQTD'
    if &PedQtd > &MaiorPedQtd and &MaiorPedQtd > 0
        &Mensagem = 'Atenção quantidade digitada é maior que ' + trim(toformattedString(&MaiorPedQtd)) + ' [CONF213]'
        &IsErro = 'S'
    Else
		&PedQtdCan = 0
		
		If &PedQtd > 0
			If &ProQtdEmb > 1 
				
				&AuxPedQtd = &PedQtd
				&Resto = mod(&Pedqtd, &ProQtdEmb)
				Do While &Resto <> 0					
					&Pedqtd += 1
					&Resto = mod(&Pedqtd, &ProQtdEmb)
					
					&Mensagem = 'Embalagem Mínima de '+trim(str(&ProQtdEmb)) + ', Informado: ' + trim(str(&AuxPedQtd)) + ' Ajustado: ' + trim(Str(&Pedqtd))
					&IsErro = 'X'
				EndDo
			EndIF
			
			if (&PedSts = Status_Pedido.FECHADO OR &PedSts = Status_Pedido.SEPARANDO)
			    &newEstQtd = &EstQtd
			Else
				&newEstQtd = &EstSdo
			Endif
			
			If &IsErro = 'N' and &PedQtd > &newEstQtd and &AlertarProdutoSemEstoque = 'S'
				&Mensagem = 'Produto: '+ trim(str(&ProCod))+ ', com estoque insuficiente! Em estoque: ' + trim(str(&newEstQtd)) +  '. [CONF181]'
			Endif
		EndIF
    EndIF
	
EndSub

Sub 'GetDesconto'
	
    &PedVlrUntDsc = &PedVlrUnt
    if &PedItmDsc <> 0
		&PedVlrUntDsc = round(&PedVlrUnt - (&PedVlrUnt * &PedItmDsc * 0.01), 2)
    	&PedVlrUntDsc = round(&PedVlrUnt - (&PedVlrUnt * &PedItmDsc * 0.01), 2)
    endif
	
	&PedItmPrm = RetornaPrecoUnitarioTipo.Udp(&EmpCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedItmDsc)
EndSub

Sub 'GetPreco'
	
	Do Case
		Case &LctRetCus = Status_SimNao.Sim and &PedVlrUnt <= 0
			&PedVlrUnt = &ProVlrCus
			
		Case &LctInfPrc = Status_SimNao.Nao or &PedVlrUnt <= 0
			&EspPedVlrUnt = RetornaPrecoEspecialCliente.UDP(&EmpCod, &PedCliCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms)
			&PedVlrUnt = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)			
			
			if &EspPedVlrUnt < &PedVlrUnt and &EspPedVlrUnt > 0
				&PedItmDsc = 100 - ((&EspPedVlrUnt / &PedVlrUnt) * 100)
				&NoPedItmDsc = &PedItmDsc
			EndIF
	EndCase

	if &PedItmDsc.IsEmpty() and &PedCliDscCom > 0
		&PedItmDsc = &PedCliDscCom // DESCONTO COMBINADO
	EndIf
	
	&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
EndSub

Sub 'GetTotal'
	
	&PedVlrItm = round(&PedQtd * &PedVlrUntDsc, 2)
	
EndSub

Sub 'LoadPedido'
		
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon033_MaiorQtdVendida, &CfgVlr)
    &MaiorPedQtd = val(&CfgVlr)
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon003_AvisarEstoque, &AlertarProdutoSemEstoque)
	
	&ProGraCod = 1 //FIXEI PORQUE NAO TEM OPCAO DE GRADE NA TELA; JDF
	
	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon017_DescMax, &Varchar)
	&TCon017_DescMax = val(&Varchar) //Tabela Normal

	RetornaConfSistema.Call(&EmpCod, &FilCod, domConfSistema.TCon131_DescMaxTabPromocao, &Varchar)
	&TCon131_DescMaxTabPromocao = val(&Varchar) //Tabela Normal
	
    For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		
		If PedSts = Status_Pedido.CANCELADO
			do 'Destino'
		EndIf
		
		&PedCliCod = PedCliCod
		
		//TABELA
		&TabCod = TabCod
		&TabPrmCod = TabPrmCod
		&TabColCod = TabColCod
		
		//DADOS PEDIDO
		&PedDtaEms = PedDtaEms
		
		//CLIENTE
		&PesDscMax = PedCliDscMax
		
		//TIPO LANCAMENTO
		&LctRetCus = LctRetCus
		&LctInfPrc  = LctInfPrc
		
		&PedSts = PedSts
		
		&PedCliDscCom = PedCliDscCom
		Exit
    EndFor
	
EndSub

Sub 'Destino'
	
	Do Case
		Case &DeOndeVem = 'PEDIDOFATURAMENTO'
			WWPedidoFaturamento.Link()
		Case &DeOndeVem = 'PEDIDOVENDA'
			WWPedidoVenda.Link()
		Case &DeOndeVem = 'PEDIDOTELEVENDAS'
			WWPedidoTelevendas.Link()
		Case &DeOndeVem = 'ORDEMSERVICO'
			wwOrdemServico.Link()
		Case &DeOndeVem = 'OFICINAMEC'
			wwOficinaMecanica.Link()
	EndCase
	
EndSub


Sub 'DescontoMaximo'
	
	&TotalDescontos = 0
	IF (&PedVlrUnt <> &PedVlrTab) AND (&PedVlrUnt > 0) AND (&PedVlrTab > 0)
		&TotalDescontos = (100 - ((&PedVlrUnt / &PedVlrTab) * 100))
	EndIF
	
	//if &PedItmDsc > 0
	&TotalDescontos += &PedItmDsc
	//EndIF
	if &PedItmDsc < 0
		&TotalDescontos = 0
	Endif
	
	VerificaDescontoMaximoPedidoItem.Call(&EmpCod, &FilCod, &PedCod, &wwpContext, &PedItmCod, &PedItmPrm, &PedVlrItm, &TotalDescontos, &PedVlrUnt, &TCon017_DescMax, &TCon131_DescMaxTabPromocao, &PesDscMax, &ProDesMax, &GrupDscMax, &PedLibAutPedQtd, &PedLibAutPedVlr, &PedLibAutPedDesc, &ProRef, &ProNom, &Mensagem, &IsErroDescontoMaximo)
	&IsErro = iif(&IsErroDescontoMaximo = true, 'S', 'N')
EndSub
]]></Source>
