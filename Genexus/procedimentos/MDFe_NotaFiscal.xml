      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &NfeCidNom.Trim().IsEmpty()
	Do 'getCidade'	
EndIf

If &OqueFazer = 'ADD'
	For Each Order EmpCod, FilCod, MDFeCod, MDFeNFeFilCod, MDFeNfeCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod		
		Where MDFeNFeFilCod = &NfeFilCod
		Where MDFeNFeItm = &ParMDFeNFeItm or MDFeNfeChv = &NfeChv
		
		msg('Nota Alterada!')
		MDFeNfeChv2 = &MDFeCteChv2
		MDfeNfeCidCod = &NfeCidCod
		MDFeNfeCidNom = &NfeCidNom
		MdfeNfeUfeCod = &NfeUfeCod
		MDFeNfeChv = &NfeChv
		MDFeNfeVlrTot = &NfeVlrTot
		MDfeNfePso = &NfePso
		Exit
		
	When none
		
		For Each Order EmpCod, FilCod, MDFeCod, (MDFeNFeItm)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			&MDFeNFeItm = MDFeNFeItm
			Exit
		EndFor
		&MDFeNFeItm += 1
		
		new
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MdfeCod
			MDFeNFeItm =  &MDFeNFeItm
			MDFeNFeFilCod = &NfeFilCod
			MDFeNfeCod = &NfeCod
			MDFeNfeChv = &NfeChv
			MDFeNfeChv2 = &MDFeCteChv2
			MDfeNfeCidCod = &NfeCidCod
			MDFeNfeCidNom = &NfeCidNom
			MdfeNfeUfeCod = &NfeUfeCod
			MDFeNfeVlrTot = &NfeVlrTot
			MDfeNfePso = &NfePso
		EndNEw
		
		msg('Nota adicionada com sucesso!')
	EndFor
Else
	For Each Order EmpCod, FilCod, MDFeCod, MDFeNFeItm
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeNFeItm = &ParMDFeNFeItm
		Delete
		Exit
	EndFor
EndIF

Commit

	
Sub 'getCidade'
	For each Order EmpCod,CidIBGE, CidCod
		Where EmpCod = &EmpCod
		Where CidIBGE = &NfeCidCod		
		&NfeCidNom = CidNom
		exit
	EndFor
EndSub
]]></Source>
