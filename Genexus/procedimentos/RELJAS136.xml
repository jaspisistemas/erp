//IMPRESSAO DETALHADA RENEGOCIAÇÃO - TICKET (WWDUPLICATASRENEGOCIACAO)
MB 0
MT 0

Do 'Filial' //Dados Cabecalho
Print Cabecalho

Do 'PegaCodRenegociacaoDuplicata' //Verifica se é Renegociada	

	if &IsErro = true
		Print Erro
	else
		Do 'DuplicatasOrigem' //imprime todas origem
		Do 'DuplicatasDestino' //imprime todas destino
		Print Assinatura
	EndIf



//######################### SUBS ######################\\

Sub 'PegaCodRenegociacaoDuplicata' //Pegar Cód da renegociacao duplicata  p/ depois procurar as dup origem e destino //pega a duplicata pelo CreCod e pega o CreRenDstCod, este é igual a CreRenOriCod

	&IsErro = false
	For each order EmpCod,FilCod,CreCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where CreCod = &CreCod
		where CreRenDstCod > 0
		&CodigoReneg = CreRenDstCod
		exit
	when none
		&IsErro = true
		&msgErro = 'ATENÇÃO! Duplicata selecionada não é renegociada.'
		Print Erro
	EndFor
	
EndSub

Sub 'DuplicatasOrigem' //Pegar as Duplicatas Geradas pela duplicata de origem
	
	&titulo = 'DUPLICATAS ORIGEM'
	Print Titulo
	Do 'ZeraTotais'
	For each order EmpCod,FilCod,CreCod,CreRenCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where CreRenOriCod = &CodigoReneg
		&AuxCreCod = CreCod
		&CreVlrDup = CreVlrDup
		&CreVlrSdo = CreVlrSdo
		&CreDtaVct = CreDtaVct
		&CreDupNro = CreDupNro
		&CreCliRaz = CreCliRaz
		Do case
			case CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
				&TotalCartao += CreVlrDup
				&Tipo = 'CARTÃO'
			case CreFrpPgtoTip = TipoDuplicata.DINHEIRO
				&TotalDinheiro += CreVlrDup
				&Tipo = 'DINHEIRO'
			case CreFrpPgtoTip = TipoDuplicata.DUPLICATA
				&TotalDuplicata += CreVlrDup
				&Tipo = 'DUPLICATA'
			case CreFrpPgtoTip = TipoDuplicata.CHEQUEP or CreFrpPgtoTip = TipoDuplicata.CHEQUET
				&TotalCheque += CreVlrDup
				&Tipo = 'CHEQUE'
			case CreFrpPgtoTip = TipoDuplicata.DEPOSITO
				&TotalDepositoMoeda += CreVlrDup
				&Tipo = 'DEPÓSITO'
			case CreFrpPgtoTip = TipoDuplicata.PIX
				&TotalPixMoeda += CreVlrDup
				&Tipo = 'PIX'
			otherwise
				&TotalOutros += CreVlrDup
				&Tipo = 'OUTRO TIPO'
		EndCase
		
		&CpfCnpj = iif(CreCliTip = 'F',CreCliCpf,CreCliCnpj)
		&Total += CreVlrDup
		Print Duplicata
	EndFor

	if &TotalDinheiro > 0
		Print TotalDinheiro
	EndIf
	if  &TotalDuplicata > 0
		Print TotalDuplicata
	EndIf
	if &TotalCartao > 0
		Print TotalCartao
	EndIf
	If &TotalCheque > 0
		Print TotalCheque
	EndIf
	if &TotalPixMoeda > 0
		print TotalPix
	Endif
	if &TotalDepositoMoeda > 0
		Print TotalDeposito
	Endif
	If &TotalOutros > 0
		Print TotalOutros
	EndIf
	Print Total
	
EndSub

Sub 'DuplicatasDestino' //Pegar dados das duplicatas renegociadas
	
	&Titulo = 'DUPLICATAS GERADAS'
	Print Titulo
	Do 'ZeraTotais'
	For each order EmpCod,FilCod,CreCod
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where CreRenDstCod = &CodigoReneg
		&AuxCreCod = CreCod
		&CreVlrDup = CreVlrDup
		&CreVlrSdo = CreVlrSdo
		&CreDtaVct = CreDtaVct
		&CreDupNro = CreDupNro
		&CreFrpPgtoTip = CreFrpPgtoTip
		&CreCliRaz = CreCliRaz
		&CpfCnpj = iif(CreCliTip = 'F',CreCliCpf,CreCliCnpj)
		Do case
			case CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
				&TotalCartao += CreVlrDup
				&Tipo = 'CARTÃO'
			case CreFrpPgtoTip = TipoDuplicata.DINHEIRO
				&TotalDinheiro += CreVlrDup
				&Tipo = 'DINHEIRO'
			case CreFrpPgtoTip = TipoDuplicata.DUPLICATA
				&TotalDuplicata += CreVlrDup
				&Tipo = 'DUPLICATA'
			case CreFrpPgtoTip = TipoDuplicata.CHEQUEP or CreFrpPgtoTip = TipoDuplicata.CHEQUET
				&TotalCheque += CreVlrDup
				&Tipo = 'CHEQUE'
			case CreFrpPgtoTip = TipoDuplicata.DEPOSITO
				&TotalDepositoMoeda += CreVlrDup
				&Tipo = 'DEPÓSITO'
			case CreFrpPgtoTip = TipoDuplicata.PIX
				&TotalPixMoeda += CreVlrDup
				&Tipo = 'PIX'
			otherwise
				&TotalOutros += CreVlrDup
				&Tipo = 'OUTRO TIPO'
		EndCase
		&Total += CreVlrDup
		Print Duplicata
	EndFor
	
	if &TotalDinheiro > 0
		Print TotalDinheiro
	EndIf
	if  &TotalDuplicata > 0
		Print TotalDuplicata
	EndIf
	if &TotalCartao > 0
		Print TotalCartao
	EndIf
	If &TotalCheque > 0
		Print TotalCheque
	EndIf
	if &TotalPixMoeda > 0
		print TotalPix
	Endif
	if &TotalDepositoMoeda > 0
		Print TotalDeposito
	Endif
	If &TotalOutros > 0
		Print TotalOutros
	EndIf
	Print Total
	
EndSub

Sub 'Filial' //copy
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		&FilRaz = FilRaz
		if not FilFan.IsNull() and not FilFan.IsEmpty()
			&FilRaz = FilFan
		Endif
		&QtdLinhas = gxMLines(&FilRaz, 47)
		
		if &QtdLinhas > 47
			&UmFilRaz = gxGetMLi(&FilRaz, 1, 47)
			&DoisFilRaz = gxGetMLi(&FilRaz, 2, 47)
		Else
			&DoisFilRaz = gxGetMLi(&FilRaz, 1, 47)
		EndiF 

		&UmFilRaz = UPPER(&UmFilRaz)
		&DoisFilRaz = UPPER(&DoisFilRaz)
		
		if not FilCpj.IsEmpty()
			&CnpjIeIm = 'CNPJ: ' + trim(FilCpj)
		EndIF
		&FilCpj = FilCpj
		If not FilInsEst.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IE: ' + trim(FilInsEst)
		EndIF
		
		If Not FilInsMun.IsEmpty()
			If not &CnpjIeIm.IsEmpty()
				&CnpjIeIm += ' - '
			EndIf
			&CnpjIeIm += 'IM: ' + trim(FilInsMun)
		EndIF
		
		&Endereco = FilLog.Trim() + ', ' + trim(FilNro) + ' - ' + trim(FilBai)
		&Cidade = trim(FilCidNom) + ' - ' + trim(FilCidUfeCod)
		&Operador = &FilRaz
		Exit
	EndFor
EndSub

Sub 'ZeraTotais'
	&Total = 0
	&TotalCartao = 0
	&TotalDinheiro = 0
	&TotalCheque = 0
	&TotalOutros = 0
	&TotalDuplicata = 0
EndSub
