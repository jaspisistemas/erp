        <Source><![CDATA[
For Each Order EmpCod, MrkCod
	Where EmpCod = &EmpCod
	Where MrkCod = &MrkCod
	
	//dados do marketplace
	&MrkPadFilCod = MrkPadFilCod
	&MrkPadVenCod = MrkPadVenCod
	&MrkPadNfeFilCod = MrkPadNfeFilCod
	&MrkPadLctCod = MrkPadLctCod
	
	&MrkPadCliCod = MrkPadCliCod
	//MrkPadGrvCli //IMPLEMENTAR, usuario quer cadastrar todos os clientes marketplace	
	
	if &MrkPadLctCod.IsEmpty() or &MrkPadFilCod.IsEmpty() or &MrkPadVenCod.IsEmpty() or &MrkPadCliCod.IsEmpty()
		msg('Configurações pendente no Marketplace!')
		return
	Endif //tem que ter as configs		
	
	//dados do pedido marketplace
	For Each Order EmpCod, MrkCod, MrkPedSku
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		Where MrkPedSku = &MrkPedSku
		Where MrkPedCod.IsEmpty() or MrkPedCod.IsNull()
		
		&PedDtaEms = MrkPedDtaEms
		&MrkPedCom = MrkPedCom
		//		&MrkPedVlrFrt = MrkPedVlrFrt
		//		&MrkPedVlrAcr = MrkPedVlrAcr
		&MrkPedVlrDsc = MrkPedVlrDsc
		
		//&PedDtaPrv = 
		//&PedNum = MrkPedSku //PedNum numeric
		do 'gravaCapaPedido'
		MrkPedFilCod = &MrkPadFilCod
		MrkPedCod = &MrkPedCod
		
		commit		
		
		For EAch Order EmpCod, MrkCod, MrkPedSku, MrkPedProItmCod
			&MrkPedProQtd = MrkPedProQtd
			&MrkPedProVlr = MrkPedProVlr
			&MrkPedProCom = MrkPedProCom
			&MrkPedProItmCod = MrkPedProItmCod
			do 'getProduto'
			do 'addItem'
			
		EndFor
		
	EndFor
	
	Exit
EndFor

prcAtualizaStatusInterno.Call(&EmpCod, &MrkCod, &MrkPedSku)

sub 'getProduto'
	&ProCod = 0
	&ProGraCod = 0
	
	For Each ORder EmpCod, MrkCod, MrkItmCod
		Where EmpCod = &EmpCod
		Where MrkCod = &MrkCod
		Where MrkItmCod = &MrkPedProItmCod
		&ProCod = MrkProCod
		&ProGraCod = MrkProGraCod
		Exit
	EndFor
EndSub

