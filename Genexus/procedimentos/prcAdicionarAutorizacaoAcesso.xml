      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &PesAceGuid.IsEmpty()
	&Mensagem = 'Não Informado Código GUID!'
	return
Endif

//LOCALIZA EMPRESA A SER AUTORIZADA
For each Order EmpCod
	Where PesAceGuid = &PesAceGuid	
	
	&AcessoEmpCod = EmpCod
	&AcessoPesCod = PesCod
		
	if EmpCod = &EmpCod
		&Mensagem = 'Você está tentando vincular sua empresa, na sua própria empresa. Assim não dá, Assim não pode!'
		return
	Endif

	PesAceGuid.SetEmpty()
	
	For Each ORder EmpCod, PesCod, PesAceEmpCod
		Where PesAceEmpCod = &EmpCod
		&Mensagem = 'Vínculo já realizado com outro usuário, Vínculo atual não permitido!'
		Exit
	EndFor
	
	Exit
when none
	&Mensagem = 'Código não localizado!'
	return
EndFor

commit



if &Mensagem.IsEmpty()
	&Mensagem = 'Vínculo realizado com sucesso!'
	
	//ADICIONA ACESSO EMPRESA LOGADA
	new
		EmpCod = &EmpCod
		PesCod = &PesCod
		PesAceEmpCod = &AcessoEmpCod
		PesAcePesCod = &AcessoPesCod
	EndNew
	Commit	
	
	//VINCULA A OUTRA EMPRESA A ESSA.
	new
		EmpCod = &AcessoEmpCod
		PesCod = &AcessoPesCod 
		PesAceEmpCod = &EmpCod
		PesAcePesCod = &PesCod
	EndNew
	Commit
EndIf
]]></Source>
