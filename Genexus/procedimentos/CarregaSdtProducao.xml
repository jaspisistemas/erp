<Object parentGuid="7724f965-d875-403b-a841-bc63d54e9361" user="SRVORDIG\Administrador" versionDate="2023-07-28T11:33:13.0000000Z" lastUpdate="2023-07-26T13:15:33.0000000Z" checksum="2c8b922424ea40fe6b29f155134141ba" fullyQualifiedName="CarregaSdtProducao" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="aed89841-f7b9-4782-8b64-1c25fb01001a" name="CarregaSdtProducao" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Carrega Sdt Producao" parent="OrdPrdprc" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtOrdemProducao.Clear()
&auxGrupHie = trim(&GrupHie) + '.'
For Each
	Order EmpCod , FilCod , ProSts , ProGraCod , ProSetCod ,ProTipDef, ProCod WHEN &OrderedBy = 1 
	Order EmpCod , FilCod , ProSts , ProGraCod , ProSetCod ,ProTipDef, ProNom WHEN &OrderedBy = 2 
	Order EmpCod , FilCod , ProSts , ProGraCod , ProSetCod ,ProTipDef, (EstPrio) WHEN &OrderedBy = 3 
	Order EmpCod , FilCod , ProSts , ProGraCod , ProSetCod ,ProTipDef, EstPrd WHEN &OrderedBy = 4 
	Order EmpCod , FilCod , ProSts , ProGraCod , ProSetCod ,ProTipDef, (EstPrd) WHEN &OrderedBy = 5 
	Order EmpCod , FilCod , ProSts , ProGraCod , ProSetCod ,ProTipDef, EstQtd WHEN &OrderedBy = 6 
	Order EmpCod , FilCod , ProSts , ProGraCod , ProSetCod ,ProTipDef, EstDias WHEN &OrderedBy = 7 

	Where EmpCod = &EmpCod
	Where FilCod = &FilCod 
	Where ProGraCod = 1 
	Where ProTipDef = &ProTipDef 
	Where ProSetCod = &ProSetCod 
	Where ProSts = Status_Produto.ATIVO 
	Where GrupAnaSin = 'A' 
	
	//Where EstSug > 0 or &SomenteFabricar = 'N'
	Where GrupHie like &auxGrupHie or GrupHie = &GrupHie when not &GrupHie.IsEmpty()
	Where ProClsPrdCod = &ProClsPrdCod when not &ProClsPrdCod.IsEmpty()	
	Where EstPrd < 0 when &OrdemExedente = TipoOrdem.ExedenteProducao //EXEDENTE
	Where EstPrdCan > 0 when &OrdemExedente = TipoOrdem.CancelamentoProducao //EXEDENTE
	Where EstFab > 0 when &OrdemExedente = TipoOrdem.OrdemProducao //NAO EXEDENTE
	
	&OrdItmCod += 1
	&sdtOrdemProducaoItem = new()
	&sdtOrdemProducaoItem.OrdItmCod = &OrdItmCod
	&sdtOrdemProducaoItem.ProCod = ProCod
	&sdtOrdemProducaoItem.ProGraCod = ProGraCod
	
	Do Case
		Case &OrdemExedente = TipoOrdem.ExedenteProducao //EXEDENTE
			If EstPrd_Formatado < 0
				&sdtOrdemProducaoItem.EstFab = (EstPrd_Formatado * -1)
			Else
				&sdtOrdemProducaoItem.EstFab = 0
			EndIF
		
		Case &OrdemExedente = TipoOrdem.OrdemProducao
			&sdtOrdemProducaoItem.EstFab = EstFab
			 
		Case &OrdemExedente = TipoOrdem.CancelamentoProducao
			&sdtOrdemProducaoItem.EstFab = EstPrdCan
	EndCase


	&sdtOrdemProducaoItem.EstPrio = EstPrio
	&sdtOrdemProducaoItem.ProNom = ProNom
	&sdtOrdemProducaoItem.EstPrd = EstPrd_Formatado
	&sdtOrdemProducaoItem.EstSdo = EstSdo_Formatado
	&sdtOrdemProducaoItem.EstQtd = EstQtd_Formatado
	&sdtOrdemProducaoItem.EstVen = EstVen_Formatado
	&sdtOrdemProducaoItem.EstMin = EstMin_Formatado
	&sdtOrdemProducaoItem.EstVlrCus = ProVlrCus
	&sdtOrdemProducao.Add(&sdtOrdemProducaoItem)
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
