      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&FecCod = 0
For Each Order EmpCod, CtabanCod, (FecCod)
	Where EmpCod = &EmpCod
	Where CtabanCod = &CtaBanCod
	&CtaBanFilCod = CtaBanFilCod
	&FecCod = FecCod
	Exit
EndFor


&FecCod += 1

new
	EmpCod = &EmpCod
	CtabanCod = &CtaBanCod
	FecCod = &FecCod
	FecDta = &FecHor.ToDate()
	FecHor = &FecHor
	FecSts = &FecSts
	FecPesCod = &FecPesCod
	FecStsLct = &FecSts
EndNew

Commit
Do 'AtualizaMovimento'
Commit


Sub 'AtualizaMovimento' //grava vazio para quando esta aberto
	For Each Order EmpCod, MovCtaBanCod
		Where EmpCod = &EmpCod
		Where MovCtaBanCod = &CtaBanCod
		Where MovFecCod = &RetFecCod
		
		MovFecCod = 0
	EndFor

	For each Order EmpCod,CreFrpPgtoTip,CreCod
		Where EmpCod = &EmpCod
		Where FilCod = &CtaBanFilCod //POR HORA ASSIM< MAS TA ERRADO JDF
		Where CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
		Where CreFchCod = &RetFecCod
		
		CreFchCod = 0
		
	EndFor
EndSub



]]></Source>
