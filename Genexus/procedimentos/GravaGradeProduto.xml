      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	if ProSts = Status_Produto.EXCLUIDO //PARA FAZER SAIR DO PROCEDIMENTO
		Return
	endif
	
	&ProBar = UPPER(ProBar.Trim())
	&ProRef = UPPER(ProRef.Trim())
	
	if &ProRef.IsEmpty() or &ProRef = '0'
		&ProRef = trim(str(ProCod))
		ValidaCodigoReferenciaRepetido.Call(EmpCod, ProCod,  1, &ProRef, &RepetidoReferenciaMensagem) 
		Do while not &RepetidoReferenciaMensagem.IsEmpty()
			&Codigo8 = Random() * 1000000
			&ProRef = trim(str(&Codigo8))
			ValidaCodigoReferenciaRepetido.Call(EmpCod, ProCod,  1, &ProRef, &RepetidoReferenciaMensagem) 
		EndDo
	EndiF
	
	if Not &Proref.IsEmpty()
		// SE FOR CODIGO BARRAS ATUALIZAR CODIGO DE BARRAS.
		
	Endif
	
	if ProTipCus = TipoCusto.Receita
		ProTipCusAcrRec = false //SE RECEITA TRUE 
	Endif

	ProBar = &ProBar
	ProRef = &ProRef	
	ProRefPadL = padL(&ProRef, 18, '0')
	
	If ProPadForCod <> 0 
		&ProForCod = ProPadForCod
		&ProVlrCus = ProVlrCus_FORMULA
		do 'VerificaCadastroFornecedor'
	EndIF

	&NcmCod = NcmCod
	if &NcmCod = 99
		&NcmCod = 99
		If GrupNCM > 99
			&NcmCod = GrupNCM
		Endif		
	Endif
	
	&ProCatCod = ProCatCod
	if &ProCatCod <= 0
		&ProCatCod = 1
		If not GrupCatCod.IsNull() and not GrupCatCod.IsEmpty()
			&ProCatCod = GrupCatCod
		Endif		
	Endif

	ProCatCod = &ProCatCod
	NcmCod = &NcmCod
	ProVarNcm = trim(Str(&NcmCod))
	
	If ProOriCod.IsEmpty() or ProOriCod.IsNull()
		ProOriCod = ProCod
	EndIF

	If ProEstTip = TipoEstoque.ATUALIZAR_OUTRO_PRODUTO and (ProEstProCod = ProCod or ProEstProCod.IsEmpty() or ProEstProCod.IsNull())
		ProEstTip = TipoEstoque.ATUALIZAR_ESTOQUE
	EndiF
	
	if (ProEstProCod.IsEmpty() or ProEstProCod.IsNull())
		ProEstProCod = ProCod 
	Endif

	For Each Order EmpCod, ProCod, ProGraCod
		Where ProGraCod = 1
		ProGraBar = &ProBar
		ProGraRef = &ProRef
		ProGraRefPadL = padL(&ProRef, 18, '0')
		Exit
	When none
		New
			EmpCod = &EmpCod
			ProCod = &ProCod
			ProGraCod = 1
			ProGraBar = &ProBar
			ProGraRef = &ProRef
			ProGraRefPadL = padL(&ProRef, 18, '0')
			ProGraNom = ''
			ProGraSts = Status_AtivoInativo.ATIVO
		EndNew
	EndFor
EndFor

commit

GravaCodigoProdutoRefBarras.Call(&EmpCod, &ProCod, 1, &ProRef, 'R') //REFERENCIA
GravaCodigoProdutoRefBarras.Call(&EmpCod, &ProCod, 1, &ProBar, 'B') //BARRAS



Sub 'VerificaCadastroFornecedor'
	For Each Order EmpCod, ProCod, ProForCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProForCod = &ProForCod
		Exit
	When none
		GravaProdutoFornecedor.Call(&EmpCod, &ProCod, &ProForCod, 0, 0, 1, &ProVlrCus, '', '', 0, 0, 0, 0, 0, &mensagem)
	EndFor
EndSUb
]]></Source>
