      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
// Inicializando os botões de navegação
&Pg1 = "0"
&Pg2 = "0"
&Pg3 = "0"
&Pg4 = "0"
&Pg5 = "0"

// Calcular o intervalo de páginas a serem exibidas
if &QtdPaginas <= 5
    for &i = 1 to &QtdPaginas
        do case
            case &i = 1
                 &Pg1 = "1"
            case &i = 2
               &Pg2 = "2"
            case &i = 3
                 &Pg3 = "3"
            case &i = 4
                &Pg4 = "4"
            case &i = 5
                &Pg5 = "5"
        endcase
    endfor
else
    // Quando há mais de 5 páginas, centralizar a página selecionada
    Do CAse
		CAse &PgSelecionada <= 3
	        &Pg1 = "1"
	        &Pg2 = "2"
	        &Pg3 = "3"
	        &Pg4 = "4"
	        &Pg5 = "5"
	    CAse  &PgSelecionada >= &QtdPaginas - 2
			&i = (&QtdPaginas - 4)
	        &Pg1 = &i.ToString().Trim()
			&i += 1
	        &Pg2 = &i.ToString().Trim()
			&i += 1
	        &Pg3 = &i.ToString().Trim()
			&i += 1
	        &Pg4 = &i.ToString().Trim()
			&i += 1
	        &Pg5 = &i.ToString().Trim()
	    Otherwise
			&i = (&PgSelecionada - 2)
	        &Pg1 = &i.ToString().Trim()
			&i += 1
	        &Pg2 = &i.ToString().Trim()
			&i += 1
	        &Pg3 = &i.ToString().Trim()
			&i += 1
	        &Pg4 = &i.ToString().Trim()
			&i += 1
	        &Pg5 = &i.ToString().Trim()
    EndCAse
endif
]]></Source>
