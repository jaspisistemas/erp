      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProTipDef.SetEmpty()

if not &inProGraRef.IsEmpty()
	
	If &IsAumentar = false
		&PedQtd = -1
	Else
		&PedQtd = 1
	EndIF

	&auxPedQtd = &PedQtd
	
	&IsAchouProduto = false
	&ProCod = 0
	RetornaProdutoReferencia.Call(&EmpCod, &inProGraRef, &ProCod, &ProGraCod, &ProNom, &IsAchouProduto, &ProReqVlr, &ProReqQtd, &ProBarQtd, &Mensagem)
	if not &Mensagem.IsEmpty()
		do 'SonsErro'
	EndIF
	
	if &IsAchouProduto = true 
		do 'GetDadosProdutoGrade'
		&PedQtd += &AuxPedQtd
		if &PedQtd < 0
			&PedQtd = 0
		EndIF
		
		If &PedQtd <> &OLDPedQtd
			&PedQtdCan = &PedQtdCan + (&OLDPedQtd - &PedQtd)
		EndIF
	
		If &PedVlrUnt > 0				
			If (&ProGraCod > 1 and &ProIsGra = true) or (&ProIsGra <> true and &ProGraCod = 1)
				do 'GravaItemPDV'				
			Else
				&Mensagem ='Produto com Variação, é preciso inserir o Código da Variação!'
				do 'sonsERRO'
			Endif
		Else				
			&Mensagem = 'Produto não cadastrado na tabela de Preço!'
			do 'sonsERRO'
		EndIf
	EndIF
EndiF


Sub 'GravaItemPDV'

	GravaItemPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, &PedItmCod, &ProCod, &ProGraCod, &PedQtd, &PedQtdCan, 0, &PedVlrUnt, &PedVlrTab, &PedItmDsc, '', 0, &PedCodOciRefItm, &MensagemInserida, &MensagemAlterado, &wwpContextUserName)
	&QuantoTem = &PedQtd

EndSub

Sub 'GetDadosProdutoGrade'
	
    Do 'GetProduto'
	&PedQtd = 0
	
    Do 'GetProdutoPedido'
EndSub


Sub 'GetProdutoPedido'

	&PedItmCod = 0	
	
	If &ErroProduto <> 1
		For Each Order EmpCod, FilCod, PedCod, ProCod, ProGraCod
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			Where ProCod = &ProCod
			Where ProGraCod = &ProGraCod
			
			&ProRef = ProGraRef
			&PedItmCod = PedItmCod
			&PedQtd = PedQtd
			&OldPedQtd = PedQtd
			&PedQtdCan = PedQtdCan
			&PedVlrUnt = PedVlrUnt
			&PedVlrTab = PedVlrTab
			&PedItmDsc = PedItmDsc		
			Exit
		EndFor
		
		do 'GetPreco'
		Do 'GetDesconto'	
	EndIF

EndSub

Sub 'GetProduto'
	
	&ErroProduto = 0
	&ErroInativo = 0
	
    For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
	    Where ProCod = &ProCod
		where ProSts <> Status_Produto.EXCLUIDO
		
		&ProIsGra = ProIsGra
		&ProRepItm = ProRepItm
		&ProVlrCus = ProVlrCus
		&ProQtdEmb = ProQtdEmb
		&ProQtdVol = ProQtdVol
		&ProTipDef = ProTipDef
		
		//DESCONTO
		&ProDesMax = ProDesMax
		&GrupDscMax = GrupDscMax
		
		RetornaEstoquePedido.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod, &PedSts, &EstLoc, &EstQtd, &EstSdo, &Mensagem)
		if not &Mensagem.IsEmpty()
			&Mensagem = 'Produto em Balanço, não pode ser Alterado!'
			do 'sonsERRO'
		EndIF
		
		If ProSts = Status_Produto.INATIVO and &EstQtd <= 0
			&Mensagem = 'Produto Inativo com Estoque Zero! Produto:' + trim(ProRef)
			do 'sonsERRO'
		EndIf
		
	    Exit
	When none
           &Mensagem = 'Produto código: ' +trim(&inProGraRef) + ' não localizado!'
		do 'sonsERRO'
    EndFor
EndSub


Sub 'GetPreco'

	Do Case
		Case &LctRetCus = Status_SimNao.Sim and &PedVlrUnt <= 0
			&PedVlrUnt = &ProVlrCus
			&PedVlrTab = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
			
		Case (&LctInfPrc = Status_SimNao.Nao and &ProReqVlr <> true) or &PedVlrUnt <= 0
			&PedVlrUnt = RetornaPrecoUnitarioVenda.UDP(&EmpCod, &TabCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedDtaVct)
			&PedVlrTab = &PedVlrUnt
	EndCase

EndSub

Sub 'GetDesconto'
	&PedItmPrm = RetornaPrecoUnitarioTipo.Udp(&EmpCod, &TabPrmCod, &ProCod, &ProGraCod, &TabColCod, &PedDtaEms, &PedItmDsc)
EndSub


Sub 'sonsERRO'
	Return
EndSub
]]></Source>
