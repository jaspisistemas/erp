      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each order EmpCod,FilCod,OpeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OpeCod = &OpeCod
	
		If OpeSts = Status_Ciot.Digitando
			OpeDtaIni 		= &WizardData.Inicio.OpeDtaIni
			OpeDtaFim 		= &WizardData.Inicio.OpeDtaFim
			OpeConCod 		= &WizardData.Inicio.OpeConCod
			OpeConCnpj 		= &WizardData.Inicio.OpeConCnpj
			OpeConRntrc 	= &WizardData.Inicio.OpeConRntrc
			OpeDesCod 		= &WizardData.Inicio.OpeDesCod
			OpeResPgtFrt 	= &WizardData.Inicio.OpeResPgtFrt
			OpeSubCon 		= &WizardData.Inicio.OpeSubCon
			OpeSubConCiot 	= &WizardData.Inicio.OpeSubConCiot
			OpeSigCod 		= &WizardData.Inicio.OpesigCod
			OpeTomCod 		= &WizardData.Inicio.OpeTomCod
			OpeTipVia		= &WizardData.Inicio.OpeTipVia
			OpeSts 			= Status_Ciot.Digitando
			OpeEmiGra 		= &WizardData.Inicio.OpeEmiGra
		EndIf
When none
	
	&HojeData 	= serverdate()
	&OpeCod 	= UltimoCodigoEmpresa.Udp(domParCod.OpERACAOTRANSPORTE, &EmpCod, &FilCod)
	
	New
		EmpCod 			= &EmpCod
		FilCod 			= &FilCod
		OpeCod 			= &OpeCod
		OpeMdfeFilCod 	= 0
		OpeMdfeCod 		= 0
		OpeDta 			= &HojeData
		OpeTipVia 		= &WizardData.Inicio.OpeTipVia
		OpeEmiGra 		= &WizardData.Inicio.OpeEmiGra
		OpeMatCnpj 		= '21826923000138'  // homologacao cnpj da jaspi
		OpeNro 			= ''
		OpeDtaIni 		= &WizardData.Inicio.OpeDtaIni
		OpeDtaFim 		= &WizardData.Inicio.OpeDtaFim
		OpeConCod 		= &WizardData.Inicio.OpeConCod
		OpeConCnpj		= &WizardData.Inicio.OpeConCnpj
		OpeConRntrc 	= &WizardData.Inicio.OpeConRntrc
		OpeDesCod 		= &WizardData.Inicio.OpeDesCod
		OpeResPgtFrt 	= &WizardData.Inicio.OpeResPgtFrt
		OpeSubCon 		= &WizardData.Inicio.OpeSubCon
		OpeSubConCiot 	= &WizardData.Inicio.OpeSubConCiot
		OpeSigCod 		= &WizardData.Inicio.OpesigCod
		OpeTomCod 		= &WizardData.Inicio.OpeTomCod
		OpeNroCiot 		= ''
		OpeSts 			= Status_Ciot.Digitando
	EndNew	
EndFor

]]></Source>
