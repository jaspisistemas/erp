      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CountCancelados.SetEmpty()

//Cancela impressao pendente #FILAIMPRESSAO

For each order FIempCod, FIsts, FIcod
	where FIempCod = &FIempCod
	where FIsts = 'P' //se tiver pendente
	FIsts = 'C' 
	&CountCancelados += 1
EndFor

Commit
]]></Source>
