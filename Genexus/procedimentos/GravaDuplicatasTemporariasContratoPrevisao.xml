      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order DupTmpEmpCod,DupTmpFilCod,DupTmpPesCod,DupTmpCreCod
	Where DupTmpEmpCod = &EmpCod
	Where DupTmpFilCod = &FilCod
	Where DupTmpPesCod = &PesCod
	Delete
EndFor
	
Commit	
//TABELA SERVICOCLIENTE - SOMENTE CONTRATOS E PREVISOES
For each order EmpCod, SerItmCod
	where EmpCod = &EmpCod
	where SerItmCod = &SerItmCod	
//	where SerItmSts = Status_AtivoInativo.ATIVO //Inativo tbm pode visualizar
	&SerFilCod = SerFilCod
	&SerCliCod = SerCliCod
	&SerItmRecPag = SerItmRecPag
	&SerItmTipPlan = SerItmTipPlan
	&SerItmDesc = SerItmDesc
	&SerItmDiaVct = SerItmDiaVct
	&SerItmUltVct = SerItmUltVct
	&SerItmDtaInicio = SerItmDtaInicio
	&SerItmDtaFim = SerItmDtaFim
	
	if SerItmDesc = 0
		&SerItmVlr = SerItmVlr
	else
		&SerItmVlr = SerItmVlr - (SerItmVlr * (SerItmDesc / 100))
	EndIf
	
	&SerItmTip = SerItmTip
	&SerItmQtdMes = SerItmQtdMes
	&SerItmAbv = SerItmAbv
	&SerItmPlanCod = SerItmPlanCod
	&SerItmCbrCod = SerItmCbrCod
	&SerCliNom = SerCliNom
	exit

When none
	msg('When none')
EndFor


//INICIALIZAÇÃO DE VARIAVEIS

&CreVlrDup = SerItmVlr
&CreVlrSdo = SerItmVlr

if &SerItmTipPlan = TipoPlano.ANUAL
	&QtdAnos = (&SerItmQtdMes / 12)
EndIf




GeraDtaVctContratoPrevisao.Call(&SerItmTip, &SerItmTipPlan, &SerItmDtaInicio, &SerItmDiaVct, &MesVct, &DataVencimento)



DO CASE
	//CONTRATO
	CASE &SerItmTip = TipoLancamentoServico.CONTRATO and &SerItmTipPlan = TipoPlano.MENSAL
	
		For &Count = 1 TO &SerItmQtdMes //step 1
			
			if &DataVencimento <= &SerItmDtaFim or &SerItmDtaFim.IsEmpty()
				For each order EmpCod, FilCod, CreCliCod, CreSerItmCod, CreRecPag, CreCod
					where EmpCod = &EmpCod
					where FilCod = &FilCod
					where CreCliCod = &SerCliCod
					where CreSerItmCod = &SerItmCod
					where CreRecPag = &SerItmRecPag
					where CreDtaVct.Month() = &DataVencimento.Month() and CreDtaVct.Year() = &DataVencimento.Year() //verificar, inicio mes 12 e dup mes 01
					&SerDupNro = CreDupNro
					&SerDtaEms = CreDtaEms
					&SerDtaVct = CreDtaVct
					&CreVlrDup = CreVlrDup
					&CreVlrSdo = CreVlrSdo
					&CreCbrCod = CreCbrCod			
					&CrePlanCod = CrePlanCod
					&CreCod = CreCod
					&CreBloNro = CreBloNro
					&CreSts = CreSts
					&CreRecPag = CreRecPag
					Do 'GravaTmp'
				When none				//ABV 2019/8
					&SerDupNro = 'C.' + &SerItmAbv +/* + trim(str(&SerItmCod)) +*/ ' ' + trim(str(&DataVencimento.Year())) + '/' + trim(str(&DataVencimento.Month()))
					&SerDtaEms = serverdate()
					&SerDtaVct = &DataVencimento
					&CreCbrCod = &SerItmCbrCod
					&CrePlanCod = &SerItmPlanCod
					&CreCod = 0
					&CreVlrDup = &SerItmVlr
					&CreVlrSdo = &SerItmVlr
					&CreRecPag = &SerItmRecPag
					Do 'GravaTmp'
				EndFor
				&AuxDataVencimento = &DataVencimento
				&DataVencimento = &DataVencimento.AddMonths(1)
				&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
				
				if &DataVencimento.IsEmpty()
					&AuxDataVencimento = YmDToD(&AuxDataVencimento.Year(), &AuxDataVencimento.Month(), 1)
					&AuxDataVencimento = &AuxDataVencimento.AddMonths(1)
					&AuxData = EoM(&AuxDataVencimento)
					&UltDiaMes = &AuxData.Day()
					&DataVencimento = YmDToD(&AuxDataVencimento.Year(), &AuxDataVencimento.Month(), &UltDiaMes)
				EndIf		
			EndIf
		EndFor	
	//---------------------------------------------------------------------------------------------------------------------
		
		
		
		
		
		
		
		
	CASE &SerItmTip = TipoLancamentoServico.CONTRATO and &SerItmTipPlan = TipoPlano.ANUAL 
		
		For &Count = 1 to &QtdAnos //STEP 1
			
			if &DataVencimento <= &SerItmDtaFim or &SerItmDtaFim.IsEmpty()
				For each order EmpCod, FilCod, CreCliCod, CreSerItmCod, CreRecPag, CreCod
					where EmpCod = &EmpCod
					where FilCod = &FilCod
					where CreCliCod = &SerCliCod
					where CreSerItmCod = &SerItmCod
					where CreRecPag = &SerItmRecPag
					where CreDtaVct.Month() = &DataVencimento.Month() and CreDtaVct.Year() = &DataVencimento.Year() //verificar, inicio mes 12 e dup mes 01
					&SerDupNro = CreDupNro
					&SerDtaEms = CreDtaEms
					&SerDtaVct = CreDtaVct
					&CreVlrDup = CreVlrDup
					&CreVlrSdo = CreVlrSdo
					&CreCbrCod = CreCbrCod			
					&CrePlanCod = CrePlanCod
					&CreCod = CreCod
					&CreBloNro = CreBloNro
					&CreSts = CreSts
					&CreRecPag = CreRecPag
					Do 'GravaTmp'
				When none				// ABV /2019
					&SerDupNro = 'C.' + &SerItmAbv + /*trim(str(&SerItmCod)) +*/ ' /'  + trim(str(&DataVencimento.Year())) //+ '/' + trim(str(&Count))
					&SerDtaEms = serverdate()
					&SerDtaVct = &DataVencimento
					&CreCbrCod = &SerItmCbrCod
					&CrePlanCod = &SerItmPlanCod
					&CreCod = 0
					&CreVlrDup = &SerItmVlr
					&CreVlrSdo = &SerItmVlr
					&CreRecPag = &SerItmRecPag
					Do 'GravaTmp'
				EndFor
				&AuxDataVencimento = &DataVencimento
				&DataVencimento = &DataVencimento.AddYears(1)
				&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
				
				if &DataVencimento.IsEmpty()
					&AuxDataVencimento = YmDToD(&AuxDataVencimento.Year() + 1, &AuxDataVencimento.Month(), 1)
					&AuxData = EoM(&AuxDataVencimento)
					&UltDiaMes = &AuxData.Day()
					&DataVencimento = YmDToD(&AuxDataVencimento.Year() + 1, &AuxDataVencimento.Month(), &UltDiaMes)
				EndIf	
			EndIf
		EndFor
		
	//---------------------------------------------------------------------------------------------------------------------
		
		
		
		
		
		
		
		//PREVISAO		
	case &SerItmTip = TipoLancamentoServico.PREVISAO and &SerItmTipPlan = TipoPlano.MENSAL
		
		For &Count = 1 TO &SerItmQtdMes //step 1
			
			if &DataVencimento <= &SerItmDtaFim or &SerItmDtaFim.IsEmpty()
				For each order EmpCod, FilCod, CreCliCod, CreSerItmCod, CreRecPag, CreCod
					where EmpCod = &EmpCod
					where FilCod = &FilCod
					where CreCliCod = &SerCliCod
					where CreSerItmCod = &SerItmCod
					where CreRecPag = &SerItmRecPag
					where CreDtaVct.Month() = &DataVencimento.Month() and CreDtaVct.Year() = &DataVencimento.Year() //verificar, inicio mes 12 e dup mes 01
					&SerDupNro = CreDupNro
					&SerDtaEms = CreDtaEms
					&SerDtaVct = CreDtaVct
					&CreVlrDup = CreVlrDup
					&CreVlrSdo = CreVlrSdo
					&CreCbrCod = CreCbrCod			
					&CrePlanCod = CrePlanCod
					&CreCod = CreCod
					&CreBloNro = CreBloNro
					&CreSts = CreSts
					&CreRecPag = CreRecPag
					Do 'GravaTmp'
				When none
					&SerDupNro = 'P.' +&SerItmAbv + /* + trim(str(&SerCliCod)) + */ ' - ' + trim(str(&DataVencimento.Year())) + '/' + trim(str(&DataVencimento.Month()))
					&SerDtaEms = serverdate()
					&SerDtaVct = &DataVencimento
					&CreCbrCod = &SerItmCbrCod
					&CrePlanCod = &SerItmPlanCod
					&CreCod = 0
					&CreVlrDup = &SerItmVlr
					&CreVlrSdo = &SerItmVlr
					&CreRecPag = &SerItmRecPag
					Do 'GravaTmp'
				EndFor
				&AuxDataVencimento = &DataVencimento
				&DataVencimento = &DataVencimento.AddMonths(1)
				&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
				
				if &DataVencimento.IsEmpty()
					&AuxDataVencimento = YmDToD(&AuxDataVencimento.Year(), &AuxDataVencimento.Month(), 1)
					&AuxDataVencimento = &AuxDataVencimento.AddMonths(1)
					&AuxData = EoM(&AuxDataVencimento)
					&UltDiaMes = &AuxData.Day()
					&DataVencimento = YmDToD(&AuxDataVencimento.Year(), &AuxDataVencimento.Month(), &UltDiaMes)
				EndIf	
			EndIf
		EndFor
	//---------------------------------------------------------------------------------------------------------------------
	
		
	case &SerItmTip = TipoLancamentoServico.PREVISAO and &SerItmTipPlan = TipoPlano.ANUAL
		
			For &Count = 1 to &QtdAnos //step 1
				
				if &DataVencimento <= &SerItmDtaFim or &SerItmDtaFim.IsEmpty()
					For each order EmpCod, FilCod, CreCliCod, CreSerItmCod, CreRecPag, CreCod
						where EmpCod = &EmpCod
						where FilCod = &FilCod
						where CreCliCod = &SerCliCod
						where CreSerItmCod = &SerItmCod
						where CreRecPag = &SerItmRecPag
						where CreDtaVct.Month() = &DataVencimento.Month() and CreDtaVct.Year() = &DataVencimento.Year() 
						&SerDupNro = CreDupNro
						&SerDtaEms = CreDtaEms
						&SerDtaVct = CreDtaVct
						&CreVlrDup = CreVlrDup
						&CreVlrSdo = CreVlrSdo
						&CreCbrCod = CreCbrCod			
						&CrePlanCod = CrePlanCod
						&CreCod = CreCod
						&CreBloNro = CreBloNro
						&CreSts = CreSts
						&CreRecPag = CreRecPag
						Do 'GravaTmp'
					When none		
						&SerDupNro = 'P.' + &SerItmAbv + /*trim(str(&SerCliCod)) + */ ' - ' + trim(str(&DataVencimento.Year())) //+ '/' + trim(str(&Count))
						&SerDtaEms = serverdate()
						&SerDtaVct = &DataVencimento
						&CreCbrCod = &SerItmCbrCod
						&CrePlanCod = &SerItmPlanCod
						&CreCod = 0
						&CreVlrDup = &SerItmVlr
						&CreVlrSdo = &SerItmVlr
						&CreRecPag = &SerItmRecPag
						Do 'GravaTmp'
					EndFor
					&AuxDataVencimento = &DataVencimento
					&DataVencimento = &DataVencimento.AddYears(1)
					&DataVencimento = YmDToD(&DataVencimento.Year(), &DataVencimento.Month(), &SerItmDiaVct)
					
					if &DataVencimento.IsEmpty()
						&AuxDataVencimento = YmDToD(&AuxDataVencimento.Year() + 1, &AuxDataVencimento.Month(), 1)
						&AuxData = EoM(&AuxDataVencimento)
						&UltDiaMes = &AuxData.Day()
						&DataVencimento = YmDToD(&AuxDataVencimento.Year() + 1, &AuxDataVencimento.Month(), &UltDiaMes)
					EndIf	
				EndIf
			EndFor
	
EndCase

Commit	

Sub 'GravaTmp'
	New
		DupTmpEmpCod = &EmpCod
		DupTmpFilCod = &FilCod
		DupTmpCreCod = &Count
		DupTmpPesCod = &PesCod
		DupTmpCreNovCliRaz = &SerCliNom
		DupTmpCreVenCod = &SerItmCod  // USANDO ESTA CAMPO PARA SerItmCod
		DupTmpCreDupNro = &SerDupNro
		DupTmpCreDtaEms = &SerDtaEms
		DupTmpCreDtaVct = &SerDtaVct  
		DupTmpCreVlrDup = &CreVlrDup //&SerItmVlr 
		DupTmpCreVlrSdo = &CreVlrSdo //&SerItmVlr
		DupTmpCreCliCod = &SerCliCod 	
		DupTmpCreRecPag = &SerItmRecPag // &CreRecPag 
		DupTmpCreCbrCod = &CreCbrCod
		DupTmpCreBloNro = &CreBloNro
		DupTmpCrePlanCod = &CrePlanCod
		DupTmpCreFilPgt = &SerFilCod
		DupTmpCreCodAlt = &CreCod
		
		do case
			case &CreVlrDup <> &CreVlrSdo and &CreSts = Status_Duplicata.ATIVO
				DupTmpCreSts = 'P'
				
			case /*&CreVlrDup = &CreVlrSdo and*/ &CreSts = Status_Duplicata.ATIVO
				DupTmpCreSts = 'A' // &DupTmpCreSts depois alterar pra variavel, se tiver paga no for each etc
				
			case &CreSts = Status_Duplicata.CANCELADA
				DupTmpCreSts = 'C'
				
			otherwise 
				DupTmpCreSts = 'A'
		EndCase
	EndNew

EndSub
]]></Source>
