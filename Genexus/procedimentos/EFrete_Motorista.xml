      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//Parametros Para Gravar
&MotoristasServiceGravarRequest.Integrador = Trim(&FilFrtHash)
&MotoristasServiceGravarRequest.Token = trim(&Token)
&MotoristasServiceGravarRequest.Versao = 2
&Mensg = ''
&Erro = 0

csharp System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 | System.Net.SecurityProtocolType.Tls11 | System.Net.SecurityProtocolType.Tls;
Do 'GetMotorista'

Do 'GravarMotorista'

Sub 'GravarMotorista'
	If &MotoristasServiceGravarRequest.Telefones.Celular.Numero.IsEmpty()
		Msg('Atenção! Telefone Celular é obrigatório no cadastro de Motorista.')
	Else
//		HostWebServiceEfrete.Call(&EmpWebHost, &EmpWebBaseUrl, &EmpWebPor,&Isecure)
		&Location = GetLocation('MotoristasService') //objeto externo onde foi importado o WSDL no GX XEV1 
		&Location.Host = &EmpWebHost 	     //servidor 
		&Location.BaseUrl = &EmpWebBaseUrl //diretório virtual do serviço 
		&Location.Port = &EmpWebPor
		If &IsSecure = true
			&Location.Secure = 1
		ELSE
			&Location.Secure = 0 //false 
		EndIf 		       //false 
		&Location.CancelOnError = 2 	   //tratar exceção do WS 	
		&MotoristasServiceGravarResponse = &MotoristasService.Gravar(&MotoristasServiceGravarRequest)
		
		padraoUsuario.Call('G', '#EFRETEMOTORISTA', &Context.PesCod, &Context.EmpCod, &MotoristasServiceGravarRequest.ToXml(), &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
		padraoUsuario.Call('G', '#EFRETEMOTORISTARESPOSTA', &Context.PesCod, &Context.EmpCod, &MotoristasServiceGravarResponse.ToXml(), &PadDtaMod) //GRAVA NO PADRÃO USUARIO PARA FORMAR UM LOG DE CONEXÃO E VERIFICAR ERROS.
		
		If GetSOAPErr()= 0 // Resposta do Obter Motorista
			If &MotoristasServiceGravarResponse.Sucesso = True
				&Mensg = 'Gravado com Sucesso '+ &MotoristasServiceGravarResponse.Excecao.Mensagem
				Do 'AtualizaMotorista'
			Else
				&Mensg = &MotoristasServiceGravarResponse.Excecao.Mensagem
			EndIf
		Else 
			&Erro = val(str(GetSOAPErr()))
			&Mensg += 'DESC. ERRO:'+GetSOAPErrMsg() 
		EndIf
	EndIf
EndSub

Sub 'GetMotorista'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		
		&MotoristasServiceObterRequest.CNH               = val(PesCnh)
		&MotoristasServiceObterRequest.CPF				 = val(RetornasoNumeros.Udp(PesCpf))
		&MotoristasServiceGravarRequest.CNH              = VAL(PesCnh)
		&MotoristasServiceGravarRequest.CPF              = Val(RetornasoNumeros.Udp(PesCpf))
		&MotoristasServiceGravarRequest.Nome             = trim(PesRaz)
		&MotoristasServiceGravarRequest.Endereco.Rua     = trim(PesLog)
		&MotoristasServiceGravarRequest.Endereco.Bairro  = trim(PesBai)
		&MotoristasServiceGravarRequest.Endereco.CEP     = PesCep
		&MotoristasServiceGravarRequest.Endereco.Numero  = PesNro
		&MotoristasServiceGravarRequest.DataNascimento   = PesDtaNas
		&MotoristasServiceGravarRequest.Endereco.Complemento = trim(PesCpl)
		&MotoristasServiceGravarRequest.Endereco.CodigoMunicipio = PesCidIBGE
		&MotoristasServiceGravarRequest.NomeDeSolteiraDaMae = trim(PesMaeNom)
		
		For each Order EmpCod,PesCod
			Do case
				Case PesFonTpo = TipoTelefone.CELULAR or PesFonTpo = TipoTelefone.CELULAR_WHATS
					&MotoristasServiceGravarRequest.Telefones.Celular.DDD = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),1,2))
					&MotoristasServiceGravarRequest.Telefones.Celular.Numero = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),3,20))
				Case PesFonTpo = TipoTelefone.COMERCIAL or PesFonTpo = TipoTelefone.RESIDENCIAL or PesFonTpo = TipoTelefone.OUTROS
					&MotoristasServiceGravarRequest.Telefones.Fixo.DDD = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),1,2))
					&MotoristasServiceGravarRequest.Telefones.Fixo.Numero = val(SubStr(RetornaSoNumeros.Udp(PesFonNum),3,20)) 
			EndCase
		EndFor
		exit
	EndFor
EndSub

Sub 'AtualizaMotorista'
	For each Order EmpCod,PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		PesStsEfr = Status_EFrete.Homologado
	EndFor
EndSub
]]></Source>
