      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where PedTmpBanCod = &PedTmpBanCod
	Where PedTmpAgeCod = &PedTmpAgeCod
	Where PedTmpConCod = &PedTmpConCod
	Where PedTmpFrpPgtoCod = &PedTmpFrpPgtoCod
	Where PedTmpDupNro = &PedTmpDupNro
	Where PedTmpDupVlr > 0
	&PedTmpDupCod = PedTmpDupCod
	Exit
EndFor

]]></Source>
