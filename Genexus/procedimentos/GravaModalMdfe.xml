      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod  = &EmpCod
	Where FilCod  = &FilCod
	Where MDFeCod = &MDfeCod
	MDFeRNTRC   = &MDFeRNTRC
	MdfeConCnpj = &MdfeConCnpj
	MdfeConRaz  = &MdfeConRaz
	MdfePosVale = &MdfePosVale
	MDFePgtFrt  = &MDFePgtFrt
	MDFeTomFrt  = &MDFeTomFrt
	MdfeInfPagFrtCnpj = &MdfeInfPagFrtCnpj
	MdfeInfPagFrtRaz = &MdfeInfPagFrtRaz
	
	
	MdfeCatComVei = &MdfeCatComVei

	MdfePgtFrtForPgt = &MdfePgtFrtForPgt
	MdfePgtFrtBanCod = trim(&MdfePgtFrtBanCod)
	MdfePgtFrtBanAge = trim(&MdfePgtFrtBanAge)
	MdfePgtFrtBanCnpj = &MdfePgtFrtBanCnpj
	MdfePgtFrtTot = &MdfePgtFrtTot

	MdfePgtFrtVlrAdi = &MdfePgtFrtVlrAdi
	MdfePgtFrtChvPix = &MdfePgtFrtChvPix
	exit
EndFor


//###################################################################################### PAGAMENTO 
&MdfePgtFrtCod = 0
For Each Order EmpCod, FilCod, MDFeCod,(MdfePgtFrtCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDfeCod
	delete
EndFor

If &MdfePgtFrtVlrPed > 0 
	&MdfePgtFrtCod+= 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDfeCod
		MdfePgtFrtCod = &MdfePgtFrtCod
		MdfePgtFrtTip = TipoPagamentoFrete.ValePedagio
		MdfePgtFrtVlr = &MdfePgtFrtVlrPed
	Endnew
commit
EndIf

If &MdfePgtFrtVlrTxa > 0 
	&MdfePgtFrtCod+= 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDfeCod
		MdfePgtFrtCod = &MdfePgtFrtCod
		MdfePgtFrtTip = TipoPagamentoFrete.Impostos
		MdfePgtFrtVlr = &MdfePgtFrtVlrTxa
	Endnew
commit
EndIf


If &MdfePgtFrtVlrBan > 0 
	&MdfePgtFrtCod+= 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDfeCod
		MdfePgtFrtCod = &MdfePgtFrtCod
		MdfePgtFrtTip = TipoPagamentoFrete.Despesas
		MdfePgtFrtVlr = &MdfePgtFrtVlrBan
	Endnew
	commit
EndIf

If &MdfePgtFrtVlrOut > 0 
	&MdfePgtFrtCod+= 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDfeCod
		MdfePgtFrtCod = &MdfePgtFrtCod
		MdfePgtFrtTip = TipoPagamentoFrete.Outros
		MdfePgtFrtVlr = &MdfePgtFrtVlrOut
		MdfePgtFrtDes = &MdfePgtFrtDes
	Endnew
	commit
EndIf


If &MdfePgtFrtVlrFre > 0 
	&MdfePgtFrtCod+= 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		MDFeCod = &MDfeCod
		MdfePgtFrtCod = &MdfePgtFrtCod
		MdfePgtFrtTip = TipoPagamentoFrete.Frete
		MdfePgtFrtVlr = &MdfePgtFrtVlrFre
	Endnew
	commit
EndIf

//##############################################################################################


For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDfeCod
	Where MdfeSegCod = 1
	
	If MdfeSegResCnpj.Trim().IsEmpty()
		MdfeSegResCnpj = &MdfeConCnpj
	EndIf
	Exit
EndFor

For Each Order EmpCod, FilCod, MDFeCod,MdfePedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDfeCod
	Where MdfePedCod = 1
	
	MdfePedCnpjFor = &MdfePedCnpjFor
	MdfePedNroCom  = &MdfePedNroCom
	MdfePedResPag  = &MdfePedResPag
	MdfePedVlr     = &MdfePedVlr
	MdfePedTip       = &MdfePedTip
	
	exit
When none
	New
		EmpCod         = &EmpCod
		FilCod         = &FilCod
		MDFeCod        = &MDfeCod
		MdfePedCod     = 1
		MdfePedCnpjFor = &MdfePedCnpjFor
		MdfePedNroCom  = &MdfePedNroCom
		MdfePedResPag  = &MdfePedResPag
		MdfePedVlr     = &MdfePedVlr
		MdfePedTip       = &MdfePedTip
	EndNew

EndFor

commit
]]></Source>
