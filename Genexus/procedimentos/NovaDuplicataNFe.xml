      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
Do Case
	Case &OqueFazer = 'ALT'
		For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeDupItmCod = &inNfeDupItmCod
			
			if not &NfeDupNro.IsEmpty()
				NfeDupNro = &NfeDupNro
			Endif
		
			NfeDupVlr = &NfeDupVlr	
			NfeDupVct = &NfeDupVct
			NfeCbrCod = &NfeCbrCod
			
			Exit
		EndFor
	
		Commit
	
	Case &OqueFazer = 'ADD'
		&NfeDupItmCod = 0 
		For Each Order EmpCod, FilCod, NfeCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			
			&NfeNum = NfeNum
			&CreCbrCod = FilCbrCod
			&CreVlrDup = NfeVlrTot
			&NfeCLiCod = NfeCliCod
			do 'GetCliente'
			
			For Each Order EmpCod, FilCod, NfeCod, (NfeDupItmCod)
				&NfeDupItmCod = NfeDupItmCod
				&CreVlrDup = NfeDupVlr
				&CreCbrCod = NfeCbrCod
				Exit
			EndFor
			Exit
		EndFor
	
		&NfeDupItmCod += 1
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			NfeCod = &NfeCod
			NfeDupItmCod = &NfeDupItmCod	
			
			NfeDupCreSeq = 0
			NfeDupFiLCod = 0
			
			//PedTmpTipDup = TipoDuplicata.DUPLICATA
			
			&AuxCreDupNro = trim(str(&NfeNum)) +'-'+ltrim(str(&NfeDupItmCod))
			NfeDupNro =  trim(&AuxCreDupNro)
			NfeDupVlr = &CreVlrDup
			
			NfeDupVct.SetEmpty()
			
			//&PedTmpSem = substr(cdow(&CreDtaVct(&Parcela)), 1, 3)
			//PedTmpSem = &PedTmpSem
			
			//&PedTmpPrz = (&CreDtaVct(&Parcela) - &PedDtaFat) 
			//PedTmpPrz = &PedTmpPrz
			
		    do Case
				Case &CreCbrCod <> 0
					NfeCbrCod = &CreCbrCod
				Case &PedCliCbrCod = 0
			        NfeCbrCod = 1
			    Otherwise
			        NfeCbrCod = &PedCliCbrCod
		    EndCase
		EndNew
	
		commit
		
	Case &OqueFazer = 'DEL'
		For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod
			Where EmpCod = &EmPCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			Where NfeDupItmCod = &inNfeDupItmCod
			&NfeDupFiLCod = NfeDupFiLCod
			&NfeDupCreSeq = NfeDupCreSeq
			
			delete
			Exit
		EndFor
	
		commit

//		&NfeDupFiLCod = NfeDupFiLCod
//		&NfeDupCreSeq = NfeDupCreSeq
EndCase


sub 'GetCliente'
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &NfeCliCod
		&PedCliCbrCod = PesCbrCod
		Exit
	EndFor
EndSub
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
