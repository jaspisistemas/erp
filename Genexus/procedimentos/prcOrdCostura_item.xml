      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each Order EmpCod, OcsCod, OcsItm
	Where EmpCod = &EmpCod
	Where OcsCod = &OcsCod
	Where OcsItm = &OcsItm
	
	OcsProCod = &OcsProCod
	OcsProGraCod = &OcsProGraCod
	OcsQtd = &OcsQtd
	OcsNfeProItem = &OcsNfeProItem
	
	OcsProGraNom = &OcsProGraNom
	OcsProNroCor = &OcsProNroCor
	
	Exit
When None
	
	For Each Order EmpCod, OcsCod, (OcsItm)
		Where EmpCod = &EmpCod
		Where OcsCod = &OcsCod
		
		&AuxOcsItm = OcsItm
		Exit
	EndFor
	&AuxOcsItm += 1
	
	new
		EmpCod = &EmpCod
		OcsCod = &OcsCod
		OcsItm = &AuxOcsItm
		OcsProCod = &OcsProCod
		OcsProGraCod = &OcsProGraCod
		OcsQtd = &OcsQtd
		OcsNfeProItem = &OcsNfeProItem
		OcsProGraNom = &OcsProGraNom
		OcsProNroCor = &OcsProNroCor
	EndNew

	Commit
	
	do 'addEtapas'

EndFor



Commit


sub 'addEtapas'
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &OcsProCod		
		
		&grupCod = GrupCod
		Exit
	EndFor

	
	For Each Order EmpCod, GrupCod, GrupCTrOrd
		Where EmpCod = &EmpCod
		Where GrupCod = &grupCod
		
		new
			EmpCod = &EmpCod
			OcsCod = &OcsCod
			OcsItm = &AuxOcsItm
			
			OcsEtpItm = GrupCTrOrd
			OcsEtpGrupCod = GrupCTrCod
			OcsEtpQtd = GrupCTrQtd
			
		EndNEw
		
	EndFor

	Commit
EndSub
]]></Source>
