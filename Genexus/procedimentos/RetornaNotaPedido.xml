      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&NfeNum.SetEmpty()
&NfeQtdVol.SetEmpty()
&NfePesBrt.SetEmpty()


For Each Order EmpCod, NfeFilCod, NfePedCod, NfeEntSai,NfeSts, (NfeCod)
	Where EmpCod = &EmpCod
	Where NfeFilCod = &FilCod
	Where NfePedCod = &PedCod
	 Where NfeEntSai = &NfeEntSai
    Where NfeSts = Status_NFe.Autorizada when &NfeEntSai <> Status_EntradaSaida.Entrada
    Where (NfeTraCod = &NfeTraCod) when &NfeEntSai <> Status_EntradaSaida.Entrada and &NfeTraCod <> 0
    &NfeNum = NfeNum
	&NfeQtdVol = NfeQtdVol
	&NfePesBrt = NfePesBrt
    exit
When none
    &NfeNUm = 0
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
