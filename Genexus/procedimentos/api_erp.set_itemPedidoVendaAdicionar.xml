      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

If &IsAcessoConcedido = true //Acesso concedido
	
	Do CAse
		CAse &AdicionarDiminuir = 'A'
			&IsTrueFalse = true
		CAse &AdicionarDiminuir = 'D'
			&IsTrueFalse = false
			
		Case &ProGraRef.IsEmpty()
			&QtdErros += 1
			&sdtRetornoWbsEtc.Sts = 'E' + padL(trim(str(&QtdErros)), 3, '0')
			&sdtRetornoWbsEtc.Obs += 'Produto não selecionado! '
			return
			
		Otherwise
			&QtdErros += 1
			&sdtRetornoWbsEtc.Sts = 'E' + padL(trim(str(&QtdErros)), 3, '0')
			&sdtRetornoWbsEtc.Obs += 'Operação não localizada! '
			return
	EndCase

	RetornaConfSistema_wwpVendas_3.Call(&wwpContext.EmpCod, &FilCod, &sdtConfig_wwpVendas_3) //RETORNA TODAS AS CONFIG
	
	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod		
			&PedSts = PedSts
			&LctRetCus = LctRetCus
			&TabCod = TabCod 
			&TabPrmCod = TabPrmCod
			&TabColCod = TabColCod
			&PedDtaEms = PedDtaEms 
			&PedPerSrv1 = PedPerSrv1 
			&PedPerSrv2 = PedPerSrv2 
			&PedPerPrm1 = PedPerPrm1 
			&PedPerPrm2 = PedPerPrm2 
			&PedPerSpm1 = PedPerSpm1
			&PedPerSpm2 = PedPerSpm2
		Exit
	EndFor

	GravaItemAumentarDiminuir_api.Call(&DevRandon, &wwpContext.EmpCod, &FilCod, &PedCod, &ProGraRef, &IsTrueFalse, &QuantoTemPedQtd, &sdtConfig_wwpVendas_3.TCon052_ServicoDuplicadoVenda, &sdtConfig_wwpVendas_3.Tcon053_ProdutoDuplicadoVenda, &PedSts ,&LctRetCus , &TabCod ,&TabPrmCod ,&TabColCod,&PedDtaEms ,&PedPerSrv1 ,&PedPerSrv2 ,&PedPerPrm1 ,&PedPerPrm2 ,&PedPerSpm1,&PedPerSpm2, &wwpContext.UserName, &sdtRetornoWbsEtc)
Endif
]]></Source>
