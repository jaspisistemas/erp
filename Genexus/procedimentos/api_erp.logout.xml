      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizarTabelas, &wwpContext)

if &IsAcessoConcedido = true
	&sdtSetVersao.sts = 'J200'
	&sdtSetVersao.obs = 'Logout realizado'
	
	
	//verifica acesso sessao
	For Each Order DeviceId, DevRandon //CONEXAO
		Where DevRandon = &DevRandon
		
		if DevSts = status_AtivoInativo.ATIVO
			
			DevSts = status_AtivoInativo.INATIVO
			
			DevRandonUltSync = serverNow()
		Endif
		
		exit
	EndFor
	
	commit
	
EndIf

]]></Source>
