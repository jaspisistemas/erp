      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For each Order EmpCod,CrePedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CrePedCod = &CrePedCod
	Where CreSts <> Status_Duplicata.CANCELADA
	
	Do Case
		Case CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
			&CarCreVlrDup += CreVlrDup
		Case CreFrpPgtoTip = TipoDuplicata.DINHEIRO
			&DinCreVlrDup += CreVlrDup
		Case CreFrpPgtoTip = TipoDuplicata.DUPLICATA
			&DupCreVlrDup += CreVlrDup
		Case CreFrpPgtoTip = TipoDuplicata.CHEQUEP
			&ChePCreVlrDup += CreVlrDup
		Case CreFrpPgtoTip = TipoDuplicata.CHEQUET
			&CheTCreVlrDup += CreVlrDup	
	EndCase

EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
