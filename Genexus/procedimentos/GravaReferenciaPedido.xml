      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &OqueFazer = 'ADD'
	For Each Order EmpCod, FilCod, PedCod, PedRefPesCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedRefPesCod = &PEsCod
		
		Exit
	When None
		&PedRefCod = 0
		For Each Order EmpCod, FilCod, PedCod, (PedRefCod)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where PedCod = &PedCod
			&PedRefCod = PedRefCod
			Exit
		EndFor
		&PedRefCod += 1
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			PedCod = &PedCod
			PedRefCod = &PedRefCod
			PedRefPesCod = &PEsCod
		EndNEw
		
		Commit
	EndFor
Else
	For Each Order EmpCod, FilCod, PedCod, PedRefCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where PedCod = &PedCod
		Where PedRefCod = &inPedRefCod
		
		Delete
		Exit
	EndFor

	commit
EndIF

]]></Source>
