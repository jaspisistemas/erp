      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod,TlvCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where TlvCod = &TlvCod
	DgnTlvAtv = &DgnTlvAtv
When none
	
	New //diagnostico
		
		EmpCod = &EmpCod
		ProCod = &ProCod
		TlvCod = &TlvCod
		DgnTlvAtv = &DgnTlvAtv
	EndNew
	
	commit
EndFor


For Each Order EmpCod, ProCod,TlvCod,InfCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where TlvCod = &TlvCod
	Where InfCod = &InfCod
	
	DgnInfDosAlq = &DgnInfDosAlq
	DgnInfAplMax = &DgnInfAplMax
	DgnInfDiaCar = &DgnInfDiaCar
	DgnInfDosMax = &DgnInfDosMax
	DgnInfDosMin = &DgnInfDosMin
	DgnInfTraSem = &DgnInfTraSem
	DgnInfUniUsoCod = &DgnInfUniUsoCod
	DgnInfUniUsoNom = &DgnInfUniUsoNom
	DgnInfSts = &DgnInfSts
	DgnQtdVol = &DgnQtdVol
	
When none
	New //diagnosticoInfestacao
		EmpCod = &EmpCod
		ProCod = &ProCod
		TlvCod = &TlvCod
		InfCod = &InfCod
		
		DgnInfDosAlq = &DgnInfDosAlq
		DgnInfAplMax = &DgnInfAplMax
		DgnInfDiaCar = &DgnInfDiaCar
		DgnInfDosMax = &DgnInfDosMax
		DgnInfDosMin = &DgnInfDosMin
		DgnInfTraSem = &DgnInfTraSem
		DgnInfSts = &DgnInfSts
		DgnQtdVol = &DgnQtdVol
		DgnInfUniUsoCod = &DgnInfUniUsoCod
		DgnInfUniUsoNom = &DgnInfUniUsoNom
		
	EndNew
	Commit
EndFor


&RcmTip = Recomendacao.Diagnostico
&RcmNom = &Diagnostico
&RcmCod = 1
do 'Diagnosticorecomendacao'

&RcmTip = Recomendacao.EPI
&RcmNom = &EPI
&RcmCod = 2
do 'Diagnosticorecomendacao'

&RcmTip = Recomendacao.intevaloseguranca
&RcmNom = &intevaloseguranca
&RcmCod = 3
do 'Diagnosticorecomendacao'

&RcmTip = Recomendacao.modalidadeEpoca
&RcmNom = &modalidadeEpoca
&RcmCod = 4
do 'Diagnosticorecomendacao'

&RcmTip = Recomendacao.Orientacaomanejo
&RcmNom = &Orientacaomanejo
&RcmCod = 5
do 'Diagnosticorecomendacao'

&RcmTip = Recomendacao.OutrasInfo
&RcmNom = &OutrasInfo
&RcmCod = 6
do 'Diagnosticorecomendacao'


&RcmTip = Recomendacao.Precaucoes
&RcmNom = &Precaucoes
&RcmCod = 7
do 'Diagnosticorecomendacao'

&RcmTip = Recomendacao.modalidadeEpocaAerea
&RcmNom = &modalidadeEpocaAerea
&RcmCod = 8
do 'Diagnosticorecomendacao'

Sub 'Diagnosticorecomendacao'
	For Each Order EmpCod, ProCod,TlvCod,InfCod,RcmCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where TlvCod = &TlvCod
		Where InfCod = &InfCod
		Where RcmCod = &RcmCod
		RcmNom = &RcmNom
		exit
	When none
		
		New // Diagnostico Recomendação
			EmpCod = &EmpCod
			ProCod = &ProCod
			TlvCod = &TlvCod
			InfCod = &InfCod
			RcmCod = &RcmCod
			RcmNom = &RcmNom
			RcmTip = &RcmTip
		EndNew
		commit
	EndFor
EndSub

]]></Source>
