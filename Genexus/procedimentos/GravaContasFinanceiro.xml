      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each order EmpCod,CtabanCod,CtaFunCod
	where EmpCod = &EmpCod
	where CtabanCod = &CtaBanCod
	where CtaFunCod = &CtaFunCod
	where CtaFunIs = true //SubType PesIsFun
	
	CtaFunIsPad = &CtaFunIsPad
	CtaFunIsRec = &CtaFunIsRec
	CtaFunIsPag = &CtaFunIsPag
	CtaFunIsCx = &CtaFunIsCx
	
	exit
when none
	Do 'New'
EndFor

Commit

Sub 'New'		
	New 
		EmpCod = &EmpCod
		CtabanCod = &CtaBanCod
		CtaFunCod = &CtaFunCod
		CtaFunIsPad = &CtaFunIsPad
		CtaFunIsRec = &CtaFunIsRec
		CtaFunIsPag = &CtaFunIsPag
		CtaFunIsCx = &CtaFunIsCx
	EndNew
EndSub
]]></Source>
