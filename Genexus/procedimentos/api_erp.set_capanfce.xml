<Object parentGuid="bfc50589-8947-4552-847b-80bfdf8aee52" user="WIN-JEAN\jean.fae" versionDate="2024-08-09T17:52:38.0000000Z" lastUpdate="2024-08-07T16:24:35.0000000Z" checksum="372d8156e52f9504d556f193ea235127" fullyQualifiedName="api_erp.set_capanfce" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="b9fba204-93d7-41f4-882a-71b569c6ed1d" name="set_capanfce" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="set_capanfce" parent="api_erp.Notas" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	&SdtCapaNfe.FromJson(&Cadastro)
//	padraousuario.Call('G', 'set_cliente', 1, 1, &SdtCapaNfe.ToJson(), &PadDtaMod)
//	padraousuario.Call('G', 'set_cliente1', 1, 1, &Cadastro, &PadDtaMod)
	
	&AuxLongVarchar = &Cadastro
	&AuxLongVarchar = &AuxLongVarchar.Replace('"Emails":"[{', '"Emails":[{')
	&AuxLongVarchar = &AuxLongVarchar.Replace('"Fones":"[{', '"Fones":[{')
	&AuxLongVarchar = &AuxLongVarchar.Replace('}]"', '}]')
	
	&NfeCod = &SdtCapaNfe.nfeCod
	&EmpCod = &SdtCapaNfe.empCod
	&FilCod = &SdtCapaNfe.filCod
	

	if &NfeCod <> 0
		&OqueFazer = 'UPD'
		
		For Each ORder EmpCod, FilCod, NfeCod
			Where EmpCod = &EmpCod
			Where FilCod = &FiLCod
			Where NfeCod = &nfeCod
			
			&NfeDtaEms = NfeDtaEms
			&autNfeDadAdi = NfeDadAutAdi			
			&LctCod = NfeLctCod			
			&NfeFin = NfeFin
			&NfeHorEms = NfeHorEms
			&NfeSts = NfeSts
			
			if NfeSts <> Status_Nfe.Digitando and NfeProTer = Nota_ProPriaTerceira.PROPRIA
				&sdtRetornowbs.Sts = 'E020'
				&sdtRetornowbs.Obs = 'Nota já autorizada, edição bloqueada!'
				Return
			Endif
			
			Exit
		EndFor
	Else
		&OqueFazer = 'INS'
		&EmpCod = &wwpContext.EmpCod
		&NfeFin = NotaFinalidade.EmissaoNormal
		&NfeDtaEms = serverDate()
		&NfeHorEms = ServerTime()
		&NfeSts = Status_NFe.Digitando
		
		
		for Each Order EmpCod, LctCod
			Where EmpCod = &EmpCod 
			Where LctAtuSal = Status_EntradaSaida.Saida 
			where LctTip = TipoLancamento.SaidaMercadoria
			
			&LctCod = LctCod 
			Exit
		EndFor
	
	Endif
	
	&NfeNum = &SdtCapaNfe.nfeNum
	&NfeSer = &SdtCapaNfe.nfeSer
	//&SdtCapaNfe.nfeModCod
	
//	if &SdtCapaNfe.nfeDtaEmsSeg > 0
//		&NfeDtaEms = TimestampToDate.Udp(&SdtCapaNfe.nfeDtaEmsSeg)
//	Else
	if not &SdtCapaNfe.nfeDtaEms.IsEmpty()
		&dia = val(substr(&SdtCapaNfe.nfeDtaEms, 1, 2)) //DIA
		&mes = val(substr(&SdtCapaNfe.nfeDtaEms, 4, 2)) //MES
		&Ano = val(substr(&SdtCapaNfe.nfeDtaEms, 7, 4)) //ANO
		&NfeDtaEms = ymDtoD(&Ano, &mes, &Dia)
	Endif

	//&NfeHorEms
	
	//&NfeFin
	//&LctCod 
	&nfeCliCod = &SdtCapaNfe.nfeCliCod
	&NfeCliRaz = &SdtCapaNfe.nfeCliRaz
	&nfeCliCpf = &SdtCapaNfe.nfeCliCpf
	&nfeCliCnpj = &SdtCapaNfe.nfeCliCnpj
	&NfeCliTipPes.FromString(&SdtCapaNfe.nfeCliPesTip)
	&nfeCliEml = &SdtCapaNfe.nfeCliEml
	&NfeDadAdi = &SdtCapaNfe.nfeDadAdi
	//&SdtCapaNfe.nfeSts
	
	if &NfeCliTipPes = TipoPessoa.FISICA
		ValidaCpfCnpj.Call(&nfeCliCpf, &CpfStatus, 'N')
	Else
		ValidaCpfCnpj.Call(&nfeCliCnpj, &CnpjStatus, 'N')
	Endif

	&pattern = "^((\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*)|(\s*))$" // valid email address pattern
	
	 Do Case
		
		Case not &nfeCliEml.IsEmpty() and (&nfeCliEml.IsMatch(&pattern) = false)
			&sdtRetornowbs.Sts = 'E001'
			&sdtRetornowbs.Obs = 'Endereço de E-mail não coincide com o padrão especificado!'
			
		case &NfeCliTipPes.IsEmpty()
			&sdtRetornowbs.Sts = 'E002'
			&sdtRetornowbs.Obs = 'Não selecionado tipo Pessoa!'
			
		Case &NfeCliTipPes = TipoPessoa.JURIDICA and &CnpjStatus <> 0
			&sdtRetornowbs.Sts = 'E002'
			&sdtRetornowbs.Obs = 'CNPJ Inválido!'
			
		Case &NfeCliTipPes = TipoPessoa.FISICA and &CpfStatus <> 0
			&sdtRetornowbs.Sts = 'E002'
			&sdtRetornowbs.Obs = 'CPF Inválido!'
			
		Case &FiLCod.IsEmpty()
			&sdtRetornowbs.Sts = 'E003'
			&sdtRetornowbs.Obs = 'Filial não selecionada!'
			
		Case &NfeDtaEms.IsEmpty() or &NfeDtaEms > serverdate()
			&sdtRetornowbs.Sts = 'E004'
			&sdtRetornowbs.Obs = 'Data de emissão inválida!'
			
		Case &LctCod.IsEmpty()
			&sdtRetornowbs.Sts = 'E005'
			&sdtRetornowbs.Obs = 'Operação não selecionada!'
			
		Otherwise	
			
			if &NfeCliRaz.IsEmpty()
				&NfeCliRaz = 'VENDA A CONSUMIDOR'
				&nfeCliCod = 1
			EndIF

			GravaNotaFiscalModelo65_Capa.Call(&EmpCod, &FilCod, &NfeNum, &NfeDtaEms, &NfeHorEms, &NfeSer, &NfeFin, &LctCod, &NfeCliEml, &NfeCliCod, &NfeCliRaz, &NfeCliTipPes, &NfeCliCpf, &NfeCliCnpj, &NfeDadAdi, &autNfeDadAdi, &NfeCod)
			AtualizaTotaisNFe.Call(&EmpCod, &FilCod, &NfeCod, 0)
		
			if &NfeSts = Status_NFe.Digitando
				ObsAutomaticaNFe.call(&EmpCod, &FilCod, &NfeCod)
			EndIf
			
			&sdtRetornowbs.Sts = 'J200'
			if &OqueFazer = 'INS'
				&sdtRetornowbs.Obs = 'Capa NFCe, cadastrada com sucesso!'
			Else
				&sdtRetornowbs.Obs = 'Capa NFCe, atualizada com sucesso!'
			Endif
		
			&sdtRetornowbs.Detalhes = trim(&nfeCod.ToFormattedString())

	EndCase
Endif
]]></Source>
