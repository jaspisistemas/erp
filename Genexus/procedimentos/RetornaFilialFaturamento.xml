      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &PedFatFilCod 
	
	&FilFan = FilFan
	&FilRaz = FilRaz
	&FiLCidNom = FilCidNom.Trim() + ' - ' + trim(FilCidUfeCod)
	&FilLog = 'END: ' + trim(FilLog) + ', ' + trim(FilNro) + ' - ' + trim(FilBai)
	&FilCidNom = 'CIDADE: ' + trim(FilCidNom) + ' - ' + trim(FilCidUfeCod) + ' CEP: ' + trim(FilCep)
	
	If not FilCpj.IsEmpty()
		&Contato = 'CNPJ: '+ trim(FilCpj) 
	EndIF	
	if not FilInsEst.IsEmpty() and FilInsEst <> 'ISENTO'
		&Contato += ' IE: ' + trim(FilInsEst)
	EndIF	
	&Contato = &Contato.Trim()
	
	
	if not FilFonNum.IsEmpty()
		&Contato2 = 'Fone: '
		&Contato2 += trim(FilFonNum)
	EndIF
	if not FilFonNum2.IsEmpty()
		&Contato2 += ' / ' + trim(FilFonNum2)
	EndIF
	if not FilFonNum3.IsEmpty()
		&Contato2 += ' / ' + trim(FilFonNum3)
	EndIF

	if Not FilEml.IsEmpty()
		&Contato2 += ' E-MAIL: ' + trim(FilEml)
	EndiF
	if Not FilSit.IsEmpty()
		&Contato2 += ' SITE: ' + trim(FilSit)
	EndiF
	&Contato2 = &Contato2.Trim()
	
	if FilImg_LogRel.IsEmpty()
		&FilImg146_50.FromImage(FilialSemImagem)
	Else
		&FilImg146_50 = FilImg_LogRel
	EndIF
	
	Exit
EndFor
]]></Source>
