      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//RetornaPrimeiroCEST.Call(&NcmCod, &NcmCestCod)

//GRAVA LOG
&TabelaVarchar = 'PRODUTO'
&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
&LogErpRegTip = TrnMode.Update
//GRAVA LOG

For &SdtProdutosItem in &SdtProdutos
	&LogErpRegGUID.SetEmpty()
	&LogErpRegCod1 = trim(Str(&SdtProdutosItem.ProCod))
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &SdtProdutosItem.ProCod		
		
		if &IsTrocaCatImposto = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProCatCod', trim(toformattedString(ProCatCod)), trim(toformattedString(&CatCod)), &LogErpRegGUID )
			Endif
			ProCatCod = &CatCod
		EndIF
		
		if &IsTrocaGrupo = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'GrupCod', trim(toformattedString(GrupCod)), trim(toformattedString(&GrupCod)), &LogErpRegGUID )
			Endif
			GrupCod = &GrupCod
		EndIF
		
		If &IsTrocaSetor = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProSetCod', trim(toformattedString(ProSetCod)), trim(toformattedString(&SetCod)), &LogErpRegGUID )
			Endif
			ProSetCod = &SetCod
		EndIF
		
		If &IsTrocaNCM = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'NcmCod', trim(toformattedString(NcmCod)), trim(toformattedString(&NcmCod)), &LogErpRegGUID )
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProNcmCest', trim(toformattedString(ProNcmCest)), trim(toformattedString(&NcmCestCod)), &LogErpRegGUID )
			Endif
			NcmCod = &NcmCod			
			ProNcmCest = &NcmCestCod
		EndIF		
		
		if &IsTrocaMarca = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'MarCod', trim(toformattedString(MarCod)), trim(toformattedString(&MarCod)), &LogErpRegGUID )
			Endif
			MarCod = &MarCod
		EndIf
		
		if &IsTrocaEmbalagem = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProEmbCod', trim(toformattedString(ProEmbCod)), trim(toformattedString(&ProEmbCod)), &LogErpRegGUID )
			Endif
			ProEmbCod = &ProEmbCod
		EndIf
		
		if &IsTrocaTipoCusto = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProTipCus', trim(toformattedString(ProTipCus)), trim(toformattedString(&ProTipCus)), &LogErpRegGUID )
			Endif
			ProTipCus = &ProTipCus
		EndIf
	
		If &IsTrocaSolTec = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProReqVen', trim(ProReqVen.ToString()), trim(&ProReqVen.ToString()), &LogErpRegGUID )
			Endif
			ProReqVen = &ProReqVen
		EndIf
	
		If &IsTrocaSolCpl = True
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProInfCmp', trim(toformattedString(ProInfCmp)), trim(toformattedString(&ProInfCmp)), &LogErpRegGUID )
			Endif
			ProInfCmp = &ProInfCmp
		EndIf
		
		If &IsTrocaIMC = True
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProIMC', trim(toformattedString(ProIMC)), trim(toformattedString(&ProIMC)), &LogErpRegGUID )
			Endif
			ProIMC = &ProIMC
		EndIf
	
		if &IsTrocarCor = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProCorCod', trim(toformattedString(ProCorCod)), trim(toformattedString(&ProCorCod)), &LogErpRegGUID )
			Endif
			ProCorCod = &ProCorCod
		Endif
	
		if &IsTrocaTamanho = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProTam', trim(toformattedString(ProTam)), trim(toformattedString(&ProTam)), &LogErpRegGUID )
			Endif
			ProTam = &ProTam
		Endif
	
		If &IsTrocarDescMax = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProDesMax', trim(toformattedString(ProDesMax)), trim(toformattedString(&ProDesMax)), &LogErpRegGUID )
			Endif
			ProDesMax = &ProDesMax
		Endif	
	
		if &IsTrocaPeso = true
			if &LogErpTabIsLog = true
				prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProPesLiq', trim(toformattedString(ProPesLiq)), trim(toformattedString(&ProPesLiq)), &LogErpRegGUID )
			Endif
			ProPesLiq = &ProPesLiq
		Endif			
		
		ProDtaHorUltMod = now()
		
		Exit
	EndFor

	Commit
	
	//nao pode ser subbbmit
	GravaGradeProduto.call(&EmpCod, &SdtProdutosItem.ProCod, &AuxNcmCod)
	
	if &IsTrocaNCM = true
		AtualizaNcmNotas.Call(&EmpCod,&SdtProdutosItem.ProCod,&NcmCod, &NcmCestCod)
	Endif
EndFor
]]></Source>
