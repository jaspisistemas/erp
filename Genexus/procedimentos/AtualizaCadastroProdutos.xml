	in:&ProEmbCod, in:&IsTrocaTipoCusto, in:&ProTipCus,in:&IsTrocaSolTec,in:&ProReqVen,in:&IsTrocaSolCpl,in:&ProInfCmp, In:&IsTrocaIMC, In:&ProIMC, in:&wwpContextUserName, in:&IsTrocarCor, in:&ProCorCod, in:&IsTrocaTamanho, in:&ProTam, in:&IsTrocarDescMax, in:&ProDesMax, in:&NcmCestCod,
	in:&IsTrocaPeso, in:&ProPesLiq);
]]></Source>
