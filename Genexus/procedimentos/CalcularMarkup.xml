      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&novaMargem = 0
&Mensagem = '***'
IF &ValorCustoMoeda > 0 and &Percentual > 0
	
	if &TCon083_Markup = 'S'
		&ValorVenda =  round(&ValorCustoMoeda / (&Percentual/100) , &TCon108_CasasDecimais)
		if &ValorVenda > 0 
			&novaMargem = (&ValorCustoMoeda / &ValorVenda) * 100
			If &novaMargem < 0 or &novaMargem > 100
				&novaMargem = 0
			Endif
		EndiF
		&Mensagem = 'Mark: '+ trim(toformattedString(&novaMargem)) + ' %'
	Else
		&ValorVenda = round((&ValorCustoMoeda * ( 1 + (&Percentual/100))), &TCon108_CasasDecimais)
		if &ValorVenda > 0 and &ValorCustoMoeda > 0
			&novaMargem = ((&ValorVenda / &ValorCustoMoeda) * 100) - 100
			if &novaMargem < 0
				&novaMargem = 0
			Endif
		Endif
		&Mensagem = 'Acrs: '+ trim(toformattedString(&novaMargem)) + ' %'
	Endif
Endif
]]></Source>
