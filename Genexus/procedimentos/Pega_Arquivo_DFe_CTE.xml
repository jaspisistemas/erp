      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&mensagem = 'Pega o DF-e no arquivo: '
//000000000000186-000000000000186-procCTe
	
&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +"DFe\" + &FilCpj +'-'+padL(trim(&NroNSU),15,'0')+'-procCTe.xml'
&File.Source = &ArquivoPronto
if &File.Exists()
	&mensagem += &ArquivoPronto
Else
	&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +"DFe\" + &NroNSU +'-'+padL(trim(&NroNSU),15,'0')+'-procCTe.xml'
	&File.Source = &ArquivoPronto
	if &File.Exists()
		&mensagem += &ArquivoPronto
	Else
		&mensagem = 'Arquivo XML não encontrado'
		&SolMsg = &mensagem
		do 'Mensagem'
		return
	Endif
Endif

&ManXmlNfe = ''  // pega xml em uma variavel 
&XmlDFe.Open(&ArquivoPronto)    
Do While  not &XmlDFe.EOF
&ManXmlNfe += &XmlDFe.ReadRawXML()
&XmlDFe.Read()
Enddo
&XmlDFe.Close()

leituraXmlDacte.Call(&ManXmlNfe, &SdtXmlCte)
if not &SdtXmlCte.infCte.Id.IsEmpty()
	
	&ManCha = retornaSoNumeros.Udp(&SdtXmlCte.infCte.Id)
	
	if not &SdtXmlCte.infCte.emit.CNPJ.IsEmpty()
		&ManCpfCnpj = &SdtXmlCte.infCte.emit.CNPJ
	Else
		&ManCpfCnpj = &SdtXmlCte.infCte.emit.CPF
	Endif
	
	&ManRaz = &SdtXmlCte.infCte.emit.xNome
	
	&ManInsEst = &SdtXmlCte.infCte.emit.IE
	
	&Varchar = &SdtXmlCte.infCte.ide.dhEmi
	&ManDtaIni = YmdHmstoT(val(substr(&Varchar,1,4)),val(substr(&Varchar,6,2)),val(substr(&Varchar,9,2)),val(substr(&Varchar,12,2)),val(substr(&Varchar,15,2)),Val(substr(&Varchar,18,2)))
	
	do Case
		Case &SdtXmlCte.infCte.ide.toma03.toma = '0' and &SdtXmlCte.infCte.rem.CNPJ = &FilCpj
			&IsResponsavel = true
		Case &SdtXmlCte.infCte.ide.toma03.toma = '1' and &SdtXmlCte.infCte.exped.CNPJ = &FilCpj
			&IsResponsavel = true
		Case &SdtXmlCte.infCte.ide.toma03.toma = '2' and &SdtXmlCte.infCte.Receb.CNPJ = &FilCpj
			&IsResponsavel = true
		Case &SdtXmlCte.infCte.ide.toma03.toma = '3' and &SdtXmlCte.infCte.Dest.CNPJ = &FilCpj
			&IsResponsavel = true
		Case &SdtXmlCte.infCte.ide.toma04.CNPJ = &FilCpj //&SdtXmlCte.infCte.ide.toma03.toma = '4'
			&IsResponsavel = true
	EndCase
	
	Do CAse
		CAse &SdtXmlCte.infCte.dest.CNPJ = &FilCpj or &SdtXmlCte.infCte.Receb.CNPJ = &FilCpj
			&ManTip = EntradaSaida.Entrada
			
		Case  &SdtXmlCte.infCte.rem.CNPJ = &FilCpj or &SdtXmlCte.infCte.exped.CNPJ = &FilCpj
			&ManTip = EntradaSaida.Saida
			
		Otherwise
			&ManTip.SetEmpty()
	EndCase	
	
	&ManVal = val(&SdtXmlCte.infCte.vPrest.vTPrest)
	
	&ManDtaRcb = &Varchar
	
	&ManProt = &SdtXmlCte.protCTe.infProt.nProt
	
	Do CAse
		CAse &SdtXmlCte.protCTe.infProt.cStat = '100'
			&cSitNFe = 1
		CAse &SdtXmlCte.protCTe.infProt.cStat = '101'
			&cSitNFe = 3
		Otherwise
			&cSitNFe = 1
	EndCase
	
	if &IsResponsavel = true //So aparece se sou responsavel.
		&mensagem = 'Arquivo XML encontrado com sucesso'
		&SolMsg = &mensagem
		
		GravaManifestacao.call(&EmpCod,&FilCod,&ManCpfCnpj,&ManCha,&ManRaz,&ManInsEst,&ManDtaIni,&ManTip,&ManVal,&ManDtaRcb,&ManProt,&cSitNFe,&ArquivoPronto,&NroNSU, 'CTE', &outManCod)
		
		GravaXmlNotaCTe.Call(&EmpCod,&FilCpj, &NroNSU, &ManCha,&sdtConfiguracoesPasta, &IsExisteXml)
		do 'Mensagem'
	Endif
Endif

Sub 'Mensagem'
	msg(&mensagem  + ' Hora: ' + serverTime(),status)
EndSub
]]></Source>
