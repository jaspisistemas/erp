<Object parentGuid="50441e76-eb15-41e1-892a-9780d9c915d2" user="WINJEAN\jeanfae" versionDate="2026-01-16T18:04:52.0000000Z" lastUpdate="2026-01-16T17:13:41.0000000Z" checksum="4bd0bbd4b070f59e8dd0b34b8b4f1e14" fullyQualifiedName="api_erp.get_Filiais" moduleGuid="c56b15af-cf46-41da-a1f1-2c3f6547aca4" guid="a677a08a-dd40-4d3e-ad1a-552c708e2e5c" name="get_Filiais" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="get_Filiais" parent="api_erp.consultas" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)
//
if &IsAcessoConcedido = true //Acesso concedido
	&wwFilial.qtd = 0	
	&wwFilial.sts = 'J200'
	//&TipoFilial = 'D' 
	//D - Documento Fiscal
	//L - Lancamentos
	//C - Consultas
	
	//Retorna Ultima Filial selecionada
	PadraoUsuarioHora.Call('L', 'getFilialLancamentoApp'+&Padrao.Trim(), &wwpContext.PesCod, &wwpContext.EmpCod, &PadObs, &PadDtaMod, &PadDtaHorMod, 'P')
	if not &PadObs.IsEmpty()
		&AuxFilCod = val(&PadObs)
	EndIf

	Do CAse
		CAse &wwpContext.PesCod < 0
			For Each ORder EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilRaz like &FilRaz when not &FilRaz.IsEmpty()
				
				&wwFilial.qtd += 1
				
				&wwFilialItem = new()
				&wwFilialItem.FilCod = FilCod	 	
				&wwFilialItem.FilEmiNf = iif(FilAmbEms = tAmb.Producao, 1, 0)
				&wwFilialItem.FilRaz = iif(not FilNom.isempty() and not FilNom.IsNull(), trim(FilNom), trim(FilRaz))
				&wwFilial.Filiais.Add(&wwFilialItem)
				
				if FilCod = &AuxFilCod or &wwFilial.selFilCod.IsEmpty() 
					&wwFilial.selFilCod = FilCod
					&wwFilial.selFilRaz = iif(not FilNom.isempty() and not FilNom.IsNull(), trim(FilNom), trim(FilRaz))
				EndIf
			EndFor
			
		Case &wwpContext.PesCod > 0 
			For each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				//where PesFilAceNiv > 1 when &TipoFilial = 'L' //Lancamento
				//where PesFilAceNiv > 0 when &TipoFilial = 'C' //Consulta
				where (PesFilAceNiv > 1 and &TipoFilial = 'L') or PesFilAceNiv > 0 //Lancamento
				
				
				For Each ORder EmpCod, FilCod
					Where FilCod = PesFilAce
					Where FilAmbEms = TAmb.Producao when &TipoFilial = 'D'
					where FilAmbEmsMdfe = TAmb.Producao when &TipoFilial = 'DMDFE'
					&wwFilial.qtd += 1
					
					&wwFilialItem = new()
					&wwFilialItem.FilCod = FilCod	 	
					&wwFilialItem.FilRaz = iif(not FilNom.isempty() and not FilNom.isnull(),trim(FilNom), trim(FilRaz)) //So o nome. nao o codigo
					&wwFilialItem.FilEmiNf = iif(FilAmbEms = tAmb.Producao, 1, 0)
					&wwFilial.Filiais.Add(&wwFilialItem)
					
					if FilCod = &AuxFilCod or &wwFilial.selFilCod.IsEmpty()
						&wwFilial.selFilCod = FilCod
						&wwFilial.selFilRaz = iif(not FilNom.isempty() and not FilNom.IsNull(), trim(FilNom), trim(FilRaz))
					EndIf
				EndFor
				
				
			EndFor
	EndCAse

	if &AuxFilCod = -1 and &wwFilial.selFilCod > 0 and &permitezero <> 'N'
		&wwFilial.selFilCod = 0
		&wwFilial.selFilRaz = 'TODAS AS FILIAIS'
	Endif


	if &wwFilial.qtd = 0
		&wwFilial.sts = 'E998'
		&wwFilial.msg = 'Nenhuma filial Localizada!'
	Endif

	
EndIf
]]></Source>
