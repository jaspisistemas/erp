      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CteCod = &CteCod
	&CteChv = CteChv
	Exit
EndFor

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtCOnfiguracoesPasta)

&URLFisico = &SdtCOnfiguracoesPasta.PastaNFpdf + &CteChv.Trim() + '_' + padL(trim(Str(&CteCceCod)), 2, '0') + '.pdf'
&URLVirtual = &SdtCOnfiguracoesPasta.PastaNFpdfVir + &CteChv.Trim() + '_' + padL(trim(Str(&CteCceCod)), 2, '0') + '.pdf'

&File.Source = &URLFisico
If &File.Exists()
	&File.Delete()
EndIf

RELJAS101a.Call(&EmpCod, &FilCod, &CteCod, &CteCceCod, &URLFisico)
]]></Source>
