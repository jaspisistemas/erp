      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each order EmpCod,SerCod
	where EmpCod = &EmpCod
	where SerCod = &SerCod
	Do case
		case &SerSts = Status_AtivoInativo.ATIVO //Se parametro for = ATIVO é para ativar
			SerSts = Status_AtivoInativo.ATIVO
		case &SerSts = Status_AtivoInativo.INATIVO //Se parametro for = INATIVO é para inativar
			SerSts = Status_AtivoInativo.INATIVO
	EndCase
	exit	
EndFor

commit
]]></Source>
