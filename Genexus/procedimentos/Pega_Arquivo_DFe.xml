<Object parentGuid="9bbd5271-0e6e-4b96-abef-fa6edd198f06" user="WINJEAN\jeanfae" versionDate="2025-06-23T14:26:37.0000000Z" lastUpdate="2025-06-23T12:35:12.0000000Z" checksum="78e916a271cbc51b2dfdb950f4f8f420" fullyQualifiedName="Pega_Arquivo_DFe" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="efe530ae-a44f-4cac-91df-71cf936eb2af" name="Pega_Arquivo_DFe" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="Pega_Arquivo_DFe" parent="ComunicaNFe" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	&mensagem = 'Pega o DF-e no arquivo: '
	
	&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +"DFe\" + &FilCpj +'-'+padL(trim(&NroNSU),15,'0')+'-nfe.xml' //DFe lote
	&mensagem += &ArquivoPronto
	
	do 'Mensagem'
	&File.Source = &ArquivoPronto
	If &File.Exists()
		&XMLReader.Open(&ArquivoPronto)
		&ret = &XmlReader.ReadType(1, 'resNFe') 
		if &ret <> 0
			&XmlReader.Read()
			Do while &XmlReader.Name <> 'resNFe'
				
				Do Case
					Case &XmlReader.Name = 'chNFe'
						&ManCha = retornaSoNumeros.Udp(&XMLReader.Value)
					Case &XmlReader.Name = 'CNPJ'
						&ManCpfCnpj = &XMLReader.Value
					Case &XmlReader.Name = 'CPF'
						&ManCpfCnpj = &XMLReader.Value
					Case &XmlReader.Name = 'xNome'
						&ManRaz = &XMLReader.Value
					Case &XmlReader.Name = 'IE'
						&ManInsEst = &XMLReader.Value
					Case &XmlReader.Name = 'dhEmi'
						&ManDtaIni = YmdHmstoT(val(substr(&XMLReader.Value,1,4)),val(substr(&XMLReader.Value,6,2)),val(substr(&XMLReader.Value,9,2)),val(substr(&XMLReader.Value,12,2)),val(substr(&XMLReader.Value,15,2)),Val(substr(&XMLReader.Value,18,2)))
					Case &XmlReader.Name = 'tpNF'
						If val(&XMLReader.Value) = 0
							&ManTip = EntradaSaida.Entrada
						Else
							&ManTip = EntradaSaida.Saida
						EndIf
						
					Case &XmlReader.Name = 'vNF'
						&ManVal = val(&XMLReader.Value)
					Case &XmlReader.Name = 'dhRecbto'
						&ManDtaRcb = &XMLReader.Value
					Case &XmlReader.Name = 'nProt'
						&ManProt = &XMLReader.Value
					Case &XmlReader.Name = 'cSitNFe'
						&cSitNFe = val(&XMLReader.Value)
				EndCase
				
				&XmlReader.Read()		
				if &XmlReader.EOF
					Exit
				endif					
			EndDo
			&XMLReader.Close()
			
			&mensagem = 'Arquivo XML encontrado com sucesso'
			&SolMsg = &mensagem
			
			GravaManifestacao.call(&EmpCod,&FilCod,&ManCpfCnpj,&ManCha,&ManRaz,&ManInsEst,&ManDtaIni,&ManTip,&ManVal,&ManDtaRcb,&ManProt,&cSitNFe,&ArquivoPronto,&NroNSU, 'NFE', &outManCod)
			GravaXmlNota2.Call(&EmpCod, &FilCpj, &ManCha, &NroNSU,&sdtConfiguracoesPasta, &IsExisteXml)
			do 'Mensagem'
		EndIf		
	Else
		&ArquivoPronto = &sdtConfiguracoesPasta.PastaNFretorno.Trim() +"DFe\" + &FilCpj +'-'+padL(trim(&NroNSU),15,'0')+'-procNFe.xml' //NOTA FISCAL PRONTA
		
		&NfeArqXml = ''
		&xmlNFe.Open(&ArquivoPronto)    
		Do While  not &xmlNFe.EOF
			&NfeArqXml += &xmlNFe.ReadRawXML()
			&xmlNFe.Read()
		Enddo
		&xmlNFe.Close()
		
		leituraXmlDanfe.Call(&NfeArqXml, &NfeProc)
		
		&ManCha = &NfeProc.protNFe.infProt.chNFe
		
		if not &NfeProc.NFe.infNFe.emit.CNPJ.IsEmpty()
			&ManCpfCnpj = &NfeProc.NFe.infNFe.emit.CNPJ
		Else
			&ManCpfCnpj = &NfeProc.NFe.infNFe.emit.CPF
		Endif
	
		&ManRaz = &NfeProc.NFe.infNFe.emit.xNome
		
		&ManInsEst = &NfeProc.NFe.infNFe.emit.IE
		
		&ManDtaIni = YmdHmstoT(val(substr(&NfeProc.Nfe.infNFe.ide.dhEmi,1,4)),val(substr(&NfeProc.Nfe.infNFe.ide.dhEmi,6,2)),val(substr(&NfeProc.Nfe.infNFe.ide.dhEmi,9,2)),val(substr(&NfeProc.Nfe.infNFe.ide.dhEmi,12,2)),val(substr(&NfeProc.Nfe.infNFe.ide.dhEmi,15,2)),Val(substr(&NfeProc.Nfe.infNFe.ide.dhEmi,18,2)))
		
		If &NfeProc.NFe.infNFe.ide.tpNF = '0'
			&ManTip = EntradaSaida.Entrada
		Else
			&ManTip = EntradaSaida.Saida
		EndIf
	
		&ManVal = val(&NfeProc.Nfe.infNFe.total.ICMSTot.vNF)
		
		&ManDtaRcb = &NfeProc.protNFe.infProt.dhRecbto
		
		&ManProt = &NfeProc.protNFe.infProt.nProt
		
		&cSitNFe = 1 //fixei autorizada
		
		GravaManifestacao.call(&EmpCod,&FilCod,&ManCpfCnpj,&ManCha,&ManRaz,&ManInsEst,&ManDtaIni,&ManTip,&ManVal,&ManDtaRcb,&ManProt,&cSitNFe,&ArquivoPronto,&NroNSU, 'NFE', &outManCod)
		GravaXmlNota2.Call(&EmpCod,&FilCpj, &ManCha, &NroNSU,&sdtConfiguracoesPasta, &IsExisteXml)
				
		&mensagem = 'Arquivo XML não encontrado'
		&SolMsg = &mensagem
		do 'Mensagem'
	EndIf




Sub 'Mensagem'
	msg(&mensagem  + ' Hora: ' + serverTime(),status)
EndSub

]]></Source>
