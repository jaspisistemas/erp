      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[for &sdtLeituraRomaneioTxt in &sdtLeituraRomaneioTxts
	if &sdtLeituraRomaneioTxt.isSelected
		&codigoRomaneio = &sdtLeituraRomaneioTxt.Codigo
		&NfeDadAdi = format('ROMANEIO: %1',trim(&sdtLeituraRomaneioTxt.Codigo.ToString()))
		do 'buscaNotaEmitidaRomaneio'
	endif
endfor

for &sdtLeituraRomaneioTxt in &sdtLeituraRomaneioTxts
	if &sdtLeituraRomaneioTxt.isSelected
		and not &sdtLeituraRomaneioTxt.Codigo.IsEmpty()
		and not &sdtLeituraRomaneioTxt.PesoLiquido.IsEmpty()
		&NFePesLiq = &sdtLeituraRomaneioTxt.PesoLiquido
		&NFeProQtd = &sdtLeituraRomaneioTxt.PesoLiquido
		&NFePesBrt = &sdtLeituraRomaneioTxt.PesoLiquido
		&NfeDadAdi = format('ROMANEIO: %1',trim(&sdtLeituraRomaneioTxt.Codigo.ToString()))
		&UserMessage = GravaNotaFiscalModelo55Romaneio(&EmpCod, &FilCod, &NFeCliCod, &NFeLctCod, &NFeProCod, &NfeProGraCod, &NFePesLiq, &NFePesBrt, &NFeProQtd, &NfeDadAdi, &NfeTipFrt)
		
		&countNotasSucesso += 1
		if not &UserMessage.isSucess
			return
		endif
	endif
endfor

&UserMessage = criaUserMessageSucesso('',format('%1 notas importadas',trim(&countNotasSucesso.ToString())))

Sub 'buscaNotaEmitidaRomaneio'
	for each Notas
		where EmpCod = &EmpCod
		where FilCod = &FilCod
		where NfeDadAdi like '%'+&NfeDadAdi+'%'
		where not NfeSts in (Status_NFe.Cancelada,Status_NFe.Excluida)
		
		&UserMessage = criaUserMessageError(format('Romaneio %1 com nota %2',trim(&codigoRomaneio.ToString()),trim(NfeSts.EnumerationDescription())),'')
		return
		
		exit
	endfor
EndSub
]]></Source>
