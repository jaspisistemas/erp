      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &parProCod or &parProCod = 0

	ProStsRec = 'N'
	&MEnsagem = ''
	
	&cOUNT = 0
	For Each Order EmpCod, ProCod, RecProCod
		&MEnsagem = testeerroMateriaPrima.udp(EmpCod, ProCod, RecProCod)
		if not &MEnsagem.IsEmpty()
			exit
		EndIF
		&cOUNT += 1
	EndFor
	
	Do Case
		Case (&cOUNT = 0 and ProTipCus = '1')
			&MEnsagem = 'Produto com tipo de Custo de Receita mas sem Receita!'
		Case &MEnsagem.IsEmpty()
			ProStsRec = 'S'
	EndCase

	Commit
EndFor
]]></Source>
