      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PercentualTotal = 0
For each Order EmpCod,PedSts,LctAtuEst,LctTip,ProGraRefPadL,GrupHiePadL
	Where EmpCod = &EmpCod
	where FilCod = &FilCod
	Where PedSts = Status_Pedido.FECHADO
	Where LctAtuEst = Status_EntradaSaida.Saida
	Where (GrupHie = &GrupHie or GrupHie like &auxGrupHie) when not &GrupHie.IsEmpty()
	Where LctTip = TipoLancamento.SaidaMercadoria
	Where PedDtaFat >= &PedDtaFat and PedDtaFat <= &PedDtaFat_Go
	Where LctCod = &LctCod when not &LctCod.IsEmpty()
	Where LctGerFin = &LctGerFin when not &LctGerFin.IsEmpty()
	Where PedCliCod = &PesCod When not &PesCod.IsEmpty()
	Where PedVenCod = &PedVenCod when not &PedVenCod.IsEmpty()
	Where ProCod = &ProCod when not &ProCod.IsEmpty()
	where PedQtd > 0
	where ProTipDef = Definicao.SERVICO when &TipoProduto = 'S' 
	where ProTipDef <> Definicao.SERVICO when &TipoProduto = 'P' 
	Where ProSts <> Status_Produto.EXCLUIDO
	&PercentualTotal +=1
EndFor

If &PercentualTotal = 0
	&Percentual = 100
	&ProgressLogXml = 'Nenhum registro encontrado para o período informado!'
Else
	&ProgressLogXml = ''
	&Percentual = 0
	&ProgressIni = serverNow()
	&PerCount = 0
EndIf


do 'Atualiza'

&auxGrupHie = &GrupHie+'.'
&PedQtd = 0
&CountPro = 0
&PedVlrCus = 0
&PedVlrLiq = 0
&TempRent = 0

For each Order EmpCod,TempUsr,TempRent
	Where EmpCod = &EmpCod
	Where TempUsr = &usrCod

	delete
EndFor
Commit


If &PercentualTotal > 0
	
	For each Order EmpCod,PedSts,LctAtuEst,LctTip,GrupHiePadL,ProGraRefPadL    
		Where EmpCod = &EmpCod
		where FilCod = &FilCod
		Where PedSts = Status_Pedido.FECHADO
		Where LctAtuEst = Status_EntradaSaida.Saida
		Where (GrupHie = &GrupHie or GrupHie like &auxGrupHie) when not &GrupHie.IsEmpty()
		Where LctTip = TipoLancamento.SaidaMercadoria
		Where PedDtaFat >= &PedDtaFat and PedDtaFat <= &PedDtaFat_Go
		Where LctCod = &LctCod when not &LctCod.IsEmpty()
		Where LctGerFin = &LctGerFin when not &LctGerFin.IsEmpty()
		Where PedCliCod = &PesCod When not &PesCod.IsEmpty()
		Where PedVenCod = &PedVenCod when not &PedVenCod.IsEmpty()
		Where ProCod = &ProCod when not &ProCod.IsEmpty()
		where PedQtd > 0
		where ProTipDef = Definicao.SERVICO when &TipoProduto = 'S' 
		where ProTipDef <> Definicao.SERVICO when &TipoProduto = 'P' 
		Where ProSts <> Status_Produto.EXCLUIDO
		
		//Pedido Produto - Soma todos os produto calculando ,vlr liq, custo, rent vlr, rent %.
		If ProGraRefPadL <> &TempProGraRef
			If not &tempProGraRef.IsEmpty()
				
				If &PedVlrCus > 0
					&TempProPerRet = ((&PedVlrLiq * 100) / &PedVlrCus) - 100
				Else
					&TempProPerRet = 0
				EndIf
				
				&TempProVlrRet = &PedVlrLiq - &PedVlrCus
				If &TempProPerRet > 0
					&TempProPerRet = &TempProPerRet
				Else
					&TempProPerRet = 0
				EndIf
				
				
				Do 'AddProduto'
				&PedQtd = 0
				&CountPro = 0
				&PedVlrCus = 0
				&PedVlrLiq = 0
				&TempProPerRet = 0
				&TempProVlrRet = 0
			EndIf
		EndIf
		
		&TempProGraRef = ProGraRefPadL
		&AddProGraRef = ProGraRef
		&TempProCod = ProCod
		&TempProNom = ProNomGra
		&PedQtd    += PedQtd
		&CountPro  += 1
		&PedVlrCus += round((PedVlrCus * PedQtd),2)
		&PedVlrLiq += PedVlrItmComDsc
		&TempGrupCod = GrupCod
		&TempGrupNom = GrupNom
		&tempGrupCodNom = GrupCodNom
		&TempGrupHie = GrupHie
		&TempGrupPaiCod = GrupPaiCod
		&TempGrupPaiHie = GrupPaiHie
		
		&X +=1
		If &X > 500
			&PerCount += 500
			&X=1
			Do 'Percentual'
			do 'Atualiza'
		EndIf
		
	EndFor
	
	
	//###################### ultimo produto - calcula
	If &PedVlrCus > 0
		&TempProPerRet = ((&PedVlrLiq * 100) / &PedVlrCus) - 100
	Else
		&TempProPerRet = 0
	EndIf
	
	&TempProVlrRet = &PedVlrLiq - &PedVlrCus
	If &TempProPerRet > 0
		&TempProPerRet = &TempProPerRet
	Else
		&TempProPerRet = 0
	EndIf
	Do 'AddProduto'
	//###############################################
	//&PerCount += &X
	//Do 'Percentual'
	&Percentual = 100
	&ProgressFin = serverNow()
	do 'Atualiza'
	
EndIf

Sub 'AddProduto'
	If &TempProNom.Trim().IsEmpty()
		&TempProNom = 'Produto vendido mais não encontrado no cadastro.'
	EndIf
	
	If &IsSintetico = false
		
		&TempRent+=1
		
		New		
			EmpCod = &EmpCod
			TempUsr = &usrCod
			TempRent = &TempRent
			tempProQtd = &CountPro
			TempQuantidade = &PedQtd
			TempProCod = &TempProCod
			TempProGraRef = &AddProGraRef
			TempProGraRefPadL = &TempProGraRef
			TempProNom = &TempProNom			
			TempProVlrCus = &PedVlrCus
			TempPedVlrLIq = &PedVlrLiq
			TempProVlrRet = &TempProVlrRet
			TempProPerRet = &TempProPerRet
			TempGrupCod = &TempGrupCod
			TempGrupNom = &TempGrupNom	
			TempGruphie = &TempGrupHie
			TempGrupCodNom = &TempGrupCodNom
			TempGrupPaiHie = &TempGrupPaiHie
		EndNew
		
		Commit
	EndIf
	//depois de adicionador o produto usa recursividade para adicionar e calcular os totais do sub grupo e grupo passando o grupo do produto &TempGrupCod
	CarregaSdtCategorias.Call(&EmpCod, &TempGrupCod,&PedVlrLiq,&PedQtd,&CountPro,&PedVlrCus, &usrCod,&TempRent,0,0)
	
	do 'GetUltimoCodigo'// JDF - TEM QUE DEIXAR POIS LA DENTRO do CarregasdtCategorias ele tambem grava
EndSub

Sub 'GetUltimoCodigo'
	&TempRent = 0
	For each Order EmpCod,TempUsr,(TempRent)
		Where EmpCod = &EmpCod
		Where TempUsr = &usrCod
		&TempRent = TempRent
		Exit
	EndFor
EndSub


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
		ProgressLogXml = &ProgressLogXml 
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
			ProgressLogXml = &ProgressLogXml 
		Endnew
	endfor

	commit
EndSub

sub 'Percentual'
	&PerCount += 1
	If &PerCount > 0
		&Percentual = round((&PerCount / &PercentualTotal) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
EndSub
]]></Source>
