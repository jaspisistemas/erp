      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[//CONTAS 
For &sdtContasBancariasItem in &sdtContasBancarias
	For each order EmpCod, PesCod, PesConCod
		where EmpCod = &EmpCod
		where PesCod = &PesCod
		where PesConCod = &sdtContasBancariasItem.PesConCod
		
		if &sdtContasBancariasItem.PesConSts = Status_SimNao.Sim 
			PesConBanCod = &sdtContasBancariasItem.PesConBanCod
			PesConAge = &sdtContasBancariasItem.PesConAge
			PesConTpo = &sdtContasBancariasItem.PesConTpo
			PesCon = &sdtContasBancariasItem.PesCon
			PesConFav  = &sdtContasBancariasItem.PesConFav
			PesConIsSel  = &sdtContasBancariasItem.PesConIsSel
			PesConPix  = &sdtContasBancariasItem.PesConPix
			
			if &sdtContasBancariasItem.PesCon.IsEmpty() and &sdtContasBancariasItem.PesConPix.IsEmpty()
				Delete
			EndIf
			
		else 
			Delete // se tiver Sts = nao - deleta
		EndIf
		
	When none
		if &sdtContasBancariasItem.PesConSts = Status_SimNao.Sim
			if not &sdtContasBancariasItem.PesCon.IsEmpty() or not &sdtContasBancariasItem.PesConPix.IsEmpty()
				New
					EmpCod = &EmpCod
					PesCod = &PesCod
					PesConCod = &sdtContasBancariasItem.PesConCod
					PesConBanCod = &sdtContasBancariasItem.PesConBanCod
					PesConAge = &sdtContasBancariasItem.PesConAge
					PesConTpo = &sdtContasBancariasItem.PesConTpo
					PesCon = &sdtContasBancariasItem.PesCon
					PesConFav  = &sdtContasBancariasItem.PesConFav
					PesConIsSel  = &sdtContasBancariasItem.PesConIsSel
					PesConPix  = &sdtContasBancariasItem.PesConPix
				EndNew
			EndIf
		EndIf
	EndFor
	
	Commit
EndFor

]]></Source>
