      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	&wwNotasProdutos.qtd = 0
	&wwNotasProdutos.temMais = 'N'
	
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
	
		&Moeda2 = NfeVlrTot
		&wwNotasProdutos.varNfeTot = RetiraZerosDepoisVirgulaxCasas.Udp(2, &Moeda2.ToFormattedString())
		&wwNotasProdutos.nfests = NfeSts
		
		For Each Order EmpCod, FilCod, NfeCod, (NfeItmCod)
			Where EmpCod = &wwpContext.EmpCod
			Where FilCod = &FilCod
			Where NfeCod = &NfeCod
			&wwNotasProdutos.qtd += 1
			
			&wwNotasProdutositem = new()
			&wwNotasProdutositem.Nom = NfeProNom
			&wwNotasProdutositem.Ref = NfeProGraRef
			
			&wwNotasProdutositem.Itm = NfeItmCod
			
			&Moeda6 = NfeProQtd
			&wwNotasProdutositem.Qtd = RetiraZerosDepoisVirgulaxCasas.Udp(0, &Moeda6.ToFormattedString())
			//		&wwNotasProdutositem.Qtd = &wwNotasProdutositem.Qtd.Replace(',','.')
			
			
			&Moeda5 = NfeProVlrUnt
			&wwNotasProdutositem.Unt = RetiraZerosDepoisVirgulaxCasas.Udp(2, &Moeda5.ToFormattedString())
			//		&wwNotasProdutositem.Unt = &wwNotasProdutositem.Unt.Replace(',','.')
			
			
			&Moeda2 = NfeProVlrTot
			&wwNotasProdutositem.Tot = RetiraZerosDepoisVirgulaxCasas.Udp(2, &Moeda2.ToFormattedString())
			//		&wwNotasProdutositem.Tot = &wwNotasProdutositem.Tot.Replace(',','.')
			
			&wwNotasProdutositem.Ncm = NfeNcmCod
			&wwNotasProdutositem.Cfo = NfeCfoCod
			&wwNotasProdutositem.Sit = NfeSitCod
			&wwNotasProdutositem.Und = NfeEmbUnd
			&wwNotasProdutos.Items.Add(&wwNotasProdutositem)
		EndFor
	
		Exit
		
	When none
		&wwNotasProdutos.qtd = 0
		&wwNotasProdutos.temMais = 'X'
	EndFor
	
Endif

]]></Source>
