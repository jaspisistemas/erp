      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsDisponivel = true
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedDtaPrv <= &PedDtaPrv and PedDtaRetCon >= &PedDtaPrv or PedDtaPrv <= &PedDtaRetCon and PedDtaRetCon >= &PedDtaRetCon
	Where LctTip = TipoLancamento.LocacaoPecas
	Where PedSts <> Status_Pedido.CANCELADO
	Where ProCod = &ProCod
	Where ProGraCod = &ProGracod
	
	
	
	&IsDisponivel = false
	
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
