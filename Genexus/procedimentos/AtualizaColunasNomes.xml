      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//atualiza tabela atual
For Each Order EmpCod, TabCod
	WHere EmpCod = &EmpCod
	Where TabCod = &TabCod
	TabDtaHorMod = now()
	Exit
EndFor


//atauliza todas as colunas de todas as tabelas que sejam vazias
For Each Order EmpCod, TabCod, TabColCod
	Where EmpCod = &EmpCod
	Where TabColNom.IsEmpty() or TabColNom.IsNull()
	TabColNom = 'Col.' + trim(str(TabColCod))	
EndFor

Commit
]]></Source>
