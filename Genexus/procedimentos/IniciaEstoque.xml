      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Exit
When none
	If &ProCod <> 0 and &ProGraCod <> 0 
		new
			EmpCod = &EmpCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
		EndNew
	
		commit
	EndIF
EndFor


For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
    Exit
When None
	
    If &ProCod <> 0 and &ProGraCod <> 0 and &FilCod <> 0 and &EmpCod <> 0
        New   // NOVO REGISTRO TABELA ESTOQUE
			EmpCod = &EmpCod
			FilCod = &FilCod
			ProCod = &ProCod
			ProGraCod = &ProGraCod
			EstLoc = ''
			EstABC_Ren = 'D'
			EstABC_Qtd = 'D'
			EstUltEnt = nullvalue(EstUltEnt)
			EstUltSai = nullvalue(EstUltSai)
			EstUltFab = nullvalue(EstUltFab)
			EstQtd = 0
			EstQtdFis = 0
			EstPrd = 0
			EstVen = 0
			EstSug = 0
			EstCom = 0
			EstMin = 0
			EstFabMin = 0
			//EstSug = 0
			EstFab = 0
			EstDtaHorUltMod = now()
        EndNew
	
		commit
    EndIF
EndFor


]]></Source>
