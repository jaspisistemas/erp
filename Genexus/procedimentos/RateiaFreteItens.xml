      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&TotalPedidos = 0
&FrtItmVlrCal = 0

For Each Order EmpCod, FilCod, FrtCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where FrtCod = &FrtCod
	
	&PedCnhTracod = FrtTraCod
	For Each Order EmpCod, FilCod, FrtCod, FrtItmCod
		&NfeEntSai = FrtItmNot
		
		if FrtItmVlr > 0
			&FrtItmVlrCal += FrtItmVlr
		Else
			&PedVlrbrt = 0
			If FrtPedCod = 0 //NOTA
				retornaPedidoNotaSequencia.Call(EmpCod, FilCod, FrtNfeCod, &NfeEntSai, &NfeFilCod, &NFePedCod)
				RetornaTotalLiquidoBruto.Call(EmpCod, &NfeFilCod, &NFePedCod, &PedVlrbrt, &PedVlrlIq)
			
			else //PEDIDO
				&NfeFilCod = FrtPedFiLCod
				&NFePedCod = FrtPedCod
				RetornaTotalLiquidoBruto.Call(EmpCod, FrtPedFiLCod, FrtPedCod, &PedVlrbrt, &PedVlrlIq)
				
			EndIf
		
			&TotalPedidos += &PedVlrbrt
		EndIF
	EndFor
EndFor


If &TotalPedidos > 0 or &FrtItmVlrCal > 0
	For Each Order EmpCod, FilCod, FrtCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where FrtCod = &FrtCod
		
		&FrtVlrCtb = FrtVlrCtb - &FrtItmVlrCal
		&FrtDtaEms = FrtDtaLct
		
		For Each Order EmpCod, FilCod, FrtCod, FrtItmCod
			&FrtItmCte = FrtItmCte
			&NfeEntSai = FrtItmNot
			
			If FrtItmVlr > 0
				FrtItmVlrCal = FrtItmVlr
				&PedCnhVlr = FrtItmVlr
				
				If FrtPedCod = 0 //NOTA
					retornaPedidoNotaSequencia.Call(EmpCod, FilCod, FrtNfeCod, &NfeEntSai, &PedFilCod, &FrtPedCod)
					RetornaTotalLiquidoBruto.Call(EmpCod, &PedFilCod, &FrtPedCod, &PedVlrbrt, &PedVlrlIq)
					
				else //PEDIDO	
					&PedFilCod = FrtPedFiLCod
					&FrtPedCod = FrtPedCod
				EndIf	
			
			Else		
				&PedVlrBrt = 0
				If FrtPedCod = 0 //NOTA
					retornaPedidoNotaSequencia.Call(EmpCod, FilCod, FrtNfeCod, &NfeEntSai, &PedFilCod, &FrtPedCod)
					RetornaTotalLiquidoBruto.Call(EmpCod, &PedFilCod, &FrtPedCod, &PedVlrbrt, &PedVlrlIq)
					
				else //PEDIDO	
					&PedFilCod = FrtPedFiLCod
					&FrtPedCod = FrtPedCod
					RetornaTotalLiquidoBruto.Call(EmpCod, FrtPedFiLCod, FrtPedCod, &PedVlrBrt, &PedVlrlIq )
				EndIf						
				
				if &FrtVlrCtb > 0 and &TotalPedidos > 0
					
					&PedCnhVlr= round(((&FrtVlrCtb / &TotalPedidos) * &PedVlrBrt), 2)
					FrtItmVlrCal = &PedCnhVlr
				Else
					FrtItmVlrCal = 0
					&PedCnhVlr = 0
				EndIF
				
			EndIF
		
			//Commit
			
			if &FrtPedCod > 0
				GravaDadosconhecimento.Call(&EmpCod, &PedFilCod, &FrtPedCod, &NfeEntSai, &FrtDtaEms, &PedCnhVlr, &FrtItmCte, &PedCnhTracod)
			EndIF
			&FrtPedCod = 0
		EndFor
	EndFor


	commit
EndIF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
