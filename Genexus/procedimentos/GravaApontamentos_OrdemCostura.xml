      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
if &inAptCod <> 0
	For Each order EmpCod, AptDtaLct, AptCod
		where EmpCod = &EmpCod
		Where AptDtaLct = &AptDtaLct
		Where AptCod = &inAptCod
		AptAtiCod = &AptAtiCod
		AptFunCod = &AptFunCod
//		AptHorIni = &AptHorIni
//		AptHorFin = &AptHorFin
		AptProCod = &AptProCod
		AptProGraCod = &AptProGraCod
		AptEtpCod = &AptEtpCod
		AptQtd = &AptQtd
		AptObs = &AptObs
		AptOcsItm = &AptOcsItm
		AptOcsCod = &AptOcsCod
		Exit
	EndFor

	commit
Else
	&aptCod = 0
	For Each order EmpCod, AptDtaLct, (AptCod)
		where EmpCod = &EmpCod
		Where AptDtaLct = &AptDtaLct
		&AptCod = AptCod
		Exit
	EndFor
	&AptCod += 1
	
	new
		EmpCod = &EmpCod
		AptDtaLct = &AptDtaLct
		AptCod = &AptCod
		AptAtiCod = &AptAtiCod
		AptFunCod = &AptFunCod
//		AptHorIni = &AptHorIni
//		AptHorFin = &AptHorFin
		AptProCod = &AptProCod
		AptProGraCod = &AptProGraCod
		AptEtpCod = &AptEtpCod
		AptQtd = &AptQtd
		AptObs = &AptObs
		AptOcsItm = &AptOcsItm
		AptOcsCod = &AptOcsCod
	EndNew
	
	commit
EndiF
]]></Source>
