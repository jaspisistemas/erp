<Object parentGuid="bed31150-2c6c-4266-ac03-d4c1ac1bc0d9" user="WINJEAN\jeanfae" versionDate="2025-08-04T11:11:37.0000000Z" lastUpdate="2025-08-01T19:17:01.0000000Z" checksum="3a75acbbb0b1aeef225791d175be242d" fullyQualifiedName="prcGravaPedidosImportados" moduleGuid="afa47377-41d5-4ae8-9755-6f53150aa361" guid="614e0af8-fa85-4329-9363-8bbe743d6007" name="prcGravaPedidosImportados" type="84a12160-f59b-4ad7-a683-ea4481ac23e9" description="prc Grava Pedidos Importados" parent="produtosmarket" parentType="00000000-0000-0000-0000-000000000008">
      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&sdtMLPedido.FromJson(&longVarchar)

For Each Order EmpCod, MrkCod, MrkPedSku
	Where EmpCod = &EmPCod
	Where MrkCod = &MrkCod
	Where MrkPedSku = &sdtMLPedido.id
	//atualiza itens
	//MrkPedFilCod
	//MrkPedCod = &sdtMLPedido.total_amount
	MrkPedVlr = &sdtMLPedido.total_amount
	//MrkPedCom
	
	&ano = val(Substr(&sdtMLPedido.date_created, 1, 4))
	&Mes = val(Substr(&sdtMLPedido.date_created, 6, 2))
	&dia = val(Substr(&sdtMLPedido.date_created, 9, 2))
	MrkPedDtaEms = YMDtoD(&ano,&mes, &dia)
	MrkPedHorEms = Substr(&sdtMLPedido.date_created, 12,8)
	
	MrkPedSts = MercadoLivreStatusPedido.Udp(TipoMarketplace.MercadoLivre, 'N', &sdtMLPedido.status)
	
	//cliente
	MrkPedCliId = &sdtMLPedido.buyer.id
	MrkPedNick = &sdtMLPedido.buyer.nickname
	MrkPedCliNom = &sdtMLPedido.buyer.first_name + ' '+ &sdtMLPedido.buyer.last_name
	
	MrkPedShipSku = &sdtMLPedido.shipping.id
	
	MrkPedLong = &longVarchar
	
	Exit
When none
	New
		EmpCod = &EmPCod
		MrkCod = &MrkCod
		MrkPedSku = &sdtMLPedido.id
		
		//MrkPedFilCod
		//MrkPedCod = &sdtMLPedido.total_amount
		MrkPedVlr = &sdtMLPedido.total_amount
		//MrkPedCom
		
		&ano = val(Substr(&sdtMLPedido.date_created, 1, 4))
		&Mes = val(Substr(&sdtMLPedido.date_created, 6, 2))
		&dia = val(Substr(&sdtMLPedido.date_created, 9, 2))
		MrkPedDtaEms = YMDtoD(&ano,&mes, &dia)
		MrkPedHorEms = Substr(&sdtMLPedido.date_created, 12,8)
		
		
		MrkPedSts = MercadoLivreStatusPedido.Udp(TipoMarketplace.MercadoLivre, 'N', &sdtMLPedido.status)
		
		MrkPedEtqDtaHor.SetEmpty()
		MrkPedDspDtaHor.SetEmpty()
		
		//cliente
		MrkPedCliId = &sdtMLPedido.buyer.id
		MrkPedNick = &sdtMLPedido.buyer.nickname
		MrkPedCliNom = &sdtMLPedido.buyer.first_name + ' '+ &sdtMLPedido.buyer.last_name
		
		MrkPedShipSku = &sdtMLPedido.shipping.id
		
		MrkPedLong = &longVarchar
	EndNew

	For &Produtos in &sdtMLPedido.order_items
			
		new
			EmpCod = &EmPCod
			MrkCod = &MrkCod
			MrkPedSku = &sdtMLPedido.id
			MrkPedProItmCod = &Produtos.item.id
			MrkPedProQtd = &Produtos.quantity
			MrkPedProVlr = &Produtos.unit_price
			MrkPedProCom = &Produtos.sale_fee
		EndNew
		
	EndFor
	
EndFor

Commit


//navega nos pagamentos
For &itenspagamento in &sdtMLPedido.payments
	
	//total pago          "total_paid_amount":54.66,
	//valor transacao          "transaction_amount":29.97,
	
	&MrkPedVlrAcr += &itenspagamento.total_paid_amount - &itenspagamento.transaction_amount 
	
	//transaction_amount_refunded
	//taxes_amount
	//shipping_cost
	//coupon_amount
	
	&MrkPedCom += &itenspagamento.marketplace_fee
	
Endfor


For Each Order EmpCod, MrkCod, MrkPedSku
	Where EmpCod = &EmPCod
	Where MrkCod = &MrkCod
	Where MrkPedSku = &sdtMLPedido.id
	
	MrkPedCom = &MrkPedCom
	MrkPedVlrAcr = &MrkPedVlrAcr
	Exit
	
EndFor

commit

prcAtualizaStatusInterno.Call(&EmPCod, &MrkCod, &sdtMLPedido.id)
]]></Source>
