      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 0
MT 0


For Each Order EmpCod, GrupHiePadL
	Where EmpCod = &Context.EmpCod
	Where ProPadForCod = &ProPadForCod
	
	if &GrupHie <> GrupHie
		&IsAchou = false
		if &sdtGrupoQtdItem in &sdtGrupoQtd
			if &sdtGrupoQtdItem.GrupHie = GrupHie
				&IsAchou = true
				Exit
			EndIf
		EndIf
		
		if &IsAchou = false
			&sdtGrupoQtdItem = new()
			&sdtGrupoQtdItem.GrupHie = GrupHie
			&sdtGrupoQtd.Add(&sdtGrupoQtdItem)
		EndIF
	EndIF
	
	&grupHie = GrupHie
EndFor

For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &ProPadForCod
	&titulo = 'GRUPOS/ETAPAS DA: ' + trim(PesRaz)
	Exit
EndFor

print Cabecalho


For &sdtGrupoQtdItem in &sdtGrupoQtd
	&MensagemLongVarchar.SetEmpty()
	For Each Order EmpCod, GrupHie, GrupCTrOrd
		Where EmpCod = &EmpCod
		Where GrupHie = &sdtGrupoQtdItem.GrupHie
		if not &MensagemLongVarchar.IsEmpty()
			&MensagemLongVarchar += ' | '
		Endif
	
		&GrupNom = GrupHie.Trim() + '-' + GrupNomCmp.Trim()
		&MensagemLongVarchar += trim(str(GrupCTrOrd)) + ' - ' + trim(GrupCTrNom)
	EndFor
	
	if not &MensagemLongVarchar.IsEmpty()
		&count = gxMLines(&MensagemLongVarchar, 185)
		
		print PrincipalItem
		
		For &index = 1 to &count
			&Item = gxGetMLi(&MensagemLongVarchar, &Index, 185)
			print Item
			
			if &index < &count
				noskip
				print tracejado
			endif
		EndFor
	
		print traco
	Endif
EndFor


]]></Source>
