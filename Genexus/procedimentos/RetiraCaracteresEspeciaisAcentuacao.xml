      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[/* Esta rotina retira toda a acentuacao de uma string, deixando os caracteres respectivos sem acentos
Desenvolvedor: Tiago Tecchio 
Analista Genexus Junior
Email: tiago_ordig@hotmail.com	

Parametros
in:
   &StringInicial C(255) = String que deseja retirar os acentos
out:
   &StringFinal C(255) = Retorna string sem os acentos
   
*/

&ComAcentos = "ÁÉÍÓÚáéíóúÀÈÌÒÙàèìòùÂÊÎÔÛâêîôûÄËÏÖÜäëïöüÃÕãõÇçÑñº°ª'´–§&"+'                                      ' //os espacos no final para chegar aos 100 caracteres
&SemAcentos = "AEIOUaeiouAEIOUaeiouAEIOUaeiouAEIOUaeiouAOaoCcNnooa... E"+'                                      '
&String = &StringInicial

for &x = 1 to 80
   &Acento = substr(&ComAcentos, &x, 1)
   &SAcento = substr(&SemAcentos, &x, 1)
   &StringFinal = StrReplace(&String, &Acento, &SAcento)
   &String = &StringFinal
endfor

&String = Trim(strreplace(&String,'  ',' '))
&String = Trim(strreplace(&String,Chr(9),' '))
&String = Trim(strreplace(&String,Chr(13),' '))
&String = Trim(strreplace(&String,Chr(10),' '))
&String = Trim(strreplace(&String,'  ',' '))
&String = &String.ReplaceRegEx('\s+', ' ')

Return

]]></Source>
