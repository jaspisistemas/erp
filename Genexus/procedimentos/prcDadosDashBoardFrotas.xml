      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&QtdVeiCod = 0 //Total de Veículos Cadastrados
&QtdMotCod = 0 //Total de Motoristas Ativos
&QtdViaCod = 0 //Total de Viagens em Trânsito
&QtdMotTra = 0 //Total de Motoristas em Trânsito
&QtdPlaCod = 0 //Total de Veiculos em Trânsito
&QtdCNHAtr = 0 //Total de CNH's à vencer daqui a, no mínimo, 30 dias

&Vencimento = &Today.AddDays(30)

For Each Order EmpCod, VeiCod
	Where EmpCod = &parmEmpCod //Empresa
	
	&QtdVeiCod += 1 //Quantidade Veículos
	
EndFor

For Each Order EmpCod, PesCod
	Where EmpCod 	= &parmEmpCod //Empresa
	Where PesIsMot 	= True		//Motorista
	Where PesSts	= Status_AtivoInativo.ATIVO //Ativo
	
	&QtdMotCod += 1 //Quantidade Motoristas
	
	Do Case
		Case PesCNHVen <= &Vencimento And Not PesCNHVen.IsEmpty()
			&QtdCNHAtr += 1 //CNH em Atraso
	EndCase
	
EndFor

For Each Order EmpCod, FilCod, ViaCod
	Where EmpCod = &parmEmpCod	//Empresa
	Where FilCod = &parmFilCod 	//Filial
	Where ViaSts = 'T'			//Viagens em Trânsito
	
	&QtdViaCod += 1 //Quantidade Viagens
	
	&QtdMotTra += 1 //Quantidade Motoristas
	
	&QtdPlaCod += 1 //Placas em Trânsito
	
	//Adiciona as carretas na contagem
	Do Case
		Case Not ViaPlaCar1.IsEmpty()
			&QtdPlaCod += 1
			
		Case Not ViaPlaCar2.IsEmpty()
			&QtdPlaCod += 1
			
		Case Not ViaPlaCar3.IsEmpty()
			&QtdPlaCod += 1
			
	EndCase
	
EndFor

For Each Order EmpCod, FilCod, ViaCod
	Where EmpCod = &parmEmpCod	//Empresa
	Where FilCod = &parmFilCod 	//Filial
	Where ViaSts <> 'C'			//Diferente de Canceladas
	
	&ViaTot += 1	//Total de viagens realizadas
	
EndFor

//Calcula as porcentagens para o progrress
If &QtdViaCod > 0
	&ViaTot = (&QtdViaCod/&ViaTot)*100
EndIf
If &QtdMotTra > 0
	&MotPorc = (&QtdMotTra/&QtdMotCod)*100
EndIf
If &QtdPlaCod > 0
	&PlaPorc = (&QtdPlaCod/&QtdVeiCod)*100
EndIf
If &QtdCNHAtr > 0
	&CNHPorc = (&QtdCNHAtr/&QtdMotCod)*100
EndIf
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
