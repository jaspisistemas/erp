      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtConfiguracoesPasta)
&Random = Random() * 10000
&Filename = &SdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + "ExportarProducao" + &Random.ToString().Trim() + !".xlsx"
&DiretorioVirtual = &SdtConfiguracoesPasta.PastaDiretorioTempVir.Trim() + "ExportarProducao" + &Random.ToString().Trim() + !".xlsx"

&ExcelDocument.Open(&Filename)
&ExcelDocument.Clear()
	
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	&FilFan = FilFan
	Exit
EndFor

&CellRow = 1
&ExcelDocument.Cells(&CellRow,1).Bold = True
////&ExcelDocument.Cells(&CellRow,1).Color = 14
&ExcelDocument.Cells(&CellRow,1).Text = &FilFan
&CellRow += 1
&ExcelDocument.Cells(&CellRow,1).Bold = True
//&ExcelDocument.Cells(&CellRow,1).Color = 14
&ExcelDocument.Cells(&CellRow,1).Text = 'ENTRADA DA PRODUÇÃO'

&CellRow += 2

&ExcelDocument.Cells(&CellRow,1).Bold = True
//&ExcelDocument.Cells(&CellRow,1).Color = 14
&ExcelDocument.Cells(&CellRow,1).Text = "Referência"

&ExcelDocument.Cells(&CellRow,2).Bold = True
//&ExcelDocument.Cells(&CellRow,2).Color = 11
&ExcelDocument.Cells(&CellRow,2).Text = "Nome Produto"

&ExcelDocument.Cells(&CellRow,3).Bold = True
//&ExcelDocument.Cells(&CellRow,3).Color = 11
&ExcelDocument.Cells(&CellRow,3).Text = "Grupo Produto"

&ExcelDocument.Cells(&CellRow,4).Bold = True
//&ExcelDocument.Cells(&CellRow,4).Color = 11
&ExcelDocument.Cells(&CellRow,4).Text = "Quantidade"

//&ExcelDocument.Cells(&CellRow,5).Bold = True
//&ExcelDocument.Cells(&CellRow,5).Color = 11
//&ExcelDocument.Cells(&CellRow,5).Text = "SubGrupo"
&CellRow += 1

For Each Order EmpCod, FilCod, GrupHiePadL, ProGraRefPadL
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PrdDtaEnt >= &iniPedDtaEms and PrdDtaEnt <= &finPrdDtaEnt 
	
	if &AuxProCod <>  ProCod or &AuxProGraCod <> ProGraCod
		if &PrdItmQtd > 0
			&sdtProdutosItem = new()
			&sdtProdutosItem.ProRef 	= &ProGraRef
			&sdtProdutosItem.ProNom 	= &ProNom
			&sdtProdutosItem.PedQtd 	= &PrdItmQtd
			&sdtProdutosItem.GrupHie 	= &GrupHie
			&sdtProdutosItem.GrupNomComp = &GrupNomComp
			&sdtProdutos.Add(&sdtProdutosItem)
		EndiF
		&PrdItmQtd = 0
	Endif
	
	&PrdItmQtd += PrdItmQtd
	
	&GrupHie = GrupHie
	&AuxProCod = ProCod
	&AuxProGraCod = ProGraCod
	&ProGraRef = ProGraRef
	&ProNom = ProNomGra	
	&GrupNomComp = GrupNomCmp
	
EndFor

if &PrdItmQtd > 0	
	&sdtProdutosItem = new()
	&sdtProdutosItem.ProRef  = &ProGraRef
	&sdtProdutosItem.ProNom  = &ProNom
	&sdtProdutosItem.PedQtd  = &PrdItmQtd
	&sdtProdutosItem.GrupHie = &GrupHie
	&sdtProdutosItem.GrupNomComp = &GrupNomComp
	&sdtProdutos.Add(&sdtProdutosItem)
Endif

&GrupHie.SetEmpty()

For &sdtProdutosItem in &sdtProdutos
	
	&ExcelDocument.Cells(&CellRow,1).Bold = false
//	&ExcelDocument.Cells(&CellRow,1).Color = 10
	&ExcelDocument.Cells(&CellRow,1).Text = &sdtProdutosItem.ProRef.Trim()
	
	&ExcelDocument.Cells(&CellRow,2).Bold = false
//	&ExcelDocument.Cells(&CellRow,2).Color = 10
	&ExcelDocument.Cells(&CellRow,2).Text = &sdtProdutosItem.ProNom.Trim()
	
//	if &sdtProdutosItem.GrupHie <> &GrupHie
//		For Each Order EMpCod, GrupCod
//			Where EmPCod = &EmpCod
//			Where GrupCod = &sdtProdutosItem.GrupHie
//			
//			&Grup
//		EndFor
//		
//	Endif
//	&GrupHie = &sdtProdutosItem.GrupHie
	
	&ExcelDocument.Cells(&CellRow,3).Bold = false
//	&ExcelDocument.Cells(&CellRow,3).Color = 10
	&ExcelDocument.Cells(&CellRow,3).Text = &sdtProdutosItem.GrupNomComp.Trim()
	
	&QuantidadeFormatadaRedonda = &sdtProdutosItem.PedQtd
	&ExcelDocument.Cells(&CellRow,4).Bold = false
//	&ExcelDocument.Cells(&CellRow,4).Color = 10	
	&ExcelDocument.Cells(&CellRow,4).Text = &QuantidadeFormatadaRedonda.ToFormattedString()
	
	&CellRow += 1
EndFor

&ExcelDocument.Save()
&ExcelDocument.Close()
]]></Source>
