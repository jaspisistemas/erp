      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each order EmpCod, SerItmCod
	where EmpCod = &EmpCod
	where SerItmCod = &SerItmCod
	&SerItmAbv = SerItmAbv
	&SerCliCod = SerCliCod
	&SerItmPlanCod = SerItmPlanCod
	&SerItmCbrCod = SerItmCbrCod
	if SerItmDesc = 0
		&SerItmVlr = SerItmVlr
	else
		&SerItmVlr = SerItmVlr - (SerItmVlr * (SerItmDesc / 100))
	EndIf
	&SerItmTip = SerItmTip
	&SerCliNom = SerCliNom
	Do 'New'
	exit
EndFor

Commit

Sub 'New'	
	New
		DupTmpEmpCod = &EmpCod
		DupTmpFilCod = &FilCod
		DupTmpCreCod = &Count //PRA NAO INTERFERIR POIS É CHAVE PK
		DupTmpPesCod = &PesCod
		DupTmpCreNovCliRaz = &SerCliNom
		DupTmpCreVenCod = &SerItmCod  // USANDO ESTA CAMPO PARA SerItmCod
		DupTmpCreDupNro = substr(&SerItmTip, 1, 1) + '.' + &SerItmAbv + '-AVULSA'   //&SerDupNro
		DupTmpCreDtaEms = ServerDate()
		DupTmpCreDtaVct = ServerDate()
		DupTmpCreVlrDup = &SerItmVlr
		DupTmpCreVlrSdo = &SerItmVlr
		DupTmpCreCliCod = &SerCliCod 	//Verificar &PesCod
		DupTmpCreRecPag = &CreRecPag
		DupTmpCreBloNro = '' //&CreBloNro
		DupTmpCreCodBar = '' 		//&SerCodBar
		DupTmpCrePlanCod = &SerItmPlanCod
		DupTmpCreCbrCod = &SerItmCbrCod
		DupTmpCreFilPgt = &FilCod
		DupTmpCreSts = 'A' //Ativa
	EndNew
EndSub


]]></Source>
