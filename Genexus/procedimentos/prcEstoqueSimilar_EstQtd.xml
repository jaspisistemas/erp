      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&AuxSimEstQtd = 0
&ProQtdMin = 0
&ProQtdMax = 0

//Calcula a quantidade de estoque em similares
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	&ProQtdMin = ProQtdMin
	&ProQtdMax = ProQtdMax
	
	For Each Order EmpCod, FilCod, ProCod, ProGraCod
		Where FilCod = &FilCod
		Where ProGraCod = 1
		
		&EstLoc = EstLoc
		&AuxSimEstQtd = EstQtd 
		
		Exit	
	EndFor
	Exit
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
