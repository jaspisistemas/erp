      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order tmpNFeCod
	where tmpNFeCod = &tmpNFeCod
	
	For Each Order tmpNFeCod, tmpNfeItmCod
		delete
	EndFor
	delete
EndFor

commit

For each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	//CST PIS COFINS PADRAO
	&TbLctCstPisCof = retornaPisCofinsPadrao.Udp(EmpCod, FilCod, LctCod)
	&VarcharPisCofins = &TbLctCstPisCof.ToString()
	
	//MODELO PADRAO
	if not LctModPad.IsEmpty() and not LctModPad.IsNull()
		&tmpModCod = LctModPad
	Else
		&tmpModCod = '55'
	Endif

	&FatFilCod = PedFatFilCod
	If &FatFilCod.IsEmpty()
		&FatFilCod = FilCod
	EndIF
	RetornaFilialBaseImposto.Call(&EmpCod, &FatFilCod, &ImpFilCod)
	
	&ImpUfeCod = PedCliCidUfeCod
	&ImpLctCod = LctBasImpCod
	&ImpGruImpCod = PedCliGruImpCod
	
	&PedVlrFrt = PedVlrFrt
	New
		tmpNFeCod = &tmpNFeCod
		tmpEmpCod = &EmpCod
		tmpNfeDtaMod = serverdate()
		tmpFilCod = FilCod
		tmpPedCod = PedCod
		tmpModCod = &tmpModCod
		tmpNfeDtaEms.SetEmpty() //= &PedDtaFat //JDF comentei pois Eliandro pediu para trazer vazio, se algum cliente uqer trazer preenchido fazer paramentro sistema.
		tmpNfeDtaDsp = &PedDtaFat
		tmpNfeFatFilCod = &FatFilCod	
		tmpNfeSer = '1'	
		tmpTotPro = 0
		tmpTotFrt = PedVlrFrt
		tmpTotSeg = 0
		tmpTotOut = 0
		tmpTotDsc = 0
		tmpTotPed = 0
		tmpTotNFe = PedVlrLiq
	EndNew

	commit
	
	For Each Order EmpCod, FilCod, PedCod
		Where PedQtd > 0				
		
		&ImpCatCod = ProCatCod
		&tmpProCod = ProCod
		New
			tmpNFeCod = &tmpNFeCod
			tmpNfeItmCod = PedItmCod
			tmpProCod = ProCod
			tmpProGraCod = ProGraCod
			tmpProRef = ProGraRef
			
			tmpProNom = ProNomGra.Trim() + ' ' + trim(PedItmCmp)
			tmpProNom = tmpProNom.Trim()
			
			tmpPedQtd = PedQtdEmb
			tmpPedVlrUnt = PedVlrUnt
			&tmpPedVlrTot = PedVlrUnt * PedQtdEmb
			tmpNcmCod = NcmCod
			tmpNcmCEST = trim(str(ProNcmCest))
			tmpUnd = ProEmbUnd
						
			do 'tabImposto'
			
			if &sdtCadastrotabelaImpostoCbs.sts <> 'S' //Nao Localizado
				tmpCFOP = '0.000'
				tmpNfeSitCod = '999'
			Else
				tmpCFOP = &sdtCadastrotabelaImpostoCbs.CImpCfoCod
				tmpNfeSitCod = &sdtCadastrotabelaImpostoCbs.CImpCstCod
			Endif
		
			tmpProPerIcm = PedItmIcm
			tmpProVlrIcm = PedItmVlrIcm * PedQtdEmb
			tmpProBasVlrIcm = &tmpPedVlrTot
			
			//DIFERIMENTO
			tmpProPerDif = 0
			tmpProVlrDif = 0
			
			tmpProVlrIcmSt = PedItmVlrIcmSt * PedQtdEmb
			tmpProBasVlrIcmSt = &tmpPedVlrTot
			tmpProPerIcmSt = PedItmIcmSt 
			
			tmpProBasVlrIpi = &tmpPedVlrTot
			tmpProPerIpi = PedItmIpi
			tmpProVlrIpi = PedItmVlrIpi * PedQtdEmb
			
			//PIS e COFINS
			tmpProBasPIS = PedItmPisBas
			tmpProBasCofins = PedItmPisBas
			tmpProPerPIS = PedItmPis
			tmpProPerCOFINS = PedItmCofins
			tmpProVlrPIS = PedItmPisVlr * PedQtdEmb
			tmpProVlrCOFINS = PedItmCofinsVlr * PedQtdEmb
			
			tmpPedVlrTot = &tmpPedVlrTot
			
			tmpImpCstPis.FromString(&VarcharPisCofins)
			tmpNfeCstPIS.FromString(&VarcharPisCofins)
			tmpNfeCstCofins.FromString(&VarcharPisCofins)

		EndNew
	EndFor

EndFor

commit


For Each Order tmpNFeCod
	Where tmpNFeCod = &tmpNFeCod
	
	tmpTotPro += (tmpPedQtd * tmpPedVlrUnt )
	
	tmpTotBasIcm += tmpProBasVlrIcm
	tmpTotVlrIcm += tmpProVlrIcm
	tmpTotBasSt += tmpProBasVlrIcmSt
	tmpVlrSt += tmpProVlrIcmSt
	tmpTotIpi += tmpProVlrIpi
EndFor

commit


sub 'tabImposto'
	
	RetornaRegimeTributarioFilial.Call(&EmpCod, &ImpFilCod, &FilRegTrib, &CImpOriUfeCod)
	&sdtCadastroTabelaImpostoCbs = new()
	&sdtCadastroTabelaImpostoCbs.EmpCod = &EmpCod
	&sdtCadastroTabelaImpostoCbs.CImpTbFilCod = &ImpFilCod
	&sdtCadastroTabelaImpostoCbs.CImpLctCod = &ImpLctCod
	&sdtCadastroTabelaImpostoCbs.CImpOriUfeCod = &CImpOriUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpDstUfeCod = &ImpUfeCod
	&sdtCadastroTabelaImpostoCbs.CImpGruImpCod = &ImpGruImpCod
	&sdtCadastroTabelaImpostoCbs.CImpCatCod = &ImpCatCod
	&sdtCadastroTabelaImpostoCbs.ProCod = &tmpProCod
	&sdtCadastroTabelaImpostoCbs.CImpDtaIni = serverdate()
	prcRetornaConfiguracaoImposto_IBSCBS.Call(&sdtCadastrotabelaImpostoCbs)
		
EndSub

]]></Source>
