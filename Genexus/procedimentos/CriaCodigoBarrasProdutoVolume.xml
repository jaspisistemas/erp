      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Codigo8 = &ProCod
&ProQtdEmb = &parProQtdEmb
if &ProQtdEmb < 999
	&NewProBar = '33'+ padL(trim(str(&Codigo8)), 7, '0') + padL(trim(str(&ProQtdEmb)), 3, '0')
	digitoEAN13.Call(&NewProBar, &NewProBar)
	ValidaEan13.Call(&ProCod, &NewProBar, &NewProBar, &ErroEan13Mensagem)
	ValidaCodigoReferenciaRepetido.Call(&EmpCod, 0, 0, &NewProBar, &ErroEan13Mensagem)
Else
	&ProQtdEmb = 0
	&ErroEan13Mensagem = 'campo grande'
Endif

	
do While Not &ErroEan13Mensagem.IsEmpty()
	if &ProQtdEmb > 999
		&ProQtdEmb = 1
		&Codigo8 = Random() * 100000000
	Else
		&ProQtdEmb += 1
	Endif	
	&NewProBar = '33'+ padL(trim(str(&Codigo8)), 7, '0') + padL(trim(str(&ProQtdEmb)), 3, '0')
	
	digitoEAN13.Call(&NewProBar, &NewProBar)
	ValidaCodigoReferenciaRepetido.Call(&EmpCod, 0, 0, &NewProBar, &ErroEan13Mensagem)
EndDo

&ProBar = &NewProBar
GravaCodigoProduto.Call(&EmpCod, &ProCod, &ProGraCod, &NewProBar, 'E', &parProQtdEmb, 0, 999, &Mensagem, &IsErro)

]]></Source>
