      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

if &TabCod.IsEmpty()
	&Filtro = 'TODAS AS TABELAS'
else
	&Filtro = 'TABELA: ' + trim(&TabCod)
EndIF

if &AnaliticoSintetico = 'F' //INCLUIR NOTAS
	&VarTituloTotalNotas = trim(toformattedString(&TotalNotasPedidosMoeda))
Endif

&titulo = 'VENDAS POR TABELA'
Do Case
	CAse &Agrupar = 'E' //Agrupar por Estado (UF):E,
		&Filtro += ' | AGRUPAR POR ESTADO'
		&titulo = 'VENDAS POR UF'
	Case &Agrupar = 'F' //Ordenar por Faturamento:F
		&Filtro += ' | ORDENAR FATURAMENTO'
	Case &Agrupar = 'T' //Agru
		&Filtro += ' | AGRUPAR POR TABELA'
		&titulo = 'VENDAS POR TABELA'
EndCAse

&Filtro += ' | FAT:' + trim(toformattedString(&iniPedDtaFat)) +'/'+ trim(toformattedString(&finPedDtaFat))
Header
	&titulo = 'VENDAS POR TABELA'
	
	print Cabecalho
	print printFiltro
	if &AnaliticoSintetico = 'F'
		print printTotalUF
	Endif
End

 
For Each 
	Order EmpCod, FilCod, PedCliCidUfeCod, PedDtaFat when &Agrupar = 'E' //Agrupar por Estado (UF):E,
	Order EmpCod, FilCod, PedDtaFat when &Agrupar = 'F' //Ordenar por Faturamento:F
	Order EmpCod, FilCod, TabCod, PedDtaFat when &Agrupar = 'T' //Agrupar por Tabela:T, 	
	
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedVenCod = &PedVenCod when not &PedVenCod.IsEmpty()
	Where PedVenAreCod = &PedVenAreCod when Not &PedVenAreCod.IsEmpty()
	where PedCliCod = &PedCliCod when not &PedCliCod.IsEmpty()
	where PedCliCidCod = &PedCliCidCod when not &PedCliCidCod.IsEmpty()
	Where PedCliCidAreCod = &PedCliCidAreCod when not &PedCliCidAreCod.IsEmpty()
	where PedCliCidUfeCod = &PedCliCidUfeCod when not &PedCliCidUfeCod.IsEmpty()
	Where PedCliRatCod = &RatCod when not &RatCod.IsEmpty()
	
	Where (PedSts = &PedSts) or &PedSts.IsEmpty() and (PedSts = Status_Pedido.ABERTO or PedSts = Status_Pedido.FECHADO or PedSts = Status_Pedido.SEPARANDO)
	
	//where PedDtaFat >= &iniPedDtaFat and PedDtaFat <= &finPedDtaFat
	Where (PedDtaEms >= &iniPedDtaFat And PedDtaEms <= &finPedDtaFat) When &PedSts <> Status_Pedido.FECHADO
	Where (PedDtaFat >= &iniPedDtaFat And PedDtaFat <= &finPedDtaFat) When &PedSts = Status_Pedido.FECHADO
	
	where LctCod = &LctCod when not &LctCod.IsEmpty()
	Where LctGerFin = &LctGerFin when not &LctGerFin.IsEmpty()
	Where LctAtuSal = &LctAtuSal
	where TabCod = &TabCod when not &TabCod.IsEmpty()	
	
	Do Case
		Case &Agrupar = 'E'//Agrupar por Estado (UF):E,
			if &AuxUfeCod <> PedCliCidUfeCod 
				If not &AuxUfeCod.IsEmpty()
					
					if &AnaliticoSintetico = 'A'
						print tracocurto
					Else
						Noskip
					endif
					
					&TotalUFNotas = ''
					if &AnaliticoSintetico = 'F' //INCLUIR NOTAS
						&TotalUFNotas = trim(toformattedString(&TotalNotasPedidosMoeda))
					Endif
					&TotalNotasPedidosMoeda = 0
					print TotalUF
					&UfPedVlrLiq = 0
				EndIF
				&AuxUfeCod = PedCliCidUfeCod
				do 'GetUF'
				print printEstado
			EndIF
			
		Case &Agrupar = 'T' //Agrupar por Tabela:T, 	
			If &AuxTabCod <> TabCod 
				if not &AuxTabCod.IsEmpty()
					
					if &AnaliticoSintetico = 'A'
						print tracocurto
					Else
						Noskip
					endif
					
					&TotalUFNotas = ''
					if &AnaliticoSintetico = 'F' //INCLUIR NOTAS
						&TotalUFNotas = trim(toformattedString(&TotalNotasPedidosMoeda))
					Endif
					&TotalNotasPedidosMoeda = 0
					
					print TotalTabela
					&TabPedVlrLIq = 0
				EndIF
				
				&AuxTabCod = TabCod
				&printTabNom = TabNom
				&PrintTabCod = TabCod
				
				Print Tabela
			EndIF
			
	EndCase

	if &AnaliticoSintetico = 'F' //INCLUIR NOTAS
		RetornaTotalNotasPedido.call(EmpCod, FilCod, PedCod, &TotalNotasMoeda)
		&TotalNotasPedidosMoeda += &TotalNotasMoeda
	Endif

	&TotPedVlrLiq = (PedVlrLiq - PedVlrGnre - PedVlrFrt - PedVlrOut - PedVlrIpi)
	&UfPedVlrLiq += &TotPedVlrLiq
	&TabTotPedVlrLIq = (PedVlrLiq - PedVlrGnre - PedVlrFrt - PedVlrOut - PedVlrIpi)
	&TabPedVlrLIq += &TabTotPedVlrLIq
	&TotGerPedVlrLiq = (PedVlrLiq - PedVlrGnre - PedVlrFrt - PedVlrOut - PedVlrIpi)
	&GerPedVlrLIq += &TotGerPedVlrLiq 
	
	if &AnaliticoSintetico = 'A'
		print pedido
	Endif
EndFor

Do Case
	Case &Agrupar = 'E'//Agrupar por Estado (UF):E,
		if &AnaliticoSintetico = 'A'
			print tracocurto
		Else
			Noskip
		endif
		&TotalUFNotas = ''
		if &AnaliticoSintetico = 'F' //INCLUIR NOTAS
			&TotalUFNotas = trim(toformattedString(&TotalNotasPedidosMoeda))
		Endif
		&TotalNotasPedidosMoeda = 0
		
		print TotalUF
		
	Case &Agrupar = 'T' //Agrupar por Tabela:T, 
		if &AnaliticoSintetico = 'A'
			print tracocurto
		Else
			Noskip
		endif
		&TotalUFNotas = ''
		if &AnaliticoSintetico = 'F' //INCLUIR NOTAS
			&TotalUFNotas = trim(toformattedString(&TotalNotasPedidosMoeda))
		Endif
		&TotalNotasPedidosMoeda = 0
		
		print TotalTabela
EndCase

print TotalPeriodo

Footer
	print Rodape
End

sub 'GetUF' 
	For Each Order EmpCod, UfeCod
		Where EmpCod = &EmpCod
		Where UfeCod = &AuxUfeCod
		&UfeCodNom = UfeCodNom
		Exit
	EndFor
EndSUb
