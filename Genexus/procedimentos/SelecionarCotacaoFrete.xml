      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

For Each ORder EmpCod, CotCod
	Where EmpCod = &EmpCod
	Where CotPedCod = &CotPedCod
	CotIs = false
EndFor

if &OqueFazer = 'ADD'
	For Each Order EmpCod, CotCod
		Where EmpCod = &EmpCod
		Where CotCod = &CotCod
		CotIs = true
		Exit
	EndFor
EndiF

Commit
]]></Source>
