      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//JDF - AQUI NAO VAI COLOCAR O USE. POIS AS CONFIGURACOES VAI FICAR NA BASE DO ERP

For Each Order EmpCod, LogErpTabCod
	Where EmpCod = &EmpCod
	Where LogErpTabCod = upper(&LogErpTabCod)
	&LogErpTabIsLog = LogErpTabIsLog
	Exit
When None
	&LogErpTabIsLog = false
	
	For Each Order EmpCod
		Where EmpCod = &EmpCod
		&LogErpTabIsLog = EmpIsLog
		
		New
			EmpCod = &EmpCod
			LogErpTabCod = upper(&LogErpTabCod)
			LogErpTabIsLog = &LogErpTabIsLog
		EndNew
		
		Commit
		
		Exit
	EndFor

EndFor
]]></Source>
