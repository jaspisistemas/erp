      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[for Each order EmpCod, PdvCod
	Where PdvRandon = &PdvRandon //PRA SABER SE É UM PDV VALIDO
	
	&EmpCod = EmpCod
//	&FilCod = PdvFIlCod
	
	Exit
When none 
	Return
EndFor
  
For Each Order EmpCod, PesCod
	Where EmpCod = &EmpCod
	Where PesCod = &PesCod
	
	&sdtGetCobrancaPDV.CliCod = PesCod
	
	&sdtGetCobrancaPDV.Sts = 'J200'
	&sdtGetCobrancaPDV.Msg = 'Cliente localizado'
	
	Exit
When none
	&sdtGetCobrancaPDV.Sts = 'E998'
	&sdtGetCobrancaPDV.Msg = 'Cliente não localizado'
	Return
EndFor


For Each Order EmpCod, CreCliCod, CreDtaEms, CreCod
	Where EmpCod = &EmpCod
	Where CreCliCod = &PesCod
	Where CreVlrSdo > 0
	Where CreRecPag = ReceberPagar.Receber
	Where CreSts <> Status_Duplicata.CANCELADA
	Where CreFrpPgtoTip = TipoDuplicata.DUPLICATA
	
	
	&Pagina = &parPaginaSelecionada
	&QtdRegistros = &parQtdRegistros
	if &QtdRegistros.IsEmpty()
		&QtdRegistros = 20
	Endif
	
	if &Pagina.IsEmpty()
		&Pagina = 1
	Endif
	
	if &IsPaginaOk = false
		if &TestaPagina = true
			if &QtdPaginas = &Pagina				
				&IsPaginaOk = true
			Else
				&QtdLInhasPagina = 0
				&sdtGetCobrancaPDV.Dup.Clear()
				&TestaPagina = false
			Endif
		Endif
		
		if &IsPaginaOk = false			
			&sdtGetCobrancaPDVDupItem = new()
			&sdtGetCobrancaPDVDupItem.DtaEms = CreDtaEms
			&sdtGetCobrancaPDVDupItem.DtaVct = CreDtaVct
			&sdtGetCobrancaPDVDupItem.DupNro = CreDupNro
			&sdtGetCobrancaPDVDupItem.PedCod = CrePedCod
			
			&CreFilPgt = FilCod
			&PedCod = CrePedCod
			do 'GetNfe'
			&sdtGetCobrancaPDVDupItem.NroNfe = &NfeNum
			&sdtGetCobrancaPDVDupItem.SerNfe = &NfeSer		
			&sdtGetCobrancaPDVDupItem.VlrSdo = CreVlrSdo		
			
			&sdtGetCobrancaPDV.Dup.Add(&sdtGetCobrancaPDVDupItem)
			
		Endif		
	Endif
	
	&QtdLInhasPagina += 1
	if (&QtdLinhasPagina = &QtdRegistros)
		&QtdPaginas += 1
		&TestaPagina = true
		&QtdLInhasPagina = 0
	Endif
	
	
EndFor

&sdtGetCobrancaPDV.Pagina = &QtdPaginas


Sub 'GetNfe'
	
	&NfeNum.SetEmpty()
	&NfeSer.SetEmpty()
	For Each ORder EmpCod, FilCod, NfePedCod, NfeSts
		Where EmpCod = &EmpCod
		Where NfeFilCod = &CreFilPgt
		Where NfePedCod = &PedCod
		Where NfeSts = Status_Nfe.Autorizada
		
		&NfeNum = NfeNum
	 	&NfeSer = NfeSer
		Exit
	EndFor
EndSUb
]]></Source>
