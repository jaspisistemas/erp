      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsErro = false

If &PesCod <> 0
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesCod = &PesCod
		where PesIsTra = true
		&PesRaz = PesRaz
		Exit
	When none
		&IsErro = true
		&PesRaz = 'TRANSPORTADORA NAO LOCALIZADA'
	EndFor
Else
	Do Case
		Case &AceitaTodos_SN = 'S'
			&PesRaz = 'TODAS AS TRANSPORTADORAS'
		Case &AceitaTodos_SN = 'N'
			&IsErro = true
			&PesRaz = 'TRANSPORTADORA NÃO INFORMADA'
		Otherwise
			&PesRaz = ''
	EndCase
	
EndIF

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
