      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

&LogGUID = GUID.newGuid()

if &IsAcessoConcedido = true //Acesso conced
	
	&DataHora = serverNow()
	&inicioPedDtaFat = timestampToDate(&dataInicioTmp)
	&finalPedDtaFat = timestampToDate(&dataFimTmp)
	
	if &PedVenCod > 0
		&AuxPedVenCod = &PedVenCod
	Endif

	if &wwpContext.PesCod <> &AuxPedVenCod and &wwpContext.TipoPerfil <> 3 //verifica se eu posso ver vendas de todos os vendedores
		retornaautorizacaoApi.Call('WD_VISUALIZARVENDASTODOS', &wwpContext, &parAutGrpCod, &WD_VISUALIZARVENDASTODOSAutNiv)
		if &WD_VISUALIZARVENDASTODOSAutNiv < 1
			&AuxPedVenCod = &wwpContext.PesCod
		Endif
	Endif
	
	if &auxFilCod = 0
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAceNiv > 0				
				&collFilCod.add(PesFilAce)
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif
	Else
		if &wwpContext.PesCod > 0
			For Each Order EmpCod, PesCod, PesFilAce
				Where EmpCod = &wwpContext.EmpCod
				Where PesCod = &wwpContext.PesCod
				Where PesFilAce = &auxFilCod
				Where PesFilAceNiv > 0				
				&collFilCod.add(PesFilAce)
			EndFor
		Else
			For each Order EmpCod, FilCod
				Where EmpCod = &wwpContext.EmpCod
				Where FilCod = &auxFilCod
				&collFilCod.Add(FilCod) 
			EndFor
		Endif	
	EndIf
	
	if &collFilCod.Count = 0
		&sdtRetornoWbsEtc.sts = 'E998'	
		&sdtRetornoWbsEtc.obs = 'Não autorizado a acessar dados de vendas!'
	Else
//		gravaLogDevNew.Call(1, &LogGUID, &Pgmname, 'prcTotalVendasHojeTicketMedioVendedor', '')
//		gravaLogDevNew.Call(1, &LogGUID, &Pgmname, 'prcTotalVendasHojeTicketMedioVendedor', &collFilCod.ToJson())
//		
//		gravaLogDevNew.Call(1, &LogGUID, &Pgmname, '&inicioPedDtaFat', &inicioPedDtaFat.ToString())
//		gravaLogDevNew.Call(1, &LogGUID, &Pgmname, '&finalPedDtaFat', &finalPedDtaFat.ToString())
//		gravaLogDevNew.Call(1, &LogGUID, &Pgmname, '&AuxPedVenCod', &AuxPedVenCod.ToString())
		prcTotalVendasHojeTicketMedioVendedor.Call(&wwpContext.EmpCod, &collFilCod, &AuxPedVenCod, &inicioPedDtaFat, &finalPedDtaFat, &TotalPedVlrLiq, &MediaMoeda, &QtdPedidos)
//		gravaLogDevNew.Call(1, &LogGUID, &Pgmname, 'J200', '')
		&sdtRetornoWbsEtc.sts = 'J200'
	Endif
	
	&sdtRetornoWbsEtc.c1 = trim(toformattedString(&TotalPedVlrLiq)) //total vendido
	&sdtRetornoWbsEtc.c2 = trim(toformattedString(&MediaMoeda)) //media
	&sdtRetornoWbsEtc.c3 = trim(toformattedString(&QtdPedidos)) //qtd pedidos
	&sdtRetornoWbsEtc.c4 = trim(toformattedString(&DataHora)) //data atualizado
	&sdtRetornoWbsEtc.c5 = trim(toformattedString(&AuxPedVenCod)) //Vendedor
	if &collFilCod.Count = 1
		For &FilCod in &collFilCod
			&sdtRetornoWbsEtc.c6 = trim(toformattedString(&FilCod))
		Endfor
	
	Else
		&sdtRetornoWbsEtc.c6 = '0'
	Endif

	
	&sdtRetornoWbsEtc.c7 = &inicioPedDtaFat.ToFormattedString()
	&sdtRetornoWbsEtc.c8 = &finalPedDtaFat.ToFormattedString()

	
Endif
]]></Source>
