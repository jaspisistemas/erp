      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


&TefCod = 0
For each ORder EmpCod, (TefCod)
	Where EmpCod = &EmpCod
	&TefCod = TefCod
	Exit
EndFor
&TefCod += 1


new
	EmpCod = &EmpCod
	TefCod = &TefCod
	TefFilCod = &TefFilCod
	TefPedCod = &TefPedCod
	TefBanCarCod = &BanCarCod
	TefDtaSol = serverDate()
	TefHorSol = serverTime()
	TefSts = 'P'
	TefVlr = &TefVlr
	TefCreDebVou = &TefCreDebVou
	TefCrePar = &TefCrePar
	TefStsSyncServ = 'N'
	&GUID = GUID.NewGuid()
	TefGUID = &GUID.ToString()
EndNEw

Commit

]]></Source>
