      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsPodeFaturarOrdemCarregamento = true

For Each order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &pedCod
	
	&PedCodOciRef = PedCodOciRef
	
	If PedStsGer <> Pedido_gerado.OrdemCarregamento
		Return
	EndIf


	For Each Order EmpCod, FilCod, PedCod, PedItmCod
		
		&PedQtdSdo = RetornaSaldoPedQtdSdo.UDP(EmpCod, FilCod, &PedCodOciRef,ProCod,ProGraCod)
		If PedQtd > &PedQtdSdo
			&IsPodeFaturarOrdemCarregamento = false
			return
		Endif
	
	EndFor

EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
