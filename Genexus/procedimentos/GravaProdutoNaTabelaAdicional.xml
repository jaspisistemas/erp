      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&dataVazia.SetEmpty()
For Each Order EmpCod, TabCod, ProCod, ProGraCod, (TabAltCod)
    Where EmpCod = &EmpCod
	Where TabCod = &TabNum
    Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod when &ProGraCod > 1
	Where TabAltCod = &TabAltCod
	
	TabPrcIsTip = &TabPrcIsTip
	
	TabPerAcr = &TabPerAcr
	TabPerAnt = &TabPerAnt
	If &TabPerAnt > 0
		TabDtaVct = &TabDtaVct
	Else
		TabDtaVct = &dataVazia
	EndIf

	Exit
EndFor

commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
