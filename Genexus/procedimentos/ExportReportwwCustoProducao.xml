Sub 'PrintFilters'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	If not &TcpAno.IsEmpty()
		print printBlockFilterTcpAno
	EndIf
	If not &TcpMes.IsEmpty()
		&FilterTcpMesValueDescription = ''
		Do Case
			Case &TcpMes = 1
				&FilterTcpMesValueDescription = "Janeiro" 

			Case &TcpMes = 2
				&FilterTcpMesValueDescription = "Fevereiro" 

			Case &TcpMes = 3
				&FilterTcpMesValueDescription = "Março" 

			Case &TcpMes = 4
				&FilterTcpMesValueDescription = "Abril" 

			Case &TcpMes = 5
				&FilterTcpMesValueDescription = "Maio" 

			Case &TcpMes = 6
				&FilterTcpMesValueDescription = "Junho" 

			Case &TcpMes = 7
				&FilterTcpMesValueDescription = "Julho" 

			Case &TcpMes = 8
				&FilterTcpMesValueDescription = "Agosto" 

			Case &TcpMes = 9
				&FilterTcpMesValueDescription = "Setembro" 

			Case &TcpMes = 10
				&FilterTcpMesValueDescription = "Outubro" 

			Case &TcpMes = 11
				&FilterTcpMesValueDescription = "Novembro" 

			Case &TcpMes = 12
				&FilterTcpMesValueDescription = "Dezembro" 

		EndCase

		print printBlockFilterTcpMes
	EndIf

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrintColumnTitles'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	print printBlockBeforeGrid
	print printBlockLines_titles

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'PrintData'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	For each
		order TcpAno  when &OrderedBy = 1 AND &OrderedDsc = False
		order (TcpAno)  when &OrderedBy = 1 AND &OrderedDsc = True
		order TcpMes  when &OrderedBy = 2 AND &OrderedDsc = False
		order (TcpMes)  when &OrderedBy = 2 AND &OrderedDsc = True
		order TcpForCod  when &OrderedBy = 3 AND &OrderedDsc = False
		order (TcpForCod)  when &OrderedBy = 3 AND &OrderedDsc = True
		order TcpQtdFun  when &OrderedBy = 4 AND &OrderedDsc = False
		order (TcpQtdFun)  when &OrderedBy = 4 AND &OrderedDsc = True
		order TcpDias  when &OrderedBy = 5 AND &OrderedDsc = False
		order (TcpDias)  when &OrderedBy = 5 AND &OrderedDsc = True
		order TcpVlrCus  when &OrderedBy = 6 AND &OrderedDsc = False
		order (TcpVlrCus)  when &OrderedBy = 6 AND &OrderedDsc = True
		
		using DSwwCustoProducao(&TcpAno, &TcpMes)
		&TcpMesDescription = ''
		Do Case
			Case TcpMes = 1
				&TcpMesDescription = "Janeiro" 

			Case TcpMes = 2
				&TcpMesDescription = "Fevereiro" 

			Case TcpMes = 3
				&TcpMesDescription = "Março" 

			Case TcpMes = 4
				&TcpMesDescription = "Abril" 

			Case TcpMes = 5
				&TcpMesDescription = "Maio" 

			Case TcpMes = 6
				&TcpMesDescription = "Junho" 

			Case TcpMes = 7
				&TcpMesDescription = "Julho" 

			Case TcpMes = 8
				&TcpMesDescription = "Agosto" 

			Case TcpMes = 9
				&TcpMesDescription = "Setembro" 

			Case TcpMes = 10
				&TcpMesDescription = "Outubro" 

			Case TcpMes = 11
				&TcpMesDescription = "Novembro" 

			Case TcpMes = 12
				&TcpMesDescription = "Dezembro" 

		EndCase

		Do 'BeforePrintLine'
		print printBlockLines_data
		Do 'AfterPrintLine'
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

Sub 'LoadGridState'

	/* Generated by DVelop Work With Plus Pattern [Start] - Do not change */

	// Load grid state from session.
	If &Session.Get(!"wwCustoProducaoGridState") = !""
		&GridState.FromXml(LoadGridState.Udp(!"wwCustoProducaoGridState"))
	Else
		&GridState.FromXml(&Session.Get(!"wwCustoProducaoGridState"))
	Endif	

	&OrderedBy = &GridState.OrderedBy
	&OrderedDsc = &GridState.OrderedDsc

	For &GridStateFilterValue in &GridState.FilterValues
		Do Case
			Case &GridStateFilterValue.Name = !"TCPANO"
				&TcpAno.FromString(&GridStateFilterValue.Value)
			Case &GridStateFilterValue.Name = !"TCPMES"
				&TcpMes.FromString(&GridStateFilterValue.Value)
		EndCase
	EndFor

	/* Generated by DVelop Work With Plus Pattern [End] - Do not change */

EndSub

