      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&IsAchou = False
For Each Order EmpCod, CreCarNroAut, CreRecPag, CreDtaVct
    Where EmpCod    = &EmpCod  // Empresa
	//	Where CreBloNro = &CreCarNroAut    // Nosso Número
	Where CreFrpPgtoTip = TipoDuplicata.CARTAOD or CreFrpPgtoTip = TipoDuplicata.CARTAOC
	Where CreCarNroAut = &CreCarNroAut
	Where (CreCarArqc = &CreCarArqc) or (CreCarArqc.IsEmpty() or CreCarArqc.IsNull() or CreCarArqc = '0') when not &CreCarArqc.IsEmpty() //PARCELA REAPROVEITADO O CAMPO.
	Where CreRecPag = ReceberPagar.Receber              // Duplicata a Receber
	where CreSts <> Status_Duplicata.CANCELADA
	
	if CreCarNroNsu = &CreCarNroNsu and not CreCarNroNsu.IsEmpty() and not CreCarNroNsu.IsNull() //Verificar NSU, pois o CreCarNroAut esta vindo repetido ZOOP. - JDF
		&BanCarCod = CreCarBanCod
		do 'GetBandeira'
		if &BanCarConfAut = 'J' //BAIXA MAQUININHA JASPI
			&IsAchou = True
			&FilCod = FilCod
			&CreCod = CreCod
			Exit //Da exit pois o NSU é igual senao fica vendo se tem mais
		Endif
	Else
		&BanCarCod = CreCarBanCod
		do 'GetBandeira'
		if &BanCarConfAut = 'J' //BAIXA MAQUININHA JASPI
			&IsAchou = True
			&FilCod = FilCod
			&CreCod = CreCod
		Endif
	Endif

EndFor


sub 'GetBandeira'
	&BanCarConfAut.SetEmpty()
	For Each Order EmpCod, BanCod
		Where EmpCod = &EmpCod
		Where BanCarCod = &BanCarCod
		
		&BanCarConfAut = BanCarConfAut
		Exit
	EndFor
EndSub


]]></Source>
