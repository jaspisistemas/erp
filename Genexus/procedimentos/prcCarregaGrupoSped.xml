      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//carrega informacao padrao do tipo de lancamento
For Each ORder EmpCod, LctCod
	Where EmpCod = &parEmPCod when not &parEmPCod = 0
	Where LctCod = &parTbLctCod when not &parTbLctCod = 0
	
	&EmPCod = EmpCod
	&TbLctCod  = LctCod
	&TbLctApvIcms = LctAprvICMS //QUANDO REVEMOR DEFINIR COMO PADRAO 100
	&TbLctApvIpi= LctAprvIPI //QUANDO REVEMOR DEFINIR COMO PADRAO 100
	&TbLctCtaFis= LctCodCta
	&TbLctPlaCodRFB = LctCodCtaRFB
	&TbLctPlaNatCrd = LctCodNatCrdPisCof
	&TbLctNatRecCod = LctCodCtaM410
	&TbLctCstPisCof = LctPadPisCof
	
	do 'grupoimposto'
EndFor

Commit

Sub 'grupoimposto'
	//grupo filial imposto
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmPCod	
		
		&FilCod = FilCod
		
		//tipo lancamneots
		For Each Order EmpCod, FilCod, TbLctCod
			Where TbLctCod = &TbLctCod
			
			Exit
		WHen none
			NEw
				EmpCod = &EmPCod
				FilCod = &FilCod
				TbLctCod = &TbLctCod
				
				TbLctApvIcms = &TbLctApvIcms
				TbLctApvIpi = &TbLctApvIpi
				TbLctCtaFis = &TbLctCtaFis
				TbLctPlaCodRFB = &TbLctPlaCodRFB
				TbLctPlaNatCrd = &TbLctPlaNatCrd
				TbLctNatRecCod = &TbLctNatRecCod
				TbLctCstPisCof = &TbLctCstPisCof
				
			EndNEw
		ENdFor
		
	EndFor
EndSUb



]]></Source>
