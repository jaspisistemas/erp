      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
loadWWPContext.Call(&Context)
If &Context.PesCod = 0
	Return
EndIf

&PesRaz = &Context.PesRaz
For Each Order EmpCod, FilCod
	Where EmpCod = &Context.EmpCod
	Where FilCod = &Context.FilCod
	&FilFan = FilFan
	Exit
EndFor

MB 4
MT 2

Header
	&titulo = 'LISTAGEM DE CLIENTES'
	print Cabecalho
	//	if &CnpjIE = 'S'
	//		print TituloCnpj
	//	Else
	//		Print Titulo
	//	EndIF
End


Do Case
	Case &Validar = '1'
		&IsEnderecoRepetido = true
	case &Validar = '2'
		&IsTelefoneRepetido = true	
	Case &validar = '3'
		&IsEmailRepetido = true
	otherwise
		&IsEnderecoRepetido	= true
		&IsEmailRepetido = true
		&IsTelefoneRepetido = true
EndCase

&sdtClientesImpresso.Clear()
if &IsEnderecoRepetido = true	//ENDERECO
	&OqueIMprimir = 'ENDEREÇOS REPETIDOS'
	print OqueImprimir
	
	For Each Order EmpCod, PesCod	
		Where EmpCod = &EmpCod
		Where PesIntVenCod = &PesIntVenCod when not &PesIntVenCod.IsEmpty()
		Where PesSts = Status_ativoInativo.ATIVO
		Where PesIsCli = true when &TipoPessoa = 'C'
		Where PesIsTra = true when &TipoPessoa = 'T'
		Where PesIsFor = true when &TipoPessoa = 'F'
		Where (PesTip = TipoPessoa.JURIDICA and (PesCnpj <> '11.111.111/1111-11' and PesCnpj <> '111.111.111-11')) or (PesTip = TipoPessoa.FISICA and PesCpf <> '111.111.111-11')
		
		&sdtClientes.Clear()
		&AuxPesCod = PesCod
		do 'Verifica'
		
		if &IsJaVerificado = false
			ValidaEnderecoRepetidoColl.Call(EmpCod, PesCod,PesVinCod, PesCep, PesLog, PesNro, PesBai, PesCidCod, &sdtClientes)
			if &sdtClientes.Count > 0
				&Mensagem = 'ENDEREÇO REPETIDO: ' + trim(PesLog) + ', ' + trim(PesNro) + ' - ' + trim(PesBai) + ', ' + PesCidNom.Trim() + '-' + PesCidUfeCod.Trim()
				print Endereco
				
				&PesCod = PesCod
				&PesRaz = PesRaz
				&PesIntVenCodPrint = PesIntVenCod
				&Alerta = ''
				if &PesIntVenCodPrint <> PesIntVenCod
					&Alerta = 'VENDEDOR DIFERENTE'
				EndiF
				print ClientesRepetidos
				do 'addsdt'
				For &sdtClientesItem in &sdtClientes
					&PesCod = &sdtClientesItem.CreCliCod
					&PesRaz = &sdtClientesItem.PesRaz
					&PesIntVenCodPrint = &sdtClientesItem.VenCod
					&Alerta = ''
					if &PesIntVenCodPrint <> PesIntVenCod
						&Alerta = 'VENDEDOR DIFERENTE'
					EndiF
					print ClientesRepetidos
					do 'addsdt'
				EndFor
				
				print tracejado
			EndIF
		Endif
		
	EndFor
Endif



&sdtClientesImpresso.Clear()
if &IsTelefoneRepetido = true
	&OqueIMprimir = 'TELEFONES REPETIDOS'
	print OqueImprimir
	
	For Each Order EmpCod, PesCod, PesFonCod
		Where EmpCod = &EmpCod
		Where PesIntVenCod = &PesIntVenCod when not &PesIntVenCod.IsEmpty()
		Where PesSts = Status_ativoInativo.ATIVO
		Where PesIsCli = true when &TipoPessoa = 'C'
		Where PesIsTra = true when &TipoPessoa = 'T'
		Where PesIsFor = true when &TipoPessoa = 'F'
		Where (PesTip = TipoPessoa.JURIDICA and (PesCnpj <> '11.111.111/1111-11' and PesCnpj <> '111.111.111-11')) or (PesTip = TipoPessoa.FISICA and PesCpf <> '111.111.111-11')
		
		&sdtClientes.Clear()
		&AuxPesCod = PesCod
		do 'Verifica'
		
		if &IsJaVerificado = false
			ValidaTelefoneRepetidoColl.Call(EmpCod, PesCod,PesVinCod, PesFonNum, '', &sdtClientes)
			if &sdtClientes.Count > 0
				&Mensagem = 'FONE REPETIDO: ' + trim(PesFonNum) 
				print Endereco
				
				&PesCod = PesCod
				&PesRaz = PesRaz
				&PesIntVenCodPrint = PesIntVenCod
				&Alerta = ''
				if &PesIntVenCodPrint <> PesIntVenCod
					&Alerta = 'VENDEDOR DIFERENTE'
				EndiF
				print ClientesRepetidos
				do 'addsdt'
				
				For &sdtClientesItem in &sdtClientes
					&PesCod = &sdtClientesItem.CreCliCod
					&PesRaz = &sdtClientesItem.PesRaz
					&PesIntVenCodPrint = &sdtClientesItem.VenCod
					&Alerta = ''
					if &PesIntVenCodPrint <> PesIntVenCod
						&Alerta = 'VENDEDOR DIFERENTE'
					EndiF
					print ClientesRepetidos
					do 'addsdt'
				EndFor
				
				print tracejado
			Endif
		EndIF
	EndFor
Endif

&sdtClientesImpresso.Clear()
if &IsEmailRepetido = true	
	&OqueIMprimir = 'EMAILS REPETIDOS'
	print OqueImprimir
	
	For Each Order EmpCod, PesCod, PesEmlCod
		Where EmpCod = &EmpCod
		Where PesIntVenCod = &PesIntVenCod when not &PesIntVenCod.IsEmpty()
		Where PesSts = Status_ativoInativo.ATIVO
		Where PesIsCli = true when &TipoPessoa = 'C'
		Where PesIsTra = true when &TipoPessoa = 'T'
		Where PesIsFor = true when &TipoPessoa = 'F'
		Where (PesTip = TipoPessoa.JURIDICA and (PesCnpj <> '11.111.111/1111-11' and PesCnpj <> '111.111.111-11')) or (PesTip = TipoPessoa.FISICA and PesCpf <> '111.111.111-11')
		
		
		&sdtClientes.Clear()
		&AuxPesCod = PesCod
		do 'Verifica'
		
		if &IsJaVerificado = false
			ValidaTelefoneRepetidoColl.Call(EmpCod, PesCod,PesVinCod, '', PesEml, &sdtClientes)
			if &sdtClientes.Count > 0
				&Mensagem = 'EMAIL REPETIDO: ' + trim(PesEml) 
				print Endereco
				
				&PesCod = PesCod
				&PesRaz = PesRaz
				&PesIntVenCodPrint = PesIntVenCod
				&Alerta = ''
				if &PesIntVenCodPrint <> PesIntVenCod
					&Alerta = 'VENDEDOR DIFERENTE'
				EndiF
				print ClientesRepetidos
				do 'addsdt'
				
				For &sdtClientesItem in &sdtClientes
					&PesCod = &sdtClientesItem.CreCliCod
					&PesRaz = &sdtClientesItem.PesRaz
					&PesIntVenCodPrint = &sdtClientesItem.VenCod
					&Alerta = ''
					if &PesIntVenCodPrint <> PesIntVenCod
						&Alerta = 'VENDEDOR DIFERENTE'
					EndiF
					print ClientesRepetidos
					do 'addsdt'
				EndFor
				
				print tracejado
			Endif
		Endif
	
	EndFor
Endif

Footer
	print Rodape
End

Sub 'Verifica'
	&IsJaVerificado = false
	For &sdtClientesImpressoItem in &sdtClientesImpresso
		if &sdtClientesImpressoItem.CreCliCod = &AuxPesCod
			
			&IsJaVerificado = true
			Exit
		Endif
	EndFor
EndSub

sub 'addsdt'
	&sdtClientesImpressoItem = new()
	&sdtClientesImpressoItem.CreCliCod = &PesCod
	&sdtClientesImpresso.Add(&sdtClientesImpressoItem)
endsub
]]></Source>
