      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&MensagemClienteCpfCnpjRepetido.SetEmpty()

&IsErroCpfCnpjRepetido = false

if not &PesCnpj.IsEmpty() or not &PesCpf.IsEmpty()
	For Each Order EmpCod, PesSts, PesCod
		Where EmpCod = &EmpCod
		Where PesCod <> &PesCod
		Where PesSts = Status_AtivoInativo.ATIVO
		Where PesCnpj = &PesCnpj and (not PesCnpj.IsEmpty() and not PesCnpj.IsNull()) When &PesTip = TipoPessoa.JURIDICA
		Where PesCpf = &PesCpf and (not PesCpf.IsEmpty() and not PesCpf.IsNull()) When &PesTip = TipoPessoa.FISICA 
		
		If &PesTip = TipoPessoa.JURIDICA
			if &PesCnpj <> '11.111.111/1111-11' and  &PesCnpj <> '111.111.111-11'
				&MensagemClienteCpfCnpjRepetido = 'Pessoa: ' + trim(str(PesCod)) + ' Possui mesmo Cnpj.'
				&IsErroCpfCnpjRepetido = true
			Endif
			
		Else
			if &PesCpf <> '111.111.111-11'
				&MensagemClienteCpfCnpjRepetido = 'Pessoa: ' + trim(str(PesCod)) + ' Possui mesmo Cpf.'
				&IsErroCpfCnpjRepetido = true
			Endif
		EndIF	
	    
	    exit
	EndFor
EndIF
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
