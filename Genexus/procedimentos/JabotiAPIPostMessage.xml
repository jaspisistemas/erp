        <Source><![CDATA[do 'getDadosAPI'

if &sdtJabotiResponse.error.code.IsEmpty()
	&URLCompleta = &EmpJaspiChatAPIUrl + '/envio'
	
	&localVarHeaders.Set('Authorization','Bearer ' + &EmpJaspiChatToken)
	&localVarHeaders.Set('telefone',&EmpJaspiChatFon)
	
	&localVarResponse = OpenAPICommon.CallApi(HttpMethod.Post, &URLCompleta, &localVarHeaders, &localVarPathParams, &localVarQueryParams, &localFileFormParams, &localVarFormParams, &sdtJabotiPost.ToJson(),'application/json', 0, 0)
	
	GravaLogDevNew(&EmpCod,&LogGUID,&Pgmname,'&localVarResponse',&localVarResponse.ToJson())
	
	&sdtJabotiResponse.FromJson(&localVarResponse.Content)
	
	if &sdtJabotiResponse.id.IsEmpty() and &sdtJabotiResponse.error.code.IsEmpty()
		&sdtJabotiResponse.error.code = &localVarResponse.StatusCode
		&sdtJabotiResponse.error.message = &localVarResponse.Content
	endif
endif

Sub 'getDadosAPI'
	JabotiAPIConfig(&EmpCod,&EmpJaspiChatAPIUrl,&EmpJaspiChatFon,&EmpJaspiChatToken)
	
	do case
		case &EmpJaspiChatAPIUrl.IsEmpty()
			&sdtJabotiResponse.error.code = 1
			&sdtJabotiResponse.error.type = 'interno'
			&sdtJabotiResponse.error.message = 'API não definida'
		
		case &EmpJaspiChatFon.IsEmpty()
			&sdtJabotiResponse.error.code = 2
			&sdtJabotiResponse.error.type = 'interno'
			&sdtJabotiResponse.error.message = 'Telefone não definido'
		
		case &EmpJaspiChatToken.IsEmpty()
			&sdtJabotiResponse.error.code = 3
			&sdtJabotiResponse.error.type = 'interno'
			&sdtJabotiResponse.error.message = 'Token não configurado'
	endcase
EndSub
]]></Source>
