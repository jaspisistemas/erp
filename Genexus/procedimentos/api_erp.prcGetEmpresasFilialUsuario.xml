      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

//TRATAR A VERSAO DO APPP
//vApi
//vApiNew
//linkBaixaApp

//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizarTabelas, &wwpContext)

if &IsAcessoConcedido = true
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		
		&sdtEmpresaFilialItem = new()
		&sdtEmpresaFilialItem.FilCod = FilCod
		&sdtEmpresaFilialItem.FilRaz = FilRaz
		&sdtEmpresaFilial.Add(&sdtEmpresaFilialItem) 
	EndFor
	
	if &sdtEmpresaFilial.Count = 0
		&sdtEmpresaFilialItem = new()
		&sdtEmpresaFilialItem.FilCod = 0
		&sdtEmpresaFilialItem.FilRaz = 'Selecione a filial.'
		&sdtEmpresaFilial.Add(&sdtEmpresaFilialItem)
	Endif
Endif
 
]]></Source>
