      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

&LogGUID = GUID.NewGuid()

if &IsAcessoConcedido = true //Acesso concedido
	
	//PARAMETROS
	&ManterImagemOriginal = true //solicitar por parametro
	&addProImgPri = true //solicitar por parametro
	&ProImgTip = TipoImagemProduto.IMAGEM_VENDA //Solicitar por parametro 
	
	For Each Order EmpCod, ProCod
		Where EmpCod = &wwpContext.EmpCod
		Where ProCod = &ProCod

		&addProImgNom = GxGetMLi(trim(ProNom), 1, 40)
		Exit
	EndFor

	&Extensao = &parExtensao.trim()	
	&Extensao = &Extensao.Replace('.','')
	
	RetornaConfiguracoesPastas.Call(&wwpContext.EmpCod, &wwpContext.FilCod, &sdtConfiguracoesPasta)
	&DiretorioImagem1024 = &sdtConfiguracoesPasta.PastaDiretorioImagensProduto + '1024_1024/'
	&DiretorioImagem325  = &sdtConfiguracoesPasta.PastaDiretorioImagensProduto + '325_325/'
	&DiretorioImagem180  = &sdtConfiguracoesPasta.PastaDiretorioImagensProduto + '180_180/'
	&DiretorioTemp = &sdtConfiguracoesPasta.PastaDiretorioImagensProduto + 'tmp/'
	
	//SALVAR A IMAGEM EM BASE64 FISICAMENTE
	&ArquivoTemporario = &DiretorioTemp+trim(&LogGUID.ToString()) +'.'+ &Extensao.Trim()
	
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'ArquivoTemporario',&ArquivoTemporario)
		
	&file.Source = &ArquivoTemporario
	&file.FromBase64String(&base64)
	&File.Close()
			
	do 'UploadImagem'
	
Endif



Sub 'UploadImagem'
	
	&GUID = GUID.NewGuid()
	&nomeImagemFinal = trim(str(&ProCod)) + '_' + trim(&GUID.ToString())
	
	&Directory.Source = &DiretorioImagem1024
	if not &Directory.Exists()
		&Directory.Create()
	EndIf
	
	&Directory.Source = &DiretorioImagem325
	if not &Directory.Exists()
		&Directory.Create()
	EndIf
	
	&Directory.Source = &DiretorioImagem180
	if not &Directory.Exists()
		&Directory.Create()
	EndIf
	
	&Directory.Source = &DiretorioTemp
	if not &Directory.Exists()
		&Directory.Create()
	EndIf	
	
	If not &ArquivoTemporario.IsEmpty()
		&ArquivoFile.Source = &ArquivoTemporario.Trim()
		If &ArquivoFile.Exists()
			
			&Largura1024 = 1024
			&Altura1024 = 1024
			
			&Altura325 = 325
			&Largura325 = 325
			
			&Altura180 = 180
			&Largura180 = 180
			
			//CARREGA A IMAGEM TEMPORARIA
			&IgImageEditor.Open(&ArquivoTemporario)	
			
			//Pega o tamanho da imagem para verificar Retrato ou paisagem
			&width  = &IgImageEditor.GetWidth
			&Height = &IgImageEditor.GetHeight
			
			//Pega a extensao da imagem
			&Extensao = &IgImageEditor.GetFormat
			
			If &Extensao <> 'JPG' //CONVERTE PARA JPG			
				&NovaTempImagem = &DiretorioTemp + trim(&nomeImagemFinal) + 'temp.jpg'
				&ArquivoFile.Source = &NovaTempImagem
				If &ArquivoFile.Exists()
					&ArquivoFile.Delete()
				EndIF
				
				&IgImageEditor.Format('JPG', 90, &NovaTempImagem)
			Else
				&NovaTempImagem = &ArquivoTemporario
			EndIF
			&IgImageEditor.Close()
			
			//Imagem produtos/temp
			&IgImageEditor.Open(&NovaTempImagem)
			
			&ImagemTemp1024 = &DiretorioTemp + trim(&nomeImagemFinal) + 'temp1.jpg'
			&ArquivoFile.Source = &ImagemTemp1024
			If &ArquivoFile.Exists()
				&ArquivoFile.Delete()
			EndIF
			
			//resize  Imagem 1024
			If &Height > &width //RETRATO 
				If &Height > &Altura1024 and &ManterImagemOriginal = false
					&NovoHeight = &Altura1024
					&multiplicador = &NovoHeight / &Height
					&NovoWidth = round(&width * &multiplicador, 0)
					
					&IgImageEditor.Resize(&NovoHeight, &NovoWidth, &ImagemTemp1024)
					&IgImageEditor.Close()
				Else
					&IgImageEditor.Close()
					
					&ArquivoFile.Source = &NovaTempImagem
					&ArquivoFile.Copy(&ImagemTemp1024)
				EndIF
				
			Else //PAISAGEM
				If &width > &Largura1024 and &ManterImagemOriginal = false
					&NovoWidth = &Largura1024
					&multiplicador = &NovoWidth / &width
					&NovoHeight = round(&Height * &multiplicador, 0)
					
					&IgImageEditor.Resize(&NovoHeight, &NovoWidth, &ImagemTemp1024)
					&IgImageEditor.Close()
				Else
					&IgImageEditor.Close()
					
					&ArquivoFile.Source = &NovaTempImagem
					&ArquivoFile.Copy(&ImagemTemp1024)
				EndIF
			EndIf
			
			//Formatada imagem e grava pasta correta
			&color = RGB(255,255,255)
			
			&Final1024 = &DiretorioImagem1024.Trim() + trim(&nomeImagemFinal) + '.jpg'
			&ArquivoFile.Source = &Final1024
			If &ArquivoFile.Exists()
				&ArquivoFile.Delete()
			EndIF
			
			if &ManterImagemOriginal = false
				&tmpBlob = loadBitmap(&ImagemTemp1024)
				&FinalBlob = LoadBitmap(&Final1024)
				&ImageTools.GenerateThumbnail(&tmpBlob, &FinalBlob, &Altura1024, &Largura1024, &Color)
				&tmpBlob.SetEmpty()
				&FinalBlob.SetEmpty()
			else
				&ArquivoFile.Source = &ImagemTemp1024
				&ArquivoFile.Copy(&Final1024)
			Endif
			
			//Resize 325.325
			&Final325 = &DiretorioImagem325.Trim() + trim(&nomeImagemFinal) + '.jpg'
			&ArquivoFile.Source = &Final325
			If &ArquivoFile.Exists()
				&ArquivoFile.Delete()
			EndIF
			
			if &ManterImagemOriginal = false
				&IgImageEditor.Open(&Final1024)
				&IgImageEditor.Resize(&Altura325, &Largura325, &Final325)
				&IgImageEditor.Close()
			else
				&ArquivoFile.Source = &Final1024
				&ArquivoFile.Copy(&Final325)
			EndIf
			
			//Resize 180.180
			&Final180 = &DiretorioImagem180.Trim() + trim(&nomeImagemFinal) + '.jpg'
			&ArquivoFile.Source = &Final180
			If &ArquivoFile.Exists()
				&ArquivoFile.Delete()
			EndIF
			
			if &ManterImagemOriginal = false
				&IgImageEditor.Open(&Final1024)
				&IgImageEditor.Resize(&Altura180, &Largura180, &Final180)
				&IgImageEditor.Close()
			else
				&ArquivoFile.Source = &Final1024
				&ArquivoFile.Copy(&Final180)
			Endif
			
			&ProImgNomFis = trim(&nomeImagemFinal) + '.jpg'
			&NomeVirtual = &sdtConfiguracoesPasta.PastaDiretorioImgProdutoVir.Trim() + '180_180/' + &ProImgNomFis.Trim()
			&ProImg.FromURL(&NomeVirtual)
			
			&NomeVirtual = &sdtConfiguracoesPasta.PastaDiretorioImgProdutoVir.Trim() + '325_325/' + &ProImgNomFis.Trim()
			&ProImg325.FromURL(&NomeVirtual)
			
			&NomeVirtual = &sdtConfiguracoesPasta.PastaDiretorioImgProdutoVir.Trim() + '1024_1024/' + &ProImgNomFis.Trim()
			&ProImg1024.FromURL(&NomeVirtual)
			
			&NomeVirtual = &ArquivoTemporario
			&ProImgOriginal.FromURL(&NomeVirtual)
			
			if &ProImgCod = 0
				For Each Order EmpCod, ProCod, (ProImgCod)
					Where EmpCod = &wwpContext.EmpCod
					Where ProCod = &ProCod
					&ProImgCod = ProImgCod
					Exit
				EndFor
				&ProImgCod += 1
			EndIF
	
			GravaDadosImagemProduto.Call(&wwpContext.EmpCod, &ProCod, &ProImgCod, &addProImgNom, &ProImgTip, &ProImgNomFis, &addProImgPri, &ProImg, &ProImg325, &ProImg1024, &ProImgOriginal)
			
			&sdtRetornoWbsEtc.sts = 'J200'
			&sdtRetornoWbsEtc.obs = 'Imagem salva com sucesso!'
			
		Else
			&sdtRetornoWbsEtc.sts = 'E999'
			&sdtRetornoWbsEtc.obs = 'Nenhuma imagem selecionada, ou inválida!'
			Return
		EndIF
	EndIF
	
EndSub


Sub 'Exception_handler'
	&sdtRetornowbsEtc.Sts = 'E999'
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXexceptionType',&GXexceptionType)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionDetails',&GXExceptionDetails)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Exception_handler: &GXExceptionStack',&GXExceptionStack)
//	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'subError_handler',&sdtProduto.ToJson())
Endsub

Sub 'Error_handler'
	&sdtRetornowbsEtc.Sts = 'E998'
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &Err',&Err.ToFormattedString())
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBErr',&gxDBErr.ToFormattedString())
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &GxDbSqlState',&GxDbSqlState)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxDBTxt',&gxDBTxt)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxOper',&gxOper)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrTbl',&gxErrTbl)
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'Error_handler: &gxErrOpt',&gxErrOpt.ToFormattedString())
Endsub
]]></Source>
