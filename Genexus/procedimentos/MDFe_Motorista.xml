      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

if &OQueFazer = 'ADD'
	For Each Order EmpCod, FilCod, MDFeCod, MDFeMotCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeMotCpf = &MDFeMotCpf
		msg('Motorista já adicionado!')
		Exit
	When None
		For Each Order EmpCod, FilCod, MDFeCod, (MDFeMotCod)
			Where EmpCod = &EmpCod
			Where FilCod = &FilCod
			Where MDFeCod = &MDFeCod
			&MDFeMotCod = MDFeMotCod
			Exit
		EndFor
		&MDFeMotCod += 1
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			MDFeCod = &MDFeCod
			MDFeMotCod = &MDFeMotCod
			MDFeMotCpf = &MDFeMotCpf
			MDFeMotNom = &MDFeMotNom
		EndNEw
	EndFor
Else
	For Each Order EmpCod, FilCod, MDFeCod, MDFeMotCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where MDFeCod = &MDFeCod
		Where MDFeMotCod = &ParmMDFeMotCod
		Delete
		Exit
	EndFor
EndIF

Commit
]]></Source>
