        <Source><![CDATA[
loadWWPContext.Call(&Context)
//&SdtRecibo.FromXml(&webSession.Get('ReciboImp'))
If &Context.PesCod = 0
	Return
EndIf

MB 4
MT 2

//&Image = FilImg146_50 _ que isso arnaldo Att perdido?
&PesRaz = &Context.PesRaz
&Cont = 0	
//For &SdtReciboItem In &SdtRecibo
	
	For each Order EmpCod, RcbDstCod, RcbMovCod
		Where EmpCod = &EmpCod
		Where RcbMovCod = &MovCod when &deondevem = 'MOVIMENTO'
//		Where RcbCod = &SdtReciboItem.RcbCod when &deondevem = 'AVULSO'
		&Cont+=1
		&RcbVlr    = RcbVlr
		&RcbCod    = RcbCod
		&RcbEmpCod = EmpCod
		&RcbFilCod = RcbFilCod
		&RcbDta    = RcbDta
		&RcbDoc    = RcbDoc
		&RcbDstCod = RcbDstCod
		Do 'Pessoa'
		Do 'Filial'
		
		If RcbTip = TipoRecibo.Receber
			If &PesCnpj.Trim().IsEmpty()
				&RcbDes1 = trim(RcbDstNom)+' a importância de:'
			Else
				&RcbDes1 = trim(RcbDstNom)+' - CPF/CNPJ n° ' + &PesCnpj.Trim()
			EndIf
			&RcbDstNom = &FilFan
		Else
			If &FilCpj.Trim().IsEmpty()
				&RcbDes1 = trim(&FilFan)+' a importância de:'
			Else
				&RcbDes1 = trim(&FilFan)+' - CPF/CNPJ n° ' + &FilCpj.Trim()
			EndIf
			&RcbDstNom = RcbDstNom
			
		EndIf
	
		&RcbDes2 = trim(PorExtenso.Udp(RcbVlr))
		Print Cabecalho
		Print Conteudo

		&RcbCreCod = RcbCreCod
		&RcbCrePagCod = RcbCrePagCod
		&RcbObs = ''
		Do 'ValidaDuplicata'
		If &RcbObs.isEmpty()
			&RcbObs = RcbObs
		EndIf
		&Obs = &RcbObs.Trim().ToUpper()
		&nlin = GXMLines(&Obs,70)
		&i = 1
		Do While &i <= &nlin
			&RcbDes3 = GXGetMLi(&Obs,&i,70)
			Print Extenso // (print block that prints &txt)
			&i += 1
		Enddo
		
		
		&Datadoem = trim(&FilCidNom)+', '+trim(str(day(&RcbDta)))+' de '+trim(cmonth(&RcbDta))+' de '+trim(str(year(&RcbDta)))
		&Datadoem = &Datadoem.ToUpper()
		//		&aux = EmpDirExt.Trim()+str(RcbCodeVR)
		//		Do 'geraHash'
		//		&QrImage.fromURL(&cHashQRCode)
		Print Rodape
		If &Cont = 2
			Eject
			&Cont  = 0
		Else
			Print Tesoura
		EndIf
	EndFor
//EndFor

Sub 'Filial'
	For Each Order EmpCod, FilCod
		Where EmpCod = &RcbEmpCod
		Where FilCod = &RcbFilCod
		&FilFan    = FilFan.Trim().ToUpper()
		&FilLogNro = FilLogNro.Trim()
		&FilLogNro += ' '+FilBai.Trim() 
		&FilCepCidUfe = FilCepCidUfe.Trim()
		&FilDes = FilCpj.Trim() +'/'+ FilFonNum.Trim()
		&FilCidNom = FilCidNom.Trim()
		&FilCpj = FilCpj.Trim()
		If FilImg_LogRel.IsEmpty()
			&Image.FromImage('FilialSemImagem')  
		Else
			&Image = FilImg_LogRel
		EndIF
		
		Exit
	EndFor
EndSub

Sub 'Pessoa'
	For each Order EmpCod, PesCod
		Where EmpCod = &RcbEmpCod
		Where PesCod = &RcbDstCod
		If PesTip = TipoPessoa.FISICA
			&PesCnpj = PesCpf
		Else
			&PesCnpj = PesCnpj
		EndIf
		Exit
	EndFor
EndSub

//Sub 'geraHash'
//	csharp 		  System.Security.Cryptography.SHA1 Sha = new System.Security.Cryptography.SHA1Managed(); 
//    csharp 		  Sha.ComputeHash(System.Text.Encoding.Default.GetBytes([!&aux!])); 
//	csharp 		  [!&cHashQRCode!] = BitConverter.ToString(Sha.Hash).Replace("-", "");
//EndSub

Sub 'ValidaDuplicata'
	For each Order EmpCod,FilCod,CreCod,CrePagCod
		Where EmpCod = &RcbEmpCod
		Where FilCod = &RcbFilCod
		Where CreCod = &RcbCreCod
		Where CrePagCod = &RcbCrePagCod
		
		&RcbObs = 'pagamento da duplicata Nº '+ TRIM(CreDupNro) + ' no dia '+dtoc(CrePagDta)
		&CrePedCod = CrePedCod
		&CreFilCod = FilCod
		Do 'GetNfe'
		If not &Numeros.IsEmpty()
			&RcbObs+= ' referente as notas '+&Numeros 
		EndIf
		exit
	EndFor
EndSub

Sub 'GetNfe'
	&Ped = 1
	&Numeros = ''
	For Each Order EmpCod, NfePedCod,NfeFilCod
		Where EmpCod = &RcbEmpCod 
		Where NfeFilCod = &CreFilCod
		Where NfePedCod = &CrePedCod
		
		If &Ped = 1 
			&Numeros = trim(str(NfeNum))
		Else
			&Numeros += ' - '+trim(str(NfeNum))
		EndIf
		&Ped+=1		
	EndFor
EndSub

	
	
