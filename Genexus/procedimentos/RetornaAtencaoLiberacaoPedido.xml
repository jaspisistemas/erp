      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsAtencao = false
&Mensagem = ''
For Each ORder EmpCod, PesCod
	Where EmpCod = &EmpCod
	WHere PesCod = &PesCod

	&PagamentoMensagem = RetornaObsClienteFORMULA.udp(&EmpCod, &FilCod, 0, &PesCod, 'P1')
		
	Do Case
		Case not PesEnvSpc.IsEmpty()
			&Mensagem = 'Cliente Protestado por esta Empresa em: '+trim(DtoC(PesEnvSpc))+'!'
			
		Case PesProAtv = 'S'
			&Mensagem = 'Cliente com Protestos!'
		
		Case PesProAtv = 'J'
			&Mensagem = 'Cliente com Protestos Judiciais!'
			
		Case PesVenAprz = 'N'
			&Mensagem = 'Cliente marcado como NÃO Vender a Prazo!'
			
		Case PesResChe = Status_SimNao.Sim
			&Mensagem = 'Cliente com Restrições de Cheques!'
			
		Case PesResSpc = Status_SimNao.Sim
			&Mensagem = 'Cliente com Restrições ao SCPC!'
		
		Case not PesPefQtd.IsEmpty()
			&Mensagem = 'PEFIN: ' + trim(toformattedString(PesPefQtd)) + ' TOTAL: ' + trim(toformattedString(PesPefVlr))
		
		Case not PesRefQtd.IsEmpty()
			&Mensagem = 'REFIN: ' + trim(toformattedString(PesRefQtd)) + ' TOTAL: ' + trim(toformattedString(PesRefVlr))
	
//		Case not PesDivQtd.IsEmpty()
//			&Mensagem = 'DÍVIDA ATIVA: ' + trim(toformattedString(PesDivQtd)) + ' TOTAL: ' + trim(toformattedString(PesDivVlr))
			
		Case not &PagamentoMensagem.IsEmpty()
			&Mensagem = &PagamentoMensagem
			&IsAtencao = true
			
		Case &UtilizadoPesCliCrd > PesCliCrd and PesCliCrd > 0
			&Mensagem = 'Atenção. Crédito Cliente atingido!'
			&IsAtencao = true
			
		CAse PesClaTip = ClienteClassificacao.INADIMPLENTE or PesClaTip = ClienteClassificacao.RUIM
			&Mensagem = 'Atenção. Cliente classificado como: '+trim(PesClaTip.EnumerationDescription())+'!'
			&IsAtencao = true
			
		Case PesCliCrd.IsEmpty() or PesCliCrd.IsNull()
			&Mensagem = 'Não definido limite de crédito para o cliente!'
			&IsAtencao = true
	EndCAse
	Exit
EndFor

]]></Source>
