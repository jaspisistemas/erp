      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[For Each Order EmpCod, MovCod, MovItmCod
	Where EmpCod		= &EmpCod
	Where MovTip		= TipoMovimento.Adiantamento
	Where MovCreCod		= &MovCreCod
	Where MovItmSts	   <> Status_Caixa.Cancelado
	Where MovCreFilCod	= &MovCreFilCod
	
	AtualizaSaldoConta.Call(TrnMode.Delete, EmpCod, MovCtaBanCod, MovDtaCon, MovCreDeb, MovItmVlr, MovDtaCon, MovItmVlr, MovCreDeb)
	
	MovItmSts 	= Status_Caixa.Cancelado
	MovSts		= Status_Caixa.Cancelado
	
	Commit
EndFor	
	
]]></Source>
