      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
If &FilInuCod = 0 //ADICIONA NOTA INUTILIZACAO
	For Each Order EmpCod, FilCod,FilInuNroIni,FilInuNroFin,FilInuMod,FilInuSer,FilNfeCod,FilInuSts
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where FilInuNroIni = &FilInuNroIni
		Where FilInuNroFin = &FilInuNroFin
		where FilInuSts = Status_NFe.Digitando
		Where FilInuMod = &FilInuMod
		Where FilInuSer = &FilInuSer
		Where FilNfeCod = &NfeCod

		delete
	EndFor
	
	Commit
	
	&FilInuCod = 0
	For Each Order EmpCod, FilCod, (FilInuCod)
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		
		&FilInuCod = FilInuCod
		Exit
	EndFor
	&FilInuCod += 1
	
	new
		EmpCod = &EmpCod
		FilCod = &FilCod
		FilInuCod = &FilInuCod
		FilInuNroIni = &FilInuNroIni
		FilInuNroFin = &FilInuNroFin
		FilInuMod = &FilInuMod
		FilInuSer = &FilInuSer
		FilInuAno = &FilInuAno
		FilInuDhRec = &FilInuDhRec
		FilInuProt = &FilInuProt
		FilInuPesCod = &FilInuPesCod
		FilInuSts = &Status_NFe
		FilNfeCod = &NfeCod
	EndNew
		
Else //ATUALIZA STATUS
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where FilInuCod = &FilInuCod
		FilInuDhRec = &FilInuDhRec
		FilInuProt = &FilInuProt
		FilInuSts = &Status_NFe
		FilNfeCod = &NfeCod
		Exit
	EndFor
EndIF

commit
]]></Source>
