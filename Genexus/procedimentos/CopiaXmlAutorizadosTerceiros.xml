      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Varchar = &destinoPasta

&PastaAutorizada = &sdtConfiguracoesPasta.PastaNFenviado.Trim() + 'autorizados\'

//CRIA DIR TMPNF
&PastaTemporaria  = &sdtConfiguracoesPasta.PastaDiretorioTempFis.Trim() + 'xmlNotasTerceiros-'+ trim(&Varchar)
&Directory.Source = &PastaTemporaria
if not &Directory.Exists()
	&Directory.Create()
Else
	&Directory.Delete()
	&Directory.Create()
endif

&IsExistDiretorio = false
For Each Order EmpCod, FilCod, NfeProTer, NfeDtaFat, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod

	Where (NfeDtaFat >= &iniNfeDtaEms and NfeDtaFat <= &finNfeDtaEms) //When &TipoData = 'E'
	Where NfeNum <> 0
	//Where NfeSts = Status_NFe.Autorizada and NFeSts <> Status_NFe.Inutilizada and NFeSts <> Status_Nfe.Digitando
	Where (NfeSts = Status_NFe.Autorizada or NfeSts = Status_NFe.Digitando)	or (NfeSts <> Status_NFe.Inutilizada and &SomenteAutorizadas = Status_SimNao.Nao)
	where NfeProTer = Nota_ProPriaTerceira.TERCEIROS
	Where ModCod = '55' or ModCod = '65'
	Where NfeChv <> ''
	Where not NfeArqXml.IsEmpty()
	
	//BUSCAR NOTA AUTORIZADA
	&AnoMesEnviado = PadL(LTrim(str(Year(NfeDtaEms))), 4, '0') + PadL(LTrim(str(Month(NfeDtaEms))), 2, '0')
	
	&IsExistDiretorio = true
	
//	&ArquivoXML =  &PastaAutorizada.Trim() + &AnoMesEnviado.Trim() +"\"+ NfeChv.Trim() + '-procNFe.xml'
	&ArquivoDestino = &PastaTemporaria +"\"+ NfeChv.Trim() + '-procNFe.xml'
	
//	&File.Source = &ArquivoXML.Trim()
//	if &File.Exists()
//		//COPIA PASTA TEMPORARIA
//		&File.Copy(&ArquivoDestino)
//	else
		&XmlWriter.Open(&ArquivoDestino)
		&XmlWriter.WriteRawText(NfeArqXml)
		&XmlWriter.Close()
//	endif
//	&File.Close()
	
	&ArquivoXML =  &PastaAutorizada.Trim() + &AnoMesEnviado.Trim() +"\"+ NfeChv.Trim() + '_110111_01-procEventoNFe'
	&ArquivoDestino = &PastaTemporaria +"\"+ NfeChv.Trim() + '_110111_01-procEventoNFe'
	
	&File.Source = &ArquivoXML.Trim()
	if &File.Exists()
		//COPIA PASTA TEMPORARIA
		&File.Copy(&ArquivoDestino)
	EndIF
	&File.Close()
	
	&ArquivoXML =  &PastaAutorizada.Trim() + &AnoMesEnviado.Trim() +"\"+ NfeChv.Trim() + '-ped-inu.xml'
	&ArquivoDestino = &PastaTemporaria +"\"+ NfeChv.Trim() + '-ped-inu.xml'
	
	&File.Source = &ArquivoXML.Trim()
	if &File.Exists()
		//COPIA PASTA TEMPORARIA
		&File.Copy(&ArquivoDestino)
	EndIF	
	&File.Close()
EndFor

if &IsExistDiretorio = true
	&inputFolderPath =  &PastaTemporaria.Trim()
	&destinoPasta = &PastaTemporaria + ".zip"
	
	&File.Source = &destinoPasta
	if &File.Exists()
		&File.Delete()
	EndIf
	&File.Close()
	
	//Compacta
	&ZipUtil.ZipFiles(&inputFolderPath, &destinoPasta, &password)
EndIF	
]]></Source>
