      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
	For each Order DupTmpEmpCod, DupTmpFilCod, DupTmpPesCod, DupTmpCreCod
		Where DupTmpEmpCod = &EmpCod
		where DupTmpFilCod = &FilCod
		Where DupTmpPesCod = &PesCod
		where DupTmpCreVlrDup > 0
		where DupTmpCreSts = 'A' or DupTmpCreSts = 'I' //se for P (Paga/Parcial)  ou C-cancelada nao atualiza nada
		//se for A ele atualiza deixando ativa, se for I ele atualiza e cancela
		&CreSts = DupTmpCreSts
		
		For each order EmpCod, FilCod, CreCod
			where EmpCod = DupTmpEmpCod
			where FilCod = DupTmpFilCod
			where CreCod = DupTmpCreCodAlt
			
			//JDF TEM QUE SER O IF NAO O WHERE< SENAO CAI NO WHEN NONE E GERA NOVA MENSALIDADE
			if CreSts <> Status_Duplicata.CANCELADA //Ela precisa estar ativa caso contrario nao altera nda
				&CreCod = CreCod
				
				if &CreSts = 'I' 
					CreSts = Status_Duplicata.CANCELADA
				else 
					if &CreSts = 'A'
						CreSts = Status_Duplicata.ATIVO
						
						CreNovCliRaz = DupTmpCreNovCliRaz
						CreDupNro = DupTmpCreDupNro		
						CreDtaVct = DupTmpCreDtaVct
						CreVlrDup = DupTmpCreVlrDup
						CreCbrCod = DupTmpCreCbrCod
						CreDtaEms = DupTmpCreDtaEms
						CreVlrSdo = DupTmpCreVlrSdo
						CreBloNro = DupTmpCreBloNro
						CrePlanCod = DupTmpCrePlanCod
						CreFilPgt = DupTmpCreFilPgt
					EndIf
				EndIf
			Endif
		
			exit
		When none
			
			if DupTmpCreSts = 'A' or &CreSts = 'A' 		//só da new se for 'A'
				&CreCod.SetEmpty()
				UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, DupTmpEmpCod, DupTmpFilCod,&CreCod)
				
				New
					EmpCod = DupTmpEmpCod
					FilCod = DupTmpFilCod
					CreSerItmCod = &CreSerItmCod
					CreCod = &CreCod
					CreDupNro = DupTmpCreDupNro		
					CreDtaVct = DupTmpCreDtaVct
					CreVlrDup = DupTmpCreVlrDup
					CreCbrCod = DupTmpCreCbrCod
					CreDtaEms = DupTmpCreDtaEms
					CreVlrSdo = DupTmpCreVlrSdo
					CreCliCod = DupTmpCreCliCod
					CreVenCod = DupTmpCreVenCod
					CreRecPag = DupTmpCreRecPag 
					CreBloNro = DupTmpCreBloNro
					CreSts = Status_Duplicata.ATIVO
					CreFrpPgtoCod = 1// duplicata
					CreOriDup = OrigemDuplicata.MensalidadeServico
					CrePlanCod = DupTmpCrePlanCod
					CrePerComCbr = DupTmpCrePerComCbr
					if DupTmpCreFilPgt.IsEmpty()
						CreFilPgt = 1
					Else
						CreFilPgt = DupTmpCreFilPgt
					Endif
					//CreAbvDup = RetornaTipoOrigemDuplicata.udp(EmpCod, FilCod, CrePedCod, CreRenDstCod, CreFrtCod, CreNfeCod)
					CreNovCliRaz = DupTmpCreNovCliRaz
				EndNew
			EndIf
			
		EndFor
		
		commit
		atualizaSaldoDuplicata.Call(&EmpCod, &CreCod, &FilCod)
		
	EndFor

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
