        <Source><![CDATA[
&Linha = &PrimeiraLinha
&Excel.Open(&selectedURL)


&Total = 1000
&Count = 50
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

If &Excel.ErrCode <> 0
	msg(&Excel.ErrDescription)
Else
	Do While &Fim < 50		
		Do 'LimpaCampos'
		
		&AuxCount += 1
		
		if &AuxCount = 100
			&AuxCount = 0
			&Count += 10
			If &Count > 0
				&Percentual = round((&Count / &Total) * 100, 0)
			EndIF
			If &Percentual >= 100
				&Percentual = 99
			EndIf
			do 'Atualiza'
		Endif
		
		//&xlsxPesCod = val(trim(&Excel.Cells(&Linha,&ColPesCod).Text)) // Código 
		&xlsxPesRaz = Substr(trim(&Excel.Cells(&Linha,&ColPesRaz).text), 1, 80) // NOME	
		&xlsxPesCnpj = RetornaSoNumeros.udp(&Excel.Cells(&Linha,&ColPesCnpj).text)
		&xlsxPesInsEst = RetornaSoNumeros.udp(&Excel.Cells(&Linha,&ColPesIns).text)
		&xlsxPesRg = RetornaSoNumeros.udp(&Excel.Cells(&Linha,&ColPesRg).text)
		&xlsxPesSuf = Substr(trim(&Excel.Cells(&Linha,&ColPesSuf).text), 1, 10)
		&xlsxPesCelNum = RetornaSoNumeros.udp(&Excel.Cells(&Linha,&ColPesCel).text)
		&xlsxPesFonNum = RetornaSoNumeros.udp(&Excel.Cells(&Linha,&ColPesFon).text)
		&xlsxPesDtaNas = ctod(&Excel.Cells(&Linha,&ColPesDtaNas).text)
		&xlsxPesEml = trim(&Excel.Cells(&Linha,&ColPesEml).text)		
		
		&xlsxPes = trim(&Excel.Cells(&Linha,&ColPesEml).text)		
		&xlsxPesEml = trim(&Excel.Cells(&Linha,&ColPesEml).text)		
		
		&xlsxPesCEP = RetornaSoNumeros.udp(&Excel.Cells(&Linha,&ColPesCEP).text)
		&xlsxPesLog = Substr(trim(&Excel.Cells(&Linha,&ColPesLog).text), 1, 80)
		if &xlsxPesLog = 'NULL'
			&xlsxPesLog.SetEmpty()
		Endif
		&xlsxPesNro = trim(&Excel.Cells(&Linha,&ColPesNro).text)
		&xlsxPesBai = trim(&Excel.Cells(&Linha,&ColPesBai).text)
		if &xlsxPesBai = 'NULL'
			&xlsxPesBai.SetEmpty()
		Endif
		&xlsxPesCpl = Substr(trim(&Excel.Cells(&Linha,&ColPesCpl).text), 1, 60)
		if &xlsxPesCpl = 'NULL'
			&xlsxPesCpl.SetEmpty()
		Endif
		&xlsxPesCidNom = RetiraCaracteresEspeciais.Udp(Substr(trim(&Excel.Cells(&Linha,&ColPesCidCod).text), 1, 80))
		&xlsxUfeCod = RetiraCaracteresEspeciais.Udp(Substr(trim(&Excel.Cells(&Linha,&ColPesUfeCod).Text), 1, 80))
		&XlsCidIBGE = val(RetornaSoNumeros.Udp(&Excel.Cells(&Linha,&ColIBGE).text))
		do 'GetCidade'
		&xlsxPesObs = Substr(trim(&Excel.Cells(&Linha,&ColPesObs).text), 1, 1000)
		if &xlsxPesObs = 'NULL'
			&xlsxPesObs.SetEmpty()
		Endif
		If &PesCod.IsEmpty() and &xlsxPesRaz.IsEmpty()
			&Fim += 1
		Else
			ValidaCpfCnpj.Call(&xlsxPesCnpj,0,'S')
			FormataCEP.Call(&xlsxPesCEP,&xlsxPesCEP)
			FormatafONE.Call(&xlsxPesCelNum,&xlsxPesCelNum)
			FormataFONE.Call(&xlsxPesFonNum,&xlsxPesFonNum)
			
			Do 'GetCliente'
			
			if (&StsCadastro = 'N') or (&StsCadastro = 'M' and &MostrarSomenteNaoCadastrado <> 'S') or &MostrarSomenteNaoCadastrado = 'T'
				if &SemCpfSemCnpj = 'S' or (&xlsxPesCnpj.Length() > 10)
					Do 'GravaSdt'
				Endif

			Endif
			
			&Fim = 0
		EndIf
		&Linha += 1
	EndDo
EndIf

&Percentual = 100
&ProgressFin = serverNow()
&ProgressLogXml = &sdtClientexls.ToJson()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ProgressLogXml
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &ProgressLogXml
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub

sub 'GravaSdt'
	&IsAchou = false
	if not &xlsxPesCnpj.IsEmpty()
		For &sdtClientexlsItem in &sdtClientexls
			if &sdtClientexlsItem.PesCnpj = &xlsxPesCnpj
				&IsAchou = true
				Exit
			Endif
		EndFor
	Endif

	if &IsAchou = false
		&sdtClientexlsItem = new()		
		&sdtClientexlsItem.EmpCod = &xlsxEmpCod
		&sdtClientexlsItem.PesCod =  &PesCod 
		&sdtClientexlsItem.PesRaz = &xlsxPesRaz	
		&sdtClientexlsItem.PesCnpj = &xlsxPesCnpj
		&sdtClientexlsItem.PesInsEst = &xlsxPesInsEst 
		&sdtClientexlsItem.PesRg = &xlsxPesRg 
		&sdtClientexlsItem.PesSuf = &xlsxPesSuf 
		&sdtClientexlsItem.PescelNum = &xlsxPesCelNum 
		&sdtClientexlsItem.PesFonNum = &xlsxPesFonNum 
		&sdtClientexlsItem.PesDtaNas = &xlsxPesDtaNas
		&sdtClientexlsItem.PesEmail = &xlsxPesEml 	
		&sdtClientexlsItem.PesCep = &xlsxPesCEP 
		&sdtClientexlsItem.PesLog = &xlsxPesLog 
		
		if &xlsxPesNro.IsEmpty() or &xlsxPesNro = 'NULL' or &xlsxPesNro = '0'
			&sdtClientexlsItem.PesNro = 'S/N' 
		Else
			&sdtClientexlsItem.PesNro = &xlsxPesNro 
		Endif

		&sdtClientexlsItem.PesBai = &xlsxPesBai 
		&sdtClientexlsItem.PesCpl = &xlsxPesCpl 
		&sdtClientexlsItem.PesCidNom = &xlsxPesCidNom 
		&sdtClientexlsItem.PesCidCod = &xlsxCidCod 
		&sdtClientexlsItem.PesObs = &xlsxPesObs
		&sdtClientexlsItem.StsCadastro = &StsCadastro
		
		&sdtClientexls.Add(&sdtClientexlsItem)
	Endif
EndSub

Sub 'LimpaCampos'
	&Mensagem = ''
	&IsErro = false
	&PesCod = 0
		
	&xlsxPesRaz.SetEmpty()
	&xlsxPesCnpj.SetEmpty()
	&xlsxPesInsEst.SetEmpty()
	&xlsxPesRg.SetEmpty()
	&xlsxPesSuf.SetEmpty()
	&xlsxPesCelNum.SetEmpty()
	&xlsxPesFonNum.SetEmpty()
	&xlsxPesDtaNas.SetEmpty()
	&xlsxPesEml.SetEmpty()
	&xlsxPesCEP.SetEmpty()
	&xlsxPesLog.SetEmpty()
	&xlsxPesNro.SetEmpty()
	&xlsxPesBai.SetEmpty()
	&xlsxPesCpl.SetEmpty()
	&xlsxPesCidNom.SetEmpty()
	&xlsxUfeCod.SetEmpty()
	&xlsxPesObs.SetEmpty()
EndSub

Sub 'GetCliente'
	&StsCadastro = 'N'
	&PesCod = 0
	if &xlsxPesCnpj.Length() < 11
		&xlsxPesCnpj.SetEmpty()
	Endif
	&xlsxPesCnpj = &xlsxPesCnpj.Trim()
	Do Case
		Case ((not &xlsxPesCnpj.IsEmpty()) and (&xlsxPesCnpj.Length() > 14))
			For Each Order EmpCod, PesCnpj
				Where EmpCod = &EmpCod
				Where PesCnpj = &xlsxPesCnpj
				Where PesTip = TipoPessoa.JURIDICA
				
				&StsCadastro = 'S'
				&PesCod = PesCod
				
				Do Case
					Case PesRaz <> &xlsxPesRaz and &ColPesRaz > 0
						&StsCadastro = 'M'
					Case PesCnpj <> &xlsxPesCnpj and &ColPesCnpj > 0
						&StsCadastro = 'M'
					Case PesInsEst <> &xlsxPesInsEst  and &ColPesins > 0
						&StsCadastro = 'M'
					Case PesRg <> &xlsxPesRg  and &ColPesRg > 0
						&StsCadastro = 'M' 
					Case PesSuf <> &xlsxPesSuf  and &ColPessuf > 0
						&StsCadastro = 'M'
					Case PesDtaNas <> &xlsxPesDtaNas and &ColPesDtaNas > 0
						&StsCadastro = 'M'
					Case PesCep <> &xlsxPesCEP   and &ColPesceP > 0
						&StsCadastro = 'M'
					Case PesLog <> &xlsxPesLog  and &ColPesLog > 0
						&StsCadastro = 'M'
					Case PesNro <> &xlsxPesNro  and &ColPesNro > 0
						&StsCadastro = 'M'
					Case PesBai <> &xlsxPesBai  and &ColPesbai > 0
						&StsCadastro = 'M'
					Case PesCpl <> &xlsxPesCpl  and &ColPescpl > 0
						&StsCadastro = 'M'
					Case PesCidCod <> &xlsxCidCod  and ((&ColPescidCod > 0 and &ColPesufeCod > 0) or  &ColIBGE > 0)
						&StsCadastro = 'M'
					Case PesObs <> &xlsxPesObs  and &ColPesObs > 0
						&StsCadastro = 'M'
				EndCase	
				
				For Each Order EmpCod, PesFonCod
					Do case
						Case PesFonNum = &xlsxPesCelNum
							&xlsxPesCelNum.SetEmpty()
						Case PesFonNum = &xlsxPesFonNum
							&xlsxPesFonNum.SetEmpty()
					Endcase
				EndFor
				For Each Order EmpCod,PesEmlCod
					If PesEml = &xlsxPesEml
						&xlsxPesEml.SetEmpty()
						exit
					Endif
				EndFor
				Exit
			EndFor
			
		Case ((not &xlsxPesCnpj.IsEmpty()) and (&xlsxPesCnpj.Length() <= 14))
			
			For Each Order EmpCod, PesTip, PesCpf
				Where EmpCod = &EmpCod
				Where PesCpf = &xlsxPesCnpj
				Where PesTip = TipoPessoa.FISICA
				
				&StsCadastro = 'S'
				&PesCod = PesCod
				
				Do Case
					Case PesRaz <> &xlsxPesRaz and &ColPesRaz > 0
						&StsCadastro = 'M'
					Case PesCpf <> &xlsxPesCnpj and &ColPesCnpj > 0
						&StsCadastro = 'M'
					Case PesCadPro <> &xlsxPesInsEst  and &ColPesins > 0
						&StsCadastro = 'M'
					Case PesRg <> &xlsxPesRg  and &ColPesRg > 0
						&StsCadastro = 'M' 
					Case PesSuf <> &xlsxPesSuf  and &ColPessuf > 0
						&StsCadastro = 'M'
					Case PesDtaNas <> &xlsxPesDtaNas and &ColPesDtaNas > 0
						&StsCadastro = 'M'
					Case PesCep <> &xlsxPesCEP  and &ColPesceP > 0
						&StsCadastro = 'M'
					Case PesLog <> &xlsxPesLog  and &ColPesLog > 0
						&StsCadastro = 'M'
					Case PesNro <> &xlsxPesNro  and &ColPesNro > 0
						&StsCadastro = 'M'
					Case PesBai <> &xlsxPesBai  and &ColPesbai > 0
						&StsCadastro = 'M'
					Case PesCpl <> &xlsxPesCpl  and &ColPescpl > 0
						&StsCadastro = 'M'
					Case PesCidCod <> &xlsxCidCod  and ((&ColPescidCod > 0 and &ColPesufeCod > 0) or  &ColIBGE > 0)
						&StsCadastro = 'M'
					Case PesObs <> &xlsxPesObs  and &ColPesObs > 0
						&StsCadastro = 'M'
				EndCase
				
				For Each Order EmpCod, PesFonCod
					Do case
						Case PesFonNum = &xlsxPesCelNum
							&xlsxPesCelNum.SetEmpty()
						Case PesFonNum = &xlsxPesFonNum
							&xlsxPesFonNum.SetEmpty()
					Endcase
				EndFor
				For Each Order EmpCod,PesEmlCod
					If PesEml = &xlsxPesEml
						&xlsxPesEml.SetEmpty()
						exit
					Endif
				EndFor				
				Exit
			EndFor
			
		Case &SemCpfSemCnpj = 'S'		
			For Each Order EmpCod, PesTip, PesCpf
				Where EmpCod = &EmpCod
				Where PesRaz = &xlsxPesRaz
				
				&StsCadastro = 'S'
				&PesCod = PesCod
				
				Do Case
					Case PesRaz <> &xlsxPesRaz and &ColPesRaz > 0
						&StsCadastro = 'M'
						//					Case PesCnpj <> &xlsxPesCnpj and &ColPesCnpj > 0
						//						&StsCadastro = 'M'
						//					Case PesInsEst <> &xlsxPesInsEst  and &ColPesins > 0
						//						&StsCadastro = 'M'
					Case PesRg <> &xlsxPesRg  and &ColPesRg > 0
						&StsCadastro = 'M' 
					Case PesSuf <> &xlsxPesSuf  and &ColPessuf > 0
						&StsCadastro = 'M'
					Case PesDtaNas <> &xlsxPesDtaNas and &ColPesDtaNas > 0
						&StsCadastro = 'M'
					Case PesCep <> &xlsxPesCEP   and &ColPesceP > 0
						&StsCadastro = 'M'
					Case PesLog <> &xlsxPesLog  and &ColPesLog > 0
						&StsCadastro = 'M'
					Case PesNro <> &xlsxPesNro  and &ColPesNro > 0
						&StsCadastro = 'M'
					Case PesBai <> &xlsxPesBai  and &ColPesbai > 0
						&StsCadastro = 'M'
					Case PesCpl <> &xlsxPesCpl  and &ColPescpl > 0
						&StsCadastro = 'M'
					Case PesCidCod <> &xlsxCidCod  and ((&ColPescidCod > 0 and &ColPesufeCod > 0) or  &ColIBGE > 0)
						&StsCadastro = 'M'
					Case PesObs <> &xlsxPesObs  and &ColPesObs > 0
						&StsCadastro = 'M'
				EndCase	
				
				For Each Order EmpCod, PesFonCod
					Do case
						Case PesFonNum = &xlsxPesCelNum
							&xlsxPesCelNum.SetEmpty()
						Case PesFonNum = &xlsxPesFonNum
							&xlsxPesFonNum.SetEmpty()
					Endcase
				EndFor
				For Each Order EmpCod,PesEmlCod
					If PesEml = &xlsxPesEml
						&xlsxPesEml.SetEmpty()
						exit
					Endif
				EndFor				
				Exit
			EndFor		
	EndCase
EndSub


Sub 'GetCidade'
	&xlsxCidCod = 0
	For each Order EmpCod, CidNom, UfeCod
		Where EmpCod = &EmpCod
		Where CidIBGE = &XlsCidIBGE when not &XlsCidIBGE.IsEmpty()
		Where UfeCod = &xlsxUfeCod when &XlsCidIBGE.IsEmpty()
		Where CidNom = &xlsxPesCidNom when &XlsCidIBGE.IsEmpty()
		
		 &xlsxCidCod = CidCod
		 Exit
	EndFor
EndSub
