        <Source><![CDATA[
ProVlrCus_ProdutoEstoque.Call(&EmpCod, &ProCod)

//Verifica Produtos que tem o produto como receita
For Each Order EmpCod, RecProCod, RecItmCod
	Where EmpCod = &EmpCod
	Where RecProCod = &ProCod
	where ProCod <> &ProCod
	
	ProVlrCus = prcProVlrCus_FORMULA.Udp(EmpCod, ProCod, ProEstProCod, ProPadForCod, ProTipCus)
	
	commit
	
EndFor

commit

For Each Order EmpCod, RecProCod, RecItmCod
	Where EmpCod = &EmpCod
	Where RecProCod = &ProCod
	where ProCod <> &ProCod
	
	ProVlrCus_Receita.Call(EmpCod, ProCod)
EndFor
]]></Source>
