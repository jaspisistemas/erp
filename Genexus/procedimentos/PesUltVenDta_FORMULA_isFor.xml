      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&PedCliCod.Clear()
&PedTraRedCod.SetEmpty()
&PedTraSaiCod.SetEmpty()

For &sdtVinCulosItem in &sdtVinCulos
	&PedCliCod.Add(&sdtVinCulosItem.PesCod)
EndFor

For Each Order EmpCod, PedSts, LctTip, LctGerFin, LctAtuEst, (PedDtaFat)
	Where EmpCod = &EmpCod
	Where PedCliCod in &PedCliCod	
	Where PedSts = Status_Pedido.FECHADO //PEDIDO FECHADO
	Where LctTip = TipoLancamento.EntradaMercadoria //SAIDA MERCADORIA
	Where LctGerFin = Status_SimNao.Sim //GERA FINANCEIRO
	Where PedVlrLiq > 0
	
	&PedTraRedCod = PedTraRedCod
	&PedTraSaiCod = PedTraSaiCod
	
	Exit
EndFor
//SOMENTE TRANSPORTADORA PARA ENTRADA
]]></Source>
