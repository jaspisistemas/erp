      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

Do CAse
	CAse &OqueFazer = 'R'
		&CreDupIsAce = DuplicataAceite.REJEITADA
		&CreCobObs = format('DUPLICATA PAGAR REJEITADA, MOTIVO: %1', &MotivoVarchar)
	CAse &OqueFazer = 'A'
		&CreDupIsAce = DuplicataAceite.COM_ACEITE
		&CreCobObs = 'DUPLICATA PAGAR ACEITA'
	Case &OqueFazer = 'C'
		&CreDupIsAce = DuplicataAceite.SEM_ACEITE
		&CreCobObs = format('REMOVIDO ACEITE/REJEIÇÃO, MOTIVO: %1', &MotivoVarchar)
	Otherwise
		return
EndCAse


//Aceita ou Rejeita DUplicatas
For &SdtPagamentoDuplicataItem in &SdtPagamentoDuplicata
	For Each ORder EmpCod, FilCod, CreCod
		Where EmpCod = &sdtPagamentoDuplicataItem.EmpCod 
		Where CreCod = &SdtPagamentoDuplicataItem.CreCod
		Where FilCod = &SdtPagamentoDuplicataItem.FilCod
		
		CreDupIsAce = &CreDupIsAce
		CreDtaAce = Serverdate()
		Exit
	EndFor

	Commit
	
	GravaCobranca.call(&sdtPagamentoDuplicataItem.EmpCod,&sdtPagamentoDuplicataItem.FilCod,&sdtPagamentoDuplicataItem.CreCod,&CreCobObs,0,0,&CrePrmPag, &Hora, TIpoObservacaoDuplicata.INTERNA)

EndFor

]]></Source>
