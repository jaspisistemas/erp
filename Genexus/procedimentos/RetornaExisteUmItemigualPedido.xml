      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsExiste = false
&ExisteMensagem.SetEmpty()
For Each Order EmpCod, FilCod, PedCod, PedItmCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
	Where PedItmCod <> &PedItmCod
	Where PedQtd > 0
	
	&ExisteMensagem = 'REF: ' + ProRef.Trim() + ' - ' + ProNom.Trim() + ' Já adicionado uma vez no Pedido!'
	&IsExiste = true
EndFor
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
