      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&ConSdoEnt = 0
&ConSdoSai = 0
For each order EmpCod,MovCtaBanCod,MovCreDeb
	Where EmpCod  = &EmpCod
	Where MovCtaBanCod = &MovCtaBanCod
	Where MovDtaCon.IsEmpty() or MovDtaCon.IsNull() 
	Where MovCreDeb = 'C'
	&ConSdoEnt += MovVlr
EndFor

For each order EmpCod,MovCtaBanCod,MovCreDeb
	Where EmpCod  = &EmpCod
	Where MovCtaBanCod = &MovCtaBanCod
	Where MovDtaCon.IsEmpty() or MovDtaCon.IsNull() 
	Where MovCreDeb = 'D'
	&ConSdoSai += MovVlr
EndFor
	
]]></Source>
