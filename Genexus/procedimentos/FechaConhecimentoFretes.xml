      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For &sdtPedidosItem in &sdtPedidos	
	For Each Order EmpCod, FilCod, FrtCod
		Where EmpCod = &EmpCod
		Where FilCod = &sdtPedidosItem.FiLCod
		Where FrtCod = &sdtPedidosItem.PedCod
		&FrtStsFin = FrtStsFin
		
		//GRAVA LOG
		&TabelaVarchar = 'FRETE'
		&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
		if &LogErpTabIsLog = true
			&LogErpRegCod1 = trim(Str(FrtCod))
			&LogErpRegTip = TrnMode.Update
			&LogErpRegGUID.SetEmpty()
			//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
			prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'FrtStsFin', trim(FrtStsFin), trim(&FrtStsFin), &LogErpRegGUID )
		Endif
		//GRAVA LOG
		
		FrtStsFin = Status_Financeiro.FECHADO
		Exit
	EndFor
	
	if &FrtStsFin = Status_Financeiro.ABERTO
		UltimoCodigoEmpresa.Call(domParCod.DUPLICATA, &EmpCod, &FilCod, &CreCod)
		
		retornaCodigoPlanoContas.Call(&EmpCod, &sdtPedidosItem.PlanHie, &PlanCod)
		
		New
			EmpCod = &EmpCod
			FilCod = &FilCod
			CreCod = &CreCod
			CreFrtFilCod = &sdtPedidosItem.FiLCod
			CreFrtCod = &sdtPedidosItem.PedCod
			CreDupNro = trim(&sdtPedidosItem.frtDoc)
			CreDtaVct = &sdtPedidosItem.PedDtaDsp
			CreVlrDup = &sdtPedidosItem.PedVlrLiq
			CreCbrCod = &CreCbrCod
			CreDtaEms = &sdtPedidosItem.PedDtaFat
			CreVlrSdo = &sdtPedidosItem.PedVlrLiq
			CreCliCod = &sdtPedidosItem.PedCliCod
			CreVenCod = 1
			CreRecPag = ReceberPagar.Pagar 
			CreBloNro = ''
			CreSts = Status_Duplicata.ATIVO
			CreFrpPgtoCod = 1// duplicata
			CreOriDup = OrigemDuplicata.ConhecimentoFrete
			
			CrePlanCod = &PlanCod
			CreFilPgt = &sdtPedidosItem.FiLCod
		EndNew
	EndiF
EndFor

Commit
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
