      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = &sdtPedidoProduto.Count + 10
&Count = 5
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'


DeletaItemPedidoCompra.Call(&EmpCod, &FilCod, &PedCod, 0)


&Count += 5
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

	
For &sdtPedidoProdutoItem in &sdtPedidoProduto
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	If &sdtPedidoProdutoItem.Erro = 'N' or &sdtPedidoProdutoItem.Erro = 'X'
		//GravaItemPedidoVenda.Call(&EmpCod, &FilCod, &PedCod, 0, &sdtPedidoProdutoItem.ProCod, &sdtPedidoProdutoItem.ProGraCod, &sdtPedidoProdutoItem.PedQtd, &sdtPedidoProdutoItem.PedQtdCan, &sdtPedidoProdutoItem.PedVlrUnt, &sdtPedidoProdutoItem.PedVlrTab, &sdtPedidoProdutoItem.PedItmDsc, '', 0,0, &MensagemInserido, &MensagemAlterado)
		GravaItemPedidoVenda_Precificacao.Call(&EmpCod, &FilCod, &PedCod, 0, &sdtPedidoProdutoItem.ProCod, &sdtPedidoProdutoItem.ProGraCod, &sdtPedidoProdutoItem.PedQtd, &sdtPedidoProdutoItem.PedQtdCan, &sdtPedidoProdutoItem.PedVlrUnt, &sdtPedidoProdutoItem.PedVlrTab, &sdtPedidoProdutoItem.PedItmDsc, '', 0,0, &PedItmTabDtaVct, &PedItmTabPerAcr, &PedItmTabPerAnt, &sdtPedidoProdutoItem.PedItmProRefDig, &PedNItmPed, &MensagemInserido, &MensagemAlterado)
	EndIF
EndFor

  
&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub
]]></Source>
