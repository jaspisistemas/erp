        <Source><![CDATA[

&Total = &sdtServicosSelecionados.Count
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

&Hoje = serverdate()
&Ano = year(&hoje)
&Mes = month(&Hoje)
&SerItmUltVct = yMDtoD(&Ano, &Mes, 1)
&PedDtaFat = &Hoje
&UltimodiaMesData = EoM(&SerItmUltVct)

For &sdtServicosSelecionadosItem in &sdtServicosSelecionados
	
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	//GetServico
	For Each ORder EmpCod, SerItmCod 
		Where EmpCod = &EmpCod
		Where SerItmCod = &sdtServicosSelecionadosItem.SerItmCod
		Where SerItmTip = TipoLancamentoServico.VENDA
		Where SerItmSts = Status_ativoInativo.ATIVO
		Where SerItmUltVct.IsEmpty() or SerItmUltVct.IsNull() or SerItmUltVct < &SerItmUltVct 
		//Where SerItmAtuMan = 'M' //MANUAL na vdd nao precisa filtrar pois se é automatico e o cara quer gerar, entao gere.
		
		if &tabCod.IsEmpty()
			RetornaTabelaColunaFilial.Call(EmpCod, SerFilCod, &tabCod, &TabColCod)
		Endif
		
		&SerItmDiaVct = SerItmDiaVct-1
		&CreDtaVct = &SerItmUltVct
		&CreDtaVct = &CreDtaVct.AddDays(&SerItmDiaVct) //ADICIONAD A QTD DE DIAS.
		
		Do CAse
			CAse &CreDtaVct > &UltimodiaMesData //CASO VENCIMENTO FOR MAIOR QUE ULTIMODIA DO MES
				&CreDtaVct = &UltimodiaMesData
			Case &CreDtaVct < &hoje
				&CreDtaVct = &Hoje
		EndCase
		
		//GRAVA CAPA DO PEDIDO
		&sdtGravaPedido = new()
		&sdtGravaPedido.FilCod = SerFilCod
		&sdtGravaPedido.EmpCod = EmpCod
		&sdtGravaPedido.LctCod = SerItmLctCod
		&sdtGravaPedido.PedCliCod = SerCliCod
		&sdtGravaPedido.PedDtaEms = serverdate()
		&sdtGravaPedido.TabCod = &tabCod
		//&sdtGravaPedido.TabPrmCod
		&sdtGravaPedido.TabColCod = &TabColCod
		&sdtGravaPedido.PedVenCod = &wwpContextPesCod
		
		//	FINANCEIRO
		//PedPraCod = &sdtGravaPedido.PedPraCod
		//PedFrpPgtoCod = &sdtGravaPedido.PedFrpPgtocod
		//PedPraParNom = &sdtGravaPedido.PedPraParNom
		
		//	TRANSPORTE
		//PedTraRedCod = &sdtGravaPedido.PedTraRedCod
		&sdtGravaPedido.PedTipFrt = TipoFrete.SemFrete		
		//PedTraSaiCod = &sdtGravaPedido.PedTraSaiCod
		&sdtGravaPedido.PedTipSaiFrt = TipOFrete.SemFrete		
		//PedObsEst = &sdtGravaPedido.PedObsEst
		//PedObsFin = &sdtGravaPedido.PedObsFin
		//PedObsGer = &sdtGravaPedido.PedObsGer
		//PedObsNfe = &sdtGravaPedido.PedObsNfe		
		&sdtGravaPedido.PedFatFilCod = SerFilCod		
		//PedCbrCod = &sdtGravaPedido.PedCbrCod
		//PedCtaBanCod = &sdtGravaPedido.PedCtaBanCod		
		
		&sdtGravaPedido.PedStsGer = Pedido_Gerado.ServicoMensalidade
		&sdtGravaPedido.PedSerItmCod = SerItmCod
		
		prcGravaServicoPedido.Call(EmpCod, SerFilCod, &sdtGravaPedido, &WwpContextUserName, &PedCod)
		criticasPedido.Call(EmpCod, SerFilCod, &PedCod, TipoCriticaPedido.Digitado, &wwpContextPesCod)
		
		//GRAVA ITENS DO PEDIDO
		For Each Order EmpCod, SerItmCod, SerItmProId
			Where SerItmProSts <> Status_Produto.EXCLUIDO
			
			Do Case
				CAse SerItmProTipDef = Definicao.SERVICO //SERVICO
					&IsTemServico = true
				Case SerItmProTipDef <> Definicao.SERVICO
					&IsTemProduto = true
			EndCase
		
			prcGravaLancamentoServicoProdutos.Call(EmpCod, SerFilCod, &PedCod, 0, SerItmProCod, SerItmProGraCod, SerItmProQtd, &PedQtdCan, SerItmProVlrUnt, SerItmProVlrUnt, &PedItmDsc, &PedItmCmp, 0, 0, &TabDtaVct, &TabPerAcr, &TabPerAnt, &PedItmProRefDig, &PedNItmPed, &MensagemInserido, &MensagemAlterado)
		EndFor
		AtualizaTotaisPedido.Call(EmpCod, SerFilCod, &PedCod, 0, 'C')
		
		//FECHA ESTOQUE
		AtualizaEstoqueGerencialVenda.Call(EmpCod, SerFilCod, &PedCod, &PedDtaFat, &wwpContextPesCod,  Status_Pedido.FECHADO)
		
		//GERA FINANCEIRO
		&sdtPgto = new()
		&sdtPgto.FrpPgtoCod = 1
		&sdtPgto.FrpPgtoTip = TipoDuplicata.DUPLICATA //Deve ser preenchido
		&sdtPgto.OpcaoFechamento = 'U' //UNICA
		//&sdtPgto.PedDtaFat = &CrePagDta
		&sdtPgto.PedTmpCreCliCod = 0
		&sdtPgto.FunPesCod = 0
		&sdtPgto.PlanCod = SerItmPlanCod
		&sdtPgto.IsPago = false
		&sdtPgto.CreCbrCod = SerItmCbrCod
		
		&sdtPgto.creVlrDup = SerItmVlr
		Do Case
			CAse SerItmTipPlan = TipoPlano.MENSAL
				&CreDupNro = format('%1-%2/%3', trim(SerItmAbv), trim(Str(&Ano)),trim(Str(&Mes)))
			CAse SerItmTipPlan = TipoPlano.ANUAL
				&CreDupNro = format('%1-%2/A', trim(SerItmAbv), trim(Str(&Ano)))
			Otherwise
				&CreDupNro = format('%1-%2', trim(SerItmAbv), trim(Str(&Ano)))
		EndCase
		
		&sdtPgto.CreDupNro = &CreDupNro
		&sdtPgto.CreDtaVct = &CreDtaVct
		MontaDuplicatasPedidoVenda01_JDF.Call('ADD', EmpCod, SerFilCod, &PedCod, &sdtPgto)
		GravaDuplicatasAReceber1.Call(EmpCod, SerFilCod, &PedCod)
		
		
		//GERA NOTA FISCAL SERVICO
		&NfsCod = 0
		If SerItmIsEmiNFSe = true and &IsTemServico = true
			prcGravaNotaFiscalServicoPedido.Call(EmpCod, SerFilCod, &PedCod, &NfsCod)
			//prcValidacoesNFSe.call(EmpCod, &NfsCod, &IsErro, &erroMensagem)
			GravaSolicitacao.Call(EmpCod, SerFilCod, &NfsCod, 0, TipoSolicitacao.Autorizar_NFSE, &wwpContextPesCod, &SolCod)
		Endif
	
		//GERA NOTA FISCAL PRODUTO
		If SerItmIsEmiNFe = true and &IsTemProduto = true
			GravaNotaTemporariaVenda.Call(EmpCod, SerFilCod, &PedCod, '55')
			
			&tmpNFeCod = trim(str(EmpCod)) + trim(Str(SerFilCod)) + trim(str(&PedCod))
			//AtualizaNotaTemporariaVenda.Call(&tmpNFeCod, 0)
			//ValidacoesNFe.call(&tmpNFeCod, EmpCod, SerFilCod, &PedCod, &validacaoMensagem)
			//if &validacaoMensagem.IsEmpty()
				AtualizaFaturamentoPedido.Call(EmpCod, SerFilCod, &PedCod, SerFilCod)
				GravaNotaFiscalModelo55.Call('RETURN', EmpCod, SerFilCod, &PedCod, &tmpNFeCod, &wwpContextPesCod, 'E')
			//EndIf
		Endif
		
		//ATUALIZA ULTIMO VENCIMENTO DO SERVICO
		SerItmUltVct = &CreDtaVct
		
	EndFor
	
	Commit
EndFor


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub
]]></Source>
