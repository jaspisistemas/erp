      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsImpactouMudanca = false

For Each Order tmpNFeCod
	Where tmpNFeCod = &tmpNFeCod
		
	If tmpNfeDesImp <> &IsDescontoImpresso
		tmpNfeDesImp = &IsDescontoImpresso
		&IsImpactouMudanca = true
	EndIF
	
	If tmpNfeVlrDsc <> &tmpNfeVlrDsc
		tmpNfeVlrDsc = &tmpNfeVlrDsc
		&IsImpactouMudanca = true
	EndIF
	
	If tmpNfeIndPres <> &NfeIndPres
		tmpNfeIndPres = &NfeIndPres
		&IsImpactouMudanca = true
	EndIf

	if tmpNfeCliEntIs <> &tmpNfeCliEntIs
		tmpNfeCliEntIs = &tmpNfeCliEntIs
		&IsImpactouMudanca = true
	EndIf	

	If tmpNfePerDsc <> &tmpNfePerDsc
		tmpNfePerDsc = &tmpNfePerDsc
		&IsImpactouMudanca = true
	EndIF

	if tmpTipDesc <> &TipoDesconto
		tmpTipDesc = &TipoDesconto
		&IsImpactouMudanca = true
	EndiF
	
	If tmpNfeVlrFrt <> &PedVlrFrt
		tmpNfeVlrFrt = &PedVlrFrt
		&IsImpactouMudanca = true
	EndIF
	
	If tmpNfeFatFilCod <> &tmpNfeFatFilCod
		tmpNfeFatFilCod = &tmpNfeFatFilCod
		&IsImpactouMudanca = true
	EndIF
	
	if tmpTotOut <> &tmpTotOut
		 tmpTotOut = &tmpTotOut
		 &IsImpactouMudanca = true
	 EndIf

	Exit
EndFor

commit

if &IsImpactouMudanca = true //atualiza Totais Produto
	AtualizaNotaTemporariaVenda.Call(&tmpNFeCod, 0)
EndIf
]]></Source>
