      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[if &CrePlanCod.IsEmpty()
	RetornaConfSistema.Call(&AuxEmpCod, &AuxFilCod, domConfSistema.TCon044_PlanoRecCliente, &TCon044_PlanoRecCliente)
	&PlanCod = val(&TCon044_PlanoRecCliente)
Else
	&PlanCod = &CrePlanCod
EndiF


For each Order DupTmpEmpCod,DupTmpFilCod,DupTmpCreCod,DupTmpPesCod
	Where DupTmpEmpCod = &AuxEmpCod
	Where DupTmpFilCod = &AuxFilCod
	Where DupTmpCreCod = &AuxCreCod
	Where DupTmpPesCod = &AuxPesCod
 	DupTmpCreFilPgt = &CreFilPgt 
 	DupTmpCreDupNro = &CreDupNro
	DupTmpCreDtaEms = &CreDtaEms
	DupTmpCreDtaVct = &CreDtaVct
	DupTmpCreVlrDup = &CreVlrDup
	DupTmpCreVlrSdo = &CreVlrDup
	DupTmpCreCbrCod = &CreCbrCod
	DupTmpCreBloNro = trim(&CreBloNro)
	DupTmpCrePlanCod = &PlanCod
	DupTmpCrePerComCbr = &CrePerComCbr
	DupTmpCreSts = &DupSts
	exit
EndFor

commit
]]></Source>
