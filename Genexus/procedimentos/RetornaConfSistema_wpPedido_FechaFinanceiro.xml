      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	if FilTConCod.IsEmpty() or FilTConCod.IsNull()
		FilTConCod = 1
		&TConCod = 1
		commit
	Else
		&TConCod = FilTConCod
	EndIF	
	
	Exit
EndFor

&sdtConfig_wpPedido_FechaFinanceiro = new()

For Each Order EmpCod, TConCod
	Where EmpCod = &EmpCod
	Where TConCod = &TConCod
	
	&sdtConfig_wpPedido_FechaFinanceiro.TCon020_ClientePadraoVista = TCon020
	&sdtConfig_wwpVendas_3.TCon110_SolicitarSenha 				   = TCon110
	&sdtConfig_wpPedido_FechaFinanceiro.TCon133_BloqPedDebCliente  = TCon133
	&sdtConfig_wpPedido_FechaFinanceiro.TCon140_AlterarDataFaturamento = TCon140
	&SdtConfig_wwpVendas_3.TCon155_TipLancamentoIniciarVenda 	   = TCon155
	&sdtConfig_wpPedido_FechaFinanceiro.TCon159_DataBaseFEchamento = TCon159
	
	RetornaCodigoPlanoContas.Call(&EmpCod, TCon107, &sdtConfig_wpPedido_FechaFinanceiro.TCon107_PlanCodRecebeCartao)
	if TCon044 <> TCon107
		RetornaCodigoPlanoContas.Call(&EmpCod, TCon044, &sdtConfig_wpPedido_FechaFinanceiro.TCon044_PlanCodRecebeDinheiro)
	Else
		&sdtConfig_wpPedido_FechaFinanceiro.TCon044_PlanCodRecebeDinheiro = &sdtConfig_wpPedido_FechaFinanceiro.TCon107_PlanCodRecebeCartao
	Endif
	
	RetornaCodigoPlanoContas.Call(&EmpCod, TCon063, &sdtConfig_wpPedido_FechaFinanceiro.tcon063_PgtoComVale) //VALE
	&sdtConfig_wpPedido_FechaFinanceiro.TCon066_NaoFecharFinanceiroComDiferenca = TCon066.ToString()
	&sdtConfig_wpPedido_FechaFinanceiro.TCon075_ValidaNroDuplicata = TCon075
	
	RetornaCodigoPlanoContas.Call(&EmpCod, TCon123, &sdtConfig_wpPedido_FechaFinanceiro.TCon123_PlanCodCreditoCliente)
	
	
	Exit
EndFor
]]></Source>
