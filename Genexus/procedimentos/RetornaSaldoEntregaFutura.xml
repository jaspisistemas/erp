      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&IsSaldo = true
&SaldoMoeda = &PedVlrLiq

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedStsGer = Pedido_Gerado.OrdemCarregamento
	Where PedSts = Status_Pedido.FECHADO
	Where PedCodOciRef = &PedCod
	
	&SaldoMoeda -= PedVlrLiq
	
EndFor

if &SaldoMoeda <= 0
	&IsSaldo = false
Endif
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
