      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[/*
	Realiza a criação de um JWS;
	Cria um token de acesso, válido por 1 hora.
*/

Do 'GetContaBancaria'

&DataHora	= ServerNow()
&iatVarChar	= Trim(Str(DateTimeToTimestamp.Udp(&DataHora) * -1))
&expVarChar	= Trim(Str(DateTimeToTimestamp.Udp(&DataHora.AddHours(1)) * -1))
&jtiVarChar	= &iatVarChar + '000'
&ExecuteUrl	= IIf(&CbrCtaBanPixApi = 'P', 'https://openapi.bradesco.com.br/auth/server/v1.1/token', 'https://proxy.api.prebanco.com.br/auth/server/v1.1/token')


&JWTOptions.AddRegisteredClaim(RegisteredClaim.aud, &ExecuteUrl)
&JWTOptions.AddRegisteredClaim(RegisteredClaim.sub, &CtaBanPixCliSec.Trim())
&JWTOptions.AddRegisteredClaim(RegisteredClaim.iat, &iatVarChar)
&JWTOptions.AddRegisteredClaim(RegisteredClaim.exp, &expVarChar)
&JWTOptions.AddRegisteredClaim(RegisteredClaim.jti, &jtiVarChar)

&JWTOptions.SetPrivateKey(&PrivateKey)
&jwTOptions.SetCertificate(&certificate)
&PrivateClaims.SetClaim("ver","1.1")

&token = &JWTCreator.DoCreate(JWTAlgorithm.RS256, &PrivateClaims, &JWTOptions)
if &JWTCreator.HasError()
    msg("Erro na criação do JWT. Código: " + &JWTCreator.GetErrorCode() + " Descrição: " + &JWTCreator.GetErrorDescription())	
else
	&verification = &JWTCreator.DoVerify(&token, JWTAlgorithm.RS256, &PrivateClaims, &JWTOptions)
    if &JWTCreator.HasError()
    	msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro - " + &JWTCreator.GetErrorCode() ,  "Erro na verificação do JWT. " + &JWTCreator.GetErrorDescription(), DVMessageType.error, "", DVMessageBoolean.True,""))
	else
		&Erro	= 0
		&Body	= 'grant_type=urn:ietf:params:oauth:grant-type:jwt-bearer'
		&Body	+= '&assertion=' + Trim(&token)
				
		&HttpClient.AddHeader('Content-Type', 'application/x-www-form-urlencoded')
		&HTTPClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
		&HTTPClient.AddHeader('Connection', 'keep-alive')
		&HTTPClient.AddString(&Body)
		
		&HTTPClient.Execute('POST', &ExecuteUrl)
		If &HttpClient.ErrCode = 0
			&BradescoAccessToken_Response.FromJson(&HttpClient.ToString())
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Sucesso!", 'Autenticação realizada.', DVMessageType.success, "", DVMessageBoolean.True,""))
			Do 'GravaAutenticacaoLocalCobranca'
		Else
			padraoUsuario.Call('G', 'BRADESCO_AccessToken_ERRO', 0, &EmpCod, &HttpClient.ToString(), ServerDate())
			&Erro = 1
			&Mensagem 		= Trim(Str(&HTTPClient.StatusCode)) +' - '+ &HTTPClient.ErrDescription + newLine() + &HttpClient.ToString()
			msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro!",  &Mensagem, DVMessageType.error, "", DVMessageBoolean.True,""))
		EndIf
    endif
endif

Sub 'GravaAutenticacaoLocalCobranca'
	
	For Each Order EmpCod, CbrCod, CbrTipImp
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		CbrChaTra		= &BradescoAccessToken_Response.access_token
		&CbrChaTra	= &BradescoAccessToken_Response.access_token
		CbrChaTraVct	= &DataHora.AddHours(1)
		
		Exit
	EndFor
	Commit
	
EndSub

Sub 'GetContaBancaria'
	
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CbrCod
		
		&CtaBanPixCliSec	= CtaBanPixCliSec
		&CbrCtaBanPixApi	= CbrCtaBanPixApi
		Exit
	EndFor
	
	RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)
	&CaminhoVarChar	= &SdtConfiguracoesPasta.PastaDiretorioCertificado + &FilCerNom
	&certificate.LoadPKCS12(&CaminhoVarChar, "", &FilCerPsw)
	&PrivateKey.LoadPKCS12(&CaminhoVarChar, "", &FilCerPsw)
	
EndSub
]]></Source>
