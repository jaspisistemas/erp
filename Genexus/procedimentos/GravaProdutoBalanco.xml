      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
IniciaEstoque.Call(&EmpCod, &FilCod, &ProCod, &ProGraCod)

&HojeData = serverdate()
&AuxFim = &HojeData.AddDays(1)

&mensagemInserido = ''
&mensagemAtualizado = ''
&ProSolLot = SolicitarLote.NAO_CONTROLAR

//atualiza a Produto no balanco
For Each Order EmpCod, FilCod, BalCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where BalCod = &BalCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod
    
	BalQtd = &BalQtd
	
	if BalDta <> &HojeData
		&DataBaseBalDta = BalDta.AddDays(1)
		EstoqueAnteriorFicha.Call(EmpCod,FilCod,ProCod,ProGraCod, 1, &DataBaseBalDta, &AuxFim, &BalQtdAnt)
	Else
		RetornaEstoquePedido.Call(EmpCod,FilCod,ProCod,ProGraCod, Status_Pedido.ABERTO, &EstLoc, &BalQtdAnt,&EstSdo, &Mensagem)
	Endif

	BalQtdAnt = &BalQtdAnt
	BalOrd = SERverNow()
    &mensagemAtualizado = 'Produto: ' +trim(ProGraRef)+ ', ATUALIZADO com sucesso.'
	&ProSolLot =  ProSolLot
	
	Exit
When none //Insere Novo Item Balanco
	&BalQtdAnt = 0
	For Each Order EmpCod, FilCod, BalCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		Where BalCod = &BalCod
		
		if BalDta <> &HojeData
			&DataBaseBalDta = BalDta.AddDays(1)
			EstoqueAnteriorFicha.Call(&EmpCod,&FilCod,&ProCod,&ProGracod, 1, &DataBaseBalDta, &AuxFim, &BalQtdAnt)
		Else
			RetornaEstoquePedido.Call(&EmpCod,&FilCod,&ProCod,&ProGraCod, Status_Pedido.ABERTO, &EstLoc, &BalQtdAnt,&EstSdo, &Mensagem)
		Endif
		
		Exit
	Endfor
	
    new
		EmpCod = &EmpCod
        FilCod = &FilCod
        BalCod = &BalCod
        ProCod = &ProCod
		ProGraCod = &ProGraCod
        BalQtd = &BalQtd
		BalOrd = SERverNow()
		BalQtdAnt = &BalQtdAnt
    EndNew

	
	for Each Order EmpCod, ProCod, ProGraCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		Where ProGraCod = &ProGraCod
		&mensagemAtualizado = 'Produto: ' +trim(ProGraRef)+', INSERIDO com sucesso.'
		&ProSolLot =  ProSolLot
		Exit
	EndFor
EndFor

commit

For Each Order EmpCod, FilCod, ProCod, ProGraCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where ProCod = &ProCod
	Where ProGraCod = &ProGraCod 
	
	EstProStsBal = Status_SimNao.Sim //JDF FIXEI para agilizar//retornaProdutoBalanco.Udp(EmpCod, FilCod, ProCod, ProGraCod)
	 
	Exit
Endfor

commit

If &ProSolLot = SolicitarLote.SIM_CONTROLAR
	GravarLotesBalanco.Call(&EmpCod, &FilCod, &BalCod, &ProCod, &ProGraCod)
Endif



]]></Source>
