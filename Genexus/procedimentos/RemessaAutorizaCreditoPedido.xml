      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, CrePedCod,CreRecPag,CreCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CrePedCod = &PedCod
	Where CreRecPag = ReceberPagar.Receber
	Where CreSts <> Status_Duplicata.CANCELADA
	&CreVlrDup += CreVlrDup
	&CreVlrsdo += CreVlrSdo	
EndFor

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	If PedVlrLiq = &CreVlrDup and &CreVlrSdo = 0 and PedStsCrd <> Status_Autorizado.AUTORIZADO
		
		GravaLiberacaoCreditoPedido.Call(&EmpCod, &FilCod, &PedCod, &PesCod, &WWpContextUserName, 'AUP', 'RECEB.VIA ARQUIVO COBRANÇA')
	EndIF
	Exit
EndFor
]]></Source>
