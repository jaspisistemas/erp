      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

for &ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem in &ppJASPI_DuplicatasERP_outADMsdtDuplicatas.Duplicatas.Items
	&CreCliCod = 0
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &EmpCod
		Where PesEmpSecCod = &ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem.CliCodSync
		
		&CreCliCod = PesCod
		
		Exit
	EndFor
	&DupTmpCreCodSecEmp = &ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem.CliCodSync
	&DupTmpCreCod = &ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem.CreCod
	&CreDupNro = trim(str(&CrecliCod)) + '-' + trim(str(Year(&ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem.CreDtaVct))) + '/'+trim(str(month(&ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem.CreDtaVct)))
	&CreVlrDup = &ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem.CreVlrDup
	&CreDtaVct = &ppJASPI_DuplicatasERP_outADMsdtDuplicatasitem.CreDtaVct
	//GravaDuplicata
	do 'GravaDuplicataTemporaria'
	
EndFor


Sub 'GravaDuplicataTemporaria'
	
	New
		DupTmpEmpCod = &EmpCod
		DupTmpFilCod = &FilCod
		DupTmpCreFilPgt = &FilCod
		DupTmpCreCod = &DupTmpCreCod
		DupTmpPesCod = &PEsCod
		
		DupTmpCreDupNro = &CreDupNro
		DupTmpCreDtaEms = &CreDtaEms
		DupTmpCreDtaVct = &CreDtaVct
		DupTmpCreVlrDup = &CreVlrDup
		DupTmpCreVlrSdo = &CreVlrDup
		DupTmpCreCliCod = &CreCliCod
		
		DupTmpCreVenCod = &CreVenCod
		DupTmpCreRecPag = ReceberPagar.Receber
		DupTmpCreCbrCod = &CreCbrCod
		DupTmpCreBloNro	= ''
		DupTmpCreCbrJurCod = &CreCbrJurCod
		DupTmpCreCodBar = ''
		DupTmpCrePlanCod = &PlanCod
		DupTmpCrePerComCbr = 0
		DupTmpCreCodSecEmp = &DupTmpCreCodSecEmp
	EndNew
	
	Commit
	
EndSub

]]></Source>
