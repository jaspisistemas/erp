      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&QtdTot = &EntradaVarchar.Length()
&VirgulaID = &EntradaVarchar.IndexOf(',', 1)
if &VirgulaID.IsEmpty()
	&VirgulaID = &EntradaVarchar.IndexOf(',', 1)
Endif
&Count = &VirgulaID

For &in = &VirgulaID to &QtdTot
	&AnalisaCAmpo = Substr(&EntradaVarchar, &in, 1)
	
	if &AnalisaCAmpo <> '0'
		&UltimoNumeric = &in
	Endif
EndFor


Do CAse
	CAse &UltimoNumeric <= &VirgulaID
		&UltimoNumeric = &VirgulaID + 2
		
	CAse &UltimoNumeric <= &VirgulaID+1
		&UltimoNumeric += 1
EndCAse

	
&SaidaVarchar = Substr(&EntradaVarchar, 1, &UltimoNumeric)
]]></Source>
