      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDFeCod
	&MDFeChv = MDFeChv
	Exit
EndFor

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &SdtCOnfiguracoesPasta)

&URLFisico = &SdtCOnfiguracoesPasta.PastaNFpdf + 'MDFe'+ &MDFeChv.Trim() + '.pdf'
&URLVirtual = &SdtCOnfiguracoesPasta.PastaNFpdfVir +'MDFe'+ &MDFeChv.Trim() + '.pdf'

&File.Source = &URLFisico

If &File.Exists()
	&File.Delete()
EndIf

RELJAS013_ToFile.Call(&EmpCod, &FilCod, &MDFeCod, &URLFisico)
]]></Source>
