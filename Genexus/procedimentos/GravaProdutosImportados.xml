      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Total = &SdtTabelaPreco.Count + 10
&Count = 5
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

Do 'Tabela'
&Count += 5
If &Count > 0
	&Percentual = round((&Count / &Total) * 100, 0)
EndIF
If &Percentual >= 100
	&Percentual = 99
EndIf
do 'Atualiza'

	
For &SdtTabelaPrecoItem in &SdtTabelaPreco
	&Count += 1
	If &Count > 0
		&Percentual = round((&Count / &Total) * 100, 0)
	EndIF
	If &Percentual >= 100
		&Percentual = 99
	EndIf
	do 'Atualiza'
	
	&ProCod  = &SdtTabelaPrecoItem.ProCod
	&ProGraCod  = &SdtTabelaPrecoItem.ProGraCod
	&TabPrc1 = &SdtTabelaPrecoItem.TabPrc1
	&TabPrc2 = &SdtTabelaPrecoItem.TabPrc2
	&TabPrc3 = &SdtTabelaPrecoItem.TabPrc3
	&TabPrc4 = &SdtTabelaPrecoItem.TabPrc4
	&TabPrc5 = &SdtTabelaPrecoItem.TabPrc5
	&TabPrc6 = &SdtTabelaPrecoItem.TabPrc6
	&TabPrc7 = &SdtTabelaPrecoItem.TabPrc7
	&TabPrc8 = &SdtTabelaPrecoItem.TabPrc8
	&TabPrc9 = &SdtTabelaPrecoItem.TabPrc9
	&TabProDtaIni = &SdtTabelaPrecoItem.TabProDtaIni
	&TabProDtaFin = &SdtTabelaPrecoItem.TabProDtaFin
	
	
	If &SdtTabelaPrecoItem.Erro = 'N'
		GravaProdutoNaTabela.Call(&EmpCod,&TabCod,&TabAltCod,&ProCod,&ProGraCod,'ADD',&TabProDtaIni,&TabProDtaFin,&TabPrc1,&TabPrc2,&TabPrc3,&TabPrc4,&TabPrc5, &TabPrc6,&TabPrc7,&TabPrc8,&TabPrc9, &wwpContextUserName)
	EndIF
EndFor

  
&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub

Sub 'Tabela'
	For Each Order EmpCod,TabCod
		Where EmpCod = &EmpCod
		Where TabCod = &TabCod
		&TabAltCod = TabUltAlt
		
		Exit		
	EndFor
EndSub

]]></Source>
