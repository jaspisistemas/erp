      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For &sdtMovimentoItem in &sdtMovimento
	if &MovCod = 0
		UltimoCodigoEmpresa.Call(domParCod.MOVIMENTO, &EmpCod, 0, &MovCod)
		
		&CrePagDta = &sdtMovimentoItem.MovDtaPgt
		
		New //GRAVA CAPA MOVIMENTO
			EmpCod = &EmpCod
			MovCod = &MovCod
			MovDta = SErverDate()
			MovDtaPgt = &sdtMovimentoItem.MovDtaPgt
			MovHor = &sdtMovimentoItem.MovHor
			MovCtaBanCod = &sdtMovimentoItem.MovCtaBanCod
			MovCreDeb = &sdtMovimentoItem.MovCreDeb
			If &sdtMovimentoItem.MovDoc <> ''
				MovDoc = &sdtMovimentoItem.MovDoc
				&Documento = &sdtMovimentoItem.MovDoc
			Else
				MovDoc = trim(str(&MovCod))
				&Documento = &sdtMovimentoItem.MovDoc
			EndIF
			MovDtaCon = &sdtMovimentoItem.MovDtaCon
			MovTip = TipoMovimento.FechamentoPedido
			&MovTip = TipoMovimento.FechamentoPedido
			If &sdtMovimentoItem.MovDtaCon.IsEmpty()
				MovIsCon = Status_SimNao.Nao
				&MovConci = 'N'
			Else
				MovIsCon = Status_SimNao.sim
				&MovConci = 'S'
			EndIf
		
			MovSts = Status_Caixa.Lancado
		EndNew
		
		commit
	EndIF
	
	&MovItmCod	 = 0
	For Each Order EmpCod, MovCod, (MovItmCod)
		Where EmpCod = &EmpCod
		Where MovCod = &MovCod
		&MovItmCod = MovItmCod
		Exit
	EndFor
	&MovItmCod += 1
	
	//GRAVA PAGAMENTO DUPLICATA
	&PlanCod = &sdtMovimentoItem.PlanCod
	GravaDuplicataPagamento.Call(&EmpCod, &sdtMovimentoItem.MovCreFilCod, &sdtMovimentoItem.MovCreCod, &sdtMovimentoItem.MovDtaCon, &sdtMovimentoItem.MovItmVlr, &sdtMovimentoItem.CrePagVlrJur, &sdtMovimentoItem.CrePagVlrDsc, &MovCod, &MovItmCod, &MovCrePagCod)
	
	//GRAVA ITEM MOVIMENTO
	
	new
		EmpCod = &EmpCod
		MovCod = &MovCod
		MovItmCod = &MovItmCod
		MovItmVlr = &sdtMovimentoItem.MovItmVlr
		MovItmCpl = &sdtMovimentoItem.MovCpl
		PlanCod = &PlanCod
		MovCreFilCod = &sdtMovimentoItem.MovCreFilCod
		MovCreCod = &sdtMovimentoItem.MovCreCod
		MovCrePagCod = &MovCrePagCod
		MovItmSts = Status_Caixa.Lancado
	EndNew
	
	commit
EndFor

commit

prcAtualizaMovimentoFinanceiro.Call(&EmpCod, &MovCod)

For Each Order EmpCod, MovCod
	Where EmpCod = &EmpCod
	Where MovCod = &MovCod
	
	AtualizaSaldoConta.Call(TrnMode.Insert, EmpCod, MovCtaBanCod, MovDtaCon, MovCreDeb, MovVlr, &AntMovDta, &AntMovVlr, '')
	Exit
EndFor
]]></Source>
