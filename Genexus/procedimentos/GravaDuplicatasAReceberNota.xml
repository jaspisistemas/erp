      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod

	&NfePedCod = NfePedCod
	&NfeDtaEms = NfeDtaEms
	&PedCliCod = NfeCliCod
	&PedVenCod = &PesCod
	
	&NfeFilCod = NfeFilCod
	
	if &NfePedCod > 0	
		RetornaClienteVendedorPedido.Call(EmpCod, NfeFilCod, NfePedCod, &PedCliCod, &PedVenCod)
	EndIF
	
	&IsUmaDup = false
	For Each Order EmpCod, FilCod, NfeCod, NfeDupItmCod //Duplicatas NFE
		&IsUmaDup = true
		&NfeDupCreCod = NfeDupCreSeq
		
		Do CAse
			Case NfeDupFiLCod > 0 //FILIAL PROPRIA DP.
				&NfeDupFilCod = NfeDupFiLCod		
			Case &NfeFilCod > 0 //FILIAL PEDIDO
				&NfeDupFilCod = &NfeFilCod
			Otherwise //FILIAL NOTA
				&NfeDupFilCod = &FilCod
		EndCAse
	
		GravaDuplicataAReceberNotaItem.Call(EmpCod, FilCod, NfeCod, &NfePedCod, &NfeDupFilCod, &NfeDupCreCod, &NfeDtaEms, &PedCliCod, &PedVenCod, 1, NfeDupNro, NfeDupVct, NfeDupVlr, NfeCbrCod,'NFE')
		
		NfeDupFiLCod = &NfeDupFilCod
		NfeDupCreSeq = &NfeDupCreCod
	EndFor
	
EndFor


commit

if &IsUmaDup = true and &NfePedCod > 0
	FechaFinanceiroPedido.Call(&EmpCod, &NfeFilCod, &NfePedCod)
EndIf
]]></Source>
