      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

LocalizaTrocaBalcaoTotal.call(&EmpCod, &FilCod, &PedCod, &DevPedCod, &DevPedVlrLiq)

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PEdCod or PedCod = &DevPedCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PEDIDO'
	&LogErpRegGUID.SetEmpty()
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(PedCod))
		&LogErpRegTip = TrnMode.Update
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedCliCod', trim(toformattedString(PedCliCod)), trim(toformattedString(&PedCliCod)), &LogErpRegGUID )
		
		if PedCod = &PEdCod
			prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'LctCod', trim(toformattedString(LctCod)), trim(toformattedString(&LctCod)), &LogErpRegGUID )
		EndiF
	
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedVenCod', trim(toformattedString(PedVenCod)), trim(toformattedString(&PedVenCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedDtaEms', trim(toformattedString(PedDtaEms)), trim(toformattedString(&PedDtaEms)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedDtaPrv', trim(toformattedString(PedDtaPrv)), trim(toformattedString(&PedDtaPrv)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TabCod', trim(toformattedString(TabCod)), trim(toformattedString(&TabCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TabPrmCod', trim(toformattedString(TabPrmCod)), trim(toformattedString(&TabPrmCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'TabColCod', trim(toformattedString(TabColCod)), trim(toformattedString(&TabColCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPraCod', trim(toformattedString(PedPraCod)), trim(toformattedString(&PedPraCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedPraParNom', trim(toformattedString(PedPraParNom)), trim(toformattedString(&PedPraParNom)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedRspCod', trim(toformattedString(PedRspCod)), trim(toformattedString(&PedRspCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, EmpCod, FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'PedFatFiLCod', trim(toformattedString(PedFatFilCod)), trim(toformattedString(&PedFatFiLCod)), &LogErpRegGUID )
		
	Endif
	//GRAVA LOG
	
	if PedCod = &PEdCod
		&OldLctCod = LctCod
		LctCod = &LctCod
	EndiF
	
	PedCliCod = &PedCliCod
	PedVenCod = &PedVenCod
	PedDtaEms = &PedDtaEms
	PedFatFilCod = &PedFatFiLCod
	
	if (PedDtaFat.IsEmpty() or PedDtaFat.IsNull()) or PedSts = Status_Pedido.ABERTO
		PedDtaFic = PedDtaEms
	Else
		PedDtaFic = PedDtaFat
	EndIF

	PedDtaPrv = &PedDtaPrv
	TabCod = &TabCod
	TabPrmCod = &TabPrmCod
	TabColCod = &tabColCod
	
	PedPraCod = &PedPraCod
	PedPraParNom = &PedPraParNom
	PedRspCod = &PedRspCod
	
	PedNovCliRaz = RetiraCaracteresEspeciais.Udp(&PedNovCliRaz)
	PedNovCliCpfCnpj = &PedNovCliCpfCnpj
	
	if PedNovCliCpfCnpj.Length() = 18 //'21.826.923/0001-77' //JURIDICA
		PedNovTip = TipoPessoa.JURIDICA
	Else
		PedNovTip = TipoPessoa.FISICA
	Endif
	
EndFor

commit

if &OldLctCod <> &LctCod and &OldLctCod <> 0 and &LctCod <> 0
	PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &PedCod)
EndIf
]]></Source>
