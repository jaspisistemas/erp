      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each
	Where EmpCod = &EmpCod
	Where CtabanCod = &CtaBanCod
	Where LanBanStatus <> StatusConciliacao.Pendente
	//	Where LanBanVlr = &LanBanVlr when not &LanBanVlr.IsEmpty()
	//	Where LanBanDoc like &localizar or LanBanDesc like &localizar when not &localizar.IsEmpty()
	where LanBanData.Month() = &MEs when not &MEs.IsEmpty()
	where LanBanData.year() = &Ano when not &Ano.IsEmpty()
	where LanBanData.day() = &Dia when not &Dia.IsEmpty()
	
	&Total += 1
	
EndFor

&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'


For Each
	Where EmpCod = &EmpCod
	Where CtabanCod = &CtaBanCod
	Where LanBanStatus <> StatusConciliacao.Pendente
	//	Where LanBanVlr = &LanBanVlr when not &LanBanVlr.IsEmpty()
	//	Where LanBanDoc like &localizar or LanBanDesc like &localizar when not &localizar.IsEmpty()
	where LanBanData.Month() = &MEs when not &MEs.IsEmpty()
	where LanBanData.year() = &Ano when not &Ano.IsEmpty()
	where LanBanData.day() = &Dia when not &Dia.IsEmpty()
	
	&Qtd += 1
	if &Qtd = 5
		&Count += &Qtd
		If &Count > 0
			&Percentual = round((&Count / &Total) * 100, 0)
		EndIF
		If &Percentual >= 100
			&Percentual = 99
		EndIf
		do 'Atualiza'
		&Qtd = 0
	Endif
	
	LanBanStatus = StatusConciliacao.Pendente
	
	//Atualiza Itens do movimento para nao conciliado
	For Each 
		where MovItmDoc = LanBanDoc
		
		MovItmDoc.SetEmpty()
		MovItmIsCon = Status_SimNao.Nao
		MovItmConDesc.SetEmpty()
		MovItmDtaCon.SetEmpty()
	EndFor

	Commit

EndFor


&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'

Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit	
EndSub
]]></Source>
