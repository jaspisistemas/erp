      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For each Order EmpCod,FilCod,OpeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where OpeCod = &OpeCod
	
	If OpeSts		= Status_Ciot.Digitando
		//Motorista
		OpeMotCod		= &WizardData.Viagem.OpeMotCod
		OpeMotCnpj 		= &WizardData.Viagem.OpeMotCnpj
		OpeMotCnh 		= &WizardData.Viagem.OpeMotCnh
		OpeMotTelNro 	= &WizardData.Viagem.OpeMotTelNro
		OpeMotTelDdd 	= &WizardData.Viagem.OpeMotTelDdd
		
		If &WizardData.Inicio.OpeTipVia = PefServiceTipoViagem.Padrao
			OpeNcm 			= &WizardData.Viagem.OpeNcm
			OpeTipEmb 		= &WizardData.Viagem.OpeTipEmb
			OpePso 			= &WizardData.Viagem.OpePso
			OpeTipCar		= &WizardData.Viagem.OpeTipCar
			OpeAltDes 		= &WizardData.Viagem.OpeAltDes
			OpeDesCom 		= &WizardData.Viagem.OpeDesCom
			OpeFrtRet 		= &WizardData.Viagem.OpeFrtRet 
			OpeCepRet 		= &WizardData.Viagem.OpeCepRet
			OpeDisRet 		= &WizardData.Viagem.OpeDisRet
			
			For Each Order EmpCod, FilCod, OpeCod, OpeViaCod
				Where OpeViaCod = 1
				OpeOriCidUfe 	= &WizardData.Viagem.OpeOriCidUfe
				OpeOriCidCod	= &WizardData.Viagem.OpeOriCidCod
				OpeOricidCep 	= &WizardData.Viagem.OpeOricidCep
				OpeDstCidUfe 	= &WizardData.Viagem.OpeDstCidUfe
				OpeDstCidCod 	= &WizardData.Viagem.OpeDstCidCod
				OpeDstCidCep 	= &WizardData.Viagem.OpeDstCidCep
				OpeViaDstPer 	= &WizardData.Viagem.OpeViaDstPer
				OpeTipPgt 		= &WizardData.Viagem.OpeTipPgt
				OpeNroDoc 		= &WizardData.Viagem.OpeNroDoc
				Exit
			When none
				new 
					EmpCod 			= &EmpCod
					FilCod 			= &FilCod
					OpeCod 			= &OpeCod
					OpeViaCod 		= 1
					OpeOriCidUfe 	= &WizardData.Viagem.OpeOriCidUfe
					OpeOriCidCod 	= &WizardData.Viagem.OpeOriCidCod
					OpeOricidCep 	= &WizardData.Viagem.OpeOricidCep
					OpeDstCidUfe 	= &WizardData.Viagem.OpeDstCidUfe
					OpeDstCidCod 	= &WizardData.Viagem.OpeDstCidCod
					OpeDstCidCep 	= &WizardData.Viagem.OpeDstCidCep
					OpeViaDstPer 	= &WizardData.Viagem.OpeViaDstPer
					OpeTipPgt 		= &WizardData.Viagem.OpeTipPgt
					OpeNroDoc 		= &WizardData.Viagem.OpeNroDoc
					OpeViaSts		= Status_Autorizado.AUTORIZADO
				EndNew
			EndFor
			
			For each Order EmpCod, FilCod, OpeCod, OpeViaCod
				Where OpeValCod = 1
				OpeTotAdi 		= &WizardData.Viagem.OpeTotAdi
				OpeTotPed 		= &WizardData.Viagem.OpeTotPed
				OpeTotCom 		= &WizardData.Viagem.OpeTotCom
				OpeTotSeg 		= &WizardData.Viagem.OpeTotSeg
				OpeTotQui 		= &WizardData.Viagem.OpeTotQui
				OpeTotOutCre 	= &WizardData.Viagem.OpeTotOutCre
				OpeTotOutDeb 	= &WizardData.Viagem.OpeTotOutDeb
				OpeTotOutCreJus = &WizardData.Viagem.OpeTotOutCreJus
				OpeTotOutDebJus = &WizardData.Viagem.OpeTotOutDebJus
				
			When none
				new
					EmpCod 			= &EmpCod
					FilCod 			= &FilCod
					OpeCod 			= &OpeCod
					OpeValCod 		= 1
					OpeTotAdi 		= &WizardData.Viagem.OpeTotAdi
					OpeTotPed 		= &WizardData.Viagem.OpeTotPed
					OpeTotCom 		= &WizardData.Viagem.OpeTotCom
					OpeTotSeg 		= &WizardData.Viagem.OpeTotSeg
					OpeTotQui 		= &WizardData.Viagem.OpeTotQui
					OpeTotOutCre 	= &WizardData.Viagem.OpeTotOutCre
					OpeTotOutDeb 	= &WizardData.Viagem.OpeTotOutDeb
					OpeTotOutCreJus = &WizardData.Viagem.OpeTotOutCreJus
					OpeTotOutDebJus = &WizardData.Viagem.OpeTotOutDebJus
				endnew
			EndFor
		EndIf
	EndIf
EndFor

]]></Source>
