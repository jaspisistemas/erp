      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&CteArqXml.SetEmpty()
&IsSucesso = False
do 'PegaArquivoXML'

If not &CteArqXml.Trim().IsEmpty()
	&HttpClient.Host = 'webserver.averba.com.br' //servidor
	&HttpClient.timeout = 5
	&HttpClient.Secure = 0
	//&httpclient.AddHeader(!'Accept-Encoding',!'gzip,deflate')
	&httpclient.AddHeader(!'Connection',!'Keep-Alive')
	&httpclient.AddHeader(!'Accept',!'application/json')
	&httpclient.AddHeader(!'Content-type',!'application/json')
	&HttpClient.AddString(&SdtAtm.ToJson())
	&String = '/rest/Auth' 
	&HttpClient.Execute('POST',&String)
	
	padraoUsuario.Call('G', '#AVERBAATM', &Context.PesCod, &Context.EmpCod, &HttpClient.ToString(), &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
	
	If &HttpClient.ErrCode = 0 //sem erro de comunicação
		&Bearer.fromJson(&HttpClient.ToString())
		
		If not &Bearer.Bearer.IsEmpty()
			//####################################################### AVERVA CTE #######################
			&HttpClient.Host = 'webserver.averba.com.br' //servidor
			&HttpClient.timeout = 5
			&HttpClient.Secure = 0
			&HttpClient.AddHeader(!'Authorization','Bearer '+&Bearer.Bearer.ToString())
			&httpclient.AddHeader(!'Connection',!'Keep-Alive')
			&httpclient.AddHeader(!'Accept',!'application/xml')
			&httpclient.AddHeader(!'Content-type',!'application/xml')
			&HttpClient.AddString(&CteArqXml)
			&String = '/rest/CTE' 
			
			//			padraoUsuario.Call('G', '#AVERBAATMENVIO', &Context.PesCod, &Context.EmpCod, &String, &PadDtaMod)  // Grava resultado do Post só como um LOG para Consulta
			&HttpClient.Execute('POST',&String)
			
			padraoUsuario.Call('G', '#AVERBAATMCTE', &Context.PesCod, &Context.EmpCod, &HttpClient.ToString(), &PadDtaMod)
			&longvarchar = ''
			If &HttpClient.ErrCode = 0 //sem erro de comunicação
				&longvarchar = &HttpClient.ToString()
				&longvarchar = &longvarchar.Replace('SdtRetornoAverbacao xmlns="ERP"','Retorno')
				&longvarchar = &longvarchar.Replace('SdtRetornoAverbacao','Retorno')
				
				&SdtRetornoAverbacao.FromXml(&longvarchar.ToString())
				padraoUsuario.Call('G', '#AVERBAATMCTE2', &Context.PesCod, &Context.EmpCod, &SdtRetornoAverbacao.ToXml(), &PadDtaMod)
				If &SdtRetornoAverbacaoErros.Codigo.IsEmpty()  // If not &SdtRetornoAverbacao.Averbado.Protocolo.IsEmpty() and not &SdtRetornoAverbacaoSeguro.CNPJSeguradora.IsEmpty()
					GravaAverbacaoCte.Call(&EmpCod,&FilCod,&CteCod,&SdtRetornoAverbacao) 
					&IsSucesso = True
				Else
					msg(trim(&SdtRetornoAverbacaoErros.Codigo)+' - '+trim(&SdtRetornoAverbacaoErros.Descricao))
				EndIf
			Else
				msg('Autenticado mas com Erro na Averbação!')
			EndIf
		Else
			Msg('ATENÇÃO! "Bearer" está vazio contate o suporte!')
		EndIf
	Else
		msg('Erro na comunicação!')
	EndIf
Else
	msg('Arquivo XML do CT-e não encontado!')
EndIf

Sub 'PegaArquivoXML'
	For Each Order EmpCod,FilCod,CteCod
		Where EmpCod = &EmpCod
		where FilCod = &FilCod
		Where CteCod = &CteCod
		Do Case
			Case CteSts = Status_Nfe.Autorizada
				&CteArqXml = CteArqXml
			Case CteSts = Status_Nfe.Cancelada
				&CteArqXml = CteArqXmlCan
				
		EndCase			
		Exit
	Endfor
EndSub


]]></Source>
