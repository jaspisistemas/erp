      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&collPedItmCod.Clear()
For &sdtRELJAS124_A_ProdutosItem in &parsdtRELJAS124_A_Produtos
	&collPedItmCod.Add(&sdtRELJAS124_A_ProdutosItem.PeditmCod)	
EndFor

//	EndFor
For Each Order EmpCod, FilCod, PedCod, GrupImpCod
	Where EmpCod = &AuxEmpCod
	Where FilCod = &AuxFilCod
	Where PedCod = &auxPedCod
	Where PedItmCod in &collPedItmCod
	//Where PedItmSts.IsEmpty() or PedItmSts.IsNull()
	//Where GrupImpCod > 0
	
	//VERIFICA SE TEM NO SDT			
	if (not &GrupImpCod.IsEmpty() and &GrupImpCod <> GrupImpCod)
		do 'GravaImpressao'
	Endif
	
	&sdtRELJAS124_A_ProdutosItem = new()
	&sdtRELJAS124_A_ProdutosItem.PeditmCod = PedItmCod
	&sdtRELJAS124_A_Produtos.Add(&sdtRELJAS124_A_ProdutosItem)
	
	&AuxPedVenCod = PedItmVenCod
	&GrupImpCod = GrupImpCod
	
	PedItmSts = 'C' //COZINHA
EndFor

if &sdtRELJAS124_A_Produtos.Count > 0
	do 'GravaImpressao'
	commit
Endif


Sub 'GravaImpressao'	
	RetornaConfSistema_MESAS.Call(&AuxEmpCod, domCOnfSistemaMESAS.AppCon008, &OutValor)
	&iniCount = val(&OutValor)
	&Count = &iniCount
	if &iniCount > 1
		For &iniCount = 1 to &Count
			For &sdtRELJAS124_A_ProdutosItem in &sdtRELJAS124_A_Produtos
				&sdtRELJAS124_A_ProdutosItem.Mensagem = trim(str(&iniCount))
			Endfor
		
			prcGravaImpressao.Call(&AuxEmpCod, &GrupImpCod, 'RELJAS124_A', &AuxFilCod, &AuxPedCod, &AuxPedVenCod, &sdtRELJAS124_A_Produtos.ToJson(), 0, &FiDtaIni)
		EndFor
	ELse
		prcGravaImpressao.Call(&AuxEmpCod, &GrupImpCod, 'RELJAS124_A', &AuxFilCod, &AuxPedCod, &AuxPedVenCod, &sdtRELJAS124_A_Produtos.ToJson(), 0, &FiDtaIni)
	Endif
	
	&sdtRELJAS124_A_Produtos.Clear()
EndSub
]]></Source>
