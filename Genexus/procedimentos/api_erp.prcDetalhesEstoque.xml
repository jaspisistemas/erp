      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&LogGUID = guid.NewGuid()


//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

&MarDtaHorUltMod = now()

if &IsAcessoConcedido = true //Acesso concedido
	
	prcRetornaUlimaDataHoraSincronizacao.Call(&DevRandon, 'ESTOQUEOFF', &DevTabDtaUltSync, &DevTabAtu)
	
	&sdtProdutos.temMais = 'N'
//	&sdtProdutos.sts = 'J200'
	
	//ESTOQUE
	&Count = 0
	For each order EmpCod, FilCod, ProCod, ProGraCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &wwpContext.FilCod
		where ProCod > &inProCod //when &SDUltimaSync.IsEmpty()
		Where EstDtaHorUltMod >= &DevTabDtaUltSync or &DevTabDtaUltSync.IsEmpty() or EstDtaHorUltMod.IsEmpty() or EstDtaHorUltMod.IsNull()
		Where ProSts = Status_Produto.ATIVO
		
		if (&sdtProdutos.qtdItens = 200)
			&sdtProdutos.temMais = 'S'
			exit
		Endif
		
		&sdtProdutosProdutosEstoque = new()
		&sdtProdutosProdutosEstoque.GUID = ProGUID
		&sdtProdutosProdutosEstoque.Cod = ProCod
		&sdtProdutosProdutosEstoque.graCod = ProGraCod
		
		&sdtProdutosProdutosEstoque.EstQtd = 0
		if ProEstTip = tipoestoque.ATUALIZAR_ESTOQUE or ProEstTip.IsEmpty() or ProEstTip.IsNull()
			&sdtProdutosProdutosEstoque.EstQtd = EstQtd
		Endif
	
		if EstDtaHorUltMod.IsEmpty() or EstDtaHorUltMod.IsNull()
			EstDtaHorUltMod = &MarDtaHorUltMod
			Commit
		Endif
	
		&sdtProdutos.qtdItens += 1
		&sdtProdutos.UltProCod = ProCod
		&sdtProdutos.Item.Add(&sdtProdutosProdutosEstoque)
	EndFor
	
Endif


Sub 'subException_handler'
	
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'subException_handler','subException_handler')
	
EndSub

Sub 'subError_handler'
	
	GravaLogDevNew(&wwpContext.EmpCod,&LogGUID,&Pgmname,'subError_handler','subError_handler')
	
EndSub
]]></Source>
