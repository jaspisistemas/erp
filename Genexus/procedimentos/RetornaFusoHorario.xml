      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[

&FilFusHorBR.SetEmpty()

for Each order FilFusUfeCod, (FilFusIni)
	Where FilFusUfeCod = &UfeCod
	Where FilFusIni <= &BaseData
	
	&FilFusHorBR = FilFusHorBR
	
	Exit
When none
	&FilFusHorBR = '03:00'
EndFor
]]></Source>
