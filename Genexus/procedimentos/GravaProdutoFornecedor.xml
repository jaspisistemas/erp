      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Mensagem = ''

For Each Order EmpCod, ProCod, ProForCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	Where ProForCod = &ProForCod
	
	ProForProCod = &ProForProCod
	ProForProBar = &ProForProBar
	ProForVlrCus = &ProForVlrCus
	If &ProForQtdEmb.isEmpty()
		ProForQtdEmb = 1
	Else
		ProForQtdEmb = &ProForQtdEmb
	EndIF
	
	ProForAcr = &ProForAcr
	ProForDsc = &ProForDsc
	ProForIcmSt = &ProForIcmSt
	ProForIcm = &ProForIcm
	ProForIpi = &ProForIpi
	ProForRatAcr = &ProForRatAcr
	ProForRatDsc = &ProForRatDsc
	&Mensagem = 'Atualizado com sucesso! Produto: ' + trim(ProRef) + ' Fornecedor: ' + trim(str(ProForCod))
	Exit
when none
	For Each Order EmpCod, ProCod
		Where EmpCod = &EmpCod
		Where ProCod = &ProCod
		&ProRef = ProRef
		Exit
	EndFor

	new
		EmpCod = &EmpCod
		ProCod = &ProCod
		ProForCod = &ProForCod
		ProForProCod = &ProForProCod
		ProForProBar = &ProForProBar
		ProForVlrCus = &ProForVlrCus
		
		If &ProForQtdEmb.isEmpty()
			ProForQtdEmb = 1
		Else
			ProForQtdEmb = &ProForQtdEmb
		EndIF
		
		ProForAcr = &ProForAcr
		ProForDsc = &ProForDsc
		ProForRatAcr = &ProForRatAcr
		ProForRatDsc = &ProForRatDsc
		ProForIcmSt = &ProForIcmSt
		ProForIcm = &ProForIcm
		ProForIpi = &ProForIpi
		
	EndNew
	
	&Mensagem = 'Inserido com sucesso! Produto: ' + trim(&ProRef) + ' Fornecedor: ' + trim(str(&ProForCod))
EndFor

commit


For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	if ProPadForCod.IsEmpty()
		ProPadForCod = &ProForCod
	EndIf

	Exit
EndFor

Commit
	
]]></Source>
