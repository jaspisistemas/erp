      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
For Each Order EmpCod, ProCod
	Where EmpCod = &EmpCod
	Where ProCod = &ProCod
	
	//GRAVA LOG
	&TabelaVarchar = 'PRODUTO'
	&LogErpTabIsLog = prcGetIsGravarLog.Udp(&EmpCod, &TabelaVarchar)
	if &LogErpTabIsLog = true
		&LogErpRegCod1 = trim(Str(&ProCod))
		&LogErpRegTip = TrnMode.Update
		&LogErpRegGUID.SetEmpty()
		//&wwpContextUserName -- TENTE NAO USAR O LoadWwpContext, e Sim trazer informacao por parametro onde ja tem o Context em tela carregado.
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProBar', trim(ProBar), trim(&tmpProBar), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'NcmCod', trim(toformattedString(NcmCod)), trim(toformattedString(&tmpProNcmCod)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProNcmCest', trim(toformattedString(ProNcmCest)), trim(toformattedString(&erptmpNcmCEST)), &LogErpRegGUID )
		prcGravaLog_Registros.Call(&LogErpRegTip, &EmpCod, &FilCod, &LogErpRegCod1, '', '', &TabelaVarchar, &Pgmname, &wwpContextUserName, 'ProCatCod', trim(toformattedString(ProCatCod)), trim(toformattedString(&ProCatCod)), &LogErpRegGUID )		
	Endif

	ProBar = &tmpProBar
	NcmCod = &tmpProNcmCod
	ProNcmCest = val(trim(&erptmpNcmCEST))
	ProCatCod = &ProCatCod
	
	exit
EndFor


For Each Order tmpNFeCod 
	Where tmpNFeCod = &tmpNFeCod
	Where tmpNfeItmCod = &tmpNfeItmCod

	tmpProNcmCod =  &tmpProNcmCod 
	tmpProBar = &tmpProBar 
EndFor

Commit
]]></Source>
