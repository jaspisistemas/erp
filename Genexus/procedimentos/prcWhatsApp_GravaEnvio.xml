      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


If &IsPrimeiraVez = true //Alimenta contador
	For Each Order EmpCod, WaAnoMes
		Where EmpCod = &EmpCod
		Where WaAnoMes = &WaAnoMes
		WaAnoMesQtd += 1
		Exit
	EndFor
	Commit
Endif


//Grava Mensagem Enviada
&GUID = GUID.NewGuid()
&WaGUID = &GUID.ToString()
New
	EmpCod = &EmpCod
	WaAnoMes = &WaAnoMes
	WaGuid = &WaGUID
	WaDtaEms = serverdate()
	WaDtaHorEms = serverNow()
	WaFonDest = &WaFonDest
	WaMensagem = &WaMensagem
	WaPedCod = &PedCod
	WaFilCod = &FilCod
	WaNfeCod = &NfeCod
	WaCreCod = &CreCod
	WaUsuCod = &WaUsuCod
	WaSts = 'P'
	WaIsConPlano = &IsPrimeiraVez 
EndNEw

Commit



]]></Source>
