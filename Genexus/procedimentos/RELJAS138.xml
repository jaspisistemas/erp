      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//RELATÓRIO HISTÓRICO DE PRODUTOS DO CLIENTE

MB 4
MT 2
Do 'Filial'
Print Cabecalho
Print Titulos


For each order EmpCod,PedCliCod,LctTip,LctAtuEst,LctGerFin,FilCod,PedCod
	where EmpCod = &EmpCod
	where PedCliCod = &PedCliCod
	where ProGraRef = &ProGraRef When not &ProGraRef.IsEmpty()
	where ProGraRef = &ProNom or ProNomGra like &ProNom or PedItmCmp Like &ProNom or PedItmCmpInt like &ProNom When not &ProNom.IsEmpty()
	where PedDtaEms >= &IniPedDtaEms and PedDtaEms <= &FinPedDtaEms
	where LctTip = TipoLancamento.SaidaMercadoria
	where LctAtuEst = Status_EntradaSaida.Saida
	where LctGerFin = Status_SimNao.Sim
	where PedStsGer <> Pedido_Gerado.AgruparFaturar and PedStsGer <> Pedido_Gerado.DevolucaoCompra and PedStsGer <> Pedido_Gerado.Interno
	&PedCod = PedCod
	&PedDtaEms = PedDtaEms
	&ProGraRef = ProGraRef
	&printProNom = substr(ProNom,1,100)
	&PedQtd = PedQtd
	&PedQtdDev_FORMULA = round(PedQtdDev_FORMULA,2)
	&PedVlrUnt = round(PedVlrUnt,2)
	&PedVlrItm = PedVlrItm
	&PedItmCmp = PedItmCmp
	&PedItmCmpInt = PedItmCmpInt
	Print Item
	if not &PedItmCmp.IsEmpty()
		Print comp
	EndIf
	if not &PedItmCmpInt.IsEmpty()
		Print compInt
	EndIf
	Print Linha
EndFor


Sub 'Filial'
	
	For Each Order EmpCod, FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&FilFan    = FilFan.Trim().ToUpper()
//		&FilLogNro = FilLogNro.Trim()
//		&FilLogNro += ' '+FilBai.Trim() 
//		&FilCepCidUfe = FilCepCidUfe.Trim()
//		&FilDes = FilCpj.Trim() +'/'+ FilFonNum.Trim()
//		&FilCidNom = FilCidNom.Trim()
//		&FilCpj = FilCpj.Trim()
//		If FilImg_LogRel.IsEmpty()
//			&Image.FromImage('FilialSemImagem')  
//		Else
//			&Image = FilImg_LogRel
//		EndIF
//		&Operador = &FilFan
		Exit
	EndFor
	
EndSub
]]></Source>
