      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[// O conteúdo da tag Integrador deve ser uma CONSTANTE, pois é ela quem identifica seu sistema de gestão,
//Suporte e-FRETE:	Seguem credenciais para uso em ambiente de homologação:
//Integrador:		JASPI SISTEMAS DE INFORMÁTICA
//CNPJ:				21826923000177
//Usuário:			usuario@jaspi
//Senha:			usuario#jaspi
//Hash:				b754b48e-8c22-4cfc-bb0a-3524a76284c9

LoadWWPContext(&Context)
//Config do Servidor
HostWebServiceEfrete.Call(&EmpWebHost, &ExecuteUrl, '', '', &Hash)
&ExecuteUrl			+= 'motoristas/gravar'

&HttpClient.Host	= 	&EmpWebHost
&HttpClient.Secure	= 	1
	
//Header do JSON
&HttpClient.AddHeader(!'Content-Type', !'application/json')
&HttpClient.AddHeader(!'Accept-Encoding', !'gzip, deflate, br')

&IsCelular			= False
&IsTelefoneFixo		= False
&IsOk 				= True
&Mensagem 			= 'Os seguintes campos são obrigatórios e NÃO estão preenchidos: '
Do 'GetMotorista'

If &IsOk		
	
	//Corpo do Xml
	&XmlBody	=	'{'
	&XmlBody	+=	'          "CPF": "'			+	Trim(&XMLPesCPF) 	+'",'
	&XmlBody	+=	'          "Nome": "'			+	Trim(&XMLPesRaz)	+'",'
	&XmlBody	+=	'          "CNH": "'			+	Trim(&XMLPesCnh)	+'",'
	&XmlBody	+=	'          "DataNascimento": "'	+	Trim(&XMLPesDtaNas) +'",'
	If Not &XMLPesMaeNom.IsEmpty()
		&XmlBody+=	'          "NomeDeSolteiraDaMae": "'+Trim(&XMLPesMaeNom)+'",'
	EndIf
	&XmlBody	+=	'          "Endereco": {'
	&XmlBody	+=	'              "Bairro": "'	+ 	Trim(&XMLPesBai) 	+'",'
	&XmlBody	+=	'              "Rua": "'	+	Trim(&XMLPesLog)	+'",'
	&XmlBody	+=	'              "Numero": "'	+	Trim(&XMLPesNro)	+'",'
	If Not &XMLPesCpl.IsEmpty()
		&XmlBody+=	'              "Complemento": "'+	Trim(&XMLPesCpl)+'",'
	EndIf
	&XmlBody	+=	'              "CEP": "'			+ 	Trim(&XMLPesCep)			+'",'
	&XmlBody	+=	'              "CodigoMunicipio": "'+ 	Trim(Str(&XMLPesCidIbge))	+'"'
	&XmlBody	+=	'          },'
	&XmlBody	+=	'          "Telefones":'
	&XmlBody	+=	'          {'
	&XmlBody	+=	'              "Celular": {'
	&XmlBody	+=	'                   "DDD": "'	+	Trim(Str(&XMLPesDD))+'",'
	&XmlBody	+=	'                   "Numero": "'+ 	Trim(&XMLPesFonNum)	+'"'
	If &IsTelefoneFixo = True
		&XmlBody+=	'               },'
	Else
		&XmlBody+=	'               }'
	EndIf
	If &IsTelefoneFixo = True
		&XmlBody+=	'               "Fixo": {'
		&XmlBody+=	'                   "DDD": "'	+	Trim(Str(&XMLFixoPesDD))+'",'
		&XmlBody+=	'                   "Numero": "'+ 	Trim(&XMLFixoPesFonNum)	+'"'
		&XmlBody+=	'               }'
	EndIf
	&XmlBody	+=	'          },'
	If Not &Token.IsEmpty()
		&XmlBody	+=	'          "Token": "'+Trim(&Token)+'",'
	EndIf
	&XmlBody	+=	'          "Integrador": "'+ &Hash.Trim() +'",'
	&XmlBody	+=	'          "Versao": 2'
	&XmlBody	+=	'}'				
	
	//Realiza o Envio ao WebService	
	&HttpClient.AddString(Trim(&XmlBody))
	&HttpClient.Execute('POST',&ExecuteUrl)
	
	padraoUsuario.Call('G', '#EFRETEMOTORISTA', &Context.PesCod, &Context.EmpCod, &XmlBody, &PadDtaMod)
	
	If &HttpClient.StatusCode = 200
		&XmlBody 		= &HttpClient.ToString()
		&PosicaoSucesso = StrSearch(&XmlBody, '"Sucesso"')
		&PosicaoSucesso = &PosicaoSucesso + 11
		
		&Status = SubStr(&XmlBody, &PosicaoSucesso, 4)
		
		If &Status = 'true'
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Successo!", 'Motorista gravado/alterado com sucesso!', DVMessageType.success, "", DVMessageBoolean.True,""))
			Do 'AtualizaMotorista'
			&StatusRet = 200
		Else	
			&PosicaoSucesso = StrSearch(&XmlBody, '"Mensagem"')
			&PosicaoSucesso = &PosicaoSucesso + 13
			
			&PosicaoFinal	= StrSearch(&XmlBody, '"Codigo"')
			&PosicaoFinal	= &PosicaoFinal - &PosicaoSucesso - 8
			&Status			= SubStr(&XmlBody, &PosicaoSucesso, &PosicaoFinal)
			&StatusRet 		= 0
			Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Motorista!", 'Ocorreu um erro ao salvar o motorista. ERRO: '+ Trim(&Status), DVMessageType.error, "", DVMessageBoolean.True,""))
		EndIf
		padraoUsuario.Call('G', '#EFRETEMOTORISTARESPOSTA', &Context.PesCod, &Context.EmpCod, &XmlBody, &PadDtaMod)
	Else
		Msg(DVMessageGetBasicNotificationMsg.Udp(!"Erro Motorista!", &HttpClient.StatusCode.ToString() + ":" + &HttpClient.ErrDescription, DVMessageType.error, "", DVMessageBoolean.True,""))
	EndIf
Else
	Msg(DVMessageGetBasicNotificationMsg.Udp(!"Atenção!", Trim(&Mensagem), DVMessageType.regular, "", DVMessageBoolean.True,""))	
EndIf

Sub 'GetMotorista'
	
	For Each Order EmpCod, PesCod
		Where EmpCod	= &Context.EmpCod
		Where PesCod	= &parmPesCod
		
		//Motorista
		If PesCpf.IsEmpty() Or PesCpf.IsNull()
			&Mensagem 	+= 'CPF do Motorista; '
			&IsOk		= False
		Else
			&XMLPesCPF		= RetornaSoNumeros.Udp(PesCpf)
		EndIf
		
		If PesRaz.IsEmpty() Or PesRaz.IsNull()
			&Mensagem 	+= 'Nome do Motorista; '
			&IsOk 		= False
		Else
			&XMLPesRaz		= PesRaz
		EndIf
	
		If PesCnh.IsEmpty() Or PesCnh.IsNull()
			&Mensagem 	+= 'CNH do Motorista; '
			&IsOk 		= False
		Else
			&XMLPesCnh		= PesCnh
		EndIf
		
		If PesDtaNas.IsEmpty() Or PesDtaNas.IsNull()
			&Mensagem 	+= 'Dta. Nasc. do Motorista; '
			&IsOk 		= False
		Else
			&AnoNascimento	= SubStr(ToFormattedString(PesDtaNas), 7, 4)
			&MesNascimento 	= SubStr(ToFormattedString(PesDtaNas), 4, 2)
			&DiaNascimento	= SubStr(ToFormattedString(PesDtaNas), 1, 2)
			&XMLPesDtaNas	= &AnoNascimento+'-'+&MesNascimento+'-'+&DiaNascimento
		EndIf
	
		&XMLPesMaeNom	= PesMaeNom
		
		//Endereço
		If PesBai.IsEmpty() Or PesBai.IsNull()
			&Mensagem 	+= 'Bairro de residência do Motorista; '
			&IsOk 		= False
		Else
			&XMLPesBai		= PesBai 
		EndIf
		
		If PesLog.IsEmpty() Or PesLog.IsNull()
			&Mensagem 	+= 'Rua de residência do Motorista; '
			&IsOk 		= False
		Else
			&XMLPesLog		= PesLog 
		EndIf
		
		If PesNro.IsEmpty() Or PesNro.IsNull()
			&Mensagem 	+= 'Nro. da residência do Motorista; '
			&IsOk 		= False
		Else
			&XMLPesNro		= PesNro 
		EndIf
		
		&XMLPesCpl		= PesCpl
		
		If PesCep.IsEmpty() Or PesCep.IsNull()
			&Mensagem 	+= 'CEP de residência do Motorista; '
			&IsOk 		= False
		Else
			&XMLPesCep		= PesCep 
		EndIf
	
		If PesCidIBGE.IsEmpty() Or PesCidIBGE.IsNull()
			&Mensagem 	+= 'Código do Municipio de residência; '
			&IsOk 		= False
		Else
			&XMLPesCidIbge	= PesCidIBGE 
		EndIF
		
		For Each Order EmpCod, PesCod, PesFonCod
			Do Case
				Case PesFonTpo = TipoTelefone.CELULAR or PesFonTpo = TipoTelefone.CELULAR_WHATS
					
					If PesFonNum.IsEmpty()	Or PesFonNum.IsNull()
						&Mensagem 	+= 'Informações de número para contato;'
						&IsOk 		= False
					Else
						&XMLPesDD			= Val(SubStr(RetornaSoNumeros.Udp(PesFonNum), 1, 2))
						&XMLPesFonNum		= SubStr(RetornaSoNumeros.Udp(PesFonNum), 3, 20)
					EndIf
					
				Case PesFonTpo = TipoTelefone.COMERCIAL or PesFonTpo = TipoTelefone.RESIDENCIAL or PesFonTpo = TipoTelefone.OUTROS
					If PesFonNum.IsEmpty() Or PesFonNum.IsNull()
						&Mensagem 	+= 'Informações de número para contato;'
						&IsOk 		= False
					Else
						&IsTelefoneFixo		= True
						&XMLFixoPesDD		= Val(SubStr(RetornaSoNumeros.Udp(PesFonNum), 1, 2))
						&XMLFixoPesFonNum	= SubStr(RetornaSoNumeros.Udp(PesFonNum), 3, 20)
					EndIf
					
			EndCase
		EndFor
		
		Exit
	EndFor
	
EndSub

Sub 'AtualizaMotorista'
	
	For Each Order EmpCod, PesCod
		Where EmpCod = &Context.EmpCod
		Where PesCod = &parmPesCod
		
		PesStsEfr = Status_EFrete.Homologado
		Commit
		
		Exit
	EndFor
	
EndSub
