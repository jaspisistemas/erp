        <Source><![CDATA[&TotalCrediario = 0 
For Each Order EmpCod, FilCod, CrePedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where CrePedCod = &PedCod
	Where CreSts <> Status_Duplicata.CANCELADA
	
	&TotalCrediario += CreVlrDup
EndFor
]]></Source>
