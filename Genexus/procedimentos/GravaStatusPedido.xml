      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&HisItmCod = 0

For Each Order EmpCod, FilCod, PedCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	If PedStsCod <> &PedStsCod and &PedStsCod > 0
		PedStsCod = &PedStsCod
		&Ispedido = true
	EndIF
	
	if PedStsFinCod <> &PedStsFinCod and &PedStsFinCod > 0
		PedStsFinCod = &PedStsFinCod
		&IsFinanceiro = true
	EndIF
	
	Exit
EndFor

Commit

PedNovStsCod_FORMULA.Call(&EmpCod, &FilCod, &PedCod)

For Each Order EmpCod, FilCod, PedCod, (HisItmCod)
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	&HisItmCod = HisItmCod
	Exit
EndFor

if &IsFinanceiro = true or not &HisStsObs.IsEmpty()
	&HisItmCod += 1
	if &IsFinanceiro = true
		&Mensagem = 'Financeiro'
	Else
		&Mensagem = 'Observação'
	Endif

	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		HisItmCod = &HisItmCod
		HisStsCod = &PedStsCod
		HisStsObs = format('%1 Usuario %2: %3', &Mensagem, trim(str(&ContextPesCod)), &HisStsObs)
	EndNew

	Commit
EndIF

if &Ispedido = true 
	&HisItmCod += 1
	New
		EmpCod = &EmpCod
		FilCod = &FilCod
		PedCod = &PedCod
		HisItmCod = &HisItmCod
		HisStsCod = &PedStsCod
		HisStsObs = format('Estoque usuario %1: %2', trim(str(&ContextPesCod)), &HisStsObs)
	EndNew

	Commit
EndIF
]]></Source>
