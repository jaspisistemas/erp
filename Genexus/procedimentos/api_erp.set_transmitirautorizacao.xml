      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true //Acesso concedido
	
//&PadObs = format('nfe:%1,fil:%2', trim(toformattedString(&NfeCod)), trim(toformattedString(&FilCod)))
//padraousuario.Call('G', 'set_cliente', 1, 1, &PadObs, &PadDtaMod)
//padraousuario.Call('G', 'set_cliente1', 1, 1, &sdtItemNfeLongVarchar, &PadDtaMod)
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		&ModCod = ModCod
		GravaTotaisNF.Call(EmpCod, FilCod, NfeCod, NfeVlrTotDsc, NfeVlrTotPdg, NfeVlrTotOutDsp, NfeVlrTotSeg, NfeVlrTotFrt)
		Exit
	EndFor
	
	//GRAVA XML AUTORIZACAO
	ValidaSchemaNFe.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, &wwpContext.FilCod, &Mensagem)			
	if &Mensagem.IsEmpty()
		
		&GUID = GUID.NewGuid()
		&ProgressId = format('RecepNFCe%1', &GUID.ToString())
	
		if ModCod = '65'
			GeraXmlNFeModelo65_4.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, 'S', &wwpContext.PesCod, 'E', &SolCod)
		Else
			GeraXmlNFeModelo55_4.Call(&wwpContext.EmpCod, &FilCod, &NfeCod, 'S', &wwpContext.PesCod, 'E', &SolCod)		
		EndIf
	
		RecepcaoNFe.Submit(&ProgressId, &ProgressId, &wwpContext.EmpCod, &FilCod, &NfeCod, &SolCod)
		
		&sdtCapaNfe.ProgressId = &ProgressId
		&sdtCapaNfe.SolCod = &SolCod
		&sdtCapaNfe.sts = 'J200'
		&sdtCapaNfe.obs = 'sucesso'
	Else
		//&sdtCapaNfe.ProgressId = &ProgressId
		//&sdtCapaNfe.SolCod = &SolCod
		&sdtCapaNfe.sts = 'E999'
		&sdtCapaNfe.obs = &Mensagem
	EndIF
Endif

]]></Source>
