      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[If &OqueFazer <> 'DEL'
	For each Order EmpCod,AloCod
		Where EmpCod = &EmpCod
		Where AloCod = &AloCod
		&AloLotCod = AloLotCod
		&AloQtdUni = AloQtdUni
		&AloQtdDes = AloQtdDes 
		&AloQtdMorLiq = AloQtdMorLiq
		&UniProCod = AloUniProCod
		
		AloUniProBioMasIni = AloUniProBioMasIni_Formula
		AloQtdDes = AloQtdDes_Formula
		AloQtdMor = AloQtdMor_Formula
		AloQtdPer = AloQtdPer_Formula
		AloQtdRou = AloQtdRou_Formula
		AloQtdRec = AloQtdRec_Formula
		AloQtdRac = AloQtdRac_Formula
		AloQtdMorLiq = AloQtdMorLiq_Formula
		AloPsoMed = AloPsoMed_Formula
		AloPsoGan = AloPsoGan_Formula
		AloUniProBioMas = AloUniProBioMas_Formula
		AloCAe = AloCAe_formula
		
		Do case
			Case AloQtdDes_Formula = 0              //Quantidade despescada = 0 então alojamento em produção
				AloSts = Status_Alojamento.Emproducao	
			Case AloQtdDes_Formula >= AloQtdMorLiq_Formula  // Quantidade Despescada >= a quantidade de peixe vivo no tanque então alojamento encerrado
				AloSts =  Status_Alojamento.Encerrado
				Do 'EncerraLote'
				
			Otherwise
				AloSts = Status_Alojamento.DespescaParcial 
		EndCase
	
		Do 'AtualizaUnidade'
		Do 'AtualizaLotes'
		Exit
	When none
		&UniProCod = &ParUniProCod
		Do 'AtualizaUnidade'
	EndFor
Else
	&UniProCod = &ParUniProCod
	Do 'AtualizaUnidadeDelete'
EndIf

Sub 'AtualizaUnidadeDelete' //atualiza o status da Unidade Produtora
	For each Order EmpCod,UniProCod
		Where EmpCod = &EmpCod
		Where UniProCod = &UniProCod
			UniProSts = StatusUnidadeProdutora.Disponivel
		Exit
	EndFor
EndSub

Sub 'AtualizaUnidade' //atualiza o status da Unidade Produtora
	For each Order EmpCod,UniProCod
		Where EmpCod = &EmpCod
		Where UniProCod = &UniProCod
		Do Case
			Case &AloQtdDes >= &AloQtdMorLiq  
				UniProSts = StatusUnidadeProdutora.Disponivel
			Case &AloQtdUni > 0
				UniProSts = StatusUnidadeProdutora.EmProducao
		EndCase
		Exit
	EndFor
EndSub


Sub 'AtualizaLotes'
	For each Order EmpCod,LotCod
		Where EmpCod = &EmpCod
		Where LotCod = &AloLotCod
		
		Do case 
			Case LotQtdDsp = LotQtdIni
				LotSts = Status_Lote.AguardandoAlojamento
			Case LotQtdAlo < LotQtdIni
				LotSts = Status_Lote.AlojadoParcial
			Case LotQtdDsp <= 0
				LotSts = Status_Lote.Alojado
		EndCase	
		Exit
	EndFor
EndSub

Sub 'EncerraLote'
	For each Order EmpCod,AloLotCod // Procura Todos os alojamento aberto que contenham o lote
		Where EmpCod = &EmpCod
		Where AloLotCod = &AloLotCod
		Where AloSts = Status_Alojamento.Emproducao
		
	When none  // se não achar nenhum encerra o Lote
		For each Order EmpCod,LotCod
			Where EmpCod = &EmpCod
			Where LotCod = &AloLotCod
			LotSts = Status_Lote.Vendido
		EndFor
	EndFor
EndSub
]]></Source>
