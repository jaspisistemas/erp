      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&GrupPaiCod.SetEmpty()
&GrupPaiHie.SetEmpty()

&Caractere = &GrupHie //Retorna Numero e pontos Ex: 10.1.2
do 'soNumeros'

&indexFinal = 1
&IsContinua = true
&IsPrimeiraCategoria = true

do while &IsContinua = true //Separa os Nó
	&indexFinal = &Numeros.IndexOf('.', &indexFinal)	
	&indexFinal -= 1
	&Codigo = Substr(&Numeros, 1, &indexFinal)
	
	&indexFinal += 2	
	&QtdLevel += 1
	
	if &indexFinal.IsEmpty()
		//msg('Vazio')
		&IsContinua = false
	Else
		If &Codigo.IsEmpty()
			&IsContinua = false
		Else
			//			&AuxIndexInicial = &indexFinal
			//			&AuxIndexFinal = &Numeros.Length()
			//			
			//			&IsPrimeiraCategoria = false
			
			do 'getPai'			
			If &IsErroHierarquia = true
				&IsContinua = false
				return
			EndIf
		EndIF
	EndiF

	if &GrupHie = &Codigo
		&IsContinua = false
	EndIf
EndDo

if &QtdLevel > 5
	&IsErroHierarquia = true
	&NomePaizao = 'No máximo Permitido 5 Hierarquias.'
	Return
ENdiF

//if (&IsPrimeiraCategoria = true and &Numeros.Length() > 5)
//	&IsErroHierarquia = true
//	&NomePaizao = 'Tamanho máximo de 5 Digitos, informado: ' + trim(&Numeros)
//	Return
//Else
//	&AuxNumeros = Substr(&Numeros, &AuxIndexInicial, &AuxIndexFinal)
//	if &AuxNumeros.Length() > 5
//		&IsErroHierarquia = true
//		&NomePaizao = 'Tamanho máximo de 5 Digitos, informado: ' + trim(&AuxNumeros)
//		Return
//	EndIF
//EndiF

&NewGrupHie = &Numeros

For Each Order EmpCod, GrupHie //Verifica se ja tem codigo cadastrado
	Where EmpCod = &EmpCod
	Where GrupHie = &NewGrupHie
	Where GrupCod <> &GrupCod
	&NomePaizao = 'Já Existe Categoria Cadastrada com o nome de ' + trim(GrupNom)
	&IsErroHierarquia = true
	
	Return
	Exit
EndFor


Sub 'getPai' //Verifica Existe Pai
	
	&paiGrupHie = &Codigo.Trim()
	
	if &GrupHie <> &paiGrupHie
		For Each Order EmpCod, GrupHie
			Where EmpCod = &EmpCod
			Where GrupHie = &paiGrupHie
			
			If not &NomePaizao.IsEmpty()
				&NomePaizao += ' | '
			EndIF
			
			&NomePaizao = trim(&NomePaizao) + ' ' + trim(GrupNom)
			
			If GrupAnaSin = 'A' //GRUPO ANALITICO
				&NomePaizao = 'Hierarquia não Disponível. Pai Hierárquico ' + trim(GrupNom) + ' é preciso ser Tipo:Sintético'
				&IsErroHierarquia = true
			EndIf
			
			&GrupPaiCod = GrupCod
			&GrupPaiHie = GrupHie
			
			Exit
		When none
			if &PlanHie <> &paiPlanHie
				&NomePaizao = 'Hierarquia não Disponível. Primeiramente Cadastre o Pai Hierárquico ' + trim(&paiGrupHie)
				&IsErroHierarquia = true
			Endif
		EndFor
	Endif
EndSub


Sub 'soNumeros'
	&Pos = 1
	&Numeros = ''
	
	Do While &Pos <= 100
	    
		if (substr(&Caractere,&Pos,1) >= '0' and substr(&Caractere,&Pos,1) <= '9') or (substr(&Caractere,&Pos,1) = '.' and not &Numeros.IsEmpty())
			
			If substr(&Caractere,&Pos,1) = '.'
				&temDepois = Substr(&Caractere, &Pos, 100)
				&temDepois = RetornaSoNumeros.Udp(&temDepois)
				
				if &temDepois <> ''
					&Numeros += substr(TRIM(&Caractere),&Pos,1)
				EndIF
			
			else
		        &Numeros += substr(TRIM(&Caractere),&Pos,1)
			EndIF
	
	    Endif
	
	    &Pos += 1
	EndDo
EndSub


]]></Source>
