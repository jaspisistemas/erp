      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&InssTax = 0
&InssPesVlrSalCat = 0

If &PesIsSocPro = False
	For each Order EmpCod,InssVlrIni,InssVlrFin
		Where EmpCod = &EmpCod
		Where InssVlrIni <= &PesVlrSalCat and  InssVlrFin >= &PesVlrSalCat 
		&InssTax = InssTax
		Exit
	EndFor
Else
	For each Order EmpCod FilCod
		Where EmpCod = &EmpCod
		Where FilCod = &FilCod
		&InssTax = FilPerInss
		Exit
	EndFor
EndIf

If &InssTax > 0 
	&InssPesVlrSalCat = (&PesVlrSalCat * &InssTax) / 100
EndIf

]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
