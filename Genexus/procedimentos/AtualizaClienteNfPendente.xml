      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	//Where FiLCod = &FilCod
	Where NfeSts = Status_NFe.Digitando
	Where NfeProTer = Nota_ProPriaTerceira.PROPRIA
	Where NfeCliCod = &NfeCliCod
	
		retornaProPriedadeGlebaPedido .call(EmpCod, NfeFilCod, NfePedCod, NfeCliCod, &NfeCliSuf,&NfeCliEnd,&NfeCliEndNro,&NfeCliBai,&NfeCliCidNom,&NfeCliCidCod,&NfeCliCidIbge,&NfeCliCidUF,&NfeCliCep,&NfeCliCpl, &NfeCliIns, &NfeCliCpf, &NfeCliCnpj, &NfeCliTipPes)
	
	
		NfeCliCpf = &NfeCliCpf
		NfeCliCnpj = &NfeCliCnpj
		NfeCliTipPes = &NfeCliTipPes
		
		NfeCliIns = &NfeCliIns
		NfeCliSuf = &NfeCliSuf
		
		NfeCliEnd = &NfeCliEnd
		NfeCliEndNro = &NfeCliEndNro
		NfeCliBai = &NfeCliBai
		NfeCliCidNom = &NfeCliCidNom
		NfeCliCidCod = &NfeCliCidCod
		NfeCliCidIbge = &NfeCliCidIbge
		NfeCliCidUF = &NfeCliCidUF
		NfeCliCep = &NfeCliCep
		
		NfeCliCpl = &NfeCliCpl

EndFor

commit	



For Each Order EmpCod, NfsCod
	Where EmpCod = &EmpCod
	//Where FiLCod = &FilCod
	Where NfsSts = Status_NFe.Digitando
	Where NfsProTer = Nota_ProPriaTerceira.PROPRIA
	Where NfsCliCod = &NfeCliCod
	
		retornaProPriedadeGlebaPedido .call(EmpCod, NfsFilCod, NfsPedCod, NfsCliCod, &NfeCliSuf,&NfeCliEnd,&NfeCliEndNro,&NfeCliBai,&NfeCliCidNom,&NfeCliCidCod,&NfeCliCidIbge,&NfeCliCidUF,&NfeCliCep,&NfeCliCpl, &NfeCliIns, &NfeCliCpf, &NfeCliCnpj, &NfeCliTipPes)
	
	
		NfsCliCPF = &NfeCliCpf
		NfsCliCnpj = &NfeCliCnpj
		NfsCliTipPes = &NfeCliTipPes
		
		//NfsCliIns = &NfeCliIns
		//NfsCliSuf = &NfeCliSuf
		
		NfsCliLog = &NfeCliEnd
		NfsCliNro = &NfeCliEndNro
		NfsCliBai = &NfeCliBai
		NfsCliCidNom = &NfeCliCidNom
		NfsCliCidCod = &NfeCliCidCod
		NfsCliCidIbge = &NfeCliCidIbge
		NfsCliCidUfCod = &NfeCliCidUF
		NfsCliCep = &NfeCliCep
		
		NfsCliCpl = &NfeCliCpl

EndFor

commit	
]]></Source>
