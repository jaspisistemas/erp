      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
RetornaVersaoNotas.Call(VersaoNota.VersaoMDFe, &Versao)

RetornaConfiguracoesPastas.Call(&EmpCod, &FilCod, &sdtConfiguracoesPasta)

For Each Order EmpCod, FilCod, MDFeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where MDFeCod = &MDfeCod
	&MdfeChv = MDFeChv
	Exit
EndFor


commit

&Nome_enviar = &sdtConfiguracoesPasta.PastaNFenvio.Trim() +'MDFe'+ trim(&MdfeChv) + '-ped-sit.xml'

// Abrir o arquivo XML
&ArqNota.Open(&Nome_enviar)
&ArqNota.WriteStartDocument('UTF-8')
&ArqNota.Indentation = 0

&ArqNota.WriteStartElement('consSitMDFe')
&ArqNota.WriteAttribute('versao',&Versao)
&ArqNota.WriteAttribute('xmlns','http://www.portalfiscal.inf.br/mdfe')

&ArqNota.WriteElement('tpAmb',&sdtConfiguracoesPasta.FilAmbEms)
&ArqNota.WriteElement('xServ','CONSULTAR')
&ArqNota.WriteElement('chMDFe', &MDFeChv)
&ArqNota.WriteEndElement()
&ArqNota.Close()


GravaSolicitacao.Call(&EmpCod, &FilCod, &MDfeCod, 0, TipoSolicitacao.Consultar_MDFe, &PesCod, &SolCod)


]]></Source>
