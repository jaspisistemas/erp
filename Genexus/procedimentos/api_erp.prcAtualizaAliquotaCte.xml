      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For EAch Order EmpCod, FilCod, CteCod
	Where EmpCod = &EmpCod
	Where FilCod = &FiLCod
	Where CteCod = &CteCod
	
	CteImpAli.FromString(&sdtCte.CteImpAliVar)
	CteImpAliRet.FromString(&sdtCte.CteImpAliRetVar)
	CteImpPerRed.FromString(&sdtCte.CteImpPerRedVar)
	CteImpTriAliInss.FromString(&sdtCte.cteImpTriAliInssVar)
	
	CteImpVbcRet.FromString(&sdtCte.CteImpVbcRetVar)
	CteImpVstRet.FromString(&sdtCte.CteImpVstRetVar)
	
	CteImpCst =  &sdtCte.CteImpCst
	Exit
Endfor


Commit


GravaValorImpostoApi.Call(&EmpCod, &FilCod, &CteCod)
]]></Source>
