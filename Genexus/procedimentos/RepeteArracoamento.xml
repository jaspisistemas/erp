      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&ArrDta = &ArrDta.AddDays(1)//adiciona um da trazação que ja gravou.

Do while &ArrDta <= &ToArrDta
	UltimoCodigoEmpresa.Call(domParCod.ARRACOAMENTO,&EmpCod,0,&AUXArrCod)
	NEW
		EmpCod = &EmpCod
		ArrCod = &AUXArrCod
		ArrDta = &ArrDta
		ArrFilCod = &ArrFilCod
		ArrHor = &ArrHor 
		ArrDtaHor = YMDHMStoT(year(&ArrDta),month(&ArrDta),day(&ArrDta),Hour(&ArrHor),Minute(&ArrHor),0)
		ArrProCod = &ArrProCod
		ArrQtdRac = &ArrQtdRac
		ArrPedCod = &ArrPedCod
		ArrTmp = &ArrTmp
		ArrOxi = &ArrOxi
		ArrObs = &ArrObs
		ArrAloCod = &ArrAloCod
	EndNew
	COMMIT
	
	If &ArrQtdRac > 0
		GravarPedidoArracoamento.call(&EmpCod,&ArrFilCod,&AUXArrCod,&ArrDta,&ArrHor,&ArrProCod,&ArrQtdRac)
	EndIf

	&ArrDta = &ArrDta.AddDays(1)
	
EndDo
]]></Source>
        <Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties>
