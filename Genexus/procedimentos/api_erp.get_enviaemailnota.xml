      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
//verifica id da sessao.
verificaidsessao.Call(&DevRandon, &IsAcessoConcedido, &IsAtualizaTudo, &wwpContext)

if &IsAcessoConcedido = true
	
	For Each Order EmpCod, FilCod, NfeCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &FilCod
		Where NfeCod = &NfeCod
		
		&NfeNum = NfeNum
		
		&nfeFilCod = NfeFilCod
		&Nfepedcod = NfePedCod
		do 'GetPedido'
		if &PedVeiPla.Length() = 8
			&sdtEmail.Ass = format('Nota Fiscal %1 da %2, Placa: %3', trim(toformattedString(&NfeNum)), trim(FilFan), &PedVeiPla)
		Else
			&sdtEmail.Ass = 'Nota Fiscal ' + trim(toformattedString(&NfeNum)) + ' da ' + trim(FilFan)
		Endif
	
		RetornaEmailFaturamento.call(EmpCod, NfeCliCod, &listaSdtEmail)
		
		
		//####################### Adiciona e-mai da transportadora informado na emissão da nota
		
		If not NfeTraEml.Trim().IsEmpty() and not NfeTraEml.IsNull()
			&itemSdtEmail = new()
			&itemSdtEmail.EmlUrl = NfeTraEml
			&listaSdtEmail.Add(&itemSdtEmail)
		EndIF
		//+ os e-mails do cadastro
		If NfeTraCod <> 0
			RetornaEmailFaturamento.call(EmpCod, NfeTraCod, &listaSdtEmail)
		EndIf
	
		//###############################################################
		Exit
	EndFor
	
	For &ItemSdtEmail in &listaSdtEmail
		Do Case
			Case &sdtEmail.Eml1.IsEmpty()
				&sdtEmail.Eml1 = &ItemSdtEmail.EmlUrl.ToLower()
				
			Case &sdtEmail.Eml2.IsEmpty()
				&sdtEmail.Eml2 = &ItemSdtEmail.EmlUrl.ToLower()
				
			Case &sdtEmail.Eml3.IsEmpty()
				&sdtEmail.Eml3 = &ItemSdtEmail.EmlUrl.ToLower()
				
			Case &sdtEmail.Eml4.IsEmpty()
				&sdtEmail.Eml4 = &ItemSdtEmail.EmlUrl.ToLower()
				
			Case &sdtEmail.Eml5.IsEmpty()
				&sdtEmail.Eml5 = &ItemSdtEmail.EmlUrl.ToLower()
				
			Case &sdtEmail.Eml6.IsEmpty()
				&sdtEmail.Eml6 = &ItemSdtEmail.EmlUrl.ToLower()
				
			Otherwise
				Exit
		EndCAse
	EndFor
		
Endif


Sub 'GetPedido'

	For Each Order EmpCod, FilCod, PedCod
		Where EmpCod = &wwpContext.EmpCod
		Where FilCod = &nfeFilCod
		Where PedCod = &Nfepedcod
		
		&PedVeiPla = FormataPLACA.Udp(EmpCod, PedVeiPla)
		
		Exit
	EndFor

EndSub

]]></Source>
