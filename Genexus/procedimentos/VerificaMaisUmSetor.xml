      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&ProSetCod = 0
&Qtd = 0
For Each Order EmpCod, FilCod, PedCod, ProSetCod
	Where EmpCod = &EmPCod
	Where FilCod = &FilCod
	Where PedCod = &PedCod
	
	If &ProSetCod <> ProSetCod
		&Qtd += 1
	EndIF
	
	&ProSetCod = ProSetCod
	if &Qtd > 1
		Exit
	EndIf
EndFor

]]></Source>
