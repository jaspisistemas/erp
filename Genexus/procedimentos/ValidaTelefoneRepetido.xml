      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&Mensagem.SetEmpty()

&PesFonNum = &parPesFonNum

if &PesFonNum.Length() > 5
	FormataFONE.Call(&PesFonNum, &PesFonNum)
	
	For Each Order EmpCod, PesCod, PesFonCod
		Where EmpCod = &EmpCod
		Where PesCod <> &PesCod
		Where PesSts = Status_ativoInativo.ATIVO
		Where PesFonNum = &PesFonNum
		
		&Mensagem  = 'FONE: ' + &PesFonNum.Trim() + ', REPETIDO NO CLIENTE:' + trim(str(PesCod)) + '-'+ PesRaz
		Exit	
	EndFor
Endif

if &PesEml.Length() > 5
	For Each Order EmpCod, PesCod, PesEmlCod
		Where EmpCod = &EmpCod
		Where PesCod <> &PesCod
		Where PesSts = Status_ativoInativo.ATIVO
		Where PesEml like &PesEml
		
		&Mensagem  = 'EMAIL: ' + &PesEml.Trim() + ', REPETIDO NO CLIENTE:' + trim(str(PesCod)) + '-'+ PesRaz
		Exit	
	EndFor
Endif

]]></Source>
