      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[&Preenchido	= 0
&IsErro	= False
&Mensagem	= ''

For Each Order EmpCod, FilCod, CreCod
	Where EmpCod	= &EmpCod
	Where FilCod    = &FilCod
	Where CreCod	= &CreCod	
	Where CreRecPag	= ReceberPagar.Receber
	Where CreDtaVct>= ServerDate()
	
	&CreCbrCod	= CreCbrCod
	Do 'GetLocalCobranca'
	
	If &ErroCobranca = 0
		&CreCliRaz	= RetiraCaracteresEspeciais.Udp(CreCliRaz)
		&CreCliCobLog	= RetiraCaracteresEspeciais.Udp(CreCliCobLog)
		&CreCliCobCidNom	= RetiraCaracteresEspeciais.Udp(CreCliCobCidNom)		
		
		&dia	= day(CreDtaVct)
		&mes	= month(CreDtaVct)
		&Ano	= year(CreDtaVct)
		&DataVctVarchar	= padL(str(&ano),4,'0') + '-' + padL(str(&mes),2,'0') + '-' + padL(str(&dia),2,'0')
		
		&dia	= day(CreDtaEms)
		&mes	= month(CreDtaEms)
		&Ano	= year(CreDtaEms)
		&DataEmsVarChar	= padL(str(&ano),4,'0') + '-' + padL(str(&mes),2,'0') + '-' + padL(str(&dia),2,'0')
		
		&Boleto	= New()
		&Boleto.idEspecie	= 2 //2 = DM: Dup de venda mercantil
		
		//PAGADOR
		&Boleto.tipoPagador	= IIf(CreCliTip = 'F', 0, 1)
		&Boleto.docPagador.FromString(IIf(CreCliTip = 'F', PadL(RetornaSoNumeros.Udp(CreCliCpf), 11, '0'), RetornaSoNumeros.Udp(CreCliCnpj)))
		&Boleto.pagadorNome	= Substr(Trim(&CreCliRaz), 1, 40)
		&Boleto.pagadorEndereco	= SubStr(Trim(&CreCliCobLog), 1, 40)
		&Boleto.pagadorEnderecoNumero	= CreCliCobNro
		&Boleto.pagadorBairro	= CreCliCobBai
		&Boleto.pagadorCep	= Val(SubStr(RetornaSoNumeros.Udp(CreCliCobCep), 1, 8))
		&Boleto.pagadorCidade	= SubStr(Trim(&CreCliCobCidNom), 1, 25)
		&Boleto.pagadorUf	= CreCliCobUfeCod
		
		//BOLETO
		&Boleto.numeroDocumento	= PadL(Trim(Str(FilCod)), 2, '0') + PadL(Trim(Str(CreCod)), 8, '0')
		&Boleto.dtVencimento	= &DataVctVarchar
		&Boleto.dtDocumento	= &DataEmsVarChar
		&Boleto.valorNominal	= CreVlrDup
		
		//DESCONTOS
		Do Case
			Case &CbrDesDia	<> 0
				&CreDtaVct	= CreDtaVct.AddDays((&CbrQtdDiaDesc * -1))
				&dia	= day(&CreDtaVct)
				&mes	= month(&CreDtaVct)
				&Ano	= year(&CreDtaVct)
				&DataVctVarchar	= padL(str(&ano),4,'0') + '-' + padL(str(&mes),2,'0') + '-' + padL(str(&dia),2,'0')
				&DesCreVlrDup	= (CreVlrDup * (&CbrDesDia / 100))
				
				&Boleto.valorDesconto	= &DesCreVlrDup
				&Boleto.dtLimiteDesconto	= &DataVctVarchar
			Case &CbrDesAnt <> 0
				&CreDtaVct	= CreDtaVct - 1
				&dia	= day(&CreDtaVct)
				&mes	= month(&CreDtaVct)
				&Ano	= year(&CreDtaVct)
				&DataVctVarchar	= padL(str(&ano),4,'0') + '-' + padL(str(&mes),2,'0') + '-' + padL(str(&dia),2,'0')
				&DesCreVlrDup	= (CreVlrDup * (&CbrDesAnt / 100))
				
				&Boleto.valorDesconto2	= &DesCreVlrDup
				&Boleto.dtLimiteDesconto2	= &DataVctVarchar
		EndCase
		
		//JUROS
		&Juro_Dia	= Round((CreVlrDup * &JurTaxDia), 2)
		If &JurTaxDia > 0 And &Juro_Dia > 0
			&Boleto.cdTipoJuros	= 'VALOR_FIXO'
			&Boleto.valorJuros	= &Juro_Dia
		EndIf
		
		//MULTA
		If &CbrMltVlr > 0
			&Boleto.cdTipoMulta	= 'VALOR_FIXO'
			&Boleto.valorMulta	= &CbrMltVlr
		EndIf
		
		&CresolRegistroBoleto_Request.Add(&Boleto)
		&Preenchido	= 1
	Else
		&IsErro	= True
		&Mensagem	= 'Não foi possível gerar o Token de Acesso. Erro: ' + &Mensagem
	EndIf
	
	Exit
When None
	&IsErro	= True
	&Mensagem	= 'Impossível gerar Boleto para esta Duplicata!, a Mesma NÃO pode estar vencida, e tem que ser tipo RECEBER, e com opção boleto online no local de Cobrança!'
EndFor

If &Preenchido	= 1
	
	&HttpClient.AddHeader('Accept-Encoding', 'gzip, deflate, br')
	&HttpClient.AddHeader('Connection', 'keep-alive')
	&HttpClient.AddHeader(!"Content-type", 'application/json')
	&HttpClient.AddHeader(!"Authorization", 'Bearer ' + &CbrChaTra)
	&HttpClient.AddString(&CresolRegistroBoleto_Request.ToJson())
	PadraoUsuarioHora.Call('G', '#BOLETOAPICRESOL', &ContextPesCOd, &EmpCod, &CresolRegistroBoleto_Request.ToJson(), ServerDate(), ServerNow(), 'T')
	
	//HOMOLOGAÇÃO &HttpClient.Execute(HttpMethod.Post, 'https://api-dev.governarti.com.br/titulos')
	&HttpClient.Execute(HttpMethod.Post, 'https://cresolapi.governarti.com.br/titulos')
	If &HttpClient.ErrCode	= 0
		&ResponseCresolRegistroBoleto_Request.FromJson(&HttpClient.ToString())
		PadraoUsuarioHora.Call('G', '#BOLETOAPICRESOLRESPONSE', &ContextPesCOd, &EmpCod, &HttpClient.ToString(), ServerDate(), ServerNow(), 'T')
		Do 'AtualizaDados'
	Else
		&IsErro	= True
		&Mensagem	= Trim(Str(&HttpClient.StatusCode)) + ' - ' + Trim(&HttpClient.ErrDescription)
		PadraoUsuarioHora.Call('G', '#BOLETOAPICRESOLERRO', &ContextPesCOd, &EmpCod, &HttpClient.ToString(), ServerDate(), ServerNow(), 'T')
	EndIf

EndIf

Sub 'GetLocalCobranca'
	
	&ErroCobranca	= 0
	For Each Order EmpCod, CbrCod
		Where EmpCod	= &EmpCod
		Where CbrCod	= &CreCbrCod
		Where CrbRegAut	= Status_SimNao.Sim
		
		OAuth_Cresol.Call(&EmpCod, CbrCod, &ContextPesCod, &CbrChaTra, &Mensagem)
		If Not &Mensagem.IsEmpty()
			&ErroCobranca	= 1
			&IsErro	= True
		EndIf
		
		&CbrProAut	= CbrProAut
		&CbrProQtd	= CbrProQtd
		&CbrNegAut	= CbrNegAut
		&CbrNegQtd	= CbrNegQtd
		&CbrCarCod	= CbrCarCod
		&CbrDesDia	= CbrDesDia
		&CbrQtdDiaDesc	= CbrQtdDiaDesc
		&CbrDesAnt	= CbrDesAnt
		&CbrInsBol1	= CbrInsBol1
		&CbrMltVlr	= CbrMltVlr
		&CtaBanNosNro	= CtaBanNosNro
		&CbrTipBol	= CbrTipBol
		&CbrJurCod	= CbrJurCod
		&JurTaxDia	= 0
		Do 'Juros'
		
		Exit
	When None
		&IsErro	= True
		&ErroCobranca	= 1
		&Mensagem	= 'Local de Cobrança não encontrado.'
	EndFor
	
EndSub

Sub 'Juros'	
	
	For each Order EmpCod, JurCod, (JurAno), (JurMes)
		Where EmpCod = &EmpCod
		Where JurCod = &CbrJurCod
		
		&JurTax 	= JurTax
		&JurTaxDia 	= JurTaxDia
		
		Exit
	EndFor
	
EndSub

Sub 'AtualizaDados'
	
	For Each Order EmpCod, CreCod
		Where EmpCod	= &EmpCod	
		Where CreCod	= &CreCod
		
		CreDtaRet	= ServerDate()
		
		For &Response In &ResponseCresolRegistroBoleto_Request
			CreCodBar	= &Response.codigoBarras
			CreLinDig	= &Response.linhaDigitavel
			CreBloNro	= Trim(Str(&Response.nossoNumero))
			CreCodSol	= Trim(Str(&Response.id))
		EndFor
		
		Exit
	EndFor
	Commit
	
EndSub
]]></Source>
