      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[
&HojeData = Serverdate()
&Total = &ppJASPI_CFOPsdtEstruturaCFOP.Count
&Count = 0
&Percentual = 0
&ProgressIni = serverNow()
do 'Atualiza'

if &ppJASPI_CFOPsdtEstruturaCFOP.Count > 0
	For &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem in &ppJASPI_CFOPsdtEstruturaCFOP
		
		&cemCem += 1
		if &cemCem > 500
			&Count += 500
			If &Count > 0
				&Percentual = round((&Count / &Total) * 100, 0)
			EndIF
			If &Percentual >= 100
				&Percentual = 99
			EndIf
			do 'Atualiza'
			
			&cemCem = 1
		EndIF
		
		For Each Order CfoCod
			Where CfoCod = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoCod
			CfoNom = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoNom
			CfoDesCpl = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoDesCpl
			CfoDtaAlt = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoUltAlt
			CfoInvCod = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoInvCod
			CfoInd = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoInd
		When None
			New
				CfoCod = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoCod
				CfoNom = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoNom
				CfoDesCpl = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoDesCpl
				CfoDtaAlt = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoUltAlt
				CfoInvCod = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoInvCod
				CfoInd = &ppJASPI_CFOPsdtEstruturaCFOP_sdtEstruturaCFOPItem.CfoInd
			EndNew
		EndFor			
		commit
	EndFor
	
	For Each Order EmpCod
		EmpSyncCfop = &HojeData - 1
	EndFor
	commit
		
EndIF

&Percentual = 100
&ProgressFin = serverNow()
do 'Atualiza'


Sub 'Atualiza'
	for each Order ProgressId
		where ProgressId = &ProgressId
		ProgressValue = &Percentual
		ProgressLogXml = &ppJASPI_CFOPsdtEstruturaCFOP.ToXml()
		ProgressFin = &ProgressFin
		ProgressIni = &Progressini
	When none
		new
			ProgressId = &ProgressId
			ProgressValue = &Percentual
			ProgressLogXml = &ppJASPI_CFOPsdtEstruturaCFOP.ToXml()
			ProgressFin = &ProgressFin
			ProgressIni = &Progressini
		Endnew
	endfor
	
	commit
EndSub
]]></Source>
