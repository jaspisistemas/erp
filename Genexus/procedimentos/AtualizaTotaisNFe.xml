      <Part type="528d1c06-a9c2-420d-bd35-21dca83f12ff">
        <Source><![CDATA[


For Each Order EmpCod, FilCod, NfeCod, NfeItmCod 
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	Where NfeItmCod = &nfeItmCod or &nfeItmCod = 0
	
	if &nfeItmCod = 0
		&NfeVlrTotPro += NfeProVlrTot
		&NfeVlrTotBasIcms += NfeProBasIcms
		&NfeVlrTotIcms += NfeProVlrIcms
		&NfeVlrTotBasIcmsSt += NfeProBasIcmsSt
		&NfeVlrTotIcmsSt += NfeProVlrImcsSt
		&NfeVlrTotIpi += NfeProVlrIpi
		
		&NfeTotIbsBas += NfeIbsBas
		&NfeTotIbsUfVlr += NfeIbsUfVlr
		&NfeTotIbsMunVlr += NfeIbsMunVlr
		&NfeTotCbsVlr += NfeCbsVlr
		
		&NfeTotCbsVlrDif += NfeCbsVlrDif
		&NfeTotIbsUfVlrDif += NfeIbsUfVlrDif
		&NfeTotIbsMunVlrDif += NfeIbsMunVlrDif
		
	Else
		&NfeVlrTotPro 		= NfeVlrTotPro + NfeProVlrTot
		&NfeVlrTotBasIcms 	= NfeVlrTotBasIcms + NfeProBasIcms
		&NfeVlrTotIcms 		= NfeVlrTotIcms + NfeProVlrIcms
		&NfeVlrTotBasIcmsSt = NfeVlrTotBasIcmsSt + NfeProBasIcmsSt
		&NfeVlrTotIcmsSt 	= NfeVlrTotIcmsSt + NfeProVlrImcsSt
		&NfeTotIbsBas = NfeTotIbsBas + NfeIbsBas
		&NfeTotIbsUfVlr = NfeTotIbsUfVlr + NfeIbsUfVlr
		&NfeTotIbsMunVlr = NfeTotIbsMunVlr + NfeIbsMunVlr
		&NfeTotCbsVlr = NfeTotCbsVlr + NfeCbsVlr
		
		&NfeTotCbsVlrDif = NfeTotCbsVlrDif + NfeCbsVlrDif
		&NfeTotIbsUfVlrDif = NfeTotIbsUfVlrDif + NfeIbsUfVlrDif
		&NfeTotIbsMunVlrDif = NfeTotIbsMunVlrDif + NfeIbsMunVlrDif
		
		eXIT
	EndIF
EndFor


For Each Order EmpCod, FilCod, NfeCod
	Where EmpCod = &EmpCod
	Where FilCod = &FilCod
	Where NfeCod = &NfeCod
	
	NfeVlrTotPro  = &NfeVlrTotPro
	NfeVlrTotBasIcms = &NfeVlrTotBasIcms
	NfeVlrTotIcms = &NfeVlrTotIcms
	NfeVlrTotBasIcmsSt = &NfeVlrTotBasIcmsSt
	NfeVlrTotIcmsSt = &NfeVlrTotIcmsSt
	NfeVlrTotIpi = &NfeVlrTotIpi
	
	NfeTotIbsBas  = &NfeTotIbsBas 
	NfeTotIbsUfVlr = &NfeTotIbsUfVlr 
	NfeTotIbsMunVlr = &NfeTotIbsMunVlr 
	NfeTotCbsVlr = &NfeTotCbsVlr 
	
	NfeTotCbsVlrDif = &NfeTotCbsVlrDif
	NfeTotIbsUfVlrDif = &NfeTotIbsUfVlrDif
	NfeTotIbsMunVlrDif = &NfeTotIbsMunVlrDif
	
	//TOTAL NOTA
	NfeVlrTot = round((&NfeVlrTotPro + &NfeVlrTotIpi + &NfeVlrTotIcmsSt + NfeVlrTotPdg + NfeVlrTotSeg + NfeVlrTotOutDsp + NfeVlrTotFrt + NfeVlrTotImpII + NfeTotFPIcmsSt) - (NfeVlrTotDsc + TotNfeProVlrIcmsDes), 2)
	
	RetornaAliquotasNFPeFilial.Call(&EmpCod, &FilCod,0,0,0,0,&FilPerFun,&FilPerSenar)
	
	If NfeLctDesFun = status_simNao.Sim
		NfeTotFun = IIF(&FilPerFun>0,NfeVlrTot * &FilPerFun,0)
	Else
		NfeTotFun = 0 
	EndIf

	If NfeLctDesSen = status_simNao.Sim
		NfeTotSen = IIF(&FilPerSenar>0,NfeVlrTot * &FilPerSenar,0)
	Else
		NfeTotSen = 0 
	EndIf

EndFor


Commit
]]></Source>
